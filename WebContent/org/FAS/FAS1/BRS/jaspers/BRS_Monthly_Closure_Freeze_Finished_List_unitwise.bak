	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cmbAcc_UnitCode" isForPrompting="false" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT a.accounting_unit_id,
  ACCOUNTING_FOR_OFFICE_ID,
  CASHBOOK_YEAR,
  cashbook_month,
  CASHBOOK_YEAR||'/'||decode(cashbook_month,1,'January',2,'February',3,'March',4,
  'April',5,'May',6,'June',7,'July',8,'August',9,'September',10,'October',11,'November',12,'December')desc_month1,
  FREEZED_DATE,
  a.account_no,
  (SELECT AC_OPERATIONAL_MODE_ID
  FROM FAS_MST_BANK_BALANCE b
  WHERE b.ACCOUNTING_UNIT_ID=a.accounting_unit_id
  AND b.BANK_AC_NO          =a.account_no
  )AS type1,
  (SELECT office_name
  FROM com_mst_offices
  WHERE office_id=a.accounting_for_office_id
  )AS officename
FROM fas_brs_monthly_closure a
WHERE a.accounting_unit_id=$P{cmbAcc_UnitCode}
ORDER BY a.account_no,CASHBOOK_YEAR,cashbook_month]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="DESC_MONTH1" class="java.lang.String"/>
	<field name="FREEZED_DATE" class="java.sql.Timestamp"/>
	<field name="ACCOUNT_NO" class="java.lang.String"/>
	<field name="TYPE1" class="java.lang.String"/>
	<field name="OFFICENAME" class="java.lang.String"/>


