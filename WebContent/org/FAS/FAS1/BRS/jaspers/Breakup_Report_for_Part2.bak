	<variable name="total_amt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[($F{DOC_MONTH}.compareTo( $F{PASS_MONTH} )!=0) ||($F{DOC_YEAR}.compareTo($F{PASS_YEAR})!= 0) ? $F{DR_AMOUNT} : new BigDecimal("0.00")]]></variableExpression>
	</variable>
	<variable name="total_PassAmt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[($F{CR_AMOUNT}.compareTo(BigDecimal.ZERO) != 0) || ($F{DOC_TYPE}.equals( "NT" )) ? new BigDecimal("0.00") : $F{DR_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="total_ne" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT_NE}]]></variableExpression>
	</variable>
	<variable name="total_NT" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT_NT}]]></variableExpression>
	</variable>
	<variable name="tot_cramt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="tot_dramt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[($F{DOC_MONTH}.compareTo( $P{cbmonth} )<0) ||($F{DOC_YEAR}.compareTo($P{cbyear})<0) ? new BigDecimal("0.00") :$F{DR_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="Amount" class="java.math.BigDecimal" resetType="Report" incrementType="Column" calculation="Nothing">
		<variableExpression><![CDATA[($F{DOC_MONTH}.compareTo( $F{PASS_MONTH} )!=0) ||($F{DOC_YEAR}.compareTo($F{PASS_YEAR})!= 0) ? $F{DR_AMOUNT} :new BigDecimal("0.00")]]></variableExpression>
	</variable>
	<variable name="Pass_bk_totamt" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[($F{CR_AMOUNT}.compareTo(BigDecimal.ZERO) != 0) || ($F{DOC_TYPE}.equals( "NT" )) ? new BigDecimal("0.00") : $F{DR_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="DR_AMOUNT" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[($F{DOC_MONTH}.compareTo( $P{cbmonth} )<0) ||($F{DOC_YEAR}.compareTo($P{cbyear})<0) ? new BigDecimal("0.00") :$F{DR_AMOUNT}]]></variableExpression>
	</variable>

