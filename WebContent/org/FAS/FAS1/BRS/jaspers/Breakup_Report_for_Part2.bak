	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.math.BigDecimal"/>
	<parameter name="cbyear" isForPrompting="true" class="java.math.BigDecimal"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<parameter name="openingbalance" isForPrompting="true" class="java.math.BigDecimal"/>
	<parameter name="branch" isForPrompting="true" class="java.lang.String"/>
	<parameter name="bank" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT Rownum AS Slno,
  Passbook_Date,
  Doc_No,
  Doc_Type,
  Doc_Date,
  Amount,
  CR_AMOUNT,
  dr_amount,
  Amount_In_Passbook,
  Reason_For_Difference,
  Action_Taken,
  OFFICE_NAME,
  BANK_NAME,
  BRANCH_NAME,
  OB_PART2A,
  amount_NT,
  amount_ne,
  CHEQUE_DD_NO,
  EXTRACT (MONTH FROM PASSBOOK_DATE ) AS PASS_MONTH,
  Extract (YEAR FROM Passbook_Date ) AS Pass_Year,
  EXTRACT (MONTH FROM DOC_DATE ) AS DOC_MONTH,
  Extract (YEAR FROM DOC_DATE ) AS DOC_YEAR
FROM
  (SELECT *
  FROM
    (SELECT *
    FROM
      (SELECT Accounting_Unit_Id,
        Accounting_For_Office_Id,
        Cashbook_Year,
        Cashbook_Month,
        Account_No,
        Twad_Or_Non_Twad,
        PASSBOOK_DATE,
        DOC_NO,
        Doc_Type,
        Doc_Date,
        Cheque_Dd_No,
        CR_AMOUNT,
        dr_amount,
        AMOUNT            AS AMOUNT,
        Amount_In_Passbook AS Amount_In_Passbook,
        Reason_For_Difference,
        Action_Taken,
        Amount_Nt,
        Amount_Ne
      FROM
        (SELECT Accounting_Unit_Id,
          Accounting_For_Office_Id,
          Cashbook_Year,
          Cashbook_Month,
          Account_No,
          Twad_Or_Non_Twad,
          PASSBOOK_DATE,
          DOC_NO,
          doc_type,
          doc_date,
          CHEQUE_DD_NO,
          CR_AMOUNT,
          dr_amount,
          CASE
            WHEN TWAD_OR_NON_TWAD     ='T'
            AND (cr_amount -dr_amount)<0
            THEN           -(cr_amount -dr_amount)
            WHEN TWAD_OR_NON_TWAD      ='T'
            AND (cr_amount  -dr_amount)>=0
            THEN (cr_amount -dr_amount)
            WHEN TWAD_OR_NON_TWAD     ='T'
            AND (cr_amount -dr_amount)=NULL
            THEN 0
            WHEN TWAD_OR_NON_TWAD='NT'
            THEN 0
            ELSE 0
          END AS amount,
          CASE
            WHEN Twad_Or_Non_Twad='NT'
            THEN 0
            ELSE (DECODE(Amount_In_Passbook,NULL,0,Amount_In_Passbook))
          END AS Amount_In_Passbook,
          --decode(amount_in_passbook,null,0,amount_in_passbook) as amount_in_passbook,
          DECODE(REASON_FOR_DIFFERENCE,NULL,'-',REASON_FOR_DIFFERENCE) AS REASON_FOR_DIFFERENCE,
          DECODE(ACTION_TAKEN,NULL,'-',ACTION_TAKEN)                   AS ACTION_TAKEN,
          CASE
            WHEN TWAD_OR_NON_TWAD     ='NT'
            AND (cr_amount -dr_amount)<0
            THEN           -(cr_amount -dr_amount)
            WHEN TWAD_OR_NON_TWAD     ='NT'
            AND (cr_amount  -dr_amount)>0
            THEN (cr_amount -dr_amount)
            ELSE 0
          END AS amount_NT,
          CASE
            WHEN TWAD_OR_NON_TWAD='T'
            THEN 0
            ELSE 0
          END AS amount_ne
        FROM fas_brs_transaction
        WHERE ACCOUNTING_UNIT_ID               =$P{UnitId}
        AND ACCOUNTING_FOR_OFFICE_ID           =$P{OfficeId}
        AND Extract (MONTH FROM Passbook_Date )=$P{cbmonth}
        AND Extract (YEAR FROM Passbook_Date ) =$P{cbyear}
        AND ACCOUNT_NO                         =$P{accNo}
        AND DOC_TYPE NOT                      IN ('FR by Office','J','IBT')
          --AND DOC_TYPE not in ('FR by Office','J')
        UNION ALL
        SELECT Accounting_Unit_Id,
          Accounting_For_Office_Id,
          Cashbook_Year,
          Cashbook_Month,
          Account_No,
          Twad_Or_Non_Twad,
          PASSBOOK_DATE,
          DOC_NO,
          doc_type,
          doc_date,
          CHEQUE_DD_NO,
          CR_AMOUNT,
          dr_amount,
          CASE
            WHEN TWAD_OR_NON_TWAD='T'
            THEN 0
            ELSE 0
          END AS amount,
          CASE
            WHEN TWAD_OR_NON_TWAD='T'
            THEN 0
            ELSE 0
          END                                                          AS amount_in_passbook,
          DECODE(REASON_FOR_DIFFERENCE,NULL,'-',REASON_FOR_DIFFERENCE) AS REASON_FOR_DIFFERENCE,
          DECODE(ACTION_TAKEN,NULL,'-',ACTION_TAKEN)                   AS ACTION_TAKEN,
          CASE
            WHEN TWAD_OR_NON_TWAD='NT'
            THEN 0
          END AS amount_NT,
          CASE
            WHEN (cr_amount -dr_amount)<0
            THEN            -(cr_amount -dr_amount)
            ELSE (cr_amount -dr_amount)
          END AS amount_ne
        FROM FAS_BRS_TRANSACTION_NOENTRY
        WHERE ACCOUNTING_UNIT_ID               =$P{UnitId}
        AND ACCOUNTING_FOR_OFFICE_ID           =$P{OfficeId}
        AND Extract (MONTH FROM Passbook_Date )=$P{cbmonth}
        AND Extract (YEAR FROM Passbook_Date ) =$P{cbyear}
        AND ACCOUNT_NO                         =$P{accNo}
        AND DOC_TYPE!                          ='J'
       
        ))a
    LEFT OUTER JOIN
      (SELECT OFFICE_ID,OFFICE_NAME FROM COM_MST_OFFICES
      )aa
    ON a.ACCOUNTING_FOR_OFFICE_ID = aa.OFFICE_ID
    )xx
  LEFT OUTER JOIN
    (SELECT ACCOUNTING_UNIT_ID AS acc_un_id_ob,
      ACCOUNTING_FOR_OFFICE_ID AS acc_off_id_ob,
      CASHBOOK_YEAR            AS cby_ob,
      CASHBOOK_MONTH           AS cbm_ob,
      ACCOUNT_NO               AS accno_ob,
      OB_PART2A
    FROM FAS_BRS_OB
    WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
    AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
    AND CASHBOOK_YEAR           =$P{cbyear}
    AND CASHBOOK_MONTH          =$P{cbmonth}
    AND ACCOUNT_NO              =$P{accNo}
    )ob
  ON xx.accounting_unit_id        = ob.acc_un_id_ob
  AND xx.accounting_for_office_id = ob.acc_off_id_ob
  AND xx.cashbook_year            = ob.cby_ob
  AND xx.cashbook_month           = ob.cbm_ob
  AND xx.account_no               = ob.accno_ob
  )x
LEFT OUTER JOIN
  (SELECT ACCOUNTING_UNIT_ID AS acc_unit_id,
    ACCOUNTING_FOR_OFFICE_ID AS acc_off_id,
    CASHBOOK_YEAR            AS csh_bk_yr,
    CASHBOOK_MONTH           AS csh_bk_mnth,
    ACCOUNT_NO               AS acc_no,
    BANK_NAME,
    BRANCH_NAME
  FROM
    (SELECT ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      ACCOUNT_NO,
      BANK_ID,
      BRANCH_ID
    FROM FAS_BRS_MASTER
    WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
    AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
    AND CASHBOOK_YEAR           =$P{cbyear}
    AND CASHBOOK_MONTH          =$P{cbmonth}
    AND ACCOUNT_NO              =$P{accNo}
    )b
  LEFT OUTER JOIN
    (SELECT BRANCH_ID AS brnch_id,
      BANK_ID         AS bnk_id,
      BRANCH_NAME
    FROM FAS_MST_BANK_BRANCHES
    )c
  ON b.BANK_ID    = c.bnk_id
  AND b.BRANCH_ID = c.brnch_id
  LEFT OUTER JOIN
    (SELECT BANK_ID AS bnk_id1,BANK_NAME FROM FAS_MST_BANKS
    )d
  ON b.BANK_ID                 = d.bnk_id1
  )y ON x.ACCOUNTING_UNIT_ID   = y.acc_unit_id
AND x.ACCOUNTING_FOR_OFFICE_ID = y.acc_off_id
AND X.CASHBOOK_YEAR            = Y.CSH_BK_YR
AND x.ACCOUNT_NO               = y.acc_no
ORDER BY PASSBOOK_DATE,
  CHEQUE_DD_NO]]></queryString>

