<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Breakup_Report_for_Part1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="849"
		 pageHeight="842"
		 columnWidth="789"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="cbmonth_name" isForPrompting="true" class="java.lang.String"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<parameter name="openingbalance" isForPrompting="true" class="java.math.BigDecimal"/>
	<queryString><![CDATA[SELECT x.*,
  y.unitname,
  y. BANK_NAME,
  y.BRANCH_NAME,
  z.OPENING_BALANCE
FROM
  (SELECT *
  FROM
    (SELECT accounting_unit_id,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      account_no,
      entry_date,
      cheque_dd_no,
      passbook_date,
      doc_type,
      doc_date,
      SUM(amount_remitted)AS amount_remitted,
      SUM(ack_by_bank)    AS ack_by_bank,
      SUM(no_entry)       AS no_entry,
      SUM(not_remittted)  AS not_remittted,
      follow_up_action_required,
      REASON_FOR_DIFFERENCE,
      ACTION_TAKEN,
      TWAD_OR_NON_TWAD,
      challan_no
    FROM
      (SELECT b.accounting_unit_id ,
        b.accounting_for_office_id ,
        b.cashbook_year ,
        b.cashbook_month ,
        b.account_no,
        b.entry_date,
        b.cheque_dd_no,
        b.passbook_date,
        b.doc_type,
        b.doc_date,
        b.cr_amount          AS amount_remitted,
        b.AMOUNT_IN_PASSBOOK AS ack_by_bank,
        0                    AS no_entry,
        CASE
          WHEN b.TWAD_OR_NON_TWAD='NT'
          THEN (b.cr_amount+b.dr_amount)
          ELSE 0
        END AS not_remittted,
        b.follow_up_action_required,
        b.REASON_FOR_DIFFERENCE,
        b.ACTION_TAKEN,
        b.TWAD_OR_NON_TWAD,
        m.challan_no,
        m.challan_date
      FROM fas_brs_transaction b
      INNER JOIN fas_receipt_master m
      ON b.accounting_unit_id=m.accounting_unit_id
      AND b.cashbook_year    =m.CASHBOOK_YEAR
      AND b.cashbook_month   =m.CASHBOOK_MONTH
      AND b.DOC_NO           =m.RECEIPT_NO
      AND b.DOC_DATE         =m.RECEIPT_DATE
      AND b.doc_type         =m.CREATED_BY_MODULE
      AND b.account_no       =m.account_no
      AND m.receipt_status   ='L'
      
      AND b.accounting_unit_id                 =$P{UnitId}
      AND b.accounting_for_office_id           =$P{OfficeId}
      AND Extract (MONTH FROM b.Passbook_Date )=$P{cbmonth}
      AND Extract (YEAR FROM b.Passbook_Date ) =$P{cbyear}
      AND b.account_no                         =$P{accNo}
      AND b.DOC_TYPE!                          ='FT from Office'
      AND b.doc_type                           ='BR'
      )
    GROUP BY accounting_unit_id,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      account_no,
      entry_date,
      cheque_dd_no,
      passbook_date,
      doc_type,
      doc_date,
      follow_up_action_required,
      REASON_FOR_DIFFERENCE,
      ACTION_TAKEN,
      TWAD_OR_NON_TWAD,
      challan_no--,challan_date
    UNION ALL
    SELECT accounting_unit_id,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      account_no,
      entry_date,
      cheque_dd_no,
      passbook_date,
      doc_type,
      doc_date,
      SUM(amount_remitted)amount_remitted,
      SUM(ack_by_bank)ack_by_bank,
      SUM(no_entry)no_entry,
      SUM(not_remittted)not_remittted,
      follow_up_action_required,
      REASON_FOR_DIFFERENCE,
      ACTION_TAKEN,
      TWAD_OR_NON_TWAD,
      challan_no
      -- challan_date
    FROM
      (SELECT b.accounting_unit_id,
        b.accounting_for_office_id,
        b.cashbook_year,
        b.cashbook_month,
        b.account_no,
        b.entry_date,
        b.cheque_dd_no,
        b.passbook_date,
        b.doc_type,
        b.doc_date,
        b.cr_amount          AS amount_remitted,
        b.AMOUNT_IN_PASSBOOK AS ack_by_bank,
        0                    AS no_entry,
        CASE
          WHEN b.TWAD_OR_NON_TWAD='NT'
          THEN (b.cr_amount+b.dr_amount)
          ELSE 0
        END AS not_remittted,
        b.follow_up_action_required,
        b.REASON_FOR_DIFFERENCE,
        b.ACTION_TAKEN,
        b.TWAD_OR_NON_TWAD,
        m.challan_no
        --  m.challan_date
      FROM fas_brs_transaction b,
        fas_receipt_master m
      WHERE b.accounting_unit_id               =m.accounting_unit_id
      AND Extract(YEAR FROM b.Passbook_Date )  =m.CASHBOOK_YEAR
      AND Extract(MONTH FROM b.Passbook_Date ) =m.CASHBOOK_MONTH
      AND b.DOC_NO                             =m.RECEIPT_NO
      AND b.DOC_DATE                           =m.RECEIPT_DATE
      AND b.doc_type                           =m.CREATED_BY_MODULE
      AND b.account_no                         =m.account_no
      AND b.cr_amount                          =m.total_amount
      AND m.receipt_status                     ='L'
      AND b.accounting_unit_id                 =$P{UnitId}
      AND b.accounting_for_office_id           =$P{OfficeId}
      AND Extract (MONTH FROM b.Passbook_Date )=$P{cbmonth}
      AND Extract (YEAR FROM b.Passbook_Date ) =$P{cbyear}
      AND b.account_no                         =$P{accNo}
      AND b.DOC_TYPE!                          ='FT from Office'
      AND b.doc_type                           ='CR'
      )
    GROUP BY accounting_unit_id,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      account_no,
      entry_date,
      cheque_dd_no,
      passbook_date,
      doc_type,
      doc_date,
      follow_up_action_required,
      REASON_FOR_DIFFERENCE,
      ACTION_TAKEN,
      TWAD_OR_NON_TWAD,
      challan_no
      -- challan_date
    )
  UNION ALL
    (SELECT accounting_unit_id,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      account_no,
      entry_date,
      cheque_dd_no,
      passbook_date,
      doc_type,
      doc_date,
      SUM(amount_remitted)amount_remitted,
      SUM(ack_by_bank)ack_by_bank,
      SUM(no_entry)no_entry,
      SUM(not_remittted)not_remittted,
      follow_up_action_required,
      REASON_FOR_DIFFERENCE,
      ACTION_TAKEN,
      TWAD_OR_NON_TWAD,
      challan_no
      --challan_date
    FROM
      (SELECT accounting_unit_id,
        accounting_for_office_id,
        cashbook_year,
        cashbook_month,
        account_no,
        entry_date,
        cheque_dd_no,
        passbook_date,
        doc_type,
        doc_date,
        cr_amount                                                  AS amount_remitted,
        0                                                          AS ack_by_bank,
        DECODE((cr_amount+dr_amount),NULL,0,(cr_amount+dr_amount)) AS no_entry,
        0                                                          AS not_remittted,
        follow_up_action_required,
        REASON_FOR_DIFFERENCE,
        ACTION_TAKEN,
        TWAD_OR_NON_TWAD,
        VOUCHER_OR_CHALLAN_NO AS challan_no
        --  '' as challan_date
      FROM fas_brs_transaction_noentry
      Where Accounting_Unit_Id     =$P{UnitId}
      And Accounting_For_Office_Id = $P{OfficeId}

    AND account_no               =$P{accNo}


  AND ((cashbook_year  <$P{cbyear}
            AND cashbook_month  <=12)
            Or (Cashbook_Year    =$P{cbyear}
            And Cashbook_Month  <=$P{cbmonth}))
      AND DOC_TYPE!                ='FT from Office'
      )
    GROUP BY accounting_unit_id,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      account_no,
      entry_date,
      cheque_dd_no,
      passbook_date,
      doc_type,
      doc_date,
      follow_up_action_required,
      REASON_FOR_DIFFERENCE,
      ACTION_TAKEN,
      TWAD_OR_NON_TWAD,
      challan_no
    )
  )x
LEFT OUTER JOIN
  (SELECT acc_unit_id,
    (SELECT u.accounting_unit_name
    FROM fas_mst_acct_units u
    WHERE u.accounting_unit_id=acc_unit_id
    )                        AS unitname,
    ACCOUNTING_FOR_OFFICE_ID AS acc_off_id,
    CASHBOOK_YEAR            AS csh_bk_yr,
    CASHBOOK_MONTH           AS csh_bk_mnth,
    ACCOUNT_NO               AS acc_no,
    BANK_NAME,
    BRANCH_NAME
  FROM
    (SELECT ACCOUNTING_UNIT_ID AS acc_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      ACCOUNT_NO,
      BANK_ID,
      BRANCH_ID
    FROM FAS_BRS_MASTER
    WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
    AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
    AND CASHBOOK_YEAR           =$P{cbyear}
    AND CASHBOOK_MONTH          =$P{cbmonth}
    AND ACCOUNT_NO              =$P{accNo}
    )b
  LEFT OUTER JOIN
    (SELECT BRANCH_ID AS brnch_id,
      BANK_ID         AS bnk_id,
      BRANCH_NAME
    FROM FAS_MST_BANK_BRANCHES
    )c
  ON b.BANK_ID    = c.bnk_id
  AND b.BRANCH_ID = c.brnch_id
  LEFT OUTER JOIN
    (SELECT BANK_ID AS bnk_id1,BANK_NAME FROM FAS_MST_BANKS
    )d
  ON b.BANK_ID                 = d.bnk_id1
  )y ON x.ACCOUNTING_UNIT_ID   = y.acc_unit_id
AND x.ACCOUNTING_FOR_OFFICE_ID = y.acc_off_id
AND x.ACCOUNT_NO               = y.acc_no
LEFT OUTER JOIN
  (SELECT ACCOUNTING_UNIT_ID                   AS acc_unit_id1,
    ACCOUNTING_FOR_OFFICE_ID                   AS acc_off_id1,
    CASHBOOK_YEAR                              AS csh_bk_yr1,
    CASHBOOK_MONTH                             AS csh_bk_mnth1,
    ACCOUNT_NO                                 AS acc_no1,
    DECODE(SUM(OB_PART1),NULL,0,SUM(OB_PART1)) AS OPENING_BALANCE
  FROM FAS_BRS_OB
  WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
  AND CASHBOOK_YEAR           =$P{cbyear}
  AND CASHBOOK_MONTH          =$P{cbmonth}
  AND ACCOUNT_NO              =$P{accNo}
  GROUP BY ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    ACCOUNT_NO
  )z
ON x.ACCOUNTING_UNIT_ID        = z.acc_unit_id1
AND x.ACCOUNTING_FOR_OFFICE_ID = z.acc_off_id1
AND x.cashbook_year            = z.csh_bk_yr1
AND x.cashbook_month           = z.csh_bk_mnth1
AND x.account_no               = z.acc_no1
ORDER BY PASSBOOK_DATE,
  doc_type,
  doc_date]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_NO" class="java.math.BigDecimal"/>
	<field name="ENTRY_DATE" class="java.sql.Timestamp"/>
	<field name="CHEQUE_DD_NO" class="java.math.BigDecimal"/>
	<field name="PASSBOOK_DATE" class="java.sql.Timestamp"/>
	<field name="DOC_TYPE" class="java.lang.String"/>
	<field name="DOC_DATE" class="java.sql.Timestamp"/>
	<field name="AMOUNT_REMITTED" class="java.math.BigDecimal"/>
	<field name="ACK_BY_BANK" class="java.math.BigDecimal"/>
	<field name="NO_ENTRY" class="java.math.BigDecimal"/>
	<field name="NOT_REMITTTED" class="java.math.BigDecimal"/>
	<field name="FOLLOW_UP_ACTION_REQUIRED" class="java.lang.String"/>
	<field name="REASON_FOR_DIFFERENCE" class="java.lang.String"/>
	<field name="ACTION_TAKEN" class="java.lang.String"/>
	<field name="TWAD_OR_NON_TWAD" class="java.lang.String"/>
	<field name="CHALLAN_NO" class="java.math.BigDecimal"/>
	<field name="UNITNAME" class="java.lang.String"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="BRANCH_NAME" class="java.lang.String"/>
	<field name="OPENING_BALANCE" class="java.math.BigDecimal"/>

	<variable name="total_amtRem" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT_REMITTED}]]></variableExpression>
	</variable>
	<variable name="total_PassAmt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{ACK_BY_BANK}]]></variableExpression>
	</variable>
	<variable name="total_cr" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{NO_ENTRY}]]></variableExpression>
	</variable>
	<variable name="total_NT" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{NOT_REMITTTED}]]></variableExpression>
	</variable>

