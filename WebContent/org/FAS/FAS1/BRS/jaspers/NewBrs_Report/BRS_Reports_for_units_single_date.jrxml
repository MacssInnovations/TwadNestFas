	<parameter name="trnType" isForPrompting="true" class="java.lang.String"/>
	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fromDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="toDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cmbBankAccNo" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="BankName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="acType" isForPrompting="true" class="java.lang.String"/>
	<parameter name="z_BRANCH_NAME" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT B.Accounting_Unit_Id,
  (SELECT U.Accounting_Unit_Name
  FROM Fas_Mst_Acct_Units U
  WHERE U.Accounting_Unit_Id=b.Accounting_Unit_Id
  )AS Unitname,
  Passbook_Date,
  b.Transaction_Type,
(SELECT t.TRANS_DESC from FAS_BRS_TRANSACTION_TYPE t where t.TRANS_CODE=b.Transaction_Type)as trans_desc,
  Account_No,
  Cr_Amount,
  Dr_Amount
From Fas_Brs_Transaction B
Where B.Accounting_Unit_Id=$P{UnitId}
AND b.Account_No            =$P{cmbBankAccNo}
And B.Passbook_Date Between $P{fromDate} And $P{toDate}
and B.TRANSACTION_TYPE=$P{trnType}
and b.TWAD_OR_NON_TWAD='NT'
order by Account_No,Transaction_Type,Passbook_Date]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="UNITNAME" class="java.lang.String"/>
	<field name="PASSBOOK_DATE" class="java.sql.Timestamp"/>
	<field name="TRANSACTION_TYPE" class="java.lang.String"/>
	<field name="TRANS_DESC" class="java.lang.String"/>
	<field name="ACCOUNT_NO" class="java.math.BigDecimal"/>
	<field name="CR_AMOUNT" class="java.lang.Double"/>
	<field name="DR_AMOUNT" class="java.lang.Double"/>

