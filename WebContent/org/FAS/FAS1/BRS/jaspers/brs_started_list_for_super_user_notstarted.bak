					<reportElement
						x="3"
						y="0"
						width="362"
						height="24"
						key="textField-1"/>
					<box></box>
					<textElement>
						<font pdfFontName="Helvetica-Bold" size="10" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{ACCOUNTING_UNIT_ID}+"-"+$F{ACCOUNTING_UNIT_NAME}]]></textFieldExpression>
				</textField>
			</band>
			</groupHeader>
			<groupFooter>
