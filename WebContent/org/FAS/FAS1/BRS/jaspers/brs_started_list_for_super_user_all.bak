	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[SELECT accounting_unit_id,
  accounting_unit_name,
  bank_ac_no,
  ac_operational_mode_id,
  case when online_status='Started' and monthly_closure_status='Not-Freezed'
   then DECODE(start_mn_yr,'/','',start_mn_yr)
    when online_status='Started' and monthly_closure_status='Freezed'
    then DECODE(desc_month1,'/','',desc_month1)
     when online_status='Started' and monthly_closure_status='Nil-BRS-Freeze'
    then DECODE(desc_month1,'/','',desc_month1)
 end as desc_month_one,
  online_status,
  monthly_closure_status,
  nil_brs_freeze,
  freezed_date,
  cashbook_year,
  cashbook_month
FROM
  (SELECT a.accounting_unit_id,
    a.accounting_unit_name,
    b.bank_ac_no,
    b.ac_operational_mode_id,
    DECODE(c.account_no,NULL,'Not-Started','Started')online_status,
    c.CASHBOOK_YEAR
    ||'/'
    ||DECODE(c.cashbook_month,1,'January',2,'February',3,'March',4, 'April',5,'May',6,'June',7,'July',8,'August',9,'September',10,'October',11,'November',12,'December')start_mn_yr,
    
    
    d.cashbook_year,
    d.cashbook_month,
    d.CASHBOOK_YEAR
    ||'/'
    ||DECODE(d.cashbook_month,1,'January',2,'February',3,'March',4, 'April',5,'May',6,'June',7,'July',8,'August',9,'September',10,'October',11,'November',12,'December')desc_month1,
    DECODE(d.status,'Y','Freezed',DECODE(d.nil_brs_freeze,'Y','Nil-BRS-Freeze','Not-Freezed'))monthly_closure_status,
    d.freezed_date,
    d.nil_brs_freeze
  FROM fas_mst_acct_units a
  INNER JOIN FAS_MST_BANK_BALANCE b
  ON (a.accounting_unit_id=b.accounting_unit_id)
  LEFT OUTER JOIN brs_start_month_and_year c
  ON (a.accounting_unit_id=c.accounting_unit_id
  AND b.bank_ac_no        =c.account_no)
  LEFT OUTER JOIN fas_brs_monthly_closure d
  ON (c.accounting_unit_id=d.accounting_unit_id
  AND b.bank_ac_no        =d.account_no)
  )
ORDER BY accounting_unit_id,
  bank_ac_no,
  cashbook_year,
  cashbook_month]]></queryString>

