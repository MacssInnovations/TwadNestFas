<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="BRS_Report_1_another_opt"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="cbmonth_name" isForPrompting="false" class="java.lang.String"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<parameter name="UnitName" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT rownum AS rowno1,
  OFFICE_NAME,
  OB_PART1,
  cr,cr_final,jrnl_dr,jrnl_cr,
  total1,
  dr,
  total2,
  amt_t2_A,
  amt_2T_clos_bal,
  BANK_NAME,
  BRANCH_NAME,
  t2_sl_no,
  DECODE(amt_2t,NULL,0,amt_2t)AS amt_2t,
  trans_desc,
  total_t2
FROM
  (SELECT rownum AS rowno1,
    OFFICE_NAME,
    OB_PART1,
    cr,cr_final,jrnl_dr,jrnl_cr,
    total1,
    dr,
    total2,
    amt_t2_A,
    amt_2T_clos_bal,
    BANK_NAME,
    BRANCH_NAME,
    t2_sl_no,
    amt_2t,
    trans_desc,
    (DECODE(total,NULL,0,total)+amt_t2_A+amt_2T_clos_bal) AS total_t2
  FROM
    (SELECT OFFICE_NAME,
      acc_u_id_T,
      acc_off_id_T,
      csh_bk_yr_T,
      csh_bk_mnth_T,
      acc_no_T,
      OB_PART1,
      cr,cr_final,jrnl_dr,jrnl_cr,
      total1,
      dr,
      total2,
      amt_t2_A,
      amt_2T_clos_bal,
      BANK_NAME,
      BRANCH_NAME
    FROM
      (SELECT rownum AS rowno1,
        OFFICE_NAME,
        acc_u_id_T,
        acc_off_id_T,
        csh_bk_yr_T,
        csh_bk_mnth_T,
        acc_no_T,
        DECODE(OB_PART1,NULL,0,OB_PART1) AS OB_PART1,
        DECODE(cr,NULL,0,cr)             AS cr,cr_final,jrnl_dr,jrnl_cr,
        DECODE(total1,NULL,0,total1)     AS total1,
        DECODE(dr,NULL,0,dr)             AS dr,
        DECODE(total2,NULL,0,total2)     AS total2
      FROM
        (SELECT OFFICE_NAME,
          acc_u_id_T,
          acc_off_id_T,
          csh_bk_yr_T,
          csh_bk_mnth_T,
          acc_no_T,
          OB_PART1,
          cr,cr_final,jrnl_dr,jrnl_cr,
          OB_PART1+cr AS total1,
          dr,
          ((OB_PART1+cr)-dr) AS total2
        FROM
          (SELECT acc_u_id,
            acc_off_id,
            csh_bk_yr,
            csh_bk_mnth,
            acc_no,
            OB_PART1,
            OFFICE_NAME
          FROM
            (SELECT ACCOUNTING_UNIT_ID AS acc_u_id,
              ACCOUNTING_FOR_OFFICE_ID AS acc_off_id,
              CASHBOOK_YEAR            AS csh_bk_yr,
              CASHBOOK_MONTH           AS csh_bk_mnth,
              ACCOUNT_NO               AS acc_no,
              OB_PART1
            FROM FAS_BRS_OB
            WHERE accounting_unit_id    = $P{UnitId}
            AND accounting_for_office_id=$P{OfficeId}
            AND cashbook_month          = $P{cbmonth}
            AND cashbook_year           =$P{cbyear}
            AND ACCOUNT_NO              = $P{accNo}
            AND ob_type                 ='T'
            )AUID1
          LEFT OUTER JOIN
            (SELECT OFFICE_ID,OFFICE_NAME FROM COM_MST_OFFICES
            )AUID2
          ON AUID1.acc_off_id = AUID2.OFFICE_ID
          )X
        LEFT OUTER JOIN
          (SELECT acc_u_id_T,
            acc_off_id_T,
            csh_bk_yr_T,
            csh_bk_mnth_T,
            acc_no_T,
            cr_T1 AS cr,
            dr_T1 AS dr,cr_final,jrnl_dr,jrnl_cr
          FROM
            (
            SELECT a.acc_u_id_T,
              a.acc_off_id_T,
              a.csh_bk_yr_T,
              a.csh_bk_mnth_T,
              a.acc_no_T,
              decode(e.jrnl_cr,null,0,e.jrnl_cr)as jrnl_cr,
              (DECODE(a.cramt,NULL,0,a.cramt)      +DECODE(c.cr_notrn,NULL,0,cr_notrn))                                                    AS cr_final,
              (DECODE(b.jour_amt,NULL,0,b.jour_amt)+DECODE(d.jrnl_notrn,NULL,0,d.jrnl_notrn))                                              AS jrnl_dr,
              (DECODE(a.cramt,NULL,0,a.cramt)+DECODE(b.jour_amt,NULL,0,b.jour_amt)+DECODE(c.cr_notrn,NULL,0,cr_notrn)+DECODE(d.jrnl_notrn,NULL,0,d.jrnl_notrn)+decode(e.jrnl_cr,null,0,e.jrnl_cr))AS cr_T1
              
            FROM
              (SELECT ACCOUNTING_UNIT_ID AS acc_u_id_T,
                ACCOUNTING_FOR_OFFICE_ID AS acc_off_id_T,
                CASHBOOK_YEAR            AS csh_bk_yr_T,
                CASHBOOK_MONTH           AS csh_bk_mnth_T,
                ACCOUNT_NO               AS acc_no_T,
                SUM(CR_AMOUNT)           AS cramt
              FROM FAS_BRS_TRANSACTION
              WHERE accounting_unit_id    = $P{UnitId}
              AND accounting_for_office_id=$P{OfficeId}
              AND cashbook_month          = $P{cbmonth}
              AND cashbook_year           =$P{cbyear}
              AND ACCOUNT_NO              = $P{accNo}
	      and TWAD_OR_NON_TWAD!='NT'
              AND doc_type                !='J'
              GROUP BY ACCOUNTING_UNIT_ID,
                ACCOUNTING_FOR_OFFICE_ID,
                CASHBOOK_YEAR,
                CASHBOOK_MONTH,
                ACCOUNT_NO
              )a
            FULL OUTER JOIN
              (SELECT ACCOUNTING_UNIT_ID AS acc_u_id_NT,
                ACCOUNTING_FOR_OFFICE_ID AS acc_off_id_NT,
                CASHBOOK_YEAR            AS csh_bk_yr_NT,
                CASHBOOK_MONTH           AS csh_bk_mnth_NT,
                ACCOUNT_NO               AS acc_no_NT,
                SUM(DR_AMOUNT)           AS jour_amt
              FROM FAS_BRS_TRANSACTION
              WHERE accounting_unit_id    = $P{UnitId}
              AND accounting_for_office_id=$P{OfficeId}
              AND cashbook_month          =$P{cbmonth}
              AND cashbook_year           =$P{cbyear}
              AND ACCOUNT_NO              = $P{accNo}
              AND doc_type                ='J'
              GROUP BY ACCOUNTING_UNIT_ID,
                ACCOUNTING_FOR_OFFICE_ID,
                CASHBOOK_YEAR,
                Cashbook_Month,
                ACCOUNT_NO
              )b
            ON a.acc_u_id_T    =b.acc_u_id_NT
            AND a.acc_off_id_T =b.acc_off_id_NT
            AND a.csh_bk_yr_T  =b.csh_bk_yr_NT
            AND a.csh_bk_mnth_T=b.csh_bk_mnth_NT
            AND a.acc_no_T     =b.acc_no_NT
            FULL OUTER JOIN
              (SELECT ACCOUNTING_UNIT_ID                     AS acc_u_id_T,
                ACCOUNTING_FOR_OFFICE_ID                     AS acc_off_id_T,
                CASHBOOK_YEAR                                AS csh_bk_yr_T,
                CASHBOOK_MONTH                               AS csh_bk_mnth_T,
                ACCOUNT_NO                                   AS acc_no_T,
                DECODE(SUM(CR_AMOUNT),NULL,0,SUM(CR_AMOUNT)) AS cr_notrn
              FROM FAS_BRS_TRANSACTION_NOENTRY
              WHERE accounting_unit_id    = $P{UnitId}
              AND accounting_for_office_id=$P{OfficeId}
              AND cashbook_month          = $P{cbmonth}
              AND cashbook_year           =$P{cbyear}
              AND ACCOUNT_NO              = $P{accNo}
               AND doc_type                !='J'
              GROUP BY ACCOUNTING_UNIT_ID,
                ACCOUNTING_FOR_OFFICE_ID,
                CASHBOOK_YEAR,
                CASHBOOK_MONTH,
                ACCOUNT_NO
              )c
            ON a.acc_u_id_T    =c.acc_u_id_T
            AND a.acc_off_id_T =c.acc_off_id_T
            AND a.csh_bk_yr_T  =c.csh_bk_yr_T
            AND a.csh_bk_mnth_T=c.csh_bk_mnth_T
            AND a.acc_no_T     =c.acc_no_T
            FULL OUTER JOIN
              (SELECT ACCOUNTING_UNIT_ID AS acc_u_id_NT,
                ACCOUNTING_FOR_OFFICE_ID AS acc_off_id_NT,
                CASHBOOK_YEAR            AS csh_bk_yr_NT,
                CASHBOOK_MONTH           AS csh_bk_mnth_NT,
                ACCOUNT_NO               AS acc_no_NT,
                SUM(DR_AMOUNT)           AS jrnl_notrn
              FROM FAS_BRS_TRANSACTION_NOENTRY
              WHERE accounting_unit_id    = $P{UnitId}
              AND accounting_for_office_id=$P{OfficeId}
              AND cashbook_month          =$P{cbmonth}
              AND cashbook_year           =$P{cbyear}
              AND ACCOUNT_NO              = $P{accNo}
              AND doc_type                ='J'
              GROUP BY ACCOUNTING_UNIT_ID,
                ACCOUNTING_FOR_OFFICE_ID,
                CASHBOOK_YEAR,
                Cashbook_Month,
                ACCOUNT_NO
              )d
            ON a.acc_u_id_T    =d.acc_u_id_NT
            AND a.acc_off_id_T =d.acc_off_id_NT
            AND a.csh_bk_yr_T  =d.csh_bk_yr_NT
            AND a.csh_bk_mnth_T=d.csh_bk_mnth_NT
            AND a.acc_no_T     =d.acc_no_NT
            full outer join
            (select acc_u_id_T,acc_off_id_T,csh_bk_yr_T,csh_bk_mnth_T,acc_no_T,sum(cramt)as jrnl_cr
from
(SELECT ACCOUNTING_UNIT_ID AS acc_u_id_T,
                ACCOUNTING_FOR_OFFICE_ID AS acc_off_id_T,
                CASHBOOK_YEAR            AS csh_bk_yr_T,
                CASHBOOK_MONTH           AS csh_bk_mnth_T,
                ACCOUNT_NO               AS acc_no_T,
                SUM(CR_AMOUNT)           AS cramt
              FROM FAS_BRS_TRANSACTION
              WHERE accounting_unit_id    = $P{UnitId}
              AND accounting_for_office_id=$P{OfficeId}
              AND cashbook_month          = $P{cbmonth}
              AND cashbook_year           =$P{cbyear}
              AND ACCOUNT_NO              = $P{accNo}
              and doc_type='J'
              GROUP BY ACCOUNTING_UNIT_ID,
                ACCOUNTING_FOR_OFFICE_ID,
                CASHBOOK_YEAR,
                CASHBOOK_MONTH,
                ACCOUNT_NO
              union all
                SELECT ACCOUNTING_UNIT_ID                     AS acc_u_id_T,
                ACCOUNTING_FOR_OFFICE_ID                     AS acc_off_id_T,
                CASHBOOK_YEAR                                AS csh_bk_yr_T,
                CASHBOOK_MONTH                               AS csh_bk_mnth_T,
                ACCOUNT_NO                                   AS acc_no_T,
                DECODE(SUM(CR_AMOUNT),NULL,0,SUM(CR_AMOUNT)) AS cr_notrn
              FROM FAS_BRS_TRANSACTION_NOENTRY
              WHERE accounting_unit_id    = $P{UnitId}
              AND accounting_for_office_id=$P{OfficeId}
              AND cashbook_month          = $P{cbmonth}
              AND cashbook_year           =$P{cbyear}
              AND ACCOUNT_NO              = $P{accNo}
               and doc_type='J'
              GROUP BY ACCOUNTING_UNIT_ID,
                ACCOUNTING_FOR_OFFICE_ID,
                CASHBOOK_YEAR,
                CASHBOOK_MONTH,
                ACCOUNT_NO)
                group by acc_u_id_T,acc_off_id_T,csh_bk_yr_T,csh_bk_mnth_T,acc_no_T)e
                   ON a.acc_u_id_T    =e.acc_u_id_T
            AND a.acc_off_id_T =e.acc_off_id_T
            AND a.csh_bk_yr_T  =e.csh_bk_yr_T
            AND a.csh_bk_mnth_T=e.csh_bk_mnth_T
            AND a.acc_no_T     =e.acc_no_T
            )a
          LEFT OUTER JOIN
            (

            select sum(dr_T1)as dr_T1,acc_u_id_T1,acc_off_id_T1,csh_bk_yr_T1,csh_bk_mnth_T1,acc_no_T1 from
(SELECT ACCOUNTING_UNIT_ID AS acc_u_id_T1,
              ACCOUNTING_FOR_OFFICE_ID AS acc_off_id_T1,
              CASHBOOK_YEAR            AS csh_bk_yr_T1,
              CASHBOOK_MONTH           AS csh_bk_mnth_T1,
              ACCOUNT_NO               AS acc_no_T1,
              SUM(DR_AMOUNT)           AS dr_T1
            FROM FAS_BRS_TRANSACTION
            WHERE accounting_unit_id    = $P{UnitId}
            AND accounting_for_office_id=$P{OfficeId}
            AND cashbook_month          =$P{cbmonth}
            AND cashbook_year           =$P{cbyear}
            AND ACCOUNT_NO              =$P{accNo}
            AND doc_type LIKE 'FT%'
            GROUP BY ACCOUNTING_UNIT_ID,
              ACCOUNTING_FOR_OFFICE_ID,
              CASHBOOK_YEAR,
              CASHBOOK_MONTH,
              ACCOUNT_NO
              union all
              SELECT ACCOUNTING_UNIT_ID AS acc_u_id_T1,
              ACCOUNTING_FOR_OFFICE_ID AS acc_off_id_T1,
              CASHBOOK_YEAR            AS csh_bk_yr_T1,
              CASHBOOK_MONTH           AS csh_bk_mnth_T1,
              ACCOUNT_NO               AS acc_no_T1,
              SUM(DR_AMOUNT)           AS dr_T1
            FROM fas_brs_transaction_noentry
            WHERE accounting_unit_id    = $P{UnitId}
            AND accounting_for_office_id=$P{OfficeId}
            AND cashbook_month          =$P{cbmonth}
            AND cashbook_year           =$P{cbyear}
            AND ACCOUNT_NO              =$P{accNo}
            AND doc_type LIKE 'FT%'
            GROUP BY ACCOUNTING_UNIT_ID,
              ACCOUNTING_FOR_OFFICE_ID,
              CASHBOOK_YEAR,
              CASHBOOK_MONTH,
              ACCOUNT_NO)group by acc_u_id_T1,acc_off_id_T1,csh_bk_yr_T1,csh_bk_mnth_T1,acc_no_T1
		)c
          ON a.acc_u_id_T     =c.acc_u_id_T1
          AND a.acc_off_id_T  = c.acc_off_id_T1
          AND a.csh_bk_yr_T   = c.csh_bk_yr_T1
          AND a.csh_bk_mnth_T = c.csh_bk_mnth_T1
          AND a.acc_no_T      = c.acc_no_T1
          ) Y ON X.acc_u_id   = Y.acc_u_id_T
        AND X.acc_off_id      = Y.acc_off_id_T
        AND X.csh_bk_yr       = Y.csh_bk_yr_T
        AND X.csh_bk_mnth     = Y.csh_bk_mnth_T
        AND X.acc_no          = Y.acc_no_T
        )
      )XX
    LEFT OUTER JOIN
      (SELECT rownum                                   AS t2_slno,
        DECODE(amt_t2_A,NULL,0,amt_t2_A)               AS amt_t2_A,
        DECODE(amt_2T_clos_bal,NULL,0,amt_2T_clos_bal) AS amt_2T_clos_bal,
        BANK_NAME,
        BRANCH_NAME
      FROM
        (SELECT rownum AS r__2T_A,
          amt_t2_A
        FROM
          (SELECT SUM(amt_t2_A) AS amt_t2_A
          FROM
            (
           SELECT ( SUM(cr_amount) - SUM(dr_amount) ) AS amt_t2_A
    FROM FAS_BRS_TRANSACTION_NOENTRY
    WHERE accounting_unit_id               =$P{UnitId}
    AND accounting_for_office_id           =$P{OfficeId}
   AND ((cashbook_year                     <$P{cbyear} and cashbook_month<=12) or (cashbook_year=$P{cbyear} and cashbook_month<=$P{cbmonth}))
    AND ACCOUNT_NO                         = $P{accNo}
    AND TWAD_OR_NON_TWAD                   ='T'
    AND doc_type                          IN ('CR', 'BR','FR by HO', 'FR by Office')
    UNION ALL
    SELECT ( SUM(cr_amount) - SUM(dr_amount) ) AS amt_t2_A
            FROM FAS_BRS_TRANSACTION
            WHERE accounting_unit_id                =$P{UnitId}
            AND Accounting_For_Office_Id            =$P{OfficeId}
            and extract (year FROM PASSBOOK_DATE)>cashbook_year
            AND Cashbook_Month                     =$P{cbmonth}
            AND cashbook_year                      =$P{cbyear}
            AND Account_No                          =$P{accNo}
            AND Twad_Or_Non_Twad                    ='T'
            AND doc_type                           IN ('CR', 'BR','FR by HO', 'FR by Office')
              UNION ALL
    SELECT ( SUM(cr_amount) - SUM(dr_amount) ) AS amt_t2_A
            FROM FAS_BRS_TRANSACTION
            WHERE accounting_unit_id                =$P{UnitId}
            AND Accounting_For_Office_Id            =$P{OfficeId}
            and ((extract (year FROM PASSBOOK_DATE )=cashbook_year) and (extract (month FROM PASSBOOK_DATE )>Cashbook_Month))
            AND Cashbook_Month                     =$P{cbmonth}
            AND cashbook_year                      =$P{cbyear}
            AND Account_No                          =$P{accNo}
            AND Twad_Or_Non_Twad                    ='T'
            AND doc_type                           IN ('CR', 'BR','FR by HO', 'FR by Office')
            )
          )
        )T2_A
      LEFT OUTER JOIN
        (SELECT r__2T_C,
          amt_2T_clos_bal,
          BANK_ID,
          BRANCH_ID,
          BANK_NAME,
          BRANCH_NAME
        FROM
          (SELECT rownum                                     AS r__2T_C,
            DECODE(PASSBOOK_BALANCE,NULL,0,PASSBOOK_BALANCE) AS amt_2T_clos_bal,
            BANK_ID,
            BRANCH_ID
          FROM FAS_BRS_MASTER
          WHERE accounting_unit_id    = $P{UnitId}
          AND accounting_for_office_id=$P{OfficeId}
          AND cashbook_month          = $P{cbmonth}
          AND cashbook_year           =$P{cbyear}
          AND ACCOUNT_NO              = $P{accNo}
          )sss
        LEFT OUTER JOIN
          (SELECT BRANCH_ID AS brnch_id,
            BANK_ID         AS bnk_id,
            BRANCH_NAME
          FROM FAS_MST_BANK_BRANCHES
          )c
        ON sss.BANK_ID    = c.bnk_id
        AND sss.BRANCH_ID = c.brnch_id
        LEFT OUTER JOIN
          (SELECT BANK_ID AS bnk_id1,BANK_NAME FROM FAS_BANK_LIST
          )d
        ON sss.BANK_ID        = d.bnk_id1
        )T2_C ON T2_A.r__2T_A = T2_C.r__2T_C
      ) YY ON XX.rowno1       = YY.t2_slno
    ) AAA
  LEFT OUTER JOIN
    (SELECT *
    FROM
      (SELECT rownum AS t2_sl_no,
        amt_2t,
        trans_desc,
	$P{cbyear} as cbyear,
        auid_2T_5A,
        aoid_2T_5A,
        cbm_2T_5A,
        cby_2T_5A,
        ano_2T_5A
      FROM
        (SELECT DECODE( (SUM(dr_amount) - SUM(cr_amount)),NULL,0,(SUM(dr_amount) -SUM(cr_amount)) ) AS amt_2t,
          transaction_type,
          accounting_unit_id       AS auid_2T_5A,
          accounting_for_office_id AS aoid_2T_5A,
          cashbook_month           AS cbm_2T_5A,
          cashbook_year            AS cby_2T_5A,
          ACCOUNT_NO               AS ano_2T_5A
        FROM fas_brs_transaction
        WHERE accounting_unit_id    = $P{UnitId}
        AND accounting_for_office_id=$P{OfficeId}
        AND ((cashbook_year          <$P{cbyear}
            AND cashbook_month          <=12)
            OR (cashbook_year            =$P{cbyear}
            AND cashbook_month          <=$P{cbmonth}))
        AND ACCOUNT_NO              = $P{accNo}
        AND twad_or_non_twad        = 'NT'
	and (CLEARED_BASED_ON_FOLLOWUP is null or CLEARED_BASED_ON_FOLLOWUP='N')
        GROUP BY transaction_type,
          accounting_unit_id,
          accounting_for_office_id,
          cashbook_month,
          cashbook_year,
          ACCOUNT_NO
        )t2_c
      LEFT OUTER JOIN
        ( SELECT trans_code,trans_desc FROM fas_brs_transaction_type
        )t2_d
      ON t2_c.transaction_type = t2_d.trans_code
      )YYY,
      (
      SELECT SUM(amt_2t) AS total
      FROM
        (
        SELECT rownum AS t2_sl_no,
  amt_2t,
  trans_desc,
  auid_2T_5A,
  aoid_2T_5A,
  cby_2T_5A,
  ano_2T_5A
FROM
  (SELECT transaction_type,
    DECODE( (SUM(dr_amount) - SUM(cr_amount)),NULL,0,(SUM(dr_amount) -SUM(cr_amount)) ) AS amt_2t,
    auid_2T_5A,
    aoid_2T_5A,
    cby_2T_5A,
    ano_2T_5A
  FROM
    (SELECT SUM(dr_amount)dr_amount,
      SUM(cr_amount)cr_amount,
      transaction_type,
      accounting_unit_id       AS auid_2T_5A,
      accounting_for_office_id AS aoid_2T_5A,
      $P{cbyear}               AS cby_2T_5A,
      ACCOUNT_NO               AS ano_2T_5A
    FROM fas_brs_transaction
    WHERE accounting_unit_id    = $P{UnitId}
    AND accounting_for_office_id=$P{OfficeId}
    AND ((cashbook_year         <$P{cbyear}
    AND cashbook_month         <=12)
    OR (cashbook_year           =$P{cbyear}
    AND cashbook_month         <=$P{cbmonth}))
    AND ACCOUNT_NO              = $P{accNo}
    AND twad_or_non_twad        = 'NT'
	and (CLEARED_BASED_ON_FOLLOWUP is null or CLEARED_BASED_ON_FOLLOWUP='N')
    GROUP BY transaction_type,
      accounting_unit_id,
      accounting_for_office_id,
      ACCOUNT_NO
    )
  GROUP BY auid_2T_5A,
    transaction_type,
    aoid_2T_5A,
    cby_2T_5A,
    ano_2T_5A
  )t2_c
LEFT OUTER JOIN
  ( SELECT trans_code,trans_desc FROM fas_brs_transaction_type
  )t2_d
ON t2_c.transaction_type = t2_d.trans_code
        )
      )XXX
    )BBB ON AAA.acc_u_id_T = BBB.auid_2T_5A
  AND AAA.acc_off_id_T     = BBB.aoid_2T_5A
  AND AAA.csh_bk_yr_T      = BBB.cbyear
  AND AAA.acc_no_T = BBB.ano_2T_5A
  )
WHERE amt_t2_A IS NOT NULL
ORDER BY t2_sl_no]]></queryString>

	<field name="ROWNO1" class="java.math.BigDecimal"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="OB_PART1" class="java.math.BigDecimal"/>
	<field name="CR" class="java.math.BigDecimal"/>
	<field name="CR_FINAL" class="java.math.BigDecimal"/>
