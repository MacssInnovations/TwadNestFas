<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="BankBalancereport"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="842"
		 columnWidth="818"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="openingmonth" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="closingmonth" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="openingyear" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="closingyear" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="unitStr" isForPrompting="false" class="java.lang.String"/>
	<parameter name="month" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT 

to_char(A.Accounting_Unit_Id,'000') || '-'
    ||
u.accounting_unit_name as UnitIdName,
  a.Bankname,
  a.branch_id,
  a.Bank_Ac_No,
  a.Bank_Ac_Type_Id,
  a.acc_type_desc,
  a.Ac_Operational_Mode_Id,
  a.acc_Mode_desc,
  a.Ac_Opening_Date,
  a.initial_deposit_amt,
  a.Cr_Dr_Type AS open_CR_Drtype,
  a.Pb_Balance AS open_PB_Bal,
  b.Cr_Dr_Type AS closing_CR_Drtype,
  b.Pb_Balance AS closing_PB_Bal
FROM
  (SELECT Balnce.Accounting_Unit_Id,
    (SELECT BANK_SHORT_NAME FROM fas_mst_banks bank WHERE bank.bank_id=balnce.bank_id
    )
    || '-'
    ||N.Branch_Name AS Bankname,
    n.branch_id,
    Balnce.Bank_Ac_No,
    Balnce.Bank_Ac_Type_Id,
    (SELECT ac_t.account_type
    FROM FAS_MST_BANK_AC_TYPES ac_t
    WHERE ac_t.account_type_id=Balnce.Bank_Ac_Type_Id
    ) acc_type_desc,
    Balnce.Ac_Operational_Mode_Id,
    (SELECT ac_mo.ac_operational_mode
    FROM FAS_MST_AC_OPER_MODES ac_mo
    WHERE ac_mo.Ac_Operational_Mode_Id=Balnce.Ac_Operational_Mode_Id
    ) acc_Mode_desc,
    Balnce.Ac_Opening_Date,
    balnce.initial_deposit_amt,
    Up.Cr_Dr_Type,
    Up.Pb_Balance
  FROM FAS_MST_BANK_BRANCHES n,
    FAS_MST_BANK_BALANCE balnce,
    BRS_BANK_BALANCE_UPDATE up
  WHERE balnce.accounting_unit_id  =up.accounting_unit_id
  AND balnce.bank_ac_no            =up.bank_ac_no
  AND balnce.BANK_AC_TYPE_ID       =up.BANK_AC_TYPE_ID
  AND Balnce.Ac_Operational_Mode_Id=Up.Ac_Operational_Mode_Id
  AND Balnce.Status                ='Y'
  AND N.Bank_Id                    =Up.Bank_Id
  AND n.branch_id                  =up.branch_id
  AND Up.PS_Year                   =$P{openingyear}
  AND Up.PS_Month                  =$P{openingmonth}
   $P!{unitStr}
  ORDER BY 
  --Balnce.Ac_Operational_Mode_Id,
  Balnce.Accounting_Unit_Id,
    balnce.bank_ac_no
  )a
INNER JOIN
  (SELECT Balnce.Accounting_Unit_Id,
    (SELECT BANK_SHORT_NAME FROM fas_mst_banks bank WHERE bank.bank_id=balnce.bank_id
    )
    || '-'
    ||N.Branch_Name AS Bankname,
    n.branch_id,
    Balnce.Bank_Ac_No,
    Balnce.Bank_Ac_Type_Id,
    (SELECT ac_t.account_type
    FROM FAS_MST_BANK_AC_TYPES ac_t
    WHERE ac_t.account_type_id=Balnce.Bank_Ac_Type_Id
    ) acc_type_desc,
    Balnce.Ac_Operational_Mode_Id,
    (SELECT ac_mo.ac_operational_mode
    FROM FAS_MST_AC_OPER_MODES ac_mo
    WHERE ac_mo.Ac_Operational_Mode_Id=Balnce.Ac_Operational_Mode_Id
    ) acc_Mode_desc,
    Balnce.Ac_Opening_Date,
    balnce.initial_deposit_amt,
    Up.Cr_Dr_Type,
    Up.Pb_Balance
  FROM FAS_MST_BANK_BRANCHES n,
    FAS_MST_BANK_BALANCE balnce,
    BRS_BANK_BALANCE_UPDATE up
  WHERE balnce.accounting_unit_id  =up.accounting_unit_id
  AND balnce.bank_ac_no            =up.bank_ac_no
  AND balnce.BANK_AC_TYPE_ID       =up.BANK_AC_TYPE_ID
  AND Balnce.Ac_Operational_Mode_Id=Up.Ac_Operational_Mode_Id
  AND Balnce.Status                ='Y'
  AND N.Bank_Id                    =Up.Bank_Id
  AND n.branch_id                  =up.branch_id
    AND Up.PS_Year                   =$P{closingyear}
  AND Up.PS_Month                  =$P{closingmonth}
  $P!{unitStr}
  ORDER BY 
  --Balnce.Ac_Operational_Mode_Id,
  Balnce.Accounting_Unit_Id,
    balnce.bank_ac_no
  )b
ON 
a.Ac_Operational_Mode_Id=b.Ac_Operational_Mode_Id and
a. Accounting_Unit_Id=b.Accounting_Unit_Id
AND a.bank_ac_no        =b.bank_ac_no
inner join fas_mst_acct_units u
on a.Accounting_Unit_Id=u.Accounting_Unit_Id
order by b.Accounting_Unit_Id,b.Ac_Operational_Mode_Id]]></queryString>

