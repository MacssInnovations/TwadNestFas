		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="792"
		 pageHeight="842"
		 columnWidth="732"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="query" isForPrompting="true" class="java.lang.String"/>
	<parameter name="heading" isForPrompting="false" class="java.lang.String"/>
	<parameter name="month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="y_bank_name" isForPrompting="true" class="java.lang.String"/>
	<parameter name="z_BRANCH_NAME" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="office_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="AccNo" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="month_1" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[Select T2_C.*,T2_D.*,U.*,
CASE WHEN CBM_2T_5A=1 THEN 'January'
WHEN CBM_2T_5A=2 THEN 'February'
WHEN CBM_2T_5A=3 THEN 'March'
WHEN CBM_2T_5A=4 THEN 'April'
WHEN CBM_2T_5A=5 THEN 'May'
WHEN CBM_2T_5A=6 THEN 'June'
WHEN CBM_2T_5A=7 THEN 'July'
WHEN CBM_2T_5A=8 THEN 'Augest'
WHEN CBM_2T_5A=9 THEN 'September'
WHEN CBM_2T_5A=10 THEN 'October'
WHEN CBM_2T_5A=11 THEN 'November'
else 'December' end as month
FROM
  (SELECT SUM(dr_amount) AS dr_amount ,
    SUM(cr_amount)       AS cr_amount,
    transaction_type,
    accounting_unit_id       AS auid_2T_5A,
    accounting_for_office_id AS aoid_2T_5A,
    cashbook_month           AS cbm_2T_5A,
    cashbook_year            AS cby_2T_5A,
    ACCOUNT_NO               AS ANO_2T_5A,
    TWAD_OR_NON_TWAD,
    CHEQUE_DD_NO,
    DOC_DATE,
    Doc_No,
    
    DOC_TYPE
  FROM fas_brs_transaction
  WHERE accounting_unit_id        = $P{unit_id}
  AND accounting_for_office_id    =$P{office_id}
  AND ((cashbook_year             <$P{year}
  AND cashbook_month             <=12)
  OR (cashbook_year               =$P{year}
  AND cashbook_month             <=$P{month}))
  AND ACCOUNT_NO                  = $P{AccNo}
  AND twad_or_non_twad            = 'NT'
  AND (CLEARED_BASED_ON_FOLLOWUP IS NULL
  OR CLEARED_BASED_ON_FOLLOWUP    ='N')
  GROUP BY transaction_type, accounting_unit_id, accounting_for_office_id, cashbook_month, cashbook_year, ACCOUNT_NO, TWAD_OR_NON_TWAD, CHEQUE_DD_NO, DOC_DATE, Doc_No, DOC_TYPE
  UNION ALL
  SELECT SUM(dr_amount) AS dr_amount ,
    SUM(cr_amount)      AS cr_amount, 
    transaction_type,
    accounting_unit_id       AS auid_2T_5A,
    accounting_for_office_id AS aoid_2T_5A,
    cashbook_month           AS cbm_2T_5A,
    cashbook_year            AS cby_2T_5A,
    ACCOUNT_NO               AS ANO_2T_5A,
    TWAD_OR_NON_TWAD,
    CHEQUE_DD_NO,
    DOC_DATE,
    Doc_No,
   
    DOC_TYPE
  FROM fas_brs_transaction
  WHERE accounting_unit_id      = $P{unit_id}
  AND accounting_for_office_id  =$P{office_id}
  AND ((cashbook_year           <$P{year}
  AND cashbook_month           <=12)
  OR (cashbook_year             =$P{year}
  AND cashbook_month           <=$P{month}))
  AND ACCOUNT_NO                = $P{AccNo}
  AND twad_or_non_twad          = 'NT'
  AND (CLEARED_BASED_ON_FOLLOWUP='Y'
  AND clearence_date            >(''))
  GROUP BY transaction_type,
    accounting_unit_id,
    accounting_for_office_id,
    cashbook_month,
    CASHBOOK_YEAR,
    ACCOUNT_NO,
    TWAD_OR_NON_TWAD,
    CHEQUE_DD_NO,
    Doc_Date,
    
    DOC_NO,
    DOC_TYPE
  )T2_C
LEFT OUTER JOIN
  (SELECT TRANS_CODE,TRANS_DESC FROM FAS_BRS_TRANSACTION_TYPE
  )T2_D
On T2_C.Transaction_Type = T2_D.Trans_Code 
Left Outer Join
(SELECT ACCOUNTING_UNIT_ID, ACCOUNTING_UNIT_NAME as unit_name
From Fas_Mst_Acct_Units 
)U
 On T2_C.auid_2T_5A=u.ACCOUNTING_UNIT_ID
  ORDER BY  cby_2T_5A, CBM_2T_5A,transaction_type]]></queryString>

