	<parameter name="Sl.No" isForPrompting="false" class="java.lang.Integer"/>
	<queryString><![CDATA[select A.status,to_char(A.Accounting_Unit_Id,'000')as Unit_Id,A.AC_OPERATIONAL_MODE_ID,(SELECT BANK_SHORT_NAME
  FROM fas_mst_banks bank
  WHERE bank.bank_id=A.bank_id
  )AS Bankname,
  U.ACCOUNTING_UNIT_NAME,
  A.BANK_AC_NO,B.status as status1 from 
(SELECT distinct Balnce.Accounting_Unit_Id,
BALNCE.BANK_AC_NO,BALNCE.BANK_ID,
BALNCE.STATUS,BALNCE.AC_OPERATIONAL_MODE_ID 
FROM FAS_MST_BANK_BALANCE balnce
INNER JOIN brs_start_month_and_year c
ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
AND Balnce.Bank_Ac_No =C.Account_No
INNER JOIN Fas_Brs_Transaction T
ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
AND BALNCE.BANK_AC_NO =T.ACCOUNT_NO
AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%Main%')  A
left join 
(SELECT distinct Balnce.Accounting_Unit_Id,
BALNCE.BANK_AC_NO,
d.STATUS,
 D.CASHBOOK_MONTH,D.CASHBOOK_YEAR ,
TO_CHAR(D.FREEZED_DATE,'DD/MM/YY')AS updated_date
FROM FAS_MST_BANK_BALANCE balnce
INNER JOIN brs_start_month_and_year c
ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
AND Balnce.Bank_Ac_No =C.Account_No
INNER JOIN Fas_Brs_Transaction T
ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
AND BALNCE.BANK_AC_NO =T.ACCOUNT_NO
AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%Main%'
inner JOIN Fas_Brs_Monthly_Closure D
ON BALNCE.ACCOUNTING_UNIT_ID=D.ACCOUNTING_UNIT_ID
AND BALNCE.BANK_AC_NO = D.ACCOUNT_NO
and d.STATUS='Y') B
on A.Accounting_Unit_Id=B.Accounting_Unit_Id
and A.BANK_AC_NO=B.BANK_AC_NO
INNER JOIN Fas_Mst_Acct_Units U
ON A.ACCOUNTING_UNIT_ID=U.ACCOUNTING_UNIT_ID

ORDER BY A.Ac_Operational_Mode_Id,
  A.ACCOUNTING_UNIT_ID,
  A.Bank_Ac_No
]]></queryString>

