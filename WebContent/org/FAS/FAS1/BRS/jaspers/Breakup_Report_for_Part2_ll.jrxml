<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Breakup_Report_for_Part2_ll"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="907"
		 pageHeight="842"
		 columnWidth="847"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select rownum as slno,PASSBOOK_DATE,DOC_NO,doc_type,doc_date,amount,amount_in_passbook,REASON_FOR_DIFFERENCE,ACTION_TAKEN,
OFFICE_NAME,BANK_NAME,BRANCH_NAME,OB_PART2A,amount_NT,amount_ne,CHEQUE_DD_NO, from
( select * from
( select * from
(   SELECT accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_no,TWAD_OR_NON_TWAD,
PASSBOOK_DATE,DOC_NO,doc_type,doc_date,CHEQUE_DD_NO,
case when TWAD_OR_NON_TWAD='T' and (cr_amount -dr_amount)<0 then -(cr_amount -dr_amount)
when TWAD_OR_NON_TWAD='T' and (cr_amount -dr_amount)>=0 then (cr_amount -dr_amount)
when TWAD_OR_NON_TWAD='T' and (cr_amount -dr_amount)=null then 0
when TWAD_OR_NON_TWAD='NT' then 0
 else 0 end as amount,
decode(amount_in_passbook,null,0,amount_in_passbook) as amount_in_passbook,
decode(REASON_FOR_DIFFERENCE,null,'-',REASON_FOR_DIFFERENCE) as REASON_FOR_DIFFERENCE,
decode(ACTION_TAKEN,null,'-',ACTION_TAKEN) as ACTION_TAKEN,
case when TWAD_OR_NON_TWAD='NT' and (cr_amount -dr_amount)<0 then -(cr_amount -dr_amount) 
 when TWAD_OR_NON_TWAD='NT' and (cr_amount -dr_amount)>0 then (cr_amount -dr_amount) 
 else 0 end as amount_NT,
 case when TWAD_OR_NON_TWAD='T' then 0 else 0 end as amount_ne
FROM fas_brs_transaction
WHERE ACCOUNTING_UNIT_ID=$P{UnitId} and 
ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId} and 
CASHBOOK_YEAR=$P{cbyear} and 
CASHBOOK_MONTH=$P{cbmonth} and 
ACCOUNT_NO=$P{accNo}

union all

SELECT accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_no,TWAD_OR_NON_TWAD,
PASSBOOK_DATE,DOC_NO,doc_type,doc_date,
case when TWAD_OR_NON_TWAD='T' then 0 else 0 end as amount,
case when TWAD_OR_NON_TWAD='T' then 0 else 0 end as amount_in_passbook,
decode(REASON_FOR_DIFFERENCE,null,'-',REASON_FOR_DIFFERENCE) as REASON_FOR_DIFFERENCE,
decode(ACTION_TAKEN,null,'-',ACTION_TAKEN) as ACTION_TAKEN,
case when TWAD_OR_NON_TWAD='NT' then 0 end as amount_NT,
case when (cr_amount -dr_amount)<0 then -(cr_amount -dr_amount) else (cr_amount -dr_amount) end as amount_ne
FROM FAS_BRS_TRANSACTION_NOENTRY
WHERE ACCOUNTING_UNIT_ID=$P{UnitId} and 
ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId} and 
CASHBOOK_YEAR=$P{cbyear} and 
CASHBOOK_MONTH=$P{cbmonth} and 
ACCOUNT_NO=$P{accNo}  )a

left outer join

(select OFFICE_ID,OFFICE_NAME from BKUP_COM_MST_OFFICES)aa on
a.ACCOUNTING_FOR_OFFICE_ID = aa.OFFICE_ID )xx

left outer join 

( select ACCOUNTING_UNIT_ID as acc_un_id_ob,ACCOUNTING_FOR_OFFICE_ID as acc_off_id_ob,
CASHBOOK_YEAR as cby_ob,CASHBOOK_MONTH as cbm_ob,ACCOUNT_NO as accno_ob,OB_PART2A from FAS_BRS_OB where 
ACCOUNTING_UNIT_ID=$P{UnitId} and 
ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId} and 
CASHBOOK_YEAR=$P{cbyear} and 
CASHBOOK_MONTH=$P{cbmonth} and 
ACCOUNT_NO=$P{accNo} )ob on

xx.accounting_unit_id = ob.acc_un_id_ob and 
xx.accounting_for_office_id = ob.acc_off_id_ob and 
xx.cashbook_year = ob.cby_ob and 
xx.cashbook_month = ob.cbm_ob and 
xx.account_no = ob.accno_ob)x


left outer join

( select ACCOUNTING_UNIT_ID as acc_unit_id,ACCOUNTING_FOR_OFFICE_ID as acc_off_id,CASHBOOK_YEAR as csh_bk_yr,
CASHBOOK_MONTH as csh_bk_mnth,ACCOUNT_NO as acc_no,BANK_NAME,BRANCH_NAME from 

( select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,CASHBOOK_YEAR,CASHBOOK_MONTH,ACCOUNT_NO,BANK_ID,BRANCH_ID 
from FAS_BRS_MASTER where 
ACCOUNTING_UNIT_ID=$P{UnitId} and 
ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId} and 
CASHBOOK_YEAR=$P{cbyear} and 
CASHBOOK_MONTH=$P{cbmonth} and 
ACCOUNT_NO=$P{accNo})b

left outer join

( select BRANCH_ID as brnch_id,BANK_ID as bnk_id,BRANCH_NAME from FAS_MST_BANK_BRANCHES)c on
b.BANK_ID = c.bnk_id and 
b.BRANCH_ID = c.brnch_id 

left outer join

(select BANK_ID as bnk_id1,BANK_NAME from FAS_MST_BANKS)d on
b.BANK_ID = d.bnk_id1 )y on
x.ACCOUNTING_UNIT_ID = y.acc_unit_id and 
x.ACCOUNTING_FOR_OFFICE_ID = y.acc_off_id and 
x.CASHBOOK_YEAR = y.csh_bk_yr and 
x.CASHBOOK_MONTH = y.csh_bk_mnth and 
x.ACCOUNT_NO = y.acc_no order by PASSBOOK_DATE]]></queryString>

