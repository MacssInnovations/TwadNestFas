	<queryString><![CDATA[SELECT DISTINCT o.accounting_unit_id,
  o.accounting_for_office_id,
  o.account_no,
  -- o.cashbook_month,
  st.cashbook_month,
  st.cashbook_year,
  o.pass_book_date,
  --  o.cashbook_year,
  o.bank_id,
  o.branch_id,
  b.bank_name,
  br.branch_name,
  ob_status.ob_status,
  case when ob_status.ob_status='Y' then 'Freezed' when ob_status.ob_status is null then 'Not Freezed' end as obStatus_view,
   case when ob_trn.ob_pushed='Y' then 'Pushed' when ob_trn.ob_pushed is null then 'Not Pushed' end as obPushed_view,
  ob_status.UPDATED_DATE,
  ob_trn.ob_pushed,
  ob_trn.OB_PUSHED_DATE,
  u.accounting_unit_name
  
FROM fas_brs_ob o,
  brs_start_month_and_year st,
  fas_mst_banks b,
  FAS_MST_BANK_BRANCHES br,
  FAS_BRS_OB_STATUS ob_status,
  FAS_BRS_OB_TRANSACTION ob_trn,
  fas_mst_acct_units u
WHERE st.accounting_unit_id     = o.accounting_unit_id
AND st.accounting_for_office_id = o.accounting_for_office_id
AND st.account_no               = o.account_no
AND b.bank_id                   =o.bank_id
AND br.bank_id                  =o.bank_id
AND br.branch_id                =o.branch_id
AND
  --ob_status.accounting_for_office_id = o.accounting_for_office_id and
  ob_status.accounting_unit_id = o.accounting_unit_id
AND ob_status.cashbook_month   = o.cashbook_month
AND ob_status.cashbook_year    = o.cashbook_year
AND ob_status.account_no       = o.account_no
and ob_trn.accounting_for_office_id = o.accounting_for_office_id and
u.accounting_unit_id=o.accounting_unit_id and

ob_trn.accounting_unit_id = o.accounting_unit_id and
ob_trn.accounting_for_office_id = o.accounting_for_office_id and
ob_trn.account_no=o.account_no 

order by o.accounting_unit_id   

--AND o.accounting_unit_id       =182
  --and
  --st.cashbook_month = o.cashbook_month and
  --st.cashbook_year = o.cashbook_year
  --where ]]></queryString>

