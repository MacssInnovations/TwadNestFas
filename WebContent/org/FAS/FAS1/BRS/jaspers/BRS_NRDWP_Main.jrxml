<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="BRS_NRDWP_Main"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="594"
		 pageHeight="842"
		 columnWidth="534"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="Sl.No" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["/home/nic/Desktop/"]]></defaultValueExpression>
	</parameter>
	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<parameter name="s_head" isForPrompting="false" class="java.lang.String"/>
	<parameter name="sel" isForPrompting="false" class="java.lang.String"/>
	<parameter name="sub_q" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT F.ACCOUNTING_UNIT_ID,TO_CHAR(f.ACCOUNTING_UNIT_ID,'000') UNIT_ID,
U.ACCOUNTING_UNIT_NAME,
F.BANK_AC_NO,
F.BANK_ID,(select B.BANK_SHORT_NAME from FAS_MST_BANKS b where B.BANK_ID=f.BANK_ID) bank_name ,
F.AC_OPERATIONAL_MODE_ID,
F.CLO_MON,
f.ope_YR 
FROM
  ( SELECT DISTINCT Balnce.Accounting_Unit_Id,
    BALNCE.BANK_AC_NO,
    BALNCE.BANK_ID,
    BALNCE.AC_OPERATIONAL_MODE_ID,
    MAX(D.CASHBOOK_MONTH)
    ||'/'
    || MAX(D.CASHBOOK_YEAR) AS Clo_MON,
     CASE WHEN (MAX(D.CASHBOOK_YEAR)=MIN(D.CASHBOOK_YEAR)) and  (MAX(D.CASHBOOK_MONTH)=MIN(D.CASHBOOK_MONTH))
    then   MIN(D.CASHBOOK_MONTH-1)
    ||'/'
    || MIN(D.CASHBOOK_YEAR) else MIN(D.CASHBOOK_MONTH)
    ||'/'
    || MIN(D.CASHBOOK_YEAR) end AS OPE_YR,
    BALNCE.STATUS
  FROM FAS_MST_BANK_BALANCE balnce
  INNER JOIN brs_start_month_and_year c
  ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
  AND Balnce.Bank_Ac_No       =C.Account_No
  INNER JOIN Fas_Brs_Transaction T
  ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
  AND BALNCE.BANK_AC_NO        =T.ACCOUNT_NO
 $P!{sel}
  INNER JOIN Fas_Brs_Monthly_Closure D
  ON BALNCE.ACCOUNTING_UNIT_ID=D.ACCOUNTING_UNIT_ID
  AND BALNCE.BANK_AC_NO       = D.ACCOUNT_NO
  AND D.STATUS                ='Y'
 
  AND Balnce.STATUS           ='Y'
  GROUP BY Balnce.Accounting_Unit_Id,
    BALNCE.BANK_AC_NO,
    BALNCE.BANK_ID,
    BALNCE.AC_OPERATIONAL_MODE_ID,
    BALNCE.STATUS
  UNION ALL
  SELECT *
  FROM
    (SELECT DISTINCT Balnce.Accounting_Unit_Id,
      BALNCE.BANK_AC_NO,
      BALNCE.BANK_ID,
      BALNCE.AC_OPERATIONAL_MODE_ID,
      NULL AS CLO_MON,
      DECODE(MIN(C.CASHBOOK_MONTH)
      ||'/'
      || MIN(C.CASHBOOK_YEAR),'/','',MIN(C.CASHBOOK_MONTH)
      ||'/'
      || MIN(C.CASHBOOK_YEAR)) AS ope_YR,
      BALNCE.STATUS
    FROM FAS_MST_BANK_BALANCE BALNCE
    LEFT OUTER JOIN brs_start_month_and_year c
    ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
    AND Balnce.Bank_Ac_No       =C.Account_No
 
    AND BALNCE.STATUS           ='Y'
    GROUP BY Balnce.Accounting_Unit_Id,
      BALNCE.BANK_AC_NO,
      BALNCE.BANK_ID,
      BALNCE.AC_OPERATIONAL_MODE_ID,
      NULL,
      BALNCE.STATUS
    )X
  WHERE 
$P!{sub_q}
  AND 
STATUS          ='Y'
  AND BANK_AC_NO NOT IN
    (SELECT D.ACCOUNT_NO
    FROM Fas_Brs_Monthly_Closure D
    WHERE x.ACCOUNTING_UNIT_ID=D.ACCOUNTING_UNIT_ID
    AND x.BANK_AC_NO          = D.ACCOUNT_NO
    AND D.STATUS              ='Y'
    )
  ORDER BY ACCOUNTING_UNIT_ID,
    BANK_AC_NO
  )f INNER JOIN  FAS_MST_ACCT_UNITS U on
  F.ACCOUNTING_UNIT_ID= U.ACCOUNTING_UNIT_ID
  ORDER BY ACCOUNTING_UNIT_ID,BANK_AC_NO]]></queryString>

