<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="BRS_Report_2_value"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth_name" isForPrompting="false" class="java.lang.String"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<parameter name="four_b" isForPrompting="true" class="java.math.BigDecimal"/>
	<parameter name="four_c" isForPrompting="true" class="java.math.BigDecimal"/>
	<parameter name="UnitName" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT DECODE(OFFICE_NAME,NULL,'-',OFFICE_NAME) AS OFFICE_NAME,
  DECODE(BANK_NAME,NULL,'-',BANK_NAME)          AS BANK_NAME,
  DECODE(BRANCH_NAME,NULL,'-',BRANCH_NAME)      AS BRANCH_NAME,
  acc_u_id,
  acc_off_id,
  csh_bk_yr,
  csh_bk_mnth,
  acc_no,
  DECODE(OB_PART2A,NULL,0,OB_PART2A) AS A_1,
  A_2a,
  A_2b,
  A_2c,
  A_2d,
  A_2e,
  (DECODE(OB_PART2A,NULL,0,OB_PART2A)+A_2e) AS A_3,
  A_4,
  ( (DECODE(Ob_Part2a,NULL,0,Ob_Part2a)+A_2e)-A_4) AS A_5,
  A_6a,
  A_6b ,
  A_6c,
  PASSBOOK_BALANCE
FROM (
  (SELECT Acc_U_Id6,
    Acc_Off_Id6,
    Csh_Bk_Yr6,
    Csh_Bk_Mnth6,
    Acc_No6,
    Ob_Part2a,
    OFFICE_NAME,
    BANK_NAME,
    BRANCH_NAME,
    PASSBOOK_BALANCE
  FROM
    (SELECT rownum AS slno1,
      acc_u_id6,
      acc_off_id6,
      csh_bk_yr6,
      csh_bk_mnth6,
      acc_no6,
      OB_PART2A,
      OFFICE_NAME
    FROM
      (SELECT ACCOUNTING_UNIT_ID AS acc_u_id6,
        ACCOUNTING_FOR_OFFICE_ID AS acc_off_id6,
        CASHBOOK_YEAR            AS csh_bk_yr6,
        CASHBOOK_MONTH           AS csh_bk_mnth6,
        ACCOUNT_NO               AS acc_no6,
        OB_PART2A
      FROM FAS_BRS_OB
      WHERE accounting_unit_id    = $P{UnitId}
      AND accounting_for_office_id= $P{OfficeId}
      AND cashbook_month          = $P{cbmonth}
      AND cashbook_year           =$P{cbyear}
      AND ACCOUNT_NO              = $P{accNo}
      )AUID1
    LEFT OUTER JOIN
      (SELECT OFFICE_ID,OFFICE_NAME FROM BKUP_COM_MST_OFFICES
      )AUID2
    ON AUID1.acc_off_id6 = AUID2.OFFICE_ID
    ) t1
  LEFT OUTER JOIN
    (SELECT Slno2,
      Bank_Name,
      Branch_Name,
      PASSBOOK_BALANCE
    FROM
      (SELECT rownum AS slno2,
        BANK_ID,
        BRANCH_ID,
        PASSBOOK_BALANCE
      FROM FAS_BRS_MASTER
      WHERE accounting_unit_id    = $P{UnitId}
      AND accounting_for_office_id= $P{OfficeId}
      AND cashbook_month          = $P{cbmonth}
      AND cashbook_year           =$P{cbyear}
      AND ACCOUNT_NO              = $P{accNo}
      )sss
    LEFT OUTER JOIN
      (SELECT BRANCH_ID AS brnch_id,
        BANK_ID         AS bnk_id,
        BRANCH_NAME
      FROM FAS_BANK_BRANCH
      )c
    ON sss.BANK_ID    = c.bnk_id
    AND sss.BRANCH_ID = c.brnch_id
    LEFT OUTER JOIN
      (SELECT BANK_ID AS bnk_id1,BANK_NAME FROM FAS_BANK_LIST
      )d
    ON sss.BANK_ID  = d.bnk_id1
    )t2 ON t1.slno1 = t2.slno2
  )XX
LEFT OUTER JOIN
  (SELECT acc_u_id,
    acc_off_id,
    csh_bk_yr,
    csh_bk_mnth,
    acc_no,
    A_2a,
    A_2b,
    A_2c,
    A_2d,
    A_2e,
    A_4,
    DECODE(A_6a,NULL,0,A_6a)                             AS A_6a,
    DECODE(A_6b,NULL,0,A_6b)                             AS A_6b ,
    (DECODE(A_6a,NULL,0,A_6a) + DECODE(A_6b,NULL,0,A_6b))AS A_6c
  FROM
    (SELECT acc_u_id,
      acc_off_id,
      csh_bk_yr,
      csh_bk_mnth,
      acc_no,
      A_2a,
      Decode(A_2b,Null,0,A_2b)As A_2b,
      A_2a+( Decode(A_2b,Null,0,A_2b)) AS A_2c,
      Decode(A_2d,Null,0,A_2d)As A_2d,
      (A_2a+( Decode(A_2b,Null,0,A_2b)))-( Decode(A_2d,Null,0,A_2d)) AS A_2e
    FROM
      (SELECT acc_u_id,
        acc_off_id,
        csh_bk_yr,
        csh_bk_mnth,
        acc_no,
        SUM(A_2a) AS A_2a
      FROM
        (SELECT acc_u_id,
          acc_off_id,
          csh_bk_yr,
          csh_bk_mnth,
          acc_no,
          SUM(A_2a) AS A_2a
        FROM
          (SELECT ACCOUNTING_UNIT_ID AS acc_u_id,
            ACCOUNTING_FOR_OFFICE_ID AS acc_off_id,
            CASHBOOK_YEAR            AS csh_bk_yr,
            CASHBOOK_MONTH           AS csh_bk_mnth,
            Account_No               AS Acc_No,
            SUM(total_amount)        AS A_2a
          FROM FAS_payment_master
          WHERE accounting_unit_id    = $P{UnitId}
          AND accounting_for_office_id=$P{OfficeId}
          AND cashbook_month          = $P{cbmonth}
          AND Cashbook_Year           =$P{cbyear}
          AND ACCOUNT_NO              = $P{accNo}
          AND Payment_Status          ='L'
          GROUP BY Accounting_Unit_Id,
            Accounting_For_Office_Id,
            Cashbook_Year,
            Cashbook_Month,
            Account_No
          UNION ALL
          SELECT ACCOUNTING_UNIT_ID  AS acc_u_id,
            ACCOUNTING_FOR_OFFICE_ID AS acc_off_id,
            CASHBOOK_YEAR            AS csh_bk_yr,
            CASHBOOK_MONTH           AS csh_bk_mnth,
            Account_No               AS Acc_No,
            SUM(Total_Amount)        AS A_2a
          FROM FAS_receipt_master
          WHERE accounting_unit_id    = $P{UnitId}
          AND accounting_for_office_id=$P{OfficeId}
          AND cashbook_month          = $P{cbmonth}
          AND Cashbook_Year           =$P{cbyear}
          AND Account_No              = $P{accNo}
          AND receipt_Status          ='L'
          AND CREATED_BY_MODULE       ='SC'
          GROUP BY Accounting_Unit_Id,
            Accounting_For_Office_Id,
            Cashbook_Year,
            Cashbook_Month,
            Account_No
          )
        GROUP BY acc_u_id,
          acc_off_id,
          csh_bk_yr,
          Csh_Bk_Mnth,
          acc_no
        )
      GROUP BY acc_u_id,
        acc_off_id,
        csh_bk_yr,
        csh_bk_mnth,
        acc_no
      )a
    LEFT OUTER JOIN
      (SELECT ACCOUNTING_UNIT_ID AS acc_u_id1,
        ACCOUNTING_FOR_OFFICE_ID AS acc_off_id1,
        CASHBOOK_YEAR            AS csh_bk_yr1,
        CASHBOOK_MONTH           AS csh_bk_mnth1,
        ACCOUNT_NO               AS acc_no1,
        SUM(CR_AMOUNT)           AS A_2b
      FROM FAS_BRS_TRANSACTION_NOENTRY
      WHERE accounting_unit_id    = $P{UnitId}
      AND accounting_for_office_id=$P{OfficeId}
      AND cashbook_month          = $P{cbmonth}
      AND cashbook_year           =$P{cbyear}
      AND ACCOUNT_NO              = $P{accNo}
      AND doc_type                ='J'
      GROUP BY ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_YEAR,
        CASHBOOK_MONTH,
        ACCOUNT_NO
      )b
    ON a.acc_u_id     =b.acc_u_id1
    AND a.acc_off_id  = b.acc_off_id1
    AND a.csh_bk_yr   = b.csh_bk_yr1
    AND a.csh_bk_mnth = b.csh_bk_mnth1
    AND a.acc_no      = b.acc_no1
    LEFT OUTER JOIN
      (SELECT ACCOUNTING_UNIT_ID AS acc_u_id2,
        ACCOUNTING_FOR_OFFICE_ID AS acc_off_id2,
        CASHBOOK_YEAR            AS csh_bk_yr2,
        CASHBOOK_MONTH           AS csh_bk_mnth2,
        ACCOUNT_NO               AS acc_no2,
        SUM(DR_AMOUNT)           AS A_2d
      FROM FAS_BRS_TRANSACTION_NOENTRY
      WHERE accounting_unit_id    = $P{UnitId}
      AND accounting_for_office_id=$P{OfficeId}
      AND cashbook_month          = $P{cbmonth}
      AND cashbook_year           =$P{cbyear}
      AND ACCOUNT_NO              = $P{accNo}
      AND doc_type                ='J'
      GROUP BY ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_YEAR,
        CASHBOOK_MONTH,
        ACCOUNT_NO
      )c
    ON a.acc_u_id     =c.acc_u_id2
    AND a.acc_off_id  = c.acc_off_id2
    AND a.csh_bk_yr   = c.csh_bk_yr2
    AND a.csh_bk_mnth = c.csh_bk_mnth2
    AND a.acc_no      = c.acc_no2
    )x
  LEFT OUTER JOIN
    (SELECT acc_u_id3,
      acc_off_id3,
      csh_bk_yr3,
      $P{cbmonth} AS csh_bk_mnth3,
      acc_no3,
      A_4
    FROM
      (SELECT acc_u_id3,
        acc_off_id3,
        csh_bk_yr3,
        acc_no3,
        SUM(A_4) AS A_4
      FROM
        (SELECT ACCOUNTING_UNIT_ID AS acc_u_id3,
          ACCOUNTING_FOR_OFFICE_ID AS acc_off_id3,
          CASHBOOK_YEAR            AS csh_bk_yr3,
          ACCOUNT_NO               AS acc_no3,
          SUM(DR_AMOUNT)           AS A_4
        FROM FAS_BRS_TRANSACTION
        WHERE accounting_unit_id             = $P{UnitId}
        AND accounting_for_office_id         =$P{OfficeId}
        AND cashbook_year                    =$P{cbyear}
        AND ACCOUNT_NO                       = $P{accNo}
        AND extract(MONTH FROM PASSBOOK_DATE)=$P{cbmonth}
	and TWAD_OR_NON_TWAD='T'
        AND doc_type                        IN ('P')
        GROUP BY ACCOUNTING_UNIT_ID,
          ACCOUNTING_FOR_OFFICE_ID,
          CASHBOOK_YEAR,
          ACCOUNT_NO
        UNION ALL
        SELECT ACCOUNTING_UNIT_ID  AS acc_u_id3,
          ACCOUNTING_FOR_OFFICE_ID AS acc_off_id3,
          CASHBOOK_YEAR            AS csh_bk_yr3,
          ACCOUNT_NO               AS acc_no3,
          SUM(CR_AMOUNT)           AS A_4
        FROM FAS_BRS_TRANSACTION
        WHERE accounting_unit_id             = $P{UnitId}
        AND accounting_for_office_id         =$P{OfficeId}
        AND cashbook_year                    =$P{cbyear}
        AND ACCOUNT_NO                       = $P{accNo}
        AND extract(MONTH FROM PASSBOOK_DATE)=$P{cbmonth}
	and TWAD_OR_NON_TWAD='T'
        AND doc_type                        IN ('SC')
        GROUP BY ACCOUNTING_UNIT_ID,
          ACCOUNTING_FOR_OFFICE_ID,
          CASHBOOK_YEAR,
          CASHBOOK_MONTH,
          ACCOUNT_NO
        )
      GROUP BY acc_u_id3,
        acc_off_id3,
        csh_bk_yr3,
        acc_no3
      )
    )y
  ON x.acc_u_id     =y.acc_u_id3
  AND x.acc_off_id  = y.acc_off_id3
  AND x.csh_bk_yr   = y.csh_bk_yr3
  AND x.csh_bk_mnth = y.csh_bk_mnth3
  AND x.acc_no      = y.acc_no3
  LEFT OUTER JOIN
    (

    SELECT acc_u_id4,
      acc_off_id4,
      Acc_No4,
      Sum(A_6a) As A_6a From
((
SELECT acc_u_id4,
      acc_off_id4,
      acc_no4,
      SUM(A_6a) AS A_6a
    FROM
      (SELECT ACCOUNTING_UNIT_ID AS acc_u_id4,
        ACCOUNTING_FOR_OFFICE_ID AS acc_off_id4,
        CASHBOOK_YEAR            AS csh_bk_yr4,
        CASHBOOK_MONTH           AS csh_bk_mnth4,
        ACCOUNT_NO               AS acc_no4,
        SUM(DR_AMOUNT)           AS A_6a
      FROM FAS_BRS_TRANSACTION_NOENTRY
      WHERE accounting_unit_id    = 3
      And Accounting_For_Office_Id=5000
      And ((Cashbook_Year          =2010
      And Cashbook_Month          <=10)
      OR (cashbook_year           <2010))
      AND ACCOUNT_NO              = 4181
      AND doc_type                ='P'
      GROUP BY ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_YEAR,
        CASHBOOK_MONTH,
        ACCOUNT_NO
      UNION ALL
      SELECT ACCOUNTING_UNIT_ID  AS acc_u_id4,
        ACCOUNTING_FOR_OFFICE_ID AS acc_off_id4,
        CASHBOOK_YEAR            AS csh_bk_yr4,
        CASHBOOK_MONTH           AS csh_bk_mnth4,
        ACCOUNT_NO               AS acc_no4,
        SUM(CR_AMOUNT)           AS A_6a
      FROM FAS_BRS_TRANSACTION_NOENTRY
      WHERE accounting_unit_id    = 3
      And Accounting_For_Office_Id=5000
      And ((Cashbook_Year          =2010
      And Cashbook_Month          <=10)
      OR (cashbook_year           <2010))
      AND ACCOUNT_NO              = 4181
      AND doc_type                ='SC'
      GROUP BY ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_YEAR,
        CASHBOOK_MONTH,
        ACCOUNT_NO
      )
    GROUP BY acc_u_id4,
      Acc_Off_Id4,
      acc_no4
)
union all
(Select Acc_U_Id4,Acc_Off_Id4,Acc_No4,
sum(Dra)AS A_6a from
(
Select ACCOUNTING_UNIT_ID AS acc_u_id4,
        ACCOUNTING_FOR_OFFICE_ID AS acc_off_id4,
        CASHBOOK_YEAR            AS csh_bk_yr4,
        Cashbook_Month           As Csh_Bk_Mnth4,
        ACCOUNT_NO               AS acc_no4,
Sum(Dr_Amount) As Dra,
  Sum(Cr_Amount)as cra
From Fas_Brs_Transaction
WHERE ((Extract(YEAR FROM Passbook_Date)=2010
And Extract(Month From Passbook_Date)   >10)
And (Cashbook_Year                      =2010
And Cashbook_Month                      =10)
)
And Account_No=4181
AND doc_type    in('P','SC')
GROUP BY ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_YEAR,
        CASHBOOK_MONTH,
        ACCOUNT_NO


Union All

Select ACCOUNTING_UNIT_ID AS acc_u_id4,
        ACCOUNTING_FOR_OFFICE_ID AS acc_off_id4,
        CASHBOOK_YEAR            AS csh_bk_yr4,
        Cashbook_Month           As Csh_Bk_Mnth4,
        ACCOUNT_NO               AS acc_no4,
Sum(Dr_Amount) As Dra,
  SUM(cr_amount)as cra
From Fas_Brs_Transaction
WHERE Account_No=4181 and 
((Extract(Year From Passbook_Date)=2010
And Extract(Month From Passbook_Date)   >10)
and
(Cashbook_Year                       =2010
And Cashbook_Month                      <10))
AND doc_type    in('P','SC')
GROUP BY ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_YEAR,
        Cashbook_Month,
        ACCOUNT_NO


Union All

Select ACCOUNTING_UNIT_ID AS acc_u_id4,
        ACCOUNTING_FOR_OFFICE_ID AS acc_off_id4,
        CASHBOOK_YEAR            AS csh_bk_yr4,
        Cashbook_Month           As Csh_Bk_Mnth4,
        ACCOUNT_NO               AS acc_no4,
Sum(Dr_Amount) As Dra,
  SUM(cr_amount)as cra
From Fas_Brs_Transaction
Where Account_No=4181 And 
((Extract(Year From Passbook_Date)=2010
And Extract(Month From Passbook_Date)   >10)
And
(Cashbook_Year                       <2010
)
)
AND doc_type    in('P','SC')
GROUP BY ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_YEAR,
        Cashbook_Month,
        ACCOUNT_NO

)
Group By Acc_U_Id4,Acc_Off_Id4,Acc_No4
)
)Group By Acc_U_Id4,Acc_Off_Id4,Acc_No4
    )g
  ON x.acc_u_id    =g.acc_u_id4
  AND x.acc_off_id = g.acc_off_id4
  AND x.acc_no     = g.acc_no4
  LEFT OUTER JOIN
    (SELECT ACCOUNTING_UNIT_ID AS acc_u_id5,
      ACCOUNTING_FOR_OFFICE_ID AS acc_off_id5,
      CASHBOOK_YEAR            AS csh_bk_yr5,
      CASHBOOK_MONTH           AS csh_bk_mnth5,
      ACCOUNT_NO               AS acc_no5,
      SUM(CR_AMOUNT-DR_AMOUNT) AS A_6b
    FROM FAS_BRS_TRANSACTION
    WHERE accounting_unit_id    = $P{UnitId}
    AND accounting_for_office_id=$P{OfficeId}
    AND cashbook_year           =$P{cbyear}
    AND ACCOUNT_NO              = $P{accNo}
    AND cashbook_month          = $P{cbmonth}
    AND TWAD_OR_NON_TWAD        ='NT'
    GROUP BY ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      ACCOUNT_NO
    )g1
  ON x.acc_u_id       =g1.acc_u_id5
  AND x.acc_off_id    = g1.acc_off_id5
  AND x.csh_bk_yr     = g1.csh_bk_yr5
  AND x.csh_bk_mnth   = g1.csh_bk_mnth5
  AND x.acc_no        = g1.acc_no5
  )YY ON XX.acc_u_id6 = YY.acc_u_id
AND XX.acc_off_id6    = YY.acc_off_id
AND XX.csh_bk_yr6     = YY.csh_bk_yr
AND Xx.Csh_Bk_Mnth6   = Yy.Csh_Bk_Mnth
AND XX.acc_no6        = YY.acc_no)]]></queryString>

	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="BRANCH_NAME" class="java.lang.String"/>
	<field name="ACC_U_ID" class="java.math.BigDecimal"/>
	<field name="ACC_OFF_ID" class="java.math.BigDecimal"/>
	<field name="CSH_BK_YR" class="java.math.BigDecimal"/>
	<field name="CSH_BK_MNTH" class="java.math.BigDecimal"/>
	<field name="ACC_NO" class="java.math.BigDecimal"/>
	<field name="A_1" class="java.math.BigDecimal"/>
	<field name="A_2A" class="java.math.BigDecimal"/>
	<field name="A_2B" class="java.math.BigDecimal"/>
	<field name="A_2C" class="java.math.BigDecimal"/>
	<field name="A_2D" class="java.math.BigDecimal"/>
	<field name="A_2E" class="java.math.BigDecimal"/>
	<field name="A_3" class="java.math.BigDecimal"/>
	<field name="A_4" class="java.math.BigDecimal"/>
	<field name="A_5" class="java.math.BigDecimal"/>
	<field name="A_6A" class="java.math.BigDecimal"/>
	<field name="A_6B" class="java.math.BigDecimal"/>
	<field name="A_6C" class="java.math.BigDecimal"/>
	<field name="PASSBOOK_BALANCE" class="java.math.BigDecimal"/>

	<variable name="four_total" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{A_4}.add($P{four_b})]]></variableExpression>
	</variable>
	<variable name="fiveDiff" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{A_6A}.subtract( $P{four_b} )]]></variableExpression>
	</variable>
	<variable name="total_five" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{A_3}.subtract($V{four_total})]]></variableExpression>
	</variable>

		<group  name="bankName" isStartNewPage="true" isReprintHeaderOnEachPage="true" >
			<groupExpression><![CDATA[]]></groupExpression>
			<groupHeader>
			<band height="100"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="6"
						y="4"
						width="128"
						height="13"
						key="staticText-21"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement>
						<font isBold="true"/>
					</textElement>
				<text><![CDATA[A/c Unit Name : ]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="6"
						y="28"
						width="142"
						height="21"
						key="staticText-22"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement>
						<font isBold="true"/>
					</textElement>
				<text><![CDATA[Bank Name & a/c nO    :    ]]></text>
				</staticText>
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="138"
						y="3"
						width="384"
						height="18"
						key="textField"/>
					<box></box>
					<textElement>
						<font/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$P{UnitName}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="138"
						y="28"
						width="387"
						height="21"
						key="textField-6"/>
					<box></box>
					<textElement>
						<font/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{BANK_NAME}+" & "+$P{accNo}]]></textFieldExpression>
				</textField>
