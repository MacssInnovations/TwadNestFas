	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[SELECT min.minor_head_code m_code,lpad(min.alias_no,3,0)||'-'||m_code.minor_head_desc as minor_head_code,
    min.Activity_id,
    (select activityname from ACTIVITY where ACTIVITYID=  min.Activity_id)act_name,
    SUM(min.debit-min.credit)amt,
    m_code.minor_head_desc
  FROM
    (SELECT a.CASHBOOK_YEAR,
      a.CASHBOOK_MONTH,
      d.minor_head_code,
      a.ACCOUNT_HEAD_CODE,
      a.CURRENT_MONTH_DEBIT debit,
      a.CURRENT_MONTH_CREDIT credit,
      ah.Activity_id,ah.alias_no
      --(a.CURRENT_MONTH_DEBIT-a.CURRENT_MONTH_CREDIT) AS amt
    FROM FAS_TRIAL_BALANCE a,
      com_mst_account_heads c,
      com_mst_minor_heads d,
      activity_head ah
    WHERE To_Date((a.cashbook_month
      ||'-'
      || a.cashbook_year),'mm-yyyy') BETWEEN To_Date( 4
      ||'-'
      ||2010,'mm-yyyy')
    AND to_date( 3
      ||'-'
      ||2011,'mm-yyyy')
    AND a.ACCOUNT_HEAD_CODE=c.account_head_code
    AND c.minor_head_code  =d.minor_head_code
    AND c.major_head_code  ='A'
    AND ah.headofaccount   =a.account_head_code
    AND ah.minor_head_code =d.minor_head_code
      -- and a.account_head_code in (700201,700202)
    ORDER BY c.minor_head_code
    )MIN,
    com_mst_minor_heads m_code
  WHERE m_code.minor_head_code=min.minor_head_code
  GROUP BY min.minor_head_code,min.alias_no,
    min.Activity_id,
    m_code.minor_head_desc order by min.alias_no]]></queryString>

