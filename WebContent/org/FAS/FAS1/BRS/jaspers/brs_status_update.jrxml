	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="heading" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[Select B.Accounting_Unit_Id As Unitid,
(Select U.Accounting_Unit_Name From Fas_Mst_Acct_Units U Where U.Accounting_Unit_Id=B.Accounting_Unit_Id) As Unitname,
Brs_Year AS manual_year,
Brs_Month     As Manual_Month,
Case When Brs_Month=1 Then 'January' 
  When Brs_Month=2 Then 'February' 
  When Brs_Month=3 Then 'March' 
  When Brs_Month=4 Then 'April' 
  When Brs_Month=5 Then 'May' 
  When Brs_Month=6 Then 'June' 
  When Brs_Month=7 Then 'July' 
  When Brs_Month=8 Then 'August' 
  When Brs_Month=9 Then 'September' 
  When Brs_Month=10 Then 'October' 
  When Brs_Month=11 Then 'November' 
  When Brs_Month=12 Then 'December'
  When Brs_Month is null Then '--'
  End As Manual_Monthdesc,
  decode(Brs_Online_Year,null,'--',Brs_Online_Year)as Brs_Online_Year,
  decode(Brs_Online_Month,null,'--',Brs_Online_Month)as Brs_Online_Month,
  Case When Brs_Online_Month=1 Then 'January' 
  When Brs_Online_Month=2 Then 'February' 
  When Brs_Online_Month=3 Then 'March' 
  When Brs_Online_Month=4 Then 'April' 
  When Brs_Online_Month=5 Then 'May' 
  When Brs_Online_Month=6 Then 'June' 
  When Brs_Online_Month=7 Then 'July' 
  When Brs_Online_Month=8 Then 'August' 
  When Brs_Online_Month=9 Then 'September' 
  When Brs_Online_Month=10 Then 'October' 
  When Brs_Online_Month=11 Then 'November' 
  When Brs_Online_Month=12 Then 'December'
    When Brs_Online_Month is null Then '--'
  end as online_monthDesc
  
FROM BRS_STATUS_UPDATE b where
 Tb_Year=$P{cashbookyear}
AND TB_MONTH =$P{cashbookmonth}]]></queryString>

	<field name="UNITID" class="java.math.BigDecimal"/>
	<field name="UNITNAME" class="java.lang.String"/>
	<field name="MANUAL_YEAR" class="java.math.BigDecimal"/>
	<field name="MANUAL_MONTH" class="java.lang.String"/>
	<field name="MANUAL_MONTHDESC" class="java.lang.String"/>
	<field name="BRS_ONLINE_YEAR" class="java.lang.String"/>
	<field name="BRS_ONLINE_MONTH" class="java.lang.String"/>
	<field name="ONLINE_MONTHDESC" class="java.lang.String"/>

