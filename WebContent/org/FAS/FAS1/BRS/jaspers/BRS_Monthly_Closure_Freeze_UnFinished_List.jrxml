	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select rownum as slno, ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,ACCOUNTING_UNIT_NAME from 
(select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,ACCOUNTING_UNIT_NAME from
(
select ACCOUNTING_UNIT_ID ,ACCOUNTING_UNIT_OFFICE_ID as ACCOUNTING_FOR_OFFICE_ID from FAS_MST_ACCT_UNITS

MINUS

select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID
from FAS_BRS_MONTHLY_CLOSURE where 
CASHBOOK_YEAR=$P{cbyear} and
CASHBOOK_MONTH=$P{cbmonth}
)x
left outer join
(
select ACCOUNTING_UNIT_ID as acc_id,ACCOUNTING_UNIT_OFFICE_ID,
ACCOUNTING_UNIT_NAME from FAS_MST_ACCT_UNITS 
)y 
on
x.ACCOUNTING_UNIT_ID = y.acc_id and 
x.ACCOUNTING_FOR_OFFICE_ID = y.ACCOUNTING_UNIT_OFFICE_ID order by ACCOUNTING_UNIT_ID )]]></queryString>

	<field name="SLNO" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>

