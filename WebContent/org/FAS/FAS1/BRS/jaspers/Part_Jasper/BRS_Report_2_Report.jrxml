	<field name="S4C" class="java.math.BigDecimal"/>
	<field name="S5A" class="java.math.BigDecimal"/>
	<field name="S5B" class="java.math.BigDecimal"/>
	<field name="S4D" class="java.math.BigDecimal"/>
	<field name="S4E" class="java.math.BigDecimal"/>
	<field name="S4_FINAL" class="java.math.BigDecimal"/>
	<field name="S4F" class="java.math.BigDecimal"/>
	<field name="S5" class="java.math.BigDecimal"/>
	<field name="S5A_I" class="java.math.BigDecimal"/>
	<field name="S5_A_DIFFERENCE" class="java.math.BigDecimal"/>
	<field name="CLOSING_BAL" class="java.math.BigDecimal"/>

	<variable name="four_total" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{S4A}.add($F{S4B})]]></variableExpression>
	</variable>
	<variable name="fiveDiff" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{S5A}.subtract( $F{S5B} )]]></variableExpression>
	</variable>
	<variable name="final_four" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{S4C}.add($V{four_total})]]></variableExpression>
	</variable>
	<variable name="closing_bal" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{S3}.subtract($V{final_four})]]></variableExpression>
	</variable>
	<variable name="five_difference" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$P{four_c}.add($P{four_b})]]></variableExpression>
	</variable>
	<variable name="tally_final" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{closing_bal}.subtract($F{S5A}.subtract($P{four_b}))]]></variableExpression>
	</variable>
	<variable name="two_end" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{fiveDiff}.subtract($V{closing_bal})]]></variableExpression>
	</variable>
	<variable name="five_fiveb" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{S5A}.subtract( $F{S5B} )]]></variableExpression>
	</variable>
	<variable name="final_diiff" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{S5}.subtract($F{CLOSING_BAL})]]></variableExpression>
	</variable>

