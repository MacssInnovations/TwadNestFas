	<field name="TWAD_AMOUNT" class="java.math.BigDecimal"/>
	<field name="FOR_NT_CR" class="java.math.BigDecimal"/>
	<field name="FOR_NT_DR" class="java.math.BigDecimal"/>
	<field name="TORT" class="java.math.BigDecimal"/>
	<field name="UPTO_REASON45_CR" class="java.math.BigDecimal"/>
	<field name="UPTO_REASON45_DR" class="java.math.BigDecimal"/>
	<field name="FOR_REASON45_CR" class="java.math.BigDecimal"/>
	<field name="FOR_REASON45_DR" class="java.math.BigDecimal"/>

	<variable name="pass_Tot_CR" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{CHEQUE_CASHED}.add( $F{FOR_NT_CR} )]]></variableExpression>
	</variable>
	<variable name="pass_Tot_DR" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{TWAD_AMOUNT}.add( $F{FOR_NT_DR} )]]></variableExpression>
	</variable>
	<variable name="Reconcile_CR" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{UPTO_REASON45_CR}.add( $F{FOR_REASON45_CR})]]></variableExpression>
	</variable>
	<variable name="Reconcile_DR" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{UPTO_REASON45_DR}.add( $F{FOR_REASON45_DR} )]]></variableExpression>
	</variable>
	<variable name="grant_tot_CR" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{pass_Tot_CR}.subtract( $V{Reconcile_CR} )]]></variableExpression>
	</variable>
	<variable name="grant_tot_DR" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{pass_Tot_DR}.subtract( $V{Reconcile_DR} )]]></variableExpression>
	</variable>
	<variable name="difference" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{grant_tot_CR}.subtract( $V{grant_tot_DR} )]]></variableExpression>
	</variable>
	<variable name="diff" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{difference}.abs()]]></variableExpression>
	</variable>

