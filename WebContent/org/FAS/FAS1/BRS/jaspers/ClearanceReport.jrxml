	<variable name="fiveDiff1" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{five_minus_one}.subtract( $P{four_b} )]]></variableExpression>
	</variable>
	<variable name="DplusE" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$P{bank_credit_bdecimal}.add($P{i4_four_new})]]></variableExpression>
	</variable>
	<variable name="five_minus_one" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
	</variable>
	<variable name="sub_both_five" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{five_minus_one}.subtract( $P{four_b} )]]></variableExpression>
	</variable>
	<variable name="aPLUSbcf" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
	</variable>
	<variable name="3_minuss_4" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
	</variable>
	<variable name="new_var_close" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{sub_both_five}.subtract($V{3_minuss_4})]]></variableExpression>
	</variable>
	<variable name="abcfPLUS" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
	</variable>
	<variable name="4_MINUS" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{abcfPLUS}.subtract($V{DplusE})]]></variableExpression>
	</variable>
	<variable name="3MINUSS4" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
	</variable>
	<variable name="LAST_VARIABLE" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{sub_both_five}.subtract($V{3MINUSS4})]]></variableExpression>
	</variable>
