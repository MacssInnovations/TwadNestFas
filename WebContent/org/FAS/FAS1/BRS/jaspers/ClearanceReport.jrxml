<jasperReport
		 name="ClearanceReport"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="736"
		 pageHeight="963"
		 columnWidth="676"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cbmonth_name" isForPrompting="false" class="java.lang.String"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<parameter name="four_b" isForPrompting="false" class="java.math.BigDecimal"/>
	<parameter name="four_c" isForPrompting="false" class="java.math.BigDecimal"/>
	<parameter name="UnitName" isForPrompting="false" class="java.lang.String"/>
	<parameter name="excess_db" isForPrompting="false" class="java.math.BigDecimal"/>
	<parameter name="last_date_one" isForPrompting="false" class="java.lang.String"/>
	<parameter name="sql" isForPrompting="false" class="java.lang.String"/>
	<parameter name="bank_credit_bdecimal" isForPrompting="false" class="java.math.BigDecimal"/>
	<parameter name="i4_four_new" isForPrompting="false" class="java.math.BigDecimal"/>
	<parameter name="five_a1" isForPrompting="false" class="java.math.BigDecimal"/>
	<parameter name="five_a1_ct_mn" isForPrompting="false" class="java.math.BigDecimal"/>
	<queryString><![CDATA[SELECT distinct  a.REF_AMOUNT,
  a.accounting_unit_id,
u.accounting_unit_name,
o.office_name,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.account_no,
 A.DR_AMOUNT as dramount,
 to_char(a.DOC_DATE,'dd/mm/yyyy') as docdate,

  a.Sl_NO,
  c.DOC_TYPE,
  to_char(a.CLEARED_DATE,'dd/mm/yyyy') as cleraedDte, 
  c.account_no,
 case when  a.TWAD_OR_NON_TWAD='NT' then 'Non-Twad'
 when  a.TWAD_OR_NON_TWAD='T' then 'Twad' end as TWAD_OR_NON_TWAD,
  c.cr_amount,
  c.dr_amount,
  CASE
    WHEN c.cr_amount>0
    THEN 'CR'
    WHEN c.dr_amount>0
    THEN 'DR'
  END AS CRorDR,
c.transaction_type,
  b.TRANS_DESC
FROM FAS_BRS_CLEARANCE A,
 FAS_BRS_TRANSACTION_TYPE b,
  FAS_BRS_TRANSACTION c,FAS_MST_ACCT_UNITS u,COM_MST_OFFICES o
WHERE a.accounting_unit_id     =c.accounting_unit_id
AND A.ACCOUNTING_FOR_OFFICE_ID =C.ACCOUNTING_FOR_OFFICE_ID
AND A.CASHBOOK_YEAR     =C.CASHBOOK_YEAR
AND A.CASHBOOK_MONTH =C.CASHBOOK_MONTH
AND a.account_no               =c.account_no
AND A.REF_DOC_NO                   =C.DOC_NO
AND A.REF_DOC_TYPE                 =C.DOC_TYPE
and A.DR_AMOUNT=C.CR_AMOUNT
AND A.ACCOUNTING_UNIT_ID=$P{UnitId}
AND A.ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
AND A.CASHBOOK_YEAR=$P{cbyear}
AND A.CASHBOOK_MONTH=$P{cbmonth}
and a.account_no =$P{accNo}
AND b.trans_code               =c.transaction_type
and u.accounting_unit_id     =c.accounting_unit_id
AND o.office_id =c.accounting_for_office_id
AND C.CLEARED_BASED_ON_FOLLOWUP='Y'
AND c.IS_IT_CLEARING_ENTRY     ='Y']]></queryString>

	<field name="REF_AMOUNT" class="java.lang.Double"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
