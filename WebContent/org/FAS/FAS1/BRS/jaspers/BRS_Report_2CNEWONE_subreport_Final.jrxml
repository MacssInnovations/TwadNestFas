	</variable>
	<variable name="tot_noentry_dr" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{Var_dr}.add( $P{Var_dr_noentry} )]]></variableExpression>
	</variable>
