	</variable>
	<variable name="grand_tot_dr" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$P{grand_tot_dr}.subtract( $V{tot_noentry_dr} )]]></variableExpression>
	</variable>
