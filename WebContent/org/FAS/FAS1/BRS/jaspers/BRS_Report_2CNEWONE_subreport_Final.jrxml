		<variableExpression><![CDATA[$P{grand_tot_cr}.subtract( $V{tot_noentry_cr} )]]></variableExpression>
	</variable>
	<variable name="difference" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{grand_tot_dr}.subtract($V{grand_tot_cr})]]></variableExpression>
	</variable>
