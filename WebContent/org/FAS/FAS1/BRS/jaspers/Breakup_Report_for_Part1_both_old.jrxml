	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="cbmonth_name" isForPrompting="false" class="java.lang.String"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<parameter name="openingbalance" isForPrompting="true" class="java.math.BigDecimal"/>
	<queryString><![CDATA[SELECT ACCOUNTING_UNIT_ID,
  ACCOUNTING_FOR_OFFICE_ID,
  CASHBOOK_YEAR,
  CASHBOOK_MONTH,
  OFFICE_NAME,
  BANK_NAME,
  BRANCH_NAME,
  ACCOUNT_NO,
  rownum AS SL_NO,
  ENTRY_DATE,
  DOC_TYPE,
  doc_date,
  NO1,
  PASSBOOK_DATE,
  OPENING_BALANCE,
  AMOUNT_REMITTED,
  DECODE(AMOUNT_IN_PASSBOOK,NULL,0,AMOUNT_IN_PASSBOOK) AS AMOUNT_IN_PASSBOOK,
  CR_AMOUNT,
  DECODE(REASON_FOR_DIFFERENCE,NULL,'-',REASON_FOR_DIFFERENCE) AS REASON_FOR_DIFFERENCE1,
  DECODE(ACTION_TAKEN,NULL,'-',ACTION_TAKEN)                   AS ACTION_TAKEN1,
  TWAD_OR_NON_TWAD,
  DECODE(amount_in_passbook_NT,NULL,0,amount_in_passbook_NT) AS amount_in_passbook_NT
FROM
  (SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    OFFICE_NAME,
    ACCOUNT_NO,
    ENTRY_DATE,
    DOC_TYPE,
  doc_date,
    NO1,
    PASSBOOK_DATE,
    OPENING_BALANCE,
    AMOUNT_REMITTED,
    AMOUNT_IN_PASSBOOK,
    CR_AMOUNT,
    REASON_FOR_DIFFERENCE,
    ACTION_TAKEN,
    TWAD_OR_NON_TWAD,
    amount_in_passbook_NT
  FROM
    (SELECT accounting_unit_id,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      account_no,
      entry_date,
      no1,
      passbook_date,
      cheque_dd_no,
      doc_type,
  doc_date,
	    amount_remitted,
    -- SUM(amount_remitted) AS amount_remitted,
      cr_amount,
      follow_up_action_required,
      REASON_FOR_DIFFERENCE,
      ACTION_TAKEN,
      TWAD_OR_NON_TWAD,
     amount_in_passbook,
     -- SUM(amount_in_passbook) AS amount_in_passbook,
      amount_in_passbook_NT
    FROM
      (SELECT accounting_unit_id,
  accounting_for_office_id,
  cashbook_year,
  cashbook_month,
  account_no,
  entry_date,
  no1,
  passbook_date,
  cheque_dd_no,
  doc_type,
  doc_date,
  -- amount_remitted,
  SUM(amount_remitted) AS amount_remitted,
  cr_amount,
  follow_up_action_required,
  REASON_FOR_DIFFERENCE,
  ACTION_TAKEN,
  TWAD_OR_NON_TWAD,
  -- amount_in_passbook,
  SUM(amount_in_passbook) AS amount_in_passbook,
  amount_in_passbook_NT
FROM
  (SELECT accounting_unit_id,
    accounting_for_office_id,
    cashbook_year,
    cashbook_month,
    account_no,
    entry_date,
    cheque_dd_no AS no1,
    passbook_date,
    cheque_dd_no,
    doc_type,
  doc_date,
    (cr_amount -dr_amount) AS amount_remitted,
    0                      AS cr_amount,
    follow_up_action_required,
    REASON_FOR_DIFFERENCE,
    ACTION_TAKEN,
    TWAD_OR_NON_TWAD,
    amount_in_passbook,
    CASE
      WHEN TWAD_OR_NON_TWAD='NT'
      THEN 0
    END AS amount_in_passbook_NT
  FROM fas_brs_transaction
  WHERE accounting_unit_id     =$P{UnitId}
  AND accounting_for_office_id =$P{OfficeId}
  And Extract (Month From Passbook_Date )=$P{cbmonth}
  And Extract (Year From Passbook_Date )=$P{cbyear}
  AND account_no               =$P{accNo}
  AND TWAD_OR_NON_TWAD         ='T'
AND DOC_TYPE!='FT from Office'
  )
GROUP BY accounting_unit_id,
  accounting_for_office_id,
  cashbook_year,
  cashbook_month,
  account_no,
  entry_date,
  no1,
  passbook_date,
  cheque_dd_no,
  doc_type,
  doc_date,
  cr_amount,
  follow_up_action_required,
  REASON_FOR_DIFFERENCE,
  ACTION_TAKEN,
  TWAD_OR_NON_TWAD,
  amount_in_passbook_NT
      UNION ALL
      SELECT accounting_unit_id,
        accounting_for_office_id,
        cashbook_year,
        cashbook_month,
        account_no,
        entry_date,
        cheque_dd_no AS no1,
        passbook_date,
        cheque_dd_no,
        doc_type,
	doc_date,
        (cr_amount -dr_amount) AS amount_remitted,
        cr_amount,
        follow_up_action_required,
        REASON_FOR_DIFFERENCE,
        ACTION_TAKEN,
        TWAD_OR_NON_TWAD,
        CASE
          WHEN TWAD_OR_NON_TWAD='T'
          THEN 0
        END                AS amount_in_passbook,
        amount_in_passbook AS amount_in_passbook_NT
      FROM fas_brs_transaction
      WHERE accounting_unit_id     =$P{UnitId}
      AND accounting_for_office_id =$P{OfficeId}
        And Extract (Month From Passbook_Date )=$P{cbmonth}
  And Extract (Year From Passbook_Date )=$P{cbyear}
      AND account_no               =$P{accNo}
      AND TWAD_OR_NON_TWAD         ='NT'
AND DOC_TYPE!='FT from Office'
      )
    )a
  LEFT OUTER JOIN
    (SELECT acc_unit_id1,
      acc_off_id1,
      csh_bk_yr1,
      csh_bk_mnth1,
      acc_no1,
      OPENING_BALANCE
    FROM
      (SELECT ACCOUNTING_UNIT_ID AS acc_unit_id1,
        ACCOUNTING_FOR_OFFICE_ID AS acc_off_id1,
        CASHBOOK_YEAR            AS csh_bk_yr1,
        CASHBOOK_MONTH           AS csh_bk_mnth1,
        ACCOUNT_NO               AS acc_no1,
        ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_YEAR,
        CASHBOOK_MONTH,
        ACCOUNT_NO,
        DECODE(SUM(OB_PART1),NULL,0,SUM(OB_PART1)) AS OPENING_BALANCE
      FROM FAS_BRS_OB
      WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
      AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
      AND CASHBOOK_YEAR           =$P{cbyear}
      AND CASHBOOK_MONTH          =$P{cbmonth}
      AND ACCOUNT_NO              =$P{accNo}
      GROUP BY ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_YEAR,
        CASHBOOK_MONTH,
        ACCOUNT_NO
      )
    )a1
  ON a.ACCOUNTING_UNIT_ID        = a1.acc_unit_id1
  AND a.ACCOUNTING_FOR_OFFICE_ID = a1.acc_off_id1
  AND a.CASHBOOK_YEAR            = a1.csh_bk_yr1
  AND a.CASHBOOK_MONTH           = a1.csh_bk_mnth1
  AND a.ACCOUNT_NO               = a1.acc_no1
  LEFT OUTER JOIN
    (SELECT OFFICE_ID,OFFICE_NAME FROM COM_MST_OFFICES
    )aa
  ON a.ACCOUNTING_FOR_OFFICE_ID = aa.OFFICE_ID
  )x
LEFT OUTER JOIN
  (SELECT ACCOUNTING_UNIT_ID AS acc_unit_id,
    ACCOUNTING_FOR_OFFICE_ID AS acc_off_id,
    CASHBOOK_YEAR            AS csh_bk_yr,
    CASHBOOK_MONTH           AS csh_bk_mnth,
    ACCOUNT_NO               AS acc_no,
    BANK_NAME,
    BRANCH_NAME
  FROM
    (SELECT ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      ACCOUNT_NO,
      BANK_ID,
      BRANCH_ID
    FROM FAS_BRS_MASTER
    WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
    AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
    AND CASHBOOK_YEAR           =$P{cbyear}
    AND CASHBOOK_MONTH          =$P{cbmonth}
    AND ACCOUNT_NO              =$P{accNo}
    )b
  LEFT OUTER JOIN
    (SELECT BRANCH_ID AS brnch_id,
      BANK_ID         AS bnk_id,
      BRANCH_NAME
    FROM FAS_MST_BANK_BRANCHES
    )c
  ON b.BANK_ID    = c.bnk_id
  AND b.BRANCH_ID = c.brnch_id
  LEFT OUTER JOIN
    (SELECT BANK_ID AS bnk_id1,BANK_NAME FROM FAS_MST_BANKS
    )d
  ON b.BANK_ID                 = d.bnk_id1
  )y ON x.ACCOUNTING_UNIT_ID   = y.acc_unit_id
AND x.ACCOUNTING_FOR_OFFICE_ID = y.acc_off_id
AND x.CASHBOOK_YEAR            = y.csh_bk_yr
--AND x.CASHBOOK_MONTH           = y.csh_bk_mnth
AND x.ACCOUNT_NO               = y.acc_no
ORDER BY PASSBOOK_DATE,doc_date]]></queryString>

