	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<parameter name="s_head" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT  TO_CHAR(DECODE(CCC.UNIT_ID,NULL,DDD.ACCOUNTING_UNIT_ID,CCC.UNIT_ID),'000') AS UNIT_ID ,
DECODE(CCC.UNIT_ID,NULL,DDD.ACCOUNTING_UNIT_NAME,CCC.UNIT_name) UNIT_NAME,
    CCC.BANKNAME,
    CCC.BANK_AC_NO,
    CCC.BANK_AC_NO1,

    CCC.AC_OPERATIONAL_MODE_ID,
    CCC.BANKNAME1,

    CCC.AC_OPERATIONAL_MODE_ID1,

    DDD.AC_OPERATIONAL_MODE_ID AS AC_OPERATIONAL_MODE_ID2,
    DDD.BANK_AC_NO AS BANK_AC_NO2,
   DDD.BANKNAME AS BANKNAME2,
  CCC.FREEZED1,
      CCC.PROGERSS1,
       CCC.FREEZED2,
       CCC.PROGERSS2,
          DDD.FREEZED AS FREEZED3,
        DDD.PROGERSS AS PROGERSS3
    
FROM
  (SELECT 
  DECODE(AAA.ACCOUNTING_UNIT_ID,NULL,BBB.ACCOUNTING_UNIT_ID,AAA.ACCOUNTING_UNIT_ID) UNIT_ID,
  DECODE(aaa.Accounting_Unit_Id,NULL,BBB.ACCOUNTING_UNIT_NAME,aaa.ACCOUNTING_UNIT_NAME) UNIT_name,
    aaa.BANKNAME,
    AAA.BANK_AC_NO,
    bbb.BANK_AC_NO AS BANK_AC_NO1,
    AAA.ACCOUNTING_UNIT_NAME,
    AAA.AC_OPERATIONAL_MODE_ID,
    BBB.BANKNAME AS BANKNAME1,
    BBB.ACCOUNTING_UNIT_NAME AS ACCOUNTING_UNIT_NAME1,
    BBB.AC_OPERATIONAL_MODE_ID AS AC_OPERATIONAL_MODE_ID1,
 AAA.FREEZED AS FREEZED1,
        AAA.PROGERSS AS PROGERSS1,
        BBB.FREEZED AS FREEZED2,
        BBB.PROGERSS AS PROGERSS2
  FROM
    (SELECT
      (SELECT BANK_SHORT_NAME FROM FAS_MST_BANKS BANK WHERE BANK.BANK_ID=F.BANK_ID
      )AS BANKNAME,
      U.ACCOUNTING_UNIT_NAME,
      -- TO_CHAR(f.Accounting_Unit_Id,'000')AS Accounting_Unit_Id_1 ,
      f.*
    FROM
      (SELECT AA.*,
        ''  AS FREEZED,
        'Y' AS PROGERSS
      FROM
        (SELECT DISTINCT Balnce.Accounting_Unit_Id,
          BALNCE.BANK_AC_NO,
          BALNCE.BANK_ID,
          BALNCE.AC_OPERATIONAL_MODE_ID
        FROM FAS_MST_BANK_BALANCE balnce
        INNER JOIN brs_start_month_and_year c
        ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
        AND Balnce.Bank_Ac_No       =C.Account_No
        INNER JOIN Fas_Brs_Transaction T
        ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
        AND BALNCE.BANK_AC_NO        =T.ACCOUNT_NO
        AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%Main%'
        MINUS
        SELECT DISTINCT Balnce.Accounting_Unit_Id,
          BALNCE.BANK_AC_NO,
          BALNCE.BANK_ID,
          BALNCE.AC_OPERATIONAL_MODE_ID
        FROM FAS_MST_BANK_BALANCE balnce
        INNER JOIN brs_start_month_and_year c
        ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
        AND Balnce.Bank_Ac_No       =C.Account_No
        INNER JOIN Fas_Brs_Transaction T
        ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
        AND BALNCE.BANK_AC_NO        =T.ACCOUNT_NO
        AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%Main%'
        INNER JOIN Fas_Brs_Monthly_Closure D
        ON BALNCE.ACCOUNTING_UNIT_ID=D.ACCOUNTING_UNIT_ID
        AND BALNCE.BANK_AC_NO       = D.ACCOUNT_NO
        AND D.STATUS                ='Y'
        ) AA
      UNION ALL
      SELECT DISTINCT Balnce.Accounting_Unit_Id,
        BALNCE.BANK_AC_NO,
        BALNCE.BANK_ID,
        BALNCE.AC_OPERATIONAL_MODE_ID,
        'Y' AS FREEZED,
        ''  AS progerss
      FROM FAS_MST_BANK_BALANCE balnce
      INNER JOIN brs_start_month_and_year c
      ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
      AND Balnce.Bank_Ac_No       =C.Account_No
      INNER JOIN Fas_Brs_Transaction T
      ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
      AND BALNCE.BANK_AC_NO        =T.ACCOUNT_NO
      AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%Main%'
      INNER JOIN Fas_Brs_Monthly_Closure D
      ON BALNCE.ACCOUNTING_UNIT_ID=D.ACCOUNTING_UNIT_ID
      AND BALNCE.BANK_AC_NO       = D.ACCOUNT_NO
      AND D.STATUS                ='Y'
      )F
    INNER JOIN Fas_Mst_Acct_Units U
    ON f.ACCOUNTING_UNIT_ID=U.ACCOUNTING_UNIT_ID
    )AAA
  FULL OUTER JOIN
    (SELECT
      (SELECT BANK_SHORT_NAME FROM FAS_MST_BANKS BANK WHERE BANK.BANK_ID=F.BANK_ID
      )AS BANKNAME,
      U.ACCOUNTING_UNIT_NAME,
      --  TO_CHAR(f.Accounting_Unit_Id,'000')AS Accounting_Unit_Id ,
      f.*
    FROM
      (SELECT AA.*,
        ''  AS FREEZED,
        'Y' AS PROGERSS
      FROM
        (SELECT DISTINCT Balnce.Accounting_Unit_Id,
          BALNCE.BANK_AC_NO,
          BALNCE.BANK_ID,
          BALNCE.AC_OPERATIONAL_MODE_ID
        FROM FAS_MST_BANK_BALANCE balnce
        INNER JOIN brs_start_month_and_year c
        ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
        AND Balnce.Bank_Ac_No       =C.Account_No
        INNER JOIN Fas_Brs_Transaction T
        ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
        AND BALNCE.BANK_AC_NO        =T.ACCOUNT_NO
        AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%Support%'
        MINUS
        SELECT DISTINCT Balnce.Accounting_Unit_Id,
          BALNCE.BANK_AC_NO,
          BALNCE.BANK_ID,
          BALNCE.AC_OPERATIONAL_MODE_ID
        FROM FAS_MST_BANK_BALANCE balnce
        INNER JOIN brs_start_month_and_year c
        ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
        AND Balnce.Bank_Ac_No       =C.Account_No
        INNER JOIN Fas_Brs_Transaction T
        ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
        AND BALNCE.BANK_AC_NO        =T.ACCOUNT_NO
        AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%Support%'
        INNER JOIN Fas_Brs_Monthly_Closure D
        ON BALNCE.ACCOUNTING_UNIT_ID=D.ACCOUNTING_UNIT_ID
        AND BALNCE.BANK_AC_NO       = D.ACCOUNT_NO
        AND D.STATUS                ='Y'
        ) AA
      UNION ALL
      SELECT DISTINCT Balnce.Accounting_Unit_Id,
        BALNCE.BANK_AC_NO,
        BALNCE.BANK_ID,
        BALNCE.AC_OPERATIONAL_MODE_ID,
        'Y' AS FREEZED,
        ''  AS progerss
      FROM FAS_MST_BANK_BALANCE balnce
      INNER JOIN brs_start_month_and_year c
      ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
      AND Balnce.Bank_Ac_No       =C.Account_No
      INNER JOIN Fas_Brs_Transaction T
      ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
      AND BALNCE.BANK_AC_NO        =T.ACCOUNT_NO
      AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%Support%'
      INNER JOIN Fas_Brs_Monthly_Closure D
      ON BALNCE.ACCOUNTING_UNIT_ID=D.ACCOUNTING_UNIT_ID
      AND BALNCE.BANK_AC_NO       = D.ACCOUNT_NO
      AND D.STATUS                ='Y'
      )F
    INNER JOIN Fas_Mst_Acct_Units U
    ON F.ACCOUNTING_UNIT_ID       =U.ACCOUNTING_UNIT_ID
    )BBB ON AAA.ACCOUNTING_UNIT_ID=BBB.ACCOUNTING_UNIT_ID
  )CCC
FULL OUTER JOIN
  (SELECT
    (SELECT BANK_SHORT_NAME FROM FAS_MST_BANKS BANK WHERE BANK.BANK_ID=F.BANK_ID
    )AS BANKNAME,
    U.ACCOUNTING_UNIT_NAME,
    --  TO_CHAR(f.Accounting_Unit_Id,'000')AS Accounting_Unit_Id ,
    f.*
  FROM
    (SELECT AA.*,
      ''  AS FREEZED,
      'Y' AS PROGERSS
    FROM
      (SELECT DISTINCT Balnce.Accounting_Unit_Id,
        BALNCE.BANK_AC_NO,
        BALNCE.BANK_ID,
        BALNCE.AC_OPERATIONAL_MODE_ID
      FROM FAS_MST_BANK_BALANCE balnce
      INNER JOIN brs_start_month_and_year c
      ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
      AND Balnce.Bank_Ac_No       =C.Account_No
      INNER JOIN Fas_Brs_Transaction T
      ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
      AND BALNCE.BANK_AC_NO        =T.ACCOUNT_NO
      AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%FDW%'
      MINUS
      SELECT DISTINCT Balnce.Accounting_Unit_Id,
        BALNCE.BANK_AC_NO,
        BALNCE.BANK_ID,
        BALNCE.AC_OPERATIONAL_MODE_ID
      FROM FAS_MST_BANK_BALANCE balnce
      INNER JOIN brs_start_month_and_year c
      ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
      AND Balnce.Bank_Ac_No       =C.Account_No
      INNER JOIN Fas_Brs_Transaction T
      ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
      AND BALNCE.BANK_AC_NO        =T.ACCOUNT_NO
      AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%FDW%'
      INNER JOIN Fas_Brs_Monthly_Closure D
      ON BALNCE.ACCOUNTING_UNIT_ID=D.ACCOUNTING_UNIT_ID
      AND BALNCE.BANK_AC_NO       = D.ACCOUNT_NO
      AND D.STATUS                ='Y'
      ) AA
    UNION ALL
    SELECT DISTINCT Balnce.Accounting_Unit_Id,
      BALNCE.BANK_AC_NO,
      BALNCE.BANK_ID,
      BALNCE.AC_OPERATIONAL_MODE_ID,
      'Y' AS FREEZED,
      ''  AS progerss
    FROM FAS_MST_BANK_BALANCE balnce
    INNER JOIN brs_start_month_and_year c
    ON Balnce.Accounting_Unit_Id=C.Accounting_Unit_Id
    AND Balnce.Bank_Ac_No       =C.Account_No
    INNER JOIN Fas_Brs_Transaction T
    ON Balnce.Accounting_Unit_Id =t.Accounting_Unit_Id
    AND BALNCE.BANK_AC_NO        =T.ACCOUNT_NO
    AND BALNCE.AC_OPERATIONAL_MODE_ID LIKE '%FDW%'
    INNER JOIN Fas_Brs_Monthly_Closure D
    ON BALNCE.ACCOUNTING_UNIT_ID=D.ACCOUNTING_UNIT_ID
    AND BALNCE.BANK_AC_NO       = D.ACCOUNT_NO
    AND D.STATUS                ='Y'
    )F
  INNER JOIN Fas_Mst_Acct_Units U
  ON F.ACCOUNTING_UNIT_ID =U.ACCOUNTING_UNIT_ID
  )DDD ON CCC.UNIT_ID     =DDD.ACCOUNTING_UNIT_ID]]></queryString>

