	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[SELECT bb.ACCOUNTING_UNIT_ID,
      (select uu.accounting_unit_name from fas_mst_acct_units uu where uu.accounting_unit_id=bb.ACCOUNTING_UNIT_ID)as unitName,
  bb.CASHBOOK_YEAR,
  bb.CASHBOOK_MONTH,
  bb.BANK_ID,
  (select bank.BANK_NAME from FAS_MST_BANKS bank where bank.BANK_ID=bb.BANK_ID) as bankName,
   bb.BRANCH_ID,
   (select branch.BRANCH_NAME from FAS_BANK_BRANCH branch 
   where branch.BANK_ID=bb.BANK_ID and branch.BRANCH_ID=bb.BRANCH_ID) as branchName,
  bb.OB_TYPE,
  bb.CR_AMOUNT,
  bb.DR_AMOUNT,
 bb.PASS_BOOK_DATE,
  bb.TRANSACTION_TYPE,
  bb.ACCOUNT_NO,
  (select bal.BANK_AC_TYPE_ID from FAS_BANK_BALANCE bal where bal.BANK_AC_NO=bb.ACCOUNT_NO)as accType
FROM FAS_BRS_OB bb
WHERE bb.ACCOUNTING_UNIT_ID=3
AND bb.CASHBOOK_YEAR       =2010
AND bb.CASHBOOK_MONTH      =9
and bb.OB_TYPE='NT'
order by
BANK_ID, accType,ACCOUNT_NO,TRANSACTION_TYPE,PASS_BOOK_DATE]]></queryString>

