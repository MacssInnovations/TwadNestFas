	<queryString><![CDATA[select rownum as id,a.* from
(SELECT DISTINCT Balnce.Accounting_Unit_Id ,to_char(Balnce.Accounting_Unit_Id,'000')||'-'||U.ACCOUNTING_UNIT_NAME as ACCOUNTING_UNIT_NAME
      
    FROM FAS_MST_BANK_BALANCE BALNCE,  FAS_MST_ACCT_UNITS U
   WHERE BALNCE.Accounting_Unit_Id= U.Accounting_Unit_Id
 and BALNCE.STATUS='Y'
   order by  Balnce.Accounting_Unit_Id)a]]></queryString>

