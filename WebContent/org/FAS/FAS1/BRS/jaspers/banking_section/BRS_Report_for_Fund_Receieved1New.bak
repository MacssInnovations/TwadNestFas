		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="cbmonth_name" isForPrompting="false" class="java.lang.String"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT rownum AS slno,
  CHEQUE_DD_NO,
  DOC_DATE,
  BANK_NAME,
  BRANCH_NAME,
  AMOUNT_IN_PASSBOOK,PASSBOOK_DATE,
  OFFICE_NAME,
  total
FROM
  (SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    ACCOUNT_NO,
    CHEQUE_DD_NO,
    DOC_DATE,PASSBOOK_DATE,
    AMOUNT_IN_PASSBOOK,
    OFFICE_NAME,
    total
  FROM
    (SELECT ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      ACCOUNT_NO,
      CHEQUE_DD_NO,
      DOC_DATE,PASSBOOK_DATE,
      AMOUNT_IN_PASSBOOK
    FROM FAS_BRS_TRANSACTION
    WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
    AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
    AND CASHBOOK_YEAR           =$P{cbyear}
    AND CASHBOOK_MONTH          =$P{cbmonth}
    AND ACCOUNT_NO              =$P{accNo}
    AND DOC_TYPE                ='FR by Office'
    )a
  LEFT OUTER JOIN
    (SELECT ACCOUNTING_UNIT_ID AS a_u_id,
      ACCOUNTING_FOR_OFFICE_ID AS a_o_id,
      CASHBOOK_YEAR            AS c_y,
      CASHBOOK_MONTH           AS c_m,
      ACCOUNT_NO               AS a_no,
      SUM(AMOUNT_IN_PASSBOOK)  AS total
    FROM FAS_BRS_TRANSACTION
    WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
    AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
    AND CASHBOOK_YEAR           =$P{cbyear}
    AND CASHBOOK_MONTH          =$P{cbmonth}
    AND ACCOUNT_NO              =$P{accNo}
    AND DOC_TYPE                ='FR by Office'
    GROUP BY ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      ACCOUNT_NO
    ) a1
  ON a.ACCOUNTING_UNIT_ID        = a1.a_u_id
  AND a.ACCOUNTING_FOR_OFFICE_ID = a1.a_o_id
  AND a.CASHBOOK_YEAR            = a1.c_y
  AND a.CASHBOOK_MONTH           = a1.c_m
  AND a.ACCOUNT_NO               = a1.a_no
  LEFT OUTER JOIN
    (SELECT OFFICE_ID,OFFICE_NAME FROM COM_MST_OFFICES
    )aa
  ON a.ACCOUNTING_FOR_OFFICE_ID = aa.OFFICE_ID
  )x
LEFT OUTER JOIN
  (SELECT ACCOUNTING_UNIT_ID AS acc_unit_id,
    ACCOUNTING_FOR_OFFICE_ID AS acc_off_id,
    CASHBOOK_YEAR            AS csh_bk_yr,
    CASHBOOK_MONTH           AS csh_bk_mnth,
    ACCOUNT_NO               AS acc_no,
    BANK_NAME,
    BRANCH_NAME
  FROM
    (SELECT ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      ACCOUNT_NO,
      BANK_ID,
      BRANCH_ID
    FROM FAS_BRS_MASTER
    WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
    AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
    AND CASHBOOK_YEAR           =$P{cbyear}
    AND CASHBOOK_MONTH          =$P{cbmonth}
    AND ACCOUNT_NO              =$P{accNo}
    )b
  LEFT OUTER JOIN
    (SELECT BRANCH_ID AS brnch_id,
      BANK_ID         AS bnk_id,
      BRANCH_NAME
    FROM FAS_MST_BANK_BRANCHES
    )c
  ON b.BANK_ID    = c.bnk_id
  AND b.BRANCH_ID = c.brnch_id
  LEFT OUTER JOIN
    (SELECT BANK_ID AS bnk_id1,BANK_NAME FROM FAS_MST_BANKS
    )d
  ON b.BANK_ID                 = d.bnk_id1
  )y ON x.ACCOUNTING_UNIT_ID   = y.acc_unit_id
AND x.ACCOUNTING_FOR_OFFICE_ID = y.acc_off_id
AND x.CASHBOOK_YEAR            = y.csh_bk_yr
AND x.CASHBOOK_MONTH           = y.csh_bk_mnth
AND x.ACCOUNT_NO               = y.acc_no
ORDER BY DOC_DATE,slno]]></queryString>

