<jasperReport
		 name="BRS_Report_for_Fund_Receieved1New"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="623"
		 pageHeight="842"
		 columnWidth="563"
		 columnSpacing="0"
		 leftMargin="30"
