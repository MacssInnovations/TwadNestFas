	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonthwords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="query" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
accounting_unit_id,
accounting_for_office_id,
ACCOUNT_NO,
bank_id,
branch_id,
ACCOUNT_HEAD_CODE,
pass_book_date,
particulars,
cheque_no,
CHEQUE_DETAILS,
cr_amount,
dr_amount,
(select accounting_unit_name from fas_mst_acct_units f where f.accounting_unit_id=b.accounting_unit_id)as unitname,
(select bank_short_name from FAS_MST_BANKS a where a.bank_id=b.bank_id) as bankname,
(select branch_name from fas_mst_bank_branches a1 where a1.bank_id=b.bank_id
and a1.branch_id=b.branch_id) as branchname
from fas_brs_ob b where 
ob_type ='NT'
and cashbook_year=$P{cbyear}
and cashbook_month=$P{cbmonth}
$P!{query}
order by accounting_for_office_id]]></queryString>

