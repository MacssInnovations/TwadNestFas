	<parameter name="cbyear" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT a.accounting_unit_id,
  ACCOUNTING_FOR_OFFICE_ID,
  CASHBOOK_YEAR,
  cashbook_month,
  FREEZED_DATE,
  a.account_no,
  (select AC_OPERATIONAL_MODE_ID from FAS_MST_BANK_BALANCE b where b.ACCOUNTING_UNIT_ID=a.accounting_unit_id and b.BANK_AC_NO=a.account_no)as type1,
  (SELECT office_name
  FROM com_mst_offices
  WHERE office_id=a.accounting_for_office_id
  )AS officename
FROM fas_brs_monthly_closure a
WHERE a.cashbook_year=$P{cbyear}
AND a.cashbook_month =$P{cbmonth}
ORDER BY a.accounting_unit_id]]></queryString>

