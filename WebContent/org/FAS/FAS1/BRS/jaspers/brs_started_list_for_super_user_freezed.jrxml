<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="brs_started_list_for_super_user_freezed"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="822"
		 pageHeight="842"
		 columnWidth="762"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="sel" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT accounting_unit_id,
  accounting_unit_name,
  bank_ac_no,
  ac_operational_mode_id,
  online_status,
  DECODE(desc_month1,'/','',desc_month1)AS desc_month1,
  decode(monthly_closure_status,'Not-Freezed','Nil-Freezed','Freezed')as freeze_status,
  freezed_date,
  cashbook_year,
  cashbook_month
FROM
  (SELECT a.accounting_unit_id,
    a.accounting_unit_name,
    b.bank_ac_no,
    b.ac_operational_mode_id,
    DECODE(c.account_no,NULL,'Not-Started','Started')online_status,
    d.cashbook_year,
    d.cashbook_month,
    d.CASHBOOK_YEAR
    ||'/'
    ||DECODE(d.cashbook_month,1,'January',2,'February',3,'March',4, 'April',5,'May',6,'June',7,'July',8,'August',9,'September',10,'October',11,'November',12,'December')desc_month1,
    DECODE(d.status,NULL,'Not-Freezed','Freezed')monthly_closure_status,
    d.freezed_date,
    d.nil_brs_freeze
  FROM fas_mst_acct_units a
  INNER JOIN FAS_MST_BANK_BALANCE b
  ON (a.accounting_unit_id=b.accounting_unit_id)
  LEFT OUTER JOIN brs_start_month_and_year c
  ON (a.accounting_unit_id=c.accounting_unit_id
  AND b.bank_ac_no        =c.account_no)
  LEFT OUTER JOIN fas_brs_monthly_closure d
  ON (c.accounting_unit_id=d.accounting_unit_id
  AND b.bank_ac_no        =d.account_no)
  where (d.STATUS='Y' or d.nil_brs_freeze='Y')
  )
$P!{sel}
ORDER BY accounting_unit_id,
  bank_ac_no,
  cashbook_year,
  cashbook_month]]></queryString>

