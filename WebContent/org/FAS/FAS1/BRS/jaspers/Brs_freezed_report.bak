<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Brs_freezed_report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select brs.ACCOUNTING_UNIT_ID,
(select u.accounting_unit_name from fas_mst_acct_units u where u.accounting_unit_id=brs.ACCOUNTING_UNIT_ID)as unitName,
brs.CASHBOOK_YEAR,brs.ACCOUNTING_FOR_OFFICE_ID,
brs.CASHBOOK_MONTH ,mst.ACCOUNTING_UNIT_ID,
mst.CASHBOOK_YEAR,mst.ACCOUNTING_FOR_OFFICE_ID,mst.ACCOUNT_NO,
mst.CASHBOOK_MONTH,clo.ACCOUNTING_UNIT_ID,
clo.CASHBOOK_YEAR,clo.ACCOUNTING_FOR_OFFICE_ID,
clo.CASHBOOK_MONTH from
(select ACCOUNTING_UNIT_ID,
CASHBOOK_YEAR,ACCOUNTING_FOR_OFFICE_ID,
CASHBOOK_MONTH from BRS_START_MONTH_AND_YEAR)brs
left outer join
(select ACCOUNTING_UNIT_ID,
CASHBOOK_YEAR,ACCOUNTING_FOR_OFFICE_ID,
CASHBOOK_MONTH,ACCOUNT_NO from fas_brs_master)mst on
brs.ACCOUNTING_UNIT_ID=mst.ACCOUNTING_UNIT_ID and
brs.CASHBOOK_YEAR=mst.CASHBOOK_YEAR and
brs.CASHBOOK_MONTH=mst.CASHBOOK_MONTH and
brs.ACCOUNTING_FOR_OFFICE_ID=mst.ACCOUNTING_FOR_OFFICE_ID
left join
(select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,
CASHBOOK_YEAR,
CASHBOOK_MONTH from fas_brs_monthly_closure)clo
on
 brs.ACCOUNTING_UNIT_ID=clo.ACCOUNTING_UNIT_ID and
 brs.CASHBOOK_YEAR=clo.CASHBOOK_YEAR and
brs.CASHBOOK_MONTH=clo.CASHBOOK_MONTH and
brs.ACCOUNTING_FOR_OFFICE_ID=clo.ACCOUNTING_FOR_OFFICE_ID
order by  brs.ACCOUNTING_UNIT_ID]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="UNITNAME" class="java.lang.String"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_NO" class="java.math.BigDecimal"/>

	<variable name="slno" class="java.lang.Integer" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{REPORT_COUNT}]]></variableExpression>
	</variable>
		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="50"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="10"
						y="5"
						width="525"
						height="32"
						key="staticText-1"/>
					<box></box>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font size="12"/>
					</textElement>
				<text><![CDATA[List of BRS Started But Not Freezed]]></text>
				</staticText>
				<line direction="TopDown">
					<reportElement
						x="5"
						y="43"
						width="523"
						height="1"
						key="line-1"/>
					<graphicElement stretchType="NoStretch"/>
				</line>
				<staticText>
					<reportElement
						x="410"
						y="21"
						width="50"
						height="20"
						key="staticText-2"/>
					<box></box>
					<textElement textAlignment="Right">
						<font size="8"/>
					</textElement>
				<text><![CDATA[DATE:]]></text>
				</staticText>
				<textField isStretchWithOverflow="false" pattern="dd/MM/yyyy" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="465"
						y="21"
						width="64"
						height="20"
						key="textField-1"/>
					<box></box>
					<textElement>
						<font size="8"/>
					</textElement>
				<textFieldExpression   class="java.util.Date"><![CDATA[new java.util.Date()]]></textFieldExpression>
				</textField>
			</band>
		</title>
		<pageHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageHeader>
		<columnHeader>
			<band height="31"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="38"
						y="0"
						width="265"
						height="21"
						key="staticText-4"/>
					<box></box>
					<textElement textAlignment="Left">
						<font/>
					</textElement>
				<text><![CDATA[Name Of the Unit]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="291"
						y="0"
						width="94"
						height="21"
						key="staticText-5"/>
					<box></box>
					<textElement>
						<font/>
					</textElement>
				<text><![CDATA[Start Month/Year]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="470"
						y="0"
						width="65"
						height="21"
						key="staticText-6"/>
					<box></box>
					<textElement>
						<font/>
					</textElement>
				<text><![CDATA[Data entry Done]]></text>
				</staticText>
				<line direction="TopDown">
					<reportElement
						x="5"
						y="28"
						width="523"
						height="1"
						key="line-2"/>
					<graphicElement stretchType="NoStretch"/>
				</line>
				<staticText>
					<reportElement
						x="386"
						y="0"
						width="84"
						height="21"
						key="staticText-8"/>
					<box></box>
					<textElement>
						<font/>
					</textElement>
				<text><![CDATA[AccountNo]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="10"
						y="0"
						width="28"
						height="21"
						key="staticText-9"/>
					<box></box>
					<textElement>
						<font/>
					</textElement>
				<text><![CDATA[Sl.No]]></text>
				</staticText>
			</band>
		</columnHeader>
		<detail>
			<band height="22"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="38"
						y="0"
						width="265"
						height="22"
						key="textField-2"
						isPrintRepeatedValues="false"/>
					<box></box>
					<textElement>
						<font size="8"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{ACCOUNTING_UNIT_ID}+" ( "+$F{UNITNAME}.trim()+" ) "]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="291"
						y="0"
						width="95"
						height="18"
						key="textField-3"/>
					<box></box>
					<textElement textAlignment="Justified">
						<font/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{CASHBOOK_MONTH}+" "+"/"+" "+$F{CASHBOOK_YEAR}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement
						x="470"
						y="0"
						width="65"
						height="18"
						key="staticText-7"/>
					<box></box>
					<textElement textAlignment="Left">
						<font size="8"/>
					</textElement>
				<text><![CDATA[NO]]></text>
				</staticText>
				<textField isStretchWithOverflow="false" pattern="" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="386"
						y="0"
						width="84"
						height="18"
						key="textField"/>
					<box></box>
					<textElement>
						<font/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$F{ACCOUNT_NO}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="10"
						y="0"
						width="28"
						height="22"
						key="textField"/>
					<box></box>
					<textElement>
						<font/>
					</textElement>
				<textFieldExpression   class="java.lang.Integer"><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
				</textField>
			</band>
		</detail>
		<columnFooter>
