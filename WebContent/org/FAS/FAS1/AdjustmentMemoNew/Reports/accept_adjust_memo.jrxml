<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="accept_adjust_memo"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false"
		 isIgnorePagination="true">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="vou_no" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT a.FOR_ACCOUNTING_UNIT_ID,
  (SELECT ACCOUNTING_UNIT_NAME
  From Fas_Mst_Acct_Units
  WHERE FAS_MST_ACCT_UNITS.ACCOUNTING_UNIT_ID=a.FOR_ACCOUNTING_UNIT_ID
  ) As Unitname,
  A.Letter_No,
  A.Letter_Date,
  A.Voucher_No As Memo_No,
  A.Voucher_Date As Memo_Date,
  b.cashbook_year,
  b.cashbook_month,
  b.Account_Head_Code,
 (select ACCOUNT_HEAD_DESC from Com_Mst_Account_Heads h where H.Account_Head_Code=B.Account_Head_Code)as headdesc,
  B.Jrnl_No,B.Jrnl_Date,
  B.Cr_Dr_Indicator,
  B.Amount,
  Case When B.Cashbook_Month=1 Then 'January'
  When B.Cashbook_Month=2 Then 'February'
  When B.Cashbook_Month=3 Then 'March'
  When B.Cashbook_Month=4 Then 'April'
  When B.Cashbook_Month=5 Then 'May'
  When B.Cashbook_Month=6 Then 'June'
  When B.Cashbook_Month=7 Then 'July'
  When B.Cashbook_Month=8 Then 'August'
  When B.Cashbook_Month=9 Then 'September'
  When B.Cashbook_Month=10 Then 'October'
  When B.Cashbook_Month=11 Then 'November'
  Else 'December' end as month_desc  
FROM
(Select T.Accounting_Unit_Id,
    T.Acceptance_Status,
    T.Accept_Voucher_No,
    t.Accept_Voucher_Date,
    t.FOR_ACCOUNTING_UNIT_ID,
    T.Cashbook_Month,
    T.Letter_No,
    T.Cashbook_Year,
    T.Letter_Date,
    t.Voucher_No,m.VOUCHER_DATE
  From Fas_Adjust_Memo_Mst M,Fas_Adjust_Memo_Trn T
  Where M.Accounting_Unit_Id=T.Accounting_Unit_Id
  And M.Cashbook_Year=T.Cashbook_Year
  And M.Cashbook_Month=T.Cashbook_Month
  And M.Voucher_No=T.Voucher_No
  and t.FOR_ACCOUNTING_UNIT_ID =$P{accountingunitid}
  And T.Cashbook_Year            =$P{txtCB_Year}
  And T.Cashbook_Month           =$P{txtCB_Month}
  And T.Voucher_No               =$P{vou_no}
  And T.Letter_No               Is Not Null
  And T.Letter_Date             Is Not Null
  And T.Acceptance_Status        ='Y'
  and m.MEMO_STATUS='L'
  And T.Accept_Voucher_No       Is Not Null
  And T.Accept_Voucher_Date     Is Not Null)a
  left outer join
  (Select T.Accounting_Unit_Id,
    T.Voucher_No As Jrnl_No,
    M.Voucher_Date as jrnl_date,
    T.Account_Head_Code,
    T.Cr_Dr_Indicator,
    t.AMOUNT,
    T.Cashbook_Year,
    t.Cashbook_Month
  From Fas_Journal_Master M,Fas_Journal_Transaction T
  Where M.Accounting_Unit_Id=T.Accounting_Unit_Id
  And M.Accounting_For_Office_Id=T.Accounting_For_Office_Id
  And M.Cashbook_Year=T.Cashbook_Year
  And M.Cashbook_Month=T.Cashbook_Month
  And M.Voucher_No=T.Voucher_No
  And M.Journal_Status='L'
  And M.Accounting_Unit_Id=$P{accountingunitid})b
  On A.FOR_ACCOUNTING_UNIT_ID=B.Accounting_Unit_Id
  And A.Accept_Voucher_No=B.Jrnl_No
  and a.Accept_Voucher_Date=b.jrnl_date]]></queryString>

