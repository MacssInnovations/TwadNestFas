	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthinwords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="voucherNo" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cmbAcc_UnitCode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCrea_date" isForPrompting="true" class="java.util.Date"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String"/>
	<parameter name="monthinwords_New" isForPrompting="true" class="java.lang.String"/>
	<parameter name="signAutName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="signAutDesg" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT A.*,
  b.*,c.RECEIVED_FROM,c.receipt_date
FROM
  (SELECT TRIM(A.AUTHORITY_ADDRESS)AS ADDRESS,
    B.ACCOUNTING_UNIT_ID,
    b.ACCOUNTING_FOR_OFFICE_ID,
    B.REMARKS,
    A.RECEIPT_NO,
    B.CASHBOOK_YEAR,
    b.CASHBOOK_MONTH,
    (SELECT ACC.ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES ACC
    WHERE ACC.ACCOUNTING_UNIT_ID = B.FOR_ACCOUNTING_UNIT_ID 
    and ACC.ACCOUNTING_FOR_OFFICE_ID in 
      (SELECT OFFICE_ID
      FROM COM_MST_OFFICES
      WHERE OFFICE_STATUS_ID NOT IN ('CL','NC','RD')
      )
    )                                           AS OFFICE_ID,
    trim(TO_CHAR(b.AMOUNT,'99999999999999.99')) AS amount
  FROM FAS_ADJUST_MEMO_MST A,
    FAS_ADJUST_MEMO_TRN B
  WHERE a.accounting_unit_id    =b.accounting_unit_id
  AND a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID
  AND a.CASHBOOK_YEAR           =b.CASHBOOK_YEAR
  AND a.CASHBOOK_MONTH          =b.CASHBOOK_MONTH
  AND a.VOUCHER_NO              =b.VOUCHER_NO
  AND a.memo_status             ='L'
  AND b.FOR_ACCOUNTING_UNIT_ID  =$P{cmbAcc_UnitCode}
  AND b.voucher_no              =$P{voucherNo}
  AND b.cashbook_month          =$P{cashbookmonth}
  AND b.cashbook_year           =$P{cashbookyear}
  AND B.ACCOUNT_HEAD_CODE       =610101
  )A
LEFT OUTER JOIN
  (SELECT O.OFFICE_ADDRESS1,
    NVL(SUBSTR(O.OFFICE_NAME, 0, INSTR(O.OFFICE_NAME, ',')), O.OFFICE_NAME) AS OFFICE_NAME,
    O.OFFICE_ADDRESS2,
    O.CITY_TOWN_NAME,
    O.OFFICE_ID
  FROM COM_MST_OFFICES O
  ) B
ON A.OFFICE_ID=B.OFFICE_ID
LEFT OUTER JOIN
  (SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    RECEIPT_NO,
    to_char(receipt_date,'DD/MM/YY') as receipt_date ,
    RECEIVED_FROM
  FROM FAS_RECEIPT_MASTER
  )C
ON C.ACCOUNTING_UNIT_ID=A.ACCOUNTING_UNIT_ID
and c.ACCOUNTING_FOR_OFFICE_ID=a.ACCOUNTING_FOR_OFFICE_ID
AND C.RECEIPT_NO              =A.RECEIPT_NO
AND C.CASHBOOK_YEAR           =A.CASHBOOK_YEAR
AND c.CASHBOOK_MONTH          =a.CASHBOOK_MONTH]]></queryString>

