				<textFieldExpression   class="java.lang.String"><![CDATA["      I am to inform that the " +  $F{RECEIVED_FROM}  + " has remitted a sum of Rs. " +  $F{AMOUNT}+ "/- , dated " + $F{RECEIPT_DATE} + " towards "+  $F{REMARKS} +
"  and this amount has been credited in Head Office Bank and accounted for under  “ 610101 – Transfer from Board – Receipt.” I enclose credit advice for this amount. "]]></textFieldExpression>
