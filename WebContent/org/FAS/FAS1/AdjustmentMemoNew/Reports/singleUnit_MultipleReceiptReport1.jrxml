	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthinwords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="voucherNo" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT 
  a.remarks, a.office_address,a.for_accounting_unit_id,
  trim(TO_CHAR(a.amount,'99999999999999.99')) AS amount ,(select AUTHORITY_NAME from fas_adjust_memo_mst where voucher_no=$P{voucherNo}

and cashbook_month=$P{cashbookmonth}
and cashbook_year=$P{cashbookyear}) as AName
  
 
FROM FAS_ADJUST_MEMO_TRN a
  
WHERE a.voucher_no=$P{voucherNo}

and a.cashbook_month=$P{cashbookmonth}
and a.cashbook_year=$P{cashbookyear}
and a.FOR_ACCOUNTING_UNIT_ID=$P{unitid}]]></queryString>

