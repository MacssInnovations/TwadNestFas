	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthinwords" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 

                  a.*,b.*,c.*,
                  
                  case when  c.CR_DR_INDICATOR='DR' then
                   AMOUNT 
                   else 
                   0 end as debitamt,
                   case when  c.CR_DR_INDICATOR='CR' then
                   AMOUNT 
                   else
                   0 end as creditamt
                  
                  
from
(
    
(SELECT PARTICULARS,
  VOUCHER_NO,
  VOUCHER_DATE,TOTAL_AMOUNT
FROM FAS_ADJUST_MEMO_MST
WHERE cashbook_month=$P{cashbookmonth}
AND cashbook_year   =$P{cashbookyear}
and FOR_ACCOUNTING_UNIT_ID=$P{accountingunitid}
)a 


left outer join


(SELECT VOUCHER_NO as journalno,
  VOUCHER_DATE as journaldate
FROM FAS_JOURNAL_MASTER
WHERE cashbook_year  =$P{cashbookyear}
AND cashbook_month   =$P{cashbookmonth}
AND journal_type_code=70  
and ACCOUNTING_UNIT_ID=$P{accountingunitid}
and ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
  
)b ON a.VOUCHER_NO=b.journalno



left outer join 

( select VOUCHER_NO,ACCOUNT_HEAD_CODE,SUB_LEDGER_TYPE_CODE,SUB_LEDGER_CODE ,AMOUNT,CR_DR_INDICATOR

from FAS_JOURNAL_TRANSACTION where cashbook_month=$P{cashbookmonth}
AND cashbook_year   =$P{cashbookyear}
and ACCOUNTING_UNIT_ID=$P{accountingunitid}
and ACCOUNTING_FOR_OFFICE_ID=$P{officeid}


)c
on b.journalno=c.VOUCHER_NO

)]]></queryString>

