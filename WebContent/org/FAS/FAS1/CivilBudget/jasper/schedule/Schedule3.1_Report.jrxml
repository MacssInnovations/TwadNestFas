	<property name="ireport.scriptlethandling" value="2" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[--select case
--when a.NET_DEPRE_COST  IS NULL then 0
--when a.NET_DEPRE_COST  IS not null then a.NET_DEPRE_COST   as net_amt,asset_major_class_code
--
SELECT a.asset_major_class_code,
  CASE 
    WHEN financial_year='2011-12'
    THEN 'Closing Balance as on 2011-12'
    ELSE financial_year
  END AS financial_year,
  a.ASSET_MAJOR_CLASS_DESC,
  CASE
    WHEN NET_DEPRE_COST IS NULL
    THEN 0
    ELSE NET_DEPRE_COST
  END AS net_Amount
FROM
  (SELECT SUM(reg.NET_DEPRE_COST)AS NET_DEPRE_COST,
    financial_year,(mst.asset_major_class_code||','||TRIM(mst.ASSET_MAJOR_CLASS_DESC))as asset_major_class_code,
    (TRIM(mst.ASSET_MAJOR_CLASS_DESC) ||'-'||mst.asset_major_class_code)AS ASSET_MAJOR_CLASS_DESC
  FROM FAS_A52_REGISTER_CPY reg,
    fas_mst_assets_class mst
  WHERE financial_year          ='2011-12'
  AND reg.asset_major_class_code=mst.asset_major_class_code
 GROUP BY financial_year, mst.ASSET_MAJOR_CLASS_DESC,mst.asset_major_class_code
  ORDER BY mst.asset_major_class_code
  )a
]]></queryString>

