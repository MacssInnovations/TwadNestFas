	<queryString><![CDATA[select a2.FORMAT_DESC_MAIN,a2.FORMAT_DESC_SUB,a1.FORMAT_NO,
  a1.BUDGET_GROUP_ID,
  a1.BUDGET_GROUP_MAJOR,
  a1.ACC_HEAD_CODE,
  a3.ACCOUNT_HEAD_DESC
from (SELECT a.FORMAT_NO,
  a.BUDGET_GROUP_ID,
  b.BUDGET_GROUP_MAJOR,
  a.ACC_HEAD_CODE
FROM FAS_BUDGET_AC_HEADS_MAP a
INNER JOIN FAS_BUDGET_GROUP_MASTER b
ON b.budget_group_id=a.budget_group_id) a1 
left outer join
FAS_FORMAT_MASTER a2
on a1.FORMAT_NO=a2.FORMAT_NO
left outer join 
COM_MST_ACCOUNT_HEADS a3
on   a1.ACC_HEAD_CODE=a3.ACCOUNT_HEAD_CODE
order by a1.FORMAT_NO, a1.BUDGET_GROUP_MAJOR,
  a1.ACC_HEAD_CODE]]></queryString>

