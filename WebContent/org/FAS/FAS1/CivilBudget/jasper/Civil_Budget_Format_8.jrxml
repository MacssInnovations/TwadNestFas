a.ANTICIPATED_DEC_TO_END_OF_CY,
a.TOTAL,
a.NEXT_YEAR from FAS_BUDGET_FORMAT_8 a where ACCOUNTING_UNIT_ID=$P{UnitId} and ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId} and FINANCIAL_YEAR=$P{year}]]></queryString>

