<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="AnnualAccountReport"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="765"
		 pageHeight="842"
		 columnWidth="705"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="qry" isForPrompting="true" class="java.lang.String"/>
	<parameter name="heading" isForPrompting="false" class="java.lang.String"/>
	<parameter name="CR Heading" isForPrompting="true" class="java.lang.String"/>
	<parameter name="DR Heading" isForPrompting="true" class="java.lang.String"/>
	<parameter name="Net Heading" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select case when total1 is null then 0
else total1 end as total1_before,
case when total1_next is null then 0
else total1_next end as total1_after,
fin.*

from

(SELECT aa.ORDER_NO,
  aa.minor_head_code,
 (SELECT MINOR_HEAD_DESC FROM COM_MST_MINOR_HEADS min1 WHERE min1.MINOR_HEAD_CODE=aa.MINOR_HEAD_CODE)as MINOR_HEAD_DESC,
  aa.major_head_code,
  (SELECT MAJOR_HEAD_DESC
  FROM com_mst_major_heads maj
  WHERE MAJ.MAJOR_HEAD_CODE= aa.major_head_code
  )as MAJOR_HEAD_DESC,
  aa.GROUP_HEAD_CODE,
  (select GROUP_HEAD_DESC from FAS_MIS_GROUP_MASTER gp where gp.group_head_code= aa.GROUP_HEAD_CODE)as GROUP_HEAD_DESC,

  sum((SELECT SUM(trial.DEBIT_CLOSING_BALANCE)
  FROM FAS_TRIAL_BALANCE trial
  WHERE trial.ACCOUNT_HEAD_CODE=hc.ACCOUNT_HEAD_CODE
  $P!{qry} 
  ))AS total1,
 sum((SELECT SUM(trial.CREDIT_CLOSING_BALANCE)
  FROM FAS_TRIAL_BALANCE trial
  WHERE trial.ACCOUNT_HEAD_CODE=hc.ACCOUNT_HEAD_CODE
  $P!{qry}
  GROUP BY trial.ACCOUNT_HEAD_CODE
  ))AS total1_next
FROM ANNUAL_ACCOUNT_SUB_GROUP aa,
  com_mst_account_heads hc
WHERE aa.MINOR_HEAD_CODE= hc.MINOR_HEAD_CODE
AND aa.MAJOR_HEAD_CODE  = hc.MAJOR_HEAD_CODE


GROUP BY aa.ORDER_NO,
  aa.minor_head_code,
  aa.major_head_code,
  aa.GROUP_HEAD_CODE
ORDER BY aa.major_head_code, aa.minor_head_code,aa.GROUP_HEAD_CODE,
  aa.ORDER_NO)fin]]></queryString>

	<field name="TOTAL1_BEFORE" class="java.math.BigDecimal"/>
	<field name="TOTAL1_AFTER" class="java.math.BigDecimal"/>
	<field name="ORDER_NO" class="java.lang.String"/>
	<field name="MINOR_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="MINOR_HEAD_DESC" class="java.lang.String"/>
	<field name="MAJOR_HEAD_CODE" class="java.lang.String"/>
	<field name="MAJOR_HEAD_DESC" class="java.lang.String"/>
	<field name="GROUP_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="GROUP_HEAD_DESC" class="java.lang.String"/>
	<field name="TOTAL1" class="java.math.BigDecimal"/>
	<field name="TOTAL1_NEXT" class="java.math.BigDecimal"/>

	<variable name="net_Value" class="java.math.BigDecimal" resetType="Group" resetGroup="Head_Code" calculation="Sum">
		<variableExpression><![CDATA[$V{NetAmt}]]></variableExpression>
	</variable>
	<variable name="debitTotal" class="java.math.BigDecimal" resetType="Group" resetGroup="Head_Code" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL1_BEFORE}]]></variableExpression>
	</variable>
	<variable name="creditTotal" class="java.math.BigDecimal" resetType="Group" resetGroup="Head_Code" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL1_AFTER}]]></variableExpression>
	</variable>
	<variable name="NetAmt" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{TOTAL1_BEFORE}.subtract( $F{TOTAL1_AFTER} )]]></variableExpression>
	</variable>
	<variable name="Grd_Debit" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL1_BEFORE}]]></variableExpression>
	</variable>
	<variable name="GrdCredit" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL1_AFTER}]]></variableExpression>
	</variable>
	<variable name="ger_net" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{Grd_Debit}.subtract( $V{GrdCredit} )]]></variableExpression>
	</variable>

