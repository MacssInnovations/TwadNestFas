a.VARIATION_BTWN_REYR_AND_NXTYR from FAS_BUDGET_FORMAT_2 a where a.accounting_unit_id=$P{UnitId} and 
a.ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId} and a.FINANCIAL_YEAR=$P{year}]]></queryString>

