	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="vou_no" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="jou" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supplement_no" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT b.ACCOUNTING_UNIT_NAME AS divi,
  (a.voucher_no
  ||'-'
  ||a.voucherDate) AS TDA,
  a.rea            AS rea,
  a.TOTAL_AMOUNT   AS TOTAL_AMOUNT,
  (a.ACCEPTING_JVR_NO
  ||'-'
  ||a.ACCEPTING_JVR_DATE)AS JR,
  (a.accepting_slno
  ||'-'
  ||a.accepting_date)    AS ACC,
  a.particulars          AS PARTICULARS,
  c.accounting_unit_name AS U
FROM
  (SELECT mst.VOUCHER_DATE AS voucherDate,
    --mst.accounting_for_office_id,
    mst.ACCOUNTING_UNIT_ID,
    mst.TRF_ACCOUNTING_UNIT_ID,
    mst.voucher_no AS voucher_no,
    mst.TDA_OR_TCA,
    mst.ORGINATING_JVR_NO,
    mst.ORGINATING_JVR_DATE,
    mst.REASON_FOR_TRANSFER,
    (SELECT REASON_DESC
    FROM FAS_MST_TDA_TCA_REASON
    WHERE REASON_CODE=mst.REASON_FOR_TRANSFER::numeric
    )rea,
    mst1.ACCEPTING_JVR_NO   AS ACCEPTING_JVR_NO,
    mst1.ACCEPTING_JVR_DATE AS ACCEPTING_JVR_DATE,
    mst.accepting_slno      AS accepting_slno,
    mst.accepting_date      AS accepting_date,
    mst.particulars         AS particulars,
    mst.TOTAL_AMOUNT        AS TOTAL_AMOUNT
  FROM FAS_TDA_TCA_RAISED_MST mst,
    FAS_TDA_TCA_RAISED_MST mst1
  WHERE mst.TRF_ACCOUNTING_UNIT_ID=mst1.ACCOUNTING_UNIT_ID
  AND mst.ACCEPTING_SLNO          =mst1.VOUCHER_NO
  AND mst.status                  ='L'
  AND mst.accounting_for_office_id=$P{accountofficeid}
  AND mst.cashbook_month          =$P{txtCB_Month}
  AND mst.cashbook_year           =$P{txtCB_Year}
  AND (mst.TDA_OR_TCA             ='TDAO'
  OR mst.tda_or_tca               ='TDAO')
  AND mst.ACCEPTANCE_STATUS       ='Y'
$P!{supplement_no}
  )a
LEFT OUTER JOIN FAS_MST_ACCT_UNITS b
ON a.ACCOUNTING_UNIT_ID=b.accounting_unit_id
LEFT OUTER JOIN FAS_MST_ACCT_UNITS c
ON c.ACCOUNTING_UNIT_ID=a.TRF_ACCOUNTING_UNIT_ID
ORDER BY a.voucher_no]]></queryString>

