		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="vou_no" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="unit" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[	SELECT adjdb,
		  adjcr,unit,
		  (SELECT accounting_unit_name
		  FROM fas_mst_acct_units
		  WHERE accounting_unit_id=unit
		  )tr_unit,
		  (SELECT accounting_unit_name
		  FROM fas_mst_acct_units
		  WHERE accounting_unit_id=$P{accountingunitid}
		  )ac_unit,
		  (SELECT adjdeb
		  FROM
		    (SELECT
		      CASE
		        WHEN deb='DR'
		        THEN amt
		      END AS adjdeb
		    FROM
		      (SELECT CR_DR_INDICATOR AS deb,
		        amount                AS amt
		      FROM fas_journal_transaction
		      WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
		      AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
		      AND cashbook_year           =$P{txtCB_Year}
		      AND cashbook_month          =$P{txtCB_Month}
		      AND voucher_no              =$P{vou_no}
		      AND account_head_code       =900109
		      )
		    )
		  )deb,
		  (SELECT db
		  FROM
		    (SELECT
		      CASE
		        WHEN deb='DR'
		        THEN amt
		      END AS db
		    FROM
		      (SELECT MONTH_OPENING_BAL_DR_CR_IND AS deb,
		        MONTH_OPENING_BALANCE             AS amt
		      FROM fas_general_ledger
		      WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
		      AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
		      AND YEAR                    =$P{txtCB_Year}
		      AND MONTH                   =$P{txtCB_Month}
		      AND account_head_code       =901001
		      )
		    )
		  )db,
		  (SELECT cr
		  FROM
		    (SELECT
		      CASE
		        WHEN deb='CR'
		        THEN amt
		      END AS cr
		    FROM
		      (SELECT MONTH_OPENING_BAL_DR_CR_IND AS deb,
		        MONTH_OPENING_BALANCE             AS amt
		      FROM fas_general_ledger
		      WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
		      AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
		      AND YEAR                    =$P{txtCB_Year}
		      AND MONTH                   =$P{txtCB_Month}
		      AND account_head_code       =901001
		      )
		    )
		  )cr,
		  (
		  (SELECT -(db-adjcr)
		  FROM
		    (SELECT
		      CASE
		        WHEN deb='DR'
		        THEN amt
		      END AS db
		    FROM
		      (SELECT MONTH_OPENING_BAL_DR_CR_IND AS deb,
		        MONTH_OPENING_BALANCE             AS amt
		      FROM fas_general_ledger
		      WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
		      AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
		      AND YEAR                    =$P{txtCB_Year}
		      AND MONTH                   =$P{txtCB_Month}
		      AND account_head_code       =901001
		      )
		    )
		  ))dbal,
		  (
		  (SELECT -(adjdb-cr)
		  FROM
		    (SELECT
		      CASE
		        WHEN deb='CR'
		        THEN amt
		      END AS cr
		    FROM
		      (SELECT MONTH_OPENING_BAL_DR_CR_IND AS deb,
		        MONTH_OPENING_BALANCE             AS amt
		      FROM fas_general_ledger
		      WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
		      AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
		      AND YEAR                    =$P{txtCB_Year}
		      AND MONTH                   =$P{txtCB_Month}
		      AND account_head_code       =901001
		      )
		    )
		  ))cbal
		FROM
		  (SELECT
		    CASE
		      WHEN deb='DR'
		      THEN amt
		    END AS adjdb,
		    CASE
		      WHEN deb='CR'
		      THEN amt
		    END AS adjcr,unit
		  FROM
		    (SELECT CR_DR_INDICATOR AS deb,
		      amount                AS amt,		  (SELECT accounting_unit_id
		  FROM FAS_TDA_TCA_RAISED_MST
		  WHERE CASHBOOK_YEAR       =$P{txtCB_Year}
		  AND CASHBOOK_MONTH        =$P{txtCB_Month}
		  AND trf_accounting_unit_id=$P{accountingunitid}
		  AND voucher_no            =$P{vou_no}
		  )unit
		    FROM fas_journal_transaction
		    WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
		    AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
		    AND cashbook_year           =$P{txtCB_Year}
		    AND cashbook_month          =$P{txtCB_Month}
		    AND voucher_no              =$P{vou_no}
		    AND account_head_code       =900108
		    )
		  )
]]></queryString>

