<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="TransferDBorCR"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="708"
		 pageHeight="842"
		 columnWidth="648"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="adviceNo" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="supplement_no" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[Select M.Trf_Accounting_Unit_Id,M.Total_Amount as ttl,
(SELECT Uu.Accounting_Unit_Name
    From Fas_Mst_Acct_Units Uu
    WHERE Uu.Accounting_Unit_Id=m.Trf_Accounting_Unit_Id) as acceptUnit,
    m.ACCOUNTING_UNIT_ID,
    (SELECT Uu.Accounting_Unit_Name
    FROM fas_mst_acct_units uu
    WHERE Uu.Accounting_Unit_Id=m.Accounting_Unit_Id
    )AS orgunitname,
    m.CASHBOOK_YEAR,
    m.CASHBOOK_MONTH,
    m.VOUCHER_NO,
    TO_CHAR(m.VOUCHER_DATE,'dd/MM/yyyy') AS VOUCHER_DATE,
    m.Accepting_Slno,
    m.Accepting_Date,
    t.AMOUNT,
    m.Orginating_Jvr_No,
    TO_CHAR(m.ORGINATING_JVR_DATE,'dd/MM/yyyy') AS ORGINATING_JVR_DATE,
   t.ACCOUNT_HEAD_CODE As Acc_head,
     acc_desc.account_head_desc As Acc_Desc,
    t.CR_DR_INDICATOR      AS crdr,
 T.Sub_Ledger_Type_Code,
    (select SUB_LEDGER_TYPE_DESC from COM_MST_SL_TYPES c where c.SUB_LEDGER_TYPE_CODE=  T.Sub_Ledger_Type_Code)as typeDesc,
    T.Sub_Ledger_Code,
    (select SL_CODENAME from SL_TYPE_CODE_NAME_VIEW_M v where v.SL_TYPE=T.Sub_Ledger_Type_Code and v.SL_CODE=T.Sub_Ledger_Code limit 1)as codeDesc,
    (SELECT One.Accepting_Jvr_No
    FROM Fas_Tda_Tca_Raised_Mst One
    WHERE One.Trf_Accounting_Unit_Id=m.Accounting_Unit_Id
   AND one.voucher_no =m.accepting_slno
    ) AS Acceptjournalno,
    (SELECT Two.Accepting_Jvr_Date
    FROM Fas_Tda_Tca_Raised_Mst Two
    WHERE Two.Trf_Accounting_Unit_Id=m.Accounting_Unit_Id
    AND two.voucher_no =m.accepting_slno
    )AS Acceptjournaldate,
m.PARTICULARS,
    t.MBOOK_NO,
t.MBOOK_PAGENO,
t.MBOOK_DATE
From
Fas_Tda_Tca_Raised_Mst M,
FAS_TDA_TCA_RAISED_TRN T,
  com_mst_account_heads acc_desc
where m.ACCOUNTING_UNIT_ID        =t.ACCOUNTING_UNIT_ID
    And m.Cashbook_Year            =t.Cashbook_Year
    And m.Cashbook_Month             =t.Cashbook_Month
    And M.Voucher_No             =T.Voucher_No  
    AND t.account_head_code       = acc_desc.account_head_code
  and m.ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND m.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND m.CASHBOOK_YEAR           =$P{cashbookyear}
  And m.Cashbook_Month          =$P{cashbookmonth}
  AND m.voucher_no              =$P{adviceNo}
  AND (m.TDA_OR_TCA             ='TDAO'
  OR m.TDA_OR_TCA               ='TCAO'
  Or M.Tda_Or_Tca               ='TDACB'
  Or m.Tda_Or_Tca               ='TCACB')
$P!{supplement_no}]]></queryString>

