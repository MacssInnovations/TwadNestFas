<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="TCA_List_All_rw_date"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1162"
		 pageHeight="842"
		 columnWidth="1102"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtCB_Year_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_to" isForPrompting="true" class="java.lang.String"/>
	<parameter name="officeCode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Sub_Jour" isForPrompting="false" class="java.lang.String"/>
	<parameter name="statusHeading" isForPrompting="false" class="java.lang.String"/>
	<parameter name="sub_q" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select * from (SELECT A.*,B.ACCEPTING_JVR_NO,B.ACCEPTING_JVR_DATE FROM
(SELECT mst.VOUCHER_DATE ,
    mst.VOUCHER_NO  ,
    mst.TDA_OR_TCA ,
    mst.ACCOUNTING_UNIT_ID,
   (SELECT ACCOUNTING_UNIT_NAME 
    FROM FAS_MST_ACCT_UNITS unit
    Where Unit.Accounting_Unit_Id=Mst.ACCOUNTING_UNIT_ID
    )As Orgname,
      Mst.Trf_Accounting_Unit_Id, 
      (SELECT ACCOUNTING_UNIT_NAME
    FROM FAS_MST_ACCT_UNITS unit
    WHERE unit.ACCOUNTING_UNIT_ID=mst.Trf_Accounting_Unit_Id
    ) as ACCEPTEDNAME,
    mst.TOTAL_AMOUNT,
    mst.ORGINATING_JVR_NO ,
    mst.ORGINATING_JVR_DATE ,
    mst.RESPONDING_JVR_NO ,
    mst.RESPONDING_JVR_DATE,
    Mst.Status,
    mst.PARTICULARS,MST.ACCEPTING_SLNO,
 coalesce(mst.ACCEPTANCE_STATUS,NULL,'-',mst.ACCEPTANCE_STATUS) AS ACCEPTANCE_STATUS
  From Fas_Tda_Tca_Raised_Mst Mst
  WHERE mst.ORGINATING_JVR_NO                      IS NOT NULL
  AND mst.orginating_jvr_date                    IS NOT NULL
  And Mst.Status                                  ='L'
  AND mst.TDA_OR_TCA             in ('TCAO','TCACB')
   And To_Date((mst.Cashbook_Month
  ||'-'
  || mst.Cashbook_Year),'mm-yyyy') BETWEEN To_Date($P{txtCB_Month_from}::int
  ||'-'
  ||$P{txtCB_Year_from},'mm-yyyy')
AND to_date($P{txtCB_Month_to}::Int
  ||'-'
  ||$P{txtCB_Year_to}::int,'mm-yyyy') 
 -----$P!{sub_q}
  and mst.accounting_for_office_id in (SELECT office_id
FROM COM_MST_ALL_OFFICES_VIEW
WHERE region_office_id =$P{officeCode}::int)
)A
  Left Outer JOIN
    
  (SELECT mst.VOUCHER_DATE,
    mst.VOUCHER_NO,
    mst.TDA_OR_TCA,
    mst.ACCOUNTING_UNIT_ID,
    mst.TOTAL_AMOUNT,
    mst.ACCEPTING_JVR_NO,
    mst.ACCEPTING_JVR_DATE,
    mst.STATUS
  From Fas_Tda_Tca_Raised_Mst Mst
  WHERE mst.ACCEPTING_JVR_NO                      IS NOT NULL
  AND mst.ACCEPTING_JVR_DATE                    IS NOT NULL
  And Mst.Status                                  ='L'
  AND mst.TDA_OR_TCA             in ('TCAA')
)B
  On A.TRF_ACCOUNTING_UNIT_ID=B.Accounting_Unit_Id
  AND A.ACCEPTING_SLNO=B.VOUCHER_NO
  order by a.Orgname,a.VOUCHER_NO)f$P!{Sub_Jour}]]></queryString>

