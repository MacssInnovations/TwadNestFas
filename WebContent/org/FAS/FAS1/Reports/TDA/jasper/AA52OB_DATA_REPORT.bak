	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cmbassetcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cmbFinancialYear" isForPrompting="true" class="java.lang.String"/>
	<parameter name="querp" isForPrompting="true" class="java.lang.String"/>
	<parameter name="queryAsset" isForPrompting="true" class="java.lang.String"/>
	<parameter name="circleQry" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[Select A.Accounting_Unit_Id,a.accounting_unit_office_id,A.Asset_Major_Class_Code,
(select office_name from COM_MST_OFFICES where OFFICE_ID=a.ACCOUNTING_UNIT_OFFICE_ID) as officeName,
(select U.Accounting_Unit_Name from fas_mst_acct_units u where U.Accounting_Unit_Id=a.Accounting_Unit_Id)as unitname,
  a.FINANCIAL_YEAR,
  a.ASSET_CODE,
  a.BOOKVALUE,
  a.APPOR_GRANT,
  a.DEP_DEBIT,
  a.JOURNAL_NO,
  a.JOURNAL_DATE,
  a.SURVEY_NO,
  a.SURVEY_DATE,
  a.AUCTION_DATE,
  a.PERSON_NAME,
  a.AUCTION_AMOUNT,
  a.CB_VOUCHERNO,
  a.CB_VOUCHERDATE,
  a.PROFIT,
  a.LOSS,
  a.OFF_DEBIT,
  a.OFF_CREDIT,
  a.REMARKS,
(Select Asset_Major_Class_Desc From Fas_Mst_Assets_Class where Asset_Major_Class_Code = A.Asset_Major_Class_Code) as major_class_desc
FROM FAS_AA52REGISTER a INNER JOIN fas_asset_val_ac_render_units c
ON a.ACCOUNTING_UNIT_ID =c.Acct_Rendering_Unit_Id
and A.ACCOUNTING_UNIT_OFFICE_ID=C.RENDERING_UNIT_OFFICE_ID
inner join fas_mst_acct_units b  on
a.accounting_unit_id     =b.accounting_unit_id
AND a.financial_year             =$P{cmbFinancialYear}
$P!{circleQry}
$P!{queryAsset}
$P!{querp} order by a.accounting_unit_id]]></queryString>

