	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supplement_no" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT b.TRF_ACCOUNTING_UNIT_ID,
  (SELECT a.ACCOUNTING_UNIT_NAME
  FROM fas_mst_acct_units a
  WHERE a.ACCOUNTING_UNIT_ID=b.TRF_ACCOUNTING_UNIT_ID
  )unitName,
  b.tda_or_tca,
  B.Accounting_Unit_Id,
  (SELECT uu.accounting_unit_name
  FROM fas_mst_acct_units uu
  WHERE uu.Accounting_Unit_Id=b.Accounting_Unit_Id
  )AS orgUnitName,
  b.VOUCHER_NO
  || '    '
  ||b.VOUCHER_DATE AS vnd,
  b.TOTAL_AMOUNT,
  b. ORGINATING_JVR_NO
  || '     '
  ||b.ORGINATING_JVR_DATE AS ona,
  b.ACCEPTING_SLNO
  ||'&'
  || b.ACCEPTING_DATE AS accNo,
  c.ACCEPTING_JVR_NO
  ||'        '
  ||c.ACCEPTING_JVR_DATE AS jvrnd,
  b.RESPONDING_JVR_NO
  ||' '
  || b.RESPONDING_JVR_DATE
  ||' '
  || b.PARTICULARS AS parti
FROM FAS_TDA_TCA_RAISED_MST b,
  FAS_TDA_TCA_RAISED_MST c
WHERE b.TRF_ACCOUNTING_UNIT_ID=c.ACCOUNTING_UNIT_ID
And B.Accepting_Slno          =C.Voucher_No
And B.Accounting_Unit_Id      =$P{accountingunitid}
And B.Accounting_For_Office_Id=$P{accountofficeid}
And Extract(Month From b.Responding_Jvr_Date)          =$P{cashbookmonth}
AND extract(year from b.Responding_Jvr_Date)           =$P{cashbookyear}
AND (b.TDA_OR_TCA             ='TDACB'
OR b.TDA_OR_TCA               ='TDAO'
OR b.TDA_OR_TCA               ='TCACB'
OR b.TDA_OR_TCA               ='TCAO')
$P!{supplement_no}]]></queryString>

	<field name="TRF_ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="UNITNAME" class="java.lang.String"/>
	<field name="TDA_OR_TCA" class="java.lang.String"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ORGUNITNAME" class="java.lang.String"/>
