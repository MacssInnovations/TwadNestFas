<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="TransferDBorCR_test"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="651"
		 pageHeight="842"
		 columnWidth="591"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="adviceNo" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select a.*,
case 
when crdr='CR' then TOTAL_AMOUNT
end AS CRAmount,
case
when crdr='DR' then TOTAL_AMOUNT
 ELSE 0
END AS DRAmount
from
(
select tda_mst.TRF_ACCOUNTING_UNIT_ID,tda_mst.TOTAL_AMOUNT,tda_mst.ACCOUNTING_UNIT_ID,
tda_mst.CASHBOOK_YEAR,tda_mst.CASHBOOK_MONTH,
tda_mst.VOUCHER_NO,to_char(tda_mst.VOUCHER_DATE,'dd/MM/yyyy') as VOUCHER_DATE,tda_mst.ACCOUNT_HEAD_CODE||' & '||acc_desc.ACCOUNT_HEAD_DESC as acc_desc,
tda_mst.CR_DR_INDICATOR as crdr,
acc_units.accounting_unit_name,
(select  sum(TOTAL_AMOUNT)as ttlamt from FAS_TDA_TCA_RAISED_MST dd
where dd.ACCOUNTING_FOR_OFFICE_ID=tda_mst.ACCOUNTING_FOR_OFFICE_ID and 
dd.ACCOUNTING_UNIT_ID=tda_mst.ACCOUNTING_UNIT_ID and
dd.CASHBOOK_MONTH=tda_mst.CASHBOOK_MONTH and
dd.CASHBOOK_YEAR=tda_mst.CASHBOOK_YEAR and 
dd.TDA_OR_TCA=tda_mst.TDA_OR_TCA) as tt_Amt

from FAS_TDA_TCA_RAISED_MST tda_mst,com_mst_account_heads acc_desc,
fas_mst_acct_units acc_units
where tda_mst.ACCOUNTING_UNIT_ID=$P{accountingunitid} and 
tda_mst.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} and tda_mst.CASHBOOK_YEAR=$P{cashbookyear} and 
tda_mst.CASHBOOK_MONTH=$P{cashbookmonth} and  tda_mst.voucher_no=$P{adviceNo}
 AND (tda_mst.TDA_OR_TCA              ='TDAO' or tda_mst.TDA_OR_TCA              ='TCAO' OR 
  tda_mst.TDA_OR_TCA              ='TDACB'  or tda_mst.TDA_OR_TCA              ='TCACB')
and tda_mst.account_head_code = acc_desc.account_head_code
and tda_mst.TRF_ACCOUNTING_UNIT_ID = acc_units.accounting_unit_id 
)a]]></queryString>

	<field name="TRF_ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="TOTAL_AMOUNT" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="VOUCHER_NO" class="java.math.BigDecimal"/>
	<field name="VOUCHER_DATE" class="java.lang.String"/>
	<field name="ACC_DESC" class="java.lang.String"/>
	<field name="CRDR" class="java.lang.String"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="TT_AMT" class="java.math.BigDecimal"/>
	<field name="CRAMOUNT" class="java.math.BigDecimal"/>
	<field name="DRAMOUNT" class="java.math.BigDecimal"/>

	<variable name="sum_DRAmt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DRAMOUNT}]]></variableExpression>
	</variable>
	<variable name="SUM_DRAMOUNT_1" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{DRAMOUNT}]]></variableExpression>
	</variable>
