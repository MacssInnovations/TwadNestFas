<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="TDA_Report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1019"
		 pageHeight="842"
		 columnWidth="959"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="vou_no" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="supplement_no" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT DISTINCT b.*,
  a.ac,
  a.deb,
  a.crd,
  a.stype,
  a.scode,
  a.sl_no,
  (select ACCOUNTING_UNIT_NAME from FAS_MST_ACCT_UNITS where ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID)as unit_name,
    (select sub_ledger_type_desc from com_mst_sl_types where sub_ledger_type_code=a.stype ) as sl_desc,
    (select ACCOUNT_HEAD_DESC from COM_MST_ACCOUNT_HEADS where ACCOUNT_HEAD_CODE=a.ac)as ac_desc

FROM (
  (SELECT
    CASE
      WHEN deb='DR'
      THEN da
    END AS deb,
    CASE
      WHEN crd='CR'
      THEN ca
    END AS crd,
    CASE
      WHEN deb='DR'
      OR crd  ='CR'
      THEN ac
    END ac,
    CASE
      WHEN deb='DR'
      OR crd  ='CR'
      THEN stype
    END stype,
    CASE
      WHEN deb='DR'
      OR crd  ='CR'
      THEN scode
    END scode,
    CASE
      WHEN deb='DR'
      OR crd  ='CR'
      THEN unit
    END unit,
    CASE
      WHEN deb='DR'
      OR crd  ='CR'
      THEN office
    END office,
    CASE
      WHEN deb='DR'
      OR crd  ='CR'
      THEN cyear
    END cyear,
    CASE
      WHEN deb='DR'
      OR crd  ='CR'
      THEN num
    END num,
    CASE
      WHEN deb='DR'
      OR crd  ='CR'
      THEN cmonth
    END cmonth,sl_no
  FROM
    (SELECT VOUCHER_NO         AS num,
      SL_NO	               AS sl_no,
      AMOUNT                   AS da,
      amount                   AS ca,
      ACCOUNTING_UNIT_ID       AS unit,
      ACCOUNTING_FOR_OFFICE_ID AS office,
      CASHBOOK_YEAR            AS cyear,
      CASHBOOK_MONTH           AS cmonth,
      CR_DR_INDICATOR          AS deb,
      CR_DR_INDICATOR          AS crd,
      account_head_code        AS ac,
      SUB_LEDGER_TYPE_CODE     AS stype,
      SUB_LEDGER_CODE          AS scode
    FROM FAS_TDA_TCA_RAISED_TRN where ACCOUNTING_UNIT_ID=$P{accountingunitid} and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} and CASHBOOK_YEAR=$P{txtCB_Year} and CASHBOOK_MONTH=$P{txtCB_Month}
	order by sl_no
    )as ps
  )a
right OUTER JOIN
  (SELECT VOUCHER_NO,
    TRF_ACCOUNTING_UNIT_ID,
    --(select ACCOUNTING_UNIT_NAME,ACCOUNTING_UNIT_ID as uni from FAS_MST_ACCT_UNITS where uni=ACCOUNTING_UNIT_ID)as ACCOUNTING_UNIT_ID,
    VOUCHER_NO
    ||'-'
    ||TO_CHAR(VOUCHER_DATE,'dd/mm/yy') AS tda_no,
    TOTAL_AMOUNT                       AS amt,REASON_FOR_TRANSFER,
    (select REASON_DESC from FAS_MST_TDA_TCA_REASON where REASON_CODE::varchar=REASON_FOR_TRANSFER)as reason,
    ORGINATING_JVR_NO
    ||'-'
    ||TO_CHAR(ORGINATING_JVR_DATE,'dd/mm/yy') AS org_jvr_slno,
    TOTAL_AMOUNT,
    ACCEPTING_SLNO
    ||'-'
    ||TO_CHAR(ACCEPTING_DATE,'dd/mm/yy') AS accept_sl,
    ACCEPTING_JVR_NO
    ||'-'
    ||TO_CHAR(ACCEPTING_JVR_DATE,'dd/mm/yy') AS accept_jvr,
    ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH
  FROM FAS_TDA_TCA_RAISED_MST 
where ACCOUNTING_UNIT_ID=$P{accountingunitid} 
and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} 
and CASHBOOK_YEAR=$P{txtCB_Year} 
and CASHBOOK_MONTH=$P{txtCB_Month}
$P!{supplement_no}
  )b
ON a.unit   =b.ACCOUNTING_UNIT_ID
AND a.office=b.ACCOUNTING_FOR_OFFICE_ID
AND a.cyear =b.CASHBOOK_YEAR
AND a.cmonth=b.CASHBOOK_MONTH
AND a.num   =b.VOUCHER_NO)
ORDER BY a.sl_no]]></queryString>

	<field name="VOUCHER_NO" class="java.math.BigDecimal"/>
	<field name="TRF_ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="TDA_NO" class="java.lang.String"/>
