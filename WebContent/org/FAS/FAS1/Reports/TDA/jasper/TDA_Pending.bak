		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="tdatype" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cashyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthinwords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="reportName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="tpaTypeCB" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT a.*,
  b.ACCOUNTING_UNIT_NAME AS orgin_unit,
  c.accounting_unit_name AS accepting_unit
FROM
  (SELECT mst.VOUCHER_DATE,
    mst.ACCOUNTING_UNIT_ID,
    mst.TRF_ACCOUNTING_UNIT_ID,
    mst.particulars,
    mst.total_amount,
    mst.REASON_FOR_NON_ACCEPT,
    DECODE(mst.acceptance_status,NULL,'P',mst.acceptance_status) AS status
   -- mst.accept_voucher_date
  FROM FAS_TDA_TCA_RAISED_MST mst
   
  WHERE mst.status                ='L'
 
  AND mst.TRF_ACCOUNTING_UNIT_ID  =$P{unitid}
  AND mst.cashbook_month          =$P{cashmonth}
  AND mst.cashbook_year           =$P{cashyear}
  AND (mst.TDA_OR_TCA                =$P{tdatype} OR mst.TDA_OR_TCA      =$P{tpaTypeCB})
  AND mst.acceptance_status       IS NULL
  )a
LEFT OUTER JOIN FAS_MST_ACCT_UNITS b
ON a.ACCOUNTING_UNIT_ID=b.accounting_unit_id
LEFT OUTER JOIN FAS_MST_ACCT_UNITS c
ON c.ACCOUNTING_UNIT_ID=a.TRF_ACCOUNTING_UNIT_ID]]></queryString>

