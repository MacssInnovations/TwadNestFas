	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="voucher_no" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="orgUnitName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="heading_one" isForPrompting="true" class="java.lang.String"/>
	<parameter name="heading" isForPrompting="true" class="java.lang.String"/>
	<parameter name="drcode" isForPrompting="false" class="java.lang.String"/>
	<parameter name="crcode" isForPrompting="false" class="java.lang.String"/>
	<parameter name="supplement_no" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT a.*,
  CASE
    WHEN CR_DR_INDICATOR='CR'
    THEN TOTAL_AMOUNT
  END AS CRAmount,
  CASE
    WHEN CR_DR_INDICATOR='DR'
    THEN TOTAL_AMOUNT
  END AS DRAmount
FROM
  (SELECT tda_mst.TRF_ACCOUNTING_UNIT_ID,
    tda_mst.TOTAL_AMOUNT,
    tda_mst.CASHBOOK_YEAR,
    tda_mst.CASHBOOK_MONTH,
    tda_mst.ACCEPTING_JVR_NO,
    tda_mst.ACCEPTING_JVR_DATE,
    tda_mst.VOUCHER_NO,
    tda_mst.VOUCHER_DATE,
    Org_Unit.Voucher_No   AS org_no,
    org_unit.voucher_date AS org_date,
    tda_mst.ACCOUNT_HEAD_CODE
    ||' & '
    ||acc_desc.ACCOUNT_HEAD_DESC AS acc_desc,
    tda_mst.CR_DR_INDICATOR,
    acc_units.accounting_unit_name,
    (SELECT SUM(TOTAL_AMOUNT)AS ttlamt
    FROM FAS_TDA_TCA_RAISED_MST dd
    WHERE dd.ACCOUNTING_FOR_OFFICE_ID=tda_mst.ACCOUNTING_FOR_OFFICE_ID
    AND dd.ACCOUNTING_UNIT_ID        =tda_mst.ACCOUNTING_UNIT_ID
    AND dd.CASHBOOK_MONTH            =tda_mst.CASHBOOK_MONTH
    AND dd.CASHBOOK_YEAR             =tda_mst.CASHBOOK_YEAR
    AND dd.TDA_OR_TCA                =tda_mst.TDA_OR_TCA
    ) AS tt_Amt,tda_mst.particulars
  FROM FAS_TDA_TCA_RAISED_MST tda_mst,
    Fas_Tda_Tca_Raised_Mst org_unit,
    com_mst_account_heads acc_desc,
    fas_mst_acct_units acc_units
  WHERE tda_mst.accounting_unit_id    =org_unit.trf_accounting_unit_id
  AND Tda_Mst.Voucher_No              =Org_Unit.Accepting_Slno
  AND tda_mst.ACCOUNTING_UNIT_ID      =$P{accountingunitid}
  AND tda_mst.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND tda_mst.CASHBOOK_YEAR           =$P{cashbookyear}
  AND tda_mst.STATUS                  ='L'
  AND tda_mst.CASHBOOK_MONTH          =$P{cashbookmonth}
  AND (tda_mst.TDA_OR_TCA             ='TDAA'
  OR tda_mst.TDA_OR_TCA               ='TCAA')
  AND tda_mst.VOUCHER_NO              =$P{voucher_no}
  AND tda_mst.account_head_code       = acc_desc.account_head_code
  AND tda_mst.TRF_ACCOUNTING_UNIT_ID  = acc_units.accounting_unit_id
 $P!{supplement_no}
  )a]]></queryString>

