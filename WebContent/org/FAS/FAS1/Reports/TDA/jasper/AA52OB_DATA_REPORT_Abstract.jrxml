<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="AA52OB_DATA_REPORT_Abstract"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1074"
		 pageHeight="842"
		 columnWidth="1014"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cmbFinancialYear" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT a.ACCOUNTING_UNIT_ID ,
  (SELECT cc.Accounting_Unit_Name
  FROM fas_mst_acct_units cc
  WHERE cc.Accounting_Unit_Id=a.ACCOUNTING_UNIT_ID
  )AS unitname,
  ACCOUNTING_UNIT_OFFICE_ID,
  (SELECT oo.OFFICE_NAME
  FROM COM_MST_OFFICES oo
  WHERE oo.OFFICE_ID=ACCOUNTING_UNIT_OFFICE_ID
  )AS officename,
  FINANCIAL_YEAR,
  JOURNAL_NO,
  JOURNAL_DATE,
  SURVEY_NO,
  SURVEY_DATE,
  AUCTION_DATE,
  PERSON_NAME,
  CB_VOUCHERNO,
  CB_VOUCHERDATE,
  PROFIT,
  LOSS,
 disc_jvr_type,
  final_adj_jvr_no,
  final_adj_jvr_date,
 final_adj_jvr_type,
  doh_asset_to_aucionee,
  a.ASSET_MAJOR_CLASS_CODE,
  (SELECT bb.ASSET_MAJOR_CLASS_DESC
  FROM FAS_MST_ASSETS_CLASS bb
  WHERE bb.ASSET_MAJOR_CLASS_CODE=a.ASSET_MAJOR_CLASS_CODE
  )                  AS major_class_desc,
  SUM( a.BOOKVALUE)  AS BOOKVALUE,
  SUM( a.APPOR_GRANT)AS APPOR_GRANT,
  SUM(a.DEP_DEBIT)   AS DEP_DEBIT,
  SUM(AUCTION_AMOUNT)AS AUCTION_AMOUNT,
  SUM(a.OFF_DEBIT)   AS OFF_DEBIT,
  SUM(a.OFF_CREDIT)  AS OFF_CREDIT,
  sum(a.quantity) AS quantity
FROM FAS_AA52REGISTER a
Where Accounting_Unit_Id=$P{accountingunitid}
And Financial_Year=$P{cmbFinancialYear}
GROUP BY a.ACCOUNTING_UNIT_ID,
  ACCOUNTING_UNIT_OFFICE_ID,
  FINANCIAL_YEAR,
  JOURNAL_NO,
  JOURNAL_DATE,
  SURVEY_NO,
  SURVEY_DATE,
  AUCTION_DATE,
  PERSON_NAME,
  CB_VOUCHERNO,
  CB_VOUCHERDATE,
  PROFIT,
  LOSS,disc_jvr_type,
  final_adj_jvr_no,
  final_adj_jvr_date,
 final_adj_jvr_type,
  doh_asset_to_aucionee,
  a.ASSET_MAJOR_CLASS_CODE]]></queryString>

