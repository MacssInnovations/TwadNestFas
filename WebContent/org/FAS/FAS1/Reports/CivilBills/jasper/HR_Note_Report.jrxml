	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Fin_year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="CByear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="CBmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="billmajorcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="billminorcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="billsubcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="note_No" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT hr_note_no,
  note_date,
  note_amount,
--'( '||to_char(to_date(note_amount,'J'), 'JSP')|| ' ONLY )' as note_amount_1,

    replace(upper(substr(to_char(to_date(note_amount,'J'), 'JSP'), 1, 1)) || lower(substr(to_char(to_date(note_amount,'J'), 'JSP'), 2))||' only','-',' ')
 as note_amount_1,  a.account_head_code AS acctcode,
  b.account_head_desc,
  c.CURRENT_YEAR_BUDGET_ALLOTTED               AS bud_provided,
  a.note_amount                                AS bud_spent,
  c.CURRENT_YEAR_BUDGET_ALLOTTED-a.note_amount AS bal_amt,
  d.office_name,
  a.FINANCIAL_YEAR
FROM
  (SELECT accounting_unit_id,
    accounting_for_office_id,
    hr_note_no,
    FINANCIAL_YEAR,
    note_date,
    note_amount,
    account_head_code
  FROM fas_hr_note_details
  WHERE accounting_unit_id     =$P{accountingunitid}
  AND accounting_for_office_id = $P{accountofficeid}
  AND bill_major_type_code     =$P{billmajorcode}
  AND bill_minor_type_code     =$P{billminorcode}
  AND bill_sub_type_code       = $P{billsubcode}
  AND financial_year           =$P{Fin_year}
  AND hr_note_no               =$P{note_No}
  )a
INNER JOIN
  (SELECT account_head_code,account_head_desc FROM com_mst_account_heads
  ) b
ON a.account_head_code = b.account_head_code
JOIN
  (SELECT office_id,office_name FROM com_mst_offices
  )d
ON d.office_id = a.accounting_for_office_id
INNER JOIN
  (SELECT account_head_code,
    CURRENT_YEAR_BUDGET_ALLOTTED,
    BUDGET_SOFAR_SPENT,
    FINANCIAL_YEAR
  FROM COM_BUDGET_DETAILS
  WHERE accounting_unit_id     =$P{accountingunitid}
  AND accounting_for_office_id =$P{accountofficeid}
  )c
ON trim(c.FINANCIAL_YEAR)=trim(a.FINANCIAL_YEAR)
AND c.account_head_code  = a.account_head_code]]></queryString>

