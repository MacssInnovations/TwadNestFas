	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cheqNO" isForPrompting="true" class="java.lang.String"/>
	<parameter name="drawdate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="recNo" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select accUint.ACCOUNTING_UNIT_NAME, Office.OFFICE_NAME,c.OFFICE_NAME as disburseoffice,a.EMPLOYEE_CODE,
e.EMPLOYEE_INITIAL ||' '||e.EMPLOYEE_NAME ||' ('||a.EMPLOYEE_CODE||')' 
 AS empName,b.DESIGNATION,a.ACCOUNTING_UNIT_ID,a.ACCOUNTING_FOR_OFFICE_ID,a.DISBURSING_OFFICE_CODE,a.EMPLOYEE_CODE,a.sum_Amt from 
( select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,DISBURSING_OFFICE_CODE,
EMPLOYEE_CODE,sum(TOTAL_AMOUNT) as sum_Amt from 
FAS_ACQ_ROLL_TRANSACTION a
where ACCOUNTING_UNIT_ID=$P{acc_unit_id} and ACCOUNTING_FOR_OFFICE_ID=$P{off_id}
and CASHBOOK_YEAR =$P{yr} and 
CASHBOOK_MONTH=$P{mon} and 
VOUCHER_NO in
(select VOUCHER_NO from FAS_PAYMENT_MASTER where ACCOUNTING_UNIT_ID=$P{acc_unit_id}  and 
ACCOUNTING_FOR_OFFICE_ID=$P{off_id} and CASHBOOK_YEAR =$P{yr} and CASHBOOK_MONTH=$P{mon} and SELFCHEQUE_RECEIPT_NO=$P{recNo} 
 and NO_OF_ACQ_ROLLS>0)
group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,DISBURSING_OFFICE_CODE,EMPLOYEE_CODE ) a,
HRM_MST_EMPLOYEES e,COM_MST_OFFICES c,HRM_EMP_CURRENT_POSTING d,
HRM_MST_DESIGNATIONS b ,COM_MST_OFFICES Office, FAS_MST_ACCT_UNITS accUint 
where  e.EMPLOYEE_ID=a.EMPLOYEE_CODE and 
c.OFFICE_ID=a.DISBURSING_OFFICE_CODE
and a.EMPLOYEE_CODE=d.EMPLOYEE_ID and d.DESIGNATION_ID=b.DESIGNATION_ID and  
a.ACCOUNTING_UNIT_ID=accUint.ACCOUNTING_UNIT_ID 
and a.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID
order by a.DISBURSING_OFFICE_CODE,a.EMPLOYEE_CODE]]></queryString>

	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="DISBURSING_OFFICE_CODE" class="java.math.BigDecimal"/>
	<field name="DISBURSEOFFICE" class="java.lang.String"/>
	<field name="EMPLOYEE_CODE" class="java.math.BigDecimal"/>
	<field name="EMPNAME" class="java.lang.String"/>
	<field name="DESIGNATION" class="java.lang.String"/>
	<field name="SUM_AMT" class="java.math.BigDecimal"/>


