	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cheq_no" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cheq_date" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select b.ACCOUNTING_UNIT_NAME,c.OFFICE_NAME,a.ACCOUNTING_UNIT_ID,a.ACCOUNTING_FOR_OFFICE_ID,a.CASHBOOK_YEAR,a.CASHBOOK_MONTH,a.ACQ_ROLL_NO,
       a.VOUCHER_NO,a.DATE_OF_DISBURSE,a.AMOUNT_DISBURSED,a.UNDISBURSED,a.REMARKS,a.ACCOUNT_HEAD_CODE,a.CHEQUE_AMOUNT 
from FAS_UDP_REGISTER_REPORT a,FAS_MST_ACCT_UNITS b,COM_MST_OFFICES c
where a.ACCOUNTING_UNIT_ID=$P{accountingunitid} 
      and a.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} 
      and a.CASHBOOK_YEAR=$P{txtCB_Year}  
      and a.CASHBOOK_MONTH=$P{txtCB_Month} 
      and a.CHEQUE_NO=$P{cheq_no} 
      and a.CHEQUE_DATE=to_date($P{cheq_date},'DD/MM/YYYY')
      and a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID
      and a.ACCOUNTING_FOR_OFFICE_ID=c.OFFICE_ID
      

order by a.CHEQUE_NO,a.CHEQUE_DATE,a.UNDISBURSED desc]]></queryString>

