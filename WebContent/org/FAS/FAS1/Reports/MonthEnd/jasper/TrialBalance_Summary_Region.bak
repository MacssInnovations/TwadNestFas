<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="TrialBalance_Summary_Region"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="870"
		 pageHeight="595"
		 columnWidth="810"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="RegionName" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select 
     
      acchead1 as "ACCHEAD1",
      account_head_desc as "ACCOUNT_HEAD_DESC" ,
      cashbook_month,
      debit_opening_balance as "DEBIT_OPENING_BALANCE", 
      credit_opening_balance as "CREDIT_OPENING_BALANCE",
      current_month_debit as "CURRENT_MONTH_DEBIT",
      current_month_credit as "CURRENT_MONTH_CREDIT",      
      ( debit_opening_balance + current_month_debit ) as "DEBIT_CB" ,
      ( credit_opening_balance + current_month_credit ) as "CREDIT_CB" ,     
      x1 as "X1",
      y1 as "Y1"
      
from 
(


select * from
(



select 
 
   account_head_code, 
   to_char(mon_year_date,'MM') as cashbook_month1,
   to_char(mon_year_date, 'YYYY' ) as cashbook_year1
from 
(
     select 
    
       account_head_code, 
       min(mon_year_date) as mon_year_date
    from 
     (
          select 
             
              account_head_code, 
              ( to_date(cashbook_month ||'-'|| cashbook_year, 'mm-yyyy')) as mon_year_date
          from
              fas_trial_balance 
          where       
             accounting_unit_id in (SELECT ACCOUNTING_UNIT_ID
FROM FAS_MST_ACCT_UNITS
WHERE ACCOUNTING_UNIT_OFFICE_ID in
  (SELECT OFFICE_ID FROM COM_MST_ALL_OFFICES_VIEW  where REGION_OFFICE_ID=($P{accountingunitid}::int)
  )
) and 
             to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth}::int)  || '-' || ($P{from_cashbookyear}::int) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}::int) ||'-' || ($P{to_cashbookyear}::int) , 'mm-yyyy')
  
    ) as opt1
    group by 
    account_head_code
) as opt2
order by  
account_head_code 

) a


left outer join

(select  acchead1,
   cashbook_month, 
   cashbook_year,
 sum(debit_opening_balance) as debit_opening_balance, 
   sum(credit_opening_balance) as credit_opening_balance 
   from 
(select 
  
   account_head_code as acchead1,
   cashbook_month, 
   cashbook_year,
    debit_opening_balance, 
   credit_opening_balance
from 
   fas_trial_balance
where  
   accounting_unit_id in (SELECT ACCOUNTING_UNIT_ID 
FROM FAS_MST_ACCT_UNITS
WHERE ACCOUNTING_UNIT_OFFICE_ID in
  (SELECT OFFICE_ID FROM COM_MST_ALL_OFFICES_VIEW  where REGION_OFFICE_ID=($P{accountingunitid}::int)
  )
) and 
   to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth}::int)  || '-' || ($P{from_cashbookyear}::int) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}::int) ||'-' || ($P{to_cashbookyear}::int) , 'mm-yyyy')
 
   
) as opt3 group by acchead1, 
   cashbook_month, 
   cashbook_year ) b

on  
    a.account_head_code = b.acchead1 and  
    a.cashbook_month1 = b.cashbook_month::varchar  and  
    a.cashbook_year1 = b.cashbook_year::varchar   

left outer join 
 
(
select 
      account_head_code,
      sum(current_month_debit) as current_month_debit,
      sum(current_month_credit) as current_month_credit 
      
from 
    fas_trial_balance  
where 
   accounting_unit_id in (SELECT ACCOUNTING_UNIT_ID
FROM FAS_MST_ACCT_UNITS
WHERE ACCOUNTING_UNIT_OFFICE_ID in
  (SELECT OFFICE_ID FROM COM_MST_ALL_OFFICES_VIEW  where REGION_OFFICE_ID=($P{accountingunitid}::int)
  )
) and 
   to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth}::int)  || '-' || ($P{from_cashbookyear}::int) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}::int) ||'-' || ($P{to_cashbookyear}::int) , 'mm-yyyy') 
   
   group by account_head_code   
   order by account_head_code
)c
on b.acchead1=c.account_head_code 

left outer join 

(
select account_head_desc, account_head_code as achcode from com_mst_account_heads
)d
on d.achcode=c.account_head_code

) as opt4,


( select 

   sum(CURRENT_MONTH_DEBIT) as x1 , 
   sum(CURRENT_MONTH_CREDIT) as  y1 
      
from  
      fas_trial_balance 
  
where 
 
      accounting_unit_id  in (SELECT ACCOUNTING_UNIT_ID
FROM FAS_MST_ACCT_UNITS
WHERE ACCOUNTING_UNIT_OFFICE_ID in
  (SELECT OFFICE_ID FROM COM_MST_ALL_OFFICES_VIEW  where REGION_OFFICE_ID=($P{accountingunitid}::int)
  )
)  and       
      to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth}::int)  || '-' || ($P{from_cashbookyear}::int) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}::int) ||'-' || ($P{to_cashbookyear}::int) , 'mm-yyyy')
     
) as opt411

order by acchead1]]></queryString>

