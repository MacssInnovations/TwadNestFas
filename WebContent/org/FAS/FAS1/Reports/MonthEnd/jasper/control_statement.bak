	<parameter name="regionId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yearfrom" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yearto" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthfrom" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthto" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="acchead" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supno" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="financialyear" isForPrompting="true" class="java.lang.String"/>
	<parameter name="offname" isForPrompting="true" class="java.lang.String"/>
	<parameter name="strQuery" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[Select sup,
(Cashbook_Month||'-'||Cashbook_Year)as year,Ct_Db,Ct_Cr,
CASE
    WHEN Ct_Db>Ct_Cr
    THEN (Ct_Db-Ct_Cr)
      ||' DR'
    WHEN Ct_Cr>Ct_Db
    THEN (Ct_Cr-Ct_Db)
      ||' CR'
    ELSE '0'
  END AS Net_Total,
Account_Head_Code,
Headdesc
From
(Select 'Regular' as sup,
T.Cashbook_Year,
t.Cashbook_Month,
Sum(Current_Month_Debit) As Ct_Db,
Sum(Current_Month_Credit) As Ct_Cr,T.Account_Head_Code,
(Select S.Account_Head_Desc From Com_Mst_Account_Heads S Where S.Account_Head_Code=t.Account_Head_Code)As Headdesc
From FAS_TRIAL_BALANCE_CMP t Where 
To_Date((Cashbook_Month
  ||'-'
  || Cashbook_Year),'mm-yyyy') BETWEEN To_Date($P{monthfrom}
  ||'-'
  ||$P{yearfrom},'mm-yyyy')
AND to_date($P{monthto}
  ||'-'
  ||$P{yearto},'mm-yyyy') 
  --And Account_Head_Code=390302
$P!{acchead}
$P!{strQuery}
 Group By Cashbook_Year,Cashbook_Month,Account_Head_Code
  
  union all
  
  Select 'S'||supplement_no as sup,
  T.Cashbook_Year,
t.Cashbook_Month,
Sum(Current_Month_Debit) As Ct_Db,
Sum(Current_Month_Credit) As Ct_Cr,T.Account_Head_Code,
(Select S.Account_Head_Desc From Com_Mst_Account_Heads S Where S.Account_Head_Code=T.Account_Head_Code)As Headdesc
From FAS_TRIAL_BALANCE_SJV_CMP t Where Cashbook_Year=$P{yearto} and Cashbook_Month=$P{monthto} and SUPPLEMENT_NO<=$P{supno}

  --And Account_Head_Code=390302
$P!{acchead}
 $P!{strQuery}
  Group By Cashbook_Year,Cashbook_Month,Account_Head_Code,Supplement_No

  
  ) Order By Account_Head_Code,Cashbook_Year,Cashbook_Month,sup]]></queryString>

	<field name="SUP" class="java.lang.String"/>
	<field name="YEAR" class="java.lang.String"/>
	<field name="CT_DB" class="java.math.BigDecimal"/>
	<field name="CT_CR" class="java.math.BigDecimal"/>
	<field name="NET_TOTAL" class="java.lang.String"/>
	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="HEADDESC" class="java.lang.String"/>

	<variable name="ttl_debit" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CT_DB}]]></variableExpression>
	</variable>
	<variable name="ttl_credit" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CT_CR}]]></variableExpression>
	</variable>
	<variable name="ttl_net" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[(($V{ttl_debit}.subtract($V{ttl_credit})).intValue()<0) ? ($V{ttl_credit}.subtract($V{ttl_debit}))+" CR" : ($V{ttl_debit}.subtract($V{ttl_credit}))+" DR"]]></variableExpression>
	</variable>
	<variable name="h_debit" class="java.math.BigDecimal" resetType="Group" resetGroup="headcode" calculation="Sum">
		<variableExpression><![CDATA[$F{CT_DB}]]></variableExpression>
	</variable>
	<variable name="h_credit" class="java.math.BigDecimal" resetType="Group" resetGroup="headcode" calculation="Sum">
		<variableExpression><![CDATA[$F{CT_CR}]]></variableExpression>
	</variable>
	<variable name="head_net" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[(($V{h_debit}.subtract($V{h_credit})).intValue()<0) ? ($V{h_credit}.subtract($V{h_debit}))+" CR" : ($V{h_debit}.subtract($V{h_credit}))+" DR"]]></variableExpression>
	</variable>

