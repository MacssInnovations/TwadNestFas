<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="fund_receipt_by_office_before_TB_FORALLUNITS"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="737"
		 pageHeight="842"
		 columnWidth="677"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="year1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="year2" isForPrompting="true" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["/home/twadonline_new/WebContent/org/FAS/FAS1/Reports/FundReceiptSystem/jasper/sub_report/"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[Select O.Accounting_Unit_Id,
(select u.accounting_unit_name from fas_mst_acct_units u where u.accounting_unit_id=o.Accounting_Unit_Id)as unitName,
A.Transfer_To_Office_Id,
A.Cashbook_Year,
A.Cashbook_Month,
A.Bamt,
O.Offamt,
(A.Bamt-O.Offamt)As Diff,
A.Ttlbank,
O.Ttloffice,
(A.Ttlbank-O.Ttloffice)as cumDiff
from
(
--bank amt calculation
Select 
Transfer_To_Office_Id,Cashbook_Year,Cashbook_Month,Bamt,
--finding cumm diff split monthwise total
Case When Cashbook_Month=4 Then Bamt
  when Cashbook_Month=5 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        And Mas.Transfer_Status         ='L'
       And Trn.Cashbook_Month In(4,5) And Trn.Cashbook_Year=$P{year1})
 when Cashbook_Month=6 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        And Mas.Transfer_Status         ='L'
       And Trn.Cashbook_Month In(4,5,6) And Trn.Cashbook_Year=$P{year1})
when Cashbook_Month=7 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        And Mas.Transfer_Status         ='L'
       And Trn.Cashbook_Month In(4,5,6,7) And Trn.Cashbook_Year=$P{year1})
when Cashbook_Month=8 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        And Mas.Transfer_Status         ='L'
        And Trn.Cashbook_Month In(4,5,6,7,8) And Trn.Cashbook_Year=$P{year1})
when Cashbook_Month=9 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        And Mas.Transfer_Status         ='L'
        And Trn.Cashbook_Month In(4,5,6,7,8,9) And Trn.Cashbook_Year=2011)
when Cashbook_Month=10 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        And Mas.Transfer_Status         ='L'
        And Trn.Cashbook_Month In(4,5,6,7,8,9,10) And Trn.Cashbook_Year=2011)
when Cashbook_Month=11 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        And Mas.Transfer_Status         ='L'
       And Trn.Cashbook_Month In(4,5,6,7,8,9,10,11) And Trn.Cashbook_Year=2011)
when Cashbook_Month=12 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        And Mas.Transfer_Status         ='L'
        And Trn.Cashbook_Month In(4,5,6,7,8,9,10,11,12) And Trn.Cashbook_Year=$P{year1})
when Cashbook_Month=1 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        And Mas.Transfer_Status         ='L'
       AND To_Date((Trn.Cashbook_Month
          ||'-'
          || Trn.Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
          ||'-'
          ||$P{year1},'mm-yyyy') And To_Date(1||'-'||$P{year2},'mm-yyyy'))
when Cashbook_Month=2 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
      INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
      ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
      AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
      AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
      AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
      AND Mas.Voucher_No              =Trn.Voucher_No
      And Mas.Transfer_Status         ='L'
     AND To_Date((Trn.Cashbook_Month
        ||'-'
        || Trn.Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
        ||'-'
        ||$P{year1},'mm-yyyy') And To_Date(2||'-'||$P{year2},'mm-yyyy'))
when Cashbook_Month=3 then (select Sum(Trn.Amount)As mayamt from  Fas_Fund_Trf_From_Ho_Master Mas
    INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
    ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
    AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
    AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
    AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
    AND Mas.Voucher_No              =Trn.Voucher_No
    And Mas.Transfer_Status         ='L'
   AND To_Date((Trn.Cashbook_Month
      ||'-'
      || Trn.Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
      ||'-'
      ||$P{year1},'mm-yyyy') and to_date(3||'-'||$P{year2},'mm-yyyy'))
end as ttlBank

from
(SELECT Trn.Transfer_To_Office_Id,
  Trn.Cashbook_Year,
  Trn.Cashbook_Month,
  Sum(Trn.Amount)As Bamt
FROM Fas_Fund_Trf_From_Ho_Master Mas
INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
AND Mas.Voucher_No              =Trn.Voucher_No
AND Mas.Transfer_Status         ='L'
AND To_Date((Trn.Cashbook_Month
  ||'-'
  || Trn.Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
  ||'-'
  ||$P{year1},'mm-yyyy') and to_date(3||'-'||$P{year2},'mm-yyyy')
GROUP BY Trn.Transfer_To_Office_Id, Trn.Cashbook_Year, Trn.Cashbook_Month
ORDER BY Trn.Transfer_To_Office_Id,
  Trn.Cashbook_Year,
  Trn.Cashbook_Month)
)A
  inner Join
  (
  --office
  Select Accounting_For_Office_Id,ACCOUNTING_UNIT_ID,
Cashbook_Year,
Cashbook_Month,
offAmt,
Case 
  When Cashbook_Month=4 Then Offamt
when Cashbook_Month=5 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
        And Cashbook_Month In(4,5) And Cashbook_Year=$P{year1})
when Cashbook_Month=6 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
        And Cashbook_Month In(4,5,6) And Cashbook_Year=2011)
  when Cashbook_Month=7 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
        And Cashbook_Month In(4,5,6,7) And Cashbook_Year=$P{year1})
when Cashbook_Month=8 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
        And Cashbook_Month In(4,5,6,7,8) And Cashbook_Year=$P{year1})
when Cashbook_Month=9 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
        And Cashbook_Month In(4,5,6,7,8,9) And Cashbook_Year=$P{year1})
when Cashbook_Month=10 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
        And Cashbook_Month In(4,5,6,7,8,9,10) And Cashbook_Year=$P{year1})
when Cashbook_Month=11 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
        And Cashbook_Month In(4,5,6,7,8,9,10,11) And Cashbook_Year=$P{year1})
when Cashbook_Month=12 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
        And Cashbook_Month In(4,5,6,7,8,9,10,11,12) And Cashbook_Year=$P{year1})  
when Cashbook_Month=1 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
        AND To_Date((Cashbook_Month
        ||'-'
        || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
        ||'-'
        ||$P{year1},'mm-yyyy') And To_Date(1||'-'||$P{year2},'mm-yyyy'))
when Cashbook_Month=2 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
        AND To_Date((Cashbook_Month
        ||'-'
        || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
        ||'-'
        ||$P{year1},'mm-yyyy') And To_Date(2||'-'||$P{year2},'mm-yyyy'))
when Cashbook_Month=3 then(Select sum(TOTAL_AMOUNT)as offAmt
        FROM Fas_Fund_Receipt_By_Office
        Where Receipt_Status        ='L'
       AND To_Date((Cashbook_Month
        ||'-'
        || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
        ||'-'
        ||$P{year1},'mm-yyyy') And To_Date(3||'-'||$P{year2},'mm-yyyy'))
End As Ttloffice
from
(Select Accounting_For_Office_Id,ACCOUNTING_UNIT_ID,
Cashbook_Year,
Cashbook_Month,
sum(TOTAL_AMOUNT)as offAmt
  FROM Fas_Fund_Receipt_By_Office
  WHERE Receipt_Status        ='L'
 AND To_Date((Cashbook_Month
  ||'-'
  || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
  ||'-'
  ||$P{year1},'mm-yyyy') And To_Date(3||'-'||$P{year2},'mm-yyyy')
  Group By Accounting_For_Office_Id, Accounting_Unit_Id, Cashbook_Year, Cashbook_Month
  Order By Accounting_For_Office_Id, Cashbook_Year, Cashbook_Month)
  )o
  ON o.Accounting_For_Office_Id =a.Transfer_To_Office_Id
And O.Cashbook_Year           =A.Cashbook_Year
And O.Cashbook_Month          =A.Cashbook_Month
order by unitName,O.Cashbook_Year,O.Cashbook_Month]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="UNITNAME" class="java.lang.String"/>
	<field name="TRANSFER_TO_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="BAMT" class="java.math.BigDecimal"/>
	<field name="OFFAMT" class="java.math.BigDecimal"/>
	<field name="DIFF" class="java.math.BigDecimal"/>
	<field name="TTLBANK" class="java.math.BigDecimal"/>
	<field name="TTLOFFICE" class="java.math.BigDecimal"/>
	<field name="CUMDIFF" class="java.math.BigDecimal"/>

	<variable name="bankTotal" class="java.math.BigDecimal" resetType="Group" resetGroup="unitId" calculation="Sum">
		<variableExpression><![CDATA[$F{BAMT}]]></variableExpression>
	</variable>
	<variable name="offTotal" class="java.math.BigDecimal" resetType="Group" resetGroup="unitId" calculation="Sum">
		<variableExpression><![CDATA[$F{OFFAMT}]]></variableExpression>
	</variable>
	<variable name="diffe_bank_off" class="java.math.BigDecimal" resetType="Group" resetGroup="unitId" calculation="Nothing">
		<variableExpression><![CDATA[$V{bankTotal}.subtract($V{offTotal})]]></variableExpression>
	</variable>

		<group  name="unitId" >
			<groupExpression><![CDATA[$F{ACCOUNTING_UNIT_ID}]]></groupExpression>
			<groupHeader>
			<band height="25"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" pattern="###0" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
