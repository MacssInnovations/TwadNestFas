		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="535"
		 pageHeight="802"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[--office
  SELECT Accounting_For_Office_Id,
    ACCOUNTING_UNIT_ID,
    Cashbook_Year,
    Cashbook_Month,
    offAmt,
    CASE
      WHEN Cashbook_Month=4
      THEN Offamt
      WHEN Cashbook_Month=5
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND Cashbook_Month  IN(4,5)
        AND Cashbook_Year    =2012
        )
      WHEN Cashbook_Month=6
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND Cashbook_Month  IN(4,5,6)
        AND Cashbook_Year    =2011
        )
      WHEN Cashbook_Month=7
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND Cashbook_Month  IN(4,5,6,7)
        AND Cashbook_Year    =2012
        )
      WHEN Cashbook_Month=8
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND Cashbook_Month  IN(4,5,6,7,8)
        AND Cashbook_Year    =2012
        )
      WHEN Cashbook_Month=9
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND Cashbook_Month  IN(4,5,6,7,8,9)
        AND Cashbook_Year    =2012
        )
      WHEN Cashbook_Month=10
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND Cashbook_Month  IN(4,5,6,7,8,9,10)
        AND Cashbook_Year    =2012
        )
      WHEN Cashbook_Month=11
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND Cashbook_Month  IN(4,5,6,7,8,9,10,11)
        AND Cashbook_Year    =2012
        )
      WHEN Cashbook_Month=12
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND Cashbook_Month  IN(4,5,6,7,8,9,10,11,12)
        AND Cashbook_Year    =2012
        )
      WHEN Cashbook_Month=1
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND To_Date((Cashbook_Month
          ||'-'
          || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
          ||'-'
          ||2012,'mm-yyyy')
        AND To_Date(1
          ||'-'
          ||2013,'mm-yyyy')
        )
      WHEN Cashbook_Month=2
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND To_Date((Cashbook_Month
          ||'-'
          || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
          ||'-'
          ||2012,'mm-yyyy')
        AND To_Date(2
          ||'-'
          ||2013,'mm-yyyy')
        )
      WHEN Cashbook_Month=3
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status ='L'
        AND To_Date((Cashbook_Month
          ||'-'
          || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
          ||'-'
          ||2012,'mm-yyyy')
        AND To_Date(3
          ||'-'
          ||2013,'mm-yyyy')
        )
    END AS Ttloffice
  FROM
    (SELECT Accounting_For_Office_Id,
      ACCOUNTING_UNIT_ID,
      Cashbook_Year,
      Cashbook_Month,
      SUM(TOTAL_AMOUNT)AS offAmt
    FROM Fas_Fund_Receipt_By_Office
    WHERE Receipt_Status ='L'
    AND To_Date((Cashbook_Month
      ||'-'
      || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
      ||'-'
      ||2012,'mm-yyyy')
    AND To_Date(3
      ||'-'
      ||2013,'mm-yyyy')
    GROUP BY Accounting_For_Office_Id,
      Accounting_Unit_Id,
      Cashbook_Year,
      Cashbook_Month
    ORDER BY Accounting_For_Office_Id,Accounting_Unit_Id,
      Cashbook_Year,
      Cashbook_Month
    )]]></queryString>

	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="OFFAMT" class="java.math.BigDecimal"/>
	<field name="TTLOFFICE" class="java.math.BigDecimal"/>

