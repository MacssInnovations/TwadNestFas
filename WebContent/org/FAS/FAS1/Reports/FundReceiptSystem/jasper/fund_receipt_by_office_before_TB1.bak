<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="fund_receipt_by_office_before_TB1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="793"
		 pageHeight="842"
		 columnWidth="733"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="year2" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountingunit" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT O.Accounting_Unit_Id,
  (SELECT u.accounting_unit_name
  FROM fas_mst_acct_units u
  WHERE u.accounting_unit_id=o.Accounting_Unit_Id
  )AS unitName,
  A.Transfer_To_Office_Id,
  A.Cashbook_Year,
  A.Cashbook_Month,
  A.Bamt,
  O.Offamt,
  (A.Bamt-O.Offamt)AS Diff,
  A.Ttlbank,
  O.Ttloffice,
  (A.Ttlbank-O.Ttloffice)AS cumDiff
FROM
  (
  --bank amt calculation
  SELECT Transfer_To_Office_Id,
    Cashbook_Year,
    Cashbook_Month,
    Bamt,
    --finding cumm diff split monthwise total
    CASE
      WHEN Cashbook_Month=4
      THEN Bamt
      WHEN Cashbook_Month=5
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND Trn.Cashbook_Month         IN(4,5)
        AND Trn.Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=6
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND Trn.Cashbook_Month         IN(4,5,6)
        AND Trn.Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=7
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND Trn.Cashbook_Month         IN(4,5,6,7)
        AND Trn.Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=8
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND Trn.Cashbook_Month         IN(4,5,6,7,8)
        AND Trn.Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=9
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND Trn.Cashbook_Month         IN(4,5,6,7,8,9)
        AND Trn.Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=10
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND Trn.Cashbook_Month         IN(4,5,6,7,8,9,10)
        AND Trn.Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=11
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND Trn.Cashbook_Month         IN(4,5,6,7,8,9,10,11)
        AND Trn.Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=12
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND Trn.Cashbook_Month         IN(4,5,6,7,8,9,10,11,12)
        AND Trn.Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=1
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND To_Date((Trn.Cashbook_Month
          ||'-'
          || Trn.Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
          ||'-'
          ||$P{year1},'mm-yyyy')
        AND To_Date(1
          ||'-'
          ||$P{year2},'mm-yyyy')
        )
      WHEN Cashbook_Month=2
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND To_Date((Trn.Cashbook_Month
          ||'-'
          || Trn.Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
          ||'-'
          ||$P{year1},'mm-yyyy')
        AND To_Date(2
          ||'-'
          ||$P{year2},'mm-yyyy')
        )
      WHEN Cashbook_Month=3
      THEN
        (SELECT SUM(Trn.Amount)AS mayamt
        FROM Fas_Fund_Trf_From_Ho_Master Mas
        INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
        ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
        AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
        AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
        AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
        AND Mas.Voucher_No              =Trn.Voucher_No
        AND Mas.Transfer_Status         ='L'
        AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
        AND To_Date((Trn.Cashbook_Month
          ||'-'
          || Trn.Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
          ||'-'
          ||$P{year1},'mm-yyyy')
        AND to_date(3
          ||'-'
          ||$P{year2},'mm-yyyy')
        )
    END AS ttlBank
  FROM
    (SELECT Trn.Transfer_To_Office_Id,
      Trn.Cashbook_Year,
      Trn.Cashbook_Month,
      SUM(Trn.Amount)AS Bamt
    FROM Fas_Fund_Trf_From_Ho_Master Mas
    INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
    ON Mas.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
    AND Mas.Accounting_For_Office_Id=Trn.Accounting_For_Office_Id
    AND Mas.CASHBOOK_YEAR           =Trn.CASHBOOK_YEAR
    AND Mas.CASHBOOK_MONTH          =Trn.CASHBOOK_MONTH
    AND Mas.Voucher_No              =Trn.Voucher_No
    AND Mas.Transfer_Status         ='L'
    AND Trn.Transfer_To_Office_Id   =$P{accountofficeid}
    AND To_Date((Trn.Cashbook_Month
      ||'-'
      || Trn.Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
      ||'-'
      ||$P{year1},'mm-yyyy')
    AND to_date(3
      ||'-'
      ||$P{year2},'mm-yyyy')
    GROUP BY Trn.Transfer_To_Office_Id,
      Trn.Cashbook_Year,
      Trn.Cashbook_Month
    ORDER BY Trn.Transfer_To_Office_Id,
      Trn.Cashbook_Year,
      Trn.Cashbook_Month
    )
  )A
INNER JOIN
  (
  --office
  SELECT Accounting_For_Office_Id,
    ACCOUNTING_UNIT_ID,
    Cashbook_Year,
    Cashbook_Month,
    offAmt,
    CASE
      WHEN Cashbook_Month=4
      THEN Offamt
      WHEN Cashbook_Month=5
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND Cashbook_Month         IN(4,5)
        AND Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=6
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND Cashbook_Month         IN(4,5,6)
        AND Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=7
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND Cashbook_Month         IN(4,5,6,7)
        AND Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=8
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND Cashbook_Month         IN(4,5,6,7,8)
        AND Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=9
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND Cashbook_Month         IN(4,5,6,7,8,9)
        AND Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=10
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND Cashbook_Month         IN(4,5,6,7,8,9,10)
        AND Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=11
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND Cashbook_Month         IN(4,5,6,7,8,9,10,11)
        AND Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=12
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND Cashbook_Month         IN(4,5,6,7,8,9,10,11,12)
        AND Cashbook_Year           =$P{year1}
        )
      WHEN Cashbook_Month=1
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND To_Date((Cashbook_Month
          ||'-'
          || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
          ||'-'
          ||$P{year1},'mm-yyyy')
        AND To_Date(1
          ||'-'
          ||$P{year2},'mm-yyyy')
        )
      WHEN Cashbook_Month=2
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND To_Date((Cashbook_Month
          ||'-'
          || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
          ||'-'
          ||$P{year1},'mm-yyyy')
        AND To_Date(2
          ||'-'
          ||$P{year2},'mm-yyyy')
        )
      WHEN Cashbook_Month=3
      THEN
        (SELECT SUM(TOTAL_AMOUNT)AS offAmt
        FROM Fas_Fund_Receipt_By_Office
        WHERE Receipt_Status        ='L'
        AND Accounting_For_Office_Id=$P{accountofficeid}
        AND To_Date((Cashbook_Month
          ||'-'
          || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
          ||'-'
          ||$P{year1},'mm-yyyy')
        AND To_Date(3
          ||'-'
          ||$P{year2},'mm-yyyy')
        )
    END AS Ttloffice
  FROM
    (SELECT Accounting_For_Office_Id,
      ACCOUNTING_UNIT_ID,
      Cashbook_Year,
      Cashbook_Month,
      SUM(TOTAL_AMOUNT)AS offAmt
    FROM Fas_Fund_Receipt_By_Office
    WHERE Receipt_Status        ='L'
    AND Accounting_For_Office_Id=$P{accountofficeid}
    AND To_Date((Cashbook_Month
      ||'-'
      || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
      ||'-'
      ||$P{year1},'mm-yyyy')
    AND To_Date(3
      ||'-'
      ||$P{year2},'mm-yyyy')
    GROUP BY Accounting_For_Office_Id,
      Accounting_Unit_Id,
      Cashbook_Year,
      Cashbook_Month
    ORDER BY Accounting_For_Office_Id,
      Cashbook_Year,
      Cashbook_Month
    )
  )o
ON o.Accounting_For_Office_Id =a.Transfer_To_Office_Id
AND O.Cashbook_Year           =A.Cashbook_Year
AND O.Cashbook_Month          =A.Cashbook_Month
AND o.ACCOUNTING_UNIT_ID      =$P{accountingunit}]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="UNITNAME" class="java.lang.String"/>
	<field name="TRANSFER_TO_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="BAMT" class="java.math.BigDecimal"/>
	<field name="OFFAMT" class="java.math.BigDecimal"/>
	<field name="DIFF" class="java.math.BigDecimal"/>
	<field name="TTLBANK" class="java.math.BigDecimal"/>
	<field name="TTLOFFICE" class="java.math.BigDecimal"/>
	<field name="CUMDIFF" class="java.math.BigDecimal"/>

	<variable name="bankTotal" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{BAMT}]]></variableExpression>
	</variable>
	<variable name="offTotal" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{OFFAMT}]]></variableExpression>
	</variable>
	<variable name="diffe_bank_off" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{bankTotal}.subtract($V{offTotal})]]></variableExpression>
	</variable>

		<group  name="unitId" >
			<groupExpression><![CDATA[$F{ACCOUNTING_UNIT_ID}]]></groupExpression>
			<groupHeader>
			<band height="25"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" pattern="###0" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="2"
						width="339"
						height="22"
						key="textField"/>
					<box></box>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font pdfFontName="Helvetica-Bold" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{UNITNAME}]]></textFieldExpression>
				</textField>
			</band>
			</groupHeader>
			<groupFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</title>
		<pageHeader>
			<band height="100"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="148"
