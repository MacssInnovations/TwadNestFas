<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Fund_receipt_payment"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="842"
		 columnWidth="818"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="2" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[SELECT a.RECEIPT_DATE,
  a.HO_REF_DATE,
  a.fundReceived,
  a.CASHBOOK_YEAR,
  a.CASHBOOK_MONTH,
  b.CHEQUE_DD_NO,
  b.CHEQUE_DD_DATE,
  b.AMOUNT,
  b.PAYMENT_DATE,
  b.VOUCHER_NO,
  b.paid_to
FROM
  (
  SELECT RECEIPT_DATE,
  Ho_Ref_Date,
  SUM(TOTAL_AMOUNT) AS fundReceived,
  ACCOUNTING_UNIT_ID,
  CASHBOOK_YEAR,
  CASHBOOK_MONTH
FROM fas_fund_receipt_by_office
WHERE ACCOUNTING_UNIT_ID    =70
AND ACCOUNTING_FOR_OFFICE_ID=6870
AND CASHBOOK_YEAR           =2012
AND Cashbook_Month          =11
GROUP BY Receipt_Date,
  Ho_Ref_Date,
  ACCOUNTING_UNIT_ID,
  Cashbook_Year,
  Cashbook_Month
  order by RECEIPT_DATE,Ho_Ref_Date
  )a
INNER JOIN
  (
  SELECT m.ACCOUNTING_UNIT_ID,
    m.CASHBOOK_YEAR,
    m.CASHBOOK_MONTH,
    t.CHEQUE_DD_NO,
    t.CHEQUE_DD_DATE,
    SUM(t.AMOUNT)AS amount,
    m.PAYMENT_DATE,
    m.VOUCHER_NO,
    m.paid_to
  From Fas_Payment_Master M,
    Fas_Payment_Transaction T  
  WHERE m.accounting_unit_id    =t.accounting_unit_id
  AND m.ACCOUNTING_FOR_OFFICE_ID=t.ACCOUNTING_FOR_OFFICE_ID
  AND m.CASHBOOK_YEAR           =t.CASHBOOK_YEAR
  AND m.CASHBOOK_MONTH          =t.CASHBOOK_MONTH
  AND M.Voucher_No              =T.Voucher_No
  AND m.ACCOUNTING_UNIT_ID      =70
  AND M.Accounting_For_Office_Id=6870
  AND m.CASHBOOK_YEAR           =2012
  AND m.CASHBOOK_MONTH          =11
  AND m.PAYMENT_STATUS          ='L'
  AND M.CREATED_BY_MODULE      IN ('BPF','BPP') 
  GROUP BY M.Accounting_Unit_Id,
    M.Cashbook_Year,
    M.Cashbook_Month,
    t.CHEQUE_DD_NO,
    t.CHEQUE_DD_DATE,
    m.PAYMENT_DATE,
    M.Voucher_No,
    M.Paid_To
    order by M.Accounting_Unit_Id,
    M.Cashbook_Year,
    M.Cashbook_Month,
    t.CHEQUE_DD_NO,
    t.CHEQUE_DD_DATE,
    M.Payment_Date,
    M.Voucher_No
  )b
ON a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID
AND a.CASHBOOK_YEAR    =b.CASHBOOK_YEAR
And A.Cashbook_Month   =B.Cashbook_Month
ORDER BY a.RECEIPT_DATE,b.CASHBOOK_YEAR,B.Cashbook_Month,
  B.Cheque_Dd_No,
  B.Cheque_Dd_Date]]></queryString>

