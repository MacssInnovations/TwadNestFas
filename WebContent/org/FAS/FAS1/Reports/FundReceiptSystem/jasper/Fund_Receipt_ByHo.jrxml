<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Fund_Receipt_ByHo"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="vouNO" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select  accUint.ACCOUNTING_UNIT_NAME,
  Office.OFFICE_NAME as main_office,
   ( SELECT ACCOUNTING_UNIT_NAME FROM FAS_MST_ACCT_UNITS WHERE ACCOUNTING_UNIT_OFFICE_ID = FMas.received_from_office_id ) AS sub_office,
	Office.CITY_TOWN_NAME,
--decode(FMas.RECEIPT_TYPE,'C','Collection','U','Unspent','Type not found') as R_type,

CASE
		
		WHEN FMas.RECEIPT_TYPE = 'C' THEN
		'Collection' 
		WHEN FMas.RECEIPT_TYPE = 'U' THEN
		'Unspent' 
		when FMas.RECEIPT_TYPE = 'WATCHARGEREV' THEN
		 'WATCHARGEREV'
		 when  FMas.RECEIPT_TYPE = 'WATCHARGEREV_Hogenakkal' THEN
		 'WATCHARGEREV_Hogenakkal'
		  when  FMas.RECEIPT_TYPE = 'NONWATCHARGEREV' THEN
		 'NONWATCHARGEREV'
		  when  FMas.RECEIPT_TYPE = 'Security Deposit' THEN
		 'Security Deposit'
		 when  FMas.RECEIPT_TYPE = 'UNS' THEN
		 'UNS'
		 when  FMas.RECEIPT_TYPE = 'FDW from Collection' THEN
		 'FDW from Collection'
		ELSE'Type not Found' 
	END AS R_type,
 Office.CITY_TOWN_NAME ,        
 to_char(FMas.RECEIPT_DATE,'DD/MM/YYYY') as DateOfReceipt,
 FMas.RECEIPT_NO,
 FMas.TOTAL_AMOUNT as TOT_AMT_NO, FMas.PARTICULARS,
 numtochar(FMas.TOTAL_AMOUNT) as TOT_AMT_CHAR  
 from FAS_FUND_RECEIPT_BY_HO FMas,COM_MST_OFFICES Office,COM_MST_OFFICES Office_2,
 FAS_MST_ACCT_UNITS accUint
 where 
 FMas.ACCOUNTING_UNIT_ID=accUint.ACCOUNTING_UNIT_ID and
 FMas.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID and 
 FMas.RECEIVED_FROM_OFFICE_ID=Office_2.OFFICE_ID and 
 FMas.ACCOUNTING_UNIT_ID=$P{acc_unit_id}::numeric  and FMas.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}::numeric and
 FMas.CASHBOOK_YEAR=$P{yr}::numeric and FMas.CASHBOOK_MONTH=$P{mon}::numeric and FMas.RECEIPT_NO=$P{vouNO}::numeric]]></queryString>

