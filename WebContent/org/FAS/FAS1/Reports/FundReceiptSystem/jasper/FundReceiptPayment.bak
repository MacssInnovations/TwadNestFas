	<field name="amount1" class="java.lang.String"/>

	<variable name="total" class="java.math.BigDecimal" resetType="Group" resetGroup="pay_date_grp" calculation="Sum">
		<variableExpression><![CDATA[$F{amount}]]></variableExpression>
	</variable>
	<variable name="count" class="java.lang.Integer" resetType="None" incrementType="Group" incrementGroup="frDate" calculation="Count">
		<variableExpression><![CDATA[$V{REPORT_COUNT}]]></variableExpression>
	</variable>
	<variable name="tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="payment_total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{amount}]]></variableExpression>
	</variable>
	<variable name="bal_final" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{tot}.subtract($V{payment_total})]]></variableExpression>
	</variable>
	<variable name="rec_total" class="java.math.BigDecimal" resetType="None" incrementType="Group" incrementGroup="frDate" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="total_ammt" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{total_amount1}.equalsIgnoreCase("0")?"":($F{total_amount1}.indexOf( "." )==-1?$F{total_amount1}+".00":$F{total_amount1})]]></variableExpression>
	</variable>
	<variable name="vorcher_no" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{voucher_no}.intValue()==0?"":$F{voucher_no}.toString()]]></variableExpression>
	</variable>
	<variable name="var_amt_new" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{amount1}.equalsIgnoreCase("0")?"":($F{amount1}.indexOf( "." )==-1?$F{amount1}+".00":$F{amount1})]]></variableExpression>
	</variable>

