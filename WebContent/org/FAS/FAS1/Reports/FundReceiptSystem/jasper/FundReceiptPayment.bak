<jasperReport
		 name="FundReceiptPayment"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="963"
		 pageHeight="842"
		 columnWidth="903"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtFrom_date" isForPrompting="false" class="java.util.Date"/>
	<parameter name="txtTo_date" isForPrompting="false" class="java.util.Date"/>
	<parameter name="txtCB_Year_to" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="txtCB_Month_to" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="res_quer" isForPrompting="true" class="java.lang.String"/>
	<parameter name="result_query" isForPrompting="true" class="java.lang.String"/>
	<parameter name="heading" isForPrompting="true" class="java.lang.String"/>
	<parameter name="Amount_unspent" isForPrompting="false" class="java.lang.Double"/>
	<parameter name="UnitName" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select
accounting_unit_id,
accounting_for_office_id,
cashbook_year,
cashbook_month,
TO_char('FR') as type1,
cheque_dd_no as fund_cheq_no,
 null "cheque_dd_no1",
NULL "cheque_dd_date",
  ho_ref_date ,
total_amount,
 to_char(total_amount) as total_amount1 ,
  receipt_date as voucher_date,
  0 "amount",
 to_char(0) "amount1",
0 "voucher_no",
  to_char('--') "paid_to",
  null as paydate,
  receipt_date as recdate,
  PARTICULARS
FROM fas_fund_receipt_by_office
WHERE ACCOUNTING_UNIT_ID    =$P{unitid}
AND ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
$P!{res_quer}
UNION ALL
select
m.accounting_unit_id,
m.accounting_for_office_id,
  m.cashbook_year,
  m.cashbook_month,
TO_char('Payment') as type1,
  null "fund_cheq_no",
  t.cheque_dd_no as cheque_dd_no1,
  t.cheque_dd_date,
  null "ho_ref_date",
0 "total_amount",
  to_char(0) "total_amount1",
    m.PAYMENT_DATE as voucher_date,
  SUM(t.AMOUNT)AS amount,
to_char(SUM(t.AMOUNT)) as amount1,
  m.voucher_no,
  m.paid_to,
  m.payment_date as paydate,
  null as recdate,
 to_char('--') "PARTICULARS"
FROM FAS_PAYMENT_MASTER m,
  FAS_PAYMENT_TRANSACTION t
WHERE m.accounting_unit_id    =t.accounting_unit_id
AND m.ACCOUNTING_FOR_OFFICE_ID=t.ACCOUNTING_FOR_OFFICE_ID
AND m.CASHBOOK_YEAR           =t.CASHBOOK_YEAR
AND m.CASHBOOK_MONTH          =t.CASHBOOK_MONTH
AND M.Voucher_No              =T.Voucher_No
AND m.ACCOUNTING_UNIT_ID =$P{unitid}
And M.Accounting_For_Office_Id=$P{officeid}
$P!{result_query}
AND m.PAYMENT_STATUS          ='L'
AND M.CREATED_BY_MODULE      IN ('BPF','BPP')
group by m.accounting_unit_id,
m.accounting_for_office_id,
  m.CASHBOOK_YEAR,
  m.CASHBOOK_MONTH,
  t.cheque_dd_no,
  t.cheque_dd_date,
 m.payment_date,
  m.voucher_no,
  m.paid_to
  Order By voucher_date,type1]]></queryString>

