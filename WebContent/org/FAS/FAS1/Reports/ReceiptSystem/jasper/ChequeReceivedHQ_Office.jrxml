				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$V{Total_amt}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement
						x="432"
						y="0"
						width="71"
						height="21"
						key="staticText-18"/>
					<box></box>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font pdfFontName="Helvetica-Bold" size="8" isBold="true"/>
