<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ChequeReceivedHQ_Office"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1020"
		 pageHeight="842"
		 columnWidth="1020"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyearFrom" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonthFrom" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyearTo" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonthTo" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT one.*,
  two.Passbook_Date
from
  (SELECT a.receipt_no,
    a.receipt_date,
    'R' as DocType,
    a.challan_date,
    a.received_from as money_rec_from ,
    b.Account_Head_Code as acheadcode,
    a.sub_ledger_type_code as sltype,
    a.sub_ledger_code as slcode,
    a.CR_DR_INDICATOR as cr_dr, 
    b.amount  AS amt,
    b.particulars,
   b.cheque_dd_no as ddno,
    b.cheque_or_dd,
--   b.cheque_dd_no,
 TO_CHAR(b.CHEQUE_DD_DATE,'DD/MM/YYYY'),
    d.accounting_unit_name,
    f.office_short_name
  FROM fas_receipt_master a,
    fas_receipt_transaction b,
    com_mst_account_heads c,
    fas_mst_acct_units d,
    com_mst_offices f
  WHERE a.cashbook_month        =b.cashbook_month
  AND a.cashbook_year           =b.cashbook_year
  AND a.accounting_unit_id      =b.accounting_unit_id
  AND a.accounting_for_office_id=b.accounting_for_office_id
  AND b.account_head_code       =c.account_head_code
  AND d.accounting_unit_id      =a.accounting_unit_id
  AND a.accounting_for_office_id=f.office_id
  AND a.receipt_no              =b.receipt_no
  AND a.receipt_status         <>'C'
  and a.receipt_type            ='B'
  AND a.cashbook_year 
  between $P{cashbookyearFrom} and $P{cashbookyearTo}
  and a.cashbook_month
  BETWEEN $P{cashbookmonthFrom} AND $P{cashbookmonthTo}
  AND a.accounting_unit_id      = $P{accountingunitid}
  AND a.accounting_for_office_id=$P{accountofficeid}
  UNION ALL
  SELECT a.receipt_no,
    a.receipt_date,
     'FR' as DocType,
    a.challan_date,
    '' as money_rec_from,
    a.dr_account_head_code as acheadcode,
    0 as sltype,
    0 as slcode,
    'DR' as cr_dr,  
    a.TOTAL_AMOUNT    AS amt,
    a.PARTICULARS,
   a.CHEQUE_DD_NO AS ddno,
    a.cheque_or_dd,
--    a.CHEQUE_DD_NO,
   TO_CHAR(a.CHEQUE_DD_DATE,'DD/MM/YYYY'),
    d.accounting_unit_name,
    f.office_short_name
  From Fas_Fund_Receipt_By_Office A ,
    fas_mst_acct_units d,
    com_mst_offices f ,
    fas_mst_banks g
  where a.cashbook_year 
  between $P{cashbookyearFrom} and $P{cashbookyearTo}
  and a.cashbook_month
  BETWEEN $P{cashbookmonthFrom} AND $P{cashbookmonthTo} 
  and a.accounting_unit_id      = $P{accountingunitid}
  AND a.accounting_for_office_id= $P{accountofficeid}
  And A.Receipt_Status         <>'C'
  AND d.accounting_unit_id      =a.accounting_unit_id
  AND a.accounting_for_office_id=f.office_id
  AND a.HO_BANK_ID              = g.BANK_ID
  )One
LEFT OUTER JOIN
  (SELECT Passbook_Date,Cheque_Dd_No FROM Fas_Brs_Transaction
  )Two
on one.ddno=two.cheque_dd_no
ORDER BY one.receipt_date]]></queryString>

