<jasperReport
		 name="List_of_All_Transactions"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="from_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookmonthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_cashbookmonthvalue" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[-- Receipt Count 
select 
  unit_id,
 (select accounting_unit_name from fas_mst_acct_units where accounting_unit_id=unit_id) as unit_name, 
  mon,
  decode(mon,1,'Jan',2,'Feb',3,'Mar',4,'Apr',5,'May',6,'Jun',7,'Jul',8,'Aug',9,'Sep',10,'Oct',11,'Nov',12,'Dec') as MonthName,
  yr, 
  sum(receipt_count) as receipt_count, 
  sum(journal_count) as journal_count, 
  sum(payment_count) as payment_count, 
  sum(fundreceipt_count) as fundreceipt_count, 
  sum(fundtransfer_count) as fundtransfer_count
  
from 
(
select 
     unit_id,
     mon, 
     yr,     
     receipt_count,
     0 as journal_count, 
     0 as payment_count, 
     0 as fundreceipt_count, 
     0 as fundtransfer_count
from 
(
select 
   accounting_unit_id as unit_id,
   cashbook_month as mon,
   cashbook_year as yr,
   count(*) as receipt_count 
from fas_receipt_master 
where 
    to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
and accounting_unit_id > 10 

group by accounting_unit_id, cashbook_year, cashbook_month 
order by accounting_unit_id, cashbook_year, cashbook_month
)


union all 
-- Journal Count 

select 
     unit_id,
     mon, 
     yr,     
     0 as receipt_count,
     journal_count, 
     0 as payment_count, 
     0 as fundreceipt_count, 
     0 as fundtransfer_count
     
from 
(
select 
   accounting_unit_id as unit_id,
   cashbook_month as mon,
   cashbook_year as yr,
   count(*) as journal_count 
from fas_journal_master 
where 
  to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
and accounting_unit_id  > 10 

group by accounting_unit_id, cashbook_year, cashbook_month 
order by accounting_unit_id, cashbook_year, cashbook_month
)


union all 

select 
     unit_id,
     mon, 
     yr,
     0 as receipt_count,
     0 as journal_count, 
     payment_count, 
     0 as fundreceipt_count, 
     0 as fundtransfer_count
     
from 
(
select 
   accounting_unit_id as unit_id,
   cashbook_month as mon,
   cashbook_year as yr,
   count(*) as payment_count 
from fas_payment_master 
where 
    to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
and accounting_unit_id > 10 

group by accounting_unit_id, cashbook_year, cashbook_month 
order by accounting_unit_id, cashbook_year, cashbook_month
)

union all 

select 
     unit_id,
     mon, 
     yr,     
     0 as receipt_count,
     0 as journal_count, 
     0 as payment_count, 
     fundreceipt_count, 
     0 as fundtransfer_count
from 
(
select 
   accounting_unit_id as unit_id,
   cashbook_month as mon,
   cashbook_year as yr,
   count(*) as fundreceipt_count 
from fas_fund_receipt_by_office 
where 
    to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
and accounting_unit_id > 10 

group by accounting_unit_id, cashbook_year, cashbook_month 
order by accounting_unit_id, cashbook_year, cashbook_month
)


union all 


select 
     unit_id,
     mon, 
     yr,     
     0 as receipt_count,
     0 as journal_count, 
     0 as payment_count, 
     0 as fundreceipt_count, 
     fundtransfer_count
from 
(
select 
   accounting_unit_id as unit_id,
   cashbook_month as mon,
   cashbook_year as yr,
   count(*) as fundtransfer_count 
from fas_fund_trf_from_office 
where 
   to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
and accounting_unit_id > 10 

group by accounting_unit_id, cashbook_year, cashbook_month 
order by accounting_unit_id, cashbook_year, cashbook_month
)


)
group by unit_id, yr, mon 
order by unit_id, yr, mon]]></queryString>

