	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="ACCOUNT_NO" class="java.math.BigDecimal"/>

	<variable name="total_value" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_AMT}]]></variableExpression>
	</variable>

