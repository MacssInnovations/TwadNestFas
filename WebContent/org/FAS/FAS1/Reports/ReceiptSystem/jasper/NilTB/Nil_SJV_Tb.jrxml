	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Supplement_No" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 
   unit_id,  
   ( select accounting_unit_name from fas_mst_acct_units where accounting_unit_id= unit_id ), 
   tb_date, 
   supplement_no
from 
(   
    select 
      accounting_unit_id as unit_id,   
      tb_date, 
      supplement_no  
    from fas_trial_balance_status_sjv
    where cashbook_month= $P{txtCB_Month}
    and cashbook_year= $P{txtCB_Year} 
    and nil_tb_status='Y' 
    and supplement_no = $P{Supplement_No} 
)]]></queryString>

	<field name="UNIT_ID" class="java.math.BigDecimal"/>
	<field name="(SELECTACCOUNTING_UNIT_NAMEFROMFAS_MST_ACCT_UNITSWHEREACCOUNTING_UNIT_ID=UNIT_ID)" class="java.lang.String"/>
