	<field name="C_AMT" class="java.lang.Integer"/>
	<field name="SUB2_DESC" class="java.lang.String"/>

	<variable name="acc_total" class="java.lang.Integer" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Integer ($F{C_AMT}.intValue() + $F{W_AMT}.intValue())]]></variableExpression>
	</variable>
	<variable name="SUM_W_AMT_2" class="java.lang.Integer" resetType="Group" resetGroup="accountheadcode" calculation="Sum">
