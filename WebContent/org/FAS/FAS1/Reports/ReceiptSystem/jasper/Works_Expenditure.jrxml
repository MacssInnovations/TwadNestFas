<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Works_Expenditure"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="regionid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="regionname" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select 
  account_head_code, 
  accounting_unit_id, 
  accounting_unit_name,
  accounting_for_office_id,
  cashbook_year, 
  cashbook_month, 
  amount,
  ident, 
  
  case when ident='W' then 
     amount
     else 
     0
    end as w_amt ,
  
  case when ident='C' then 
     amount
     else 
     0
    end as c_amt  ,
    
    sub2_desc 
    

from 
( 


SELECT 
  a.ACCOUNT_HEAD_CODE,
  a.accounting_unit_id,
  b.accounting_unit_name,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.amount,
  'W' AS ident,
  (
   SELECT d.sub_head_desc
   FROM 
     com_mst_account_heads c,
     com_mst_sub_heads d
   WHERE d.sub_head_code = c.sub_head2_code
   AND c.major_head_code = 'L'
   AND c.minor_head_code = 183
   AND c.sub_head1_code = 31
   AND c.account_head_code = a.account_head_code)AS sub2_desc

FROM fas_payment_transaction a,
     fas_mst_acct_units b
WHERE
     b.accounting_unit_id = a.accounting_unit_id
 AND a.cashbook_year = $P{cashbookyear}
 and a.cashbook_month= $P{cashbookmonth} 
 and a.ACCOUNTING_FOR_OFFICE_ID in ( select office_id from COM_MST_ALL_OFFICES_VIEW 
    where region_office_id= $P{regionid} )
 AND a.account_head_code IN
  (SELECT account_head_code
   FROM com_mst_account_heads
   WHERE major_head_code = 'L'
   AND minor_head_code = 183
   AND sub_head1_code = 31
   AND sub_head2_code > 0)

UNION ALL 

SELECT 
  a.ACCOUNT_HEAD_CODE,
  a.accounting_unit_id,
  b.accounting_unit_name,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.amount,
  'C' ident,
    (SELECT d.sub_head_desc
   FROM com_mst_account_heads c,
     com_mst_sub_heads d
   WHERE d.sub_head_code = c.sub_head2_code
   AND c.major_head_code = 'L'
   AND c.minor_head_code = 183
   AND c.sub_head1_code = 32
   AND c.account_head_code = a.account_head_code) AS sub2_desc

FROM 
    fas_payment_transaction a,
    FAS_MST_ACCT_UNITS b  
  WHERE
    b.accounting_unit_id = a.accounting_unit_id
 and a.cashbook_year = $P{cashbookyear}
 and a.cashbook_month= $P{cashbookmonth} 
 and a.ACCOUNTING_FOR_OFFICE_ID in ( select office_id from COM_MST_ALL_OFFICES_VIEW 
    where region_office_id=$P{regionid} )
 AND a.account_head_code IN

  (SELECT account_head_code
   FROM com_mst_account_heads
   WHERE major_head_code = 'L'
   AND minor_head_code = 183
   AND sub_head1_code = 32
   AND sub_head2_code > 0)

union all 
 
SELECT 
  a.ACCOUNT_HEAD_CODE,
  a.accounting_unit_id,
  b.accounting_unit_name,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.amount,
  'W' AS ident,
  (
   SELECT 
         d.sub_head_desc
   FROM 
       com_mst_account_heads c,
       com_mst_sub_heads d
   WHERE 
       d.sub_head_code = c.sub_head2_code
   AND c.major_head_code = 'L'
   AND c.minor_head_code = 183
   AND c.sub_head1_code = 31
   AND c.account_head_code = a.account_head_code)AS sub2_desc

FROM 
     fas_journal_transaction a,
     fas_mst_acct_units b
WHERE
     b.accounting_unit_id = a.accounting_unit_id
 AND a.cashbook_year = $P{cashbookyear}
 and a.cashbook_month= $P{cashbookmonth} 
 and a.ACCOUNTING_FOR_OFFICE_ID in ( select office_id from COM_MST_ALL_OFFICES_VIEW 
      where region_office_id= $P{regionid} )
 AND a.account_head_code IN
  (SELECT account_head_code
   FROM com_mst_account_heads
   WHERE major_head_code = 'L'
   AND minor_head_code = 183
   AND sub_head1_code = 31
   AND sub_head2_code > 0)

UNION ALL

SELECT 
  a.ACCOUNT_HEAD_CODE,
  a.accounting_unit_id,
  b.accounting_unit_name,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.amount,
  'C' ident,
    (SELECT d.sub_head_desc
   FROM com_mst_account_heads c,
     com_mst_sub_heads d
   WHERE d.sub_head_code = c.sub_head2_code
   AND c.major_head_code = 'L'
   AND c.minor_head_code = 183
   AND c.sub_head1_code = 32
   AND c.account_head_code = a.account_head_code) AS sub2_desc

FROM 
    fas_journal_transaction a,
    FAS_MST_ACCT_UNITS b  
  WHERE
    b.accounting_unit_id = a.accounting_unit_id
 and a.cashbook_year = $P{cashbookyear}
 and a.cashbook_month= $P{cashbookmonth}  
 and a.ACCOUNTING_FOR_OFFICE_ID in ( select office_id from COM_MST_ALL_OFFICES_VIEW 
    where region_office_id=$P{regionid} )
 AND a.account_head_code IN
  (SELECT account_head_code
   FROM com_mst_account_heads
   WHERE major_head_code = 'L'
   AND minor_head_code = 183
   AND sub_head1_code = 32
   AND sub_head2_code > 0)
   
union  all

SELECT 
  a.ACCOUNT_HEAD_CODE,
  a.accounting_unit_id,
  b.accounting_unit_name,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.amount,
  'W' AS ident,
  (
   SELECT 
         d.sub_head_desc
   FROM 
       com_mst_account_heads c,
       com_mst_sub_heads d
   WHERE 
       d.sub_head_code = c.sub_head2_code
   AND c.major_head_code = 'L'
   AND c.minor_head_code = 183
   AND c.sub_head1_code = 31
   AND c.account_head_code = a.account_head_code)AS sub2_desc

FROM 
     fas_receipt_transaction a,
     fas_mst_acct_units b
WHERE
     b.accounting_unit_id = a.accounting_unit_id
 AND a.cashbook_year = $P{cashbookyear}
 and a.cashbook_month= $P{cashbookmonth} 
 and a.ACCOUNTING_FOR_OFFICE_ID in ( select office_id from COM_MST_ALL_OFFICES_VIEW 
    where region_office_id=$P{regionid} )
 AND a.account_head_code IN
  (SELECT account_head_code
   FROM com_mst_account_heads
   WHERE major_head_code = 'L'
   AND minor_head_code = 183
   AND sub_head1_code = 31
   AND sub_head2_code > 0)

UNION ALL

SELECT 
  a.ACCOUNT_HEAD_CODE,
  a.accounting_unit_id,
  b.accounting_unit_name,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.amount,
  'C' ident,
    (SELECT d.sub_head_desc
   FROM com_mst_account_heads c,
     com_mst_sub_heads d
   WHERE d.sub_head_code = c.sub_head2_code
   AND c.major_head_code = 'L'
   AND c.minor_head_code = 183
   AND c.sub_head1_code = 32
   AND c.account_head_code = a.account_head_code) AS sub2_desc

FROM 
    fas_receipt_transaction a,
    FAS_MST_ACCT_UNITS b  
  WHERE
    b.accounting_unit_id = a.accounting_unit_id
 and a.cashbook_year = $P{cashbookyear}
 and a.cashbook_month= $P{cashbookmonth}  
 and a.ACCOUNTING_FOR_OFFICE_ID in ( select office_id from COM_MST_ALL_OFFICES_VIEW 
    where region_office_id= $P{regionid} )
 AND a.account_head_code IN
  (SELECT account_head_code
   FROM com_mst_account_heads
   WHERE major_head_code = 'L'
   AND minor_head_code = 183
   AND sub_head1_code = 32
   AND sub_head2_code > 0)
   
)
  order by account_head_code, accounting_unit_id]]></queryString>

