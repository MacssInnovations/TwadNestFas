<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="SalesTax_Return_report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthinwords" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
   doc_type as "DOC_TYPE", 
   account_head_code, 
   recno as "RECNO", 
   rdate as "RDATE", 
   received_from as "RECEIVED_FROM", 
   amount as "AMOUNT", 
   coalesce(amt,null,0.00,amt) as "AMT",
   accounting_unit_id, 
   cashbook_year, 
   cashbook_month, 
   particulars as "PARTICULARS", 
   accounting_unit_name as "ACCOUNTING_UNIT_NAME" 
from 
(
(   --- Part I start 
select 
   'J' as doc_type,
   account_head_code,
   recno,
   rdate,
   received_from,
   amount,
   amt,
   accounting_unit_id,
   cashbook_year,
   cashbook_month,
   particulars,
   accounting_unit_name 
 from 
   (
     select 
        account_head_code,
        VOUCHER_NO as recno,
        amount,
        accounting_unit_id,
        cashbook_year,
        cashbook_month,
        particulars
     from
        FAS_JOURNAL_TRANSACTION a
     where 
         account_head_code in (select account_head_code from fas_st_heads)  
     and accounting_unit_id=$P{accunitid}::int
     and cashbook_year=$P{cyear}::int
     and cashbook_month=$P{cmonth}::int
   )a
  
  left outer join 
  
  (
    select
       coalesce(amount,null,0.00,amount) as amt,
       VOUCHER_NO 
    from 
       FAS_JOURNAL_TRANSACTION 
    where 
        account_head_code = (550402) 
    and accounting_unit_id=$P{accunitid}::int
    and cashbook_year=$P{cyear}::int 
    and cashbook_month=$P{cmonth}::int  
  ) b
  
  on a.recno=b.VOUCHER_NO
  
  inner join
 
  (
    select 
       VOUCHER_DATE as rdate,
       '' as received_from,
       VOUCHER_NO 
    from 
       FAS_JOURNAL_MASTER  
    where 
        CREATED_BY_MODULE='GJV' 
    and JOURNAL_STATUS='L' 
    and accounting_unit_id=$P{accunitid}::int
    and cashbook_year=$P{cyear}::int 
    and cashbook_month=$P{cmonth}::int 
  )c
  on a.recno=c.VOUCHER_NO
  
  left outer join
  
  (
    select
       accounting_unit_name,
       accounting_unit_id as accuid 
    from 
       FAS_MST_ACCT_UNITS 
    where 
       accounting_unit_id=$P{accunitid}::int
  )d
  
  on a.accounting_unit_id=d.accuid

)   --- Part I end 


union all


(  --- Part II start 
 select 
    'R' as doc_type,
    account_head_code,
    recno,
    rdate,
    received_from,
    amount,
    amt,
    accounting_unit_id,
    cashbook_year,
    cashbook_month,
    particulars,
    accounting_unit_name 
 from
  (
     select 
        account_head_code,
        receipt_no as recno,
        amount,
        accounting_unit_id,
        cashbook_year,
        cashbook_month,
        particulars
     from 
        fas_receipt_transaction a
     where
        account_head_code in (select account_head_code from fas_st_heads)  
    and accounting_unit_id=$P{accunitid}::int
    and cashbook_year=$P{cyear}::int 
    and cashbook_month=$P{cmonth}::int 
  )a

  left outer join 
  
  (
    select 
       coalesce(amount,null,0.00,amount) as amt,     
       receipt_no 
    from 
       fas_receipt_transaction 
    where 
        account_head_code = (550402)  
    and accounting_unit_id=$P{accunitid}::int
    and cashbook_year=$P{cyear}::int and cashbook_month=$P{cmonth}::int 
  ) salestax
  on a.recno=salestax.receipt_no
  
  inner join

  (
   select 
      receipt_date as rdate,
      receipt_no,
      received_from 
   from 
      fas_receipt_master 
   where  
       RECEIPT_STATUS='L' 
   and accounting_unit_id=$P{accunitid}::int
   and cashbook_year=$P{cyear}::int 
   and cashbook_month=$P{cmonth}::int 
  )c
  on a.recno=c.receipt_no

  left outer join

  (
    select 
       accounting_unit_name,
       accounting_unit_id as accuid 
    from 
       FAS_MST_ACCT_UNITS 
    where
       accounting_unit_id=$P{accunitid}::int
  )d
  on a.accounting_unit_id=d.accuid


)  --- Part II end 
order by recno,rdate
) as opt1
order by rdate, doc_type, recno]]></queryString>

	<field name="DOC_TYPE" class="java.lang.String"/>
	<field name="account_head_code" class="java.math.BigDecimal"/>
	<field name="RECNO" class="java.math.BigDecimal"/>
	<field name="RDATE" class="java.sql.Date"/>
