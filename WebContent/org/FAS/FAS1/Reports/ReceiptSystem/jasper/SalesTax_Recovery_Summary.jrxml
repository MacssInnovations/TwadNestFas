<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="SalesTax_Recovery_Summary"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="735"
		 pageHeight="842"
		 columnWidth="675"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_value" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from 
(
select 
   year_account_head_code, 
   ( select account_head_desc from com_mst_account_heads where account_head_code = year_account_head_code ) as account_head_des,
   ( select PRTGRP from fas_ho_gpf where account_head_code = year_account_head_code ) as prtgrp,
   
   year_accounting_unit_id,    
   (select trim(ACCOUNTING_UNIT_NAME) from fas_mst_acct_units where accounting_unit_id = year_accounting_unit_id ) as accounting_unit_name, 
   
   year_dr, 
   year_cr,      
   
   case when ( year_dr - year_cr ) > 0 then 
    nvl(( year_dr - year_cr ),0) || ' Dr'
   else 
    nvl(( year_cr - year_dr ),0) || ' Cr' 
   end as year_net_disp,   
   
   nvl(( year_cr - year_dr ),0) as year_net,     

   cashbook_month,
   cashbook_year, 
   
   nvl(current_month_debit,0) as current_month_debit,
   nvl(current_month_credit,0) as current_month_credit,
   
   case when ( current_month_debit - current_month_credit ) > 0 then 
    nvl(( current_month_debit - current_month_credit ),0) || ' Dr'
   else 
    nvl(( current_month_credit - current_month_debit ),0) || ' Cr' 
   end as curr_net_disp,   
   
   nvl(( current_month_credit - current_month_debit ),0) as curr_net   
   
from 
(

select * 
from 
(
select 
       account_head_code as year_account_head_code,
       accounting_unit_id as year_accounting_unit_id,              
       sum(current_month_debit) as year_dr,
       sum(current_month_credit) as year_cr    
from fas_trial_balance 
where     
 to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') 
 BETWEEN case when $P{cb_mon} <=3 then  to_date(  '04' || '-' || ($P{cb_year} - 1) ,  'mm-yyyy') else to_date( '04' || '-' || $P{cb_year} ,  'mm-yyyy') end 
 AND to_date ( $P{cb_mon} ||'-' || $P{cb_year} , 'mm-yyyy')
 
and accounting_unit_id in ( select accounting_unit_id from fas_trial_balance_status where 
                          
                            to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') 
 BETWEEN case when $P{cb_mon} <=3 then  to_date(  '04' || '-' || ($P{cb_year} - 1) ,  'mm-yyyy') else to_date( '04' || '-' || $P{cb_year} ,  'mm-yyyy') end 
 AND to_date ( $P{cb_mon} ||'-' || $P{cb_year} , 'mm-yyyy')
                          
                          ) 
                            
and account_head_code=550402
group by account_head_code, accounting_unit_id 
order by year_accounting_unit_id
) a 

left outer join 

(
 select 
    accounting_unit_id,     
    account_head_code, 
    cashbook_month, 
    cashbook_year, 
    current_month_debit, 
    current_month_credit    
from fas_trial_balance 
where 
    account_head_code=550402
and accounting_unit_id in ( select accounting_unit_id from fas_trial_balance_status where 
                            cashbook_month = $P{cb_mon} and cashbook_year = $P{cb_year} ) 
and cashbook_month= $P{cb_mon} 
and cashbook_year= $P{cb_year}
order by accounting_unit_id
) b
 
on  b.account_head_code  = a.year_account_head_code
and b.accounting_unit_id = a.year_accounting_unit_id
)

order by year_account_head_code, year_accounting_unit_id
), 

(
  select 
    case when 
      (  select 
                tb_status 
          from fas_tb_closure 
          where cashbook_year=$P{cb_year}
            and cashbook_month = $P{cb_mon} 
            and tb_status='Y'   
      ) = 'Y' then ' ' else 'TENTATIVE FIGURES' end as month_closure_stat 
  from dual 
)]]></queryString>

