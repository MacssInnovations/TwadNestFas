<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="SelfBalance2"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="898"
		 pageHeight="595"
		 columnWidth="838"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookyear_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="UnitName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue_from" isForPrompting="true" class="java.lang.String"/>
	<parameter name="OfficeName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue_to" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sl_type" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sl_code" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 
   * 
   from 
   (
        select
          accounting_unit_id, 
          accounting_for_office_id, 
          year, 
          month, 
          acc_code, 
          h.ACCOUNT_HEAD_DESC as ACCOUNT_HEAD_DESC, 
          sl_type_code, 
          v.SUB_LEDGER_TYPE_DESC,
          sub_ledger_code, 
          vouType, 
          vouNo, 
          vouDate,
          bill_no,
          bill_date, 
          agreement_no,
          particulars, 
          credit_amount, 
          debit_amount,
          ob_cr_dr_indicator, 
          ob_amt,
          cb_cr_dr_indicator,
          cb_amt
        from 
        ( 
          -- Get Data from 'FAS_SUB_LEDGER_MASTER AND TRANSACTION TABLE' 
          select * from 
          (
           SELECT 
                  m.ACCOUNTING_UNIT_ID,
                  m.ACCOUNTING_FOR_OFFICE_ID,
                  m.FINANCIAL_YEAR,
                  m.YEAR,
                  m.MONTH,
                  m.ACCOUNT_HEAD_CODE as acc_code ,
                  m.SUB_LEDGER_TYPE_CODE as sl_type_code,
                  m.SUB_LEDGER_CODE,
                  t.CR_VOUCHER_TYPE || t.DR_VOUCHER_TYPE as vouType,
                  t.CR_VOUCHER_NO || t.DR_VOUCHER_NO as vouNO,
                  to_date(t.CR_VOUCHER_DATE || t.DR_VOUCHER_DATE) as vouDate,
                  t.BILL_NO,
                  t.BILL_DATE,
                  t.AGREEMENT_NO,
                  trim( t.PARTICULARS ) as PARTICULARS ,
                  t.CREDIT_AMOUNT,
                  t.DEBIT_AMOUNT 
            FROM 
                  FAS_SUB_LEDGER_MASTER m,
                  FAS_SUB_LEDGER_TRANSACTION t
            WHERE 
                 m.ACCOUNTING_UNIT_ID=t.ACCOUNTING_UNIT_ID and 
                 m.ACCOUNTING_FOR_OFFICE_ID=t.ACCOUNTING_FOR_OFFICE_ID and 
                 m.FINANCIAL_YEAR=t.FINANCIAL_YEAR and 
                 m.YEAR=t.YEAR and 
                 m.MONTH=t.MONTH and 
                 m.ACCOUNT_HEAD_CODE=t.ACCOUNT_HEAD_CODE and 
                 m.SUB_LEDGER_TYPE_CODE=t.SUB_LEDGER_TYPE_CODE and 
                 m.SUB_LEDGER_CODE=t.SUB_LEDGER_CODE and  
                 m.ACCOUNTING_UNIT_ID=$P{accountingunitid} and 
                 m.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} and 
                 m.MONTH=$P{cashbookmonth_from} and 
                 m.YEAR=$P{cashbookyear_from} and 
                m.SUB_LEDGER_TYPE_CODE=$P{sl_type} and 
                m.SUB_LEDGER_CODE=$P{sl_code}
       ) xx 
      
       left outer join 
        
       (   
          -- FINDING MONTH OPENING BALANCE IN SUB LEDGER TYPE CODE WISE 
         select 
            case when ob_credit > 0 then 
              'CR' 
            else 
              'DR'   
            end as ob_cr_dr_indicator, 
            ob_credit + ob_debit as ob_amt,
            ob_unitid, 
            ob_officeid,
            ob_month, 
            ob_year, 
            ob_sl_type_code, 
            ob_sl_code
        from 
        (  
          select 
              case when credit_minus_debit > 0 then 
                  abs(credit_minus_debit) 
              else 
                  0 
              end as ob_credit, 
      
              case when credit_minus_debit < 0 then 
                   abs(credit_minus_debit) 
              else 
                  0 
              end as ob_debit,
              ob_unitid, 
              ob_officeid,
              ob_month, 
              ob_year, 
              ob_sl_type_code, 
              ob_sl_code
           from 
           ( 
              select 
                    sum(ob_credit) as ob_credit,  
                    sum(ob_debit) as ob_debit, 
                    sum(ob_credit) - sum(ob_debit) as credit_minus_debit, 
                    ob_unitid, 
                    ob_officeid,
                    ob_month, 
                    ob_year, 
                    ob_sl_type_code, 
                    ob_sl_code
              from 
                (
                  select
                       case when month_opening_bal_dr_cr_ind ='CR' then 
                          month_opening_balance 
                       else 
                           0 
                       end as ob_credit,
                       case when month_opening_bal_dr_cr_ind ='DR' then 
                          month_opening_balance 
                       else 
                          0 
                       end as ob_debit,
                       accounting_unit_id as ob_unitid, 
                       accounting_for_office_id as ob_officeid, 
                       month as ob_month, 
                       year as ob_year, 
                       sub_ledger_type_code as ob_sl_type_code, 
                       sub_ledger_code as ob_sl_code 
                  from 
                       fas_sub_ledger_master 
                  where accounting_unit_id = $P{accountingunitid}
                  and accounting_for_office_id = $P{accountofficeid}
                    and month = $P{cashbookmonth_from} 
                    and year = $P{cashbookyear_from} 
                
                ) 
                group by ob_unitid, 
                    ob_officeid,
                    ob_month, 
                    ob_year, 
                    ob_sl_type_code, 
                    ob_sl_code
            ) 
          )
        )ob
      
      on 
          xx.ACCOUNTING_UNIT_ID = ob.ob_unitid and 
          xx.ACCOUNTING_FOR_OFFICE_ID = ob.ob_officeid and 
          xx.MONTH = ob.ob_month and 
          xx.YEAR = ob.ob_year and 
          xx.sl_type_code = ob.ob_sl_type_code  and 
          xx.SUB_LEDGER_CODE= ob.ob_sl_code  
       
       left outer join 
      
       (   
         -- FINDING MONTH CLOSING BALANCE IN SUB LEDGER TYPE CODE WISE 
         select 
            case when cb_credit > 0 then 
              'CR' 
            else 
              'DR'   
            end as cb_cr_dr_indicator, 
            cb_credit + cb_debit as cb_amt,
            cb_unitid, 
            cb_officeid,
            cb_month, 
            cb_year, 
            cb_sl_type_code, 
            cb_sl_code
        from 
        (  
          select 
              case when credit_minus_debit > 0 then 
                  abs(credit_minus_debit) 
              else 
                  0 
              end as cb_credit, 
      
              case when credit_minus_debit < 0 then 
                   abs(credit_minus_debit) 
              else 
                  0 
              end as cb_debit,
              cb_unitid, 
              cb_officeid,
              cb_month, 
              cb_year, 
              cb_sl_type_code, 
              cb_sl_code
           from 
           ( 
              select 
                    sum(cb_credit) as cb_credit,  
                    sum(cb_debit) as cb_debit, 
                    sum(cb_credit) - sum(cb_debit) as credit_minus_debit, 
                    cb_unitid, 
                    cb_officeid,
                    cb_month, 
                    cb_year, 
                    cb_sl_type_code, 
                    cb_sl_code
              from 
                (
                  select
                       case when month_closing_bal_dr_cr_ind ='CR' then 
                          month_closing_balance 
                       else 
                           0 
                       end as cb_credit,
                       case when month_opening_bal_dr_cr_ind ='DR' then 
                          month_closing_balance 
                       else 
                          0 
                       end as cb_debit,
                       accounting_unit_id as cb_unitid, 
                       accounting_for_office_id as cb_officeid, 
                       month as cb_month, 
                       year as cb_year, 
                       sub_ledger_type_code as cb_sl_type_code, 
                       sub_ledger_code as cb_sl_code 
                  from 
                       fas_sub_ledger_master 
                  where accounting_unit_id = $P{accountingunitid}
                  and accounting_for_office_id = $P{accountofficeid}
                    and month = $P{cashbookmonth_from} 
                    and year = $P{cashbookyear_from}                   
                ) 
                group by cb_unitid, 
                    cb_officeid,
                    cb_month, 
                    cb_year, 
                    cb_sl_type_code, 
                    cb_sl_code
            ) 
          )
        )cb
      
      on 
          xx.ACCOUNTING_UNIT_ID = cb.cb_unitid and 
          xx.ACCOUNTING_FOR_OFFICE_ID = cb.cb_officeid and 
          xx.MONTH = cb.cb_month and 
          xx.YEAR = cb.cb_year and 
          xx.sl_type_code = cb.cb_sl_type_code  and 
          xx.SUB_LEDGER_CODE= cb.cb_sl_code  
     ) mm , 
      
     COM_MST_SL_TYPES v,
     COM_MST_ACCOUNT_HEADS h
     
    where   mm.sl_type_code=v.SUB_LEDGER_TYPE_CODE and  
            mm.acc_code=h.ACCOUNT_HEAD_CODE   
            
) x 

left outer join 

( 
 select trim(sl_type) as sl_type, trim(sl_code) as sl_code, trim( sl_codename ) as  SLCODE_NAME from  SL_TYPE_CODE_NAME_VIEW_M             
) y
     
on x.sl_type_code = y.SL_TYPE  and 
   x.SUB_LEDGER_CODE=y.SL_CODE                  

ORDER BY sl_type_code,SUB_LEDGER_CODE,acc_code, voutype, vouno, voudate]]></queryString>

