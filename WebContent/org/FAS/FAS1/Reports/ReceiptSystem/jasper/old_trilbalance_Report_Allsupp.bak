	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="flag" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT a.ACCOUNTING_UNIT_ID,
  a.cashbook_year,
  a.cashbook_month,
  a.ACCOUNT_HEAD_CODE,
  a.CURRENT_MONTH_DEBIT,
  a.CURRENT_MONTH_CREDIT,
  b.ACCOUNTING_UNIT_NAME,
  a.flagdesc, c.ACCOUNT_HEAD_DESC
FROM FAS_TRAIL_BALANCE_DATA_9507 a,
  FAS_MST_ACCNT_UNIT_OLD9507 b,
  COM_MST_ACCOUNT_HEADS c
WHERE a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID and a.ACCOUNT_HEAD_CODE=c.ACCOUNT_HEAD_CODE
AND cashbook_year         =$P{cb_year}
AND cashbook_month        =$P{cb_mon}
AND a.flagid              =$P{flag}
ORDER BY accounting_unit_id,
  account_head_code]]></queryString>

