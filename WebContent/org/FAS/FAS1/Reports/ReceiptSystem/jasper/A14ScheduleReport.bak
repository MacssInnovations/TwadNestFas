	<parameter name="Accounting_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Accounting_forofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthwords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT DISTINCT A.Accounting_Unit_Id,
  (SELECT U.Accounting_Unit_Name
  FROM Fas_Mst_Acct_Units U
  WHERE u.Accounting_Unit_Id=a.Accounting_Unit_Id
  ) AS unitName,
  a.Vou_No,
  a.Vou_Date,
  A.Sub_Ledger_Type_Code,
  (SELECT s.SUB_LEDGER_TYPE_DESC
  FROM COM_MST_SL_TYPES s
  WHERE s.Sub_Ledger_Type_Code=a.Sub_Ledger_Type_Code
  )AS type_desc,
  A.Sub_Ledger_Code,
  (SELECT v.SL_CODENAME
  FROM SL_TYPE_CODE_NAME_VIEW v
  WHERE v.SL_TYPE=a.Sub_Ledger_Type_Code
  AND v.SL_CODE  =A.Sub_Ledger_Code
  )AS code_desc,
  a.Account_Head_Code,
  A.Amount,
  B.Payno,
  B.Paydate,
  b.payAmt,
  b.payRemarks
From
  (SELECT M.Voucher_No as vou_no,
    M.Accounting_Unit_Id,
    M.Voucher_Date as vou_date,
    T.Sub_Ledger_Type_Code,
    t.Sub_Ledger_Code,
    T.Account_Head_Code,
    t.AMOUNT,
    T.Cb_Ref_No,
    T.Cb_Ref_Date
  FROM Fas_Journal_Master M
  INNER JOIN Fas_Journal_Transaction T
  ON M.Accounting_Unit_Id       =T.Accounting_Unit_Id
  AND M.Accounting_For_Office_Id=T.Accounting_For_Office_Id
  AND M.Cashbook_Year           =T.Cashbook_Year
  AND M.Cashbook_Month          =T.Cashbook_Month
  AND M.Voucher_No              =T.Voucher_No
  And M.Accounting_Unit_Id      =$P{Accounting_unit_id}
  AND M.Accounting_For_Office_Id=$P{Accounting_forofficeid}
  And M.Cashbook_Year           =$P{year}
  AND M.Cashbook_Month          =$P{month}
  AND M.Created_By_Module       ='LJV'
  AND M.Journal_Status          ='L'
  )a
Inner Join
  (Select M.Voucher_No ,
    m.PAYMENT_DATE, t.payable_voucher_no AS payNo,t.payable_voucher_date AS payDate,
    M.Total_Amount     As Payamt,
    M.Remarks          As Payremarks
   
  FROM Fas_Payment_Master M
  INNER JOIN Fas_Payment_Transaction T
  ON M.Accounting_Unit_Id       =T.Accounting_Unit_Id
  AND M.Accounting_For_Office_Id=T.Accounting_For_Office_Id
  AND M.Cashbook_Year           =T.Cashbook_Year
  AND M.Cashbook_Month          =T.Cashbook_Month
  And M.Voucher_No              =T.Voucher_No
  And M.Accounting_Unit_Id      =$P{Accounting_unit_id}
  AND M.Accounting_For_Office_Id=$P{Accounting_forofficeid}
  And M.Cashbook_Year           =$P{year}
  AND M.Cashbook_Month          =$P{month}
  AND M.Payment_Status          ='L'
  AND M.Payable_Voucher_Type    ='J'
  )B
  On A.Vou_No             =B.Payno
Order By A.vou_no, a.vou_date]]></queryString>

