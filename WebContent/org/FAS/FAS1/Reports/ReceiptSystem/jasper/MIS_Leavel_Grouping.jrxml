<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="MIS_Leavel_Grouping"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="545"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="20"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="previous_month_to" isForPrompting="true" class="java.lang.String"/>
	<parameter name="current_date_to" isForPrompting="true" class="java.lang.String"/>
	<parameter name="previous_year_to" isForPrompting="true" class="java.lang.String"/>
	<parameter name="header" isForPrompting="true" class="java.lang.String"/>
	<parameter name="previous_month_from" isForPrompting="true" class="java.lang.String"/>
	<parameter name="current_date_from" isForPrompting="true" class="java.lang.String"/>
	<parameter name="previous_year_from" isForPrompting="true" class="java.lang.String"/>
	<parameter name="major_head_ode" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
 (select account_head_desc from com_mst_account_heads where account_head_code=(select min(account_head_code) from com_mst_account_heads where major_head_code=a.major_head_code and minor_head_code=a.minor_head_code)) as account_head_desc,
  current_year_head,current_fellyear_head,previous_month_head,previous_year_head,
  case when (major_head_code='I' or major_head_code='A' or major_head_code='O')
            then sum(cr_upto_this_date)- sum(dr_upto_this_date)
       else
            sum(dr_upto_this_date)- sum(cr_upto_this_date)
  end as upto_current_date,
  case when (major_head_code='I' or major_head_code='A' or major_head_code='O')
            then sum(cr_upto_previous_month)- sum(dr_upto_previous_month)
       else
            sum(dr_upto_previous_month)- sum(cr_upto_previous_month)
  end as upto_previous_month,
  case when (major_head_code='I' or major_head_code='A' or major_head_code='O')
            then sum(cr_upto_previous_year)- sum(dr_upto_previous_year)
       else
            sum(dr_upto_previous_year)- sum(cr_upto_previous_year)
  end as upto_previous_year
from
(
    select 
      major_head_code,
      minor_head_code,
      account_head_code,
      '          '||to_char(to_date($P{current_date_to},'mm-yyyy'),'MON')||'-'||extract(year from to_date($P{current_date_to},'mm-yyyy'))||' in '||
              case when(extract (month from to_date($P{current_date_to},'mm-yyyy'))>3) 
                   then to_char(to_date($P{current_date_to},'mm-yyyy'),'yyyy')||'-'||to_char(extract(year from to_date($P{current_date_to},'mm-yyyy'))+1)
              else 
                   to_char(extract(year from to_date($P{current_date_to},'mm-yyyy'))-1)||'-'||to_char(to_date($P{current_date_to},'mm-yyyy'),'yyyy')
              end as current_year_head,
      trim(to_char(to_date($P{current_date_to},'mm-yyyy'),'MONTH'))||' '||extract(year from to_date($P{current_date_to},'mm-yyyy'))||' in '||
              case when(extract (month from to_date($P{current_date_to},'mm-yyyy'))>3) 
                   then to_char(to_date($P{current_date_to},'mm-yyyy'),'yyyy')||'-'||to_char(extract(year from to_date($P{current_date_to},'mm-yyyy'))+1)
              else 
                   to_char(extract(year from to_date($P{current_date_to},'mm-yyyy'))-1)||'-'||to_char(to_date($P{current_date_to},'mm-yyyy'),'yyyy')
              end as current_fellyear_head,
      '          '||to_char(to_date($P{previous_month_to},'mm-yyyy'),'MON')||'-'||extract(year from to_date($P{previous_month_to},'mm-yyyy'))||' in '||
              case when(extract (month from to_date($P{previous_month_to},'mm-yyyy'))>3) 
                   then to_char(to_date($P{previous_month_to},'mm-yyyy'),'yyyy')||'-'||to_char(extract(year from to_date($P{previous_month_to},'mm-yyyy'))+1)
              else 
                   to_char(extract(year from to_date($P{previous_month_to},'mm-yyyy'))-1)||'-'||to_char(to_date($P{previous_month_to},'mm-yyyy'),'yyyy')
              end as previous_month_head,
      '          '||to_char(to_date($P{previous_year_to},'mm-yyyy'),'MON')||'-'||extract(year from to_date($P{previous_year_to},'mm-yyyy'))||' in '||
              case when(extract (month from to_date($P{previous_year_to},'mm-yyyy'))>3) 
                   then to_char(to_date($P{previous_year_to},'mm-yyyy'),'yyyy')||'-'||to_char(extract(year from to_date($P{previous_year_to},'mm-yyyy'))+1)
              else 
                   to_char(extract(year from to_date($P{previous_year_to},'mm-yyyy'))-1)||'-'||to_char(to_date($P{previous_year_to},'mm-yyyy'),'yyyy')
              end as previous_year_head,
      case when (to_date(cashbook_month ||'-'||cashbook_year, 'mm-yyyy') between to_date($P{current_date_from},'mm-yyyy') and to_date($P{current_date_to},'mm-yyyy'))then
        sum(current_month_credit)
      else 0 end as cr_upto_this_date,
      case when (to_date(cashbook_month ||'-'||cashbook_year, 'mm-yyyy') between to_date($P{current_date_from},'mm-yyyy') and to_date($P{current_date_to},'mm-yyyy'))then
        sum(current_month_debit)
      else 0 end as dr_upto_this_date,
       case when (to_date(cashbook_month ||'-'||cashbook_year, 'mm-yyyy') between to_date($P{previous_month_from},'mm-yyyy') and to_date($P{previous_month_to},'mm-yyyy'))then
        sum(current_month_credit)
      else 0 end as cr_upto_previous_month,
      case when (to_date(cashbook_month ||'-'||cashbook_year, 'mm-yyyy') between to_date($P{previous_month_from},'mm-yyyy') and to_date($P{previous_month_to},'mm-yyyy'))then
        sum(current_month_debit)
      else 0 end as dr_upto_previous_month,
      case when (to_date(cashbook_month ||'-'||cashbook_year, 'mm-yyyy') between to_date($P{previous_year_from},'mm-yyyy') and to_date($P{previous_year_to},'mm-yyyy'))then
        sum(current_month_credit)
      else 0 end as cr_upto_previous_year,
      case when (to_date(cashbook_month ||'-'||cashbook_year, 'mm-yyyy') between to_date($P{previous_year_from},'mm-yyyy') and to_date($P{previous_year_to},'mm-yyyy'))then
        sum(current_month_debit)
      else 0 end as dr_upto_previous_year
    from
    (
        select 
          major_head_code,
          a.account_head_code,
          minor_head_code, 
          cashbook_month,
          cashbook_year,
          current_month_debit,
          current_month_credit
        from 
          com_mst_account_heads a,
          fas_trial_balance b
        where
          a.account_head_code=b.account_head_code and 
          major_head_code=$P{major_head_ode} and
          to_date(cashbook_month ||'-'|| + cashbook_year, 'mm-yyyy') BETWEEN to_date($P{previous_year_from},'mm-yyyy')  AND to_date($P{current_date_to},'mm-yyyy')
        order by
          major_head_code,
          minor_head_code,
          account_head_code,
          cashbook_year,
          cashbook_month
    )
    group by
          major_head_code,
          minor_head_code,
          account_head_code,
          cashbook_month,
          cashbook_year
)a
group by
      major_head_code,
      minor_head_code,
      current_year_head,
      current_fellyear_head,
      previous_month_head,
      previous_year_head
order by
      minor_head_code]]></queryString>

