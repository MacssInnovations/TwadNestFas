<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ListOf_LJV_withDate"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="992"
		 pageHeight="595"
		 columnWidth="964"
		 columnSpacing="0"
		 leftMargin="14"
		 rightMargin="14"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select  
--decode(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'TWAD','-')as sub_ledger_type_code,
DECODE(A.SUB_LEDGER_TYPE_CODE,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',10,'Project', 11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'DCB-Beneficiary',15,'Accounting Units',16,'Scheme Type',	
	17,'Miscellaneous',18,'Pensioners',19,'Family Pensioner',20,'IMIS-SA-CCDU',21,'IMIS-SA-MIS',22,'IMIS-SA-GIS',23,'IMIS-SA-R and D',24,'IMIS-SA-M and I',25,'Special PF Payments',26,'Work In Progress',27,'IMIS-SA-WQMS',28,'One Day Salary Contribution','-') as sub_ledger_type_code_desc,
f.ACCOUNTING_UNIT_NAME,b.voucher_date,d.ACCOUNT_HEAD_CODE,d.ACCOUNT_HEAD_DESC,c.office_name,a.voucher_no,a.accounting_unit_id,
a.accounting_for_office_id,a.amount,a.particulars,a.sub_ledger_type_code,
(select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M where sl_type=a.sub_ledger_type_code and sl_code=a.SUB_LEDGER_CODE) as slcode,
b.remarks,a.CR_DR_INDICATOR,e.JOURNAL_TYPE_DESC,
CASE
      WHEN A.CR_DR_INDICATOR ='DR'
      THEN a.amount
      ELSE 0
    END AS DEBIT_AMT,
    CASE
      WHEN A.CR_DR_INDICATOR ='CR'
      THEN a.amount
      ELSE 0
    END AS credit_amt
 from fas_journal_transaction a,fas_journal_master b,
com_mst_offices c,com_mst_account_heads d,FAS_MST_ACCT_UNITS f,FAS_MST_JOURNAL_TYPE e where  a.accounting_unit_id=b.accounting_unit_id
and a.accounting_for_office_id=b.accounting_for_office_id and a.cashbook_year=b.cashbook_year
and a.cashbook_month=b.cashbook_month and a.voucher_no=b.voucher_no and b.created_by_module='LJV'
and a.accounting_for_office_id=c.office_id and d.ACCOUNT_HEAD_CODE=a.ACCOUNT_HEAD_CODE 
and b.voucher_date between $P{txtfrom} and $P{txtto} and a.accounting_unit_id=$P{accountingunitid} 
and a.accounting_for_office_id=$P{accountofficeid} and f.ACCOUNTING_UNIT_ID=a.accounting_unit_id  
and b.JOURNAL_TYPE_CODE = e.JOURNAL_TYPE_CODE and b.journal_status<>'C' order by voucher_date,voucher_no,ACCOUNT_HEAD_CODE]]></queryString>

	<field name="SUB_LEDGER_TYPE_CODE_DESC" class="java.lang.String"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="VOUCHER_DATE" class="java.sql.Timestamp"/>
	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
