<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Listof_self_check_withDate"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="595"
		 columnWidth="818"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[SELECT accounting_unit_id,
  accounting_for_office_id,
  payment_date,
  voucher_no,
  paid_to,
  acc_head_code,
  account_head_desc,
  office_name,
  accounting_unit_name,
  amt,
  decode(sub_ledger_code,0,'-') as SUBLEDCODE,
  --DECODE(subtycode,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'TWAD','-')AS sub_ledger_type_code,
DECODE(A.SUB_LEDGER_TYPE_CODE,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',10,'Project', 11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'DCB-Beneficiary',15,'Accounting Units',16,'Scheme Type',	
	17,'Miscellaneous',18,'Pensioners',19,'Family Pensioner',20,'IMIS-SA-CCDU',21,'IMIS-SA-MIS',22,'IMIS-SA-GIS',23,'IMIS-SA-R and D',24,'IMIS-SA-M and I',25,'Special PF Payments',26,'Work In Progress',27,'IMIS-SA-WQMS',28,'One Day Salary Contribution','-') as sub_ledger_type_code_desc,
  CR_DR_INDICATOR,
  PARTICULARS,
CASE
      WHEN CR_DR_INDICATOR ='DR'
      THEN total_amount
      ELSE 0
    END AS DEBIT_AMT,
    CASE
      WHEN CR_DR_INDICATOR ='CR'
      THEN total_amount
      ELSE 0
    END AS credit_amt
FROM
  (SELECT accounting_unit_id,
    accounting_for_office_id,
    payment_date,
    cashbook_year,
    cashbook_month,
    voucher_no,
    account_head_code,
    sub_ledger_type_code,
    sub_ledger_code,
    paid_to,
    total_amount,
    created_by_module,
    payment_status,
    remarks
  FROM fas_payment_master
  WHERE created_by_module='SC'
  AND payment_status     ='L'
  ) a
LEFT OUTER JOIN
  (SELECT ACCOUNTING_UNIT_ID AS accunit,
    ACCOUNTING_FOR_OFFICE_ID AS officeid,
    CASHBOOK_YEAR            AS cayr,
    CASHBOOK_MONTH           AS camt,
    ACCOUNT_HEAD_CODE        AS ahc,
    VOUCHER_NO               AS voucherno, 
    SUB_LEDGER_TYPE_CODE     AS subtycode,
    AMOUNT                   AS amt,
    SUB_LEDGER_CODE          AS subledcode,
    CR_DR_INDICATOR,
    PARTICULARS
  FROM fas_payment_transaction
  )b
ON a.accounting_unit_id       =b.accunit
AND a.accounting_for_office_id=b.officeid
AND a.cashbook_year           =b.cayr
AND a.cashbook_month          =b.camt
AND a.voucher_no      =b.voucherno
LEFT OUTER JOIN
  (SELECT account_head_code AS acc_head_code,
    account_head_desc
  FROM com_mst_account_heads
  )c
ON b.ahc=c.acc_head_code
LEFT OUTER JOIN
  ( SELECT office_id,office_name FROM com_mst_offices
  )d
ON a.accounting_for_office_id=d.office_id
LEFT OUTER JOIN
  (SELECT accounting_unit_id AS acc_unit_id,
    accounting_unit_name
  FROM FAS_MST_ACCT_UNITS
  )e
ON a.accounting_unit_id       =e.acc_unit_id
WHERE a.accounting_unit_id    =$P{accountingunitid}
AND a.accounting_for_office_id=$P{accountofficeid}
and (payment_date between $P{txtfrom} and $P{txtto})
AND a.cashbook_year           =$P{txtCB_Year}
AND a.cashbook_month          =$P{txtCB_Month}]]></queryString>

