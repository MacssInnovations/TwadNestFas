	<field name="REMARKS" class="java.lang.String"/>
	<field name="CR_DR_INDICATOR" class="java.lang.String"/>
	<field name="SUB_LEDGER_TYPE_CODE_DESC" class="java.lang.String"/>
	<field name="DEBIT_AMT" class="java.math.BigDecimal"/>
	<field name="CREDIT_AMT" class="java.math.BigDecimal"/>

	<variable name="SUM_TOTAL_AMOUNT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="CR_AMT" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_AMT}]]></variableExpression>
	</variable>
	<variable name="DR_AMT" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_AMT}]]></variableExpression>
	</variable>
