<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ListOf_BPF_withDate"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1012"
		 pageHeight="595"
		 columnWidth="984"
		 columnSpacing="0"
		 leftMargin="14"
		 rightMargin="14"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select  

--decode(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'TWAD','-')as sub_ledger_type_code,
--DECODE(A.SUB_LEDGER_TYPE_CODE,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',10,'Project', 11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'DCB-Beneficiary',15,'Accounting Units',16,'Scheme Type',	
--	17,'Miscellaneous',18,'Pensioners',19,'Family Pensioner',20,'IMIS-SA-CCDU',21,'IMIS-SA-MIS',22,'IMIS-SA-GIS',23,'IMIS-SA-R and D',24,'IMIS-SA-M and I',25,'Special PF Payments',26,'Work In Progress',27,'IMIS-SA-WQMS',28,'One Day Salary Contribution','-') as sub_ledger_type_code_desc,
CASE WHEN A.SUB_LEDGER_TYPE_CODE= 1 THEN 'Supplier'
	 WHEN A.SUB_LEDGER_TYPE_CODE= 2 THEN 'Firms'
     WHEN A.SUB_LEDGER_TYPE_CODE= 3 THEN 'Assets'
    WHEN A.SUB_LEDGER_TYPE_CODE= 4 THEN 'ChequeBooks'
    WHEN A.SUB_LEDGER_TYPE_CODE= 5 THEN 'Offices'
    WHEN A.SUB_LEDGER_TYPE_CODE= 6 THEN 'Bank'
    WHEN A.SUB_LEDGER_TYPE_CODE= 7 THEN 'Employees'
    WHEN A.SUB_LEDGER_TYPE_CODE= 8 THEN '-'
    WHEN A.SUB_LEDGER_TYPE_CODE= 9 THEN 'OtherDepartments'
    WHEN A.SUB_LEDGER_TYPE_CODE= 10 THEN 'Project' 
    WHEN A.SUB_LEDGER_TYPE_CODE= 11 THEN 'Contractors'
    WHEN A.SUB_LEDGER_TYPE_CODE= 12 THEN 'Scheme Owner'
    WHEN A.SUB_LEDGER_TYPE_CODE= 13 THEN 'Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 14 THEN 'DCB-Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 15 THEN 'Accounting Units'
    WHEN A.SUB_LEDGER_TYPE_CODE= 16 THEN 'Scheme Type'

WHEN A.SUB_LEDGER_TYPE_CODE= 17 THEN 'Miscellaneous'
WHEN A.SUB_LEDGER_TYPE_CODE= 18 THEN 'Pensioners'

WHEN A.SUB_LEDGER_TYPE_CODE= 19 THEN 'Family Pensioner'
WHEN A.SUB_LEDGER_TYPE_CODE= 20 THEN 'IMIS-SA-CCDU'
WHEN A.SUB_LEDGER_TYPE_CODE= 21 THEN 'IMIS-SA-MIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 22 THEN 'IMIS-SA-GIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 23 THEN 'IMIS-SA-R and D'
WHEN A.SUB_LEDGER_TYPE_CODE= 24 THEN 'IMIS-SA-M and I'
WHEN A.SUB_LEDGER_TYPE_CODE= 25 THEN 'Special PF Payments'
WHEN A.SUB_LEDGER_TYPE_CODE= 26 THEN 'Work In Progress'
WHEN A.SUB_LEDGER_TYPE_CODE= 27 THEN 'IMIS-SA-WQMS'
WHEN A.SUB_LEDGER_TYPE_CODE= 28 THEN 'One Day Salary Contribution'
 ELSE '-' END as "SUB_LEDGER_TYPE_CODE_DESC",

f.ACCOUNTING_UNIT_NAME as "ACCOUNTING_UNIT_NAME",b.payment_date as "PAYMENT_DATE",d.ACCOUNT_HEAD_CODE as "account_head_code",d.ACCOUNT_HEAD_DESC as "ACCOUNT_HEAD_DESC",c.office_name as "OFFICE_NAME",
a.voucher_no as "voucher_no" ,a.accounting_unit_id,
a.accounting_for_office_id,b.paid_to as "PAID_TO",a.amount as "AMOUNT",a.particulars as "PARTICULARS",a.sub_ledger_type_code,
(select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M where sl_type=a.sub_ledger_type_code and sl_code=a.SUB_LEDGER_CODE) as "SLCODE",
b.remarks,a.cr_dr_indicator as "CR_DR_INDICATOR",
CASE
      WHEN A.CR_DR_INDICATOR ='DR'
      THEN a.amount
      ELSE 0
    END AS "DEBIT_AMT",
    CASE
      WHEN A.CR_DR_INDICATOR ='CR'
      THEN a.amount
      ELSE 0
    END AS "CREDIT_AMT"
 from fas_payment_transaction a,fas_payment_master b,
com_mst_offices c,com_mst_account_heads d,FAS_MST_ACCT_UNITS f where  a.accounting_unit_id=b.accounting_unit_id
and a.accounting_for_office_id=b.accounting_for_office_id and a.cashbook_year=b.cashbook_year 
and a.cashbook_month=b.cashbook_month and a.voucher_no=b.voucher_no and b.created_by_module='BPF' 
and a.accounting_for_office_id=c.office_id and d.ACCOUNT_HEAD_CODE=a.ACCOUNT_HEAD_CODE    
and b.payment_date::varchar between $P{txtfrom} and $P{txtto}  
and a.accounting_unit_id=$P{accountingunitid}::int  
and a.accounting_for_office_id=$P{accountofficeid}::int and f.ACCOUNTING_UNIT_ID=a.accounting_unit_id and payment_status<>'C' 
order by payment_date,voucher_no,ACCOUNT_HEAD_CODE]]></queryString>

	<field name="SUB_LEDGER_TYPE_CODE_DESC" class="java.lang.String"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="PAYMENT_DATE" class="java.sql.Date"/>
	<field name="account_head_code" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
