<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Listof_Cash_Payment_withDate"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_head_code,
account_head_desc,office_name,accounting_unit_name,payment_type,created_by_module,
payment_status,voucher_no,payment_date,paid_to,
--decode(sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'TWAD','-')as sub_ledger_type_code,
DECODE(A.SUB_LEDGER_TYPE_CODE,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',10,'Project', 11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'DCB-Beneficiary',15,'Accounting Units',16,'Scheme Type',	
	17,'Miscellaneous',18,'Pensioners',19,'Family Pensioner',20,'IMIS-SA-CCDU',21,'IMIS-SA-MIS',22,'IMIS-SA-GIS',23,'IMIS-SA-R and D',24,'IMIS-SA-M and I',25,'Special PF Payments',26,'Work In Progress',27,'IMIS-SA-WQMS',28,'One Day Salary Contribution','-') as sub_ledger_type_code_desc,
decode(sub_ledger_code,0,'-') as sub_ledger_code,total_amount,
remarks,cr_dr_indicator,
CASE
      WHEN CR_DR_INDICATOR ='DR'
      THEN total_amount
      ELSE 0
    END AS DEBIT_AMT,
    CASE
      WHEN CR_DR_INDICATOR ='CR'
      THEN total_amount
      ELSE 0
    END AS credit_amt
 from
(
select accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_head_code,
payment_type,created_by_module,
payment_status,voucher_no,payment_date,paid_to,sub_ledger_type_code,sub_ledger_code,total_amount,
remarks,cr_dr_indicator
from fas_payment_master
where payment_type='C' and payment_status='L'
and created_by_module='CRM'
) a
left outer join
(
select account_head_code as acc_head_code,account_head_desc from com_mst_account_heads
) b
on a.account_head_code=b.acc_head_code
left outer join
(
select office_id,office_name from com_mst_offices
) c
on a.accounting_for_office_id=c.office_id
left outer join
(
select accounting_unit_id as acc_unit_id,accounting_unit_name from FAS_MST_ACCT_UNITS
) d
on a.accounting_unit_id=d.acc_unit_id
where a.accounting_unit_id=$P{accountingunitid} and a.accounting_for_office_id=$P{accountofficeid} and
cashbook_month=$P{txtCB_Month} and cashbook_year=$P{txtCB_Year} and (payment_date between $P{txtfrom} and $P{txtto})
order by payment_date,voucher_no,account_head_code]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_CODE" class="java.lang.Integer"/>
