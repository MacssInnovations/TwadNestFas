<jasperReport
		 name="Listof_Fund_Transfer_withoutDate"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select accounting_unit_id,accounting_unit_name,accounting_for_office_id,office_name,date_of_transfer,cashbook_year,cashbook_month,voucher_no,cr_account_head_code,
account_head_desc,total_amount,particulars,transfer_status from
(
select accounting_unit_id,accounting_for_office_id,date_of_transfer,cashbook_year,cashbook_month,voucher_no,cr_account_head_code,
total_amount,particulars,transfer_status from fas_fund_trf_from_office
where transfer_status='L'
) a
left outer join
(
select account_head_code,account_head_desc from com_mst_account_heads
) b
on a.cr_account_head_code=b.account_head_code
left outer join
(
select office_id,office_name from com_mst_offices
) c
on a.accounting_for_office_id=c.office_id
left outer join
(
select accounting_unit_id as acc_unit_id,accounting_unit_name from FAS_MST_ACCT_UNITS
) d
on a.accounting_unit_id=d.acc_unit_id
where a.accounting_unit_id=$P{accountingunitid} and a.accounting_for_office_id=$P{accountofficeid} and
cashbook_month=$P{txtCB_Month} and cashbook_year=$P{txtCB_Year}
order by date_of_transfer,voucher_no,cr_account_head_code]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.lang.Integer"/>
