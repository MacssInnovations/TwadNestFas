<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Listof_IBT_withDate"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="992"
		 pageHeight="595"
		 columnWidth="932"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[SELECT distinct m.VOUCHER_NO                        AS VOUCHER_NO,
  TO_CHAR(m.DATE_OF_TRANSFER,'DD/MM/YYYY') AS VOUCHER_DATE ,
  m.PARTICULARS                            AS PARTICULARS,
  m.TOTAL_AMOUNT                           AS TOTAL_AMOUNT,
  m.REF_NO,
  TO_CHAR(m.REF_DATE,'DD/MM/YYYY') AS ref_date,
  bk.BANK_SHORT_NAME
  ||'-'
  || br.BRANCH_NAME
  ||'-'
  || m.FROM_ACCOUNT_NO
  ||'-'
  || bl.frombankacid AS FROMBANKACNO,
  bk1.BANK_SHORT_NAME
  ||'-'
  || br1.BRANCH_NAME
  ||'-'
  || m.TO_ACCOUNT_NO
  ||'-'
  || bl1.tobankactypeid AS TOBANKACNO,
  m.CHEQUE_OR_DD,
  NVL2(m.CHEQUE_DD_NO,m.CHEQUE_OR_DD
  ||'-'
  ||m.CHEQUE_DD_NO,'-')                           AS CHEQUE_DD_NO,
  NVL(TO_CHAR(m.CHEQUE_DD_DATE,'DD/MM/YYYY'),'-') AS cheq_dd_date,
  br2.accounting_unit_name                        AS ACCOUNTING_UNIT_NAME,
  br4.office_name                                 AS OFFICE_NAME
FROM
  (SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    VOUCHER_NO,
    DATE_OF_TRANSFER,
    PARTICULARS,
    TOTAL_AMOUNT,
    REF_NO,
    REF_DATE,
    FROM_ACCOUNT_NO,
    TO_ACCOUNT_NO,
    CHEQUE_OR_DD,
    CHEQUE_DD_NO,
    CHEQUE_DD_DATE,
    FROM_BANK_ID,
    FROM_BRANCH_ID,
    TO_BANK_ID,
    TO_BRANCH_ID
  FROM FAS_INTER_BANK_TRF_AT_HO
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} 
  AND TRANSFER_STATUS         ='L'
  AND DATE_OF_TRANSFER       >=$P{txtfrom}
  AND DATE_OF_TRANSFER       <=$P{txtto}
  ) m
LEFT OUTER JOIN
  ( SELECT BANK_ID,BANK_SHORT_NAME FROM FAS_MST_BANKS
  )bk
ON m.FROM_BANK_ID=bk.BANK_ID
LEFT OUTER JOIN
  ( SELECT BANK_ID,BRANCH_ID,BRANCH_NAME FROM FAS_MST_BANK_BRANCHES
  )br
ON m.FROM_BANK_ID   =br.BANK_ID
AND m.FROM_BRANCH_ID=br.BRANCH_ID
LEFT OUTER JOIN
  ( SELECT BANK_ID,BANK_SHORT_NAME FROM FAS_MST_BANKS
  )bk1
ON m.TO_BANK_ID=bk1.BANK_ID
LEFT OUTER JOIN
  ( SELECT BANK_ID,BRANCH_ID,BRANCH_NAME FROM FAS_MST_BANK_BRANCHES
  )br1
ON m.TO_BANK_ID   =br1.BANK_ID
AND m.TO_BRANCH_ID=br1.BRANCH_ID
LEFT OUTER JOIN
  ( SELECT accounting_unit_id,accounting_unit_name FROM FAS_MST_ACCT_UNITS
  )br2
ON m.ACCOUNTING_UNIT_ID=br2.ACCOUNTING_UNIT_ID
LEFT OUTER JOIN
  ( SELECT office_id,office_name FROM com_mst_offices
  )br4
ON m.ACCOUNTING_FOR_OFFICE_ID=br4.office_id
left outer join 
(SELECT ACCOUNTING_UNIT_ID,
    BANK_ID AS bankid,
    BANK_AC_TYPE_ID as frombankacid,
    BANK_AC_NO
  FROM FAS_MST_BANK_BALANCE
  )bl
ON m.FROM_BANK_ID       =bl.bankid
AND m.ACCOUNTING_UNIT_ID=bl.ACCOUNTING_UNIT_ID
and m.FROM_ACCOUNT_NO=bl.BANK_AC_NO
left outer join
(SELECT ACCOUNTING_UNIT_ID as toaccunitid,
    BANK_ID AS tobankid,
    BANK_AC_TYPE_ID as tobankactypeid,
    BANK_AC_NO as tobankac
  FROM FAS_MST_BANK_BALANCE
  )bl1
ON m.TO_BANK_ID       =bl1.tobankid
AND m.ACCOUNTING_UNIT_ID=bl1.toaccunitid
and m.TO_ACCOUNT_NO=bl1.tobankac]]></queryString>

