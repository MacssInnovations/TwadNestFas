<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Listof_self_check_withoutDate"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="850"
		 pageHeight="595"
		 columnWidth="790"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT accounting_unit_id,
  accounting_for_office_id,
  payment_date as "PAYMENT_DATE",
  voucher_no as "VOUCHER_NO",
  paid_to as "PAID_TO",
  acc_head_code as "ACC_HEAD_CODE",
  account_head_desc as "ACCOUNT_HEAD_DESC",
  office_name as "OFFICE_NAME",
  accounting_unit_name as "ACCOUNTING_UNIT_NAME",
  amt as "AMT",
  coalesce(sub_ledger_code,0) as "SUBLEDCODE",
  --DECODE(subtycode,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'TWAD','-')AS sub_ledger_type_code,
---DECODE(A.SUB_LEDGER_TYPE_CODE,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',10,'Project', 11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'DCB-Beneficiary',15,'Accounting Units',16,'Scheme Type',	
----	17,'Miscellaneous',18,'Pensioners',19,'Family Pensioner',20,'IMIS-SA-CCDU',21,'IMIS-SA-MIS',22,'IMIS-SA-GIS',23,'IMIS-SA-R and D',24,'IMIS-SA-M and I',25,'Special PF Payments',26,'Work In Progress',27,'IMIS-SA-WQMS',28,'One Day Salary Contribution','-') as sub_ledger_type_code_desc,
CASE WHEN A.SUB_LEDGER_TYPE_CODE= 1 THEN 'Supplier'
	 WHEN A.SUB_LEDGER_TYPE_CODE= 2 THEN 'Firms'
     WHEN A.SUB_LEDGER_TYPE_CODE= 3 THEN 'Assets'
    WHEN A.SUB_LEDGER_TYPE_CODE= 4 THEN 'ChequeBooks'
    WHEN A.SUB_LEDGER_TYPE_CODE= 5 THEN 'Offices'
    WHEN A.SUB_LEDGER_TYPE_CODE= 6 THEN 'Bank'
    WHEN A.SUB_LEDGER_TYPE_CODE= 7 THEN 'Employees'
    WHEN A.SUB_LEDGER_TYPE_CODE= 8 THEN '-'
    WHEN A.SUB_LEDGER_TYPE_CODE= 9 THEN 'OtherDepartments'
    WHEN A.SUB_LEDGER_TYPE_CODE= 10 THEN 'Project' 
    WHEN A.SUB_LEDGER_TYPE_CODE= 11 THEN 'Contractors'
    WHEN A.SUB_LEDGER_TYPE_CODE= 12 THEN 'Scheme Owner'
    WHEN A.SUB_LEDGER_TYPE_CODE= 13 THEN 'Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 14 THEN 'DCB-Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 15 THEN 'Accounting Units'
    WHEN A.SUB_LEDGER_TYPE_CODE= 16 THEN 'Scheme Type'

WHEN A.SUB_LEDGER_TYPE_CODE= 17 THEN 'Miscellaneous'
WHEN A.SUB_LEDGER_TYPE_CODE= 18 THEN 'Pensioners'

WHEN A.SUB_LEDGER_TYPE_CODE= 19 THEN 'Family Pensioner'
WHEN A.SUB_LEDGER_TYPE_CODE= 20 THEN 'IMIS-SA-CCDU'
WHEN A.SUB_LEDGER_TYPE_CODE= 21 THEN 'IMIS-SA-MIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 22 THEN 'IMIS-SA-GIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 23 THEN 'IMIS-SA-R and D'
WHEN A.SUB_LEDGER_TYPE_CODE= 24 THEN 'IMIS-SA-M and I'
WHEN A.SUB_LEDGER_TYPE_CODE= 25 THEN 'Special PF Payments'
WHEN A.SUB_LEDGER_TYPE_CODE= 26 THEN 'Work In Progress'
WHEN A.SUB_LEDGER_TYPE_CODE= 27 THEN 'IMIS-SA-WQMS'
WHEN A.SUB_LEDGER_TYPE_CODE= 28 THEN 'One Day Salary Contribution'
 ELSE '-' END as "SUB_LEDGER_TYPE_CODE_DESC",

  CR_DR_INDICATOR as "CR_DR_INDICATOR",
  PARTICULARS as "PARTICULARS",
CASE
      WHEN CR_DR_INDICATOR ='DR'
      THEN total_amount
      ELSE 0
    END AS "DEBIT_AMT",
    CASE
      WHEN CR_DR_INDICATOR ='CR'
      THEN total_amount
      ELSE 0
    END AS "CREDIT_AMT"
FROM
  (SELECT accounting_unit_id,
    accounting_for_office_id,
    payment_date,
    cashbook_year,
    cashbook_month,
    voucher_no,
    account_head_code,
    sub_ledger_type_code,
    sub_ledger_code,
    paid_to,
    total_amount as amt,
    created_by_module,
    payment_status,
    remarks
  FROM fas_payment_master
  WHERE created_by_module='SC'
  AND payment_status     ='L'
  ) a
LEFT OUTER JOIN
  (SELECT ACCOUNTING_UNIT_ID AS accunit,
    ACCOUNTING_FOR_OFFICE_ID AS officeid,
    CASHBOOK_YEAR            AS cayr,
    CASHBOOK_MONTH           AS camt,
    ACCOUNT_HEAD_CODE        AS ahc,
    VOUCHER_NO               AS voucherno,
    SUB_LEDGER_TYPE_CODE     AS subtycode,
    AMOUNT                   AS total_amount,
    SUB_LEDGER_CODE          AS subledcode,
    CR_DR_INDICATOR,
    PARTICULARS
  FROM fas_payment_transaction
  )b
ON a.accounting_unit_id       =b.accunit
AND a.accounting_for_office_id=b.officeid
AND a.cashbook_year           =b.cayr
AND a.cashbook_month          =b.camt
AND a.voucher_no       =b.voucherno
LEFT OUTER JOIN
  (SELECT account_head_code AS acc_head_code,
    account_head_desc
  FROM com_mst_account_heads
  )c
ON  b.ahc=c.acc_head_code
LEFT OUTER JOIN
  ( SELECT office_id,office_name FROM com_mst_offices
  )d
ON a.accounting_for_office_id=d.office_id
LEFT OUTER JOIN
  (SELECT accounting_unit_id AS acc_unit_id,
    accounting_unit_name
  FROM FAS_MST_ACCT_UNITS
  )e
ON a.accounting_unit_id       =e.acc_unit_id
WHERE a.accounting_unit_id    =$P{accountingunitid}::int
AND a.accounting_for_office_id=$P{accountofficeid}::int
AND a.cashbook_year           =$P{txtCB_Year}::int
AND a.cashbook_month          =$P{txtCB_Month}::int]]></queryString>

