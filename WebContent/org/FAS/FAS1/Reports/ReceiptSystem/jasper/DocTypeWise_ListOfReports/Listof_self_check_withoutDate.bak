	<variable name="SUM_TOTAL_AMOUNT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_AMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
