		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="regionid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select * 
from 
(
SELECT SUM( CASE WHEN x.receipt_type = 'C' THEN x.total_amount ELSE 0 END) AS c, 
       SUM( CASE WHEN x.receipt_type = 'B' THEN x.total_amount ELSE 0 END) AS b,
       accounting_unit_id ,
       ACCOUNTING_FOR_OFFICE_ID
       
FROM fas_receipt_master x
WHERE x.cashbook_month = $P{cashbookmonth}::int 
  AND x.cashbook_year = $P{cashbookyear} ::int
  and x.receipt_status = 'L' 
  and x.created_by_module !='SC'
  and x.ACCOUNTING_FOR_OFFICE_ID in ( select office_id from COM_MST_ALL_OFFICES_VIEW 
                             where office_id= $P{regionid}::int ) 

GROUP BY accounting_unit_id , ACCOUNTING_FOR_OFFICE_ID
ORDER BY accounting_unit_id

) m  

left outer join 

(
  select 
       accounting_unit_id, 
       accounting_unit_name
 from 
      fas_mst_acct_units     

) n 
on m.accounting_unit_id=n.accounting_unit_id 

order by m.accounting_unit_id]]></queryString>

	<field name="c" class="java.math.BigDecimal"/>
	<field name="b" class="java.math.BigDecimal"/>
	<field name="accounting_unit_id" class="java.math.BigDecimal"/>
	<field name="accounting_for_office_id" class="java.math.BigDecimal"/>
	<field name="accounting_unit_name" class="java.lang.String"/>

	<variable name="SUM_C_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{c}]]></variableExpression>
	</variable>
	<variable name="SUM_B_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{b}]]></variableExpression>
	</variable>
