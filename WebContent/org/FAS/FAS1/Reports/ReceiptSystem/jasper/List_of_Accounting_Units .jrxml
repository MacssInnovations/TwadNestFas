<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="List_of_Accounting_Units "
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="regionid" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select
    a.ACCOUNTING_UNIT_ID ,
    A.Accounting_Unit_Name, 
    B.Accounting_For_Office_Id,
 C.Office_Level_Id,      
    D.OFFICE_LEVEL_NAME
from 
    Fas_Mst_Acct_Units A,
    Fas_Mst_Acct_Unit_Offices B,
   Com_Mst_Offices C ,
    COM_MST_OFFICE_LEVELS D
where
        A.Accounting_Unit_Id=B.Accounting_Unit_Id And 
       A.ACCOUNTING_UNIT_OFFICE_ID=c.office_id and
       C.Office_Level_Id=D.Office_Level_Id   And 
        B.Accounting_For_Office_Id In ($P!{regionid}) And 
        C.Office_Status_Id Not In ('CL','RD','NC')    And 
  C.Office_Id In ($P!{regionid})
Order By A.Accounting_Unit_Id]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
