<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="MIS_WorksExpenditure_MonthlyGrouping"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="679"
		 pageHeight="842"
		 columnWidth="629"
		 columnSpacing="0"
		 leftMargin="30"
