	<parameter name="current_from_date" isForPrompting="true" class="java.lang.String"/>
	<parameter name="current_to_date" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthinwords" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select
      order_no,
      major_head_desc,
      grouping_level2_id,
      level2_group_desc,
      grouping_level3_id,
      level3_group_desc,
      fas_ac_head_code,
      account_head_desc,
      level2_orderno,
      level3_orderno,
      sum(current_month_credit) as current_year_cr,
      sum(current_month_debit) as current_year_dr,
      sum(current_month_debit)-sum(current_month_credit) as total
from
(
    select
          decode(major_head_code,'I',1,2)as order_no,
          major_head_desc,
          grouping_level2_id,
          level2_group_desc,
          grouping_level3_id,
          level3_group_desc,
          fas_ac_head_code,
          account_head_desc,
          cashbook_year,
          cashbook_month,
          current_month_credit,
          current_month_debit,
          level2_orderno,
          level3_orderno
    from
          v_fas_mis_monthly_grouping a,
          fas_trial_balance b
    where
          a.fas_ac_head_code=b.account_head_code and
          major_head_code in ('I','E') and
          to_date(cashbook_month ||'-'|| + cashbook_year, 'mm-yyyy') BETWEEN to_date('4-2008','mm-yyyy')  AND to_date('3-2009', 'mm-yyyy') 
)     
group by
      order_no,
      major_head_desc,
      grouping_level2_id,
      level2_group_desc,
      grouping_level3_id,
      level3_group_desc,
      fas_ac_head_code,
      account_head_desc,
      level2_orderno,
      level3_orderno
order by
      order_no,major_head_desc,level2_orderno,level3_orderno,grouping_level2_id,grouping_level3_id]]></queryString>

