	<parameter name="unitcode" isForPrompting="false" class="java.lang.String"/>
	<parameter name="cnt" isForPrompting="false" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT m.RECEIPT_NO as "RECEIPT_NO",   
        				  m.RECEIPT_DATE as "RECEIPT_DATE",  
        				  m.TOTAL_AMOUNT as "TOTAL_AMOUNT",  
        				  M.SUB_LEDGER_CODE as "SUB_LEDGER_CODE",  
        				  SL.SL_CODENAME as "SL_CODENAME" 
        				  FROM FAS_RECEIPT_MASTER m, 
        				  SL_TYPE_CODE_NAME_VIEW_M sl  
        				 WHERE  
        				 M.SUB_LEDGER_TYPE_CODE    =SL.SL_TYPE  
        				 AND M.SUB_LEDGER_CODE =SL.SL_CODE 
        				 and M.ACCOUNTING_UNIT_ID=  348 
        				 AND M.ACCOUNTING_FOR_OFFICE_ID=  6825  
        				 AND M.RECEIPT_DATE BETWEEN ' 2023-03-01 ' AND ' 2023-08-04 '  
        				 AND m.SUB_LEDGER_TYPE_CODE=14  
        				 and M.RECEIPT_STATUS='L' order by m.RECEIPT_DATE ;]]></queryString>

