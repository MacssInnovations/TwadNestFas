	</variable>
	<variable name="previous_fin_year_total" class="java.math.BigDecimal" resetType="Group" resetGroup="MAJOR_HEAD_DESC" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE_AS_ON_FIN_YEAR}]]></variableExpression>
	</variable>

