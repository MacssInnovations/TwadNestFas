<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Annexure-III"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthinwords" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select
 unit_id,
 ( select accounting_unit_name from fas_mst_acct_units where accounting_unit_id=unit_id) as accounting_unit_name, 
 cashbook_month, 
 cashbook_year, 
 sum(amt_160502cr) as amt_160502cr, 
 sum(amt_780406dr) as amt_780406dr,
 sum(amt_160611cr) as amt_160611cr,
 sum(amt_780406cr) as amt_780406cr , 
 sum(amt_160611cr) + sum(amt_780406cr) as tot 
from
(
select 
    accounting_unit_id as unit_id ,
    accounting_for_office_id,
    cashbook_month,
    cashbook_year ,
  case when ( account_head_code = 160502 and  CR_DR_INDICATOR ='CR' ) then 
  sum(amount)  
  else 
  0 
  end as amt_160502cr, 
  
  case when ( account_head_code = 780406 and  CR_DR_INDICATOR ='DR' ) then 
  sum(amount)  
  else 
  0 
  end as amt_780406dr , 
  
  case when ( account_head_code = 160611 and  CR_DR_INDICATOR ='CR' ) then 
  sum(amount)  
  else 
  0 
  end as amt_160611cr , 
  
  case when ( account_head_code = 780406 and  CR_DR_INDICATOR ='CR' ) then 
  sum(amount)  
  else 
  0 
  end as amt_780406cr     
    
from 
(
select 
  m.accounting_unit_id , 
  m.accounting_for_office_id , 
  m.cashbook_month, 
  m.cashbook_year,     
  t.account_head_code,
  t.CR_DR_INDICATOR, 
  t.amount   
from 
  fas_journal_master m ,
  fas_journal_transaction t
where 
  m.accounting_unit_id = t.accounting_unit_id and 
  m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
  m.cashbook_month = t.cashbook_month and 
  m.cashbook_year = t.cashbook_year and 
  m.voucher_no = t.voucher_no and 
  m.journal_status='L' and 
  (
     ( t.account_head_code = 160502 and  t.CR_DR_INDICATOR='CR' ) or 
     ( t.account_head_code = 780406 and  t.CR_DR_INDICATOR='DR' ) or 
     ( t.account_head_code = 160611 and  t.CR_DR_INDICATOR='CR' ) or 
     ( t.account_head_code = 780406 and  t.CR_DR_INDICATOR='CR' )     
  ) and     
  m.cashbook_month = $P{cashbookmonth} and 
  m.cashbook_year = $P{cashbookyear} 
  
 union all 
 
 select 
  m.accounting_unit_id , 
  m.accounting_for_office_id , 
  m.cashbook_month, 
  m.cashbook_year,     
  t.account_head_code,
  t.CR_DR_INDICATOR, 
  t.amount   
from 
  fas_payment_master m ,
  fas_payment_transaction t
where 
  m.accounting_unit_id = t.accounting_unit_id and 
  m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
  m.cashbook_month = t.cashbook_month and 
  m.cashbook_year = t.cashbook_year and 
  m.voucher_no = t.voucher_no and 
  m.payment_status='L' and 
  (
     ( t.account_head_code = 160502 and  t.CR_DR_INDICATOR='CR' ) or 
     ( t.account_head_code = 780406 and  t.CR_DR_INDICATOR='DR' ) or 
     ( t.account_head_code = 160611 and  t.CR_DR_INDICATOR='CR' ) or 
     ( t.account_head_code = 780406 and  t.CR_DR_INDICATOR='CR' )     
  ) and     
  m.cashbook_month = $P{cashbookmonth} and 
  m.cashbook_year = $P{cashbookyear}
  
  
  union all 
  
  select 
  m.accounting_unit_id , 
  m.accounting_for_office_id , 
  m.cashbook_month, 
  m.cashbook_year,     
  t.account_head_code, 
  t.CR_DR_INDICATOR,
  t.amount    
from 
  fas_receipt_master m ,
  fas_receipt_transaction t
where 
  m.accounting_unit_id = t.accounting_unit_id and 
  m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
  m.cashbook_month = t.cashbook_month and 
  m.cashbook_year = t.cashbook_year and 
  m.receipt_no = t.receipt_no and 
  m.receipt_status='L' and 
  (
     ( t.account_head_code = 160502 and  t.CR_DR_INDICATOR='CR' ) or 
     ( t.account_head_code = 780406 and  t.CR_DR_INDICATOR='DR' ) or 
     ( t.account_head_code = 160611 and  t.CR_DR_INDICATOR='CR' ) or 
     ( t.account_head_code = 780406 and  t.CR_DR_INDICATOR='CR' )     
  ) and     
  m.cashbook_month = $P{cashbookmonth} and 
  m.cashbook_year = $P{cashbookyear}
 
)  
group by accounting_unit_id,
         accounting_for_office_id , 
         cashbook_month, 
         cashbook_year,
         account_head_code,
         CR_DR_INDICATOR  
         
)
group by unit_id,cashbook_month, 
 cashbook_year
order by unit_id]]></queryString>

