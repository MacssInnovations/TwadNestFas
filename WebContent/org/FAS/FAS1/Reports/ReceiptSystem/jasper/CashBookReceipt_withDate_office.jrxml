<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="CashBookReceipt_withDate_office"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="870"
		 pageHeight="850"
		 columnWidth="860"
		 columnSpacing="0"
		 leftMargin="5"
		 rightMargin="5"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunit_name" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cmbBankId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="bankOpeningBal_for_COL" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="bankOpeningBal_for_OPR" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select  b.OFFICE_NAME,a.ACCOUNTING_UNIT_ID,a.ACCOUNTING_FOR_OFFICE_ID,a.CASHBOOK_YEAR,a.CASHBOOK_MONTH,
        a.vouDate,a.recNo,a.recPart,a.recAcchead,a.recAmt,a.recCheqDD_no,a.recChequeDD_date,a.recRecFrom,
        a.payNo,a.payPart,a.payAcchead,a.payAmt,a.payCheqDD_no,a.payChequeDD_date,a.payRefno,a.payPaidto
FROM (
                      SELECT t.ACCOUNTING_UNIT_ID,t.ACCOUNTING_FOR_OFFICE_ID,t.CASHBOOK_YEAR,t.CASHBOOK_MONTH,
                       m.receipt_date AS vouDate,t.receipt_no as recNo,t.particulars AS recPart, t.account_head_code AS  recAcchead,
                       decode(t.cr_dr_indicator,'CR',t.amount,-t.amount) as recAmt, decode(t.cheque_or_dd || '-' ||t.cheque_dd_no,'-',null,t.cheque_or_dd || '-' ||t.cheque_dd_no) AS  recCheqDD_no,
                       t.cheque_dd_date AS  recChequeDD_date,m.received_from as recRecFrom,
                       
                       to_number(null) as payNo,to_char(null) as payPart, to_number(null) AS  payAcchead,
                       to_number(null) as payAmt,to_char(null) as  payCheqDD_no,
                       to_date(null) as  payChequeDD_date,to_char(null) as payRefno,to_char(null) as payPaidto
                           
                      FROM FAS_RECEIPT_MASTER m, FAS_RECEIPT_TRANSACTION t
                      WHERE t.accounting_unit_id = m.accounting_unit_id
                         AND t.accounting_for_office_id = m.accounting_for_office_id
                         AND t.cashbook_year = m.cashbook_year
                         AND t.cashbook_month = m.cashbook_month
                         AND t.receipt_no = m.receipt_no
                         AND m.receipt_status!='C'
                         AND m.created_by_module in('CR','SC')
                      
                      UNION ALL
                      
                      SELECT t.ACCOUNTING_UNIT_ID,t.ACCOUNTING_FOR_OFFICE_ID,t.CASHBOOK_YEAR,t.CASHBOOK_MONTH,
                            m.receipt_date AS vouDate, t.receipt_no as recNo,t.particulars AS recPart, t.account_head_code AS  recAcchead,
                           decode(t.cr_dr_indicator,'CR',t.amount,-t.amount) as recAmt,    decode(t.cheque_or_dd || '-' ||t.cheque_dd_no,'-',null,t.cheque_or_dd || '-' ||t.cheque_dd_no) AS  recCheqDD_no,
                           t.cheque_dd_date AS  recChequeDD_date,m.received_from as recRecFrom,
                           
                           to_number(null) as payNo,to_char(null) as payPart, to_number(null) AS  payAcchead,
                           to_number(null) as payAmt,  to_char(null) as  payCheqDD_no,
                           to_date(null) as  payChequeDD_date,to_char(null) as payRefno,to_char(null) as payPaidto
                           
                      FROM FAS_RECEIPT_MASTER m, FAS_RECEIPT_TRANSACTION  t 
                      WHERE t.accounting_unit_id = m.accounting_unit_id 
                         AND t.accounting_for_office_id = m.accounting_for_office_id 
                         AND t.cashbook_year = m.cashbook_year 
                         AND t.cashbook_month = m.cashbook_month 
                         AND t.receipt_no = m.receipt_no 
                         AND m.receipt_status!='C' 
                         AND m.bank_id=$P{cmbBankId} 
                         AND m.created_by_module='BR' 
                         
                      UNION ALL
                      
                      SELECT t.ACCOUNTING_UNIT_ID,t.ACCOUNTING_FOR_OFFICE_ID,t.CASHBOOK_YEAR,t.CASHBOOK_MONTH,
                             m.payment_date AS vouDate,to_number(null) as recNo,to_char(null) as recPart, to_number(null) AS  recAcchead,
                             to_number(null) as recAmt,to_char(null) as  recCheqDD_no,to_date(null) as  recChequeDD_date,to_char(null) as recRecFrom,
                           
                              t.voucher_no AS  payNo,t.particulars AS payPart,t.account_head_code AS  payAcchead,
                              decode(t.cr_dr_indicator,'DR',t.amount,-t.amount) as payAmt,decode(t.cheque_or_dd || '-' ||t.cheque_dd_no,'-',null,t.cheque_or_dd || '-' ||t.cheque_dd_no) AS  payCheqDD_no,
                              t.cheque_dd_date AS  payChequeDD_date,to_char(null) AS payRefno,m.paid_to as payPaidto
                      
                      FROM FAS_PAYMENT_MASTER m, FAS_PAYMENT_TRANSACTION  t 
                      WHERE t.accounting_unit_id = m.accounting_unit_id 
                         AND t.accounting_for_office_id = m.accounting_for_office_id 
                         AND t.cashbook_year = m.cashbook_year 
                         AND t.cashbook_month = m.cashbook_month 
                         AND t.voucher_no = m.voucher_no 
                         AND m.PAYMENT_status!='C' 
                         AND m.bank_id=$P{cmbBankId} 
                         AND m.created_by_module in ('BPP','BPF','NP') 
                           
                      UNION ALL
                      
                      SELECT t.ACCOUNTING_UNIT_ID,t.ACCOUNTING_FOR_OFFICE_ID,t.CASHBOOK_YEAR,t.CASHBOOK_MONTH,
                           m.payment_date AS vouDate, to_number(null) as recNo,to_char(null) as recPart, to_number(null) AS  recAcchead,
                           to_number(null) as recAmt,    to_char(null) as  recCheqDD_no,
                           to_date(null) as  recChequeDD_date,to_char(null) as recRecFrom,
                           
                          t.voucher_no AS  payNo,t.particulars AS payPart,t.account_head_code AS  payAcchead,
                          decode(t.cr_dr_indicator,'DR',t.amount,-t.amount) as payAmt,    decode(t.cheque_or_dd || '-' ||t.cheque_dd_no,'-',null,t.cheque_or_dd || '-' ||t.cheque_dd_no) AS  payCheqDD_no,
                          t.cheque_dd_date AS  payChequeDD_date,to_char(null) AS payRefno,m.paid_to as payPaidto 
                      
                      FROM FAS_PAYMENT_MASTER m, FAS_PAYMENT_TRANSACTION  t 
                      WHERE t.accounting_unit_id = m.accounting_unit_id 
                         AND t.accounting_for_office_id = m.accounting_for_office_id 
                         AND t.cashbook_year = m.cashbook_year 
                         AND t.cashbook_month = m.cashbook_month 
                         AND t.voucher_no = m.voucher_no 
                         AND m.PAYMENT_status!='C' 
                         AND m.created_by_module in ('SC')
                         
                      
                      UNION ALL 
                      
                      SELECT ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,CASHBOOK_YEAR,CASHBOOK_MONTH,
                            DATE_OF_TRANSFER AS vouDate,VOUCHER_NO as recNo,particulars AS recPart, DR_ACCOUNT_HEAD_CODE AS  recAcchead,
                           TOTAL_AMOUNT as recAmt,     decode(cheque_or_dd || '-' ||cheque_dd_no,'-',null,cheque_or_dd || '-' ||cheque_dd_no) AS  recCheqDD_no,
                           cheque_dd_date AS  recChequeDD_date,to_char('Interbank Receipt') as recRecFrom,
                           
                           to_number(null) as payNo,to_char(null) as payPart, to_number(null) AS  payAcchead,
                           to_number(null) as payAmt,    to_char(null) as  payCheqDD_no,
                           to_date(null) as  payChequeDD_date,to_char(null) as payRefno,to_char(null) as payPaidto
                      FROM FAS_INTER_BANK_TRF_AT_HO
                      WHERE TRANSFER_STATUS!='C' AND TO_BANK_ID=$P{cmbBankId} 
                      
                      UNION ALL 
                      
                      SELECT ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,CASHBOOK_YEAR,CASHBOOK_MONTH,
                            DATE_OF_TRANSFER AS vouDate,to_number(null) as recNo,to_char(null) as recPart, to_number(null) AS  recAcchead,
                           to_number(null) as recAmt,to_char(null) as  recCheqDD_no,to_date(null) as  recChequeDD_date,to_char(null) as recRecFrom,
                           
                          voucher_no AS  payNo,particulars AS payPart,CR_ACCOUNT_HEAD_CODE AS  payAcchead,
                          TOTAL_AMOUNT as payAmt,    decode(cheque_or_dd || '-' ||cheque_dd_no,'-',null,cheque_or_dd || '-' ||cheque_dd_no) AS  payCheqDD_no,
                          cheque_dd_date AS  payChequeDD_date,to_char(null) AS payRefno,to_char('Interbank Transfer') as payPaidto
                          
                      FROM FAS_INTER_BANK_TRF_AT_HO 
                      WHERE TRANSFER_STATUS!='C' AND FROM_BANK_ID=$P{cmbBankId} 
                      
                      
                      UNION ALL
                      
                      SELECT ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,CASHBOOK_YEAR,CASHBOOK_MONTH,
                          receipt_date AS vouDate,receipt_no as recNo, particulars AS recPart, DR_ACCOUNT_HEAD_CODE AS  recAcchead,
                           TOTAL_AMOUNT as recAmt,  decode(cheque_or_dd || '-' ||cheque_dd_no,'-',null,cheque_or_dd || '-' ||cheque_dd_no) AS  recCheqDD_no,
                           cheque_dd_date AS  recChequeDD_date,to_char('Fund Receipt') as recRecFrom,
                           
                           to_number(null) as payNo, to_char(null) as payPart, to_number(null) AS  payAcchead,
                           to_number(null) as payAmt,    to_char(null) as  payCheqDD_no,
                           to_date(null) as  payChequeDD_date,to_char(null) as payRefno,to_char(null) as payPaidto
                      FROM FAS_FUND_RECEIPT_BY_OFFICE
                      WHERE RECEIPT_STATUS!='C' AND OFFICE_BANK_ID=$P{cmbBankId} 
                         
                      UNION ALL
                      
                      SELECT ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,CASHBOOK_YEAR,CASHBOOK_MONTH,
                           DATE_OF_TRANSFER AS vouDate, to_number(null) as recNo, to_char(null) as recPart, to_number(null) AS  recAcchead,
                           to_number(null) as recAmt,    to_char(null) as  recCheqDD_no,
                           to_date(null) as  recChequeDD_date,to_char(null) as recRecFrom,
                           
                          voucher_no AS  payNo,particulars AS payPart,CR_ACCOUNT_HEAD_CODE AS  payAcchead,
                          TOTAL_AMOUNT as payAmt,    decode(cheque_or_dd || '-' ||cheque_dd_no,'-',null,cheque_or_dd || '-' ||cheque_dd_no) AS  payCheqDD_no,
                          cheque_dd_date AS  payChequeDD_date,to_char(null) AS payRefno,to_char('Fund Transfer') as payPaidto
                      FROM FAS_FUND_TRF_FROM_OFFICE
                      WHERE TRANSFER_STATUS!='C' AND OFFICE_BANK_ID=$P{cmbBankId} 
                  ) a ,COM_MST_OFFICES b
where a.ACCOUNTING_UNIT_ID=$P{accountingunitid}  
      and a.CASHBOOK_YEAR=$P{txtCB_Year} 
      and a.CASHBOOK_MONTH=$P{txtCB_Month} 
      and a.vouDate between to_date($P{txtfrom},'DD/MM/YYYY') and to_date($P{txtto},'DD/MM/YYYY') 
      and a.ACCOUNTING_FOR_OFFICE_ID=b.office_id 
order by b.OFFICE_NAME,a.vouDate , a.recNo, a.payNo]]></queryString>

	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="VOUDATE" class="java.sql.Timestamp"/>
	<field name="RECNO" class="java.math.BigDecimal"/>
	<field name="RECPART" class="java.lang.String"/>
	<field name="RECACCHEAD" class="java.math.BigDecimal"/>
	<field name="RECAMT" class="java.math.BigDecimal"/>
	<field name="RECCHEQDD_NO" class="java.lang.String"/>
	<field name="RECCHEQUEDD_DATE" class="java.sql.Timestamp"/>
	<field name="RECRECFROM" class="java.lang.String"/>
	<field name="PAYNO" class="java.math.BigDecimal"/>
	<field name="PAYPART" class="java.lang.String"/>
	<field name="PAYACCHEAD" class="java.math.BigDecimal"/>
	<field name="PAYAMT" class="java.math.BigDecimal"/>
	<field name="PAYCHEQDD_NO" class="java.lang.String"/>
	<field name="PAYCHEQUEDD_DATE" class="java.sql.Timestamp"/>
	<field name="PAYREFNO" class="java.lang.String"/>
	<field name="PAYPAIDTO" class="java.lang.String"/>

	<variable name="SUM_RECAMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{RECAMT}]]></variableExpression>
	</variable>
	<variable name="SUM_PAYAMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{PAYAMT}]]></variableExpression>
	</variable>
	<variable name="closing_bal_COL" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{SUM_RECAMT_1}.doubleValue()) +( $P{bankOpeningBal_for_COL}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="closing_bal_OPR" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{SUM_PAYAMT_1}.doubleValue()) -( $P{bankOpeningBal_for_OPR}.doubleValue()))]]></variableExpression>
	</variable>

