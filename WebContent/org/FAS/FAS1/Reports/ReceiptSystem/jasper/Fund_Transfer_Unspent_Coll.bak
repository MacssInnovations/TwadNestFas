<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Fund_Transfer_Unspent_Coll"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="907"
		 pageHeight="595"
		 columnWidth="847"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="bank_id" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT accounting_unit_id,
  acct_unit_name,
  accounting_for_office_id,
  cashbook_year,
  cashbook_month,
  cr_account_head_code,
  office_bank_id,
  BANK_NAME,
  SUM(COLLECTION_AMOUNT) as COLLECTION_AMOUNT,
  SUM(UNSPENT_AMOUNT) as UNSPENT_AMOUNT,
  SUM(OTHERS) AS OTHERS,
  sum(collection_amount+unspent_amount+OTHERS) AS total,type,
  cheque_or_dd,
  cheque_dd_no,
  cheque_dd_date
FROM
  (SELECT accounting_unit_id,
    acct_unit_name,
    accounting_for_office_id,
    cashbook_year,
    cashbook_month,
    cr_account_head_code,
    office_bank_id,
   -- SUM(DECODE(trim(remittance_type),'C',total_amount,0)) AS collection_amount,
   case when trim(remittance_type)='c' then Sum(total_amount) else 0 end as collection_amount,
    --SUM(DECODE(TRIM(REMITTANCE_TYPE),'U',TOTAL_AMOUNT,0)) AS UNSPENT_AMOUNT,
   case when TRIM(REMITTANCE_TYPE)='U' then sum(total_amount)else 0 end as Unspent_amount,
    CASE WHEN TRIM(REMITTANCE_TYPE) NOT LIKE 'C' AND TRIM(REMITTANCE_TYPE) NOT LIKE 'U' THEN TOTAL_AMOUNT ELSE 0 END AS OTHERS, 
 case when TRIM(REMITTANCE_TYPE) like 'C' then 'C' when TRIM(REMITTANCE_TYPE) like 'U' then 'U' else 'O' end as type,

    cheque_or_dd,
    cheque_dd_no,
    cheque_dd_date
  FROM
    (SELECT accounting_unit_id,
      acct_unit_name,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      remittance_type,
      cr_account_head_code,
      office_bank_id,
      SUM(total_amount) AS total_amount,
      cheque_or_dd,
      cheque_dd_no,
      cheque_dd_date
    FROM
      (SELECT accounting_unit_id,
        acct_unit_name,
        accounting_for_office_id,
        date_of_transfer,
        cashbook_year,
        cashbook_month,
        remittance_type,
        cr_account_head_code,
        office_bank_id,
        total_amount,
        cheque_or_dd,
        cheque_dd_no,
        cheque_dd_date
      FROM
        (SELECT accounting_unit_id,
          accounting_for_office_id,
          date_of_transfer,
          cashbook_year,
          cashbook_month,
          remittance_type,
          cr_account_head_code,
          office_bank_id,
          total_amount,
          transfer_status,
          cheque_or_dd,
          cheque_dd_no,
          cheque_dd_date
        FROM fas_fund_trf_from_office
        WHERE transfer_status='L'
        ) a
      LEFT OUTER JOIN
        (SELECT accounting_unit_id  AS acct_unit_id,
          accounting_unit_name      AS acct_unit_name,
          accounting_unit_office_id AS acct_office_id
        FROM fas_mst_acct_units
        ) b
      ON a.accounting_unit_id       =b.acct_unit_id
      AND a.accounting_for_office_id=b.acct_office_id
      ) x
    GROUP BY accounting_unit_id,
      acct_unit_name,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      remittance_type,
      cr_account_head_code,
      office_bank_id,
      cheque_or_dd,
      cheque_dd_no,
      cheque_dd_date
    )ad
 GROUP BY accounting_unit_id, acct_unit_name, accounting_for_office_id,remittance_type, cashbook_year, cashbook_month, cr_account_head_code, office_bank_id, CASE WHEN TRIM(REMITTANCE_TYPE) NOT LIKE 'C' AND TRIM(REMITTANCE_TYPE) NOT LIKE 'U' THEN TOTAL_AMOUNT ELSE 0 END, case when TRIM(REMITTANCE_TYPE) like 'C' then 'C' when TRIM(REMITTANCE_TYPE) like 'U' then 'U' else 'O' end, cheque_or_dd, cheque_dd_no, cheque_dd_date
  ) aa
LEFT OUTER JOIN
  ( SELECT bank_id,bank_name FROM fas_mst_banks
  ) bb
ON aa.office_bank_id=bb.bank_id
where cashbook_year=$P{yr}::int and cashbook_month=$P{mon}::int and office_bank_id=$P{bank_id}::int  
GROUP BY accounting_unit_id, acct_unit_name, accounting_for_office_id, cashbook_year, cashbook_month, cr_account_head_code, office_bank_id, BANK_NAME, type, cheque_or_dd, cheque_dd_no, cheque_dd_date
ORDER BY accounting_unit_id
]]></queryString>

