	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="schedule" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select 
accounting_unit_id,accounting_for_office_id,account_head_code,SCHEDULE_ID,to_char(OPENING_BALANCE) as OPENING_BALANCE,
current_month_debit,current_month_credit,to_char(CLOSING_BALANCE) AS CLOSING_BALANCE,OPENING_BALANCE_CR_DR_IND,
CLOSING_BALANCE_CR_DR_IND,CASHBOOK_YEAR,CASHBOOK_MONTH,VOUCHER_NO,DOCUMENT_TYPE,DOC_DATE,particulars from FAS_A35SCHEDULEREPORT_TMP
where SCHEDULE_ID='A26')a
inner join
(
select ACCOUNT_HEAD_CODE, account_head_desc from com_mst_account_heads ) 
b on a.account_head_code=b.account_head_code
inner join
(
select OFFICE_ID,OFFICE_NAME from  com_mst_offices ) c
on a.accounting_for_office_id=c.office_id 
inner join
(
select ACCOUNTING_UNIT_ID,ACCOUNTING_UNIT_NAME from FAS_MST_ACCT_UNITS ) d
on a.accounting_unit_id=d.accounting_unit_id 
inner join
(
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,CASHBOOK_YEAR,CASHBOOK_MONTH,
ACHCODE,SLTYPECODE,SLCODE from FAS_HEAD_SLTYPE_VIEW
) e 
on a.ACCOUNTING_UNIT_ID=e.ACCOUNTING_UNIT_ID and e.ACHCODE=a.ACCOUNT_HEAD_CODE

inner join 
(
select SL_TYPE,SL_CODE,SL_CODENAME from SL_TYPE_CODE_NAME_VIEW_M
) f
on f.SL_TYPE=e.SLTYPECODE and e.SLCODE=f.SL_CODE
inner join
(
select SUB_LEDGER_TYPE_CODE,SUB_LEDGER_TYPE_DESC from COM_MST_SL_TYPES ) g
on e.SLTYPECODE = g.SUB_LEDGER_TYPE_CODE 
where
a.cashbook_month=($P{cashbookmonth}) and a.cashbook_year=($P{cashbookyear}) and a.accounting_unit_id=($P{accountingunitid})
and a.accounting_for_office_id=($P{accountofficeid})
order by a.account_head_code,g.SUB_LEDGER_TYPE_CODE,a.DOC_DATE,a.VOUCHER_NO]]></queryString>

