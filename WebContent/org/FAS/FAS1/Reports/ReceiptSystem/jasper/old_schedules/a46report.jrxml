<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="a46report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="708"
		 pageHeight="842"
		 columnWidth="648"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="reporttype" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select 
* 
from 
( 
select 
 trim(to_char(cr_amt,'99999999999999.99'))  as cr_amt,  
 trim(to_char(dr_amt,'99999999999999.99'))  as dr_amt,  
 X_acc_head,
 ( select account_head_desc from com_mst_account_heads where account_head_code= X_acc_head) as X_acc_head_desc, 
 ( select accounting_unit_name from fas_mst_acct_units where accounting_unit_id=$P{accountingunitid} ) as accounting_unit_name, 
 ( select office_short_name from com_mst_offices where office_id= $P{accountofficeid} ) as office_short_name 
from 
( 
select 
   sum(cr_amt) as cr_amt, 
   sum(dr_amt) as dr_amt, 
   account_head_code as X_acc_head
from 
(
select 
  case when cr_dr_indicator = 'CR' then 
  amount 
  else 
  0 end as cr_amt, 
  case when cr_dr_indicator = 'DR' then 
  amount 
  else 
  0 end as dr_amt, 
  account_head_code 
from 
( 

select
   sum(a.amount) as amount,  
   a.account_head_code,
   a.cr_dr_indicator
from 
   fas_receipt_transaction a,
   fas_receipt_master b 
where 
    a.accounting_unit_id=b.accounting_unit_id 
and a.accounting_for_office_id=b.accounting_for_office_id 
and a.cashbook_year=b.cashbook_year 
and a.cashbook_month=b.cashbook_month 
and a.receipt_no=b.receipt_no 
and b.receipt_status!='C' 
and a.account_head_code in ( select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A46' )  
and a.cr_dr_indicator='CR' 
and a.cashbook_year=$P{cashbookyear} 
and a.cashbook_month=$P{cashbookmonth} 
and a.accounting_unit_id= $P{accountingunitid} 
and a.accounting_for_office_id= $P{accountofficeid} 
group by a.account_head_code, a.cr_dr_indicator

union all 

select 
    sum(a.amount) as amount, 
    a.account_head_code,
    a.cr_dr_indicator 
from 
    fas_journal_transaction a,
    fas_journal_master b 
where  
    a.accounting_unit_id=b.accounting_unit_id 
and a.accounting_for_office_id=b.accounting_for_office_id  
and a.cashbook_year=b.cashbook_year 
and a.cashbook_month=b.cashbook_month 
and a.voucher_no=b.voucher_no 
and b.journal_status!='C' 
and a.account_head_code in ( select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A46' ) 
and a.cr_dr_indicator='CR' 
and a.cashbook_year= $P{cashbookyear} 
and a.cashbook_month= $P{cashbookmonth} 
and a.accounting_unit_id= $P{accountingunitid} 
and a.accounting_for_office_id=$P{accountofficeid} 
group by a.account_head_code, a.cr_dr_indicator

union all 

select
   sum(a.amount) as amount, 
   a.account_head_code, 
   a.cr_dr_indicator
from 
   fas_payment_transaction a,
   fas_payment_master b 
where 
    a.accounting_unit_id=b.accounting_unit_id 
and a.cashbook_year=b.cashbook_year
and a.cashbook_month=b.cashbook_month 
and a.accounting_for_office_id=b.accounting_for_office_id 
and a.voucher_no=b.voucher_no 
and b.payment_status!='C'
and a.account_head_code in ( select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A46' ) 
and a.cr_dr_indicator='DR' 
and a.cashbook_year=$P{cashbookyear} 
and a.cashbook_month=$P{cashbookmonth}
and a.accounting_unit_id=$P{accountingunitid} 
and a.accounting_for_office_id=$P{accountofficeid} 
group by a.account_head_code, a.cr_dr_indicator

union all

select 
   sum(a.amount) as amount, 
   a.account_head_code, 
   a.cr_dr_indicator
from
   fas_journal_transaction a,
   fas_journal_master b 
where 
    a.accounting_unit_id=b.accounting_unit_id 
and a.accounting_for_office_id=b.accounting_for_office_id
and a.cashbook_year=b.cashbook_year 
and a.cashbook_month=b.cashbook_month 
and a.voucher_no=b.voucher_no 
and b.journal_status!='C' 
and a.account_head_code in ( select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A46' )  
and a.cr_dr_indicator='DR'
and a.cashbook_year=$P{cashbookyear} 
and a.cashbook_month=$P{cashbookmonth} 
and a.accounting_unit_id=$P{accountingunitid} 
and a.accounting_for_office_id=$P{accountofficeid} 
group by a.account_head_code, a.cr_dr_indicator
) 
)group by account_head_code 
order by account_head_code 
)) X 

left outer join 

(
 select 
   trim(to_char(MONTH_OPENING_BALANCE,'99999999999999.99'))  as MONTH_OPENING_BALANCE,
   MONTH_OPENING_BAL_DR_CR_IND, 
   trim(to_char(MONTH_CLOSING_BALANCE,'99999999999999.99'))  as MONTH_CLOSING_BALANCE,
   MONTH_CLOSING_BAL_DR_CR_IND, 
   account_head_code as Y_acc_head  
 from 
   FAS_GENERAL_LEDGER 
 where 
     ACCOUNTING_UNIT_ID=$P{accountingunitid} 
 and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} 
 and YEAR=$P{cashbookyear} 
 and MONTH=$P{cashbookmonth} 
)Y

on 
X.X_acc_head =  Y.Y_acc_head

$P!{reporttype}

order by X_acc_head]]></queryString>

