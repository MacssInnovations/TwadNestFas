a.accounting_for_office_id=c.office_id and
a.accounting_unit_id=d.accounting_unit_id and
a.cashbook_month=($P{cashbookmonth}) and a.cashbook_year=($P{cashbookyear}) and a.accounting_unit_id=($P{accountingunitid})
