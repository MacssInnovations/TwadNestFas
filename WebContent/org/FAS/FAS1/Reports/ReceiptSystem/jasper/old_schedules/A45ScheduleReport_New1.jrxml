<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="A45ScheduleReport_New1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<parameter name="schedule" isForPrompting="true" class="java.lang.String"/>
	<parameter name="reporttype" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
* 
from 
(
select 
    a.account_head_code,
    a.particulars as remarks,
    a.receipt_no as recpno,
    'R' as doctype,
    a.amount as amt ,
    a.CR_DR_INDICATOR,	    
    case  when a.CR_DR_INDICATOR='CR' then
               a.amount 
          else 
               0 
          end as cr_amt, 
    case  when a.CR_DR_INDICATOR='DR' then
               a.amount 
          else 
               0 
          end as dr_amt,    
    e.account_head_desc,
    c.office_short_name,
    d.accounting_unit_name     
from 
    fas_receipt_transaction a,
    fas_receipt_master b ,
    com_mst_account_heads e,
    com_mst_offices c,
    fas_mst_acct_units d     
where 
    a.account_head_code=e.account_head_code and
    a.accounting_for_office_id=c.office_id and
    a.accounting_unit_id=d.accounting_unit_id and  
    a.accounting_unit_id=b.accounting_unit_id and 
    a.accounting_for_office_id=b.accounting_for_office_id and 
    a.cashbook_year=b.cashbook_year and 
    a.cashbook_month=b.cashbook_month and 
    a.receipt_no=b.receipt_no and 
    b.receipt_status !='C' and 
    a.account_head_code in ( select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A45') and 
    a.cr_dr_indicator='CR' and     
    a.cashbook_year=$P{cashbookyear} and 
    a.cashbook_month=$P{cashbookmonth} and 
    a.accounting_unit_id=$P{accountingunitid} and 
    a.accounting_for_office_id=$P{accountofficeid}            
    
union 
             
select 
    a.account_head_code,
    a.particulars as remarks,
    a.voucher_no as recpno,
    'J' as doctype,
    a.amount as amt,   
    a.CR_DR_INDICATOR,	    
    case  when a.CR_DR_INDICATOR='CR' then
               a.amount 
          else 
               0 
          end as cr_amt, 
    case  when a.CR_DR_INDICATOR='DR' then
               a.amount 
          else 
               0 
          end as dr_amt,    
    e.account_head_desc,
    c.office_short_name,
    d.accounting_unit_name        
from 
    fas_journal_transaction a,
    fas_journal_master b,
    com_mst_account_heads e,
    com_mst_offices c,
    fas_mst_acct_units d  
where 
    a.account_head_code=e.account_head_code and
    a.accounting_for_office_id=c.office_id and
    a.accounting_unit_id=d.accounting_unit_id and     
    a.accounting_unit_id=b.accounting_unit_id and 
    a.accounting_for_office_id=b.accounting_for_office_id and 
    a.cashbook_year=b.cashbook_year and 
    a.cashbook_month=b.cashbook_month and 
    a.voucher_no=b.voucher_no and 
    b.journal_status!='C' and 
    b.CREATED_BY_MODULE in ('GJV' , 'LJV') and 
    a.account_head_code in ( select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A45') and
    a.cr_dr_indicator='CR' and 
    a.cashbook_year=$P{cashbookyear} and 
    a.cashbook_month=$P{cashbookmonth} and 
    a.accounting_unit_id=$P{accountingunitid} and 
    a.accounting_for_office_id=$P{accountofficeid}      
    
union 
             
select 
    a.account_head_code,
    a.particulars as remarks,
    a.voucher_no as recpno,
    'P' as doctype,
    a.amount as amt,
    a.CR_DR_INDICATOR,	    
    case  when a.CR_DR_INDICATOR='CR' then
               a.amount 
          else 
               0 
          end as cr_amt, 
    case  when a.CR_DR_INDICATOR='DR' then
               a.amount 
          else 
               0 
          end as dr_amt,    
    e.account_head_desc,
    c.office_short_name,
    d.accounting_unit_name       
from 
     fas_payment_transaction a,
     fas_payment_master b ,
     com_mst_account_heads e,
     com_mst_offices c,
     fas_mst_acct_units d      
where 
     a.accounting_unit_id=b.accounting_unit_id and 
     a.cashbook_year=b.cashbook_year and 
     a.cashbook_month=b.cashbook_month and 
     a.accounting_for_office_id=b.accounting_for_office_id and 
     a.voucher_no=b.voucher_no and 
     b.payment_status!='C' and 
     a.account_head_code in ( select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A45') and 
     a.cr_dr_indicator='DR' and 
     a.cashbook_year=$P{cashbookyear} and 
     a.cashbook_month=$P{cashbookmonth} and 
     a.accounting_unit_id=$P{accountingunitid} and 
     a.accounting_for_office_id=$P{accountofficeid} and 
     a.account_head_code=e.account_head_code and
     a.accounting_for_office_id=c.office_id and
     a.accounting_unit_id=d.accounting_unit_id 
    
     
union 
             
select 
    a.account_head_code,
    a.particulars as remarks,
    a.voucher_no as recpno,
    'J' as doctype,
    a.amount as amt ,
    a.CR_DR_INDICATOR,	    
    case  when a.CR_DR_INDICATOR='CR' then
               a.amount 
          else 
               0 
          end as cr_amt, 
    case  when a.CR_DR_INDICATOR='DR' then
               a.amount 
          else 
               0 
          end as dr_amt,    
    e.account_head_desc,
    c.office_short_name,
    d.accounting_unit_name   
from 
    fas_journal_transaction a,
    fas_journal_master b ,
    com_mst_account_heads e,
    com_mst_offices c,
    fas_mst_acct_units d 
    
where 
    a.accounting_unit_id=b.accounting_unit_id and 
    a.accounting_for_office_id=b.accounting_for_office_id and
    a.cashbook_year=b.cashbook_year and 
    a.cashbook_month=b.cashbook_month and 
    a.voucher_no=b.voucher_no and 
    b.journal_status!='C' and 
    b.CREATED_BY_MODULE in ('GJV' , 'LJV') and 
    a.account_head_code in ( select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A45') and 
    a.cr_dr_indicator='DR' and 
    a.cashbook_year=$P{cashbookyear} and 
    a.cashbook_month=$P{cashbookmonth} and 
    a.accounting_unit_id=$P{accountingunitid} and 
    a.accounting_for_office_id=$P{accountofficeid}  and 
    a.account_head_code=e.account_head_code and
    a.accounting_for_office_id=c.office_id and
    a.accounting_unit_id=d.accounting_unit_id
)

$P!{reporttype}

order by account_head_code, doctype, recpno]]></queryString>

