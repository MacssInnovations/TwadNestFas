<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="A47ScheduleReport_SJV"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="reporttype" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
  account_head_code, 
  account_head_desc, 
  cr_dr_indicator, 
  remarks, 
  recpno, 
  doctype, 
  cramount, 
  dramount,
  ACCOUNTING_UNIT_NAME,
  OFFICE_SHORT_NAME  
from 
(

select * 
from 
 (
  select 
    account_head_code as acc_head, 
    ACCOUNT_HEAD_DESC
  from 
    COM_MST_ACCOUNT_HEADS
  where     
    ACCOUNT_HEAD_CODE in 
    ( 
       select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A47'
    )   
 )a
 
inner join 

(
select 
     cr_dr_indicator, 
     remarks, 
     recpno, 
     doctype, 
     decode (cr_dr_indicator,'CR',amt,0) cramount,
     decode (cr_dr_indicator,'DR',amt,0) dramount,
     account_head_code 
from 
(

select 
     a.cr_dr_indicator,
     a.particulars as remarks,
     a.voucher_no as recpno,
     'J' as doctype,
     a.amount as amt, 
     a.account_head_code
from 
     fas_journal_transaction a,
     fas_journal_master b 
where 
     a.accounting_unit_id=b.accounting_unit_id 
 and a.accounting_for_office_id=b.accounting_for_office_id 
 and a.cashbook_year=b.cashbook_year 
 and a.cashbook_month=b.cashbook_month
 and a.voucher_no=b.voucher_no 
 and b.journal_status!='C'
 and a.cr_dr_indicator='CR' 
 and b.created_by_module in ('SJV') 
 and a.cashbook_year=$P{cashbookyear} 
 and a.cashbook_month=$P{cashbookmonth} 
 and a.accounting_unit_id=$P{accountingunitid} 
 and a.accounting_for_office_id=$P{accountofficeid} 
 
 union all
 
 select 
     a.cr_dr_indicator,
     a.particulars as remarks,
     a.voucher_no as recpno,
     'J' as doctype,
     a.amount as amt,
     a.account_head_code
from 
     fas_journal_transaction a,
     fas_journal_master b 
where 
     a.accounting_unit_id=b.accounting_unit_id
 and a.accounting_for_office_id=b.accounting_for_office_id 
 and a.cashbook_year=b.cashbook_year 
 and a.cashbook_month=b.cashbook_month 
 and a.voucher_no=b.voucher_no 
 and b.journal_status!='C'  
 and a.cr_dr_indicator='DR' 
 and b.created_by_module in ('SJV') 
 and a.cashbook_year=$P{cashbookyear} 
 and a.cashbook_month=$P{cashbookmonth} 
 and a.accounting_unit_id=$P{accountingunitid} 
 and a.accounting_for_office_id=$P{accountofficeid} 
 
 )) b 
 
 on a.acc_head = b.account_head_code 
),
(
  select 
     ACCOUNTING_UNIT_NAME 
  from 
   fas_mst_acct_units
  where ACCOUNTING_UNIT_ID = $P{accountingunitid}
     and ACCOUNTING_UNIT_OFFICE_ID = $P{accountofficeid}
),
(
  select 
    OFFICE_SHORT_NAME
  from   
     com_mst_offices
  where office_id=$P{accountofficeid}   
)

$P!{reporttype}

order by account_head_code, doctype , recpno ]]></queryString>

