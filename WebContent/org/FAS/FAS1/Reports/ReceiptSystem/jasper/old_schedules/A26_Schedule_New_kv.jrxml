<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="A26_Schedule_New_kv"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="842"
		 columnWidth="818"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="reporttype" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
  *
from 
(
select 
  z.account_head_code,
  y.account_head_desc, 
  z.accounting_unit_id,
  z.accounting_for_office_id,
  j.ACCOUNTING_UNIT_NAME,
  z.cashbook_year,
  z.cashbook_month,
  z.doc_no,
  z.doc_date,
  z.doc_type,
  z.cr_dr_indicator,  
  z.amount,  
  case when z.cr_dr_indicator='CR' then 
       z.amount
       else 
       0 
       end as cr_amt, 
  case when z.cr_dr_indicator='DR' then 
       z.amount
       else 
       0 
      end as dr_amt,     
  z.particulars,
  z.sub_ledger_type_code,
  z.sl_desc,
  z.sub_ledger_code,
  z.sl_code_desc ,
  x.MONTH_OPENING_BAL_DR_CR_IND ,
  x.MONTH_OPENING_BALANCE,  
  case when x.MONTH_OPENING_BAL_DR_CR_IND='CR' then 
       x.MONTH_OPENING_BALANCE
       else 
       0 
       end as cr_ob_amt, 
  case when x.MONTH_OPENING_BAL_DR_CR_IND='DR' then 
       x.MONTH_OPENING_BALANCE
       else 
       0 
       end as dr_ob_amt   
 -- x.ACCOUNT_HEAD_CODE
from 
(

SELECT 
a.account_head_code,
a.accounting_unit_id,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.voucher_no AS doc_no,
  b.payment_date AS doc_date,
  'P' AS doc_type,
  a.cr_dr_indicator,
  a.amount,
  a.particulars,
  a.sub_ledger_type_code,
  (select sub_ledger_type_desc from com_mst_sl_types where sub_ledger_type_code=a.sub_ledger_type_code ) as sl_desc,
  a.sub_ledger_code,
  (select sl_codename from sl_type_code_name_view_M where sl_type=a.sub_ledger_type_code and  sl_code=a.sub_ledger_code) as sl_code_desc
  
FROM

  fas_payment_transaction a,
  fas_payment_master b

WHERE a.accounting_unit_id = b.accounting_unit_id
 AND a.accounting_for_office_id = b.accounting_for_office_id
 AND a.cashbook_year = b.cashbook_year
 AND a.cashbook_month = b.cashbook_month
 and a.voucher_no=b.voucher_no 
 AND a.accounting_unit_id = $P{accountingunitid}
 AND a.accounting_for_office_id = $P{accountofficeid}
 AND a.cashbook_year = $P{cashbookyear}
 AND a.cashbook_month = $P{cashbookmonth}
 and b.PAYMENT_STATUS='L' 
 AND a.account_head_code IN
  (SELECT account_head_code
   FROM fas_schedulemaster
   WHERE schedule_id = 'A26')


UNION ALL

SELECT 
a.account_head_code,
a.accounting_unit_id,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.receipt_no AS doc_no,
  b.receipt_date AS doc_date,
  'R' AS doc_type,
  a.cr_dr_indicator,
  a.amount,
  a.particulars,
  a.sub_ledger_type_code,
 (select sub_ledger_type_desc from com_mst_sl_types where sub_ledger_type_code=a.sub_ledger_type_code ) as sl_desc,
  a.sub_ledger_code,
  (select sl_codename from sl_type_code_name_view_M where sl_type=a.sub_ledger_type_code and  sl_code=a.sub_ledger_code) as sl_code_desc
  
FROM fas_receipt_transaction a,
  fas_receipt_master b

WHERE a.accounting_unit_id = b.accounting_unit_id
 AND a.accounting_for_office_id = b.accounting_for_office_id
 AND a.cashbook_year = b.cashbook_year
 AND a.cashbook_month = b.cashbook_month
 and a.receipt_no=b.receipt_no
 AND a.accounting_unit_id = $P{accountingunitid}
 AND a.accounting_for_office_id = $P{accountofficeid}
 AND a.cashbook_year = $P{cashbookyear}
 AND a.cashbook_month = $P{cashbookmonth}
 and b.RECEIPT_STATUS='L'  
 AND a.account_head_code IN
  (SELECT account_head_code
   FROM fas_schedulemaster
   WHERE schedule_id = 'A26')
   
  
union all 

select 
a.account_head_code,
   a.accounting_unit_id ,
   a.accounting_for_office_id ,
   a.cashbook_year ,
   a.cashbook_month , 
   a.voucher_no as doc_no, 
   b.voucher_date as doc_date, 
   'J' as doc_type , 
   a.cr_dr_indicator, 
   a.amount,
   a.particulars,
   a.sub_ledger_type_code,
 (select sub_ledger_type_desc from com_mst_sl_types where sub_ledger_type_code=a.sub_ledger_type_code ) as sl_desc,
  a.sub_ledger_code,
  (select sl_codename from sl_type_code_name_view_M where sl_type=a.sub_ledger_type_code and  sl_code=a.sub_ledger_code) as sl_code_desc
  
FROM fas_journal_transaction a,
  fas_journal_master b

WHERE a.accounting_unit_id = b.accounting_unit_id
 AND a.accounting_for_office_id = b.accounting_for_office_id
 AND a.cashbook_year = b.cashbook_year
 AND a.cashbook_month = b.cashbook_month
 and a.voucher_no=b.voucher_no
 AND a.accounting_unit_id = $P{accountingunitid}
 AND a.accounting_for_office_id = $P{accountofficeid}
 AND a.cashbook_year = $P{cashbookyear}
 AND a.cashbook_month = $P{cashbookmonth}
 and b.JOURNAL_STATUS='L' 
 and b.CREATED_BY_MODULE in ('GJV', 'LJV') 
 AND a.account_head_code IN
  (SELECT account_head_code
   FROM fas_schedulemaster
   WHERE schedule_id = 'A26')
   
)  z ,

(
select 
       MONTH_OPENING_BALANCE,
       MONTH_OPENING_BAL_DR_CR_IND ,
       ACCOUNT_HEAD_CODE
       
from 
       FAS_GENERAL_LEDGER 
where 
            ACCOUNTING_UNIT_ID =  $P{accountingunitid}
        and ACCOUNTING_FOR_OFFICE_ID = $P{accountofficeid} 
        and YEAR = $P{cashbookyear} 
        and MONTH = $P{cashbookmonth}
        and ACCOUNT_HEAD_CODE in (select account_head_code from fas_schedulemaster where schedule_id='A26')

) x ,
com_mst_account_heads y,
FAS_MST_ACCT_UNITS j
  
where 
x.account_head_code=z.account_head_code and 
y.account_head_code=x.account_head_code  and 
j.ACCOUNTING_UNIT_ID = z.ACCOUNTING_UNIT_ID 

order by z.account_head_code, z.doc_date , z.doc_type , z.doc_no
)

$P!{reporttype}]]></queryString>

