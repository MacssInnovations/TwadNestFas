	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="schedule" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
a.accounting_unit_id,
a.account_head_code,
to_char(a.OPENING_BALANCE) as OPENING_BALANCE,
a.current_month_debit,a.current_month_credit,
to_char(a.CLOSING_BALANCE) AS CLOSING_BALANCE,
b.account_head_desc,
c.office_name,
d.accounting_unit_name,
a.OPENING_BALANCE_CR_DR_IND,
a.CLOSING_BALANCE_CR_DR_IND,
a.DOCUMENT_TYPE,
a.VOUCHER_NO,
a.DOC_DATE,
a.particulars,
f.SL_TYPE,
f.SL_CODE,
f.SL_CODENAME,
g.SUB_LEDGER_TYPE_DESC
from 
FAS_A35SCHEDULEREPORT_TMP a,
com_mst_account_heads b,
com_mst_offices c,
fas_mst_acct_units d,
FAS_SUB_LEDGER_TRANSACTION e,
SL_TYPE_CODE_NAME_VIEW_M f,
COM_MST_SL_TYPES g

where
a.account_head_code=b.account_head_code and
a.accounting_for_office_id=c.office_id and
a.accounting_unit_id=d.accounting_unit_id and 
a.accounting_unit_id=e.accounting_unit_id and
a.ACCOUNTING_FOR_OFFICE_ID=e.ACCOUNTING_FOR_OFFICE_ID and 
a.CASHBOOK_YEAR=e.YEAR and
a.CASHBOOK_MONTH=e.MONTH and
a.ACCOUNT_HEAD_CODE=e.ACCOUNT_HEAD_CODE and
e.SUB_LEDGER_TYPE_CODE=f.SL_TYPE and 
e.SUB_LEDGER_CODE=f.SL_CODE and
e.SUB_LEDGER_TYPE_CODE=g.SUB_LEDGER_TYPE_CODE and 
a.CASHBOOK_YEAR=e.YEAR and
a.CASHBOOK_MONTH=e.MONTH and
f.SL_TYPE=g.SUB_LEDGER_TYPE_CODE 
and
a.cashbook_month=($P{cashbookmonth}) and a.cashbook_year=($P{cashbookyear}) and a.accounting_unit_id=($P{accountingunitid})
and a.accounting_for_office_id=($P{accountofficeid})
order by a.account_head_code,e.SUB_LEDGER_TYPE_CODE,f.SL_CODE]]></queryString>

