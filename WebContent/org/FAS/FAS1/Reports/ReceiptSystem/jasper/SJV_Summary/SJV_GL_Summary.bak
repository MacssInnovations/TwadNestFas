	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="unitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="supplno" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth_value" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
    acc_code as "ACC_CODE", 
    ( select account_head_desc  from com_mst_account_heads where account_head_code= acc_code ) as "ACC_CODE_DESC",   
    MONTH_OPENING_BALANCE as "MONTH_OPENING_BALANCE",
    MONTH_OPENING_BAL_DR_CR_IND as "MONTH_OPENING_BAL_DR_CR_IND",
    CURRENT_MONTH_DEBIT as "CURRENT_MONTH_DEBIT",
    CURRENT_MONTH_CREDIT as "CURRENT_MONTH_CREDIT",
    MONTH_CLOSING_BALANCE as "MONTH_CLOSING_BALANCE",
    MONTH_CLOSING_BAL_DR_CR_IND as "MONTH_CLOSING_BAL_DR_CR_IND", 
    accounting_unit_name as "ACCOUNTING_UNIT_NAME"
from 
(

SELECT
  ACCOUNT_HEAD_CODE as acc_code,  
  MONTH_OPENING_BALANCE,
  MONTH_OPENING_BAL_DR_CR_IND,
  CURRENT_MONTH_DEBIT,
  CURRENT_MONTH_CREDIT,
  MONTH_CLOSING_BALANCE,
  MONTH_CLOSING_BAL_DR_CR_IND
FROM fas_general_ledger_sjv 
where accounting_unit_id= $P{unitId}::int
and accounting_for_office_id = $P{officeId}::int
and month= $P{cbmonth}::int 
and year= $P{cbyear}::int
and SUPPLEMENT_NO = $P{supplno}::int 
) as opt1, 
(
select accounting_unit_name from fas_mst_acct_units
where accounting_unit_id= $P{unitId}::int
) as opt2
order by acc_code]]></queryString>

	<field name="ACC_CODE" class="java.math.BigDecimal"/>
