	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.receipt_no,a.receipt_date,a.challan_date,a.received_from,(b.account_head_code ||'-'|| c.account_head_desc) as Acc_details ,b.amount,b.particulars,
(b.CHEQUE_OR_DD ||'-'|| b.CHEQUE_DD_NO ||'-'|| to_char(b.CHEQUE_DD_DATE,'DD/MM/YYYY')) as All_details, b.BANK_NAME,b.BANK_MICR_CODE,
d.accounting_unit_name,f.office_short_name from fas_receipt_master a,
fas_receipt_transaction b,com_mst_account_heads c,fas_mst_acct_units d,com_mst_offices f where
a.cashbook_month=b.cashbook_month and a.cashbook_year=b.cashbook_year
and a.accounting_unit_id=b.accounting_unit_id and
a.accounting_for_office_id=b.accounting_for_office_id and
b.account_head_code=c.account_head_code and 
d.accounting_unit_id=a.accounting_unit_id and
a.accounting_for_office_id=f.office_id and
a.receipt_no=b.receipt_no and
a.receipt_status<>'C' and 
a.receipt_type='B' and a.cashbook_year=($P{cashbookyear}) and a.cashbook_month=($P{cashbookmonth}) and
a.accounting_unit_id=($P{accountingunitid}) and a.accounting_for_office_id=($P{accountofficeid})
order by a.receipt_date]]></queryString>

