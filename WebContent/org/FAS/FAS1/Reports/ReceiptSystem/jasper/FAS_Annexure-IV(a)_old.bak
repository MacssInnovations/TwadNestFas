                           fas_journal_master m ,
                           fas_journal_transaction t
                        where 
                           m.accounting_unit_id = t.accounting_unit_id and 
                           m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                           m.cashbook_month = t.cashbook_month and 
                           m.cashbook_year = t.cashbook_year and 
                           m.voucher_no = t.voucher_no and 
                           m.journal_status='L' and 
                           (
                              t.account_head_code=(select demand_raised1 from fas_mst_annexure_iv_a_bf0910 where row_id=2) and cr_dr_indicator=(select demand_raised_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=2) or
                              t.account_head_code=(select demand_raised2 from fas_mst_annexure_iv_a_bf0910 where row_id=2) and cr_dr_indicator=(select demand_raised_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=2) or
                              t.account_head_code=(select water_charges_collection1 from fas_mst_annexure_iv_a_bf0910 where row_id=2) and cr_dr_indicator=(select water_charges_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=2) or
                              t.account_head_code=(select water_charges_collection2 from fas_mst_annexure_iv_a_bf0910 where row_id=2) and cr_dr_indicator=(select water_charges_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=2) 
                           ) and   
                           to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  ($P{from_cashbk_mon} )  || '-' || ($P{from_cashbk_yr}) ,   'mm-yyyy')  AND to_date( ( $P{to_cashbk_mon} ) ||'-' || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
                    union all
                    select 
                          m.accounting_unit_id , 
                          m.accounting_for_office_id , 
                          m.cashbook_month, 
                          m.cashbook_year,     
                          t.account_head_code,
                          t.CR_DR_INDICATOR, 
                          t.amount   
                        from 
                          fas_payment_master m ,
                          fas_payment_transaction t
                        where 
                          m.accounting_unit_id = t.accounting_unit_id and 
                          m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                          m.cashbook_month = t.cashbook_month and 
                          m.cashbook_year = t.cashbook_year and 
                          m.voucher_no = t.voucher_no and 
                          m.payment_status='L' and 
                          (
                              t.account_head_code=(select (case when demand_indicator1='DR' then (select demand_raised1 from fas_mst_annexure_iv_a_bf0910 where row_id=2) else 0 end)as demand1 from
                                                          (select demand_raised_indicator1 as demand_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=2)) or
                              t.account_head_code=(select (case when demand_indicator2='DR' then (select demand_raised2 from fas_mst_annexure_iv_a_bf0910 where row_id=2) else 0 end)as demand2 from
                                                          (select demand_raised_indicator2 as demand_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=2)) or
                              t.account_head_code=(select (case when collection_indicator1='DR' then (select water_charges_collection1 from fas_mst_annexure_iv_a_bf0910 where row_id=2) else 0 end)as collection1 from
                                                          (select water_charges_indicator1 as collection_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=2)) or
                              t.account_head_code=(select (case when collection_indicator2='DR' then (select water_charges_collection2 from fas_mst_annexure_iv_a_bf0910 where row_id=2) else 0 end)as collection2 from
                                                          (select water_charges_indicator2 as collection_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=2))
                          ) and
                          to_date(t.cashbook_month ||'-'|| + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(  ($P{from_cashbk_mon} )  || '-' || ($P{from_cashbk_yr}) ,   'mm-yyyy')  AND to_date( ( $P{to_cashbk_mon} ) ||'-' || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
                    union all
                    select 
                          m.accounting_unit_id , 
                          m.accounting_for_office_id , 
                          m.cashbook_month, 
                          m.cashbook_year,     
                          t.account_head_code,
                          t.CR_DR_INDICATOR, 
                          t.amount   
                        from 
                          fas_receipt_master m ,
                          fas_receipt_transaction t
                        where 
                          m.accounting_unit_id = t.accounting_unit_id and 
                          m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                          m.cashbook_month = t.cashbook_month and 
                          m.cashbook_year = t.cashbook_year and 
                          m.receipt_no = t.receipt_no and 
                          m.receipt_status='L' and 
                          (
                              t.account_head_code=(select (case when demand_indicator1='CR' then (select demand_raised1 from fas_mst_annexure_iv_a_bf0910 where row_id=2) else 0 end)as demand1 from
                                                          (select demand_raised_indicator1 as demand_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=2)) or
                              t.account_head_code=(select (case when demand_indicator2='CR' then (select demand_raised2 from fas_mst_annexure_iv_a_bf0910 where row_id=2) else 0 end)as demand2 from
                                                          (select demand_raised_indicator2 as demand_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=2)) or
                              t.account_head_code=(select (case when collection_indicator1='CR' then (select water_charges_collection1 from fas_mst_annexure_iv_a_bf0910 where row_id=2) else 0 end)as collection1 from
                                                          (select water_charges_indicator1 as collection_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=2)) or
                              t.account_head_code=(select (case when collection_indicator2='CR' then (select water_charges_collection2 from fas_mst_annexure_iv_a_bf0910 where row_id=2) else 0 end)as collection2 from
                                                          (select water_charges_indicator2 as collection_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=2))
                          ) and
                          to_date(t.cashbook_month ||'-'|| + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(  ($P{from_cashbk_mon} )  || '-' || ($P{from_cashbk_yr}) ,   'mm-yyyy')  AND to_date( ( $P{to_cashbk_mon} ) ||'-' || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
