<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="FAS_Annexure-IV(a)_old"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="850"
		 pageHeight="842"
		 columnWidth="790"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="from_cashbk_yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbk_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_cashbk_yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbk_mon" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select row_id,unit_id,(select accounting_unit_name from fas_mst_acct_units where accounting_unit_id=unit_id) as accounting_unit_name, 
achead1,achead2,achead3,achead4,
amt1,amt2,amt3,amt4,(amt3+amt4)as total
from
(
      select a.row_id,unit_id,
        demand_raised1||' '||demand_raised_indicator1 as achead1,demand_raised2||' '||demand_raised_indicator2 as achead2,
        water_charges_collection1||' '||water_charges_indicator1 as achead3,water_charges_collection2||' '||water_charges_indicator2 as achead4,
        sum(amt_achead1) as amt1,sum(amt_achead2) as amt2,sum(amt_achead3) as amt3,sum(amt_achead4) as amt4
      from
      (
        select 
            1 as row_id,
            accounting_unit_id as unit_id ,
            accounting_for_office_id,
            CR_DR_INDICATOR,
            case when ( account_head_code = (select demand_raised1 from fas_mst_annexure_iv_a_bf0910 where row_id=1) and CR_DR_INDICATOR=(select demand_raised_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead1,
            case when ( account_head_code = (select demand_raised2 from fas_mst_annexure_iv_a_bf0910 where row_id=1) and CR_DR_INDICATOR=(select demand_raised_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead2,
            case when ( account_head_code = (select water_charges_collection1 from fas_mst_annexure_iv_a_bf0910 where row_id=1) and CR_DR_INDICATOR=(select water_charges_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead3, 
            case when ( account_head_code = (select water_charges_collection2 from fas_mst_annexure_iv_a_bf0910 where row_id=1) and CR_DR_INDICATOR=(select water_charges_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead4 
        from
        (
                    select 
                           m.accounting_unit_id , 
                           m.accounting_for_office_id , 
                           m.cashbook_month, 
                           m.cashbook_year,     
                           t.account_head_code,
                           t.CR_DR_INDICATOR, 
                           t.amount   
                        from 
                           fas_journal_master m ,
                           fas_journal_transaction t
                        where 
                           m.accounting_unit_id = t.accounting_unit_id and 
                           m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                           m.cashbook_month = t.cashbook_month and 
                           m.cashbook_year = t.cashbook_year and 
                           m.voucher_no = t.voucher_no and 
                           m.journal_status='L' and 
                           (
                              t.account_head_code=(select demand_raised1 from fas_mst_annexure_iv_a_bf0910 where row_id=1) and cr_dr_indicator=(select demand_raised_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=1) or
                              t.account_head_code=(select demand_raised2 from fas_mst_annexure_iv_a_bf0910 where row_id=1) and cr_dr_indicator=(select demand_raised_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=1) or
                              t.account_head_code=(select water_charges_collection1 from fas_mst_annexure_iv_a_bf0910 where row_id=1) and cr_dr_indicator=(select water_charges_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=1) or
                              t.account_head_code=(select water_charges_collection2 from fas_mst_annexure_iv_a_bf0910 where row_id=1) and cr_dr_indicator=(select water_charges_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=1) 
                           ) and   
                           to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  ($P{from_cashbk_mon} )  || '-' || ($P{from_cashbk_yr}) ,   'mm-yyyy')  AND to_date( ( $P{to_cashbk_mon} ) ||'-' || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
                    union all
                    select 
                          m.accounting_unit_id , 
                          m.accounting_for_office_id , 
                          m.cashbook_month, 
                          m.cashbook_year,     
                          t.account_head_code,
                          t.CR_DR_INDICATOR, 
                          t.amount   
                        from 
                          fas_payment_master m ,
                          fas_payment_transaction t
                        where 
                          m.accounting_unit_id = t.accounting_unit_id and 
                          m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                          m.cashbook_month = t.cashbook_month and 
                          m.cashbook_year = t.cashbook_year and 
                          m.voucher_no = t.voucher_no and 
                          m.payment_status='L' and 
                          (
                              t.account_head_code=(select (case when demand_indicator1='DR' then (select demand_raised1 from fas_mst_annexure_iv_a_bf0910 where row_id=1) else 0 end)as demand1 from
                                                          (select demand_raised_indicator1 as demand_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=1)) or
                              t.account_head_code=(select (case when demand_indicator2='DR' then (select demand_raised2 from fas_mst_annexure_iv_a_bf0910 where row_id=1) else 0 end)as demand2 from
                                                          (select demand_raised_indicator2 as demand_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=1)) or
                              t.account_head_code=(select (case when collection_indicator1='DR' then (select water_charges_collection1 from fas_mst_annexure_iv_a_bf0910 where row_id=1) else 0 end)as collection1 from
                                                          (select water_charges_indicator1 as collection_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=1)) or
                              t.account_head_code=(select (case when collection_indicator2='DR' then (select water_charges_collection2 from fas_mst_annexure_iv_a_bf0910 where row_id=1) else 0 end)as collection2 from
                                                          (select water_charges_indicator2 as collection_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=1))
                          ) and
                          to_date(t.cashbook_month ||'-'|| + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(  ($P{from_cashbk_mon} )  || '-' || ($P{from_cashbk_yr}) ,   'mm-yyyy')  AND to_date( ( $P{to_cashbk_mon} ) ||'-' || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
                    union all
                    select 
                          m.accounting_unit_id , 
                          m.accounting_for_office_id , 
                          m.cashbook_month, 
                          m.cashbook_year,     
                          t.account_head_code,
                          t.CR_DR_INDICATOR, 
                          t.amount   
                        from 
                          fas_receipt_master m ,
                          fas_receipt_transaction t
                        where 
                          m.accounting_unit_id = t.accounting_unit_id and 
                          m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                          m.cashbook_month = t.cashbook_month and 
                          m.cashbook_year = t.cashbook_year and 
                          m.receipt_no = t.receipt_no and 
                          m.receipt_status='L' and 
                          (
                              t.account_head_code=(select (case when demand_indicator1='CR' then (select demand_raised1 from fas_mst_annexure_iv_a_bf0910 where row_id=1) else 0 end)as demand1 from
                                                          (select demand_raised_indicator1 as demand_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=1)) or
                              t.account_head_code=(select (case when demand_indicator2='CR' then (select demand_raised2 from fas_mst_annexure_iv_a_bf0910 where row_id=1) else 0 end)as demand2 from
                                                          (select demand_raised_indicator2 as demand_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=1)) or
                              t.account_head_code=(select (case when collection_indicator1='CR' then (select water_charges_collection1 from fas_mst_annexure_iv_a_bf0910 where row_id=1) else 0 end)as collection1 from
                                                          (select water_charges_indicator1 as collection_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=1)) or
                              t.account_head_code=(select (case when collection_indicator2='CR' then (select water_charges_collection2 from fas_mst_annexure_iv_a_bf0910 where row_id=1) else 0 end)as collection2 from
                                                          (select water_charges_indicator2 as collection_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=1))
                          ) and
                          to_date(t.cashbook_month ||'-'|| + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(  ($P{from_cashbk_mon} )  || '-' || ($P{from_cashbk_yr}) ,   'mm-yyyy')  AND to_date( ( $P{to_cashbk_mon} ) ||'-' || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
        )
        group by accounting_unit_id,
                 accounting_for_office_id ,                  
                 account_head_code,
                 CR_DR_INDICATOR order by accounting_unit_id
      )a,
      fas_mst_annexure_iv_a_bf0910 b 
      where a.row_id=b.row_id
      group by a.row_id,
               unit_id,              
               demand_raised1,demand_raised_indicator1,demand_raised2,demand_raised_indicator2,water_charges_collection1,water_charges_indicator1,water_charges_collection2,water_charges_indicator2
      union all
      select a.row_id,unit_id,
        demand_raised1||' '||demand_raised_indicator1 as achead1,demand_raised2||' '||demand_raised_indicator2 as achead2,
        water_charges_collection1||' '||water_charges_indicator1 as achead3,water_charges_collection2||' '||water_charges_indicator2 as achead4,
        sum(amt_achead1) as amt1,sum(amt_achead2) as amt2,sum(amt_achead3) as amt3,sum(amt_achead4) as amt4
      from
      (
        select 
            2 as row_id,
            accounting_unit_id as unit_id ,
            accounting_for_office_id,            
            CR_DR_INDICATOR,
            case when ( account_head_code = (select demand_raised1 from fas_mst_annexure_iv_a_bf0910 where row_id=2) and CR_DR_INDICATOR=(select demand_raised_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead1,
            case when ( account_head_code = (select demand_raised2 from fas_mst_annexure_iv_a_bf0910 where row_id=2) and CR_DR_INDICATOR=(select demand_raised_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead2,
            case when ( account_head_code = (select water_charges_collection1 from fas_mst_annexure_iv_a_bf0910 where row_id=2) and CR_DR_INDICATOR=(select water_charges_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead3, 
            case when ( account_head_code = (select water_charges_collection2 from fas_mst_annexure_iv_a_bf0910 where row_id=2) and CR_DR_INDICATOR=(select water_charges_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead4 
        from
        (
                    select 
                           m.accounting_unit_id , 
                           m.accounting_for_office_id , 
