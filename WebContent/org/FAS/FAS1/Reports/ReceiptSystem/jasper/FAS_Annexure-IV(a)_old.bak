                                                          (select demand_raised_indicator2 as demand_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=5)) or
                              t.account_head_code=(select (case when collection_indicator1='CR' then (select water_charges_collection1 from fas_mst_annexure_iv_a_bf0910 where row_id=5) else 0 end)as collection1 from
                                                          (select water_charges_indicator1 as collection_indicator1 from fas_mst_annexure_iv_a_bf0910 where row_id=5)) or
                              t.account_head_code=(select (case when collection_indicator2='CR' then (select water_charges_collection2 from fas_mst_annexure_iv_a_bf0910 where row_id=5) else 0 end)as collection2 from
                                                          (select water_charges_indicator2 as collection_indicator2 from fas_mst_annexure_iv_a_bf0910 where row_id=5))
                          ) and
                          to_date(t.cashbook_month ||'-'|| + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(  ($P{from_cashbk_mon} )  || '-' || ($P{from_cashbk_yr}) ,   'mm-yyyy')  AND to_date( ( $P{to_cashbk_mon} ) ||'-' || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
        )
        group by accounting_unit_id,
                 accounting_for_office_id , 
                 account_head_code,
                 CR_DR_INDICATOR order by accounting_unit_id
      )a,
      fas_mst_annexure_iv_a_bf0910 b 
      where a.row_id=b.row_id
      group by a.row_id,
               unit_id,
               demand_raised1,demand_raised_indicator1,demand_raised2,demand_raised_indicator2,water_charges_collection1,water_charges_indicator1,water_charges_collection2,water_charges_indicator2               
)
order by row_id,unit_id]]></queryString>

