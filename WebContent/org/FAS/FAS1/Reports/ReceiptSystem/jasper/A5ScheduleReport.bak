	<parameter name="Accounting_unit_id" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="Accounting_forofficeid" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="year" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="monthwords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select 
ISSUE_DATE,
ISSUED_TO_LEVEL_ID,
(select U1.Accounting_Unit_Name FROM Fas_Mst_Acct_Units U1 WHERE U1.ACCOUNTING_UNIT_OFFICE_ID=f.ISSUED_TO_OFFICE) as officeNameIssued,
QTY_ISSUED,
REMARKS,
TDA_ORIGINATING_JVR_NO,
TDA_ORIGINATING_JVR_DATE,
(select f1.ASSET_MAJOR_CLASS_DESC from FAS_MST_ASSETS_CLASS f1 where f1.ASSET_MAJOR_CLASS_CODE=f.ASSET_MAJOR_CLASS_CODE)as AssetMajorClassCodeDesc,
(select f2.PARTICULARS from FAS_ASSET_VAL_AC_DETAILS f2 where f2.ASSET_CODE=f.ASSET_CODE)as AssetCodeDesc,
(SELECT U.Accounting_Unit_Name
  FROM Fas_Mst_Acct_Units U
  WHERE U.Accounting_Unit_Id=f.Accounting_Unit_Id
  ) AS unitName
from FAS_ISSUEOF_ASSETS f where 
f.ACCOUNTING_UNIT_ID=$P{Accounting_unit_id}
AND f.ACCOUNTING_FOR_OFFICE_ID=$P{Accounting_forofficeid}
AND f.CASHBOOK_YEAR=$P{year}
AND f.CASHBOOK_MONTH=$P{month}]]></queryString>

