<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ReportList_Rec"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="to_cashbookyear" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="to_cashbookmonth" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="cmb_unit_name" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT voucher_no as "VOUCHER_NO",
  voucher_date  as "VOUCHER_DATE",
  SUM(cr_amt)               AS "CR_AMT",
  SUM(dr_amt)               AS "DR_AMT",
  SUM(cr_amt) - SUM(dr_amt) AS "DIFF"
from
(SELECT 
      b.receipt_date AS voucher_date,
    
      b.receipt_no AS voucher_no ,
     
      a.CR_DR_INDICATOR,
      CASE
        WHEN a.CR_DR_INDICATOR = 'DR'
        THEN a.amount
        ELSE 0
      END AS dr_amt,
      CASE 
        WHEN a.CR_DR_INDICATOR = 'CR'
        THEN a.amount 
        ELSE 0
      END      AS cr_amt,
      a.amount AS amount
  
     
    FROM fas_receipt_transaction a,
      fas_receipt_master b 
    WHERE a.accounting_unit_id     = b.accounting_unit_id  
    AND a.accounting_for_office_id = b.accounting_for_office_id 
    AND a.cashbook_year            = b.cashbook_year 
    AND a.cashbook_month           = b.cashbook_month 
    AND a.receipt_no               = b.receipt_no     
    AND b.receipt_status          <>'C' 
    and  a.accounting_unit_id::varchar   =$P{accountingunitid}::varchar     
  --AND a.accounting_for_office_id=6869 
  AND a.cashbook_month::varchar           =$P{to_cashbookmonth}::varchar    
  AND a.cashbook_year::varchar           =$P{to_cashbookyear}::varchar

  
  union all
  SELECT 
      b.receipt_date AS datevalue,
     
      b.receipt_no AS voucher_no ,
    
      b.CR_DR_INDICATOR,
      CASE
        WHEN b.CR_DR_INDICATOR = 'DR'
        THEN b.TOTAL_AMOUNT
        ELSE 0
      END AS dr_amt,
      CASE
        WHEN b.CR_DR_INDICATOR = 'CR'
        THEN b.TOTAL_AMOUNT
        ELSE 0
      END            AS cr_amt,
      B.Total_Amount AS Amount
  
    FROM fas_receipt_master b
    WHERE b.receipt_status <>'C'
    
      AND b.accounting_unit_id::varchar        =$P{accountingunitid}::varchar 
  --AND b.accounting_for_office_id=6869
  AND b.cashbook_month::varchar          =$P{to_cashbookmonth}::varchar
  AND b.cashbook_year::varchar           =$P{to_cashbookyear}::varchar ) as fasreprt

   
  GROUP BY voucher_no,
  voucher_date
ORDER BY voucher_no,
  voucher_date]]></queryString>

	<field name="VOUCHER_NO" class="java.math.BigDecimal"/>
	<field name="VOUCHER_DATE" class="java.sql.Date"/>
	<field name="CR_AMT" class="java.math.BigDecimal"/>
	<field name="DR_AMT" class="java.math.BigDecimal"/>
	<field name="DIFF" class="java.math.BigDecimal"/>

	<variable name="tot_cr" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMT}]]></variableExpression>
	</variable>
	<variable name="tot_dr" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>
