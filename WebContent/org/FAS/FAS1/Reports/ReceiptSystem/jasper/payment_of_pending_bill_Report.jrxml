	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="heading" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select (select Uu.Accounting_Unit_Name from fas_mst_acct_units uu
		where Uu.Accounting_Unit_Id=a.Accounting_Unit_Id)as "ORGUNITNAME",a.CASHBOOK_YEAR,a.CASHBOOK_MONTH,b.SL_NO,
		a.PAYMENT_DATE::date as "PAYMENT_DATE",a.VOUCHER_NO as "VOUCHER_NO",b.CHEQUE_DD_NO as "CHEQUE_DD_NO",
b.CHEQUE_DD_DATE::date as "CHEQUE_DD_DATE",
b.AMOUNT as "AMOUNT",a.SUB_LEDGER_TYPE_CODE,
 (select S.Sub_Ledger_Type_Desc from com_mst_sl_types s where s.SUB_LEDGER_TYPE_CODE=A.Sub_Ledger_Type_Code)as "SL_DESC",
  A.Sub_Ledger_Code,
  (select l.SL_CODENAME from SL_TYPE_CODE_NAME_VIEW_M l where L.Sl_Type=A.Sub_Ledger_Type_Code 
   and L.Sl_Code=A.Sub_Ledger_Code)as "CODE_DESC",
b.PAYABLE_VOUCHER_NO as "PAYABLE_VOUCHER_NO",b.PAYABLE_VOUCHER_DATE::date as "PAYABLE_VOUCHER_DATE", a.payable_voucher_type as "PAYABLE_VOUCHER_TYPE",
  b.payable_voucher_slno as "PAYABLE_VOUCHER_SLNO",b.AMOUNT as "LJVAMOUNT" from FAS_PAYMENT_MASTER a
inner join FAS_PAYMENT_TRANSACTION b on A.Accounting_Unit_Id=B.Accounting_Unit_Id
And A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
And A.Cashbook_Year=B.Cashbook_Year
And A.Cashbook_Month=B.Cashbook_Month
and A.Voucher_No=B.Voucher_No
and a.ACCOUNTING_UNIT_ID=$P{unitid}::int and a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}::int
and a.CASHBOOK_MONTH=$P{cashbookmonth}::int and a.CASHBOOK_YEAR=$P{cashbookyear}::int


---and a.ACCOUNTING_UNIT_ID=409 and a.ACCOUNTING_FOR_OFFICE_ID=7358
---and a.CASHBOOK_MONTH=2 and a.CASHBOOK_YEAR=2022
and a.CREATED_BY_MODULE='BPP' and a.PAYMENT_STATUS='L'
AND B.CR_DR_INDICATOR='DR' AND B.SUB_LEDGER_TYPE_CODE !=0
and b.Sub_Ledger_Code!=0
order by b.CHEQUE_DD_NO ,a.VOUCHER_NO,b.PAYABLE_VOUCHER_NO]]></queryString>

