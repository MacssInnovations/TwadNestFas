	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthinwords" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from 

(
select accounting_unit_id from fas_receipt_master  where  RECEIPT_STATUS='L' and 
 cashbook_year=$P{cyear} and cashbook_month=$P{cmonth} group by accounting_unit_id
)a
inner join

(
select accounting_unit_id, sum(amount) as totamount from fas_receipt_transaction 
where account_head_code in (select Account_head_code from fas_st_heads)  
and cashbook_year=$P{cyear} and CASHBOOK_MONTH=$P{cmonth}
group by accounting_unit_id
order by accounting_unit_id
) b
on a.accounting_unit_id=b.accounting_unit_id
left join
( select accounting_unit_name,accounting_unit_id from FAS_MST_ACCT_UNITS order by accounting_unit_id ) c
on a.accounting_unit_id=c.accounting_unit_id]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.lang.Integer"/>
	<field name="TOTAMOUNT" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>

	<variable name="SUM_TOTAMOUNT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAMOUNT}]]></variableExpression>
	</variable>
