<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="TrialBalance_Summary_all_units_including_SJV_Excel"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1048"
		 pageHeight="595"
		 columnWidth="988"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="from_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT Account_Head_Code,
  Debit_Opening_Balance,
  Credit_Opening_Balance,
  Current_Month_Debit,
  Current_Month_Credit,
  Total_Debit,
  Total_Credit,
  (Total_Debit-Total_Credit) AS Net,
  CASE
    WHEN Total_Debit>Total_Credit
    THEN (Total_Debit-Total_Credit)
    ELSE 0
  END AS Debitnet,
  CASE
    WHEN Total_Credit>Total_Debit
    THEN (Total_Credit-Total_Debit)
    ELSE 0
  END AS Creditnet
FROM
  (SELECT Account_Head_Code,
    SUM(Debit_Opening_Balance) AS Debit_Opening_Balance,
    SUM(Credit_Opening_Balance)AS Credit_Opening_Balance,
    SUM(Current_Month_Debit)   AS Current_Month_Debit,
    SUM(Current_Month_Credit)  AS Current_Month_Credit,
    SUM(Total_Debit)           AS Total_Debit,
    SUM(Total_Credit)          AS Total_Credit
  FROM
    (SELECT Account_Head_Code,
      dob AS Debit_Opening_Balance,
      cob AS Credit_Opening_Balance,
      Current_Month_Debit,
      Current_Month_Credit,
      (Dob+Current_Month_Debit)  AS Total_Debit,
      (Cob+Current_Month_Credit) AS Total_Credit
    FROM
      (SELECT C.Account_Head_Code,
        SUM(Debit_Opening_Balance) AS dob,
        SUM(Credit_Opening_Balance)AS cob,
        SUM(Current_Month_Debit)   AS Current_Month_Debit,
        SUM(Current_Month_Credit)  AS Current_Month_Credit
      FROM Fas_Trial_Balance c
      WHERE To_Date((Cashbook_Month
        ||'-'
        || Cashbook_Year),'mm-yyyy') BETWEEN To_Date($P{from_cashbookmonth}
        ||'-'
        ||$P{from_cashbookyear},'mm-yyyy')
      AND to_date($P{to_cashbookmonth}
        ||'-'
        ||$P{to_cashbookyear},'mm-yyyy')
      GROUP BY C.Account_Head_Code
      UNION ALL
      SELECT C.Account_Head_Code,
        SUM(Debit_Opening_Balance) AS dob,
        SUM(Credit_Opening_Balance)AS cob,
        SUM(Current_Month_Debit)   AS Current_Month_Debit,
        SUM(Current_Month_Credit)  AS Current_Month_Credit
      FROM Fas_Trial_Balance_Supplement C
      WHERE Cashbook_Year=$P{to_cashbookyear}
      AND Cashbook_Month =$P{to_cashbookmonth}
      GROUP BY Account_Head_Code
      )
    )
  GROUP BY Account_Head_Code
  ORDER BY Account_Head_Code
  )]]></queryString>

	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="DEBIT_OPENING_BALANCE" class="java.math.BigDecimal"/>
	<field name="CREDIT_OPENING_BALANCE" class="java.math.BigDecimal"/>
	<field name="CURRENT_MONTH_DEBIT" class="java.math.BigDecimal"/>
	<field name="CURRENT_MONTH_CREDIT" class="java.math.BigDecimal"/>
	<field name="TOTAL_DEBIT" class="java.math.BigDecimal"/>
	<field name="TOTAL_CREDIT" class="java.math.BigDecimal"/>
	<field name="NET" class="java.math.BigDecimal"/>
	<field name="DEBITNET" class="java.math.BigDecimal"/>
	<field name="CREDITNET" class="java.math.BigDecimal"/>

	<variable name="sum_Debit_Opening_Balance" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="sum_Credit_Opening_Balance" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="sum_current_month_Debit" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_DEBIT}]]></variableExpression>
	</variable>
	<variable name="sum_current_month_Credit" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_CREDIT}]]></variableExpression>
	</variable>
	<variable name="sum_Debit_Closing_Balance" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBITNET}]]></variableExpression>
	</variable>
	<variable name="sum_Credit_Closing_Balance" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDITNET}]]></variableExpression>
	</variable>
