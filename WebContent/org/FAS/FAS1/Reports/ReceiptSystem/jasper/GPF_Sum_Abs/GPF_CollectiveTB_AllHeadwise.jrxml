<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPF_CollectiveTB_AllHeadwise"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql2" isForPrompting="true" class="java.lang.String"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select * from
(select account_head_code,account_head_des,cashbook_month,
        cashbook_year,
        sum(current_month_debit) as current_month_debit,
        sum(current_month_credit) as current_month_credit,
 
 CASE
      WHEN ( sum(current_month_debit)     - sum(current_month_credit) ) > 0
      THEN NVL(( sum(current_month_debit) - sum(current_month_credit) ),0)
        || ' Dr'
      ELSE NVL(( sum(current_month_credit) - sum(current_month_debit) ),0)
        || ' Cr'
    END                                                   AS curr_net_disp,
    NVL(( sum(current_month_credit) - sum(current_month_debit) ),0) AS curr_net        
        
from 
( 
SELECT  f.account_head_code,
(SELECT m.account_head_desc   
FROM com_mst_account_heads m   
WHERE m.account_head_code = f.account_head_code    ) AS account_head_des,
        cashbook_month,
        cashbook_year,
        current_month_debit,
        current_month_credit
      FROM FAS_TRIAL_BALANCE_CMP f
      WHERE f.account_head_code IN
        ( $P!{sql2} )
      AND accounting_unit_id IN
        (SELECT accounting_unit_id
        FROM fas_trial_balance_status
        WHERE cashbook_month =  $P{cb_mon}
        AND cashbook_year    = $P{cb_year}
        )
      AND cashbook_month=  $P{cb_mon}
      AND cashbook_year = $P{cb_year}
      ORDER BY f.account_head_code)
      
       group by account_head_code,account_head_des,cashbook_month,
        cashbook_year
        order by account_head_code)
        ,
  (SELECT
    CASE
      WHEN (SELECT tb_status
        FROM fas_tb_closure
        WHERE cashbook_year=$P{cb_year}
        AND cashbook_month = $P{cb_mon}
        AND tb_status      ='Y' ) = 'Y'
      THEN ' '
      ELSE 'TENTATIVE FIGURES'
    END AS month_closure_stat
  FROM dual
  )]]></queryString>

