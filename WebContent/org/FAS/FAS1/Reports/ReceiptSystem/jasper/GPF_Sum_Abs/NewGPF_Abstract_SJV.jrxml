<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="NewGPF_Abstract_SJV"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="849"
		 pageHeight="842"
		 columnWidth="789"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql2" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sup_no" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Section" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT *
FROM
  (SELECT year_account_head_code,
    (SELECT account_head_desc
    FROM com_mst_account_heads
    WHERE account_head_code = year_account_head_code
    )             AS account_head_des,
    ( $P!{sql1} ) AS prtgrp,
    year_dr,
    year_cr,
    CASE
      WHEN ( year_dr     - year_cr ) > 0
      THEN NVL(( year_dr - year_cr ),0)
        || ' Dr'
      ELSE NVL(( year_cr - year_dr ),0)
        || ' Cr'
    END                          AS year_net_disp,
    NVL(( year_cr - year_dr ),0) AS year_net,
    NVL(current_month_debit,0)   AS current_month_debit,
    NVL(current_month_credit,0)  AS current_month_credit,
    CASE
      WHEN ( current_month_debit     - current_month_credit ) > 0
      THEN NVL(( current_month_debit - current_month_credit ),0)
        || ' Dr'
      ELSE NVL(( current_month_credit - current_month_debit ),0)
        || ' Cr'
    END                                                   AS curr_net_disp,
    NVL(( current_month_credit - current_month_debit ),0) AS curr_net
  FROM
    (SELECT *
    FROM
      (SELECT account_head_code   AS year_account_head_code,
        SUM(current_month_debit)  AS year_dr,
        SUM(current_month_credit) AS year_cr
      FROM FAS_TRIAL_BALANCE_SJV_CMP
      WHERE to_date(cashbook_month
        ||'-'
        || + cashbook_year, 'mm-yyyy') BETWEEN
        CASE
          WHEN $P{cb_mon} <=3
          THEN to_date( '04'
            || '-'
            || ($P{cb_year}-1) , 'mm-yyyy')
          ELSE to_date( '04'
            || '-'
            || $P{cb_year} , 'mm-yyyy')
        END
      AND to_date ( $P{cb_mon}
        ||'-'
        || $P{cb_year} , 'mm-yyyy')
      AND accounting_unit_id IN
        (SELECT accounting_unit_id
        FROM fas_trial_balance_status
        WHERE to_date(cashbook_month
          ||'-'
          || + cashbook_year, 'mm-yyyy') BETWEEN
          CASE
            WHEN $P{cb_mon} <=3
            THEN to_date( '04'
              || '-'
              || ($P{cb_year}-1) , 'mm-yyyy')
            ELSE to_date( '04'
              || '-'
              || $P{cb_year} , 'mm-yyyy')
          END
        AND to_date ( $P{cb_mon}
          ||'-'
          || $P{cb_year} , 'mm-yyyy')
        )
      AND ACCOUNT_HEAD_CODE        IN ( $P!{sql2} )
      
      AND SUPPLEMENT_NO=$P{sup_no}
      GROUP BY account_head_code
      )a
    LEFT OUTER JOIN
      (SELECT account_head_code,
        SUM(current_month_debit)  AS current_month_debit,
        SUM(current_month_credit) AS current_month_credit
      FROM FAS_TRIAL_BALANCE_SJV_CMP
      WHERE account_head_code IN ( $P!{sql2} )
      AND accounting_unit_id  IN
        (SELECT accounting_unit_id
        FROM fas_trial_balance_status
        WHERE cashbook_month = $P{cb_mon}
        AND cashbook_year    = $P{cb_year}
        )
      AND cashbook_month            = $P{cb_mon}
      AND CASHBOOK_YEAR             = $P{cb_year}
      
      AND SUPPLEMENT_NO=$P{sup_no}
      GROUP BY account_head_code
      ORDER BY account_head_code
      )b
    ON a.year_account_head_code = b.account_head_code
    )
  )
ORDER BY prtgrp,
  year_account_head_code]]></queryString>

