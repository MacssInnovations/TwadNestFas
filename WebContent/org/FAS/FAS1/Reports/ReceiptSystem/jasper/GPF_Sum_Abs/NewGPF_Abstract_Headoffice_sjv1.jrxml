	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql2" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sup_no" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT YEAR_ACCOUNT_HEAD_CODE,
  (SELECT account_head_desc
  FROM com_mst_account_heads
  WHERE account_head_code = year_account_head_code
  )            AS ACCOUNT_HEAD_DES,
  ($P!{sql1} ) AS PRTGRP,
  TOT_MON_DR_UPTO,
  TOT_MON_CR_UPTO,
  YEAR_NET_DISPLAY,
  YEAR_NET,
  YEAR_DR_SJV,
  YEAR_CR_SJV,
  YEAR_NET_DISP,
  CURR_NET,
  CASE
    WHEN ( TOT_MON_DR_UPTO - TOT_MON_CR_UPTO ) > 0
    THEN NVL(NET_CMP_SJV_DEBIT,0)
      || ' Dr'
    ELSE NVL(( NET_CMP_SJV_CREDIT),0)
      || ' Cr'
  END                           AS MON_UPTO_DISP,
  ABS(NVL(NET_CMP_SJV_DEBIT,0)) AS Mon_upto,
  TOTAL_DR,
  TOTAL_CR,
  MONTH_CLOSURE_STAT
FROM
  (SELECT year_account_head_code,
    SUM( COALESCE(TOT_MON_DR_UPTO,0)+COALESCE(CURRENT_MONTH_DEBIT,0))  AS TOT_MON_DR_UPTO,--year_dr,
    SUM( COALESCE(TOT_MON_CR_UPTO,0)+COALESCE(CURRENT_MONTH_CREDIT,0)) AS TOT_MON_CR_UPTO,-- year_cr,
    SUM( (NET_TOT_MON_DR_UPTO)      + (NET_CURRENT_MONTH_DEBIT))       AS NET_CMP_SJV_DEBIT,
    SUM( (NET_TOT_MON_CR_UPTO)      + (NET_CURRENT_MONTH_CREDIT))      AS NET_CMP_SJV_CREDIT,
    CASE
      WHEN ( TOT_MON_DR_UPTO     - TOT_MON_CR_UPTO ) > 0
      THEN NVL(( TOT_MON_DR_UPTO - TOT_MON_CR_UPTO ),0)
        || ' Dr'
      ELSE NVL(( TOT_MON_CR_UPTO - TOT_MON_DR_UPTO ),0)
        || ' Cr'
    END                                          AS YEAR_NET_DISPLAY,
    NVL(( TOT_MON_CR_UPTO - TOT_MON_DR_UPTO ),0) AS YEAR_NET,
    NVL(CURRENT_MONTH_DEBIT,0)                   AS YEAR_DR_SJV, ---current_month_debit,
    NVL(current_month_credit,0)                  AS YEAR_CR_SJV,  --current_month_credit,
    CASE
      WHEN ( current_month_debit     - current_month_credit ) > 0
      THEN NVL(( current_month_debit - current_month_credit ),0)
        || ' Dr'
      ELSE NVL(( current_month_credit - current_month_debit ),0)
        || ' Cr'
    END                                                   AS YEAR_NET_DISP, --YEAR_NET_DISP,--curr_net_disp,
    NVL(( CURRENT_MONTH_CREDIT - CURRENT_MONTH_DEBIT ),0) AS CURR_NET,
    TOTAL_DR,
    total_cr
  FROM
    (SELECT YEAR_ACCOUNT_HEAD_CODE,
      TOT_MON_DR_UPTO,
      TOT_MON_CR_UPTO,
      NVL(( TOT_MON_DR_UPTO - TOT_MON_CR_UPTO ),0) AS NET_TOT_MON_DR_UPTO,
      NVL(( TOT_MON_CR_UPTO - TOT_MON_DR_UPTO ),0) AS NET_TOT_MON_CR_UPTO,
      ACCOUNT_HEAD_CODE,
      CURRENT_MONTH_DEBIT,
      CURRENT_MONTH_CREDIT,
      NVL(( CURRENT_MONTH_DEBIT  - CURRENT_MONTH_CREDIT ),0) AS NET_CURRENT_MONTH_DEBIT ,
      NVL(( CURRENT_MONTH_CREDIT - CURRENT_MONTH_DEBIT ),0)  AS NET_CURRENT_MONTH_CREDIT,
      NVL((TOT_MON_DR_UPTO       +CURRENT_MONTH_DEBIT),0)    AS TOTAL_DR,
      NVL((TOT_MON_CR_UPTO       +CURRENT_MONTH_CREDIT),0)   AS total_cr
    FROM
      (SELECT ACCOUNT_HEAD_CODE   AS YEAR_ACCOUNT_HEAD_CODE,
        SUM(CURRENT_MONTH_DEBIT)  AS TOT_MON_DR_UPTO, --year_dr
        SUM(current_month_credit) AS TOT_MON_CR_UPTO ---year_cr
      FROM FAS_TRIAL_BALANCE_CMP
      WHERE to_date(cashbook_month
        ||'-'
        || cashbook_year, 'mm-yyyy') BETWEEN
        CASE
          WHEN $P{cb_mon} <=3
          THEN to_date( '04'
            || '-'
            || ($P{cb_year}-1) , 'mm-yyyy')
          ELSE to_date( '04'
            || '-'
            || $P{cb_year} , 'mm-yyyy')
        END
      AND to_date ( $P{cb_mon}
        ||'-'
        || $P{cb_year} , 'mm-yyyy')
      AND accounting_unit_id IN
        (SELECT accounting_unit_id
        FROM fas_trial_balance_status
        WHERE to_date(cashbook_month
          ||'-'
          || cashbook_year, 'mm-yyyy') BETWEEN
          CASE
            WHEN $P{cb_mon} <=3
            THEN to_date( '04'
              || '-'
              || ($P{cb_year}-1) , 'mm-yyyy')
            ELSE to_date( '04'
              || '-'
              || $P{cb_year} , 'mm-yyyy')
          END
        AND to_date ( $P{cb_mon}
          ||'-'
          || $P{cb_year} , 'mm-yyyy')
        )
      AND account_head_code IN ($P!{sql2} )
      GROUP BY ACCOUNT_HEAD_CODE
      )A
    LEFT OUTER JOIN
      (SELECT ACCOUNT_HEAD_CODE,
        SUM(current_month_debit)  AS current_month_debit,
        SUM(CURRENT_MONTH_CREDIT) AS CURRENT_MONTH_CREDIT
      FROM FAS_TRIAL_BALANCE_SJV_CMP
      WHERE account_head_code IN ($P!{sql2} )
      AND accounting_unit_id  IN
        (SELECT accounting_unit_id
        FROM FAS_TRIAL_BALANCE_STATUS
        WHERE cashbook_month = $P{cb_mon}
        AND cashbook_year    = $P{cb_year}
        )
      AND cashbook_month = $P{cb_mon}
      AND cashbook_year  = $P{cb_year}
      GROUP BY account_head_code
      ORDER BY account_head_code
      )b
    ON A.YEAR_ACCOUNT_HEAD_CODE = B.ACCOUNT_HEAD_CODE
    )
  GROUP BY YEAR_ACCOUNT_HEAD_CODE,
    CASE
      WHEN ( TOT_MON_DR_UPTO     - TOT_MON_CR_UPTO ) > 0
      THEN NVL(( TOT_MON_DR_UPTO - TOT_MON_CR_UPTO ),0)
        || ' Dr'
      ELSE NVL(( TOT_MON_CR_UPTO - TOT_MON_DR_UPTO ),0)
        || ' Cr'
    END ,
    NVL(( TOT_MON_CR_UPTO - TOT_MON_DR_UPTO ),0),
    NVL(CURRENT_MONTH_DEBIT,0),
    NVL(current_month_credit,0),
    CASE
      WHEN ( current_month_debit     - current_month_credit ) > 0
      THEN NVL(( current_month_debit - current_month_credit ),0)
        || ' Dr'
      ELSE NVL(( current_month_credit - current_month_debit ),0)
        || ' Cr'
    END ,
    NVL(( CURRENT_MONTH_CREDIT - CURRENT_MONTH_DEBIT ),0),
    TOTAL_DR,
    total_cr
  ) ,
  (SELECT
    CASE
      WHEN (SELECT tb_status
        FROM FAS_TB_CLOSURE
        WHERE CASHBOOK_YEAR=$P{cb_year}
        AND cashbook_month = $P{cb_mon}
        AND tb_status      ='Y' ) = 'Y'
      THEN ' '
      ELSE 'TENTATIVE FIGURES'
    END AS month_closure_stat
  FROM dual
  )
ORDER BY PRTGRP,
  YEAR_ACCOUNT_HEAD_CODE]]></queryString>

