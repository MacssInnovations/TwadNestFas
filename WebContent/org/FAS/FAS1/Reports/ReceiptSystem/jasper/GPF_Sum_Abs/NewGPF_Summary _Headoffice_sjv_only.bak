<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="NewGPF_Summary _Headoffice_sjv_only"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="660"
		 pageHeight="842"
		 columnWidth="600"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql2" isForPrompting="true" class="java.lang.String"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sup_no" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select * from
(Select Unitid,
(select U.Accounting_Unit_Name from fas_mst_acct_units u where U.Accounting_Unit_Id=Unitid)as unitName,
Unithead,
(Select V.Account_Head_Desc From Com_Mst_Account_Heads V Where V.Account_Head_Code=Unithead)As Headdesc,
 ( $P!{sql1} ) AS prtgrp,
Ct_Db,Ct_Cr,
Case When Ct_Db>Ct_Cr Then Ct_Net||'DR'
     When Ct_Cr>Ct_Db Then Ct_Net||'CR'
     else Ct_Net||'' end as Ct_Net,
Upto_Cmd,Upto_Cmc,
Case When Upto_Cmd>Upto_Cmc Then Upto_Net||'DR'
      When Upto_Cmc>Upto_Cmd Then Upto_Net||'CR'
      else Upto_Net||'' end as  Upto_Net,
supUnitId,supUnitHead
From
(Select A.Accounting_Unit_Id as supUnitId,A.Account_Head_Code as supUnitHead,
A.ACCOUNT_HEAD_CODE           AS year_account_head_code,
Decode(A.Ct_Db,Null,0,A.Ct_Db)As Ct_Db,Decode(A.Ct_Cr,Null,0,A.Ct_Cr)As Ct_Cr,
Case When Ct_Db>Ct_Cr Then (Decode(A.Ct_Db,Null,0,A.Ct_Db)-Decode(A.Ct_Cr,Null,0,A.Ct_Cr))
      When Ct_Cr>Ct_Db Then (Decode(A.Ct_Cr,Null,0,A.Ct_Cr)-Decode(A.Ct_Db,Null,0,A.Ct_Db))
      Else (Decode(A.Ct_Db,Null,0,A.Ct_Db)-Decode(A.Ct_Cr,Null,0,A.Ct_Cr))
End As Ct_Net,
B.Accounting_Unit_Id as unitid,B.Account_Head_Code as unithead,B.Upto_Cmd,B.Upto_Cmc,
Case When Upto_Cmd>Upto_Cmc Then (Upto_Cmd-Upto_Cmc)
When Upto_Cmd<Upto_Cmc Then (Upto_Cmc-Upto_Cmd)
else 0 end as upto_net
from
(SELECT accounting_unit_id,
        Account_Head_Code,
        Current_Month_Debit As Ct_Db,
        Current_Month_Credit as ct_cr
      From Fas_Trial_Balance_Sjv_Cmp
      Where Cashbook_Year=$P{cb_year} and Cashbook_Month=$P{cb_mon}
    
And Account_Head_Code in ( $P!{sql2})
  And Accounting_Unit_Id In
  (
  Select Accounting_Unit_Id From Fas_Trial_Balance_Status_Sjv Where Cashbook_Year=$P{cb_year}
  )
  And Supplement_No=$P{sup_no}
  )A
  right Outer Join
  (
  Select Accounting_Unit_Id,Account_Head_Code,Sum(Cmd)As upto_Cmd,Sum(Cmc)As upto_Cmc
  from(
  
  SELECT accounting_unit_id,
        Account_Head_Code,
       Sum(Current_Month_Debit)As Cmd,
       Sum(Current_Month_Credit)as cmc
      From Fas_Trial_Balance_Sjv_Cmp
      Where Cashbook_Year=$P{cb_year} and Cashbook_Month=$P{cb_mon}
    
  And Account_Head_Code in ( $P!{sql2})
  And Accounting_Unit_Id In
  (
  Select Accounting_Unit_Id From Fas_Trial_Balance_Status_Sjv Where Cashbook_Year=$P{cb_year}
  )
  And Supplement_No<=$P{sup_no}
 -- And Accounting_Unit_Id=18
  Group By Accounting_Unit_Id,Account_Head_Code
  )Group By Accounting_Unit_Id,account_head_code
  )B
  On A.Accounting_Unit_Id=B.Accounting_Unit_Id
  And A.Account_Head_Code=B.Account_Head_Code
  Order By B.Accounting_Unit_Id,B.Account_Head_Code)),
  (SELECT
    CASE
      WHEN (SELECT tb_status
        From Fas_Tb_Closure
        WHERE cashbook_year=$P{cb_year}
        AND cashbook_month = $P{cb_mon}
        AND tb_status      ='Y' ) = 'Y'
      THEN ' '
      ELSE 'TENTATIVE FIGURES'
    END AS month_closure_stat
  From Dual
  )
  order by Unithead,Unitid]]></queryString>

	<field name="UNITID" class="java.math.BigDecimal"/>
	<field name="UNITNAME" class="java.lang.String"/>
	<field name="UNITHEAD" class="java.math.BigDecimal"/>
	<field name="HEADDESC" class="java.lang.String"/>
	<field name="PRTGRP" class="java.lang.String"/>
	<field name="CT_DB" class="java.math.BigDecimal"/>
	<field name="CT_CR" class="java.math.BigDecimal"/>
	<field name="CT_NET" class="java.lang.String"/>
	<field name="UPTO_CMD" class="java.math.BigDecimal"/>
	<field name="UPTO_CMC" class="java.math.BigDecimal"/>
	<field name="UPTO_NET" class="java.lang.String"/>
	<field name="SUPUNITID" class="java.math.BigDecimal"/>
	<field name="SUPUNITHEAD" class="java.math.BigDecimal"/>
	<field name="MONTH_CLOSURE_STAT" class="java.lang.String"/>

	<variable name="ft_debit" class="java.math.BigDecimal" resetType="Group" resetGroup="account_head_code" calculation="Sum">
		<variableExpression><![CDATA[$F{CT_DB}]]></variableExpression>
	</variable>
	<variable name="ft_credit" class="java.math.BigDecimal" resetType="Group" resetGroup="account_head_code" calculation="Sum">
		<variableExpression><![CDATA[$F{CT_CR}]]></variableExpression>
	</variable>
	<variable name="ft_net" class="java.math.BigDecimal" resetType="None" calculation="Nothing">
		<variableExpression><![CDATA[$V{ft_debit}.subtract($V{ft_credit})]]></variableExpression>
	</variable>
	<variable name="period_debit" class="java.math.BigDecimal" resetType="Group" resetGroup="account_head_code" calculation="Sum">
		<variableExpression><![CDATA[$F{UPTO_CMD}]]></variableExpression>
	</variable>
	<variable name="peroid_credit" class="java.math.BigDecimal" resetType="Group" resetGroup="account_head_code" calculation="Sum">
		<variableExpression><![CDATA[$F{UPTO_CMC}]]></variableExpression>
	</variable>
	<variable name="period_net" class="java.lang.String" resetType="Group" resetGroup="account_head_code" calculation="Sum">
		<variableExpression><![CDATA[$F{UPTO_NET}]]></variableExpression>
	</variable>
	<variable name="ind_ct" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[(($V{ft_debit}.subtract($V{ft_credit})).intValue()<0) ? ($V{ft_credit}.subtract($V{ft_debit}))+"CR" : ($V{ft_debit}.subtract($V{ft_credit}))+"DR"]]></variableExpression>
	</variable>
	<variable name="upto_net_ind" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[(($V{period_debit}.subtract($V{peroid_credit})).intValue()<0) ? ($V{peroid_credit}.subtract($V{period_debit}))+"CR" : ($V{period_debit}.subtract($V{peroid_credit}))+"DR"]]></variableExpression>
	</variable>

