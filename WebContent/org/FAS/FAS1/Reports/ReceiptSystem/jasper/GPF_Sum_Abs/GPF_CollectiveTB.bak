<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPF_CollectiveTB"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="791"
		 pageHeight="842"
		 columnWidth="731"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql2" isForPrompting="true" class="java.lang.String"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select * from 
(
select 
   year_account_head_code, 
   ( select account_head_desc from com_mst_account_heads where account_head_code = year_account_head_code ) as account_head_des,
   ( 
     $P!{sql1}
   ) as prtgrp, 
   
   year_accounting_unit_id,    
   (select trim(ACCOUNTING_UNIT_NAME) from fas_mst_acct_units where accounting_unit_id = year_accounting_unit_id ) as accounting_unit_name, 
   
   year_dr, 
   year_cr,      
   
   case when ( year_dr - year_cr ) > 0 then 
    coalesce(( year_dr - year_cr ),0) || ' Dr'
   else 
    coalesce(( year_cr - year_dr ),0) || ' Cr' 
   end as year_net_disp,   
   
   coalesce(( year_cr - year_dr ),0) as year_net,     

   cashbook_month,
   cashbook_year, 
   
   coalesce(current_month_debit,0) as current_month_debit,
   coalesce(current_month_credit,0) as current_month_credit,
   
   case when ( current_month_debit - current_month_credit ) > 0 then 
    coalesce(( current_month_debit - current_month_credit ),0) || ' Dr'
   else 
    coalesce(( current_month_credit - current_month_debit ),0) || ' Cr' 
   end as curr_net_disp,   
   
   coalesce(( current_month_credit - current_month_debit ),0) as curr_net   
   
from 
(

select * 
from 
(
select 
       account_head_code as year_account_head_code,
       accounting_unit_id as year_accounting_unit_id,              
       sum(current_month_debit) as year_dr,
       sum(current_month_credit) as year_cr    
from FAS_TRIAL_BALANCE_CMP 
where     
 to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') 
 BETWEEN case when $P{cb_mon}::int <=3 then  to_date(  '04' || '-' || ($P{cb_year}::int - 1) ,  'mm-yyyy') else to_date( '04' || '-' || $P{cb_year}::int ,  'mm-yyyy') end 
 AND to_date ( $P{cb_mon}::int ||'-' || $P{cb_year}::int , 'mm-yyyy')
and accounting_unit_id in ( select accounting_unit_id from fas_trial_balance_status where 
                            to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') 
 BETWEEN case when $P{cb_mon}::int <=3 then  to_date(  '04' || '-' || ($P{cb_year}::int - 1) ,  'mm-yyyy') else to_date( '04' || '-' || $P{cb_year}::int ,  'mm-yyyy') end 
 AND to_date ( $P{cb_mon}::int ||'-' || $P{cb_year}::int , 'mm-yyyy')    
 ) 
and account_head_code in ( $P!{sql2} ) 

group by  accounting_unit_id,account_head_code
order by account_head_code
) a

left outer join 

(
 select 
    accounting_unit_id,     
    account_head_code, 
    cashbook_month, 
    cashbook_year, 
    current_month_debit, 
    current_month_credit    
from FAS_TRIAL_BALANCE_CMP 
where 
    account_head_code in ( $P!{sql2} )     
and accounting_unit_id in ( select accounting_unit_id from fas_trial_balance_status where 
                            cashbook_month = $P{cb_mon}::int and cashbook_year = $P{cb_year}::int ) 
and cashbook_month= $P{cb_mon}::int 
and cashbook_year= $P{cb_year}::int


order by account_head_code
) b
 
on  b.account_head_code  = a.year_account_head_code
and b.accounting_unit_id = a.year_accounting_unit_id
)ab

order by year_accounting_unit_id,year_account_head_code
)abdfdd, 

(
  select 
    case when 
      (  select 
                tb_status 
          from fas_tb_closure 
          where cashbook_year=$P{cb_year}::int 
            and cashbook_month = $P{cb_mon}::int
            and tb_status='Y'   
      ) = 'Y' then ' ' else 'TENTATIVE FIGURES' end as month_closure_stat 
  from now() 
)ab]]></queryString>

