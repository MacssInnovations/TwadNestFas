<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPFReport_Summary"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="from_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 
* 
from 
(
select 
   accounting_unit_id, 
   account_head_code, 
   current_month_debit, 
   current_month_credit,      
   case when (CURRENT_MONTH_DEBIT - CURRENT_MONTH_CREDIT)<0 then 
      (CURRENT_MONTH_CREDIT-CURRENT_MONTH_DEBIT)|| '(CR)'
   else 
      (CURRENT_MONTH_DEBIT-CURRENT_MONTH_CREDIT) || '' end  as net,
     (CURRENT_MONTH_DEBIT-CURRENT_MONTH_CREDIT)  as net1        
from 
(
select  
     a.account_head_code,
     a.accounting_unit_id, 
    sum(a.current_month_debit) as current_month_debit, 
    sum(a.current_month_credit) as current_month_credit 
 from 
    FAS_TRIAL_BALANCE a        
 where 
    to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
 and a.account_head_code in ( select account_head_code from fas_ho_gpf) 
 group by a.accounting_unit_id , a.account_head_code 
 order by a.accounting_unit_id, a.account_head_code 
)
) a

left outer join 

( 
   select g.ACCOUNT_HEAD_CODE, g.SECTION , g.PRTGRP from FAS_HO_GPF g 
   
)b 

 on 
 a.account_head_code =b.account_head_code
 left outer join
 (
 select ACCOUNTING_UNIT_ID,ACCOUNTING_UNIT_NAME from FAS_MST_ACCT_UNITS
 ) c
 on a.ACCOUNTING_UNIT_ID=c.ACCOUNTING_UNIT_ID
 left outer join
 (
 select ACCOUNT_HEAD_CODE,ACCOUNT_HEAD_DESC from COM_MST_ACCOUNT_HEADS
 ) d
 on a.ACCOUNT_HEAD_CODE=d.ACCOUNT_HEAD_CODE
 
 
 
 
 left outer join
 
 ( 
      select 
account_head_code, 
net1_dr_cr, 
net1 as snet
from 
(
select 
  account_head_code,
  case when net1<0 then 
    'CR' 
  else 
    'DR'
  end as net1_dr_cr, 
  
  case when net1 >= 0 then 
    net1 
  else 
    net1 * -1 
  end as net1
from 
(

select 
  account_head_code, 
  sum(net1) as net1 
from 
(
select 
   accounting_unit_id, 
   account_head_code, 
   current_month_debit, 
   current_month_credit,      
   case when (CURRENT_MONTH_DEBIT - CURRENT_MONTH_CREDIT)<0 then 
      (CURRENT_MONTH_CREDIT-CURRENT_MONTH_DEBIT)|| '(CR)'
   else 
      (CURRENT_MONTH_DEBIT-CURRENT_MONTH_CREDIT) || '' end  as net,
     (CURRENT_MONTH_DEBIT-CURRENT_MONTH_CREDIT)  as net1        
from 
(
select  
     a.account_head_code,
     a.accounting_unit_id, 
    sum(a.current_month_debit) as current_month_debit, 
    sum(a.current_month_credit) as current_month_credit 
 from 
    FAS_TRIAL_BALANCE a        
 where 
accounting_unit_id= ($P{accountingunitid}) and
      to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
 and a.account_head_code in ( select account_head_code from fas_ho_gpf) 
 group by a.accounting_unit_id , a.account_head_code 
 order by a.accounting_unit_id, a.account_head_code 
)
)
group by account_head_code
)
) 
)e 
on e.account_head_code = a.ACCOUNT_HEAD_CODE
order by account_head_code,accounting_unit_id]]></queryString>

