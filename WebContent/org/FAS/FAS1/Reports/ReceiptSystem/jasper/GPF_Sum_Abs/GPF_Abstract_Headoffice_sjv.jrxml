	</variable>
	<variable name="SUM_YEAR_NET_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{MON_UPTO}]]></variableExpression>
	</variable>
	<variable name="YEAR_NET_DISP" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{YEAR_NET}]]></variableExpression>
	</variable>
	<variable name="SUM_MON(DR)_UPTO" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOT_MON_DR_UPTO}]]></variableExpression>
	</variable>
	<variable name="SUM_MON(CR)_UPTO" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOT_MON_CR_UPTO}]]></variableExpression>
	</variable>
	<variable name="MonthandYear" class="java.lang.String" resetType="Report" calculation="Nothing">
	</variable>
