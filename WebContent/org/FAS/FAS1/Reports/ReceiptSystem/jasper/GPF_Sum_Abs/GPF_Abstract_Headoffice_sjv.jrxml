	<field name="TOTAL_CR" class="java.math.BigDecimal"/>
	<field name="MONTH_CLOSURE_STAT" class="java.lang.String"/>

	<variable name="SUM_CURRENT_MONTH_DEBIT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{YEAR_DR_SJV}]]></variableExpression>
	</variable>
	<variable name="SUM_CURRENT_MONTH_CREDIT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
