<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPF_CollectiveTB_AllHeadwise_sjv"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql2" isForPrompting="true" class="java.lang.String"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sup_no" isForPrompting="false" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT *
FROM
  (SELECT account_head_code,
    account_head_des,
    cashbook_month,
    cashbook_year,
--    current_month_debit,
--    current_month_credit,
--    CASE
--      WHEN (CURRENT_MONTH_DEBIT     - CURRENT_MONTH_CREDIT ) > 0
--      THEN NVL((current_month_debit - current_month_credit ),0)
--        || ' Dr'
--      ELSE NVL(( current_month_credit - current_month_debit ),0)
--        || ' Cr'
--    END                                                  AS CURR_NET_DISP,
--    NVL((current_month_credit - current_month_debit ),0) AS curr_net

sum(current_month_debit) as current_month_debit,
        sum(current_month_credit) as current_month_credit,
 
 CASE
      WHEN ( sum(current_month_debit)     - sum(current_month_credit) ) > 0
      THEN NVL(( sum(current_month_debit) - sum(current_month_credit) ),0)
        || ' Dr'
      ELSE NVL(( sum(current_month_credit) - sum(current_month_debit) ),0)
        || ' Cr'
    END                                                   AS CURR_NET_DISP,
    NVL(( sum(current_month_credit) - sum(current_month_debit) ),0) AS curr_net        
  FROM
    (SELECT year_account_head_code,
      YEAR_ACCOUNTING_UNIT_ID,
      YEAR_DR1,
      YEAR_CR1,
      ACCOUNT_HEAD_CODE,
      ACCOUNTING_UNIT_ID,
      account_head_des,
      cashbook_month,
      CASHBOOK_YEAR,
      CURRENT_MONTH_DEBIT1,
      CURRENT_MONTH_CREDIT1,
      NVL((YEAR_DR1 +CURRENT_MONTH_DEBIT1),0)  AS CURRENT_MONTH_DEBIT,
      NVL((YEAR_CR1 +CURRENT_MONTH_CREDIT1),0) AS CURRENT_MONTH_CREDIT
    FROM
      (SELECT account_head_code   AS year_account_head_code,
        ACCOUNTING_UNIT_ID        AS YEAR_ACCOUNTING_UNIT_ID,
        SUM(CURRENT_MONTH_DEBIT)  AS YEAR_DR1,
        SUM(CURRENT_MONTH_CREDIT) AS YEAR_CR1
      FROM FAS_TRIAL_BALANCE
      WHERE to_date(cashbook_month
        ||'-'
        || + cashbook_year, 'mm-yyyy') BETWEEN
        CASE
          WHEN 3 <=3
          THEN to_date( '04'
            || '-'
            || (2015 - 1) , 'mm-yyyy')
          ELSE to_date( '04'
            || '-'
            || 2015 , 'mm-yyyy')
        END
      AND to_date (3
        ||'-'
        || 2015 , 'mm-yyyy')
      AND accounting_unit_id  IN
        (SELECT accounting_unit_id
        FROM fas_trial_balance_status
        WHERE to_date(cashbook_month
          ||'-'
          || + cashbook_year, 'mm-yyyy') BETWEEN
          CASE
            WHEN 3 <=3
            THEN to_date( '04'
              || '-'
              || (2015 - 1) , 'mm-yyyy')
            ELSE to_date( '04'
              || '-'
              || 2015 , 'mm-yyyy')
          END
        AND to_date (3
          ||'-'
          || 2015 , 'mm-yyyy')
        )
      AND ACCOUNT_HEAD_CODE IN
        ( select account_head_code from com_mst_account_heads
        )
      GROUP BY accounting_unit_id,
        account_head_code
      ORDER BY ACCOUNT_HEAD_CODE
      ) a
    LEFT OUTER JOIN
      (SELECT F.ACCOUNT_HEAD_CODE,
        F.ACCOUNTING_UNIT_ID,
        (SELECT m.account_head_desc
        FROM com_mst_account_heads m
        WHERE m.account_head_code = f.account_head_code
        ) AS account_head_des,
        cashbook_month,
        CASHBOOK_YEAR,
        CURRENT_MONTH_DEBIT  AS CURRENT_MONTH_DEBIT1 ,
        CURRENT_MONTH_CREDIT AS CURRENT_MONTH_CREDIT1
      FROM FAS_TRIAL_BALANCE_SUPPLEMENT f
      WHERE f.account_head_code IN
        (select account_head_code from com_mst_account_heads
        )
      AND accounting_unit_id IN
        (SELECT accounting_unit_id
        FROM fas_trial_balance_status
        WHERE cashbook_month =3
        AND cashbook_year    = 2015
        )
      AND cashbook_month=3
      AND cashbook_year = 2015
      AND SUPPLEMENT_NO =1
      ORDER BY f.account_head_code
      )B
    ON B.ACCOUNT_HEAD_CODE   = A.YEAR_ACCOUNT_HEAD_CODE
    AND b.accounting_unit_id = a.year_accounting_unit_id
    )
    
     GROUP BY ACCOUNT_HEAD_CODE,ACCOUNT_HEAD_DES,CASHBOOK_MONTH,
        cashbook_year
  ORDER BY account_head_code
  ) ,
  (SELECT
    CASE
      WHEN (SELECT tb_status
        FROM fas_tb_closure
        WHERE cashbook_year=2015
        AND cashbook_month =3
        AND tb_status      ='Y' ) = 'Y'
      THEN ' '
      ELSE 'TENTATIVE FIGURES'
    END AS month_closure_stat
  FROM DUAL
  )]]></queryString>

