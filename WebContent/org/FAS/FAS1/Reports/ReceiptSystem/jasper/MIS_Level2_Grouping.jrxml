<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="MIS_Level2_Grouping"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="545"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="20"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="major_head_code" isForPrompting="true" class="java.lang.String"/>
	<parameter name="level2_code" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="level3_code" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="current_from_date" isForPrompting="true" class="java.lang.String"/>
	<parameter name="current_to_date" isForPrompting="true" class="java.lang.String"/>
	<parameter name="previous_from_date" isForPrompting="true" class="java.lang.String"/>
	<parameter name="previous_to_date" isForPrompting="true" class="java.lang.String"/>
	<parameter name="heading" isForPrompting="true" class="java.lang.String"/>
	<parameter name="clmn_heading1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="clmn_heading2" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
    select 
          level3_group_desc,
          fas_ac_head_code,
          account_head_desc,
          sum(current_year_cr)-sum(current_year_dr) as current_yr_amt,
          sum(previous_year_cr)-sum(previous_year_dr) as previous_yr_amt
    from
    (
        select
              level3_group_desc,
              fas_ac_head_code,
              account_head_desc,
              cashbook_month,
              cashbook_year,
              case when(to_date(cashbook_month ||'-'|| + cashbook_year, 'mm-yyyy') BETWEEN to_date($P{current_from_date},'mm-yyyy')  AND to_date($P{current_to_date} , 'mm-yyyy')) then
                         sum(current_month_credit)
                   else
                          0
              end as current_year_cr,
              case when(to_date(cashbook_month ||'-'|| + cashbook_year, 'mm-yyyy') BETWEEN to_date($P{current_from_date},'mm-yyyy')  AND to_date($P{current_to_date} , 'mm-yyyy')) then
                         sum(current_month_debit)
                   else
                          0
              end as current_year_dr,   
              case when(to_date(cashbook_month ||'-'|| + cashbook_year, 'mm-yyyy') BETWEEN to_date($P{previous_from_date},'mm-yyyy')  AND to_date($P{previous_to_date} , 'mm-yyyy')) then
                         sum(current_month_credit)
                   else
                          0
              end as previous_year_cr,
              case when(to_date(cashbook_month ||'-'|| + cashbook_year, 'mm-yyyy') BETWEEN to_date($P{previous_from_date},'mm-yyyy')  AND to_date($P{previous_to_date} , 'mm-yyyy')) then
                         sum(current_month_debit)
                   else
                          0
              end as previous_year_dr
        from
        (
            select
                  level3_group_desc,
                  fas_ac_head_code,
                  account_head_desc,
                  cashbook_year,
                  cashbook_month,
                  current_month_credit,
                  current_month_debit
            from
                  v_fas_mis_monthly_grouping a,
                  fas_trial_balance b
            where
                  a.fas_ac_head_code=b.account_head_code and
                  major_head_code=$P{major_head_code} and
                  grouping_level2_id=$P{level2_code} and
                  grouping_level3_id=$P{level3_code} and
                  (
                      to_date(cashbook_month ||'-'|| + cashbook_year, 'mm-yyyy') BETWEEN to_date($P{current_from_date},'mm-yyyy')  AND to_date($P{current_to_date} , 'mm-yyyy') or
                      to_date(cashbook_month ||'-'|| + cashbook_year, 'mm-yyyy') BETWEEN to_date($P{previous_from_date},'mm-yyyy')  AND to_date($P{previous_to_date} , 'mm-yyyy')
                  )
        )     
        group by
               level3_group_desc,
               fas_ac_head_code,
               account_head_desc,
               cashbook_year,
               cashbook_month
    )
    group by
            level3_group_desc,
            fas_ac_head_code,
            account_head_desc
)
where 
    current_yr_amt!=0 and 
    previous_yr_amt!=0
    
order by
        fas_ac_head_code]]></queryString>

	<field name="LEVEL3_GROUP_DESC" class="java.lang.String"/>
	<field name="FAS_AC_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="CURRENT_YR_AMT" class="java.math.BigDecimal"/>
	<field name="PREVIOUS_YR_AMT" class="java.math.BigDecimal"/>

	<variable name="previous_yr_total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{PREVIOUS_YR_AMT}]]></variableExpression>
	</variable>
	<variable name="current_yr_total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_YR_AMT}]]></variableExpression>
	</variable>
