<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ListOfReportAccountWise_withDate"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="814"
		 columnSpacing="0"
		 leftMargin="14"
		 rightMargin="14"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[(SELECT DECODE(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque 
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme 
Owner',13,'Beneficiary','-') AS sub_ledger_type_code,
  d.ACCOUNT_HEAD_DESC,
  c.office_name,
  b.paid_to,
  a.sub_ledger_type_code,
  (SELECT sl_codeName
  FROM SL_TYPE_CODE_NAME_VIEW_M
  WHERE sl_type=a.sub_ledger_type_code
  AND sl_code  =a.SUB_LEDGER_CODE
  )              AS slcode,
  b.payment_date AS datevalue,
  d.ACCOUNT_HEAD_CODE,
  b.voucher_no      AS voucher_no,
  'P'               AS document_type,
  a.amount AS amount,
  a.CR_DR_INDICATOR,
  a.particulars
FROM fas_payment_transaction a,
  fas_payment_master b,
  COM_MST_OFFICES c,
  COM_MST_ACCOUNT_HEADS d
WHERE a.accounting_unit_id     = b.accounting_unit_id
AND a.accounting_for_office_id = b.accounting_for_office_id
AND a.cashbook_year            = b.cashbook_year
AND a.cashbook_month           = b.cashbook_month
AND a.voucher_no               = b.voucher_no
AND b.payment_status          <>'C'
AND a.accounting_unit_id       = $P{accountingunitid}
AND a.accounting_for_office_id = $P{accountofficeid}
AND a.ACCOUNT_HEAD_CODE        =$P{accountheadcode}
AND c.office_id                =a.accounting_for_office_id
AND a.ACCOUNT_HEAD_CODE        =d.account_head_code
AND b.payment_date BETWEEN $P{txtfrom} AND $P{txtto}
)
UNION ALL
  (SELECT DECODE(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque 
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme 
Owner',13,'Beneficiary','-')AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    b.received_from,
    a.sub_ledger_type_code,
    (SELECT sl_codeName
    FROM SL_TYPE_CODE_NAME_VIEW_M
    WHERE sl_type=a.sub_ledger_type_code
    AND sl_code  =a.SUB_LEDGER_CODE
    )              AS slcode,
    b.receipt_date AS datevalue,
    d.ACCOUNT_HEAD_CODE,
    b.receipt_no AS voucher_no ,
    'R',
    a.amount AS amount,
    a.CR_DR_INDICATOR,
    a.particulars
  FROM fas_receipt_transaction a,
    fas_receipt_master b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d
  WHERE a.accounting_unit_id     = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.receipt_no               = b.receipt_no
  AND b.receipt_status          <>'C'
  AND a.accounting_unit_id       = $P{accountingunitid}
  AND a.accounting_for_office_id = $P{accountofficeid}
  AND a.ACCOUNT_HEAD_CODE        =$P{accountheadcode}
  AND c.office_id                =a.accounting_for_office_id
  AND a.ACCOUNT_HEAD_CODE        =d.account_head_code
  AND b.receipt_date BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
  (SELECT DECODE(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque 
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme 
Owner',13,'Beneficiary','-')AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    ' ',
    a.sub_ledger_type_code,
    (SELECT sl_codeName
    FROM SL_TYPE_CODE_NAME_VIEW_M
    WHERE sl_type=a.sub_ledger_type_code
    AND sl_code  =a.SUB_LEDGER_CODE
    )              AS slcode,
    b.voucher_date AS datevalue,
    d.ACCOUNT_HEAD_CODE,
    b.voucher_no      AS voucher_no ,
    'J'               AS document_type,
    a.amount AS amount,
    a.CR_DR_INDICATOR,
    a.particulars
  FROM fas_journal_transaction a,
    fas_journal_master b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d
  WHERE a.accounting_unit_id     =b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.voucher_no               = b.voucher_no
  AND b.journal_status          <>'C'
  AND a.accounting_unit_id       =$P{accountingunitid}
  AND a.accounting_for_office_id =$P{accountofficeid}
  AND a.ACCOUNT_HEAD_CODE        =$P{accountheadcode}
  AND c.office_id                =a.accounting_for_office_id
  AND a.ACCOUNT_HEAD_CODE        =d.account_head_code
  AND b.voucher_date BETWEEN $P{txtfrom} AND $P{txtto}
  )
ORDER BY datevalue,
  voucher_no]]></queryString>

	<field name="SUB_LEDGER_TYPE_CODE" class="java.lang.String"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="PAID_TO" class="java.lang.String"/>
	<field name="SLCODE" class="java.lang.String"/>
	<field name="DATEVALUE" class="java.sql.Timestamp"/>
	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="VOUCHER_NO" class="java.math.BigDecimal"/>
	<field name="DOCUMENT_TYPE" class="java.lang.String"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>
	<field name="CR_DR_INDICATOR" class="java.lang.String"/>
	<field name="PARTICULARS" class="java.lang.String"/>

	<variable name="SUM_AMOUNT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="accounthead" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="crsum" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[new BigDecimal($F{CR_DR_INDICATOR}.equalsIgnoreCase("CR")?($F{AMOUNT}.doubleValue()):0)]]></variableExpression>
	</variable>
	<variable name="drsum" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[new BigDecimal($F{CR_DR_INDICATOR}.equalsIgnoreCase("DR")?($F{AMOUNT}.doubleValue()):0)]]></variableExpression>
	</variable>

