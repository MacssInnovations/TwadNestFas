<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="AccountNo_Wise_Report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="700"
		 pageHeight="595"
		 columnWidth="700"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[SELECT m.account_no,
   (SELECT
    bk.BANK_NAME
  FROM FAS_MST_BANKS bk
  WHERE bk.BANK_ID=m.bank_id
  ) AS bank_name,
    (SELECT
    br.branch_name
  FROM fas_mst_bank_branches br
  WHERE br.bank_id=m.bank_id
  AND BRANCH_ID   =m.branch_id
  )            AS branch_name,
  m.account_no AS acc_no,
  M.CASHBOOK_YEAR,
  m.cashbook_month,
  m.receipt_no,
  TO_CHAR(m.receipt_date,'dd/mm/yyyy') AS receipt_date,
  t.amount
FROM fas_receipt_master m,
  fas_receipt_transaction t
WHERE m.accounting_unit_id    =t.accounting_unit_id
AND m.accounting_for_office_id=t.accounting_for_office_id
AND m.cashbook_year           =t.cashbook_year
AND m.cashbook_month          =t.cashbook_month
AND m.receipt_no              =t.receipt_no
AND m.receipt_status!         ='C'
AND To_Date((m.Cashbook_Month
  ||'-'
  || m.Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
  ||'-'
  ||2017,'mm-yyyy')
AND to_date(3
  ||'-'
  ||2018,'mm-yyyy')
AND m.accounting_unit_id      =5
AND m.accounting_for_office_id=5000
AND t.account_head_code       =120201
ORDER BY m.account_no,
  M.CASHBOOK_YEAR,
  m.cashbook_month]]></queryString>

	<field name="ACCOUNT_NO" class="java.math.BigDecimal"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="BRANCH_NAME" class="java.lang.String"/>
	<field name="ACC_NO" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="RECEIPT_NO" class="java.math.BigDecimal"/>
	<field name="RECEIPT_DATE" class="java.lang.String"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>

	<variable name="Sum_Amt" class="java.math.BigDecimal" resetType="Group" resetGroup="Account_No_Wise" calculation="Sum">
