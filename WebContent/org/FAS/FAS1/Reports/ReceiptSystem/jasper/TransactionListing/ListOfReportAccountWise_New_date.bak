<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ListOfReportAccountWise_New_date"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="814"
		 columnSpacing="0"
		 leftMargin="14"
		 rightMargin="14"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.String"/>
	<parameter name="PDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="RDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="VDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="DATEWISE" isForPrompting="true" class="java.lang.String"/>
	<parameter name="craccountheadcode" isForPrompting="true" class="java.lang.String"/>
	<parameter name="draccountheadcode" isForPrompting="true" class="java.lang.String"/>
	<parameter name="IBTDATEWISE" isForPrompting="true" class="java.lang.String"/>
	<parameter name="IBTDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fundTrfDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthWise" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountheadcode1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="craccountheadcode1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="draccountheadcode1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fromDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="toDate" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select distinct     
    sub_ledger_type_code_desc,
    accounting_unit_name,
    account_head_code,
    account_head_desc,
    office_name,
    paid_received,
    slcode,
    datevalue,
    voucher_no,
    document_type,
    cr_dr_indicator,
    dr_amt,
    cr_amt,
    amt,
    particulars 
from 
(

-- Payment Transactions (Original)
SELECT 
      CASE A.SUB_LEDGER_TYPE_CODE
        WHEN 1 THEN 'Supplier'
        WHEN 2 THEN 'Firms'
        WHEN 3 THEN 'Assets'
        WHEN 4 THEN 'ChequeBooks'
        WHEN 5 THEN 'Offices'
        WHEN 6 THEN 'Bank'
        WHEN 7 THEN 'Employees'
        WHEN 8 THEN '-'
        WHEN 9 THEN 'OtherDepartments'
        WHEN 10 THEN 'Project'
        WHEN 11 THEN 'Contractors'
        WHEN 12 THEN 'Scheme Owner'
        WHEN 13 THEN 'Beneficiary'
        WHEN 14 THEN 'DCB-Beneficiary'
        WHEN 15 THEN 'Accounting Units'
        WHEN 16 THEN 'Scheme Type'
        WHEN 17 THEN 'Miscellaneous'
        WHEN 18 THEN 'Pensioners'
        WHEN 19 THEN 'Family Pensioner'
        WHEN 20 THEN 'IMIS-SA-CCDU'
        WHEN 21 THEN 'IMIS-SA-MIS'
        WHEN 22 THEN 'IMIS-SA-GIS'
        WHEN 23 THEN 'IMIS-SA-R and D'
        WHEN 24 THEN 'IMIS-SA-M and I'
        WHEN 25 THEN 'Special PF Payments'
        WHEN 26 THEN 'Work In Progress'
        WHEN 27 THEN 'IMIS-SA-WQMS'
        WHEN 28 THEN 'One Day Salary Contribution'
        ELSE '-'
    END AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    b.paid_to as paid_received,
    (select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M 
     where sl_type=a.sub_ledger_type_code and sl_code=a.SUB_LEDGER_CODE) as slcode,
    b.payment_date AS datevalue,
    b.voucher_no as voucher_no,
    'P' AS document_type,
    a.cr_dr_indicator,
    case when a.cr_dr_indicator = 'DR' then a.amount else 0 END as dr_amt,
    case when a.cr_dr_indicator = 'CR' then a.amount else 0 END as cr_amt,
    a.amount as amt,
    a.particulars 
FROM fas_payment_transaction a,
     fas_payment_master b,
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f
WHERE a.accounting_unit_id = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id 
  AND a.cashbook_year = b.cashbook_year
  AND a.cashbook_month = b.cashbook_month 
  AND a.voucher_no = b.voucher_no 
  AND b.payment_status <> 'C' 
  AND to_date(b.cashbook_year || '-' || b.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int 
  AND a.accounting_for_office_id = $P{accountofficeid}::int and
   $P!{accountheadcode}
   c.office_id = a.accounting_for_office_id 
  AND A.ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE 
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id

UNION ALL 

-- Receipt Transactions
SELECT 
      CASE A.SUB_LEDGER_TYPE_CODE
        WHEN 1 THEN 'Supplier'
        WHEN 2 THEN 'Firms'
        WHEN 3 THEN 'Assets'
        WHEN 4 THEN 'ChequeBooks'
        WHEN 5 THEN 'Offices'
        WHEN 6 THEN 'Bank'
        WHEN 7 THEN 'Employees'
        WHEN 8 THEN '-'
        WHEN 9 THEN 'OtherDepartments'
        WHEN 10 THEN 'Project'
        WHEN 11 THEN 'Contractors'
        WHEN 12 THEN 'Scheme Owner'
        WHEN 13 THEN 'Beneficiary'
        WHEN 14 THEN 'DCB-Beneficiary'
        WHEN 15 THEN 'Accounting Units'
        WHEN 16 THEN 'Scheme Type'
        WHEN 17 THEN 'Miscellaneous'
        WHEN 18 THEN 'Pensioners'
        WHEN 19 THEN 'Family Pensioner'
        WHEN 20 THEN 'IMIS-SA-CCDU'
        WHEN 21 THEN 'IMIS-SA-MIS'
        WHEN 22 THEN 'IMIS-SA-GIS'
        WHEN 23 THEN 'IMIS-SA-R and D'
        WHEN 24 THEN 'IMIS-SA-M and I'
        WHEN 25 THEN 'Special PF Payments'
        WHEN 26 THEN 'Work In Progress'
        WHEN 27 THEN 'IMIS-SA-WQMS'
        WHEN 28 THEN 'One Day Salary Contribution'
        ELSE '-'
    END AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    b.received_from as paid_received,
    (select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M 
     where sl_type=a.sub_ledger_type_code and sl_code=a.SUB_LEDGER_CODE) as slcode,
    b.receipt_date AS datevalue,
    b.receipt_no as voucher_no,
    'R' as document_type,
    a.cr_dr_indicator,
    case when a.cr_dr_indicator = 'DR' then a.amount else 0 END as dr_amt,
    case when a.cr_dr_indicator = 'CR' then a.amount else 0 END as cr_amt,
    a.amount as amt,
    a.particulars 
FROM fas_receipt_transaction a,
     fas_receipt_master b,
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f 
WHERE a.accounting_unit_id = b.accounting_unit_id 
  AND a.accounting_for_office_id = b.accounting_for_office_id  
  AND a.cashbook_year = b.cashbook_year
  AND a.cashbook_month = b.cashbook_month 
  AND a.receipt_no = b.receipt_no
  AND b.receipt_status <> 'C'
  AND to_date(b.cashbook_year || '-' || b.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int
  AND a.accounting_for_office_id = $P{accountofficeid}::int  and 
   $P!{accountheadcode}
   c.office_id = a.accounting_for_office_id
  AND A.ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE 
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id

UNION ALL 

-- Journal Transactions
SELECT 
    CASE A.SUB_LEDGER_TYPE_CODE
        WHEN 1 THEN 'Supplier'
        WHEN 2 THEN 'Firms'
        WHEN 3 THEN 'Assets'
        WHEN 4 THEN 'ChequeBooks'
        WHEN 5 THEN 'Offices'
        WHEN 6 THEN 'Bank'
        WHEN 7 THEN 'Employees'
        WHEN 8 THEN '-'
        WHEN 9 THEN 'OtherDepartments'
        WHEN 10 THEN 'Project'
        WHEN 11 THEN 'Contractors'
        WHEN 12 THEN 'Scheme Owner'
        WHEN 13 THEN 'Beneficiary'
        WHEN 14 THEN 'DCB-Beneficiary'
        WHEN 15 THEN 'Accounting Units'
        WHEN 16 THEN 'Scheme Type'
        WHEN 17 THEN 'Miscellaneous'
        WHEN 18 THEN 'Pensioners'
        WHEN 19 THEN 'Family Pensioner'
        WHEN 20 THEN 'IMIS-SA-CCDU'
        WHEN 21 THEN 'IMIS-SA-MIS'
        WHEN 22 THEN 'IMIS-SA-GIS'
        WHEN 23 THEN 'IMIS-SA-R and D'
        WHEN 24 THEN 'IMIS-SA-M and I'
        WHEN 25 THEN 'Special PF Payments'
        WHEN 26 THEN 'Work In Progress'
        WHEN 27 THEN 'IMIS-SA-WQMS'
        WHEN 28 THEN 'One Day Salary Contribution'
        ELSE '-'
    END AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    ' ' as paid_received,
    (select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M 
     where sl_type=a.sub_ledger_type_code and sl_code=a.SUB_LEDGER_CODE) as slcode,
    b.voucher_date AS datevalue,
    b.voucher_no as voucher_no,
    'J' AS document_type,
    a.cr_dr_indicator,
    case when a.cr_dr_indicator = 'DR' then a.amount else 0 END as dr_amt,
    case when a.cr_dr_indicator = 'CR' then a.amount else 0 END as cr_amt,
    a.amount as amt,
    a.particulars 
FROM fas_journal_transaction a,
     fas_journal_master b,
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f 
WHERE a.accounting_unit_id = b.accounting_unit_id 
  AND a.accounting_for_office_id = b.accounting_for_office_id 
  AND a.cashbook_year = b.cashbook_year
  AND a.cashbook_month = b.cashbook_month  
  AND a.voucher_no = b.voucher_no  
  AND b.journal_status <> 'C' 
  AND to_date(b.cashbook_year || '-' || b.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int
  AND a.accounting_for_office_id = $P{accountofficeid}::int and 
   $P!{accountheadcode}
   C.OFFICE_ID = A.ACCOUNTING_FOR_OFFICE_ID 
  AND A.ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id
	
		union all 
	
	SELECT 
      CASE b.SUB_LEDGER_TYPE_CODE
        WHEN 1 THEN 'Supplier'
        WHEN 2 THEN 'Firms'
        WHEN 3 THEN 'Assets'
        WHEN 4 THEN 'ChequeBooks'
        WHEN 5 THEN 'Offices'
        WHEN 6 THEN 'Bank'
        WHEN 7 THEN 'Employees'
        WHEN 8 THEN '-'
        WHEN 9 THEN 'OtherDepartments'
        WHEN 10 THEN 'Project'
        WHEN 11 THEN 'Contractors'
        WHEN 12 THEN 'Scheme Owner'
        WHEN 13 THEN 'Beneficiary'
        WHEN 14 THEN 'DCB-Beneficiary'
        WHEN 15 THEN 'Accounting Units'
        WHEN 16 THEN 'Scheme Type'
        WHEN 17 THEN 'Miscellaneous'
        WHEN 18 THEN 'Pensioners'
        WHEN 19 THEN 'Family Pensioner'
        WHEN 20 THEN 'IMIS-SA-CCDU'
        WHEN 21 THEN 'IMIS-SA-MIS'
        WHEN 22 THEN 'IMIS-SA-GIS'
        WHEN 23 THEN 'IMIS-SA-R and D'
        WHEN 24 THEN 'IMIS-SA-M and I'
        WHEN 25 THEN 'Special PF Payments'
        WHEN 26 THEN 'Work In Progress'
        WHEN 27 THEN 'IMIS-SA-WQMS'
        WHEN 28 THEN 'One Day Salary Contribution'
        ELSE '-'
    END AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    b.paid_to as paid_received,
    (select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M 
     where sl_type=b.sub_ledger_type_code and sl_code=b.SUB_LEDGER_CODE) as slcode,
    b.payment_date AS datevalue,
    b.voucher_no as voucher_no,
    'P' AS document_type,
    b.cr_dr_indicator,
    case when b.cr_dr_indicator = 'DR' then b.total_amount else 0 END as dr_amt,
    case when b.cr_dr_indicator = 'CR' then  b.total_amount else 0 END as cr_amt,
    b.total_amount as amt,
    b.remarks as particulars 
FROM (select voucher_no,accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_head_code,sub_ledger_type_code,SUB_LEDGER_CODE,cr_dr_indicator from fas_payment_transaction group by voucher_no,accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_head_code,sub_ledger_type_code,SUB_LEDGER_CODE,cr_dr_indicator ) a,
     fas_payment_master b,
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f
WHERE a.accounting_unit_id = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id 
  AND a.cashbook_year = b.cashbook_year
  AND a.cashbook_month = b.cashbook_month 
  AND a.voucher_no = b.voucher_no 
	and a.account_head_code !=b.account_head_code
  AND b.payment_status <> 'C' 
   AND to_date(a.cashbook_year || '-' || a.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int 
  AND a.accounting_for_office_id = $P{accountofficeid}::int  and 
   $P!{draccountheadcode}
   
   c.office_id = a.accounting_for_office_id 
  AND B.ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE 
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id

UNION ALL 

-- Receipt Transactions
SELECT 
       CASE b.SUB_LEDGER_TYPE_CODE
        WHEN 1 THEN 'Supplier'
        WHEN 2 THEN 'Firms'
        WHEN 3 THEN 'Assets'
        WHEN 4 THEN 'ChequeBooks'
        WHEN 5 THEN 'Offices'
        WHEN 6 THEN 'Bank'
        WHEN 7 THEN 'Employees'
        WHEN 8 THEN '-'
        WHEN 9 THEN 'OtherDepartments'
        WHEN 10 THEN 'Project'
        WHEN 11 THEN 'Contractors'
        WHEN 12 THEN 'Scheme Owner'
        WHEN 13 THEN 'Beneficiary'
        WHEN 14 THEN 'DCB-Beneficiary'
        WHEN 15 THEN 'Accounting Units'
        WHEN 16 THEN 'Scheme Type'
        WHEN 17 THEN 'Miscellaneous'
        WHEN 18 THEN 'Pensioners'
        WHEN 19 THEN 'Family Pensioner'
        WHEN 20 THEN 'IMIS-SA-CCDU'
        WHEN 21 THEN 'IMIS-SA-MIS'
        WHEN 22 THEN 'IMIS-SA-GIS'
        WHEN 23 THEN 'IMIS-SA-R and D'
        WHEN 24 THEN 'IMIS-SA-M and I'
        WHEN 25 THEN 'Special PF Payments'
        WHEN 26 THEN 'Work In Progress'
        WHEN 27 THEN 'IMIS-SA-WQMS'
        WHEN 28 THEN 'One Day Salary Contribution'
        ELSE '-'
    END AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    b.received_from as paid_received,
    (select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M 
     where sl_type=b.sub_ledger_type_code and sl_code=b.SUB_LEDGER_CODE) as slcode,
    b.receipt_date AS datevalue,
    b.receipt_no as voucher_no,
    'R' as document_type,
    a.cr_dr_indicator,
    case when b.cr_dr_indicator = 'DR' then b.total_amount else 0 END as dr_amt,
    case when b.cr_dr_indicator = 'CR' then b.total_amount else 0 END as cr_amt,
    b.total_amount as amt,
    b.remarks as particulars 
FROM (select receipt_no,accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_head_code,sub_ledger_type_code,SUB_LEDGER_CODE,cr_dr_indicator from fas_receipt_transaction group by voucher_no,accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_head_code,sub_ledger_type_code,SUB_LEDGER_CODE,cr_dr_indicator ) a,
     fas_receipt_master b,
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f 
WHERE a.accounting_unit_id = b.accounting_unit_id 
  AND a.accounting_for_office_id = b.accounting_for_office_id  
  AND a.cashbook_year = b.cashbook_year
  AND a.cashbook_month = b.cashbook_month 
  AND a.receipt_no = b.receipt_no
	and a.account_head_code !=b.account_head_code 
  AND b.receipt_status <> 'C'
   AND to_date(a.cashbook_year || '-' || a.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int 
  AND a.accounting_for_office_id = $P{accountofficeid}::int  and 
   $P!{draccountheadcode}
   
   c.office_id = a.accounting_for_office_id
  AND B.ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE 
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id

UNION ALL 

-- Fund Receipt (CR side)
SELECT 
    '' AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' as paid_received,
    '' as slcode,
    a.RECEIPT_DATE AS datevalue,
    a.RECEIPT_NO as voucher_no,
    'FR' as document_type,
    'CR' as cr_dr_indicator, 
    0 as dr_amt, 
    a.total_amount as cr_amt,    
    a.TOTAL_AMOUNT as amt,
    a.PARTICULARS  
FROM FAS_FUND_RECEIPT_BY_OFFICE a,
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f 
WHERE a.receipt_status <> 'C' 
  AND to_date(a.cashbook_year || '-' || a.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int 
  AND a.accounting_for_office_id = $P{accountofficeid}::int  and 
   $P!{craccountheadcode}
   c.office_id = a.accounting_for_office_id 
  AND A.CR_ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE 
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id

UNION ALL 

-- Fund Receipt (DR side)
SELECT 
    '' AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' as paid_received,
    '' as slcode,
    a.RECEIPT_DATE AS datevalue,
    a.RECEIPT_NO as voucher_no,
    'FR' as document_type,
    'DR' as cr_dr_indicator, 
    a.total_amount as dr_amt, 
    0 as cr_amt,    
    a.TOTAL_AMOUNT as amt,
    a.PARTICULARS  
FROM FAS_FUND_RECEIPT_BY_OFFICE a,
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f 
WHERE a.receipt_status <> 'C' 
  AND to_date(a.cashbook_year || '-' || a.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int 
  AND a.accounting_for_office_id = $P{accountofficeid}::int  and 
   $P!{draccountheadcode}
   c.office_id = a.accounting_for_office_id 
  AND A.DR_ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE 
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id

UNION ALL 

-- Fund Transfer (DR side)
SELECT 
    '' AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' as paid_received,
    '' as slcode,
    a.DATE_OF_TRANSFER as datevalue,
    a.VOUCHER_NO as voucher_no,
    'FT' as document_type,
    'DR' as cr_dr_indicator, 
    a.total_amount as dr_amt, 
    0 as cr_amt,    
    a.TOTAL_AMOUNT as amt,
    a.PARTICULARS  
FROM fas_fund_trf_from_office a, 
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f 
WHERE a.TRANSFER_STATUS <> 'C' 
  AND to_date(a.cashbook_year || '-' || a.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int
  AND a.accounting_for_office_id = $P{accountofficeid}::int  and 
   $P!{draccountheadcode}
   c.office_id = a.accounting_for_office_id 
  AND A.DR_ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE 
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id

UNION ALL

-- Fund Transfer (CR side)
SELECT 
    '' AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' as paid_received,
    '' as slcode,
    a.DATE_OF_TRANSFER as datevalue,
    a.VOUCHER_NO as voucher_no,
    'FT' as document_type,
    'CR' as cr_dr_indicator, 
    0 as dr_amt,    
    a.total_amount as cr_amt, 
    a.TOTAL_AMOUNT as amt,
    a.PARTICULARS  
FROM fas_fund_trf_from_office a, 
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f 
WHERE a.TRANSFER_STATUS <> 'C' 
  AND to_date(a.cashbook_year || '-' || a.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int 
  AND a.accounting_for_office_id = $P{accountofficeid}::int and 
   $P!{craccountheadcode}
   c.office_id = a.accounting_for_office_id 
  AND A.CR_ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE 
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id

UNION ALL 

-- Inter-Bank Transfer (CR side)
SELECT 
    '' AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' as paid_received,
    '' as slcode,
    DATE_OF_TRANSFER AS datevalue,
    VOUCHER_NO as voucher_no,
    'IBT' as document_type,
    'CR' as cr_dr_indicator, 
    0 as dr_amt,
    TOTAL_AMOUNT as cr_amt,
    TOTAL_AMOUNT as amt,
    PARTICULARS  
FROM fas_inter_bank_trf_at_ho a,
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f 
WHERE a.TRANSFER_STATUS <> 'C' 
  AND to_date(a.cashbook_year || '-' || a.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int
  AND a.accounting_for_office_id = $P{accountofficeid}::int  and 
   $P!{craccountheadcode}
   c.office_id = a.accounting_for_office_id 
  AND A.CR_ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE 
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id

UNION ALL 

-- Inter-Bank Transfer (DR side)
SELECT 
    '' AS sub_ledger_type_code_desc,
    f.ACCOUNTING_UNIT_NAME,
    d.ACCOUNT_HEAD_CODE,     
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' as paid_received,
    '' as slcode,
    DATE_OF_TRANSFER AS datevalue,
    VOUCHER_NO as voucher_no,
    'IBT' as document_type,
    'DR' as cr_dr_indicator, 
    TOTAL_AMOUNT as dr_amt,
    0 as cr_amt,
    TOTAL_AMOUNT as amt,
    PARTICULARS  
FROM fas_inter_bank_trf_at_ho a,
     COM_MST_OFFICES c,
     COM_MST_ACCOUNT_HEADS d,
     FAS_MST_ACCT_UNITS f 
WHERE a.TRANSFER_STATUS <> 'C' 
  AND to_date(a.cashbook_year || '-' || a.cashbook_month || '-01', 'YYYY-MM-DD') 
      BETWEEN TO_CHAR(TO_DATE($P{fromDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date AND  TO_CHAR(TO_DATE($P{toDate}, 'DD/MM/YYYY'), 'YYYY-MM-DD')::date
  AND a.accounting_unit_id = $P{accountingunitid}::int
  AND a.accounting_for_office_id = $P{accountofficeid}::int and 
 $P!{draccountheadcode}
   c.office_id = a.accounting_for_office_id 
  AND A.DR_ACCOUNT_HEAD_CODE = D.ACCOUNT_HEAD_CODE 
  AND f.ACCOUNTING_UNIT_ID = a.accounting_unit_id

) ab
ORDER BY document_type, voucher_no, datevalue;]]></queryString>

