<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="LORAccountWise_withoutDate_bankingNew_Reg"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="898"
		 pageHeight="595"
		 columnWidth="870"
		 columnSpacing="0"
		 leftMargin="14"
		 rightMargin="14"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="ori_fromdate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="ori_todate" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT *
FROM
  (SELECT DECODE(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',10,'Project', 11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'DCB-Beneficiary','-') AS sub_ledger_type_code_desc,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    b.paid_to AS paid_received,
    (SELECT sl_codeName
    FROM SL_TYPE_CODE_NAME_VIEW_M
    WHERE sl_type=a.sub_ledger_type_code
    AND sl_code  =a.SUB_LEDGER_CODE
    )              AS slcode,
    b.payment_date AS datevalue,
    b.voucher_no   AS voucher_no,
    'P'            AS document_type,
    a.cr_dr_indicator,
    CASE
      WHEN a.cr_dr_indicator = 'DR'
      THEN a.amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN a.cr_dr_indicator = 'CR'
      THEN a.amount
      ELSE 0
    END      AS cr_amt,
    a.amount AS amt,
    a.particulars
  FROM fas_payment_transaction a,
    fas_payment_master b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d
  WHERE a.accounting_unit_id     = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.voucher_no               = b.voucher_no
  AND b.payment_status          <>'C'
  AND a.accounting_unit_id       = $P{accountingunitid}
  AND a.accounting_for_office_id = $P{accountofficeid}
  AND a.account_head_code        = $P{accountheadcode}
  AND c.office_id                =a.accounting_for_office_id
  AND a.ACCOUNT_HEAD_CODE        =d.account_head_code
  UNION ALL
  SELECT DECODE(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments', 10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'DCB-Beneficiary','-')AS sub_ledger_type_code_desc,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    b.received_from AS paid_received,
    (SELECT sl_codeName
    FROM SL_TYPE_CODE_NAME_VIEW_M
    WHERE sl_type=a.sub_ledger_type_code
    AND sl_code  =a.SUB_LEDGER_CODE
    )              AS slcode,
    b.receipt_date AS datevalue,
    b.receipt_no   AS voucher_no,
    'R'            AS documenttype,
    a.cr_dr_indicator,
    CASE
      WHEN a.cr_dr_indicator = 'DR'
      THEN a.amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN a.cr_dr_indicator = 'CR'
      THEN a.amount
      ELSE 0
    END      AS cr_amt,
    a.amount AS amt,
    a.particulars
  FROM fas_receipt_transaction a,
    fas_receipt_master b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d
  WHERE a.accounting_unit_id     = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.receipt_no               = b.receipt_no
  AND b.receipt_status          <>'C'
  AND a.accounting_unit_id       = $P{accountingunitid}
  AND a.accounting_for_office_id = $P{accountofficeid}
  AND a.account_head_code        = $P{accountheadcode}
  AND c.office_id                =a.accounting_for_office_id
  AND a.ACCOUNT_HEAD_CODE        =d.account_head_code
  UNION ALL
  SELECT DECODE(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'DCB-Beneficiary','-')AS sub_ledger_type_code_desc,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    ' ' AS paid_received,
    (SELECT sl_codeName
    FROM SL_TYPE_CODE_NAME_VIEW_M
    WHERE sl_type=a.sub_ledger_type_code
    AND sl_code  =a.SUB_LEDGER_CODE
    UNION ALL
    SELECT sl_codeName
    FROM test_view
    WHERE sl_type=a.sub_ledger_type_code
    AND sl_code  =a.SUB_LEDGER_CODE
    )              AS slcode,
    b.voucher_date AS datevalue,
    b.voucher_no   AS voucher_no ,
    'J'            AS document_type,
    a.cr_dr_indicator,
    CASE
      WHEN a.cr_dr_indicator = 'DR'
      THEN a.amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN a.cr_dr_indicator = 'CR'
      THEN a.amount
      ELSE 0
    END      AS cr_amt,
    a.amount AS amt,
    a.particulars
  FROM fas_journal_transaction a,
    fas_journal_master b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d
  WHERE a.accounting_unit_id     =b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.voucher_no               = b.voucher_no
  AND b.journal_status          <>'C'
  AND a.accounting_unit_id       = $P{accountingunitid}
  AND A.ACCOUNTING_FOR_OFFICE_ID = $P{accountofficeid}
  and a.ACCOUNT_HEAD_CODE=$P{accountheadcode}
  AND c.office_id                =a.accounting_for_office_id
  AND A.ACCOUNT_HEAD_CODE        =D.ACCOUNT_HEAD_CODE
  AND B.CREATED_BY_MODULE NOT IN ('SJV')
  AND (B.SUPPLEMENT_NO IS NULL 
  OR b.Supplement_No=0)
  UNION ALL
  SELECT DISTINCT(sub_ledger_type_code_desc) AS sub_ledger_type_code_desc,
    ACCOUNT_HEAD_DESC,
    office_name,
    paid_to AS paid_received,
    slcode,
    datevalue,
    voucher_no,
    document_type,
    cr_dr_indicator,
    CASE
      WHEN cr_dr_indicator = 'DR'
      THEN TOTAL_AMOUNT
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN cr_dr_indicator = 'CR'
      THEN TOTAL_AMOUNT
      ELSE 0
    END          AS cr_amt,
    TOTAL_AMOUNT AS amt ,
    REMARKS      AS particulars
  FROM
    (SELECT DECODE(b.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',10,'Project', 11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'DCB-Beneficiary','-') AS sub_ledger_type_code_desc,
      d.ACCOUNT_HEAD_DESC,
      c.office_name,
      b.paid_to,
      (SELECT sl_codeName
      FROM SL_TYPE_CODE_NAME_VIEW_M
      WHERE sl_type=b.sub_ledger_type_code
      AND sl_code  =b.SUB_LEDGER_CODE
      )              AS slcode,
      b.payment_date AS datevalue,
      b.voucher_no   AS voucher_no,
      'P'            AS document_type,
      b.cr_dr_indicator,
      b.TOTAL_AMOUNT,
      b.REMARKS
    FROM fas_payment_transaction a,
      fas_payment_master b,
      COM_MST_OFFICES c,
      COM_MST_ACCOUNT_HEADS d
    WHERE a.ACCOUNTING_UNIT_ID     !=b.ACCOUNTING_UNIT_ID
    AND a.ACCOUNTING_FOR_OFFICE_ID != b.ACCOUNTING_FOR_OFFICE_ID
    AND a.CASHBOOK_YEAR            != b.CASHBOOK_YEAR
    AND a.CASHBOOK_MONTH           != b.CASHBOOK_MONTH
    AND a.VOUCHER_NO               !=b.VOUCHER_NO
    AND a.ACCOUNT_HEAD_CODE        !=b.ACCOUNT_HEAD_CODE
    AND b.payment_status           <>'C'
    AND b.accounting_unit_id        = $P{accountingunitid}
    AND b.accounting_for_office_id  = $P{accountofficeid}
    AND b.account_head_code         = $P{accountheadcode}
    AND c.office_id                 =b.accounting_for_office_id
    AND b.ACCOUNT_HEAD_CODE         =d.account_head_code
    )
  UNION ALL
  SELECT DISTINCT(sub_ledger_type_code_desc) AS sub_ledger_type_code_desc,
    ACCOUNT_HEAD_DESC,
    office_name,
    paid_received,
    slcode,
    datevalue,
    voucher_no,
    document_type,
    cr_dr_indicator,
    CASE
      WHEN cr_dr_indicator = 'DR'
      THEN TOTAL_AMOUNT
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN cr_dr_indicator = 'CR'
      THEN TOTAL_AMOUNT
      ELSE 0
    END          AS cr_amt,
    TOTAL_AMOUNT AS amt ,
    REMARKS      AS particulars
  FROM
    (SELECT DECODE(b.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments', 10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'DCB-Beneficiary','-')AS sub_ledger_type_code_desc,
      d.ACCOUNT_HEAD_DESC,
      c.office_name,
      b.received_from AS paid_received,
      (SELECT sl_codeName
      FROM SL_TYPE_CODE_NAME_VIEW_M
      WHERE sl_type=b.sub_ledger_type_code
      AND sl_code  =b.SUB_LEDGER_CODE
      )              AS slcode,
      b.receipt_date AS datevalue,
      b.receipt_no   AS voucher_no,
      'R'            AS document_type,
      b.cr_dr_indicator,
      b.TOTAL_AMOUNT ,
      b.REMARKS
    FROM fas_receipt_transaction a,
      fas_receipt_master b,
      COM_MST_OFFICES c,
      COM_MST_ACCOUNT_HEADS d
    WHERE a.ACCOUNTING_UNIT_ID     !=b.ACCOUNTING_UNIT_ID
    AND a.ACCOUNTING_FOR_OFFICE_ID != b.ACCOUNTING_FOR_OFFICE_ID
    AND a.CASHBOOK_YEAR            != b.CASHBOOK_YEAR
    AND a.CASHBOOK_MONTH           != b.CASHBOOK_MONTH
    AND a.RECEIPT_NO               !=b.RECEIPT_NO
    AND a.ACCOUNT_HEAD_CODE        !=b.ACCOUNT_HEAD_CODE
    AND b.receipt_status           <>'C'
    AND b.accounting_unit_id        = $P{accountingunitid}
    AND b.accounting_for_office_id  = $P{accountofficeid}
    AND b.account_head_code         = $P{accountheadcode}
    AND c.office_id                 =b.accounting_for_office_id
    AND b.ACCOUNT_HEAD_CODE         =d.account_head_code
    )
  UNION ALL
  SELECT '' AS sub_ledger_type_code_desc,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    ''             AS paid_received,
    ''             AS slcode,
    a.RECEIPT_DATE AS datevalue,
    a.RECEIPT_NO   AS voucher_no,
    'FR'           AS document_type,
    'CR'           AS cr_dr_indicator,
    0              AS dr_amt,
    a.total_amount AS cr_amt,
    a.TOTAL_AMOUNT AS amt,
    a.PARTICULARS
  FROM FAS_FUND_RECEIPT_BY_HO a,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d
  WHERE a.receipt_status        <>'C'
  AND a.accounting_unit_id       = $P{accountingunitid}
  AND a.accounting_for_office_id = $P{accountofficeid}
  AND a.CR_ACCOUNT_HEAD_CODE     = $P{accountheadcode}
  AND c.office_id                =a.accounting_for_office_id
  AND a.CR_ACCOUNT_HEAD_CODE     =d.account_head_code
  UNION ALL
  SELECT '' AS sub_ledger_type_code_desc,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    ''             AS paid_received,
    ''             AS slcode,
    a.RECEIPT_DATE AS datevalue,
    a.RECEIPT_NO   AS voucher_no,
    'FR'           AS document_type,
    'DR'           AS cr_dr_indicator,
    a.total_amount AS dr_amt,
    0              AS cr_amt,
    a.TOTAL_AMOUNT AS amt,
    a.PARTICULARS
  FROM FAS_FUND_RECEIPT_BY_HO a,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d
  WHERE a.receipt_status        <>'C'
  AND a.accounting_unit_id       = $P{accountingunitid}
  AND a.accounting_for_office_id = $P{accountofficeid}
  AND a.DR_ACCOUNT_HEAD_CODE     = $P{accountheadcode}
  AND c.office_id                =a.accounting_for_office_id
  AND a.DR_ACCOUNT_HEAD_CODE     =d.account_head_code
  UNION ALL
  SELECT '' AS sub_ledger_type_code_desc,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    ''                 AS paid_received,
    ''                 AS slcode,
    a.DATE_OF_TRANSFER AS datevalue,
    a.VOUCHER_NO       AS voucher_no,
    'FT'               AS document_type,
    'DR'               AS cr_dr_indicator,
    b.AMOUNT           AS dr_amt,
    0                  AS cr_amt,
    b.AMOUNT           AS amt,
    b.PARTICULARS
  FROM fas_fund_trf_from_ho_trn b,
    fas_fund_trf_from_ho_master a,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d
  WHERE a.accounting_unit_id     =b.accounting_unit_id
  AND a.cashbook_year            =b.cashbook_year
  AND a.cashbook_month           =b.cashbook_month
  AND a.voucher_no               =b.voucher_no
  AND a.accounting_for_office_id =b.ACCOUNTING_FOR_OFFICE_ID
  AND a.TRANSFER_STATUS         <>'C'
  AND a.accounting_unit_id       =$P{accountingunitid}
  AND a.accounting_for_office_id =$P{accountofficeid}
  AND b.account_head_code        = $P{accountheadcode}
  AND c.office_id                =a.accounting_for_office_id
  AND b.account_head_code        =d.account_head_code
  UNION ALL
  SELECT '' AS sub_ledger_type_code_desc,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    ''                 AS paid_received,
    ''                 AS slcode,
    a.DATE_OF_TRANSFER AS datevalue,
    a.VOUCHER_NO       AS voucher_no,
    'FT'               AS document_type,
    'CR'               AS cr_dr_indicator,
    0                  AS dr_amt,
    b.amount           AS cr_amt,
    b.AMOUNT           AS amt,
    b.PARTICULARS
  FROM fas_fund_trf_from_ho_trn b,
    fas_fund_trf_from_ho_master a,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d
  WHERE a.accounting_unit_id     =b.accounting_unit_id
  AND a.cashbook_year            =b.cashbook_year
  AND a.cashbook_month           =b.cashbook_month
  AND a.voucher_no               =b.voucher_no
  AND a.accounting_for_office_id =b.ACCOUNTING_FOR_OFFICE_ID
  AND a.TRANSFER_STATUS         <>'C'
  AND a.accounting_unit_id       =$P{accountingunitid}
  AND a.accounting_for_office_id = $P{accountofficeid}
  AND a.account_head_code        = $P{accountheadcode}
  AND c.office_id                =a.accounting_for_office_id
  AND a.account_head_code        =d.account_head_code
  UNION ALL
  -- IBT Cr
  SELECT DISTINCT(sub_ledger_type_code_desc) AS sub_ledger_type_code_desc,
    ACCOUNT_HEAD_DESC,
    office_name,
    paid_received,
    slcode,
    datevalue,
    voucher_no,
    document_type,
    cr_dr_indicator,
    CASE
      WHEN cr_dr_indicator = 'DR'
      THEN TOTAL_AMOUNT
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN cr_dr_indicator = 'CR'
      THEN TOTAL_AMOUNT
      ELSE 0
    END            AS cr_amt,
    (TOTAL_AMOUNT) AS amt ,
    PARTICULARS
  FROM
    (SELECT '' AS sub_ledger_type_code_desc,
      d.ACCOUNT_HEAD_DESC,
      c.office_name,
      ''               AS paid_received,
      ''               AS slcode,
      DATE_OF_TRANSFER AS datevalue,
      VOUCHER_NO       AS voucher_no,
      'IBT'            AS document_type,
      'CR'             AS cr_dr_indicator,
      TOTAL_AMOUNT ,
      PARTICULARS
    FROM fas_inter_bank_trf_at_ho a,
      COM_MST_OFFICES c,
      COM_MST_ACCOUNT_HEADS d
    WHERE a.TRANSFER_STATUS       <>'C'
    AND a.accounting_unit_id       = $P{accountingunitid}
    AND a.accounting_for_office_id = $P{accountofficeid}
    AND a.CR_ACCOUNT_HEAD_CODE     = $P{accountheadcode}
    AND c.office_id                =a.accounting_for_office_id
    AND a.CR_ACCOUNT_HEAD_CODE     =d.account_head_code
    )
  UNION ALL
  -- IBT Dr
  SELECT DISTINCT(sub_ledger_type_code_desc) AS sub_ledger_type_code_desc,
    ACCOUNT_HEAD_DESC,
    office_name,
    paid_received,
    slcode,
    datevalue,
    voucher_no,
    document_type,
    cr_dr_indicator,
    CASE
      WHEN cr_dr_indicator = 'DR'
      THEN TOTAL_AMOUNT
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN cr_dr_indicator = 'CR'
      THEN TOTAL_AMOUNT
      ELSE 0
    END            AS cr_amt,
    (TOTAL_AMOUNT) AS amt ,
    PARTICULARS
  FROM
    (SELECT '' AS sub_ledger_type_code_desc,
      d.ACCOUNT_HEAD_DESC,
      c.office_name,
      ''               AS paid_received,
      ''               AS slcode,
      DATE_OF_TRANSFER AS datevalue,
      VOUCHER_NO       AS voucher_no,
      'IBT'            AS document_type,
      'DR'             AS cr_dr_indicator,
      TOTAL_AMOUNT ,
      PARTICULARS
    FROM fas_inter_bank_trf_at_ho a,
      COM_MST_OFFICES c,
      COM_MST_ACCOUNT_HEADS d
    WHERE a.TRANSFER_STATUS       <>'C'
    AND a.accounting_unit_id       = $P{accountingunitid}
    AND a.accounting_for_office_id = $P{accountofficeid}
    AND a.DR_ACCOUNT_HEAD_CODE     = $P{accountheadcode}
    AND c.office_id                =a.accounting_for_office_id
    AND a.DR_ACCOUNT_HEAD_CODE     =d.account_head_code
    )
  )
WHERE datevalue BETWEEN $P{txtfrom} AND $P{txtto}
ORDER BY DATEVALUE
  --order by  document_type , voucher_no , datevalue]]></queryString>

	<field name="SUB_LEDGER_TYPE_CODE_DESC" class="java.lang.String"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="PAID_RECEIVED" class="java.lang.String"/>
	<field name="SLCODE" class="java.lang.String"/>
	<field name="DATEVALUE" class="java.sql.Timestamp"/>
	<field name="VOUCHER_NO" class="java.math.BigDecimal"/>
	<field name="DOCUMENT_TYPE" class="java.lang.String"/>
	<field name="CR_DR_INDICATOR" class="java.lang.String"/>
	<field name="DR_AMT" class="java.math.BigDecimal"/>
	<field name="CR_AMT" class="java.math.BigDecimal"/>
	<field name="AMT" class="java.math.BigDecimal"/>
	<field name="PARTICULARS" class="java.lang.String"/>

	<variable name="SUM_AMT_1" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_DR_INDICATOR_1" class="java.lang.String" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_DR_INDICATOR}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_AMT_1" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_DR_AMT_2" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_AMT_2" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_DR_AMT_3" class="java.math.BigDecimal" resetType="Page" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_AMT_3" class="java.math.BigDecimal" resetType="Page" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_DR_AMT_4" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_AMT_4" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_DR_AMT_5" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_AMT_5" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMT}]]></variableExpression>
	</variable>
		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="80"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="573"
						y="4"
						width="94"
						height="18"
						key="staticText-2"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
