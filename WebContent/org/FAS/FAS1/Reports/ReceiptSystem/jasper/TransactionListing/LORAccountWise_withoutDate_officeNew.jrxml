<jasperReport
		 name="LORAccountWise_withoutDate_officeNew"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="898"
		 pageHeight="595"
		 columnWidth="870"
		 columnSpacing="0"
		 leftMargin="14"
		 rightMargin="14"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="ori_fromdate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="ori_todate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="heading" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select * from 
(

SELECT   
 
CASE WHEN A.SUB_LEDGER_TYPE_CODE= 1 THEN 'Supplier'
	 WHEN A.SUB_LEDGER_TYPE_CODE= 2 THEN 'Firms'
     WHEN A.SUB_LEDGER_TYPE_CODE= 3 THEN 'Assets'
    WHEN A.SUB_LEDGER_TYPE_CODE= 4 THEN 'ChequeBooks'
    WHEN A.SUB_LEDGER_TYPE_CODE= 5 THEN 'Offices'
    WHEN A.SUB_LEDGER_TYPE_CODE= 6 THEN 'Bank'
    WHEN A.SUB_LEDGER_TYPE_CODE= 7 THEN 'Employees'
    WHEN A.SUB_LEDGER_TYPE_CODE= 8 THEN '-'
    WHEN A.SUB_LEDGER_TYPE_CODE= 9 THEN 'OtherDepartments'
    WHEN A.SUB_LEDGER_TYPE_CODE= 10 THEN 'Project' 
    WHEN A.SUB_LEDGER_TYPE_CODE= 11 THEN 'Contractors'
    WHEN A.SUB_LEDGER_TYPE_CODE= 12 THEN 'Scheme Owner'
    WHEN A.SUB_LEDGER_TYPE_CODE= 13 THEN 'Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 14 THEN 'DCB-Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 15 THEN 'Accounting Units'
    WHEN A.SUB_LEDGER_TYPE_CODE= 16 THEN 'Scheme Type'
    WHEN A.SUB_LEDGER_TYPE_CODE= 17 THEN 'Miscellaneous'
    WHEN A.SUB_LEDGER_TYPE_CODE= 18 THEN 'Pensioners'
    WHEN A.SUB_LEDGER_TYPE_CODE= 19 THEN 'Family Pensioner'
    WHEN A.SUB_LEDGER_TYPE_CODE= 20 THEN 'IMIS-SA-CCDU'
WHEN A.SUB_LEDGER_TYPE_CODE= 21 THEN 'IMIS-SA-MIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 22 THEN 'IMIS-SA-GIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 23 THEN 'IMIS-SA-R and D'
WHEN A.SUB_LEDGER_TYPE_CODE= 24 THEN 'IMIS-SA-M and I'
WHEN A.SUB_LEDGER_TYPE_CODE= 25 THEN 'Special PF Payments'
WHEN A.SUB_LEDGER_TYPE_CODE= 26 THEN 'Work In Progress'
WHEN A.SUB_LEDGER_TYPE_CODE= 27 THEN 'IMIS-SA-WQMS'
WHEN A.SUB_LEDGER_TYPE_CODE= 28 THEN 'One Day Salary Contribution'
 ELSE '-' END as SUB_LEDGER_TYPE_CODE_DESC,
        d.ACCOUNT_HEAD_DESC as "ACCOUNT_HEAD_DESC",
        c.office_name as "OFFICE_NAME",
        b.paid_to as "PAID_RECEIVED",
           
   (  select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M
      where  sl_type=a.sub_ledger_type_code 
         and sl_code=a.SUB_LEDGER_CODE
	
limit 1
   ) as "SLCODE",
         b.payment_date AS "datevalue",
         b.voucher_no as "voucher_no",
         'P' AS "document_type",
         a.cr_dr_indicator as "CR_DR_INDICATOR",
          
         case when a.cr_dr_indicator = 'DR' then
               a.amount 
               else
               0  
             END as "DR_AMT",
               
          case when a.cr_dr_indicator = 'CR' then
                  a.amount 
               else
               0 
             END  as "CR_AMT",
                  
          a.amount as "AMT",
          a.particulars as "PARTICULARS"  
 
 FROM 
          fas_payment_transaction a,
          fas_payment_master b,
          COM_MST_OFFICES c,
          COM_MST_ACCOUNT_HEADS d
WHERE 
    a.accounting_unit_id = b.accounting_unit_id
AND a.accounting_for_office_id = b.accounting_for_office_id 
AND a.cashbook_year = b.cashbook_year
AND a.cashbook_month = b.cashbook_month 
AND a.voucher_no= b.voucher_no 
AND b.payment_status<>'C' 

and a.accounting_unit_id =$P{accountingunitid}::int 
AND a.accounting_for_office_id = $P{accountofficeid}::int
AND a.account_head_code = $P{accountheadcode}::int
AND c.office_id=a.accounting_for_office_id 
and a.ACCOUNT_HEAD_CODE=d.account_head_code 

UNION all 
SELECT 


CASE WHEN A.SUB_LEDGER_TYPE_CODE= 1 THEN 'Supplier'
	 WHEN A.SUB_LEDGER_TYPE_CODE= 2 THEN 'Firms'
     WHEN A.SUB_LEDGER_TYPE_CODE= 3 THEN 'Assets'
    WHEN A.SUB_LEDGER_TYPE_CODE= 4 THEN 'ChequeBooks'
    WHEN A.SUB_LEDGER_TYPE_CODE= 5 THEN 'Offices'
    WHEN A.SUB_LEDGER_TYPE_CODE= 6 THEN 'Bank'
    WHEN A.SUB_LEDGER_TYPE_CODE= 7 THEN 'Employees'
    WHEN A.SUB_LEDGER_TYPE_CODE= 8 THEN '-'
    WHEN A.SUB_LEDGER_TYPE_CODE= 9 THEN 'OtherDepartments'
    WHEN A.SUB_LEDGER_TYPE_CODE= 10 THEN 'Project' 
    WHEN A.SUB_LEDGER_TYPE_CODE= 11 THEN 'Contractors'
    WHEN A.SUB_LEDGER_TYPE_CODE= 12 THEN 'Scheme Owner'
    WHEN A.SUB_LEDGER_TYPE_CODE= 13 THEN 'Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 14 THEN 'DCB-Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 15 THEN 'Accounting Units'
    WHEN A.SUB_LEDGER_TYPE_CODE= 16 THEN 'Scheme Type'

WHEN A.SUB_LEDGER_TYPE_CODE= 17 THEN 'Miscellaneous'
WHEN A.SUB_LEDGER_TYPE_CODE= 18 THEN 'Pensioners'

WHEN A.SUB_LEDGER_TYPE_CODE= 19 THEN 'Family Pensioner'
WHEN A.SUB_LEDGER_TYPE_CODE= 20 THEN 'IMIS-SA-CCDU'
WHEN A.SUB_LEDGER_TYPE_CODE= 21 THEN 'IMIS-SA-MIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 22 THEN 'IMIS-SA-GIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 23 THEN 'IMIS-SA-R and D'
WHEN A.SUB_LEDGER_TYPE_CODE= 24 THEN 'IMIS-SA-M and I'
WHEN A.SUB_LEDGER_TYPE_CODE= 25 THEN 'Special PF Payments'
WHEN A.SUB_LEDGER_TYPE_CODE= 26 THEN 'Work In Progress'
WHEN A.SUB_LEDGER_TYPE_CODE= 27 THEN 'IMIS-SA-WQMS'
WHEN A.SUB_LEDGER_TYPE_CODE= 28 THEN 'One Day Salary Contribution'
 ELSE '-' END as SUB_LEDGER_TYPE_CODE_DESC,

            d.ACCOUNT_HEAD_DESC,
            c.office_name,
            b.received_from  as paid_received,         
    (SELECT sl_codeName
    FROM SL_TYPE_CODE_NAME_VIEW_M
    WHERE sl_type=a.sub_ledger_type_code
    AND sl_code  =a.SUB_LEDGER_CODE

limit 1
    )              AS slcode,     
        b.receipt_date AS datevalue,
        b.receipt_no as voucher_no,
        'R' as documenttype,
        a.cr_dr_indicator,
         
        case when a.cr_dr_indicator = 'DR' then
               a.amount 
               else
               0  
             END as dr_amt,
               
        case when a.cr_dr_indicator = 'CR' then
               a.amount 
               else
               0 
             END  as cr_amt,
                           
         a.amount as amt,
         a.particulars 
       
FROM 
        fas_receipt_transaction a,
        fas_receipt_master b,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where
a.accounting_unit_id = b.accounting_unit_id AND 
a.accounting_for_office_id = b.accounting_for_office_id AND 
a.cashbook_year = b.cashbook_year AND 
a.cashbook_month = b.cashbook_month AND 
a.receipt_no= b.receipt_no AND 
b.receipt_status<>'C' and

a.accounting_unit_id =$P{accountingunitid}::int  AND
a.accounting_for_office_id = $P{accountofficeid}::int AND
a.account_head_code = $P{accountheadcode}::int AND 
c.office_id=a.accounting_for_office_id and 
a.ACCOUNT_HEAD_CODE=d.account_head_code 







UNION all







SELECT 
  



CASE WHEN A.SUB_LEDGER_TYPE_CODE= 1 THEN 'Supplier'
	 WHEN A.SUB_LEDGER_TYPE_CODE= 2 THEN 'Firms'
     WHEN A.SUB_LEDGER_TYPE_CODE= 3 THEN 'Assets'
    WHEN A.SUB_LEDGER_TYPE_CODE= 4 THEN 'ChequeBooks'
    WHEN A.SUB_LEDGER_TYPE_CODE= 5 THEN 'Offices'
    WHEN A.SUB_LEDGER_TYPE_CODE= 6 THEN 'Bank'
    WHEN A.SUB_LEDGER_TYPE_CODE= 7 THEN 'Employees'
    WHEN A.SUB_LEDGER_TYPE_CODE= 8 THEN '-'
    WHEN A.SUB_LEDGER_TYPE_CODE= 9 THEN 'OtherDepartments'
    WHEN A.SUB_LEDGER_TYPE_CODE= 10 THEN 'Project' 
    WHEN A.SUB_LEDGER_TYPE_CODE= 11 THEN 'Contractors'
    WHEN A.SUB_LEDGER_TYPE_CODE= 12 THEN 'Scheme Owner'
    WHEN A.SUB_LEDGER_TYPE_CODE= 13 THEN 'Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 14 THEN 'DCB-Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 15 THEN 'Accounting Units'
    WHEN A.SUB_LEDGER_TYPE_CODE= 16 THEN 'Scheme Type'
WHEN A.SUB_LEDGER_TYPE_CODE= 17 THEN 'Miscellaneous'
WHEN A.SUB_LEDGER_TYPE_CODE= 18 THEN 'Pensioners'
WHEN A.SUB_LEDGER_TYPE_CODE= 19 THEN 'Family Pensioner'
WHEN A.SUB_LEDGER_TYPE_CODE= 20 THEN 'IMIS-SA-CCDU'
WHEN A.SUB_LEDGER_TYPE_CODE= 21 THEN 'IMIS-SA-MIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 22 THEN 'IMIS-SA-GIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 23 THEN 'IMIS-SA-R and D'
WHEN A.SUB_LEDGER_TYPE_CODE= 24 THEN 'IMIS-SA-M and I'
WHEN A.SUB_LEDGER_TYPE_CODE= 25 THEN 'Special PF Payments'
WHEN A.SUB_LEDGER_TYPE_CODE= 26 THEN 'Work In Progress'
WHEN A.SUB_LEDGER_TYPE_CODE= 27 THEN 'IMIS-SA-WQMS'
WHEN A.SUB_LEDGER_TYPE_CODE= 28 THEN 'One Day Salary Contribution'
 ELSE '-' END as SUB_LEDGER_TYPE_CODE_DESC,


d.ACCOUNT_HEAD_DESC,
c.office_name,
' ' as paid_received,

(
  select 
          sl_codeName
  from 
        SL_TYPE_CODE_NAME_VIEW_M 
  where
        sl_type=a.sub_ledger_type_code and 
        sl_code=a.SUB_LEDGER_CODE


limit 1

) as slcode,
b.voucher_date AS datevalue,
b.voucher_no as voucher_no ,
'J' AS document_type,
a.cr_dr_indicator,

         case when a.cr_dr_indicator = 'DR' then
               a.amount 
               else
               0  
             END as dr_amt,
               
          case when a.cr_dr_indicator = 'CR' then
                  a.amount 
               else
               0 
          END  as cr_amt,           
                  
  a.amount as amt,
  a.particulars 

 FROM 

fas_journal_transaction a,
fas_journal_master b,
COM_MST_OFFICES c,
COM_MST_ACCOUNT_HEADS d 

where

a.accounting_unit_id=b.accounting_unit_id and 
a.accounting_for_office_id = b.accounting_for_office_id AND 
a.cashbook_year = b.cashbook_year AND 
a.cashbook_month = b.cashbook_month AND 
a.voucher_no= b.voucher_no AND 
b.journal_status<>'C' and

a.accounting_unit_id=$P{accountingunitid}::int  and 
a.accounting_for_office_id= $P{accountofficeid}::int and
a.ACCOUNT_HEAD_CODE=$P{accountheadcode}::int  AND 
c.office_id=a.accounting_for_office_id and a.ACCOUNT_HEAD_CODE=d.account_head_code







union all 









select
     distinct(sub_ledger_type_code_desc) as sub_ledger_type_code_desc,
     ACCOUNT_HEAD_DESC,
     office_name,
     paid_to as paid_received,
     slcode,
     datevalue,
     voucher_no,
     document_type,
     cr_dr_indicator,      
      
      CASE WHEN cr_dr_indicator = 'DR' THEN
               TOTAL_AMOUNT
           ELSE
               0  
           END as dr_amt,
               
     case when cr_dr_indicator = 'CR' then
               TOTAL_AMOUNT
               else
               0  
           end as cr_amt,
           
     TOTAL_AMOUNT as amt ,
     REMARKS  as particulars
from
(
 SELECT   


CASE WHEN A.SUB_LEDGER_TYPE_CODE= 1 THEN 'Supplier'
	 WHEN A.SUB_LEDGER_TYPE_CODE= 2 THEN 'Firms'
     WHEN A.SUB_LEDGER_TYPE_CODE= 3 THEN 'Assets'
    WHEN A.SUB_LEDGER_TYPE_CODE= 4 THEN 'ChequeBooks'
    WHEN A.SUB_LEDGER_TYPE_CODE= 5 THEN 'Offices'
    WHEN A.SUB_LEDGER_TYPE_CODE= 6 THEN 'Bank'
    WHEN A.SUB_LEDGER_TYPE_CODE= 7 THEN 'Employees'
    WHEN A.SUB_LEDGER_TYPE_CODE= 8 THEN '-'
    WHEN A.SUB_LEDGER_TYPE_CODE= 9 THEN 'OtherDepartments'
    WHEN A.SUB_LEDGER_TYPE_CODE= 10 THEN 'Project' 
    WHEN A.SUB_LEDGER_TYPE_CODE= 11 THEN 'Contractors'
    WHEN A.SUB_LEDGER_TYPE_CODE= 12 THEN 'Scheme Owner'
    WHEN A.SUB_LEDGER_TYPE_CODE= 13 THEN 'Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 14 THEN 'DCB-Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 15 THEN 'Accounting Units'
    WHEN A.SUB_LEDGER_TYPE_CODE= 16 THEN 'Scheme Type'
WHEN A.SUB_LEDGER_TYPE_CODE= 17 THEN 'Miscellaneous'
WHEN A.SUB_LEDGER_TYPE_CODE= 18 THEN 'Pensioners'
WHEN A.SUB_LEDGER_TYPE_CODE= 19 THEN 'Family Pensioner'
WHEN A.SUB_LEDGER_TYPE_CODE= 20 THEN 'IMIS-SA-CCDU'
WHEN A.SUB_LEDGER_TYPE_CODE= 21 THEN 'IMIS-SA-MIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 22 THEN 'IMIS-SA-GIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 23 THEN 'IMIS-SA-R and D'
WHEN A.SUB_LEDGER_TYPE_CODE= 24 THEN 'IMIS-SA-M and I'
WHEN A.SUB_LEDGER_TYPE_CODE= 25 THEN 'Special PF Payments'
WHEN A.SUB_LEDGER_TYPE_CODE= 26 THEN 'Work In Progress'
WHEN A.SUB_LEDGER_TYPE_CODE= 27 THEN 'IMIS-SA-WQMS'
WHEN A.SUB_LEDGER_TYPE_CODE= 28 THEN 'One Day Salary Contribution'
 ELSE '-' END as SUB_LEDGER_TYPE_CODE_DESC,

             d.ACCOUNT_HEAD_DESC,
             c.office_name,
             b.paid_to,
           
   (
      select 
                 sl_codeName 
      from 
                 SL_TYPE_CODE_NAME_VIEW_M
      where 
                 sl_type=b.sub_ledger_type_code 
          and sl_code=b.SUB_LEDGER_CODE
   ) as   slcode,
          b.payment_date AS datevalue,
          b.voucher_no as voucher_no,
          'P' AS document_type,
          b.cr_dr_indicator,
          b.TOTAL_AMOUNT,
          b.REMARKS 
 
 FROM     
          fas_payment_transaction a,  
          fas_payment_master b,
          COM_MST_OFFICES c,
          COM_MST_ACCOUNT_HEADS d
WHERE 
    
       a.ACCOUNTING_UNIT_ID !=b.ACCOUNTING_UNIT_ID
 and   a.ACCOUNTING_FOR_OFFICE_ID != b.ACCOUNTING_FOR_OFFICE_ID
 and   a.CASHBOOK_YEAR != b.CASHBOOK_YEAR
 and   a.CASHBOOK_MONTH != b.CASHBOOK_MONTH
 and   a.VOUCHER_NO !=b.VOUCHER_NO
 and   a.ACCOUNT_HEAD_CODE !=b.ACCOUNT_HEAD_CODE
 

and b.payment_status<>'C' 

and b.accounting_unit_id =$P{accountingunitid}::int 
AND b.accounting_for_office_id = $P{accountofficeid}::int
AND b.account_head_code = $P{accountheadcode}::int
AND c.office_id=b.accounting_for_office_id 
and b.ACCOUNT_HEAD_CODE=d.account_head_code 
) as opt1







union all 







select 
     distinct(sub_ledger_type_code_desc) as sub_ledger_type_code_desc,
     ACCOUNT_HEAD_DESC,
     office_name,
     paid_received,
     slcode,
     datevalue,
     voucher_no,
     document_type,
     cr_dr_indicator,
     
      CASE WHEN cr_dr_indicator = 'DR' THEN
               TOTAL_AMOUNT
           ELSE
               0  
           END as dr_amt,
               
     case when cr_dr_indicator = 'CR' then
               TOTAL_AMOUNT
               else
               0  
           end as cr_amt,    
     
     TOTAL_AMOUNT as amt ,
     REMARKS  as particulars

from

( SELECT 


CASE WHEN A.SUB_LEDGER_TYPE_CODE= 1 THEN 'Supplier'
	 WHEN A.SUB_LEDGER_TYPE_CODE= 2 THEN 'Firms'
     WHEN A.SUB_LEDGER_TYPE_CODE= 3 THEN 'Assets'
    WHEN A.SUB_LEDGER_TYPE_CODE= 4 THEN 'ChequeBooks'
    WHEN A.SUB_LEDGER_TYPE_CODE= 5 THEN 'Offices'
    WHEN A.SUB_LEDGER_TYPE_CODE= 6 THEN 'Bank'
    WHEN A.SUB_LEDGER_TYPE_CODE= 7 THEN 'Employees'
    WHEN A.SUB_LEDGER_TYPE_CODE= 8 THEN '-'
    WHEN A.SUB_LEDGER_TYPE_CODE= 9 THEN 'OtherDepartments'
    WHEN A.SUB_LEDGER_TYPE_CODE= 10 THEN 'Project' 
    WHEN A.SUB_LEDGER_TYPE_CODE= 11 THEN 'Contractors'
    WHEN A.SUB_LEDGER_TYPE_CODE= 12 THEN 'Scheme Owner'
    WHEN A.SUB_LEDGER_TYPE_CODE= 13 THEN 'Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 14 THEN 'DCB-Beneficiary'
    WHEN A.SUB_LEDGER_TYPE_CODE= 15 THEN 'Accounting Units'
    WHEN A.SUB_LEDGER_TYPE_CODE= 16 THEN 'Scheme Type'
WHEN A.SUB_LEDGER_TYPE_CODE= 17 THEN 'Miscellaneous'
WHEN A.SUB_LEDGER_TYPE_CODE= 18 THEN 'Pensioners'
WHEN A.SUB_LEDGER_TYPE_CODE= 19 THEN 'Family Pensioner'
WHEN A.SUB_LEDGER_TYPE_CODE= 20 THEN 'IMIS-SA-CCDU'
WHEN A.SUB_LEDGER_TYPE_CODE= 21 THEN 'IMIS-SA-MIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 22 THEN 'IMIS-SA-GIS'
WHEN A.SUB_LEDGER_TYPE_CODE= 23 THEN 'IMIS-SA-R and D'
WHEN A.SUB_LEDGER_TYPE_CODE= 24 THEN 'IMIS-SA-M and I'
WHEN A.SUB_LEDGER_TYPE_CODE= 25 THEN 'Special PF Payments'
WHEN A.SUB_LEDGER_TYPE_CODE= 26 THEN 'Work In Progress'
WHEN A.SUB_LEDGER_TYPE_CODE= 27 THEN 'IMIS-SA-WQMS'
WHEN A.SUB_LEDGER_TYPE_CODE= 28 THEN 'One Day Salary Contribution'
 ELSE '-' END as SUB_LEDGER_TYPE_CODE_DESC,

          d.ACCOUNT_HEAD_DESC,
          c.office_name,
          b.received_from  as paid_received,
       '' as slcode,
            b.receipt_date AS datevalue,
        b.receipt_no as voucher_no,
        'R' as document_type,
        b.cr_dr_indicator,
        b.TOTAL_AMOUNT ,
        b.REMARKS 
       
FROM 
        fas_receipt_transaction a,
        fas_receipt_master b,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where

       a.ACCOUNTING_UNIT_ID !=b.ACCOUNTING_UNIT_ID
 and   a.ACCOUNTING_FOR_OFFICE_ID != b.ACCOUNTING_FOR_OFFICE_ID
 and   a.CASHBOOK_YEAR != b.CASHBOOK_YEAR
 and   a.CASHBOOK_MONTH != b.CASHBOOK_MONTH
 and   a.RECEIPT_NO !=b.RECEIPT_NO                      
 and   a.ACCOUNT_HEAD_CODE !=b.ACCOUNT_HEAD_CODE and 

b.receipt_status<>'C' and

b.accounting_unit_id =$P{accountingunitid}::int  AND
b.accounting_for_office_id = $P{accountofficeid}::int AND
b.account_head_code = $P{accountheadcode}::int AND
c.office_id=b.accounting_for_office_id and 
b.ACCOUNT_HEAD_CODE=d.account_head_code 
) as opt2




union all 





SELECT 
       '' as sub_ledger_type_code_desc,
       d.ACCOUNT_HEAD_DESC,
       c.office_name,
       '' as paid_received,
       '' as slcode,
       a.RECEIPT_DATE AS datevalue,
       a.RECEIPT_NO as voucher_no,
       'FR' as document_type,
       'CR' as cr_dr_indicator, 
       0 as dr_amt, 
       a.total_amount as cr_amt,    
       a.TOTAL_AMOUNT as amt,
       a.PARTICULARS  
       
FROM 
        FAS_FUND_RECEIPT_BY_OFFICE a,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where

       a.receipt_status<>'C' 

 and   a.accounting_unit_id =$P{accountingunitid}::int 
 AND   a.accounting_for_office_id = $P{accountofficeid}::int
 AND   a.CR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}::int
 AND   c.office_id=a.accounting_for_office_id 
 and   a.CR_ACCOUNT_HEAD_CODE=d.account_head_code 


union all 



SELECT 
       '' as sub_ledger_type_code_desc,
       d.ACCOUNT_HEAD_DESC,
       c.office_name,
       '' as paid_received,
       '' as slcode,
       a.RECEIPT_DATE AS datevalue,
       a.RECEIPT_NO as voucher_no,
       'FR' as document_type,
       'DR' as cr_dr_indicator, 
       a.total_amount as dr_amt, 
       0 as cr_amt,    
       a.TOTAL_AMOUNT as amt,
       a.PARTICULARS  
       
FROM 
        FAS_FUND_RECEIPT_BY_OFFICE a,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where

       a.receipt_status<>'C' 

 and   a.accounting_unit_id =$P{accountingunitid}::int 
 AND   a.accounting_for_office_id = $P{accountofficeid}::int
 AND   a.DR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}::int
 AND   c.office_id=a.accounting_for_office_id 
 and   a.DR_ACCOUNT_HEAD_CODE=d.account_head_code 



union all 
  

 

select 
   '' as sub_ledger_type_code_desc,
   d.ACCOUNT_HEAD_DESC,
   c.office_name,
   '' as paid_received,
   '' as slcode,
   a.DATE_OF_TRANSFER as datevalue,
   a.VOUCHER_NO as voucher_no,
   'FT' as document_type,
   'DR' as cr_dr_indicator, 
   a.total_amount as dr_amt, 
   0 as cr_amt,    
   a.TOTAL_AMOUNT as amt,
   a.PARTICULARS  
   
from 
   fas_fund_trf_from_office a, 
   COM_MST_OFFICES c,
   COM_MST_ACCOUNT_HEADS d 
where
       a.TRANSFER_STATUS<>'C' 

 and   a.accounting_unit_id =$P{accountingunitid}::int 
 AND   a.accounting_for_office_id = $P{accountofficeid}::int
 AND   a.DR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}::int
 AND   c.office_id=a.accounting_for_office_id 
 and   a.DR_ACCOUNT_HEAD_CODE=d.account_head_code 
   
   
union all



select 
   '' as sub_ledger_type_code_desc,
   d.ACCOUNT_HEAD_DESC,
   c.office_name,
   '' as paid_received,
   '' as slcode,
   a.DATE_OF_TRANSFER as datevalue,
   a.VOUCHER_NO as voucher_no,
   'FT' as document_type,
   'CR' as cr_dr_indicator, 
   0 as dr_amt,    
   a.total_amount as cr_amt, 
   a.TOTAL_AMOUNT as amt,
   a.PARTICULARS  
   
from 
   fas_fund_trf_from_office a, 
   COM_MST_OFFICES c,
   COM_MST_ACCOUNT_HEADS d 
where
       a.TRANSFER_STATUS<>'C' 

 and   a.accounting_unit_id =$P{accountingunitid}::int 
 AND   a.accounting_for_office_id = $P{accountofficeid}::int
 AND   a.CR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}::int
 AND   c.office_id=a.accounting_for_office_id 
 and   a.CR_ACCOUNT_HEAD_CODE=d.account_head_code 
 
 
 union all 

 
select 
     distinct(sub_ledger_type_code_desc) as sub_ledger_type_code_desc,
     ACCOUNT_HEAD_DESC,
     office_name,
     paid_received,
     slcode,
     datevalue,
     voucher_no,
     document_type,
     cr_dr_indicator,
       
     CASE WHEN cr_dr_indicator = 'DR' THEN
               TOTAL_AMOUNT
           ELSE
               0  
           END as dr_amt,
               
     case when cr_dr_indicator = 'CR' then
               TOTAL_AMOUNT
               else
               0  
           end as cr_amt,
       
     
     (TOTAL_AMOUNT) as amt ,
     PARTICULARS 

from

( SELECT 
       '' as sub_ledger_type_code_desc,
       d.ACCOUNT_HEAD_DESC,
       c.office_name,
       '' as paid_received,
       '' as slcode,
       DATE_OF_TRANSFER AS datevalue,
       VOUCHER_NO as voucher_no,
       'IBT' as document_type,
       'CR' as cr_dr_indicator, 
       TOTAL_AMOUNT ,
       PARTICULARS  
       
FROM 
        fas_inter_bank_trf_at_ho a,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where

       a.TRANSFER_STATUS<>'C' 

 and   a.accounting_unit_id = $P{accountingunitid}::int 
 AND   a.accounting_for_office_id = $P{accountofficeid}::int
 AND   a.CR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}::int
 AND   c.office_id=a.accounting_for_office_id 
 and   a.CR_ACCOUNT_HEAD_CODE=d.account_head_code 

) as opt41

union all 


select 
     distinct(sub_ledger_type_code_desc) as sub_ledger_type_code_desc,
     ACCOUNT_HEAD_DESC,
     office_name,
     paid_received,
     slcode,
     datevalue,
     voucher_no,
     document_type,
     cr_dr_indicator,
       
     CASE WHEN cr_dr_indicator = 'DR' THEN
               TOTAL_AMOUNT
           ELSE
               0  
           END as dr_amt,
               
     case when cr_dr_indicator = 'CR' then
               TOTAL_AMOUNT
               else
               0  
           end as cr_amt,
       
     
     (TOTAL_AMOUNT) as amt ,
     PARTICULARS 

from

( SELECT 
       '' as sub_ledger_type_code_desc,
       d.ACCOUNT_HEAD_DESC,
       c.office_name,
       '' as paid_received,
       '' as slcode,
       DATE_OF_TRANSFER AS datevalue,
       VOUCHER_NO as voucher_no,
       'IBT' as document_type,
       'DR' as cr_dr_indicator, 
       TOTAL_AMOUNT ,
       PARTICULARS  
       
FROM 
        fas_inter_bank_trf_at_ho a,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where 

       a.TRANSFER_STATUS<>'C' 

 And   A.Accounting_Unit_Id = $P{accountingunitid}::int 

 AND   a.accounting_for_office_id = $P{accountofficeid}::int
 AND   a.DR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}::int
 AND   c.office_id=a.accounting_for_office_id 
 and   a.DR_ACCOUNT_HEAD_CODE=d.account_head_code 

 ) as opt42


 
   
 
 
) as opt421 

---WHERE DATEVALUE::varchar BETWEEN '2021-04-01' AND '2022-03031'
where datevalue between $P{txtfrom}::date and $P{txtto}::date
order by  document_type ,datevalue, voucher_no]]></queryString>

