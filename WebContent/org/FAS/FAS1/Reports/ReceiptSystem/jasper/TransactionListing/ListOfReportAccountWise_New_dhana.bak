<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ListOfReportAccountWise_New_dhana"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="814"
		 columnSpacing="0"
		 leftMargin="14"
		 rightMargin="14"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.String"/>
	<parameter name="PDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="RDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="VDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="DATEWISE" isForPrompting="true" class="java.lang.String"/>
	<parameter name="craccountheadcode" isForPrompting="true" class="java.lang.String"/>
	<parameter name="draccountheadcode" isForPrompting="true" class="java.lang.String"/>
	<parameter name="IBTDATEWISE" isForPrompting="true" class="java.lang.String"/>
	<parameter name="IBTDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fundTrfDate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthWise" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountheadcode1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="craccountheadcode1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="draccountheadcode1" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[-------------------------- PAYMENT (DR Transaction)---------------------------
(
SELECT DECODE(a.sub_ledger_type_code,1,'Supplier',2,'Firms',10,'Assets',4,'Cheque              
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme              
Owner',13,'Beneficiary','-') AS sub_ledger_type_code,
  d.ACCOUNT_HEAD_DESC,
  c.office_name,
  b.paid_to AS paid_to,
  a.sub_ledger_type_code,
  (SELECT sl_codeName
  FROM SL_TYPE_CODE_NAME_VIEW_M
  WHERE sl_type=a.sub_ledger_type_code
  AND sl_code  =a.SUB_LEDGER_CODE
  )              AS slcode,
  b.payment_date AS datevalue,
  d.ACCOUNT_HEAD_CODE,
  b.voucher_no AS voucher_no,
  'P'          AS document_type,
  a.CR_DR_INDICATOR,
  CASE
    WHEN a.CR_DR_INDICATOR = 'DR'
    THEN a.amount
    ELSE 0
  END AS dr_amt,
  CASE
    WHEN a.CR_DR_INDICATOR = 'CR'
    THEN a.amount
    ELSE 0
  END      AS cr_amt,
  a.amount AS amount,
  a.particulars,
  e.ACCOUNTING_UNIT_NAME
FROM fas_payment_transaction a,
  fas_payment_master b,
  COM_MST_OFFICES c,
  COM_MST_ACCOUNT_HEADS d,
  FAS_MST_ACCT_UNITS e
WHERE a.accounting_unit_id     = b.accounting_unit_id
AND a.accounting_for_office_id = b.accounting_for_office_id
AND a.cashbook_year            = b.cashbook_year
AND a.cashbook_month           = b.cashbook_month
AND a.voucher_no               = b.voucher_no
AND b.payment_status          <>'C'
AND c.office_id                =a.accounting_for_office_id
AND a.ACCOUNT_HEAD_CODE        =d.account_head_code
AND a.accounting_unit_id       = 42
AND a.accounting_for_office_id = 6869
AND e.ACCOUNTING_UNIT_ID       =42
AND
  --  b.cashbook_year=2011 and  b.cashbook_month =10
--  $p!{Accountheadcode} 
 -- $p!{Datewise} 
  b.payment_date between '01-Apr-11' and '31-Mar-12'
)
-------------------------- PAYMENT (CR Master)---------------------------
UNION ALL
  (SELECT DECODE(b.sub_ledger_type_code,1,'Supplier',2,'Firms',10,'Assets',4,'Cheque              
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme              
Owner',13,'Beneficiary','-') AS sub_ledger_type_code,
    D.Account_Head_Desc,
    c.office_name,
    b.paid_to AS paid_to,
    b.sub_ledger_type_code,
    (SELECT sl_codeName
    FROM SL_TYPE_CODE_NAME_VIEW_M
    WHERE sl_type=b.sub_ledger_type_code
    AND sl_code  =b.SUB_LEDGER_CODE
    )              AS slcode,
    b.payment_date AS datevalue,
    d.ACCOUNT_HEAD_CODE,
    b.voucher_no AS voucher_no,
    'P'          AS Document_Type,
    'CR'         AS Cr_Dr_Indicator,
    CASE
      WHEN CR_DR_INDICATOR = 'DR'
      THEN B.TOTAL_AMOUNT
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN CR_DR_INDICATOR = 'CR'
      THEN B.TOTAL_AMOUNT
      ELSE 0
    END            AS Cr_Amt,
    b.TOTAL_AMOUNT AS Amount,
    B.REMARKS      AS particulars,
    E.Accounting_Unit_Name
  FROM fas_payment_master b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE b.payment_status        <>'C'
  AND c.office_id                =b.accounting_for_office_id
  AND b.Account_Head_Code        =D.Account_Head_Code
  AND b.accounting_unit_id       = 42
  AND b.accounting_for_office_id = 6869
  AND E.Accounting_Unit_Id       =42
  AND
    --B.Cashbook_Year=2011 And  B.Cashbook_Month =10
    --$p!{Accountheadcode1} $p!{Datewise} 
    b.payment_date between '01-Apr-11' and '31-Mar-12'
  )
UNION ALL
  -------------------------- RECEIPT ---------------------------
  (
  SELECT DECODE(a.sub_ledger_type_code,1,'Supplier',2,'Firms',10,'Assets',4,'Cheque         
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme         
Owner',13,'Beneficiary','-')AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    b.received_from AS paid_to,
    a.sub_ledger_type_code,
    (SELECT sl_codeName
    FROM SL_TYPE_CODE_NAME_VIEW_M
    WHERE sl_type=a.sub_ledger_type_code
    AND sl_code  =a.SUB_LEDGER_CODE
    )              AS slcode,
    b.receipt_date AS datevalue,
    d.ACCOUNT_HEAD_CODE,
    b.receipt_no AS voucher_no ,
    'R'          AS document_type,
    a.CR_DR_INDICATOR,
    CASE
      WHEN a.CR_DR_INDICATOR = 'DR'
      THEN a.amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN a.CR_DR_INDICATOR = 'CR'
      THEN a.amount
      ELSE 0
    END      AS cr_amt,
    a.amount AS amount,
    a.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM fas_receipt_transaction a,
    fas_receipt_master b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE a.accounting_unit_id     = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.receipt_no               = b.receipt_no
  AND b.receipt_status          <>'C'
  AND c.office_id                =a.accounting_for_office_id
  AND a.ACCOUNT_HEAD_CODE        =d.account_head_code
  AND a.accounting_unit_id       = 42
  AND a.accounting_for_office_id = 6869
  AND e.ACCOUNTING_UNIT_ID       =42
  AND
    --  b.cashbook_year=2011 and  b.cashbook_month = 10
    --$p!{Accountheadcode} $p!{Datewise} 
    b.receipt_date between '01-Apr-11' and '31-Mar-12'
  )
--------receipt (Mas)--------
UNION ALL
  (SELECT DECODE(b.sub_ledger_type_code,1,'Supplier',2,'Firms',10,'Assets',4,'Cheque         
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme         
Owner',13,'Beneficiary','-')AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    b.received_from AS paid_to,
    b.sub_ledger_type_code,
    (SELECT sl_codeName
    FROM SL_TYPE_CODE_NAME_VIEW_M
    WHERE sl_type=b.sub_ledger_type_code
    AND sl_code  =b.SUB_LEDGER_CODE
    )              AS slcode,
    b.receipt_date AS datevalue,
    d.ACCOUNT_HEAD_CODE,
    b.receipt_no AS voucher_no ,
    'R'          AS document_type,
    b.CR_DR_INDICATOR,
    CASE
      WHEN b.CR_DR_INDICATOR = 'DR'
      THEN b.TOTAL_AMOUNT
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN b.CR_DR_INDICATOR = 'CR'
      THEN b.TOTAL_AMOUNT
      ELSE 0
    END            AS cr_amt,
    B.Total_Amount AS Amount,
    b.REMARKS      AS particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM fas_receipt_master b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE b.receipt_status        <>'C'
  AND c.office_id                =b.accounting_for_office_id
  AND b.ACCOUNT_HEAD_CODE        =d.account_head_code
  AND b.accounting_unit_id       = 42
  AND b.accounting_for_office_id = 6869
  AND e.ACCOUNTING_UNIT_ID       =42
  AND
    --B.Cashbook_Year=2011 And  B.Cashbook_Month = 10
    --$P!{accountheadcode1} $P!{DATEWISE} 
    b.receipt_date between '01-Apr-11' and '31-Mar-12'
  )
UNION ALL
  -------------------------- JOURNAL  ---------------------------
  (
  SELECT DECODE(a.sub_ledger_type_code,1,'Supplier',2,'Firms',10,'Assets',4,'Cheque      
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme      
Owner',13,'Beneficiary','-')AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    ' ' AS paid_to,
    a.sub_ledger_type_code,
    (SELECT sl_codeName
    FROM SL_TYPE_CODE_NAME_VIEW_M
    WHERE sl_type=a.sub_ledger_type_code
    AND sl_code  =a.SUB_LEDGER_CODE
    )              AS slcode,
    b.voucher_date AS datevalue,
    d.ACCOUNT_HEAD_CODE,
    b.voucher_no AS voucher_no ,
    'J'          AS document_type,
    a.CR_DR_INDICATOR,
    CASE
      WHEN a.CR_DR_INDICATOR = 'DR'
      THEN a.amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN a.CR_DR_INDICATOR = 'CR'
      THEN a.amount
      ELSE 0
    END      AS cr_amt,
    a.amount AS amount,
    a.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM fas_journal_transaction a,
    fas_journal_master b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE a.accounting_unit_id     =b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.voucher_no               = b.voucher_no
  AND b.journal_status          <>'C'
  AND c.office_id                =a.accounting_for_office_id
  AND a.ACCOUNT_HEAD_CODE        =d.account_head_code
  AND a.accounting_unit_id       =42
  AND a.accounting_for_office_id =6869
  AND e.ACCOUNTING_UNIT_ID       =42
  AND
    -- b.cashbook_year=2011 and  b.cashbook_month = 10
    --$p!{Accountheadcode} $p!{Datewise} 
    b.voucher_date between '01-Apr-11' and '31-Mar-12'
  )
UNION ALL
  -----------------IBT(CR)-----------
  (
  SELECT '' AS sub_ledger_type_code,
    ACCOUNT_HEAD_DESC,
    office_name,
    '' AS Paid_To,
    0  AS sub_ledger_type_code,
    slcode,
    Date_Of_Transfer     AS Datevalue,
    CR_ACCOUNT_HEAD_CODE AS account_head_code,
    voucher_no           AS voucher_no,
    'IBT1'               AS document_type,
    cr_dr_indicator,
    CASE
      WHEN cr_dr_indicator = 'DR'
      THEN amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN cr_dr_indicator = 'CR'
      THEN amount
      ELSE 0
    END AS cr_amt,
    amount,
    PARTICULARS,
    ACCOUNTING_UNIT_NAME
  FROM
    (SELECT '' AS sub_ledger_type_code_desc,
      CR_ACCOUNT_HEAD_CODE,
      Date_Of_Transfer,
      d.ACCOUNT_HEAD_DESC,
      c.office_name,
      ''               AS paid_received,
      ''               AS slcode,
      Date_Of_Transfer AS Datevalue,
      a.VOUCHER_NO     AS voucher_no,
      'IBT'            AS document_type,
      'CR'             AS Cr_Dr_Indicator,
      Total_Amount     AS amount,
      PARTICULARS ,
      e.ACCOUNTING_UNIT_NAME
    FROM fas_inter_bank_trf_at_ho a,
      COM_MST_OFFICES c,
      Com_Mst_Account_Heads D,
      FAS_MST_ACCT_UNITS e
    WHERE a.TRANSFER_STATUS       <>'C'
    AND a.accounting_unit_id       = 42
    AND A.Accounting_For_Office_Id = 6869
    AND e.ACCOUNTING_UNIT_ID       =42
      --and   a.cashbook_year = 2011 and   a.cashbook_month = 12
    AND c.office_id           =a.accounting_for_office_id
    And A.Cr_Account_Head_Code=D.Account_Head_Code
    --AND $P!{craccountheadcode1} $P!{IBTDATEWISE}
  and   a.DATE_OF_TRANSFER between '01-Apr-11' and '31-Mar-12'
    )
  )
UNION ALL
  -------------------------- IBT (dr) ---------------------------
  (
  SELECT '' AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    ''                     AS paid_to,
    0                      AS sub_ledger_type_code,
    ''                     AS slcode,
    a.DATE_OF_TRANSFER     AS datevalue,
    a.DR_ACCOUNT_HEAD_CODE AS account_head_code,
    a.voucher_no           AS voucher_no,
    'IBT'                  AS document_type,
    'DR'                   AS CR_DR_INDICATOR,
    a.TOTAL_AMOUNT         AS dr_amt,
    0                      AS cr_amt,
    a.TOTAL_AMOUNT         AS amount,
    a.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM fas_inter_bank_trf_at_ho a,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE c.office_id             =a.accounting_for_office_id
  AND a.DR_ACCOUNT_HEAD_CODE    =d.account_head_code
  AND a.accounting_unit_id      =42
  AND a.accounting_for_office_id=6869
  AND a.TRANSFER_STATUS         ='L'
  AND e.ACCOUNTING_UNIT_ID      =42
  AND
    --  a.cashbook_year=2011 and  a.cashbook_month = 10
    --$p!{Draccountheadcode} $p!{Ibtdatewise} 
    a.DATE_OF_TRANSFER between '01-Apr-11' and '31-Mar-12'
  )
UNION ALL
  -------------------------- FR (cr) ---------------------------
  (
  SELECT 'Bank' AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    -- b.OFFICE_ACCOUNT_NO as slcode,
    ''                     AS slcode,
    b.RECEIPT_DATE         AS datevalue,
    b.CR_ACCOUNT_HEAD_CODE AS account_head_code,
    b.RECEIPT_NO           AS voucher_no,
    'FR'                   AS document_type,
    'CR'                   AS CR_DR_INDICATOR,
    0                      AS dr_amt,
    b.total_amount         AS cr_amt,
    b.total_amount         AS amount,
    b.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM FAS_FUND_RECEIPT_BY_OFFICE b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE b.receipt_status        <>'C'
  AND c.office_id                =b.accounting_for_office_id
  AND b.CR_ACCOUNT_HEAD_CODE     =d.account_head_code
  AND b.accounting_unit_id       = 42
  AND b.accounting_for_office_id = 6869
  AND e.ACCOUNTING_UNIT_ID       =42
  AND
    --  b.cashbook_year=2011 and  b.cashbook_month = 10
   -- $P!{craccountheadcode1} $P!{DATEWISE}
    b.receipt_date between '01-Apr-11' and '31-Mar-12'
  )
UNION ALL
  -------------------------- FR (dr) ---------------------------
  (
  SELECT 'Bank' AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    -- b.OFFICE_ACCOUNT_NO as slcode,
    ''                     AS slcode,
    b.RECEIPT_DATE         AS datevalue,
    b.DR_ACCOUNT_HEAD_CODE AS account_head_code,
    b.RECEIPT_NO           AS voucher_no,
    'FR'                   AS document_type,
    'DR'                   AS CR_DR_INDICATOR,
    b.total_amount         AS dr_amt,
    0                      AS cr_amt,
    b.total_amount         AS amount,
    b.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM FAS_FUND_RECEIPT_BY_OFFICE b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE b.receipt_status        <>'C'
  AND c.office_id                =b.accounting_for_office_id
  AND b.DR_ACCOUNT_HEAD_CODE     =d.account_head_code
  AND b.accounting_unit_id       = 42
  AND b.accounting_for_office_id = 6869
  AND e.ACCOUNTING_UNIT_ID       =42
  AND
    --  $P!{draccountheadcode1} $P!{DATEWISE}
    b.receipt_date between '01-Apr-11' and '31-Mar-12'
  )
UNION ALL
  ----------------------FT(dr)---------------
  (
  SELECT 'Bank' AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    '' AS slcode,
    -- b.OFFICE_ACCOUNT_NO as slcode,
    b.DATE_OF_TRANSFER     AS datevalue,
    b.DR_ACCOUNT_HEAD_CODE AS account_head_code,
    b.VOUCHER_NO           AS voucher_no,
    'FT'                   AS document_type,
    'DR'                   AS CR_DR_INDICATOR,
    b.total_amount         AS dr_amt,
    0                      AS cr_amt,
    b.total_amount         AS amount,
    b.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM FAS_FUND_TRF_FROM_OFFICE b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE b.TRANSFER_STATUS       <>'C'
  AND c.office_id                =b.accounting_for_office_id
  AND b.DR_ACCOUNT_HEAD_CODE     =d.account_head_code
  AND b.accounting_unit_id       = 42
  AND b.accounting_for_office_id = 6869
  AND e.ACCOUNTING_UNIT_ID       =42
  AND
    --  b.cashbook_year=2011 and  b.cashbook_month = 10
    --$p!{Draccountheadcode1} $p!{Datewise} 
    b.DATE_OF_TRANSFER between '01-Apr-11' and '31-Mar-12'
  )
UNION ALL
  ----------------------FT(cr)---------------
  (
  SELECT 'Bank' AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    -- b.OFFICE_ACCOUNT_NO as slcode,
    ''                     AS slcode,
    b.DATE_OF_TRANSFER     AS datevalue,
    b.CR_ACCOUNT_HEAD_CODE AS account_head_code,
    b.VOUCHER_NO           AS voucher_no,
    'FT'                   AS document_type,
    'CR'                   AS CR_DR_INDICATOR,
    0                      AS dr_amt,
    b.total_amount         AS cr_amt,
    b.total_amount         AS amount,
    b.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM FAS_FUND_TRF_FROM_OFFICE b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE b.TRANSFER_STATUS       <>'C'
  AND c.office_id                =b.accounting_for_office_id
  AND b.CR_ACCOUNT_HEAD_CODE     =d.account_head_code
  AND b.accounting_unit_id       = 42
  AND b.accounting_for_office_id = 6869
  AND e.ACCOUNTING_UNIT_ID       =42
  AND
    -- b.cashbook_year=2011 and  b.cashbook_month = 10
   -- $p!{Craccountheadcode1} $p!{Datewise} 
    b.DATE_OF_TRANSFER between '01-Apr-11' and '31-Mar-12'
  )
UNION ALL
  -------------------receipt by HO-(cr)-------------
  (
  SELECT 'Bank' AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    -- b.OFFICE_ACCOUNT_NO as slcode,
    ''                     AS slcode,
    b.RECEIPT_DATE         AS datevalue,
    b.CR_ACCOUNT_HEAD_CODE AS account_head_code,
    b.RECEIPT_NO           AS voucher_no,
    'FT'                   AS document_type,
    'CR'                   AS Cr_Dr_Indicator,
    0                      AS dr_amt,
    b.total_amount         AS cr_amt,
    b.total_amount         AS amount,
    b.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM FAS_FUND_RECEIPT_BY_HO b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE b.RECEIPT_STATUS        <>'C'
  AND c.office_id                =b.accounting_for_office_id
  AND b.CR_ACCOUNT_HEAD_CODE     =d.account_head_code
  AND B.Accounting_Unit_Id       = 42
  AND b.accounting_for_office_id = 6869
  And E.Accounting_Unit_Id       =42
 -- And $p!{Craccountheadcode1} $p!{Datewise} 
 and  b.receipt_date between '01-Apr-11' and '31-Mar-12'
    --  b.cashbook_year=2011 and  b.cashbook_month = 12
  )
UNION ALL
  -------------------receipt by HO-(dr)-------------
  (
  SELECT 'Bank' AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    -- b.OFFICE_ACCOUNT_NO as slcode,
    ''                     AS slcode,
    b.RECEIPT_DATE         AS datevalue,
    b.DR_ACCOUNT_HEAD_CODE AS account_head_code,
    B.Receipt_No           AS Voucher_No,
    'FRH'                  AS Document_Type,
    'DR'                   AS Cr_Dr_Indicator,
    B.Total_Amount         AS Dr_Amt,
    0                      AS cr_amt,
    b.total_amount         AS amount,
    b.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM FAS_FUND_RECEIPT_BY_HO b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE b.RECEIPT_STATUS        <>'C'
  AND c.office_id                =b.accounting_for_office_id
  AND b.DR_ACCOUNT_HEAD_CODE     =d.account_head_code
  AND B.Accounting_Unit_Id       = 42
  AND b.accounting_for_office_id = 6869
  AND e.ACCOUNTING_UNIT_ID       =42
  AND
    --  b.cashbook_year=2011 and  b.cashbook_month = 12
  --  $P!{draccountheadcode1} $P!{DATEWISE}
   b.receipt_date between '01-Apr-11' and '31-Mar-12'
  )
UNION ALL
  -------------------FUND_TRF_FROM_HO_TRN--(DR)------------
  (
  SELECT 'Bank' AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    -- b.OFFICE_ACCOUNT_NO as slcode,
    ''                 AS Slcode,
    b.DATE_OF_TRANSFER AS datevalue,
    d.ACCOUNT_HEAD_CODE,
    B.Voucher_No AS Voucher_No,
    'FTH'        AS Document_Type,
    'DR'         AS CR_DR_INDICATOR,
    CASE
      WHEN a.CR_DR_INDICATOR = 'DR'
      THEN a.amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN a.CR_DR_INDICATOR = 'CR'
      THEN a.amount
      ELSE 0
    END      AS cr_amt,
    a.amount AS amount,
    a.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM FAS_FUND_TRF_FROM_HO_TRN a,
    FAS_FUND_TRF_FROM_HO_MASTER b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE a.accounting_unit_id     = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.voucher_no               = b.voucher_no
  AND b.TRANSFER_STATUS         <>'C'
  AND c.office_id                =a.accounting_for_office_id
  AND a.ACCOUNT_HEAD_CODE        =d.account_head_code
  AND A.Accounting_Unit_Id       = 42
  AND a.accounting_for_office_id = 6869
  AND e.ACCOUNTING_UNIT_ID       =42
  AND
    -- b.cashbook_year=2011 and  b.cashbook_month = 12
   -- $P!{draccountheadcode1} $P!{DATEWISE}
    b.DATE_OF_TRANSFER between '01-Apr-11' and '31-Mar-12'
  )
UNION ALL
  -------------------FUND_TRF_FROM_HO_TRN--(CR)------------
  (
  SELECT 'Bank' AS sub_ledger_type_code,
    d.ACCOUNT_HEAD_DESC,
    c.office_name,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    -- b.OFFICE_ACCOUNT_NO as slcode,
    ''                 AS Slcode,
    b.DATE_OF_TRANSFER AS datevalue,
    d.ACCOUNT_HEAD_CODE,
    B.Voucher_No AS Voucher_No,
    'FTH'        AS Document_Type,
    'CR'         AS CR_DR_INDICATOR,
    0            AS dr_amt,
    a.amount     AS cr_amt,
    a.amount     AS amount,
    a.particulars,
    e.ACCOUNTING_UNIT_NAME
  FROM FAS_FUND_TRF_FROM_HO_TRN a,
    FAS_FUND_TRF_FROM_HO_MASTER b,
    COM_MST_OFFICES c,
    COM_MST_ACCOUNT_HEADS d,
    FAS_MST_ACCT_UNITS e
  WHERE a.accounting_unit_id     = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.voucher_no               = b.voucher_no
  AND b.TRANSFER_STATUS         <>'C'
  AND c.office_id                =a.accounting_for_office_id
  AND a.ACCOUNT_HEAD_CODE        =d.account_head_code
  AND A.Accounting_Unit_Id       = 42
  AND a.accounting_for_office_id = 6869
  AND e.ACCOUNTING_UNIT_ID       =42
  AND
    -- b.cashbook_year=2011 and  b.cashbook_month = 12
  --  $p!{Craccountheadcode1} $p!{Datewise} 
    b.DATE_OF_TRANSFER between '01-Apr-11' and '31-Mar-12'
  )
ORDER BY ACCOUNT_HEAD_CODE,
  datevalue,
  voucher_no]]></queryString>

