	<queryString><![CDATA[SELECT a.ACCOUNTING_UNIT_ID AS ACCOUNTING_UNIT_ID,
a.ACCOUNT_HEAD_CODE AS ACCOUNT_HEAD_CODE,
a.CURRENT_MONTH_DEBIT AS CURRENT_MONTH_DEBIT,
a.CURRENT_MONTH_CREDIT AS CURRENT_MONTH_CREDIT,
b.ACCOUNTING_UNIT_NAME AS ACCOUNTING_UNIT_NAME,
c.ACCOUNT_HEAD_DESC AS ACCOUNT_HEAD_DESC
FROM fas_trail_balance_data_9507 a,
fas_mst_accnt_unit_old9507 b,
com_mst_account_heads c
WHERE a.accounting_unit_id=b.accounting_unit_id
AND a.ACCOUNT_HEAD_CODE=c.ACCOUNT_HEAD_CODE
AND a.accounting_unit_id=$P{acunitId}
and cashbook_year=$P{cbYear}
AND cashbook_month=$P{cbMonth}
ORDER BY accounting_unit_id,
a.account_head_code]]></queryString>

