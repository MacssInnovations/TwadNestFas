	<queryString><![CDATA[select a.bank_id,a.bank_name,branch_name,c.bank_ac_no,c.ac_operational_mode_id,C.STATUS,d.accounting_unit_name
from fas_mst_banks a,fas_mst_bank_branches b,fas_mst_bank_balance c,fas_mst_acct_units d
where a.bank_id=c.bank_id and b.bank_id=c.bank_id
and b.branch_id=c.branch_id and d.accounting_unit_id=c.accounting_unit_id
and c.accounting_unit_id=$P{acunitid}]]></queryString>

