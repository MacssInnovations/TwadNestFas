	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[
select 
      to_char ( x.receipt_date,'DD-MM-YYYY') as receipt_date ,
       sum(case when x.receipt_type='C' then x.total_amount else 0 end ) as c, 
       sum(case when x.receipt_type='B' then x.total_amount else 0 end ) as b, 
       x.accounting_unit_id, 
       x.cashbook_month, 
       x.cashbook_year , 
       y.accounting_unit_name
from 
     fas_receipt_master x, 
     fas_mst_acct_units y
where 
     x.accounting_unit_id=$P{accountingunitid} and 
     x.ACCOUNTING_FOR_OFFICE_ID=$P{accountingofficeid} and 
     x.cashbook_year=$P{cashbookyear} and 
     x.cashbook_month=$P{cashbookmonth} and 
     x.accounting_unit_id=y.accounting_unit_id and 
     x.receipt_status = 'L' and 
     x.created_by_module ! ='SC'
     
group by x.receipt_date  , x.accounting_unit_id, x.cashbook_month,  x.cashbook_year , y.accounting_unit_name  order by x.receipt_date
]]></queryString>

	<field name="RECEIPT_DATE" class="java.lang.String"/>
	<field name="C" class="java.math.BigDecimal"/>
	<field name="B" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>

	<variable name="SUM_C_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
