	<parameter name="cashbook_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbook_year" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,total_cr_780406,total_dr_780406,
total_cr_160502,total_cr_160611,accounting_unit_name,
((total_cr_780406)+(total_cr_160611)) as total,
decode(cashbook_month,1,'January',2,'February',3,'March',4,'April',5,'May',6,'June',7,'July',8,'August',9,'September',10,'October',11,'November',12,'December') as mon
from
(
select accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,
sum(cr_780406) as total_cr_780406,sum(dr_780406) as total_dr_780406,sum(cr_160502) as total_cr_160502,
sum(cr_160611) as total_cr_160611
from
(
select accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_head_code,cr_dr_indicator,
sum(credited_amount) as total_credited,sum(debited_amount) as total_debited,
decode(account_head_code,'780406',decode(cr_dr_indicator,'CR',sum(credited_amount),0),0) as cr_780406,
decode(account_head_code,'780406',decode(cr_dr_indicator,'DR',sum(debited_amount),0),0) as dr_780406,
decode(account_head_code,'160502',decode(cr_dr_indicator,'CR',sum(credited_amount),0),0) as cr_160502,
decode(account_head_code,'160611',decode(cr_dr_indicator,'CR',sum(credited_amount),0),0) as cr_160611
from
(
select a.accounting_unit_id,a.accounting_for_office_id,a.cashbook_year,a.cashbook_month,a.account_head_code,
a.cr_dr_indicator,a.credited_amount,a.debited_amount from
(
select accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_head_code,
cr_dr_indicator,amount,
decode(cr_dr_indicator,'CR',amount,0) as credited_amount,
decode(cr_dr_indicator,'DR',amount,0) as debited_amount from fas_receipt_transaction
) a
left outer join
(
select accounting_unit_id as acct_unit_id,accounting_for_office_id as acc_office_id,cashbook_year,cashbook_month,
account_head_code as acc_head_cd,
cr_dr_indicator,total_amount,receipt_status,
decode(cr_dr_indicator,'CR',total_amount,0) as credited_amount,
decode(cr_dr_indicator,'DR',total_amount,0) as debited_amount from fas_receipt_master
where receipt_status='L' 
) b
on a.accounting_unit_id=b.acct_unit_id and a.accounting_for_office_id=b.acc_office_id and 
a.account_head_code=b.acc_head_cd
where a.account_head_code in (160502,780406,160611)

union all

select a.accounting_unit_id,a.accounting_for_office_id,a.cashbook_year,a.cashbook_month,a.account_head_code,
a.cr_dr_indicator,a.credited_amount,a.debited_amount from
(
select accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_head_code,
cr_dr_indicator,decode(cr_dr_indicator,'CR',amount,0) as credited_amount,
decode(cr_dr_indicator,'DR',amount,0) as debited_amount from fas_payment_transaction
) a
left outer join
(
select accounting_unit_id as acc_unit_id,accounting_for_office_id as acc_office_id,cashbook_year,cashbook_month,
account_head_code as acc_head_code,cr_dr_indicator,payment_status,
decode(cr_dr_indicator,'CR',total_amount,0) as credited_amount,
decode(cr_dr_indicator,'DR',total_amount,0) as debited_amount from fas_payment_master
where payment_status='L' 
) b
on a.accounting_unit_id=b.acc_unit_id and a.accounting_for_office_id=b.acc_office_id and
a.account_head_code=b.acc_head_code
where a.account_head_code in (160502,780406,160611)

union all

select a.accounting_unit_id, a.accounting_for_office_id, a.cashbook_year, a.cashbook_month, a.account_head_code, a.cr_dr_indicator,
a.credit_amount, a.debit_amount from
(
select accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_head_code,cr_dr_indicator,
decode(cr_dr_indicator,'CR',amount,0) as credit_amount,
decode(cr_dr_indicator,'DR',amount,0) as debit_amount from fas_journal_transaction
) a
left outer join
(
select ACCOUNTING_UNIT_ID as acct_unit_id1, ACCOUNTING_FOR_OFFICE_ID as acct_off_id1, CASHBOOK_YEAR,
CASHBOOK_MONTH, JOURNAL_STATUS from FAS_JOURNAL_MASTER
where JOURNAL_STATUS='L'
) b
on a.accounting_unit_id=b.acct_unit_id1 and a.accounting_for_office_id=b.acct_off_id1
where a.account_head_code in (160502,780406,160611)
)
group by accounting_unit_id,accounting_for_office_id,account_head_code,cashbook_year,cashbook_month,cr_dr_indicator
)
group by accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month
) cc
left outer join
(
select accounting_unit_id as acct_unit_id,accounting_unit_name,accounting_unit_office_id from FAS_MST_ACCT_UNITS
) dd
on cc.accounting_unit_id=dd.acct_unit_id and cc.accounting_for_office_id=dd.accounting_unit_office_id
where cc.cashbook_month=($P{cashbook_mon}) and cc.cashbook_year=($P{cashbook_year})
order by accounting_unit_id]]></queryString>

