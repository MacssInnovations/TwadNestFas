	<queryString><![CDATA[select 

  a.ACCOUNT_HEAD_CODE ,
  b.ACCOUNT_HEAD_DESC,
  a.SCHEDULE_ID
from 
   FAS_SCHEDULEMASTER a,
   COM_MST_ACCOUNT_HEADS b 

where 
   a.ACCOUNT_HEAD_CODE=b.ACCOUNT_HEAD_CODE

order by schedule_id, account_head_code]]></queryString>

