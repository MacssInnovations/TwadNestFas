	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select a.voucher_no,a.payment_date,a.bank_id,a.branch_id,a.paid_to,b.CHEQUE_DD_NO,b.CHEQUE_DD_DATE,b.amount,b.particulars,
c.accounting_unit_name,d.office_short_name,e.branch_name,f.BANK_NAME,e.micr_code from fas_payment_master a,
fas_payment_transaction b,fas_mst_acct_units c,com_mst_offices d,fas_mst_bank_branches e,fas_mst_banks f where 
a.cashbook_month=b.cashbook_month and a.cashbook_year=b.cashbook_year
and a.accounting_unit_id=b.accounting_unit_id and
a.accounting_for_office_id=b.accounting_for_office_id and
a.voucher_no=b.voucher_no and
c.accounting_unit_id=a.accounting_unit_id and
d.office_id=a.accounting_for_office_id and
e.bank_id=a.bank_id and
e.branch_id=a.branch_id and
f.bank_id=e.bank_id and
a.payment_status<>'C' and
a.payment_type='B' and a.cashbook_year=($P{cashbookyear})
and a.cashbook_month=($P{cashbookmonth}) and a.accounting_unit_id=($P{accountingunitid})
and a.accounting_for_office_id=($P{accountofficeid})
order by b.bank_id,a.payment_date,a.voucher_no]]></queryString>

