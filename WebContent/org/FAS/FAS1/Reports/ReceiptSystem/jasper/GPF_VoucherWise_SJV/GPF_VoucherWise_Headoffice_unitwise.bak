	<variable name="SUM_DEBIT_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="unitname" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_CREDIT_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="unitname" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_NET_AMT_1" class="java.lang.String" resetType="Group" resetGroup="unitname" calculation="Sum">
		<variableExpression><![CDATA[(($V{SUM_DEBIT_AMT_1}.subtract($V{SUM_CREDIT_AMT_1})).intValue()<0) ? ($V{SUM_CREDIT_AMT_1}.subtract($V{SUM_DEBIT_AMT_1}))+"CR" : ($V{SUM_DEBIT_AMT_1}.subtract($V{SUM_CREDIT_AMT_1}))+"DR"]]></variableExpression>
	</variable>
	<variable name="grant_debit" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_AMT}]]></variableExpression>
	</variable>
	<variable name="grant_credit" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_AMT}]]></variableExpression>
	</variable>
	<variable name="netTotal" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[(($V{grant_debit}.subtract($V{grant_credit})).intValue()<0) ? ($V{grant_credit}.subtract($V{grant_debit}))+"CR" : ($V{grant_debit}.subtract($V{grant_credit}))+"DR"]]></variableExpression>
	</variable>

