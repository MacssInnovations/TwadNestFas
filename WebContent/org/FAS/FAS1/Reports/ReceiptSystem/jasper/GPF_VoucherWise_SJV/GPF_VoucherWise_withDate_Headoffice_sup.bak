<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPF_VoucherWise_withDate_Headoffice_sup"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1077"
		 pageHeight="842"
		 columnWidth="1017"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sortingorder" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="supno" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT
  (SELECT accounting_unit_name
  FROM fas_mst_acct_units
  WHERE accounting_unit_id = unitid
  ) AS unitname,
  accounting_for_office_id,
  cashbook_month,
  cashbook_year,
  doc_no,
  doc_date,
  (SELECT account_head_desc
  FROM com_mst_account_heads
  WHERE account_head_code = acchead
  ) account_head_desc,
  debit_amt,
  credit_amt,
  PARTICULARS,
  -(debit_amt - credit_amt ) AS net_amt,
  acchead,
  Unitid,
  doc_type,
  Type_Desc,
  code_desc
FROM
  (SELECT accounting_unit_id AS unitid ,
    accounting_for_office_id,
    cashbook_month,
    cashbook_year,
    doc_no,
    doc_date,
    account_head_code AS acchead,
    CASE
      WHEN cr_dr_indicator ='DR'
      THEN amount
      ELSE 0
    END AS debit_amt,
    CASE
      WHEN cr_dr_indicator ='CR'
      THEN amount
      ELSE 0
    END AS credit_amt ,
    Particulars,
    doc_type,
    Type_Desc,
    code_desc
  FROM
    (
    -- Receipt
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.receipt_no   AS doc_no,
      m.RECEIPT_DATE AS doc_date,
      t.account_head_code,
      t.amount,
      t.CR_DR_INDICATOR,
      t.PARTICULARS,
      'R' AS doc_type,
      (SELECT S.Sub_Ledger_Type_Desc
      FROM Com_Mst_Sl_Types S
      WHERE S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code
      )AS Type_Desc,
      (SELECT V.Sl_Codename
      FROM Sl_Type_Code_Name_View_M v
      WHERE V.Sl_Type=T.Sub_Ledger_Type_Code
      AND V.Sl_Code  =T.Sub_Ledger_Code
      limit 1
      )AS code_desc
    FROM fas_receipt_master m,
      fas_receipt_transaction t
    WHERE m.ACCOUNTING_UNIT_ID     = t.ACCOUNTING_UNIT_ID
    AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
    AND m.CASHBOOK_YEAR            = t.CASHBOOK_YEAR
    AND m.CASHBOOK_MONTH           = t.CASHBOOK_MONTH
    AND m.RECEIPT_NO               = t.RECEIPT_NO
    AND M.Receipt_Status           ='L'
    AND M.Receipt_Date BETWEEN $P{fromdate}::date AND $P{todate}::date
    AND t.account_head_code = $P{accountheadcode}::numeric
    UNION ALL
    -- Payment
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.VOUCHER_NO   AS doc_no ,
      m.PAYMENT_DATE AS doc_date,
      t.account_head_code,
      t.amount,
      t.CR_DR_INDICATOR,
      t.PARTICULARS,
      'P' AS doc_type,
      (SELECT S.Sub_Ledger_Type_Desc
      FROM Com_Mst_Sl_Types S
      WHERE S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code
      )AS Type_Desc,
      (SELECT V.Sl_Codename
      FROM Sl_Type_Code_Name_View_M v
      WHERE V.Sl_Type=T.Sub_Ledger_Type_Code
      AND V.SL_CODE  =T.SUB_LEDGER_CODE
      )AS code_desc
    FROM fas_payment_master m,
      fas_payment_transaction t
    WHERE m.ACCOUNTING_UNIT_ID     = t.ACCOUNTING_UNIT_ID
    AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
    AND m.CASHBOOK_YEAR            = t.CASHBOOK_YEAR
    AND m.CASHBOOK_MONTH           = t.CASHBOOK_MONTH
    AND m.VOUCHER_NO               = t.VOUCHER_NO
    AND M.Payment_Status           ='L'
    AND m.PAYMENT_DATE BETWEEN $P{fromdate}::date AND $P{todate}::date
    AND t.account_head_code = $P{accountheadcode}::numeric
    UNION ALL
    -- Journal
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.VOUCHER_NO   AS doc_no,
      m.VOUCHER_DATE AS doc_date,
      t.account_head_code,
      t.amount,
      t.CR_DR_INDICATOR,
      t.PARTICULARS,
      'J' AS Doc_Type,
      (SELECT S.Sub_Ledger_Type_Desc
      FROM Com_Mst_Sl_Types S
      WHERE S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code
      )AS Type_Desc,
      (SELECT V.Sl_Codename
      FROM Sl_Type_Code_Name_View_M v
      WHERE V.Sl_Type=T.Sub_Ledger_Type_Code
      AND V.Sl_Code  =T.Sub_Ledger_Code
      )AS code_desc
    FROM fas_journal_master m,
      fas_journal_transaction t
    WHERE m.ACCOUNTING_UNIT_ID     = t.ACCOUNTING_UNIT_ID
    AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
    AND m.CASHBOOK_YEAR            = t.CASHBOOK_YEAR
    AND m.CASHBOOK_MONTH           = t.CASHBOOK_MONTH
    AND m.VOUCHER_NO               = t.VOUCHER_NO
    AND M.Journal_Status           ='L'
    AND m.VOUCHER_DATE BETWEEN $P{fromdate}::date AND $P{todate}::date
    AND t.account_head_code  = $P{accountheadcode}::numeric
    AND M.Created_By_Module IN ('GJV','LJV')
    --journal SJV
    UNION ALL
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.VOUCHER_NO   AS doc_no,
      m.VOUCHER_DATE AS doc_date,
      t.account_head_code,
      t.amount,
      t.CR_DR_INDICATOR,
      t.PARTICULARS,
      'J' AS Doc_Type,
      (SELECT S.Sub_Ledger_Type_Desc
      FROM Com_Mst_Sl_Types S
      WHERE S.SUB_LEDGER_TYPE_CODE=T.SUB_LEDGER_TYPE_CODE
     limit 1
      )AS Type_Desc,
      (SELECT V.Sl_Codename
      FROM Sl_Type_Code_Name_View_M v
      WHERE V.Sl_Type=T.Sub_Ledger_Type_Code
      AND V.SL_CODE  =T.SUB_LEDGER_CODE
      limit 1
      )AS code_desc
    FROM fas_journal_master m,
      fas_journal_transaction t
    WHERE m.ACCOUNTING_UNIT_ID     = t.ACCOUNTING_UNIT_ID
    AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
    AND m.CASHBOOK_YEAR            = t.CASHBOOK_YEAR
    AND m.CASHBOOK_MONTH           = t.CASHBOOK_MONTH
    AND m.VOUCHER_NO               = t.VOUCHER_NO
    AND M.Journal_Status           ='L'
    AND m.VOUCHER_DATE BETWEEN $P{fromdate}::date AND $P{todate}::date
    AND T.Account_Head_Code  = $P{accountheadcode}::numeric
    AND M.Created_By_Module IN ('SJV')
    AND M.Supplement_No     <=$P{supno}::numeric
    UNION ALL
    -- FUND TRANSFER FROM OFFICE
    SELECT accounting_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      cashbook_month,
      cashbook_year,
      VOUCHER_NO       AS doc_no,
      DATE_OF_TRANSFER AS doc_date,
      dr_account_head_code,
      TOTAL_AMOUNT,
      'DR' AS CR_DR_INDICATOR ,
      PARTICULARS ,
      'FT from Off' AS doc_type,
      '-'           AS Type_Desc,
      '-'           AS code_desc
    FROM Fas_Fund_Trf_From_Office
    WHERE DATE_OF_TRANSFER BETWEEN $P{fromdate}::date AND $P{todate}::date
    AND Transfer_Status      = 'L'
    AND dr_account_head_code = $P{accountheadcode}::numeric
    UNION ALL
    --FUND RECEIPT BY HO
    SELECT accounting_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      cashbook_month,
      cashbook_year,
      RECEIPT_NO   AS doc_no ,
      Receipt_Date AS Doc_Date,
      dr_account_head_code,
      TOTAL_AMOUNT,
      'DR' AS CR_DR_INDICATOR ,
      Particulars,
      'FR By HO' AS Doc_Type,
      '-'        AS Type_Desc,
      '-'        AS code_desc
    FROM Fas_Fund_Receipt_By_Ho
    WHERE RECEIPT_DATE BETWEEN $P{fromdate}::date AND $P{todate}::date
    AND receipt_status       ='L'
    AND Dr_Account_Head_Code = $P{accountheadcode}::numeric
    UNION ALL
    SELECT accounting_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      cashbook_month,
      cashbook_year,
      RECEIPT_NO   AS doc_no ,
      Receipt_Date AS Doc_Date,
      cr_account_head_code,
      Total_Amount,
      'CR' AS CR_DR_INDICATOR ,
      Particulars,
      'FR By HO' AS Doc_Type,
      '-'        AS Type_Desc,
      '-'        AS code_desc
    FROM Fas_Fund_Receipt_By_Ho
    WHERE RECEIPT_DATE BETWEEN $P{fromdate}::date AND $P{todate}::date
    AND Receipt_Status       ='L'
    AND CR_ACCOUNT_HEAD_CODE = $P{accountheadcode}::numeric
    UNION ALL
    -- FUND RECEIPT BY OFFICE
    SELECT accounting_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      cashbook_month,
      cashbook_year,
      RECEIPT_NO   AS doc_no ,
      RECEIPT_DATE AS doc_date,
      cr_account_head_code,
      TOTAL_AMOUNT,
      'CR' AS CR_DR_INDICATOR ,
      PARTICULARS ,
      'FR By HO' AS doc_type,
      '-'        AS Type_Desc,
      '-'        AS code_desc
    FROM Fas_Fund_Receipt_By_Office
    WHERE RECEIPT_DATE BETWEEN $P{fromdate}::date AND $P{todate}::date
    AND receipt_status      ='L'
    AND cr_account_head_code=$P{accountheadcode}::numeric
    UNION ALL
    -- FUND TRANSFER FROM HO TRANSACTION
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.VOUCHER_NO       AS doc_no,
      m.DATE_OF_TRANSFER AS doc_date,
      t.account_head_code,
      t.AMOUNT,
      t.CR_DR_INDICATOR,
      t.PARTICULARS,
      ( 'FT from HO'
      ||' to '
      ||
      (SELECT accounting_unit_name
      FROM fas_mst_acct_units
      WHERE accounting_unit_office_id= t.TRANSFER_TO_OFFICE_ID
      ) ) AS Doc_Type,
      '-' AS Type_Desc,
      '-' AS code_desc
    FROM FAS_FUND_TRF_FROM_HO_MASTER m,
      FAS_FUND_TRF_FROM_HO_TRN t
    WHERE m.accounting_unit_id     = t.accounting_unit_id
    AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
    AND m.CASHBOOK_MONTH           =t.cashbook_month
    AND m.cashbook_year            =t.cashbook_year
    AND M.Voucher_No               = T.Voucher_No
    AND m.DATE_OF_TRANSFER BETWEEN $P{fromdate}::date AND $P{todate}::date
    AND m.TRANSFER_STATUS   = 'L'
    AND t.account_head_code = $P{accountheadcode}::numeric
    )as opt1
  ) as opt2
  --$P!{sortingorder}]]></queryString>

	<field name="unitname" class="java.lang.String"/>
	<field name="accounting_for_office_id" class="java.math.BigDecimal"/>
	<field name="cashbook_month" class="java.math.BigDecimal"/>
	<field name="cashbook_year" class="java.math.BigDecimal"/>
	<field name="doc_no" class="java.math.BigDecimal"/>
	<field name="doc_date" class="java.sql.Date"/>
	<field name="account_head_desc" class="java.lang.String"/>
	<field name="debit_amt" class="java.lang.Double"/>
	<field name="credit_amt" class="java.lang.Double"/>
	<field name="particulars" class="java.lang.String"/>
	<field name="net_amt" class="java.lang.Double"/>
	<field name="acchead" class="java.math.BigDecimal"/>
	<field name="unitid" class="java.math.BigDecimal"/>
	<field name="doc_type" class="java.lang.String"/>
	<field name="type_desc" class="java.lang.String"/>
	<field name="code_desc" class="java.lang.String"/>

	<variable name="SUM_DEBIT_AMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_CREDIT_AMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_NET_AMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{NET_AMT}]]></variableExpression>
	</variable>
	<variable name="final_net" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[(($V{SUM_DEBIT_AMT_1}.subtract($V{SUM_CREDIT_AMT_1})).intValue()<0) ? ($V{SUM_CREDIT_AMT_1}.subtract($V{SUM_DEBIT_AMT_1}))+"CR" : ($V{SUM_DEBIT_AMT_1}.subtract($V{SUM_CREDIT_AMT_1}))+"DR"]]></variableExpression>
	</variable>
	<variable name="unit_debit" class="java.math.BigDecimal" resetType="Group" resetGroup="unitname" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_AMT}]]></variableExpression>
	</variable>
	<variable name="unit_credit" class="java.math.BigDecimal" resetType="Group" resetGroup="unitname" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_AMT}]]></variableExpression>
	</variable>
	<variable name="unit_net" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[(($V{unit_debit}.subtract($V{unit_credit})).intValue()<0) ? ($V{unit_credit}.subtract($V{unit_debit}))+"CR" : ($V{unit_debit}.subtract($V{unit_credit}))+"DR"]]></variableExpression>
	</variable>

