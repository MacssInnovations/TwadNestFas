<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPF_VoucherWise_Headoffice"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="992"
		 pageHeight="842"
		 columnWidth="932"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sortingorder" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="supno" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select                               
  ( select 
       accounting_unit_name 
    from 
       fas_mst_acct_units 
    where 
        accounting_unit_id = unitid )  
  as unitname, 
  accounting_for_office_id, 
  cashbook_month, 
  cashbook_year,
  doc_no, 
  doc_date, 
  (select
    account_head_desc 
   from
    com_mst_account_heads 
   where 
    account_head_code = acchead
  ) account_head_desc, 
  debit_amt, 
  credit_amt, 
  PARTICULARS, 
  -(debit_amt - credit_amt ) as net_amt, 
  case when -(debit_amt - credit_amt ) > 0 then 
     abs( -(debit_amt - credit_amt )) || ' (CR)' 
  else 
    abs( -(debit_amt - credit_amt )) || ' (DR)' 
  end as net_amt_ind,   
  acchead,
  unitid,
  doc_type,Type_Desc,
  code_desc
from 
(

select 
  accounting_unit_id as unitid , 
  accounting_for_office_id, 
  cashbook_month, 
  cashbook_year,
  doc_no, 
  doc_date, 
  account_head_code as acchead, 
  case when cr_dr_indicator ='DR' then 
    amount 
  else 
    0 
  end as debit_amt, 
  case when cr_dr_indicator ='CR' then 
    amount 
  else 
    0 
  end as credit_amt , 
  PARTICULARS,
  doc_type,Type_Desc,
  code_desc
 
from 
( 
select 
   m.accounting_unit_id, 
   m.ACCOUNTING_FOR_OFFICE_ID, 
   m.cashbook_month, 
   m.cashbook_year, 
   m.VOUCHER_NO as doc_no,
   m.VOUCHER_DATE as doc_date, 
   t.account_head_code, 
   t.amount, 
   t.CR_DR_INDICATOR, 
   t.PARTICULARS,
   'J' as doc_type,
(SELECT S.Sub_Ledger_Type_Desc
      FROM Com_Mst_Sl_Types S
      WHERE S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code
      )AS Type_Desc,
      (SELECT V.Sl_Codename
      FROM Sl_Type_Code_Name_View_M v
      WHERE V.Sl_Type=T.Sub_Ledger_Type_Code
      And V.Sl_Code  =T.Sub_Ledger_Code
      )AS code_desc
from 
  fas_journal_master m, 
  fas_journal_transaction t
where 
  m.ACCOUNTING_UNIT_ID = t.ACCOUNTING_UNIT_ID and 
  m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID and 
 
  m.CASHBOOK_YEAR = t.CASHBOOK_YEAR and 
  m.CASHBOOK_MONTH = t.CASHBOOK_MONTH and 
  m.VOUCHER_NO = t.VOUCHER_NO and 
  m.JOURNAL_STATUS = 'L' and 
  m.cashbook_month = $P{cb_mon} and   
  M.Cashbook_Year = $P{cb_year} And   
  T.Account_Head_Code = $P{accountheadcode} And 
  m.SUPPLEMENT_NO=$P{supno}
 And M.Accounting_Unit_Id In (Select ACCOUNTING_UNIT_ID From Fas_Trial_Balance_Status_Sjv Where Cashbook_Month =$P{cb_mon} And Cashbook_Year =$P{cb_year})

 )
) 
--  order by doc_date, net_amt
--  order by unitid , doc_date
  $P!{sortingorder}]]></queryString>

