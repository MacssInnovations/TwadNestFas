<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="FAS_AnnexureV"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="935"
		 pageHeight="842"
		 columnWidth="875"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="from_cashbk_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbk_yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbk_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbk_yr" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT row_id,
  unit_id,
  accounting_unit_name,
  achead1,
  achead2,
  achead3,
  achead4,
  achead5,
  achead6,
  amt1,
  amt2,
  amt3,
  amt4,
  amt5,
  amt6,
  (
  CASE
    WHEN total>0
    THEN total
      ||' '
      ||'(DR)'
    WHEN total<0
    THEN total
      ||' '
      ||'(CR)'
    ELSE TO_CHAR(total)
  END)       AS total,
  total-amt4 AS difference1
FROM
  (SELECT a.row_id,
    unit_id,
    (SELECT accounting_unit_name
    FROM fas_mst_acct_units
    WHERE accounting_unit_id=unit_id
    )                AS accounting_unit_name,
    outlay           AS achead1,
    centage          AS achead2,
    interest         AS achead3,
    maintenance      AS achead4,
    funds_receipt1   AS achead5,
    funds_receipt2   AS achead6,
    SUM(amt_achead1) AS amt1,
    SUM(amt_achead2) AS amt2,
    SUM(amt_achead3) AS amt3,
    (((
    CASE
      WHEN outlay_indicator='DR'
      THEN SUM(amt_achead1)
      ELSE 0
    END)+ (
    CASE
      WHEN centage_indicator='DR'
      THEN SUM(amt_achead2)
      ELSE 0
    END)+ (
    CASE
      WHEN interest_indicator='DR'
      THEN SUM(amt_achead3)
      ELSE 0
    END))- ((
    CASE
      WHEN outlay_indicator='CR'
      THEN SUM(amt_achead1)
      ELSE 0
    END)+ (
    CASE
      WHEN centage_indicator='CR'
      THEN SUM(amt_achead2)
      ELSE 0
    END)+ (
    CASE
      WHEN interest_indicator='CR'
      THEN SUM(amt_achead3)
      ELSE 0
    END)) )          AS total,
    SUM(amt_achead4) AS amt4,
    SUM(amt_achead5) AS amt5,
    SUM(amt_achead6) AS amt6
  FROM
    (SELECT 1            AS row_id,
      accounting_unit_id AS unit_id ,
      accounting_for_office_id,
      CR_DR_INDICATOR,
      CASE
        WHEN ( account_head_code =
          (SELECT outlay FROM fas_mst_annexure_v
          )
        AND CR_DR_INDICATOR=
          (SELECT outlay_indicator FROM fas_mst_annexure_v
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead1,
      CASE
        WHEN ( account_head_code =
          (SELECT centage FROM fas_mst_annexure_v
          )
        AND CR_DR_INDICATOR=
          (SELECT centage_indicator FROM fas_mst_annexure_v
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead2,
      CASE
        WHEN ( account_head_code =
          (SELECT interest FROM fas_mst_annexure_v
          )
        AND CR_DR_INDICATOR=
          (SELECT interest_indicator FROM fas_mst_annexure_v
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead3,
      CASE
        WHEN ( account_head_code =
          (SELECT maintenance FROM fas_mst_annexure_v
          )
        AND CR_DR_INDICATOR=
          (SELECT maintenance_indicator FROM fas_mst_annexure_v
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead4,
      CASE
        WHEN ( account_head_code =
          (SELECT funds_receipt1 FROM fas_mst_annexure_v
          )
        AND CR_DR_INDICATOR=
          (SELECT funds_receipt_indicator1 FROM fas_mst_annexure_v
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead5,
      CASE
        WHEN ( account_head_code =
          (SELECT funds_receipt2 FROM fas_mst_annexure_v
          )
        AND CR_DR_INDICATOR=
          (SELECT funds_receipt_indicator2 FROM fas_mst_annexure_v
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead6
    FROM
      (SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_journal_master m ,
        fas_journal_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.journal_status           ='L'
      AND ( t.account_head_code      =
        (SELECT outlay FROM fas_mst_annexure_v
        )
      AND cr_dr_indicator=
        (SELECT outlay_indicator FROM fas_mst_annexure_v
        )
      OR t.account_head_code=
        (SELECT centage FROM fas_mst_annexure_v
        )
      AND cr_dr_indicator=
        (SELECT centage_indicator FROM fas_mst_annexure_v
        )
      OR t.account_head_code=
        (SELECT interest FROM fas_mst_annexure_v
        )
      AND cr_dr_indicator=
        (SELECT interest_indicator FROM fas_mst_annexure_v
        )
      OR t.account_head_code=
        (SELECT maintenance FROM fas_mst_annexure_v
        )
      AND cr_dr_indicator=
        (SELECT maintenance_indicator FROM fas_mst_annexure_v
        )
      OR t.account_head_code=
        (SELECT funds_receipt1 FROM fas_mst_annexure_v
        )
      AND cr_dr_indicator=
        (SELECT funds_receipt_indicator1 FROM fas_mst_annexure_v
        )
      OR t.account_head_code=
        (SELECT funds_receipt2 FROM fas_mst_annexure_v
        )
      AND cr_dr_indicator=
        (SELECT funds_receipt_indicator2 FROM fas_mst_annexure_v
        ) )
      AND to_date(m.cashbook_month
        ||'-'
        || + m.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      UNION ALL
      SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_payment_master m ,
        fas_payment_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.payment_status           ='L'
      AND ( t.account_head_code      =
        (SELECT (
          CASE
            WHEN outlay_indicator='DR'
            THEN
              (SELECT outlay FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS outlay
        FROM
          (SELECT outlay_indicator FROM fas_mst_annexure_v
          )
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN centage_indicator='DR'
            THEN
              (SELECT centage FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS centage
        FROM
          (SELECT centage_indicator FROM fas_mst_annexure_v
          )
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN interest_indicator='DR'
            THEN
              (SELECT interest FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS interest
        FROM
          (SELECT interest_indicator FROM fas_mst_annexure_v
          )
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN maintenance_indicator='DR'
            THEN
              (SELECT maintenance FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS maintenance
        FROM
          (SELECT maintenance_indicator FROM fas_mst_annexure_v
          )
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN funds_receipt_indicator1='DR'
            THEN
              (SELECT funds_receipt1 FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS receipt1
        FROM
          (SELECT funds_receipt_indicator1 FROM fas_mst_annexure_v
          )
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN funds_receipt_indicator2='DR'
            THEN
              (SELECT funds_receipt2 FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS receipt2
        FROM
          (SELECT funds_receipt_indicator2 FROM fas_mst_annexure_v
          )
        ) )
      AND to_date(t.cashbook_month
        ||'-'
        || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      UNION ALL
      SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_receipt_master m ,
        fas_receipt_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.receipt_no               = t.receipt_no
      AND m.receipt_status           ='L'
      AND ( t.account_head_code      =
        (SELECT (
          CASE
            WHEN outlay_indicator='CR'
            THEN
              (SELECT outlay FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS outlay
        FROM
          (SELECT outlay_indicator FROM fas_mst_annexure_v
          )
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN centage_indicator='CR'
            THEN
              (SELECT centage FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS centage
        FROM
          (SELECT centage_indicator FROM fas_mst_annexure_v
          )
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN interest_indicator='CR'
            THEN
              (SELECT interest FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS interest
        FROM
          (SELECT interest_indicator FROM fas_mst_annexure_v
          )
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN maintenance_indicator='CR'
            THEN
              (SELECT maintenance FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS maintenance
        FROM
          (SELECT maintenance_indicator FROM fas_mst_annexure_v
          )
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN funds_receipt_indicator1='CR'
            THEN
              (SELECT funds_receipt1 FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS receipt1
        FROM
          (SELECT funds_receipt_indicator1 FROM fas_mst_annexure_v
          )
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN funds_receipt_indicator2='CR'
            THEN
              (SELECT funds_receipt2 FROM fas_mst_annexure_v
              )
            ELSE 0
          END)AS receipt2
        FROM
          (SELECT funds_receipt_indicator2 FROM fas_mst_annexure_v
          )
        ) )
      AND to_date(t.cashbook_month
        ||'-'
        || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      )
    GROUP BY accounting_unit_id,
      accounting_for_office_id ,
      account_head_code,
      CR_DR_INDICATOR
    ORDER BY accounting_unit_id
    )a,
    fas_mst_annexure_v b
  WHERE a.row_id=b.row_id
  GROUP BY a.row_id,
    unit_id,
    outlay,
    outlay_indicator,
    centage,
    centage_indicator,
    interest,
    interest_indicator,
    maintenance,
    funds_receipt1,
    funds_receipt2
  )]]></queryString>

	<field name="ROW_ID" class="java.math.BigDecimal"/>
	<field name="UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="ACHEAD1" class="java.math.BigDecimal"/>
	<field name="ACHEAD2" class="java.math.BigDecimal"/>
	<field name="ACHEAD3" class="java.math.BigDecimal"/>
	<field name="ACHEAD4" class="java.math.BigDecimal"/>
	<field name="ACHEAD5" class="java.math.BigDecimal"/>
	<field name="ACHEAD6" class="java.math.BigDecimal"/>
	<field name="AMT1" class="java.math.BigDecimal"/>
	<field name="AMT2" class="java.math.BigDecimal"/>
	<field name="AMT3" class="java.math.BigDecimal"/>
	<field name="AMT4" class="java.math.BigDecimal"/>
	<field name="AMT5" class="java.math.BigDecimal"/>
	<field name="AMT6" class="java.math.BigDecimal"/>
	<field name="TOTAL" class="java.lang.String"/>
	<field name="DIFFERENCE1" class="java.math.BigDecimal"/>


