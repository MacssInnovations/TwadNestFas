<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Print_Challan_CashBankDCB"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1076"
		 pageHeight="594"
		 columnWidth="1016"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="AccountUnitCode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeCode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="CashBookMonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="CashBookYear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="doctype" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select m.challan_no,
to_char(m.challan_date,'dd/mm/yyyy')as challan_date,
m.receipt_no,
to_char(m.receipt_date,'dd/mm/yyyy')as receipt_date, 
m.received_from,
m.total_amount,
--decode(t.cheque_dd_no,null,'-',t.cheque_dd_no)as cheque_dd_no,
case when (t.cheque_dd_no=null) then '-' else t.cheque_dd_no end as cheque_dd_no,
--decode(to_char(t.cheque_dd_date,'dd/mm/yyyy'),null,'-',to_char(t.cheque_dd_date,'dd/mm/yyyy'))as cheque_dd_date,
case when (to_char(t.cheque_dd_date,'dd/mm/yyyy')=null) then '-' else to_char(t.cheque_dd_date,'dd/mm/yyyy') end as cheque_dd_date,
ACCOUNT_NO,
--decode(t.bank_name,null,'-',t.bank_name)as bank_name,
case when (t.bank_name=null) then '-' else t.bank_name end as bank_name,
--decode(t.drawee_branch,null,'-',t.drawee_branch)as drawee_branch,
case when (t.drawee_branch=null) then '-' else t.drawee_branch end as drawee_branch,
t.amount,
c.accounting_unit_name as accounting_unit_name,
d.office_name
from fas_receipt_master m,
fas_receipt_transaction t,
fas_mst_acct_units c,
com_mst_offices d
where
m.accounting_unit_id = t.accounting_unit_id
and m.accounting_for_office_id = t.accounting_for_office_id
and m.cashbook_month = t.cashbook_month
and m.cashbook_year = t.cashbook_year
and m.receipt_no = t.receipt_no
and c.accounting_unit_id = m.accounting_unit_id
and d.office_id = c.ACCOUNTING_UNIT_OFFICE_ID
and d.office_id = m.accounting_for_office_id
and m.accounting_unit_id = ($P{AccountUnitCode})
and m.accounting_for_office_id = ($P{OfficeCode})
and m.cashbook_month = ($P{CashBookMonth})
and m.cashbook_year = ($P{CashBookYear})
and m.receipt_status = 'L' 
and m.created_by_module = ($P{doctype})
and m.sub_ledger_type_code !=14
order by m.challan_date,m.challan_no,m.receipt_date,m.receipt_no]]></queryString>

	<field name="CHALLAN_NO" class="java.math.BigDecimal"/>
	<field name="CHALLAN_DATE" class="java.lang.String"/>
	<field name="RECEIPT_NO" class="java.math.BigDecimal"/>
	<field name="RECEIPT_DATE" class="java.lang.String"/>
	<field name="RECEIVED_FROM" class="java.lang.String"/>
	<field name="TOTAL_AMOUNT" class="java.math.BigDecimal"/>
	<field name="CHEQUE_DD_NO" class="java.lang.String"/>
	<field name="CHEQUE_DD_DATE" class="java.lang.String"/>
	<field name="ACCOUNT_NO" class="java.math.BigDecimal"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="DRAWEE_BRANCH" class="java.lang.String"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>

	<variable name="TOTAL_CHEQ_AMT" class="java.math.BigDecimal" resetType="Group" resetGroup="challan" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="grant_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_AMOUNT}]]></variableExpression>
	</variable>

