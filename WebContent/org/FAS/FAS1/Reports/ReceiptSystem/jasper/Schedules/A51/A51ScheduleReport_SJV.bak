<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="A51ScheduleReport_SJV"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<parameter name="reporttype" isForPrompting="true" class="java.lang.String"/>
	<parameter name="suppl_No" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
*
from 
(
select 
  
   acc_code, 
   acc_desc,
   remarks, 
   recpno, 
   doctype,
   Docdate,
   dr_amt,
   
  
   case
       when 
           dr_amt >=1000 
       then 
            dr_amt
        else
             0
   end as dr_greater_amt, 
   
   
   case
       when 
           dr_amt <1000 
       then 
            dr_amt
        else
             0
   end as dr_lesser_amt, 
      
      
    case
       when 
           dr_amt >=1000 
       then 
             1
        else
             0
   end as dr_greater_count, 
   
   
   case
       when 
           dr_amt <1000 and dr_amt <> 0 
       then 
             1
        else
             0
   end as dr_lesser_count, 
         
      
   
    
   cr_amt,
 
   case
       when 
           cr_amt >=1000 
       then 
            cr_amt
        else
             0
   end as cr_greater_amt, 
   
   
   case
       when 
           cr_amt <1000 
       then 
            cr_amt
        else
             0
   end as cr_lesser_amt, 
      
      
   case
       when 
           cr_amt >=1000 
       then 
            1
        else
             0
   end as cr_greater_count, 
   
   
   case
       when 
           cr_amt <1000 and cr_amt <> 0 
       then 
             1
        else
             0
   end as cr_lesser_count, 
      
      
   
   office_short_name,
   accounting_unit_name
   
from 

(
        
select 
       a.account_head_code as acc_code, 
       c.account_head_desc  as acc_desc, 
       a.particulars as remarks,
       a.voucher_no as recpno,
       'J' as doctype,
	b.VOUCHER_DATE AS Docdate,
       a.amount as dr_amt ,
       0 as cr_amt ,
       D.OFFICE_SHORT_NAME,
       E.ACCOUNTING_UNIT_NAME,
       b.SUPPLEMENT_NO
       
from
       fas_journal_transaction a,
       fas_journal_master b ,
       com_mst_account_heads c ,
       com_mst_offices d,
       fas_mst_acct_units e
where 
       a.account_head_code=c.account_head_code and 
       a.accounting_unit_id=b.accounting_unit_id and 
       a.accounting_for_office_id=b.accounting_for_office_id and 
       a.accounting_for_office_id=d.office_id and
       a.accounting_unit_id=e.accounting_unit_id and
       a.cashbook_year=b.cashbook_year and 
       a.cashbook_month=b.cashbook_month and 
       a.voucher_no=b.voucher_no and 
       b.journal_status!='C' and 
       b.CREATED_BY_MODULE in ('SJV') and 
       a.account_head_code in (select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A51' )   and 
       a.cr_dr_indicator= 'DR' and 
       a.cashbook_year=$P{cashbookyear}::int and 
       a.cashbook_month=$P{cashbookmonth}::int and 
       a.accounting_unit_id=$P{accountingunitid}::int and
       A.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int 
       
  ---     $P!{suppl_No}
             
             
union all

select 
       a.account_head_code as acc_code,  
       c.account_head_desc  as acc_desc, 
       a.particulars as remarks,
       a.voucher_no as recpno,
       'J' as doctype,
	b.VOUCHER_DATE AS Docdate,
       0 as dr_amt, 
       a.amount as cr_amt ,
       d.office_short_name,
       E.ACCOUNTING_UNIT_NAME,
       b.SUPPLEMENT_NO
from
       fas_journal_transaction a,
       fas_journal_master b ,
       com_mst_account_heads c ,
       com_mst_offices d,
       fas_mst_acct_units e
where 
       a.account_head_code=c.account_head_code and 
       a.accounting_unit_id=b.accounting_unit_id and 
       a.accounting_for_office_id=b.accounting_for_office_id and 
       a.accounting_for_office_id=d.office_id and
       a.accounting_unit_id=e.accounting_unit_id and
       a.cashbook_year=b.cashbook_year and 
       a.cashbook_month=b.cashbook_month and 
       a.voucher_no=b.voucher_no and 
       b.journal_status!='C' and 
       b.CREATED_BY_MODULE in ('SJV') and 
       a.account_head_code in (select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A51' )   and 
       a.cr_dr_indicator= 'CR' and 
       a.cashbook_year=$P{cashbookyear}::int and  
       a.cashbook_month=$P{cashbookmonth}::int and 
       a.accounting_unit_id=$P{accountingunitid}::int and
       a.accounting_for_office_id=$P{accountofficeid}::int 
       
  -----     $P!{suppl_No}
             
  ) as opt1
)  as opt2
----$P!{reporttype}
order by acc_code, doctype,Docdate, recpno]]></queryString>

