<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="A51ScheduleReport_NewPage"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<parameter name="reporttype" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT *
FROM
  (SELECT acc_code as "acc_code",
    acc_desc as "acc_desc",
    remarks as "remarks",
    recpno AS "recpno",
    DOCTYPE AS "doctype",
    Docdate AS "docdate",
    dr_amt AS "dr_amt",
    CASE
      WHEN dr_amt >=1000
      THEN dr_amt
      ELSE 0
    END AS "dr_greater_amt",
    CASE
      WHEN dr_amt <1000
      THEN dr_amt
      ELSE 0
    END AS "dr_lesser_amt",
    CASE
      WHEN dr_amt >=1000
      THEN 1
      ELSE 0
    END AS "dr_greater_count",
    CASE
      WHEN dr_amt <1000
      AND dr_amt <> 0
      THEN 1
      ELSE 0
    END AS "dr_lesser_count",
    cr_amt,
    CASE
      WHEN cr_amt >=1000
      THEN cr_amt
      ELSE 0
    END AS "cr_greater_amt",
    CASE
      WHEN cr_amt <1000
      THEN cr_amt
      ELSE 0
    END AS "cr_lesser_amt",
    CASE
      WHEN cr_amt >=1000
      THEN 1
      ELSE 0
    END AS "cr_greater_count",
    CASE
      WHEN cr_amt <1000
      AND cr_amt <> 0
      THEN 1
      ELSE 0
    END AS "cr_lesser_count",
    office_short_name AS "office_short_name",
    accounting_unit_name AS "accounting_unit_name"
  FROM
    (SELECT a.account_head_code AS acc_code,
      c.account_head_desc       AS acc_desc,
      a.particulars             AS remarks,
      a.receipt_no              AS recpno,
      'R'                       AS DOCTYPE,
      b.receipt_date            AS Docdate,
      a.amount                  AS dr_amt,
      0                         AS cr_amt ,
      d.office_short_name,
      e.accounting_unit_name
    FROM fas_receipt_transaction a,
      fas_receipt_master b ,
      com_mst_account_heads c ,
      com_mst_offices d,
      fas_mst_acct_units e
    WHERE a.account_head_code     =c.account_head_code
    AND a.accounting_unit_id      =b.accounting_unit_id
    AND a.accounting_for_office_id=b.accounting_for_office_id
    AND a.cashbook_year           =b.cashbook_year
    AND a.cashbook_month          =b.cashbook_month
    AND a.accounting_for_office_id=d.office_id
    AND a.accounting_unit_id      =e.accounting_unit_id
    AND a.receipt_no              =b.receipt_no
    AND b.receipt_status!='C'
    AND a.account_head_code      IN
      (SELECT ACCOUNT_HEAD_CODE FROM FAS_SCHEDULEMASTER WHERE SCHEDULE_ID='A51'
      )
    AND a.cr_dr_indicator         ='DR'
    AND a.cashbook_year           =$P{cashbookyear}::int
    AND a.cashbook_month          =$P{cashbookmonth}::int
    AND a.accounting_unit_id      =$P{accountingunitid}::int
    AND a.accounting_for_office_id=$P{accountofficeid}::int
    UNION ALL
    SELECT a.account_head_code AS acc_code,
      c.account_head_desc      AS acc_desc,
      a.particulars            AS remarks,
      a.receipt_no             AS recpno,
      'R'                      AS DOCTYPE,
      b.receipt_date            AS Docdate,
      0                        AS dr_amt,
      a.amount                 AS cr_amt ,
      d.office_short_name,
      e.accounting_unit_name
    FROM fas_receipt_transaction a,
      fas_receipt_master b,
      com_mst_account_heads c ,
      com_mst_offices d,
      fas_mst_acct_units e
    WHERE a.account_head_code     =c.account_head_code
    AND a.accounting_unit_id      =b.accounting_unit_id
    AND a.accounting_for_office_id=b.accounting_for_office_id
    AND a.accounting_for_office_id=d.office_id
    AND a.accounting_unit_id      =e.accounting_unit_id
    AND a.cashbook_year           =b.cashbook_year
    AND a.cashbook_month          =b.cashbook_month
    AND a.receipt_no              =b.receipt_no
    AND b.receipt_status!='C'
    AND a.account_head_code      IN
      (SELECT ACCOUNT_HEAD_CODE FROM FAS_SCHEDULEMASTER WHERE SCHEDULE_ID='A51'
      )
    AND a.cr_dr_indicator         ='CR'
    AND a.cashbook_year           =$P{cashbookyear}::int
    AND a.cashbook_month          =$P{cashbookmonth}::int
    AND a.accounting_unit_id      =$P{accountingunitid}::int
    AND a.accounting_for_office_id=$P{accountofficeid}::int
    UNION ALL
    SELECT a.account_head_code AS acc_code,
      c.account_head_desc      AS acc_desc,
      a.particulars            AS remarks,
      a.voucher_no             AS recpno,
      'J'                      AS DOCTYPE,
      b.VOUCHER_DATE           AS Docdate,
      a.amount                 AS dr_amt ,
      0                        AS cr_amt ,
      d.office_short_name,
      e.accounting_unit_name
    FROM fas_journal_transaction a,
      fas_journal_master b ,
      com_mst_account_heads c ,
      com_mst_offices d,
      fas_mst_acct_units e
    WHERE a.account_head_code     =c.account_head_code
    AND a.accounting_unit_id      =b.accounting_unit_id
    AND a.accounting_for_office_id=b.accounting_for_office_id
    AND a.accounting_for_office_id=d.office_id
    AND a.accounting_unit_id      =e.accounting_unit_id
    AND a.cashbook_year           =b.cashbook_year
    AND a.cashbook_month          =b.cashbook_month
    AND a.voucher_no              =b.voucher_no
    AND b.journal_status!='C'
    AND a.account_head_code      IN
      (SELECT ACCOUNT_HEAD_CODE FROM FAS_SCHEDULEMASTER WHERE SCHEDULE_ID='A51'
      )
    AND a.cr_dr_indicator         = 'DR'
    AND a.cashbook_year           =$P{cashbookyear}::int
    AND a.cashbook_month          =$P{cashbookmonth}::int
    AND a.accounting_unit_id      =$P{accountingunitid}::int
    AND a.accounting_for_office_id=$P{accountofficeid}::int
    UNION ALL
    SELECT a.account_head_code AS acc_code,
      c.account_head_desc      AS acc_desc,
      a.particulars            AS remarks,
      a.voucher_no             AS recpno,
      'J'                      AS DOCTYPE,
      b.VOUCHER_DATE           AS Docdate,
      0                        AS dr_amt,
      a.amount                 AS cr_amt ,
      d.office_short_name,
      e.accounting_unit_name
    FROM fas_journal_transaction a,
      fas_journal_master b ,
      com_mst_account_heads c ,
      com_mst_offices d,
      fas_mst_acct_units e
    WHERE a.account_head_code     =c.account_head_code
    AND a.accounting_unit_id      =b.accounting_unit_id
    AND a.accounting_for_office_id=b.accounting_for_office_id
    AND a.accounting_for_office_id=d.office_id
    AND a.accounting_unit_id      =e.accounting_unit_id
    AND a.cashbook_year           =b.cashbook_year
    AND a.cashbook_month          =b.cashbook_month
    AND a.voucher_no              =b.voucher_no
    AND b.journal_status!='C'
    AND b.CREATED_BY_MODULE      IN ('GJV','LJV')
    AND a.account_head_code      IN
      (SELECT ACCOUNT_HEAD_CODE FROM FAS_SCHEDULEMASTER WHERE SCHEDULE_ID='A51'
      )
    AND a.cr_dr_indicator         = 'CR'
    AND a.cashbook_year           =$P{cashbookyear}::int
    AND a.cashbook_month          =$P{cashbookmonth}::int
    AND a.accounting_unit_id      =$P{accountingunitid}::int
    AND a.accounting_for_office_id=$P{accountofficeid}::int
    UNION ALL
    SELECT a.account_head_code AS acc_code ,
      c.account_head_desc      AS acc_desc,
      a.particulars            AS remarks,
      a.voucher_no             AS recpno,
      'P'                      AS DOCTYPE,
      b.PAYMENT_DATE           AS Docdate,
      a.amount                 AS dr_amt,
      0                        AS cr_amt ,
      d.office_short_name,
      e.accounting_unit_name
    FROM fas_payment_transaction a,
      fas_payment_master b ,
      com_mst_account_heads c ,
      com_mst_offices d,
      fas_mst_acct_units e
    WHERE a.account_head_code     =c.account_head_code
    AND a.accounting_unit_id      =b.accounting_unit_id
    AND a.accounting_for_office_id=d.office_id
    AND a.accounting_unit_id      =e.accounting_unit_id
    AND a.cashbook_year           =b.cashbook_year
    AND a.cashbook_month          =b.cashbook_month
    AND a.accounting_for_office_id=b.accounting_for_office_id
    AND a.voucher_no              =b.voucher_no
    AND b.payment_status!='C'
    AND a.account_head_code      IN
      (SELECT ACCOUNT_HEAD_CODE FROM FAS_SCHEDULEMASTER WHERE SCHEDULE_ID='A51'
      )
    AND a.cr_dr_indicator         ='DR'
    AND a.cashbook_year           =$P{cashbookyear}::int
    AND a.cashbook_month          =$P{cashbookmonth}::int
    AND a.accounting_unit_id      =$P{accountingunitid}::int
    AND a.accounting_for_office_id=$P{accountofficeid}::int
    UNION ALL
    SELECT a.account_head_code AS acc_code,
      c.account_head_desc      AS acc_desc,
      a.particulars            AS remarks,
      a.voucher_no             AS recpno,
      'P'                      AS DOCTYPE,
      b.PAYMENT_DATE           AS Docdate,
      0                        AS dr_amt,
      a.amount                 AS cr_amt ,
      d.office_short_name,
      e.accounting_unit_name
    FROM fas_payment_transaction a,
      fas_payment_master b,
      com_mst_account_heads c ,
      com_mst_offices d,
      fas_mst_acct_units e
    WHERE a.account_head_code     =c.account_head_code
    AND a.accounting_unit_id      =b.accounting_unit_id
    AND a.accounting_for_office_id=d.office_id
    AND a.accounting_unit_id      =e.accounting_unit_id
    AND a.cashbook_year           =b.cashbook_year
    AND a.cashbook_month          =b.cashbook_month
    AND a.accounting_for_office_id=b.accounting_for_office_id
    AND a.voucher_no              =b.voucher_no
    AND b.payment_status!='C'
    AND a.account_head_code      IN
      ( SELECT ACCOUNT_HEAD_CODE FROM FAS_SCHEDULEMASTER WHERE SCHEDULE_ID='A51'
      )
    AND a.cr_dr_indicator         ='CR'
    AND a.cashbook_year           =$P{cashbookyear}::int
    AND a.cashbook_month          =$P{cashbookmonth}::int
    AND a.accounting_unit_id      =$P{accountingunitid}::int
    AND a.accounting_for_office_id=$P{accountofficeid}::int
    ) as opt1
  ) as opt2 

--$P!{reporttype}
ORDER BY acc_code,
  doctype,
  Docdate,
  recpno]]></queryString>

	<field name="acc_code" class="java.math.BigDecimal"/>
	<field name="acc_desc" class="java.lang.String"/>
	<field name="remarks" class="java.lang.String"/>
	<field name="recpno" class="java.math.BigDecimal"/>
	<field name="doctype" class="java.lang.String"/>
	<field name="docdate" class="java.sql.Date"/>
	<field name="dr_amt" class="java.math.BigDecimal"/>
	<field name="dr_greater_amt" class="java.math.BigDecimal"/>
	<field name="dr_lesser_amt" class="java.math.BigDecimal"/>
	<field name="dr_greater_count" class="java.lang.Integer"/>
	<field name="dr_lesser_count" class="java.lang.Integer"/>
	<field name="cr_amt" class="java.math.BigDecimal"/>
	<field name="cr_greater_amt" class="java.math.BigDecimal"/>
	<field name="cr_lesser_amt" class="java.math.BigDecimal"/>
	<field name="cr_greater_count" class="java.lang.Integer"/>
	<field name="cr_lesser_count" class="java.lang.Integer"/>
	<field name="office_short_name" class="java.lang.String"/>
	<field name="accounting_unit_name" class="java.lang.String"/>
	<field name="ACC_CODE" class="java.lang.String"/>

	<variable name="SUM_DR_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{dr_amt}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{cr_amt}]]></variableExpression>
	</variable>
	<variable name="SUM_DR_GREATER_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{dr_greater_amt}]]></variableExpression>
	</variable>
	<variable name="SUM_DR_GREATER_COUNT_1" class="java.lang.Integer" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{dr_greater_count}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_GREATER_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{cr_greater_amt}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_GREATER_COUNT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{cr_greater_amt}]]></variableExpression>
	</variable>
	<variable name="SUM_DR_LESSER_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{dr_lesser_amt}]]></variableExpression>
	</variable>
	<variable name="SUM_DR_LESSER_COUNT_1" class="java.lang.Integer" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{dr_lesser_count}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_LESSER_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{cr_lesser_amt}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_LESSER_COUNT_1" class="java.lang.Integer" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{cr_lesser_count}]]></variableExpression>
	</variable>

