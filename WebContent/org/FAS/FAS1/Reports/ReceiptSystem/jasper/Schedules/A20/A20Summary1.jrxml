	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="from_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unit" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="office" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="assetmajor" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="financialyear" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthfrom" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthto" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="qry" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select 
(open_bal_qty+receiptqtyy-issuedqty)as closing_bal_qty,
(open_bal_value+receiptvaluee-issuedvalue)as closing_bal_val,
open_bal_qty,open_bal_value,issuedqty,issuedvalue,receiptqtyy ,receiptvaluee,
unitname,
 (select ASSET_MAJOR_CLASS_DESC from FAS_MST_ASSETS_CLASS c2 where c2.ASSET_MAJOR_CLASS_CODE=$P{assetmajor})as assetsClass
from 
(select sum(open_bal_qty) as open_bal_qty,sum(opening_bal_value) as open_bal_value,b1.unitName,
b1.issuesqty as issuedqty,b1.issuesvalue as issuedvalue,b2.receiptqty as receiptqtyy,b2.receiptvalue as receiptvaluee
from (select b.accounting_for_office_id,b.accounting_unit_id,b.financial_year,b.asset_major_class_code,
sum(b.qty_issued) as issuesqty,
sum(b.value_issued) as issuesvalue,
f.accounting_unit_name as unitname
 from fas_issueof_assets b
 join fas_mst_acct_units f on b.accounting_for_office_id=f.accounting_unit_office_id 
 --group by b.accounting_for_office_id, b.accounting_unit_id, b.financial_year, b.asset_major_class_code, cashbook_year, f.accounting_unit_name 
 where to_date(b.cashbook_month ||'-'|| b.cashbook_year, 'mm-yyyy') between to_date( $P{monthfrom} || '-'|| $P{from_cashbookyear}, 'mm-yyyy')
  and  to_date( $P{monthto} ||'-'|| $P{to_cashbookyear} , 'mm-yyyy')
  and b.asset_major_class_code=$P{assetmajor}
  and b.accounting_for_office_id=$P{office}
  and b.accounting_unit_id=$P{unit}
  and b.financial_year=$P{financialyear}
 group by b.accounting_for_office_id, b.accounting_unit_id, b.financial_year, b.asset_major_class_code, f.accounting_unit_name) b1 
 left outer join
 (select accounting_for_office_id,accounting_unit_id,financial_year,b.asset_major_class_code,
sum(b.received_qty) as receiptqty,
sum(b.received_value) as receiptvalue
 from FAS_ASSETS_RECEIPT b 
 where to_date(b.cashbook_month ||'-'|| b.cashbook_year, 'mm-yyyy') between to_date(  $P{monthfrom} || '-'|| $P{from_cashbookyear}, 'mm-yyyy')
  and to_date( $P{monthto} ||'-'|| $P{to_cashbookyear}, 'mm-yyyy')
  and asset_major_class_code=$P{assetmajor}
  and accounting_for_office_id=$P{office}
  and accounting_unit_id=$P{unit}
  and financial_year=$P{financialyear}
 group by accounting_for_office_id, accounting_unit_id, financial_year, b.asset_major_class_code)b2
 on b2.accounting_for_office_id=b1.accounting_for_office_id
 and b2.asset_major_class_code=b1.asset_major_class_code
 and b2.financial_year=b1.financial_year 
 inner join fas_a52_register a
 on a.accounting_unit_office_id=b1.accounting_for_office_id
 and a.asset_major_class_code=b1.asset_major_class_code
 and a.financial_year=b1.financial_year 
group by b1.unitName, b1.issuesqty, b1.issuesvalue, b2.receiptqty, b2.receiptvalue)]]></queryString>

