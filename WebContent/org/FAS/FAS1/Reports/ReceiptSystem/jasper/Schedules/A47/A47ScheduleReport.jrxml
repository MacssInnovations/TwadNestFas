<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="A47ScheduleReport"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="reporttype" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT account_head_code as "ACCOUNT_HEAD_CODE" ,
  account_head_desc as "ACCOUNT_HEAD_DESC",
  cr_dr_indicator,
  remarks as "REMARKS",
  recpno as "RECPNO",
  DOCTYPE as "DOCTYPE",
  docdate as "DOCDATE",
  cramount as "CRAMOUNT",
  dramount as "DRAMOUNT",
  ACCOUNTING_UNIT_NAME as "ACCOUNTING_UNIT_NAME",
  OFFICE_SHORT_NAME as "OFFICE_SHORT_NAME"
FROM
  (SELECT *
  FROM
    (SELECT account_head_code AS acc_head,
      ACCOUNT_HEAD_DESC
    FROM COM_MST_ACCOUNT_HEADS
    WHERE ACCOUNT_HEAD_CODE IN
      ( SELECT ACCOUNT_HEAD_CODE FROM FAS_SCHEDULEMASTER WHERE SCHEDULE_ID='A47'
      )
    )a
  INNER JOIN
    (SELECT cr_dr_indicator,
      remarks,
      recpno,
      DOCTYPE,
      docdate,
  ----    DECODE (cr_dr_indicator,'CR',amt,0) cramount,    

case when cr_dr_indicator='CR' then amt else 0 end as cramount,
 ----     DECODE (cr_dr_indicator,'DR',amt,0) dramount,
case when cr_dr_indicator='DR' then amt else 0 end as dramount,
      account_head_code
    FROM
      (SELECT a.cr_dr_indicator,
        a.particulars AS remarks,
        a.receipt_no  AS recpno,
        'R'           AS DOCTYPE,
        B.RECEIPT_DATE as docdate,
        a.amount      AS amt,
        a.account_head_code
      FROM fas_receipt_transaction a,
        fas_receipt_master b
      WHERE a.accounting_unit_id    = b.accounting_unit_id
      AND a.accounting_for_office_id=b.accounting_for_office_id
      AND a.cashbook_year           =b.cashbook_year
      AND a.cashbook_month          =b.cashbook_month
      AND a.receipt_no              =b.receipt_no 
      AND b.receipt_status!='C'
      AND a.cr_dr_indicator         ='CR'
      AND a.cashbook_year           =$P{cashbookyear}::int 
      AND a.cashbook_month          =$P{cashbookmonth}::int 
      AND a.accounting_unit_id      =$P{accountingunitid}::int 
      AND a.accounting_for_office_id=$P{accountofficeid}::int
      UNION ALL
      SELECT a.cr_dr_indicator,
        a.particulars AS remarks,
        a.voucher_no  AS recpno,
        'J'           AS DOCTYPE,
        b.VOUCHER_DATE as docdate,
        a.amount      AS amt,
        a.account_head_code
      FROM fas_journal_transaction a,
        fas_journal_master b
      WHERE a.accounting_unit_id    =b.accounting_unit_id
      AND a.accounting_for_office_id=b.accounting_for_office_id
      AND a.cashbook_year           =b.cashbook_year
      AND a.cashbook_month          =b.cashbook_month
      AND a.voucher_no              =b.voucher_no
      AND b.journal_status!='C'
      AND a.cr_dr_indicator         ='CR'
      AND b.created_by_module      IN ('GJV','LJV')
      AND a.cashbook_year           =$P{cashbookyear}::int
      AND a.cashbook_month          =$P{cashbookmonth}::int
      AND a.accounting_unit_id      =$P{accountingunitid}::int
      AND a.accounting_for_office_id=$P{accountofficeid}::int
      UNION ALL
      SELECT a.cr_dr_indicator,
        a.particulars AS remarks,
        a.voucher_no  AS recpno,
        'P'           AS DOCTYPE,
        B.PAYMENT_DATE as docdate,
        a.amount      AS amt,
        a.account_head_code
      FROM fas_payment_transaction a,
        fas_payment_master b
      WHERE a.accounting_unit_id    =b.accounting_unit_id
      AND a.cashbook_year           =b.cashbook_year
      AND a.cashbook_month          =b.cashbook_month
      AND a.accounting_for_office_id=b.accounting_for_office_id
      AND a.voucher_no              =b.voucher_no
      AND b.payment_status!='C'
      AND a.cr_dr_indicator         ='DR'
      AND a.cashbook_year           =$P{cashbookyear}::int
      AND a.cashbook_month          =$P{cashbookmonth}::int
      AND a.accounting_unit_id      =$P{accountingunitid}::int
      AND a.accounting_for_office_id=$P{accountofficeid}::int
      UNION ALL
      SELECT a.cr_dr_indicator,
        a.particulars AS remarks,
        a.voucher_no  AS recpno,
        'J'           AS DOCTYPE,
        B.VOUCHER_DATE as docdate,
        a.amount      AS amt,
        a.account_head_code
      FROM fas_journal_transaction a,
        fas_journal_master b
      WHERE a.accounting_unit_id    =b.accounting_unit_id
      AND a.accounting_for_office_id=b.accounting_for_office_id
      AND a.cashbook_year           =b.cashbook_year
      AND a.cashbook_month          =b.cashbook_month
      AND a.voucher_no              =b.voucher_no
      AND b.journal_status!='C'
      AND a.cr_dr_indicator         ='DR'
      AND b.created_by_module      IN ('GJV','LJV')
      AND a.cashbook_year           =$P{cashbookyear}::int
      AND a.cashbook_month          =$P{cashbookmonth}::int
      AND a.accounting_unit_id      =$P{accountingunitid}::int
      AND a.accounting_for_office_id=$P{accountofficeid}::int
      ) as opt1
    ) b
  ON a.acc_head = b.account_head_code
  ) as opt2,
  (SELECT ACCOUNTING_UNIT_NAME
  FROM fas_mst_acct_units
  WHERE ACCOUNTING_UNIT_ID      = $P{accountingunitid}::int
  AND ACCOUNTING_UNIT_OFFICE_ID = $P{accountofficeid}::int
  ) as opt3,
  (SELECT OFFICE_SHORT_NAME
  FROM com_mst_offices
  WHERE office_id=$P{accountofficeid}::int 
  ) as opt4

where account_head_code::varchar like $P{reporttype}
ORDER BY account_head_code,

  doctype,
  docdate,
  recpno]]></queryString>

	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="cr_dr_indicator" class="java.lang.String"/>
	<field name="REMARKS" class="java.lang.String"/>
	<field name="RECPNO" class="java.math.BigDecimal"/>
	<field name="DOCTYPE" class="java.lang.String"/>
	<field name="DOCDATE" class="java.sql.Date"/>
	<field name="CRAMOUNT" class="java.math.BigDecimal"/>
	<field name="DRAMOUNT" class="java.math.BigDecimal"/>
