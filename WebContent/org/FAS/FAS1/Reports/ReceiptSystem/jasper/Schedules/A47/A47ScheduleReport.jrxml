	<field name="OFFICE_SHORT_NAME" class="java.lang.String"/>

	<variable name="cramount" class="java.lang.String" resetType="Report" calculation="Nothing">
	</variable>
	<variable name="dramount" class="java.lang.String" resetType="Report" calculation="Nothing">
	</variable>
	<variable name="SUM_CRAMOUNT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{CRAMOUNT}]]></variableExpression>
	</variable>
	<variable name="SUM_DRAMOUNT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="acchead" calculation="Sum">
		<variableExpression><![CDATA[$F{DRAMOUNT}]]></variableExpression>
	</variable>
	<variable name="netdebit" class="java.lang.Integer" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Integer( ( ($V{SUM_DRAMOUNT_1}.intValue()) -($V{SUM_CRAMOUNT_1}.intValue()) ))]]></variableExpression>
	</variable>

