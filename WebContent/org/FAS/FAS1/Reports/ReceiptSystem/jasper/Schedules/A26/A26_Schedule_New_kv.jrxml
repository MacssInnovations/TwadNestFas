<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="A26_Schedule_New_kv"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="842"
		 columnWidth="818"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="reporttype" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[WITH params AS (
  SELECT 
     $P{accountingunitid}::int AS unit_id,
    $P{accountofficeid}::int AS office_id,
   $P{cashbookyear}::int AS year,
    $P{cashbookmonth}::INT AS month,
    $P{reporttype} AS report_pattern
),
schedule_heads AS (
  SELECT account_head_code 
  FROM fas_schedulemaster 
  WHERE schedule_id = 'A26'
),
opening_bal AS (
  SELECT 
    ACCOUNT_HEAD_CODE,
    MONTH_OPENING_BAL_DR_CR_IND,
    MONTH_OPENING_BALANCE
  FROM FAS_GENERAL_LEDGER gl
  CROSS JOIN params p
  WHERE gl.ACCOUNTING_UNIT_ID = p.unit_id
    AND gl.ACCOUNTING_FOR_OFFICE_ID = p.office_id
    AND gl.YEAR = p.year
    AND gl.MONTH = p.month
    AND gl.ACCOUNT_HEAD_CODE IN (SELECT account_head_code FROM schedule_heads)
),
lookup_sl_types AS (
  SELECT sub_ledger_type_code, sub_ledger_type_desc
  FROM com_mst_sl_types
),
lookup_sl_codes AS (
  SELECT sl_type, sl_code, sl_codename
  FROM sl_type_code_name_view_M
),
lookup_heads AS (
  SELECT account_head_code, account_head_desc
  FROM com_mst_account_heads
),
lookup_units AS (
  SELECT ACCOUNTING_UNIT_ID, ACCOUNTING_UNIT_NAME
  FROM FAS_MST_ACCT_UNITS
  CROSS JOIN params p  -- Assuming single unit
  WHERE ACCOUNTING_UNIT_ID = p.unit_id
),
transactions AS (
  -- Payments
  SELECT 
    a.account_head_code,
    a.accounting_unit_id, a.accounting_for_office_id,
    a.cashbook_year, a.cashbook_month,
    a.voucher_no AS doc_no, b.payment_date AS doc_date,
    'P' AS doc_type, a.cr_dr_indicator, a.amount, a.particulars,
    a.sub_ledger_type_code,
    COALESCE(slt.sub_ledger_type_desc, '') AS sl_desc,
    a.sub_ledger_code,
    COALESCE(slv.sl_codename, '') AS sl_code_desc
  FROM fas_payment_transaction a
  JOIN fas_payment_master b ON (
    a.accounting_unit_id = b.accounting_unit_id AND
    a.accounting_for_office_id = b.accounting_for_office_id AND
    a.cashbook_year = b.cashbook_year AND
    a.cashbook_month = b.cashbook_month AND
    a.voucher_no = b.voucher_no
  )
  CROSS JOIN params p
  JOIN schedule_heads sh ON a.account_head_code = sh.account_head_code
  LEFT JOIN lookup_sl_types slt ON a.sub_ledger_type_code = slt.sub_ledger_type_code
  LEFT JOIN lookup_sl_codes slv ON (
    a.sub_ledger_type_code = slv.sl_type AND
    a.sub_ledger_code = slv.sl_code
  )
  WHERE b.PAYMENT_STATUS = 'L'
    AND a.accounting_unit_id = p.unit_id
    AND a.accounting_for_office_id = p.office_id
    AND a.cashbook_year = p.year
    AND a.cashbook_month = p.month

  UNION ALL

  -- Receipts (identical structure, change to receipt_no, receipt_date, 'R', RECEIPT_STATUS='L')
  SELECT 
    a.account_head_code, a.accounting_unit_id, a.accounting_for_office_id,
    a.cashbook_year, a.cashbook_month,
    a.receipt_no AS doc_no, b.receipt_date AS doc_date,
    'R' AS doc_type, a.cr_dr_indicator, a.amount, a.particulars,
    a.sub_ledger_type_code, COALESCE(slt.sub_ledger_type_desc, '') AS sl_desc,
    a.sub_ledger_code, COALESCE(slv.sl_codename, '') AS sl_code_desc
  FROM fas_receipt_transaction a
  JOIN fas_receipt_master b ON (
    a.accounting_unit_id = b.accounting_unit_id AND
    a.accounting_for_office_id = b.accounting_for_office_id AND
    a.cashbook_year = b.cashbook_year AND
    a.cashbook_month = b.cashbook_month AND
    a.receipt_no = b.receipt_no
  )
  CROSS JOIN params p
  JOIN schedule_heads sh ON a.account_head_code = sh.account_head_code
  LEFT JOIN lookup_sl_types slt ON a.sub_ledger_type_code = slt.sub_ledger_type_code
  LEFT JOIN lookup_sl_codes slv ON (
    a.sub_ledger_type_code = slv.sl_type AND
    a.sub_ledger_code = slv.sl_code
  )
  WHERE b.RECEIPT_STATUS = 'L'
    AND a.accounting_unit_id = p.unit_id
    AND a.accounting_for_office_id = p.office_id
    AND a.cashbook_year = p.year
    AND a.cashbook_month = p.month

  UNION ALL

  -- Journals
  SELECT 
    a.account_head_code, a.accounting_unit_id, a.accounting_for_office_id,
    a.cashbook_year, a.cashbook_month,
    a.voucher_no AS doc_no, b.voucher_date AS doc_date,
    'J' AS doc_type, a.cr_dr_indicator, a.amount, a.particulars,
    a.sub_ledger_type_code, COALESCE(slt.sub_ledger_type_desc, '') AS sl_desc,
    a.sub_ledger_code, COALESCE(slv.sl_codename, '') AS sl_code_desc
  FROM fas_journal_transaction a
  JOIN fas_journal_master b ON (
    a.accounting_unit_id = b.accounting_unit_id AND
    a.accounting_for_office_id = b.accounting_for_office_id AND
    a.cashbook_year = b.cashbook_year AND
    a.cashbook_month = b.cashbook_month AND
    a.voucher_no = b.voucher_no
  )
  CROSS JOIN params p
  JOIN schedule_heads sh ON a.account_head_code = sh.account_head_code
  LEFT JOIN lookup_sl_types slt ON a.sub_ledger_type_code = slt.sub_ledger_type_code
  LEFT JOIN lookup_sl_codes slv ON (
    a.sub_ledger_type_code = slv.sl_type AND
    a.sub_ledger_code = slv.sl_code
  )
  WHERE b.JOURNAL_STATUS = 'L'
    AND b.CREATED_BY_MODULE IN ('GJV', 'LJV')
    AND a.accounting_unit_id = p.unit_id
    AND a.accounting_for_office_id = p.office_id
    AND a.cashbook_year = p.year
    AND a.cashbook_month = p.month
)
SELECT 
  t.account_head_code AS "account_head_code",
  lh.account_head_desc as "account_head_desc",
  t.accounting_unit_id as "accounting_unit_id", t.accounting_for_office_id as "accounting_for_office_id", 
  lu.ACCOUNTING_UNIT_NAME as "ACCOUNTING_UNIT_NAME",
  t.cashbook_year, t.cashbook_month,
  t.doc_no as "doc_no", t.doc_date as "doc_date" , t.doc_type as "doc_type",
  t.cr_dr_indicator, t.amount,
  CASE WHEN t.cr_dr_indicator = 'CR' THEN t.amount ELSE 0 END AS cr_amt,
  CASE WHEN t.cr_dr_indicator = 'DR' THEN t.amount ELSE 0 END AS dr_amt,
  t.particulars, t.sub_ledger_type_code, t.sl_desc,
  t.sub_ledger_code, t.sl_code_desc,
  ob.MONTH_OPENING_BAL_DR_CR_IND, ob.MONTH_OPENING_BALANCE,
  CASE WHEN ob.MONTH_OPENING_BAL_DR_CR_IND = 'CR' THEN ob.MONTH_OPENING_BALANCE ELSE 0 END AS cr_ob_amt,
  CASE WHEN ob.MONTH_OPENING_BAL_DR_CR_IND = 'DR' THEN ob.MONTH_OPENING_BALANCE ELSE 0 END AS dr_ob_amt
FROM transactions t
JOIN opening_bal ob ON t.account_head_code = ob.ACCOUNT_HEAD_CODE
JOIN lookup_heads lh ON t.account_head_code = lh.account_head_code
CROSS JOIN lookup_units lu
CROSS JOIN params p
WHERE t.account_head_code::varchar LIKE p.report_pattern
ORDER BY t.account_head_code, t.doc_date, t.doc_type, t.doc_no;
]]></queryString>

	<field name="account_head_code" class="java.math.BigDecimal"/>
	<field name="account_head_desc" class="java.lang.String"/>
	<field name="accounting_unit_id" class="java.math.BigDecimal"/>
	<field name="accounting_for_office_id" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="cashbook_year" class="java.math.BigDecimal"/>
	<field name="cashbook_month" class="java.math.BigDecimal"/>
	<field name="doc_no" class="java.math.BigDecimal"/>
	<field name="doc_date" class="java.sql.Date"/>
	<field name="doc_type" class="java.lang.String"/>
	<field name="cr_dr_indicator" class="java.lang.String"/>
	<field name="amount" class="java.math.BigDecimal"/>
	<field name="cr_amt" class="java.math.BigDecimal"/>
	<field name="dr_amt" class="java.math.BigDecimal"/>
	<field name="particulars" class="java.lang.String"/>
	<field name="sub_ledger_type_code" class="java.math.BigDecimal"/>
	<field name="sl_desc" class="java.lang.String"/>
	<field name="sub_ledger_code" class="java.math.BigDecimal"/>
	<field name="sl_code_desc" class="java.lang.String"/>
	<field name="month_opening_bal_dr_cr_ind" class="java.lang.String"/>
	<field name="month_opening_balance" class="java.math.BigDecimal"/>
	<field name="cr_ob_amt" class="java.math.BigDecimal"/>
	<field name="dr_ob_amt" class="java.math.BigDecimal"/>

	<variable name="SUM_DR_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="accountheadcode" calculation="Sum">
		<variableExpression><![CDATA[$F{dr_amt}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="accountheadcode" calculation="Sum">
		<variableExpression><![CDATA[$F{cr_amt}]]></variableExpression>
	</variable>
	<variable name="SUM_DR_OB_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="accountheadcode" calculation="Sum">
		<variableExpression><![CDATA[$F{dr_ob_amt}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_OB_AMT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="accountheadcode" calculation="Sum">
		<variableExpression><![CDATA[$F{cr_ob_amt}]]></variableExpression>
	</variable>
	<variable name="dr_total" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{dr_ob_amt}.add($V{SUM_DR_AMT_1})]]></variableExpression>
	</variable>
	<variable name="cr_total" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{cr_ob_amt}.add($V{SUM_CR_AMT_1})]]></variableExpression>
	</variable>
	<variable name="netTotal" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{cr_total}.subtract($V{dr_total})]]></variableExpression>
	</variable>
	<variable name="ind_net" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[($V{SUM_CR_AMT_1}.equals($V{SUM_DR_AMT_1}))?"CR":"DR"]]></variableExpression>
	</variable>

