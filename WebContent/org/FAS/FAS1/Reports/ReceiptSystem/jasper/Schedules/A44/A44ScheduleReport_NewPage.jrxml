<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="A44ScheduleReport_NewPage"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountheadcode" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="reporttype" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
* 
from 
(
select 
        a.account_head_code as "acc_code", 
        c.account_head_desc  as "ACC_DESC", 
        a.particulars as "REMARKS",
        a.receipt_no as "recpno",
        'R' as "doctype",
        a.amount as "DR_AMT",
        0 as "CR_AMT" ,
        d.office_short_name as "OFFICE_SHORT_NAME",
        e.accounting_unit_name  as "ACCOUNTING_UNIT_NAME"               
from 
        fas_receipt_transaction a,
        fas_receipt_master b ,
        com_mst_account_heads c ,
        com_mst_offices d,
        fas_mst_acct_units e        
where 
        a.account_head_code=c.account_head_code and 
        a.accounting_unit_id=b.accounting_unit_id and 
        a.accounting_for_office_id=b.accounting_for_office_id and 
        a.cashbook_year=b.cashbook_year and 
        a.cashbook_month=b.cashbook_month and 
        a.accounting_for_office_id=d.office_id and
        a.accounting_unit_id=e.accounting_unit_id and
        a.receipt_no=b.receipt_no and 
        b.receipt_status!='C' and 
        a.account_head_code in (select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A44' ) and 
        a.cr_dr_indicator='DR' and 
        a.cashbook_year=$P{cashbookyear}::int and 
        a.cashbook_month=$P{cashbookmonth}::int and 
        a.accounting_unit_id=$P{accountingunitid}::int and 
        a.accounting_for_office_id=$P{accountofficeid}::int  
       
        
union all

 select 
        a.account_head_code as acc_code, 
        c.account_head_desc  as acc_desc, 
        a.particulars as remarks,
        a.receipt_no as recpno,
        'R' as doctype,
        0 as dr_amt,
        a.amount as cr_amt ,
        d.office_short_name,
        e.accounting_unit_name       
                
from 
        fas_receipt_transaction a,
        fas_receipt_master b,
        com_mst_account_heads c , 
        com_mst_offices d,
        fas_mst_acct_units e
where 
        a.account_head_code=c.account_head_code and 
        a.accounting_unit_id=b.accounting_unit_id and 
        a.accounting_for_office_id=b.accounting_for_office_id and 
        a.accounting_for_office_id=d.office_id and
        a.accounting_unit_id=e.accounting_unit_id and
        a.cashbook_year=b.cashbook_year and 
        a.cashbook_month=b.cashbook_month and 
        a.receipt_no=b.receipt_no and 
        b.receipt_status!='C' and 
        a.account_head_code in (select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A44' ) and 
        a.cr_dr_indicator='CR' and 
        a.cashbook_year=$P{cashbookyear}::int and 
        a.cashbook_month=$P{cashbookmonth}::int and 
        a.accounting_unit_id=$P{accountingunitid}::int and 
        a.accounting_for_office_id=$P{accountofficeid}::int  
       
       
union all
        
select 
       a.account_head_code as acc_code, 
       c.account_head_desc  as acc_desc, 
       a.particulars as remarks,
       a.voucher_no as recpno,
       'J' as doctype,
       a.amount as dr_amt ,
       0 as cr_amt ,
       d.office_short_name,
       e.accounting_unit_name             
from
       fas_journal_transaction a,
       fas_journal_master b ,
       com_mst_account_heads c ,
       com_mst_offices d,
       fas_mst_acct_units e
where 
       a.account_head_code=c.account_head_code and 
       a.accounting_unit_id=b.accounting_unit_id and 
       a.accounting_for_office_id=b.accounting_for_office_id and 
       a.accounting_for_office_id=d.office_id and
       a.accounting_unit_id=e.accounting_unit_id and
       a.cashbook_year=b.cashbook_year and 
       a.cashbook_month=b.cashbook_month and 
       a.voucher_no=b.voucher_no and 
       b.journal_status!='C' and 
       b.CREATED_BY_MODULE in ('GJV', 'LJV') and 
       a.account_head_code in (select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A44' )   and 
       a.cr_dr_indicator= 'DR' and 
       a.cashbook_year=$P{cashbookyear}::int and 
       a.cashbook_month=$P{cashbookmonth}::int and 
       a.accounting_unit_id=$P{accountingunitid}::int and
       a.accounting_for_office_id=$P{accountofficeid}::int  
       
                          
union  all

select 
       a.account_head_code as acc_code,  
       c.account_head_desc  as acc_desc, 
       a.particulars as remarks,
       a.voucher_no as recpno,
       'J' as doctype,
       0 as dr_amt, 
       a.amount as cr_amt ,
       d.office_short_name,
       e.accounting_unit_name              
from
       fas_journal_transaction a,
       fas_journal_master b ,
       com_mst_account_heads c ,
       com_mst_offices d,
       fas_mst_acct_units e
where 
       a.account_head_code=c.account_head_code and 
       a.accounting_unit_id=b.accounting_unit_id and 
       a.accounting_for_office_id=b.accounting_for_office_id and 
       a.accounting_for_office_id=d.office_id and
       a.accounting_unit_id=e.accounting_unit_id and
       a.cashbook_year=b.cashbook_year and 
       a.cashbook_month=b.cashbook_month and 
       a.voucher_no=b.voucher_no and 
       b.journal_status!='C' and 
       b.CREATED_BY_MODULE in ('GJV', 'LJV') and 
       a.account_head_code in (select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A44' )   and 
       a.cr_dr_indicator= 'CR' and 
       a.cashbook_year=$P{cashbookyear}::int and 
       a.cashbook_month=$P{cashbookmonth}::int and 
       a.accounting_unit_id=$P{accountingunitid}::int and
       a.accounting_for_office_id=$P{accountofficeid}::int  
       
          
 union all
     
select   
       a.account_head_code as acc_code ,  
       c.account_head_desc  as acc_desc, 
       a.particulars as remarks,
       a.voucher_no as recpno,
       'P' as doctype,
       a.amount as dr_amt,  
       0 as cr_amt ,
       d.office_short_name,
       e.accounting_unit_name 
from 
       fas_payment_transaction a,
       fas_payment_master b ,
       com_mst_account_heads c ,
       com_mst_offices d,
       fas_mst_acct_units e

where 
             a.account_head_code=c.account_head_code and 
             a.accounting_unit_id=b.accounting_unit_id and              
             a.accounting_for_office_id=d.office_id and
             a.accounting_unit_id=e.accounting_unit_id and                 
             a.cashbook_year=b.cashbook_year and 
             a.cashbook_month=b.cashbook_month and 
             a.accounting_for_office_id=b.accounting_for_office_id and 
             a.voucher_no=b.voucher_no and 
             b.payment_status!='C' and 
             a.account_head_code in (select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A44' ) and 
             a.cr_dr_indicator='DR' and 
             a.cashbook_year=$P{cashbookyear}::int and 
             a.cashbook_month=$P{cashbookmonth}::int and 
             a.accounting_unit_id=$P{accountingunitid}::int and 
             a.accounting_for_office_id=$P{accountofficeid}::int  
       

union all
           
select   
       a.account_head_code as acc_code, 
       c.account_head_desc  as acc_desc, 
       a.particulars as remarks,
       a.voucher_no as recpno,
       'P' as doctype,
       0 as dr_amt,
       a.amount as cr_amt ,
       d.office_short_name,
       e.accounting_unit_name              
from 
       fas_payment_transaction a,
       fas_payment_master b,
       com_mst_account_heads c ,
       com_mst_offices d,
       fas_mst_acct_units e
       
       
where 
             a.account_head_code=c.account_head_code and 
             a.accounting_unit_id=b.accounting_unit_id and 
             a.accounting_for_office_id=d.office_id and
             a.accounting_unit_id=e.accounting_unit_id and          
             a.cashbook_year=b.cashbook_year and 
             a.cashbook_month=b.cashbook_month and 
             a.accounting_for_office_id=b.accounting_for_office_id and 
             a.voucher_no=b.voucher_no and 
             b.payment_status!='C' and 
             a.account_head_code in (select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A44' ) and 
             a.cr_dr_indicator='CR' and 
             a.cashbook_year=$P{cashbookyear}::int and 
             a.cashbook_month=$P{cashbookmonth}::int and 
             a.accounting_unit_id=$P{accountingunitid}::int and 
             a.accounting_for_office_id=$P{accountofficeid}::int
) as opt1
----$P!{reporttype}
order by acc_code, doctype , recpno]]></queryString>

	<field name="acc_code" class="java.math.BigDecimal"/>
	<field name="ACC_DESC" class="java.lang.String"/>
	<field name="REMARKS" class="java.lang.String"/>
	<field name="recpno" class="java.math.BigDecimal"/>
	<field name="doctype" class="java.lang.String"/>
	<field name="DR_AMT" class="java.math.BigDecimal"/>
