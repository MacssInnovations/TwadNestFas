	<parameter name="Accounting_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Accounting_forofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthwords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT a.accept_voucher_no AS adviceno,
  a.accept_voucher_date    AS advicedate,
  a.amount                 AS adjamt,
  a.remarks,
  b.voucher_no   AS journalno,
  b.VOUCHER_DATE AS journalDate,
  b.cr_dr_indicator,
  b.sub_ledger_type_code,
  b.sub_ledger_code,
  b.particulars,
  b.amount,
  b.ACCOUNT_HEAD_CODE,
  (SELECT U.Accounting_Unit_Name
    FROM Fas_Mst_Acct_Units U
    where u.accounting_unit_id=b.accounting_unit_id
    ) AS unitName
FROM
  (select f2.for_accounting_unit_id,
    f2.accounting_unit_id,
    f2.accounting_for_office_id,
    f2.cashbook_year,
    f2.cashbook_month,
    f2.voucher_no,
    f2.accept_voucher_no,
    f2.accept_voucher_date,
    f2.amount,
    f2.remarks
  FROM fas_adjust_memo_mst f1,
    fas_adjust_memo_trn f2
  WHERE f1.accounting_unit_id    =f2.accounting_unit_id
  AND f1.accounting_for_office_id=f2.accounting_for_office_id
  AND f1.cashbook_year           =f2.cashbook_year
  AND f1.cashbook_month          =f2.cashbook_month
  AND f1.voucher_no              =f2.voucher_no
  AND f1.memo_status             ='L'
  AND f2.acceptance_status       ='Y'
  )a
INNER JOIN
  (SELECT f3.accounting_unit_id ,
    f3.accounting_for_office_id ,
    f3.cashbook_year ,
    f3.cashbook_month ,
    f3.voucher_no,
    f3.voucher_date,
    f4.amount,
    f4.particulars,
    f4.cr_dr_indicator,
    f4.sub_ledger_type_code,
    f4.sub_ledger_code,
    f4.ACCOUNT_HEAD_CODE
  FROM fas_journal_master f3,
    fas_journal_transaction f4
  WHERE f3.accounting_unit_id    =f4.accounting_unit_id
  AND f3.accounting_for_office_id=f4.accounting_for_office_id
  AND f3.cashbook_year           =f4.cashbook_year
  AND f3.cashbook_month          =f4.cashbook_month
  AND f3.voucher_no              =f4.voucher_no
  AND f3.journal_type_code       =70
  and f3.JOURNAL_STATUS='L'
  )b
ON a.for_accounting_unit_id   =b.accounting_unit_id
AND a.accept_voucher_no       =b.voucher_no
AND a.accept_voucher_date     =b.voucher_date
and a.amount                  =b.amount
WHERE b.accounting_unit_id    =$P{Accounting_unit_id}
and b.accounting_for_office_id=$P{Accounting_forofficeid}
AND b.cashbook_year           =$P{year}
and b.cashbook_month          =$P{month}]]></queryString>

