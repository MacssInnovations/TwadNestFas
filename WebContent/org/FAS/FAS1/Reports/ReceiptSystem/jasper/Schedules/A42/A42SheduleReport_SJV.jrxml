<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="A42SheduleReport_SJV"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="842"
		 pageHeight="842"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="reporttype" isForPrompting="true" class="java.lang.String"/>
	<parameter name="suppl_No" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * 
from 
( 
select 
  vdate as  "doc_date", 
  whom as "received_or_paid", 
  remarks as "PARTICULARS", 
  recpno  as "vou_no", 
  doctype as "DOCUMENT_TYPE", 
  case when cr_dr_indicator = 'CR' then 
  amt 
  else 
  0 end as "AMOUNT", 
  case when cr_dr_indicator = 'DR' then 
  amt 
  else 
  0 end as "PAMOUNT",   
  amt as "AMT",  
  cr_dr_indicator as "cr_dr_indicator", 
  acc_head as "ACC_HEAD",
  ( select account_head_desc from com_mst_account_heads where account_head_code = acc_head ) as "account_head_desc" , 
  ( select accounting_unit_name from fas_mst_acct_units where accounting_unit_id=$P{accountingunitid}::int  ) as "accounting_unit_name",
  ( SELECT OFFICE_SHORT_NAME FROM COM_MST_OFFICES WHERE OFFICE_ID =$P{accountofficeid}::int ) AS "OFFICE_SHORT_NAME",
  SUPPLEMENT_NO as "SUPPLEMENT_NO"
from 
( 

select
    b.voucher_date as vdate,
    '' as whom,
    a.particulars as remarks,
    a.voucher_no as recpno,
    'J' as doctype,
    a.amount as amt, 
    a.cr_dr_indicator, 
    A.ACCOUNT_HEAD_CODE AS ACC_HEAD,
    B.SUPPLEMENT_NO
    
from 
    fas_journal_transaction a,
    fas_journal_master b 
where 
    a.accounting_unit_id=b.accounting_unit_id 
and a.accounting_for_office_id=b.accounting_for_office_id 
and a.cashbook_year=b.cashbook_year 
and a.cashbook_month=b.cashbook_month
and a.voucher_no=b.voucher_no 
and b.journal_status!='C'
and a.account_head_code in ( select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A42' ) 
and a.cr_dr_indicator='CR' 
and a.cashbook_year=$P{cashbookyear}::int
and a.cashbook_month=$P{cashbookmonth}::int 
and a.accounting_unit_id=$P{accountingunitid}::int 
and a.accounting_for_office_id=$P{accountofficeid}::int 
AND B.CREATED_BY_MODULE IN ( 'SJV' )  
and b.SUPPLEMENT_NO!=$P{suppl_No}::numeric
----$P!{suppl_No} 
             
union all
        
select 
    b.voucher_date as vdate,
    '' as whom,
    a.particulars as remarks,
    a.voucher_no as recpno,
    'J' as doctype,
    a.amount as amt , 
    a.cr_dr_indicator, 
    A.ACCOUNT_HEAD_CODE AS ACC_HEAD,
    B.SUPPLEMENT_NO
from 
    fas_journal_transaction a,
    fas_journal_master b 
where 
    a.accounting_unit_id=b.accounting_unit_id 
and a.accounting_for_office_id=b.accounting_for_office_id 
and a.cashbook_year=b.cashbook_year 
and a.cashbook_month=b.cashbook_month 
and a.voucher_no=b.voucher_no 
and b.journal_status!='C' 
and a.account_head_code in ( select ACCOUNT_HEAD_CODE from FAS_SCHEDULEMASTER where SCHEDULE_ID='A42' ) 
and a.cr_dr_indicator='DR' 
and a.cashbook_year=$P{cashbookyear}::int 
and a.cashbook_month=$P{cashbookmonth}::int 
and a.accounting_unit_id=$P{accountingunitid}::int 
and a.accounting_for_office_id=$P{accountofficeid}::int 
AND B.CREATED_BY_MODULE IN ( 'SJV')  
and b.SUPPLEMENT_NO!=$P{suppl_No}::numeric
---$P!{suppl_No}

)  as opt1                   
)x

left outer join

( 
  select 
   MONTH_OPENING_BALANCE,
   MONTH_OPENING_BAL_DR_CR_IND, 
   account_head_code
 from FAS_GENERAL_LEDGER 
 where 
     ACCOUNTING_UNIT_ID=$P{accountingunitid}::int 
 and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int 
 and YEAR=$P{cashbookyear}::int 
 and MONTH=$P{cashbookmonth}::int 
       
)Y 
on 
x.acc_head = Y.account_head_code 
where x.acc_head!=$P{reporttype}::numeric
----$P!{reporttype}

order by acc_head ,doc_date, DOCUMENT_TYPE, vou_no]]></queryString>

	<field name="doc_date" class="java.sql.Date"/>
	<field name="received_or_paid" class="java.lang.String"/>
	<field name="PARTICULARS" class="java.lang.String"/>
	<field name="vou_no" class="java.math.BigDecimal"/>
	<field name="document_type" class="java.lang.String"/>
	<field name="amount" class="java.math.BigDecimal"/>
	<field name="pamount" class="java.math.BigDecimal"/>
	<field name="amt" class="java.math.BigDecimal"/>
	<field name="cr_dr_indicator" class="java.lang.String"/>
	<field name="acc_head" class="java.math.BigDecimal"/>
	<field name="account_head_desc" class="java.lang.String"/>
	<field name="accounting_unit_name" class="java.lang.String"/>
	<field name="office_short_name" class="java.lang.String"/>
	<field name="supplement_no" class="java.math.BigDecimal"/>
	<field name="month_opening_balance" class="java.math.BigDecimal"/>
	<field name="month_opening_bal_dr_cr_ind" class="java.lang.String"/>
	<field name="account_head_code" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_CODE" class="java.lang.String"/>

	<variable name="SUM_AMOUNT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="ACCHEADCODE" calculation="Sum">
		<variableExpression><![CDATA[$F{amount}]]></variableExpression>
	</variable>
	<variable name="add" class="java.lang.Double" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Double(  ($F{month_opening_balance}.doubleValue()) +($V{SUM_AMOUNT_1}.doubleValue()) )]]></variableExpression>
	</variable>
	<variable name="SUM_PAMOUNT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="ACCHEADCODE" calculation="Sum">
		<variableExpression><![CDATA[$F{pamount}]]></variableExpression>
	</variable>
	<variable name="netamt" class="java.lang.Double" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Double(  ($V{add}.doubleValue()) - ($V{SUM_PAMOUNT_1}.doubleValue()) )]]></variableExpression>
	</variable>

