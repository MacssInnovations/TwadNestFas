	<variable name="closing_Qty" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{OPEN_BAL_QTY}.add($F{RECEIPTQTYY}).subtract($F{ISSUEDQTY})]]></variableExpression>
	</variable>
	<variable name="closing_Value" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{OPENING_BAL_VALUE}.add($F{RECEIPTVALUEE}).subtract($F{ISSUEDVALUE})]]></variableExpression>
	</variable>
