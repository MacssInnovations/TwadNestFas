<!-- Created with Jaspersoft Studio version 6.20.0.final using JasperReports Library version 6.20.0-2bc7ab61c56f459e8176eb05c7705e145cd400ad  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="TrialBalance_Summary_SJV" pageWidth="927" pageHeight="595" orientation="Landscape" whenNoDataType="NoPages" columnWidth="867" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="bd89d4da-001a-4f18-ab0d-fb94fde6c7a3">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="accountingunitid" class="java.lang.Integer"/>
	<parameter name="from_cashbookmonth" class="java.lang.Integer"/>
	<parameter name="from_cashbookyear" class="java.lang.Integer"/>
	<parameter name="from_monthvalue" class="java.lang.String"/>
	<parameter name="to_cashbookmonth" class="java.lang.Integer"/>
	<parameter name="to_cashbookyear" class="java.lang.Integer"/>
	<parameter name="to_monthvalue" class="java.lang.String"/>
	<parameter name="supplementno" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[SELECT accounting_unit_id,
  accounting_unit_name,
  acchead1,
  account_head_desc ,
  cashbook_month,
  debit_opening_balance,
  credit_opening_balance,
  current_month_debit,
  current_month_credit,
  ( debit_opening_balance  + current_month_debit )  AS debit_cb ,
  ( credit_opening_balance + current_month_credit ) AS credit_cb ,
  x1,
  y1
FROM
  (SELECT *
  FROM
    (
    -- Find staring Cashbook Month and Year for each and every Account Head code
    SELECT accounting_unit_id,
      account_head_code,
      TO_CHAR(mon_year_date,'MM')     AS cashbook_month1,
      TO_CHAR(mon_year_date, 'YYYY' ) AS cashbook_year1
    FROM
      (SELECT accounting_unit_id,
        account_head_code,
        MIN(mon_year_date) AS mon_year_date
      FROM
        (SELECT accounting_unit_id,
          account_head_code,
          ( to_date(cashbook_month
          ||'-'
          || cashbook_year, 'mm-yyyy')) AS mon_year_date
        FROM fas_trial_balance
        WHERE accounting_unit_id= ($P{accountingunitid})
        AND to_date(cashbook_month
          ||'-'
          || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
          || '-'
          || ($P{from_cashbookyear}) , 'mm-yyyy')
        AND to_date( ($P{to_cashbookmonth})
          ||'-'
          || ($P{to_cashbookyear}) , 'mm-yyyy')
        UNION ALL
        SELECT accounting_unit_id,
          account_head_code,
          ( to_date(cashbook_month
          ||'-'
          || cashbook_year, 'mm-yyyy')) AS mon_year_date
        FROM fas_trial_balance_supplement
        WHERE accounting_unit_id= ($P{accountingunitid})
        AND to_date(cashbook_month
          ||'-'
          || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
          || '-'
          || ($P{from_cashbookyear}) , 'mm-yyyy')
        AND to_date( ($P{to_cashbookmonth})
          ||'-'
          || ($P{to_cashbookyear}) , 'mm-yyyy')
        AND supplement_no = 1
        UNION ALL
        SELECT accounting_unit_id,
          account_head_code,
          ( to_date(cashbook_month
          ||'-'
          || cashbook_year, 'mm-yyyy')) AS mon_year_date
        FROM fas_trial_balance_supplement
        WHERE accounting_unit_id= ($P{accountingunitid})
        AND to_date(cashbook_month
          ||'-'
          || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
          || '-'
          || ($P{from_cashbookyear}) , 'mm-yyyy')
        AND to_date( ($P{to_cashbookmonth})
          ||'-'
          || ($P{to_cashbookyear}) , 'mm-yyyy')
        AND supplement_no = $P{supplementno}
        AND supplement_no = 2
        )
      GROUP BY accounting_unit_id,
        account_head_code
      )
    ORDER BY accounting_unit_id,
      account_head_code
    ) a
  LEFT OUTER JOIN
    (
    -- Find Opening Balance in Regular TB
    SELECT accounting_unit_id AS accunitid1,
      account_head_code       AS acchead1,
      cashbook_month,
      cashbook_year,
      debit_opening_balance,
      credit_opening_balance
    FROM fas_trial_balance
    WHERE accounting_unit_id= ($P{accountingunitid})
    AND to_date(cashbook_month
      ||'-'
      || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
      || '-'
      || ($P{from_cashbookyear}) , 'mm-yyyy')
    AND to_date( ($P{to_cashbookmonth})
      ||'-'
      || ($P{to_cashbookyear}) , 'mm-yyyy')
    UNION ALL
    -- Find Opening Balance in supplement TB ( supplement no = 1 )
    SELECT accounting_unit_id AS accunitid1,
      account_head_code       AS acchead1,
      cashbook_month,
      cashbook_year,
      debit_opening_balance,
      credit_opening_balance
    FROM fas_trial_balance_supplement
    WHERE accounting_unit_id= ($P{accountingunitid})
    AND to_date(cashbook_month
      ||'-'
      || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
      || '-'
      || ($P{from_cashbookyear}) , 'mm-yyyy')
    AND to_date( ($P{to_cashbookmonth})
      ||'-'
      || ($P{to_cashbookyear}) , 'mm-yyyy')
    AND supplement_no          = 1
    AND account_head_code NOT IN
      (SELECT account_head_code
      FROM fas_trial_balance
      WHERE accounting_unit_id=($P{accountingunitid})
      AND to_date(cashbook_month
        ||'-'
        || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
        || '-'
        || ($P{from_cashbookyear}) , 'mm-yyyy')
      AND to_date( ($P{to_cashbookmonth})
        ||'-'
        || ($P{to_cashbookyear}) , 'mm-yyyy')
      )
    AND account_head_code NOT IN
      (SELECT account_head_code
      FROM fas_trial_balance_supplement
      WHERE accounting_unit_id=($P{accountingunitid})
      AND to_date(cashbook_month
        ||'-'
        || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
        || '-'
        || ($P{from_cashbookyear}) , 'mm-yyyy')
      AND to_date( ($P{to_cashbookmonth})
        ||'-'
        || ($P{to_cashbookyear}) , 'mm-yyyy')
      AND supplement_no = 2
      )
    UNION ALL
    -- Find Opening Balance in supplement TB ( supplement_no = 2)
    SELECT accounting_unit_id AS accunitid1,
      account_head_code       AS acchead1,
      cashbook_month,
      cashbook_year,
      debit_opening_balance,
      credit_opening_balance
    FROM fas_trial_balance_supplement
    WHERE accounting_unit_id= ($P{accountingunitid})
    AND to_date(cashbook_month
      ||'-'
      || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
      || '-'
      || ($P{from_cashbookyear}) , 'mm-yyyy')
    AND to_date( ($P{to_cashbookmonth})
      ||'-'
      || ($P{to_cashbookyear}) , 'mm-yyyy')
    AND supplement_no          = $P{supplementno}
    AND supplement_no          = 2
    AND account_head_code NOT IN
      (SELECT account_head_code
      FROM fas_trial_balance
      WHERE accounting_unit_id=($P{accountingunitid})
      AND to_date(cashbook_month
        ||'-'
        || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
        || '-'
        || ($P{from_cashbookyear}) , 'mm-yyyy')
      AND to_date( ($P{to_cashbookmonth})
        ||'-'
        || ($P{to_cashbookyear}) , 'mm-yyyy')
      )
    ) b
  ON a.accounting_unit_id = b.accunitid1
  AND a.account_head_code = b.acchead1
  AND a.cashbook_month1   = b.cashbook_month
  AND a.cashbook_year1    = b.cashbook_year
  LEFT OUTER JOIN
    (
    -- Find Sum of Current Month Debit and Current Month Credit
    SELECT account_head_code,
      SUM(current_month_debit)  AS current_month_debit,
      SUM(current_month_credit) AS current_month_credit
    FROM
      (SELECT account_head_code,
        current_month_debit,
        current_month_credit
      FROM fas_trial_balance
      WHERE accounting_unit_id=($P{accountingunitid})
      AND to_date(cashbook_month
        ||'-'
        || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
        || '-'
        || ($P{from_cashbookyear}) , 'mm-yyyy')
      AND to_date( ($P{to_cashbookmonth})
        ||'-'
        || ($P{to_cashbookyear}) , 'mm-yyyy')
      UNION ALL
      SELECT account_head_code,
        current_month_debit,
        current_month_credit
      FROM fas_trial_balance_supplement
      WHERE accounting_unit_id = ($P{accountingunitid})
      AND cashbook_month       = $P{to_cashbookmonth}
      AND cashbook_year        = $P{to_cashbookyear}
      AND supplement_no        = 1
      UNION ALL
      SELECT account_head_code,
        current_month_debit,
        current_month_credit
      FROM fas_trial_balance_supplement
      WHERE accounting_unit_id = ($P{accountingunitid})
      AND cashbook_month       = $P{to_cashbookmonth}
      AND cashbook_year        = $P{to_cashbookyear}
      AND supplement_no        = $P{supplementno}
      AND supplement_no        = 2
      )
    GROUP BY account_head_code
    ORDER BY account_head_code
    )c
  ON b.acchead1=c.account_head_code
  LEFT OUTER JOIN
    (SELECT account_head_desc,
      account_head_code AS achcode
    FROM com_mst_account_heads
    )d
  ON d.achcode=c.account_head_code
  LEFT OUTER JOIN
    (SELECT accounting_unit_id AS aunitid,
      accounting_unit_name
    FROM fas_mst_acct_units
    )e
  ON e.aunitid=a.accounting_unit_id
  ),
  (SELECT SUM(CURRENT_MONTH_DEBIT) AS x1 ,
    SUM(CURRENT_MONTH_CREDIT)      AS y1
  FROM
    (SELECT current_month_debit,
      current_month_credit
    FROM fas_trial_balance
    WHERE accounting_unit_id= ($P{accountingunitid})
    AND to_date(cashbook_month
      ||'-'
      || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
      || '-'
      || ($P{from_cashbookyear}) , 'mm-yyyy')
    AND to_date( ($P{to_cashbookmonth})
      ||'-'
      || ($P{to_cashbookyear}) , 'mm-yyyy')
    UNION ALL
    SELECT current_month_debit,
      current_month_credit
    FROM fas_trial_balance_supplement
    WHERE accounting_unit_id= ($P{accountingunitid})
    AND to_date(cashbook_month
      ||'-'
      || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
      || '-'
      || ($P{from_cashbookyear}) , 'mm-yyyy')
    AND to_date( ($P{to_cashbookmonth})
      ||'-'
      || ($P{to_cashbookyear}) , 'mm-yyyy')
    AND supplement_no = 1
    UNION ALL
    SELECT current_month_debit,
      current_month_credit
    FROM fas_trial_balance_supplement
    WHERE accounting_unit_id= ($P{accountingunitid})
    AND to_date(cashbook_month
      ||'-'
      || + cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbookmonth})
      || '-'
      || ($P{from_cashbookyear}) , 'mm-yyyy')
    AND to_date( ($P{to_cashbookmonth})
      ||'-'
      || ($P{to_cashbookyear}) , 'mm-yyyy')
    AND supplement_no = $P{supplementno}
    AND supplement_no = 2
    )
  )
ORDER BY acchead1]]>
	</queryString>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="ACCHEAD1" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="DEBIT_OPENING_BALANCE" class="java.math.BigDecimal"/>
	<field name="CREDIT_OPENING_BALANCE" class="java.math.BigDecimal"/>
	<field name="CURRENT_MONTH_DEBIT" class="java.math.BigDecimal"/>
	<field name="CURRENT_MONTH_CREDIT" class="java.math.BigDecimal"/>
	<field name="DEBIT_CB" class="java.math.BigDecimal"/>
	<field name="CREDIT_CB" class="java.math.BigDecimal"/>
	<field name="X1" class="java.lang.String"/>
	<field name="Y1" class="java.lang.String"/>
	<variable name="SUM_DEBIT_OPENING_BALANCE_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="SUM_CREDIT_OPENING_BALANCE_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="SUM_CURRENT_MONTH_DEBIT_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_DEBIT}]]></variableExpression>
	</variable>
	<variable name="SUM_CURRENT_MONTH_CREDIT_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_CREDIT}]]></variableExpression>
	</variable>
	<variable name="SUM_DEBIT_CB_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_CB}]]></variableExpression>
	</variable>
	<variable name="SUM_CREDIT_CB_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_CB}]]></variableExpression>
	</variable>
	<variable name="SUM_DEBIT_OPENING_BALANCE_2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="SUM_CREDIT_OPENING_BALANCE_2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="SUM_CURRENT_MONTH_DEBIT_2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_DEBIT}]]></variableExpression>
	</variable>
	<variable name="SUM_CURRENT_MONTH_CREDIT_2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_CREDIT}]]></variableExpression>
	</variable>
	<variable name="SUM_DEBIT_CB_2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_CB}]]></variableExpression>
	</variable>
	<variable name="SUM_CREDIT_CB_2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_CB}]]></variableExpression>
	</variable>
	<variable name="net" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_DEBIT}.subtract($F{CURRENT_MONTH_CREDIT})]]></variableExpression>
	</variable>
