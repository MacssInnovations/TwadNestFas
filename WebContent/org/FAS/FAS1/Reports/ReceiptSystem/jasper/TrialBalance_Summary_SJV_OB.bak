<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="TrialBalance_Summary_SJV_OB"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supplementno" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 
      accounting_unit_id,
      accounting_unit_name,
      acchead1,
      account_head_desc ,
      cashbook_month,
      debit_opening_balance, 
      credit_opening_balance,
      current_month_debit,
      current_month_credit,      
      ( debit_opening_balance + current_month_debit ) as debit_cb ,
      ( credit_opening_balance + current_month_credit ) as credit_cb ,     
      x1,
      y1
from 
(

select * from
(

-- Find staring Cashbook Month and Year for each and every Account Head code 
  select 
      accounting_unit_id, 
      account_head_code, 
      to_char(mon_year_date,'MM') as cashbook_month1,
      to_char(mon_year_date, 'YYYY' ) as cashbook_year1
  from 
  (
       select 
         accounting_unit_id, 
         account_head_code, 
         min(mon_year_date) as mon_year_date
      from 
      (
          select 
            accounting_unit_id, 
            account_head_code, 
            ( to_date(cashbook_month ||'-'|| cashbook_year, 'mm-yyyy')) as mon_year_date
          from
            fas_trial_balance 
          where       
            accounting_unit_id= ($P{accountingunitid}) and 
            to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
  
          union all 
          
          select 
            accounting_unit_id, 
            account_head_code, 
            ( to_date(cashbook_month ||'-'|| cashbook_year, 'mm-yyyy')) as mon_year_date
          from
            fas_trial_balance_supplement 
          where       
            accounting_unit_id= ($P{accountingunitid}) and 
            to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
            and supplement_no = 1
            
          union all 
          
          select 
            accounting_unit_id, 
            account_head_code, 
            ( to_date(cashbook_month ||'-'|| cashbook_year, 'mm-yyyy')) as mon_year_date
          from
            fas_trial_balance_supplement 
          where       
            accounting_unit_id= ($P{accountingunitid}) and 
            to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
            and supplement_no = $P{supplementno}
            and supplement_no= 2 
 
 
     )
     group by accounting_unit_id, account_head_code
  )
  order by accounting_unit_id, account_head_code 

) a


left outer join

(
-- Find Opening Balance in Regular TB 
select 
   accounting_unit_id as accunitid1,
   account_head_code as acchead1,
   cashbook_month, 
   cashbook_year,
   debit_opening_balance, 
   credit_opening_balance
from 
   fas_trial_balance
where  
   accounting_unit_id= ($P{accountingunitid}) and 
   to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
 
union all 

-- Find Opening Balance in supplement TB ( supplement no = 1 ) 
select 
   accounting_unit_id as accunitid1,
   account_head_code as acchead1,
   cashbook_month, 
   cashbook_year,
   debit_opening_balance, 
   credit_opening_balance
from 
   fas_trial_balance_supplement 
where  
   accounting_unit_id= ($P{accountingunitid}) and 
   to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
   and supplement_no = 1
   and account_head_code not in ( 
                                select account_head_code from fas_trial_balance 
                                where
                                  accounting_unit_id=($P{accountingunitid}) and 
                                  to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
                               )
                   and account_head_code not in ( 
                                select account_head_code from fas_trial_balance_supplement  
                                where
                                  accounting_unit_id=($P{accountingunitid}) and 
                                  to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
                                   and supplement_no = 2
                               )             
                               
  union all 

-- Find Opening Balance in supplement TB ( supplement_no = 2)
select 
   accounting_unit_id as accunitid1,
   account_head_code as acchead1,
   cashbook_month, 
   cashbook_year,
   debit_opening_balance, 
   credit_opening_balance
from 
   fas_trial_balance_supplement 
where  
   accounting_unit_id= ($P{accountingunitid}) and 
   to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
   and supplement_no = $P{supplementno}
   and supplement_no = 2 
   and account_head_code not in ( 
                                select account_head_code from fas_trial_balance 
                                where
                                  accounting_unit_id=($P{accountingunitid}) and 
                                  to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
                               )                             
      
) b

on  a.accounting_unit_id = b.accunitid1 and 
    a.account_head_code = b.acchead1 and 
    a.cashbook_month1 = b.cashbook_month  and 
    a.cashbook_year1 = b.cashbook_year   

left outer join 

(
-- Find Sum of Current Month Debit and Current Month Credit 
 
  select
      account_head_code,
      sum(current_month_debit) as current_month_debit,
      sum(current_month_credit) as current_month_credit     
  from 
  (
    select 
      account_head_code,
      current_month_debit,
      current_month_credit
    from 
      fas_trial_balance 
    where 
      accounting_unit_id=($P{accountingunitid}) and 
      to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
 
    union all 

    select 
      account_head_code,
      current_month_debit,
      current_month_credit
    from 
      fas_trial_balance_supplement 
    where 
      accounting_unit_id = ($P{accountingunitid}) and 
      cashbook_month = $P{to_cashbookmonth} and 
      cashbook_year = $P{to_cashbookyear} and 
      supplement_no = 1
      
    union all 
    
    select 
      account_head_code,
      current_month_debit,
      current_month_credit
    from 
      fas_trial_balance_supplement 
    where 
      accounting_unit_id = ($P{accountingunitid}) and 
      cashbook_month = $P{to_cashbookmonth} and 
      cashbook_year = $P{to_cashbookyear} and 
      supplement_no = $P{supplementno} and 
      supplement_no = 2 
      
      
  )   
  group by account_head_code   
  order by account_head_code
     
)c
on b.acchead1=c.account_head_code 

left outer join 

(
select account_head_desc, account_head_code as achcode from com_mst_account_heads
)d
on d.achcode=c.account_head_code
   
left outer join 
(
select accounting_unit_id as aunitid, accounting_unit_name from fas_mst_acct_units   
)e
on e.aunitid=a.accounting_unit_id
),


( 

  select 
     sum(CURRENT_MONTH_DEBIT) as x1 , 
     sum(CURRENT_MONTH_CREDIT) as  y1 
  from 
  (
      select 
        current_month_debit, 
        current_month_credit
      from  
        fas_trial_balance 
      where 
        accounting_unit_id= ($P{accountingunitid}) and       
        to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')

      union all 
  
      select 
        current_month_debit, 
        current_month_credit
      from  
        fas_trial_balance_supplement  
      where 
        accounting_unit_id= ($P{accountingunitid}) and       
        to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
        and supplement_no = 1
        
      union all 
      
        select 
        current_month_debit, 
        current_month_credit
      from  
        fas_trial_balance_supplement  
      where 
        accounting_unit_id= ($P{accountingunitid}) and       
        to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{from_cashbookmonth})  || '-' || ($P{from_cashbookyear}) ,   'mm-yyyy')  AND to_date( ($P{to_cashbookmonth}) ||'-' || ($P{to_cashbookyear}) , 'mm-yyyy')
        and supplement_no = $P{supplementno}
        and supplement_no = 2 
      
      
        
  )
  
)

order by acchead1]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="ACCHEAD1" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="DEBIT_OPENING_BALANCE" class="java.math.BigDecimal"/>
	<field name="CREDIT_OPENING_BALANCE" class="java.math.BigDecimal"/>
	<field name="CURRENT_MONTH_DEBIT" class="java.math.BigDecimal"/>
	<field name="CURRENT_MONTH_CREDIT" class="java.math.BigDecimal"/>
	<field name="DEBIT_CB" class="java.lang.Double"/>
	<field name="CREDIT_CB" class="java.lang.Double"/>
	<field name="X1" class="java.lang.String"/>
	<field name="Y1" class="java.lang.String"/>

	<variable name="SUM_DEBIT_OPENING_BALANCE_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="SUM_CREDIT_OPENING_BALANCE_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="SUM_CURRENT_MONTH_DEBIT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_DEBIT}]]></variableExpression>
	</variable>
	<variable name="SUM_CURRENT_MONTH_CREDIT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_CREDIT}]]></variableExpression>
	</variable>
	<variable name="SUM_DEBIT_CB_1" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_CB}]]></variableExpression>
	</variable>
	<variable name="SUM_CREDIT_CB_1" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_CB}]]></variableExpression>
	</variable>
	<variable name="SUM_DEBIT_OPENING_BALANCE_2" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="SUM_CREDIT_OPENING_BALANCE_2" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="SUM_CURRENT_MONTH_DEBIT_2" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_DEBIT}]]></variableExpression>
	</variable>
	<variable name="SUM_CURRENT_MONTH_CREDIT_2" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_CREDIT}]]></variableExpression>
	</variable>
	<variable name="SUM_DEBIT_CB_2" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_CB}]]></variableExpression>
	</variable>
	<variable name="SUM_CREDIT_CB_2" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_CB}]]></variableExpression>
	</variable>
	<variable name="net" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CURRENT_MONTH_DEBIT}.subtract($F{CURRENT_MONTH_CREDIT})]]></variableExpression>
	</variable>
