	<parameter name="finyear" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select  
     a.account_head_code,
     a.accounting_unit_id, 
    sum(a.current_month_debit) as current_month_debit, 
    sum(a.current_month_credit) as current_month_credit 
 from 
    FAS_TRAIL_BALANCE_DATA_9507 a        
 where 

fin_year=$P{finyear}
 
 group by a.accounting_unit_id , a.account_head_code 
 order by a.accounting_unit_id, a.account_head_code 
 ) X
 left outer join
 (
 select ACCOUNTING_UNIT_ID,ACCOUNTING_UNIT_NAME from FAS_MST_ACCNT_UNIT_OLD9507 b
 
 ) Y
 on X.ACCOUNTING_UNIT_ID=Y.ACCOUNTING_UNIT_ID]]></queryString>

