	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="from_month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="m" isForPrompting="true" class="java.lang.String"/>
	<parameter name="m1" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT Cashbook_Month,
    (
    CASE Cashbook_Month
      WHEN 1
      THEN 'Jan'
      WHEN 2
      THEN 'Feb'
      WHEN 3
      THEN 'Mar Regular'
      WHEN 4
      THEN 'Apr'
      WHEN 5
      THEN 'May'
      WHEN 6
      THEN 'Jun'
      WHEN 7
      THEN 'July'
      WHEN 8
      THEN 'Aug'
      WHEN 9
      THEN 'Sep'
      WHEN 10
      THEN 'Oct'
      WHEN 11
      THEN 'Nov'
      WHEN 12
      THEN 'Dec'
    END)AS MONTH ,
    Cashbook_Year,
    SUM(CURRENT_MONTH_DEBIT),
    SUM(CURRENT_MONTH_CREDIT)
  FROM FAS_TRIAL_BALANCE_CMP
  WHERE To_Date((Cashbook_Month
    ||'-'
    || Cashbook_Year),'mm-yyyy') BETWEEN To_Date($P{from_month}
    ||'-'
    ||$P{from_year},'mm-yyyy')
  AND to_date($P{to_month}
    ||'-'
    ||$P{to_year},'mm-yyyy')
  GROUP BY Cashbook_Month,
    Cashbook_Year
   ORDER BY Cashbook_Year,
    Cashbook_Month]]></queryString>

	<field name="cashbook_month" class="java.math.BigDecimal"/>
	<field name="month" class="java.lang.String"/>
	<field name="cashbook_year" class="java.math.BigDecimal"/>
	<field name="sum" class="java.math.BigDecimal"/>

	<variable name="sum_Dr" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{cashbook_month}]]></variableExpression>
	</variable>
	<variable name="Sum_cr" class="java.lang.String" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{month}]]></variableExpression>
	</variable>

