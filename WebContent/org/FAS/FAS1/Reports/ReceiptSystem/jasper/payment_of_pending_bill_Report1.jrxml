<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="payment_of_pending_bill_Report1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1019"
		 pageHeight="842"
		 columnWidth="959"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="heading" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT a.*,
  b.row_numm
FROM (
  (SELECT aa.Accounting_Unit_Id,
    aa.Accounting_For_Office_Id,
    (SELECT Uu.Accounting_Unit_Name
    FROM fas_mst_acct_units uu
    WHERE Uu.Accounting_Unit_Id=aa.Accounting_Unit_Id
    )AS "ORGUNITNAME",
    aa.CASHBOOK_YEAR,
    aa.CASHBOOK_MONTH,
    aa.SL_NO as "sl_no",
    aa.voucher_date as "voucher_date",
    aa.VOUCHER_NO as "voucher_no",
    aa.CHEQUE_DD_NO as "cheque_dd_no",
    aa.CHEQUE_DD_DATE as "cheque_dd_date",
    aa.AMOUNT as "amount",
    aa.SUB_LEDGER_TYPE_CODE as "sub_ledger_type_code",
    (SELECT S.Sub_Ledger_Type_Desc
    FROM com_mst_sl_types s
    WHERE s.SUB_LEDGER_TYPE_CODE=Aa.Sub_Ledger_Type_Code
    )AS sl_desc,
    aa.Sub_Ledger_Code,
    (SELECT l.SL_CODENAME
    FROM SL_TYPE_CODE_NAME_VIEW_M l
    WHERE L.Sl_Type=Aa.Sub_Ledger_Type_Code
    AND L.Sl_Code  =Aa.Sub_Ledger_Code
   -- AND rownum = 1
		limit 1
    )AS "code_desc" ,
    aa.cb_ref_no,
    aa.cb_ref_date,
    aa.cheque_or_dd ,
    aa.ljvamount,
    bb.VOUCHER_NO pay_no,
    bb.PAYMENT_DATE,
    bb.AMOUNT AS pay_amt,
    aa.multiple_pvrs,
    aa.account_head_code ,
    (SELECT h.account_head_desc
    FROM com_mst_account_heads h
    WHERE h.account_head_code= aa.account_head_code
    ) AS head_desc
  FROM
    (SELECT a.Accounting_Unit_Id,
      a.Accounting_For_Office_Id,
      a.CASHBOOK_YEAR,
      a.CASHBOOK_MONTH,
      b.SL_NO,
      a.voucher_date,
      a.VOUCHER_NO,
      b.CHEQUE_DD_NO,
      b.CHEQUE_DD_DATE,
      b.AMOUNT,
      b.SUB_LEDGER_TYPE_CODE,
      b.Sub_Ledger_Code,
      b.cb_ref_no,
      b.cb_ref_date,
      b.cheque_or_dd ,
      b.AMOUNT AS ljvamount,
      b.multiple_pvrs,
      b.account_head_code
    FROM FAS_JOURNAL_MASTER a
    INNER JOIN FAS_JOURNAL_TRANSACTION b
    ON A.Accounting_Unit_Id       =B.Accounting_Unit_Id
    AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
    AND A.Cashbook_Year           =B.Cashbook_Year
    AND A.Cashbook_Month          =B.Cashbook_Month
    AND A.Voucher_No              =B.Voucher_No
    AND a.ACCOUNTING_UNIT_ID      =$P{unitid}::int 
    AND a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}::int
    AND A.CASHBOOK_MONTH          =$P{cashbookmonth}::int
    AND a.CASHBOOK_YEAR           =$P{cashbookyear}::int
    AND A.JOURNAL_STATUS          ='L'
    AND B.CR_DR_INDICATOR='CR'
         AND B.SUB_LEDGER_TYPE_CODE !=0
         and b.Sub_Ledger_Code!=0
      --AND b.cheque_dd_date         IS NOT NULL
      --AND b.cheque_dd_no            > 0
    AND ( b.multiple_pvrs IS NULL
    OR b.multiple_pvrs     = 'N') 
    )AA
  LEFT OUTER JOIN
    (SELECT a1.ACCOUNTING_UNIT_ID ,
      a1.ACCOUNTING_FOR_OFFICE_ID,
      a1.CASHBOOK_YEAR, 
      a1.CASHBOOK_MONTH,
      B1.SL_NO,
      b1.PAYABLE_VOUCHER_SLNO,
      a1.PAYMENT_DATE,
      a1.VOUCHER_NO,
      b1.CHEQUE_DD_NO,
      b1.CHEQUE_DD_DATE,
      b1.AMOUNT,
      a1.SUB_LEDGER_TYPE_CODE,
      A1.Sub_Ledger_Code,
      b1.PAYABLE_VOUCHER_NO,
      b1.PAYABLE_VOUCHER_DATE
    FROM FAS_PAYMENT_MASTER a1
    INNER JOIN FAS_PAYMENT_TRANSACTION b1
    ON A1.Accounting_Unit_Id       =B1.Accounting_Unit_Id
    AND A1.Accounting_For_Office_Id=B1.Accounting_For_Office_Id
    AND A1.Cashbook_Year           =B1.Cashbook_Year
    AND A1.Cashbook_Month          =B1.Cashbook_Month
    AND A1.Voucher_No              =B1.Voucher_No
    AND a1.CREATED_BY_MODULE       ='BPP'
    AND a1.PAYMENT_STATUS          ='L'
    AND a1.ACCOUNTING_UNIT_ID      =$P{unitid}::int
    AND a1.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}::int
    )bb ON aa.Accounting_Unit_Id   =bb.Accounting_Unit_Id
  AND aa.Accounting_For_Office_Id  =bb.Accounting_For_Office_Id
  AND aa.Voucher_No                = bb.PAYABLE_VOUCHER_NO
  AND aa.voucher_date              = bb.PAYABLE_VOUCHER_DATE
  AND aa.SUB_LEDGER_TYPE_CODE      =bb.SUB_LEDGER_TYPE_CODE
  AND AA.SUB_LEDGER_CODE           =BB.SUB_LEDGER_CODE
  AND aa.CHEQUE_DD_NO              =bb.CHEQUE_DD_NO
  AND AA.CHEQUE_DD_DATE            =BB.CHEQUE_DD_DATE
  AND aa.SL_NO                     =bb.PAYABLE_VOUCHER_SLNO
  )
UNION ALL
  (SELECT aa.Accounting_Unit_Id,
    aa.Accounting_For_Office_Id,
    (SELECT Uu.Accounting_Unit_Name
    FROM fas_mst_acct_units uu
    WHERE Uu.Accounting_Unit_Id=aa.Accounting_Unit_Id
    )AS orgunitname,
    aa.CASHBOOK_YEAR,
    aa.CASHBOOK_MONTH,
    aa.SL_NO,
    aa.voucher_date,
    aa.VOUCHER_NO,
    aa.CHEQUE_DD_NO,
    aa.CHEQUE_DD_DATE,
    aa.AMOUNT,
    aa.SUB_LEDGER_TYPE_CODE,
    (SELECT S.Sub_Ledger_Type_Desc
    FROM com_mst_sl_types s
    WHERE s.SUB_LEDGER_TYPE_CODE=Aa.Sub_Ledger_Type_Code
    )AS sl_desc,
    aa.Sub_Ledger_Code,
    (SELECT l.SL_CODENAME
    FROM SL_TYPE_CODE_NAME_VIEW_M l
    WHERE L.Sl_Type=Aa.Sub_Ledger_Type_Code
    AND L.Sl_Code  =Aa.Sub_Ledger_Code
    )AS code_desc ,
    aa.cb_ref_no,
    aa.cb_ref_date,
    aa.cheque_or_dd ,
    aa.ljvamount,
    bb.VOUCHER_NO pay_no,
    bb.PAYMENT_DATE,
    bb.AMOUNT AS pay_amt,
    aa.multiple_pvrs,
    aa.account_head_code ,
    (SELECT h.account_head_desc
    FROM com_mst_account_heads h
    WHERE h.account_head_code= aa.account_head_code
    ) AS head_desc
  FROM
    (SELECT a.Accounting_Unit_Id,
      a.Accounting_For_Office_Id,
      a.CASHBOOK_YEAR,
      a.CASHBOOK_MONTH,
      b.SL_NO,
      a.voucher_date,
      a.VOUCHER_NO,
      b.CHEQUE_DD_NO,
      b.CHEQUE_DD_DATE,
      b.AMOUNT,
      b.SUB_LEDGER_TYPE_CODE,
      b.Sub_Ledger_Code,
      b.cb_ref_no,
      b.cb_ref_date,
      b.cheque_or_dd ,
      b.AMOUNT AS ljvamount,
      b.multiple_pvrs,
      b.account_head_code
    FROM FAS_JOURNAL_MASTER a
    INNER JOIN FAS_JOURNAL_TRANSACTION b
    ON A.Accounting_Unit_Id       =B.Accounting_Unit_Id
    AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
    AND A.Cashbook_Year           =B.Cashbook_Year
    AND A.Cashbook_Month          =B.Cashbook_Month
    AND A.Voucher_No              =B.Voucher_No
    AND a.ACCOUNTING_UNIT_ID      =$P{unitid}::int
    AND a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}::int
    AND a.CASHBOOK_MONTH          =$P{cashbookmonth}::int
    AND a.CASHBOOK_YEAR           =$P{cashbookyear}::int
    AND A.JOURNAL_STATUS          ='L'
    AND B.CR_DR_INDICATOR='CR'
         AND B.SUB_LEDGER_TYPE_CODE !=0
         and b.Sub_Ledger_Code!=0
      --AND b.cheque_dd_date         IS NOT NULL
      --AND b.cheque_dd_no            > 0
    AND b.multiple_pvrs = 'Y'
    )AA
  LEFT OUTER JOIN
    (SELECT a1.ACCOUNTING_UNIT_ID ,
      a1.ACCOUNTING_FOR_OFFICE_ID,
      a1.CASHBOOK_YEAR,
      a1.CASHBOOK_MONTH,
      B1.SL_NO,
      b1.PAYABLE_VOUCHER_SLNO,
      a1.PAYMENT_DATE,
      a1.VOUCHER_NO,
      b1.CHEQUE_DD_NO,
      b1.CHEQUE_DD_DATE,
      b1.AMOUNT,
      a1.SUB_LEDGER_TYPE_CODE,
      A1.Sub_Ledger_Code,
      b1.PAYABLE_VOUCHER_NO,
      b1.PAYABLE_VOUCHER_DATE
    FROM FAS_PAYMENT_MASTER a1
    INNER JOIN FAS_PAYMENT_TRANSACTION b1
    ON A1.Accounting_Unit_Id       =B1.Accounting_Unit_Id
    AND A1.Accounting_For_Office_Id=B1.Accounting_For_Office_Id
    AND A1.Cashbook_Year           =B1.Cashbook_Year
    AND A1.Cashbook_Month          =B1.Cashbook_Month
    AND A1.Voucher_No              =B1.Voucher_No
    AND a1.CREATED_BY_MODULE       ='BPP'
    AND a1.PAYMENT_STATUS          ='L'
    AND a1.ACCOUNTING_UNIT_ID      =$P{unitid}::int
    AND a1.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}::int
    )bb ON aa.Accounting_Unit_Id   =bb.Accounting_Unit_Id
  AND aa.Accounting_For_Office_Id  =bb.Accounting_For_Office_Id
  AND aa.Voucher_No                = bb.PAYABLE_VOUCHER_NO
  AND aa.voucher_date              = bb.PAYABLE_VOUCHER_DATE
  AND aa.SUB_LEDGER_TYPE_CODE      =bb.SUB_LEDGER_TYPE_CODE
  AND AA.SUB_LEDGER_CODE           =BB.SUB_LEDGER_CODE
  AND aa.SL_NO                     =bb.PAYABLE_VOUCHER_SLNO
  )
ORDER BY Accounting_Unit_Id,
  ljvamount ) A
INNER JOIN
 ---- (SELECT rownum AS row_numm,
 (SELECT row_number() over() AS row_numm,
    Sub_Ledger_Code
  FROM
    (SELECT DISTINCT Sub_Ledger_Code
    FROM (
      (SELECT aa.Accounting_Unit_Id,
        aa.Accounting_For_Office_Id,
        (SELECT Uu.Accounting_Unit_Name
        FROM fas_mst_acct_units uu
        WHERE Uu.Accounting_Unit_Id=aa.Accounting_Unit_Id
        )AS orgunitname,
        aa.CASHBOOK_YEAR,
        aa.CASHBOOK_MONTH,
        aa.SL_NO,
        aa.voucher_date,
        aa.VOUCHER_NO,
        aa.CHEQUE_DD_NO,
        aa.CHEQUE_DD_DATE,
        aa.AMOUNT,
        aa.SUB_LEDGER_TYPE_CODE,
        (SELECT S.Sub_Ledger_Type_Desc
        FROM com_mst_sl_types s
        WHERE s.SUB_LEDGER_TYPE_CODE=Aa.Sub_Ledger_Type_Code
        )AS sl_desc,
        aa.Sub_Ledger_Code,
        (SELECT l.SL_CODENAME
        FROM SL_TYPE_CODE_NAME_VIEW_M l
        WHERE L.Sl_Type=Aa.Sub_Ledger_Type_Code
        AND L.Sl_Code  =Aa.Sub_Ledger_Code
        )AS code_desc ,
        aa.cb_ref_no,
        aa.cb_ref_date,
        aa.cheque_or_dd ,
        aa.ljvamount,
        bb.VOUCHER_NO pay_no,
        bb.PAYMENT_DATE,
        bb.AMOUNT AS pay_amt,
        aa.multiple_pvrs,
        aa.account_head_code ,
        (SELECT h.account_head_desc
        FROM com_mst_account_heads h
        WHERE h.account_head_code= aa.account_head_code
        ) AS head_desc
      FROM
        (SELECT a.Accounting_Unit_Id,
          a.Accounting_For_Office_Id,
          a.CASHBOOK_YEAR,
          a.CASHBOOK_MONTH,
          b.SL_NO,
          a.voucher_date,
          a.VOUCHER_NO,
          b.CHEQUE_DD_NO,
          b.CHEQUE_DD_DATE,
          b.AMOUNT,
          b.SUB_LEDGER_TYPE_CODE,
          b.Sub_Ledger_Code,
          b.cb_ref_no,
          b.cb_ref_date,
          b.cheque_or_dd ,
          b.AMOUNT AS ljvamount,
          b.multiple_pvrs,
          b.account_head_code
        FROM FAS_JOURNAL_MASTER a
        INNER JOIN FAS_JOURNAL_TRANSACTION b
        ON A.Accounting_Unit_Id       =B.Accounting_Unit_Id
        AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
        AND A.Cashbook_Year           =B.Cashbook_Year
        AND A.Cashbook_Month          =B.Cashbook_Month
        AND A.Voucher_No              =B.Voucher_No
        AND a.ACCOUNTING_UNIT_ID      =$P{unitid}::int
        AND a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}::int
        AND a.CASHBOOK_MONTH          =$P{cashbookmonth}::int
        AND a.CASHBOOK_YEAR           =$P{cashbookyear}::int
        AND A.JOURNAL_STATUS          ='L'
        AND B.CR_DR_INDICATOR='CR'
         AND B.SUB_LEDGER_TYPE_CODE !=0
         and b.Sub_Ledger_Code!=0
          --AND b.cheque_dd_date         IS NOT NULL
          -- AND b.cheque_dd_no            > 0
        AND ( b.multiple_pvrs IS NULL
        OR b.multiple_pvrs     = 'N')
        )AA
      LEFT OUTER JOIN
        (SELECT a1.ACCOUNTING_UNIT_ID ,
          a1.ACCOUNTING_FOR_OFFICE_ID,
          a1.CASHBOOK_YEAR,
          a1.CASHBOOK_MONTH,
          B1.SL_NO,
          b1.PAYABLE_VOUCHER_SLNO,
          a1.PAYMENT_DATE,
          a1.VOUCHER_NO,
          b1.CHEQUE_DD_NO,
          b1.CHEQUE_DD_DATE,
          b1.AMOUNT,
          a1.SUB_LEDGER_TYPE_CODE,
          A1.Sub_Ledger_Code,
          b1.PAYABLE_VOUCHER_NO,
          b1.PAYABLE_VOUCHER_DATE
        FROM FAS_PAYMENT_MASTER a1
        INNER JOIN FAS_PAYMENT_TRANSACTION b1
        ON A1.Accounting_Unit_Id       =B1.Accounting_Unit_Id
        AND A1.Accounting_For_Office_Id=B1.Accounting_For_Office_Id
        AND A1.Cashbook_Year           =B1.Cashbook_Year
        AND A1.Cashbook_Month          =B1.Cashbook_Month
        AND A1.Voucher_No              =B1.Voucher_No
        AND a1.CREATED_BY_MODULE       ='BPP'
        AND a1.PAYMENT_STATUS          ='L'
        AND a1.ACCOUNTING_UNIT_ID      =$P{unitid}::int
        AND a1.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}::int
        )bb ON aa.Accounting_Unit_Id   =bb.Accounting_Unit_Id
      AND aa.Accounting_For_Office_Id  =bb.Accounting_For_Office_Id
      AND aa.Voucher_No                = bb.PAYABLE_VOUCHER_NO
      AND aa.voucher_date              = bb.PAYABLE_VOUCHER_DATE
      AND aa.SUB_LEDGER_TYPE_CODE      =bb.SUB_LEDGER_TYPE_CODE
      AND AA.SUB_LEDGER_CODE           =BB.SUB_LEDGER_CODE
      AND aa.CHEQUE_DD_NO              =bb.CHEQUE_DD_NO
      AND AA.CHEQUE_DD_DATE            =BB.CHEQUE_DD_DATE
      AND aa.SL_NO                     =bb.PAYABLE_VOUCHER_SLNO
      )
    UNION ALL
      (SELECT aa.Accounting_Unit_Id,
        aa.Accounting_For_Office_Id,
        (SELECT Uu.Accounting_Unit_Name
        FROM fas_mst_acct_units uu
        WHERE Uu.Accounting_Unit_Id=aa.Accounting_Unit_Id
        )AS orgunitname,
        aa.CASHBOOK_YEAR,
        aa.CASHBOOK_MONTH,
        aa.SL_NO,
        aa.voucher_date,
        aa.VOUCHER_NO,
        aa.CHEQUE_DD_NO,
        aa.CHEQUE_DD_DATE,
        aa.AMOUNT,
        aa.SUB_LEDGER_TYPE_CODE,
        (SELECT S.Sub_Ledger_Type_Desc
        FROM com_mst_sl_types s
        WHERE s.SUB_LEDGER_TYPE_CODE=Aa.Sub_Ledger_Type_Code
        )AS sl_desc,
        aa.Sub_Ledger_Code,
        (SELECT l.SL_CODENAME
        FROM SL_TYPE_CODE_NAME_VIEW_M l
        WHERE L.Sl_Type=Aa.Sub_Ledger_Type_Code
        AND L.Sl_Code  =Aa.Sub_Ledger_Code
        )AS code_desc ,
        aa.cb_ref_no,
        aa.cb_ref_date,
        aa.cheque_or_dd ,
        aa.ljvamount,
        bb.VOUCHER_NO pay_no,
        bb.PAYMENT_DATE,
        bb.AMOUNT AS pay_amt,
        aa.multiple_pvrs,
        aa.account_head_code ,
        (SELECT h.account_head_desc
        FROM com_mst_account_heads h
        WHERE h.account_head_code= aa.account_head_code
        ) AS head_desc
      FROM
        (SELECT a.Accounting_Unit_Id,
          a.Accounting_For_Office_Id,
          a.CASHBOOK_YEAR,
          a.CASHBOOK_MONTH,
          b.SL_NO,
          a.voucher_date,
          a.VOUCHER_NO,
          b.CHEQUE_DD_NO,
          b.CHEQUE_DD_DATE,
          b.AMOUNT,
          b.SUB_LEDGER_TYPE_CODE,
          b.Sub_Ledger_Code,
          b.cb_ref_no,
          b.cb_ref_date,
          b.cheque_or_dd ,
          b.AMOUNT AS ljvamount,
          b.multiple_pvrs,
          b.account_head_code
        FROM FAS_JOURNAL_MASTER a
        INNER JOIN FAS_JOURNAL_TRANSACTION b
        ON A.Accounting_Unit_Id       =B.Accounting_Unit_Id
        AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
        AND A.Cashbook_Year           =B.Cashbook_Year
        AND A.Cashbook_Month          =B.Cashbook_Month
        AND A.Voucher_No              =B.Voucher_No
        AND a.ACCOUNTING_UNIT_ID      =$P{unitid}::int
        AND a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}::int
        AND a.CASHBOOK_MONTH          =$P{cashbookmonth}::int
        AND a.CASHBOOK_YEAR           =$P{cashbookyear}::int
        AND A.JOURNAL_STATUS          ='L'
        AND B.CR_DR_INDICATOR='CR'
         AND B.SUB_LEDGER_TYPE_CODE !=0
         and b.Sub_Ledger_Code!=0
          --AND b.cheque_dd_date         IS NOT NULL
          --AND b.cheque_dd_no            > 0
        AND b.multiple_pvrs = 'Y'
        )AA
      LEFT OUTER JOIN
        (SELECT a1.ACCOUNTING_UNIT_ID ,
          a1.ACCOUNTING_FOR_OFFICE_ID,
          a1.CASHBOOK_YEAR,
          a1.CASHBOOK_MONTH,
          B1.SL_NO,
          b1.PAYABLE_VOUCHER_SLNO,
          a1.PAYMENT_DATE,
          a1.VOUCHER_NO,
          b1.CHEQUE_DD_NO,
          b1.CHEQUE_DD_DATE,
          b1.AMOUNT,
          a1.SUB_LEDGER_TYPE_CODE,
          A1.Sub_Ledger_Code,
          b1.PAYABLE_VOUCHER_NO,
          b1.PAYABLE_VOUCHER_DATE
        FROM FAS_PAYMENT_MASTER a1
        INNER JOIN FAS_PAYMENT_TRANSACTION b1
        ON A1.Accounting_Unit_Id       =B1.Accounting_Unit_Id
        AND A1.Accounting_For_Office_Id=B1.Accounting_For_Office_Id
        AND A1.Cashbook_Year           =B1.Cashbook_Year
        AND A1.Cashbook_Month          =B1.Cashbook_Month
        AND A1.Voucher_No              =B1.Voucher_No
        AND a1.CREATED_BY_MODULE       ='BPP'
        AND a1.PAYMENT_STATUS          ='L'
        AND a1.ACCOUNTING_UNIT_ID      =$P{unitid}::int
        AND a1.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}::int
        )bb ON aa.Accounting_Unit_Id   =bb.Accounting_Unit_Id
      AND aa.Accounting_For_Office_Id  =bb.Accounting_For_Office_Id
      AND aa.Voucher_No                = bb.PAYABLE_VOUCHER_NO
      AND aa.voucher_date              = bb.PAYABLE_VOUCHER_DATE
      AND aa.SUB_LEDGER_TYPE_CODE      =bb.SUB_LEDGER_TYPE_CODE
      AND AA.SUB_LEDGER_CODE           =BB.SUB_LEDGER_CODE
      AND aa.SL_NO                     =bb.PAYABLE_VOUCHER_SLNO
      ) ) as opt1
    ORDER BY Sub_Ledger_Code
    ) as opt2
  ) B ON a.Sub_Ledger_Code=B.Sub_Ledger_Code
ORDER BY A.VOUCHER_NO,
	A.SL_No,
  A.VOUCHER_DATE,
  A.Sub_Ledger_Code,
  A.SUB_LEDGER_TYPE_CODE
  --ORDER BY a.Accounting_Unit_Id,  A.Ljvamount,  A.Voucher_No,  A.Cb_Ref_Date, a. pay_no]]></queryString>

	<field name="accounting_unit_id" class="java.math.BigDecimal"/>
	<field name="accounting_for_office_id" class="java.math.BigDecimal"/>
	<field name="ORGUNITNAME" class="java.lang.String"/>
	<field name="cashbook_year" class="java.math.BigDecimal"/>
	<field name="cashbook_month" class="java.math.BigDecimal"/>
	<field name="sl_no" class="java.math.BigDecimal"/>
	<field name="voucher_date" class="java.sql.Date"/>
	<field name="voucher_no" class="java.math.BigDecimal"/>
	<field name="cheque_dd_no" class="java.lang.String"/>
	<field name="cheque_dd_date" class="java.sql.Date"/>
	<field name="amount" class="java.math.BigDecimal"/>
	<field name="sub_ledger_type_code" class="java.math.BigDecimal"/>
	<field name="sl_desc" class="java.lang.String"/>
	<field name="sub_ledger_code" class="java.math.BigDecimal"/>
	<field name="code_desc" class="java.lang.String"/>
	<field name="cb_ref_no" class="java.math.BigDecimal"/>
	<field name="cb_ref_date" class="java.sql.Date"/>
	<field name="cheque_or_dd" class="java.lang.String"/>
	<field name="ljvamount" class="java.math.BigDecimal"/>
	<field name="pay_no" class="java.math.BigDecimal"/>
	<field name="payment_date" class="java.sql.Date"/>
