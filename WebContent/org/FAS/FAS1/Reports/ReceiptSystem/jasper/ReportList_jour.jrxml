<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ReportList_jour"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="to_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="cmb_unit_name" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT VOUCHER_NO as "VOUCHER_NO",
  VOUCHER_DATE as "VOUCHER_DATE",
  SUM(cr_amt)               AS "CR_AMT",
  SUM(dr_amt)               AS "DR_AMT",
  SUM(cr_amt) - SUM(dr_amt) AS "DIFF"
FROM
  (SELECT m.VOUCHER_NO, 
    m.VOUCHER_DATE,
    t.CR_DR_INDICATOR,
    t.AMOUNT,
    CASE
      WHEN t.CR_DR_INDICATOR='CR' 
      THEN t.AMOUNT
    END cr_amt,
    CASE 
      WHEN t.CR_DR_INDICATOR='DR' 
      THEN t.AMOUNT   
    END dr_amt  
  FROM fas_journal_master m,  
    fas_journal_transaction t        
  WHERE m.accounting_unit_id::varchar =t.accounting_unit_id::varchar             
  AND m.accounting_for_office_id::varchar = t.accounting_for_office_id::varchar     
  AND m.cashbook_year            =t.cashbook_year       
  AND m.cashbook_month           =t.cashbook_month   
  AND m.voucher_no             =t.voucher_no    
  AND m.accounting_unit_id::varchar       =$P{accountingunitid}::varchar           
 -- AND m.accounting_for_office_id=6869    
  AND m.cashbook_month           =$P{to_cashbookmonth}::int  
  AND m.cashbook_year           =$P{to_cashbookyear}::int  
  and m.journal_status          ='L' 
  ) as fasre1 
GROUP BY voucher_no, 
  voucher_date 
ORDER BY voucher_no, 
  voucher_date ]]></queryString>

	<field name="VOUCHER_NO" class="java.math.BigDecimal"/>
	<field name="VOUCHER_DATE" class="java.sql.Date"/>
	<field name="CR_AMT" class="java.math.BigDecimal"/>
	<field name="DR_AMT" class="java.math.BigDecimal"/>
	<field name="DIFF" class="java.math.BigDecimal"/>

	<variable name="tot_dr" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>
	<variable name="tot_cr" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMT}]]></variableExpression>
	</variable>
