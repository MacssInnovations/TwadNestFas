<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="RegisterChequeReport_HO_Detail"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="898"
		 pageHeight="595"
		 columnWidth="838"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookyear_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cashbookyear_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="head" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue1" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select
*
from 
(
select
     a.voucher_no ,
     a.payment_date as trf_date,
     a.bank_id as b_id,
     a.branch_id  br_id,
      'P' as "DOC_TYPE",
      a.SUB_LEDGER_TYPE_CODE as sl_type,
a.SUB_LEDGER_CODE as sl_code,
a.CR_DR_INDICATOR as "CRDR",
b.CHEQUE_OR_DD as "CHEQUE",

     a.paid_to as amt_paid_to,
     
     b.CHEQUE_DD_NO as "CHEQUE_DD_NO",
     b.CHEQUE_DD_DATE as "CHEQUE_DD_DATE",
     b.amount as "AMOUNT",
     b.particulars as "PARTICULARS",
     c.accounting_unit_name as "ACCOUNTING_UNIT_NAME",
     d.office_short_name as "OFFICE_SHORT_NAME",
     e.branch_name,
     f.BANK_NAME as "BANK_NAME", 
     e.micr_code ,
      ' ' as "FROMREC",
    (select SUB_LEDGER_TYPE_DESC from COM_MST_SL_TYPES where SUB_LEDGER_TYPE_CODE=a.SUB_LEDGER_TYPE_CODE)as "ST_DESC",
     (select SL_CODENAME from SL_TYPE_CODE_NAME_VIEW where SL_TYPE=a.SUB_LEDGER_TYPE_CODE and SL_CODE=a.SUB_LEDGER_CODE)as "SL_DESC",
    
     a.REMARKS

from 
     fas_payment_master a,
     fas_payment_transaction b,
     fas_mst_acct_units c,
     com_mst_offices d,
     fas_mst_bank_branches e,
     fas_mst_banks f

 where 
    a.cashbook_month=b.cashbook_month 
and a.cashbook_year=b.cashbook_year
and a.accounting_unit_id=b.accounting_unit_id 
and a.accounting_for_office_id=b.accounting_for_office_id
and a.voucher_no=b.voucher_no
and c.accounting_unit_id=a.accounting_unit_id
and d.office_id=a.accounting_for_office_id 
and e.bank_id=a.bank_id 
and e.branch_id=a.branch_id 
and f.bank_id=e.bank_id 
and a.payment_status<>'C' 
and a.payment_type='B' and
To_Date((a.cashbook_month
  ||'-'
  || a.cashbook_year),'mm-yyyy') BETWEEN To_Date($P{cashbookmonth_from}::int
  ||'-'
  ||$P{cashbookyear_from}::int,'mm-yyyy')
AND to_date($P{cashbookmonth_to}::int
  ||'-'
  ||$P{cashbookyear_to},'mm-yyyy') 
 
  and a.accounting_unit_id=$P{accountingunitid}::int
  and a.accounting_for_office_id=$P{accountofficeid}::int
  
union all
select
     a.receipt_no as voucher_no,
     a.receipt_date as trf_date,
     a.bank_id as b_id,
     a.branch_id as br_id,
      'R' as doc_tyupe,
        a.SUB_LEDGER_TYPE_CODE as sl_type,
a.SUB_LEDGER_CODE as sl_code,
a.CR_DR_INDICATOR as crDr,
b.CHEQUE_OR_DD as cheque,
     ' ' as amt_paid_to,
     b.CHEQUE_DD_NO,
     b.CHEQUE_DD_DATE,
     b.amount,
     b.particulars,
     c.accounting_unit_name,
     d.office_short_name,
     e.branch_name,
     f.BANK_NAME, 
     e.micr_code,
     a.RECEIVED_FROM as fromREc,
     (select SUB_LEDGER_TYPE_DESC from COM_MST_SL_TYPES where SUB_LEDGER_TYPE_CODE=a.SUB_LEDGER_TYPE_CODE)as st_desc,
     (select SL_CODENAME from SL_TYPE_CODE_NAME_VIEW where SL_TYPE=a.SUB_LEDGER_TYPE_CODE and SL_CODE=a.SUB_LEDGER_CODE)as SL_desc,
    
     a.REMARKS

from 
     fas_receipt_master a,
     fas_receipt_transaction b,
     fas_mst_acct_units c,
     com_mst_offices d,
     fas_mst_bank_branches e,
     fas_mst_banks f
 where 
    a.cashbook_month=b.cashbook_month 
and a.cashbook_year=b.cashbook_year
and a.accounting_unit_id=b.accounting_unit_id 
and a.accounting_for_office_id=b.accounting_for_office_id
and a.receipt_no=b.receipt_no
and c.accounting_unit_id=a.accounting_unit_id
and d.office_id=a.accounting_for_office_id 
and e.bank_id=a.bank_id 
and e.branch_id=a.branch_id 
and f.bank_id=e.bank_id 
and a.receipt_status<>'C' 
and a.created_by_module='SC' and
To_Date((a.cashbook_month
  ||'-'
  || a.cashbook_year),'mm-yyyy') BETWEEN To_Date($P{cashbookmonth_from}::int
  ||'-'
  ||$P{cashbookyear_from}::int,'mm-yyyy')
AND to_date($P{cashbookmonth_to}::int
  ||'-'
  ||$P{cashbookyear_to},'mm-yyyy') 
 
  and a.accounting_unit_id=$P{accountingunitid}::int
  and a.accounting_for_office_id=$P{accountofficeid}::int

union all
select
     a.voucher_no,
     a.date_of_transfer as trf_date,
     a.from_bank_id as b_id,
     a.from_branch_id as br_id,
     'BT' as doc_tyupe,
      0 as sl_type,
0 as sl_code,
'-' as crDr,
a.CHEQUE_OR_DD as cheque,
     ' ' as amt_paid_to,
     a.CHEQUE_DD_NO,
     a.CHEQUE_DD_DATE,
     a.total_amount as amount,
     a.particulars,
     c.accounting_unit_name,
     d.office_short_name,
     e.branch_name,
     f.BANK_NAME, 
     e.micr_code,
      ' ' as fromREc,
       ' ' as st_desc,
       ' ' as SL_desc,
    
     ' ' as REMARKS

from 
     fas_inter_bank_trf_at_ho a,
     fas_mst_acct_units c,
     com_mst_offices d,
     fas_mst_bank_branches e,
     fas_mst_banks f

 where 
    c.accounting_unit_id=a.accounting_unit_id
and d.office_id=a.accounting_for_office_id 
and e.bank_id=a.from_bank_id 
and e.branch_id=a.from_branch_id 
and f.bank_id=e.bank_id 
and a.transfer_status<>'C' 
and
To_Date((a.cashbook_month
  ||'-'
  || a.cashbook_year),'mm-yyyy') BETWEEN To_Date($P{cashbookmonth_from}::int
  ||'-'
  ||$P{cashbookyear_from},'mm-yyyy')
AND to_date($P{cashbookmonth_to}
  ||'-'
  ||$P{cashbookyear_to},'mm-yyyy') 
 
  and a.accounting_unit_id=$P{accountingunitid}::int
  and a.accounting_for_office_id=$P{accountofficeid}::int

union all 
Select 
     a.VOUCHER_NO ,
     a.DATE_OF_TRANSFER  as trf_date,
     a.HO_BANK_ID   as b_id ,
     a.HO_BRANCH_ID as br_id ,
     'FT' as doc_tyupe,
      0 as sl_type,
0 as sl_code,
a.CR_DR_INDICATOR as crDr,
b.CHEQUE_OR_DD as cheque,
     d1.office_short_name as amt_paid_to ,
          
     b.CHEQUE_DD_NO,
     b.CHEQUE_DD_DATE ,
     b.AMOUNT  ,
     b.PARTICULARS ,
     c.accounting_unit_name,
     d.office_short_name,
     e.branch_name,
     f.BANK_NAME, 
     e.micr_code,
     ' ' as fromREc,
       ' ' as st_desc,
        ' ' as SL_desc,
     a.REMARKS

from 
     FAS_FUND_TRF_FROM_HO_MASTER  a,
     FAS_FUND_TRF_FROM_HO_TRN   b ,
     fas_mst_acct_units  c,
     com_mst_offices  d,
     com_mst_offices  d1,
     fas_mst_bank_branches  e,
     fas_mst_banks  f

where
 
           a.cashbook_month     =  b.cashbook_month 
       and a.cashbook_year      =  b.cashbook_year
       and a.accounting_unit_id =  b.accounting_unit_id 
       and a.accounting_for_office_id = b.accounting_for_office_id
       and a.voucher_no         =  b.voucher_no
       
       and c.accounting_unit_id =  a.accounting_unit_id
       and d.office_id          =  a.accounting_for_office_id 
       and d1.office_id         =  b.TRANSFER_TO_OFFICE_ID 
       
       and e.bank_id            =  a.HO_BANK_ID	
       and e.branch_id          =  a.HO_BRANCH_ID	
       and f.bank_id            =  e.bank_id 
       
       and a.TRANSFER_STATUS <>'C' 
     and
To_Date((a.cashbook_month
  ||'-'
  || a.cashbook_year),'mm-yyyy') BETWEEN To_Date($P{cashbookmonth_from}::int
  ||'-'
  ||$P{cashbookyear_from},'mm-yyyy')
AND to_date($P{cashbookmonth_to}::int
  ||'-'
  ||$P{cashbookyear_to},'mm-yyyy') 
 
  and a.accounting_unit_id=$P{accountingunitid}::int
  and a.accounting_for_office_id=$P{accountofficeid}::int
 
      
) as opt1 order by b_id,voucher_no,trf_date]]></queryString>

	<field name="voucher_no" class="java.math.BigDecimal"/>
	<field name="trf_date" class="java.sql.Date"/>
	<field name="b_id" class="java.math.BigDecimal"/>
	<field name="br_id" class="java.math.BigDecimal"/>
	<field name="DOC_TYPE" class="java.lang.String"/>
	<field name="sl_type" class="java.math.BigDecimal"/>
	<field name="sl_code" class="java.math.BigDecimal"/>
	<field name="CRDR" class="java.lang.String"/>
	<field name="CHEQUE" class="java.lang.String"/>
	<field name="amt_paid_to" class="java.lang.String"/>
	<field name="CHEQUE_DD_NO" class="java.lang.String"/>
	<field name="CHEQUE_DD_DATE" class="java.sql.Date"/>
	<field name="AMOUNT" class="java.lang.Double"/>
