	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="OFFICE_SHORT_NAME" class="java.lang.String"/>
	<field name="branch_name" class="java.lang.String"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="micr_code" class="java.math.BigDecimal"/>
	<field name="FROMREC" class="java.lang.String"/>
	<field name="ST_DESC" class="java.lang.String"/>
	<field name="SL_DESC" class="java.lang.String"/>
	<field name="remarks" class="java.lang.String"/>

	<variable name="SUM_AMOUNT_1" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="SUM_AMOUNT_2" class="java.lang.Double" resetType="Group" resetGroup="VOUCHER" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="SUM_AMOUNT_3" class="java.lang.Double" resetType="Group" resetGroup="BANK" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="sum_aMT" class="java.lang.Double" resetType="Group" resetGroup="BANK" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>

