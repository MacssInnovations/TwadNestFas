recTrans.SUB_LEDGER_CODE,

 (SELECT S.Sub_Ledger_Type_Desc
  FROM com_mst_sl_types s
  WHERE s.SUB_LEDGER_TYPE_CODE=recTrans.Sub_Ledger_Type_Code
  )AS sl_desc,
 
  (SELECT l.SL_CODENAME
  FROM SL_TYPE_CODE_NAME_VIEW l
  WHERE L.Sl_Type=recTrans.Sub_Ledger_Type_Code
  AND L.Sl_Code  =recTrans.Sub_Ledger_Code
  )AS code_desc
        from FAS_RECEIPT_MASTER recMas,COM_MST_OFFICES Office,
        FAS_MST_ACCT_UNITS accUint,FAS_RECEIPT_TRANSACTION recTrans ,
        COM_MST_ACCOUNT_HEADS acchead
        where 
        recMas.ACCOUNTING_UNIT_ID=recTrans.ACCOUNTING_UNIT_ID and 
        recMas.ACCOUNTING_FOR_OFFICE_ID=recTrans.ACCOUNTING_FOR_OFFICE_ID and 
        recMas.CASHBOOK_YEAR=recTrans.CASHBOOK_YEAR and
        recMas.CASHBOOK_MONTH=recTrans.CASHBOOK_MONTH and 
        recMas.RECEIPT_NO=recTrans.RECEIPT_NO and
        recMas.ACCOUNTING_UNIT_ID=accUint.ACCOUNTING_UNIT_ID and
        recMas.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID and
        recTrans.ACCOUNT_HEAD_CODE=acchead.ACCOUNT_HEAD_CODE and recMas.receipt_status!='C' and 
	recMas.ACCOUNTING_UNIT_ID=$P{acc_unit_id}  and recMas.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}
	and (recMas.receipt_date between $P{fromdate} and $P{todate} )
	$P!{recType}]]></queryString>

