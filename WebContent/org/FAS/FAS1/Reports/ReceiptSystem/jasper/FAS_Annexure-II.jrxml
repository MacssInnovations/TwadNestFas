	<parameter name="from_cashbk_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbk_yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="row1" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["200604,201120,201122,201124,201125,201126,201129,201138,201139,201151,222601,222602,222604,222605,222606,222607,222608,222609"]]></defaultValueExpression>
	</parameter>
	<parameter name="row2" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["200601,200720,200721,200722,200723,200724,200725,200726,200728,200729,200738,200740,200742,200750,200751,200752,222201,222202,222203,222204,222205,222206,222207,222208,222209"]]></defaultValueExpression>
	</parameter>
	<parameter name="row3" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["200602,200820,200821,200822,200823,200824,200825,200826,200828,200829,200838,200839,200840,200850,200851,222301,222302,222303,222304,222305,222306,222307,222309"]]></defaultValueExpression>
	</parameter>
	<parameter name="row4" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["200605,201020,201022,201023,201024,201025,201026,201028,201029,201032,201038,201039,201040,201042,201050,201051,222501,222502,222503,222504,222505,222506,222507,222509"]]></defaultValueExpression>
	</parameter>
	<parameter name="to_cashbk_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbk_yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mnth" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select row_id,unit_id,(select accounting_unit_name from fas_mst_acct_units where accounting_unit_id=unit_id) as accounting_unit_name, 
achead1,achead2,achead3,achead4,achead5,achead6,achead7,achead8,achead9,achead10,achead11,
amt1,amt2,amt3,amt4,amt5,amt6,amt7,amt8,amt9,(amt1+amt2+amt3+amt4+amt5+amt6+amt7+amt8+amt9) as total1,
amt10,amt11,(amt1+amt2+amt3+amt4+amt5+amt6+amt7+amt8+amt9+amt10+amt11)as total12
from
(
        select a.row_id,unit_id,
        power_consumption as achead1,workers_cost as achead2,materials as achead3,chemicals as achead4,rr_motors_pumpsets as achead5,
        pipe_line_burst as achead6,royalty as achead7,original_works as achead8,others as achead9,administrative_expenditure as achead10,cost_personnel_from||' to '||cost_personnel_to as achead11,
        sum(amt_achead1) as amt1,sum(amt_achead2) as amt2,sum(amt_achead3) as amt3,sum(amt_achead4) as amt4,sum(amt_achead5) as amt5,sum(amt_achead6) as amt6,sum(amt_achead7) as amt7,sum(amt_achead8) as amt8,sum(amt_achead9) as amt9,
        sum(amt_achead10) as amt10,sum(amt_achead11) as amt11 from
        (
        select 
            1 as row_id,
            accounting_unit_id as unit_id ,
            accounting_for_office_id,
            case when ( account_head_code = (select power_consumption from fas_mst_annexure_ii where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead1,
            case when ( account_head_code = (select workers_cost from fas_mst_annexure_ii where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead2,
            case when ( account_head_code = (select materials from fas_mst_annexure_ii where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead3, 
            case when ( account_head_code = (select chemicals from fas_mst_annexure_ii where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead4, 
            case when ( account_head_code = (select rr_motors_pumpsets from fas_mst_annexure_ii where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead5, 
            case when ( account_head_code = (select pipe_line_burst from fas_mst_annexure_ii where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead6, 
            case when ( account_head_code = (select royalty from fas_mst_annexure_ii where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead7, 
            case when ( account_head_code = (select original_works from fas_mst_annexure_ii where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead8,
            case when ( account_head_code = (select others from fas_mst_annexure_ii where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead9,
            case when ( account_head_code = (select administrative_expenditure from fas_mst_annexure_ii where row_id=1)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead10,
            case when (account_head_code between (select cost_personnel_from from fas_mst_annexure_ii where row_id=1) and (select cost_personnel_to from fas_mst_annexure_ii where row_id=1)) then
              sum(amount)  
            else 
              0 
            end as amt_achead11
        from
        (
                  select accounting_unit_id,
                         accounting_for_office_id,account_head_code,CR_DR_INDICATOR,
                         sum(decode(CR_DR_INDICATOR,'CR',amount,0))as cr_amount,
                         sum(decode(CR_DR_INDICATOR,'DR',amount,0))as dr_amount,
                        (sum(decode(CR_DR_INDICATOR,'DR',amount,0))-sum(decode(CR_DR_INDICATOR,'CR',amount,0)))as amount
                  from
                  (
                      select 
                           m.accounting_unit_id ,                         
                           m.accounting_for_office_id , 
                           m.cashbook_month, 
                           m.cashbook_year,     
                           t.account_head_code,
                           t.CR_DR_INDICATOR, 
                           t.amount
                        from 
                           fas_journal_master m ,
                           fas_journal_transaction t
                        where 
                           m.accounting_unit_id = t.accounting_unit_id and 
                           m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                           m.cashbook_month = t.cashbook_month and 
                           m.cashbook_year = t.cashbook_year and 
                           m.voucher_no = t.voucher_no and 
                           m.journal_status='L' and 
                           to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                           t.account_head_code in(200604,201120,201122,201124,201125,201126,201129,201138,201139,201151,222601,222602,222604,222605,222606,222607,222608,222609)
                          union all 
                          select 
                            m.accounting_unit_id , 
                            m.accounting_for_office_id , 
                            m.cashbook_month, 
                            m.cashbook_year,     
                            t.account_head_code,
                            t.CR_DR_INDICATOR, 
                            t.amount
                          from 
                            fas_payment_master m ,
                            fas_payment_transaction t
                          where 
                            m.accounting_unit_id = t.accounting_unit_id and 
                            m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                            m.cashbook_month = t.cashbook_month and 
                            m.cashbook_year = t.cashbook_year and 
                            m.voucher_no = t.voucher_no and 
                            m.payment_status='L' and 
                            to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                            t.account_head_code in(200604,201120,201122,201124,201125,201126,201129,201138,201139,201151,222601,222602,222604,222605,222606,222607,222608,222609)
                          union all 
                          select 
                            m.accounting_unit_id , 
                            m.accounting_for_office_id , 
                            m.cashbook_month, 
                            m.cashbook_year,     
                            t.account_head_code,
                            t.CR_DR_INDICATOR, 
                            t.amount
                          from 
                            fas_receipt_master m ,
                            fas_receipt_transaction t
                          where 
                            m.accounting_unit_id = t.accounting_unit_id and 
                            m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                            m.cashbook_month = t.cashbook_month and 
                            m.cashbook_year = t.cashbook_year and 
                            m.receipt_no = t.receipt_no and 
                            m.receipt_status='L' and 
                            to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                            t.account_head_code in(200604,201120,201122,201124,201125,201126,201129,201138,201139,201151,222601,222602,222604,222605,222606,222607,222608,222609)
                  )
                  group by accounting_unit_id , 
                           accounting_for_office_id , 
                           account_head_code,
                           CR_DR_INDICATOR
        )
        group by accounting_unit_id,
                 accounting_for_office_id , 
                 account_head_code order by accounting_unit_id
        )a,
        fas_mst_annexure_ii b 
        where a.row_id=b.row_id
        group by a.row_id,
                 unit_id,
                 power_consumption,workers_cost,materials,chemicals,rr_motors_pumpsets,pipe_line_burst,royalty,original_works,others,administrative_expenditure,cost_personnel_from,cost_personnel_to
        union all
        select a.row_id,unit_id,
        power_consumption as achead1,workers_cost as achead2,materials as achead3,chemicals as achead4,rr_motors_pumpsets as achead5,
        pipe_line_burst as achead6,royalty as achead7,original_works as achead8,others as achead9,administrative_expenditure as achead10,cost_personnel_from||' to '||cost_personnel_to as achead11,
        sum(amt_achead1) as amt1,sum(amt_achead2) as amt2,sum(amt_achead3) as amt3,sum(amt_achead4) as amt4,sum(amt_achead5) as amt5,sum(amt_achead6) as amt6,sum(amt_achead7) as amt7,sum(amt_achead8) as amt8,sum(amt_achead9) as amt9,
        sum(amt_achead10) as amt10,sum(amt_achead11) as amt11 from
        (
        select 
            2 as row_id,
            accounting_unit_id as unit_id ,
            accounting_for_office_id,
            case when ( account_head_code = (select power_consumption from fas_mst_annexure_ii where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead1,
            case when ( account_head_code = (select workers_cost from fas_mst_annexure_ii where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead2,
            case when ( account_head_code = (select materials from fas_mst_annexure_ii where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead3, 
            case when ( account_head_code = (select chemicals from fas_mst_annexure_ii where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead4, 
            case when ( account_head_code = (select rr_motors_pumpsets from fas_mst_annexure_ii where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead5, 
            case when ( account_head_code = (select pipe_line_burst from fas_mst_annexure_ii where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead6, 
            case when ( account_head_code = (select royalty from fas_mst_annexure_ii where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead7, 
            case when ( account_head_code = (select original_works from fas_mst_annexure_ii where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead8,
            case when ( account_head_code = (select others from fas_mst_annexure_ii where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead9,
            case when ( account_head_code = (select administrative_expenditure from fas_mst_annexure_ii where row_id=2)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead10,
            case when (account_head_code between (select cost_personnel_from from fas_mst_annexure_ii where row_id=2) and (select cost_personnel_to from fas_mst_annexure_ii where row_id=2)) then
              sum(amount)  
            else 
              0 
            end as amt_achead11
        from
        (
              select accounting_unit_id,accounting_for_office_id,account_head_code,CR_DR_INDICATOR,
                     sum(decode(CR_DR_INDICATOR,'CR',amount,0))as cr_amount,
                     sum(decode(CR_DR_INDICATOR,'DR',amount,0))as dr_amount,
                    (sum(decode(CR_DR_INDICATOR,'DR',amount,0))-sum(decode(CR_DR_INDICATOR,'CR',amount,0)))as amount    
              from
              (
                    select 
                       m.accounting_unit_id , 
                       m.accounting_for_office_id , 
                       m.cashbook_month, 
                       m.cashbook_year,     
                       t.account_head_code,
                       t.CR_DR_INDICATOR, 
                       t.amount
                    from 
                       fas_journal_master m ,
                       fas_journal_transaction t
                    where 
                       m.accounting_unit_id = t.accounting_unit_id and 
                       m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                       m.cashbook_month = t.cashbook_month and 
                       m.cashbook_year = t.cashbook_year and 
                       m.voucher_no = t.voucher_no and 
                       m.journal_status='L' and 
                       to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                       t.account_head_code in(200601,200720,200721,200722,200723,200724,200725,200726,200728,200729,200738,200740,200742,200750,200751,200752,222201,222202,222203,222204,222205,222206,222207,222208,222209)
                    union all 
                     SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_payment_master m ,
          fas_payment_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.voucher_no               = t.voucher_no
        AND m.payment_status           ='L'
    AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2013 , 'mm-yyyy') AND  t.account_head_code in(200601,200720,200721,200722,200723,200724,200725,200726,200728,200729,200738,200740,200742,200750,200751,200752,222201,222202,222203,222204,222205,222206,222207,222208,222209)
                    union all
                    select 
                        m.accounting_unit_id , 
                        m.accounting_for_office_id , 
                        m.cashbook_month, 
                        m.cashbook_year,     
                        t.account_head_code,
                        t.CR_DR_INDICATOR, 
                        t.amount
                    from 
                        fas_receipt_master m ,
                        fas_receipt_transaction t
                    where 
                        m.accounting_unit_id = t.accounting_unit_id and 
                        m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                        m.cashbook_month = t.cashbook_month and 
                        m.cashbook_year = t.cashbook_year and 
                        m.receipt_no = t.receipt_no and 
                        m.receipt_status='L' and 
                       to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                        t.account_head_code in(200601,200720,200721,200722,200723,200724,200725,200726,200728,200729,200738,200740,200742,200750,200751,200752,222201,222202,222203,222204,222205,222206,222207,222208,222209)
              )
               group by accounting_unit_id , 
                        accounting_for_office_id , 
                        account_head_code,
                        CR_DR_INDICATOR
        )
        group by accounting_unit_id,
                 accounting_for_office_id , 
                 account_head_code order by accounting_unit_id
        )a,
        fas_mst_annexure_ii b 
        where a.row_id=b.row_id
        group by a.row_id,
                 unit_id,
                 power_consumption,workers_cost,materials,chemicals,rr_motors_pumpsets,pipe_line_burst,royalty,original_works,others,administrative_expenditure,cost_personnel_from,cost_personnel_to
                 
        union all
        
        select a.row_id,unit_id,
          power_consumption as achead1,workers_cost as achead2,materials as achead3,chemicals as achead4,rr_motors_pumpsets as achead5,
          pipe_line_burst as achead6,royalty as achead7,original_works as achead8,others as achead9,administrative_expenditure as achead10,cost_personnel_from||' to '||cost_personnel_to as achead11,
          sum(amt_achead1) as amt1,sum(amt_achead2) as amt2,sum(amt_achead3) as amt3,sum(amt_achead4) as amt4,sum(amt_achead5) as amt5,sum(amt_achead6) as amt6,sum(amt_achead7) as amt7,sum(amt_achead8) as amt8,sum(amt_achead9) as amt9,
          sum(amt_achead10) as amt10,sum(amt_achead11) as amt11 from
        (
          select 
            3 as row_id,
            accounting_unit_id as unit_id ,
            accounting_for_office_id,
            case when ( account_head_code = (select power_consumption from fas_mst_annexure_ii where row_id=3)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead1,
            case when ( account_head_code = (select workers_cost from fas_mst_annexure_ii where row_id=3)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead2,
            case when ( account_head_code = (select materials from fas_mst_annexure_ii where row_id=3)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead3, 
            case when ( account_head_code = (select chemicals from fas_mst_annexure_ii where row_id=3)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead4, 
            case when ( account_head_code = (select rr_motors_pumpsets from fas_mst_annexure_ii where row_id=3)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead5, 
            case when ( account_head_code = (select pipe_line_burst from fas_mst_annexure_ii where row_id=3)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead6, 
            case when ( account_head_code = (select royalty from fas_mst_annexure_ii where row_id=3)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead7, 
            case when ( account_head_code = (select original_works from fas_mst_annexure_ii where row_id=3)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead8,
            case when ( account_head_code = (select others from fas_mst_annexure_ii where row_id=3)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead9,
            case when ( account_head_code = (select administrative_expenditure from fas_mst_annexure_ii where row_id=3)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead10,
            case when (account_head_code between (select cost_personnel_from from fas_mst_annexure_ii where row_id=3) and (select cost_personnel_to from fas_mst_annexure_ii where row_id=3)) then
              sum(amount)  
            else 
              0 
            end as amt_achead11
        from
        (
              select accounting_unit_id,accounting_for_office_id,account_head_code,CR_DR_INDICATOR,
                     sum(decode(CR_DR_INDICATOR,'CR',amount,0))as cr_amount,
                     sum(decode(CR_DR_INDICATOR,'DR',amount,0))as dr_amount,
                    (sum(decode(CR_DR_INDICATOR,'DR',amount,0))-sum(decode(CR_DR_INDICATOR,'CR',amount,0)))as amount  
              from
              (
                  select 
                       m.accounting_unit_id , 
                       m.accounting_for_office_id , 
                       m.cashbook_month, 
                       m.cashbook_year,     
                       t.account_head_code,
                       t.CR_DR_INDICATOR, 
                       t.amount
                  from 
                       fas_journal_master m ,
                       fas_journal_transaction t
                  where 
                       m.accounting_unit_id = t.accounting_unit_id and 
                       m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                       m.cashbook_month = t.cashbook_month and 
                       m.cashbook_year = t.cashbook_year and 
                       m.voucher_no = t.voucher_no and 
                       m.journal_status='L' and 
                       to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                       t.account_head_code in(200602,200820,200821,200822,200823,200824,200825,200826,200828,200829,200838,200839,200840,200850,200851,222301,222302,222303,222304,222305,222306,222307,222309)
                  union all 
                       
                  select 
                        m.accounting_unit_id , 
                        m.accounting_for_office_id , 
                        m.cashbook_month, 
                        m.cashbook_year,     
                        t.account_head_code,
                        t.CR_DR_INDICATOR, 
                        t.amount
                  from 
                        fas_payment_master m ,
                        fas_payment_transaction t
                  where 
                        m.accounting_unit_id = t.accounting_unit_id and 
                        m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                        m.cashbook_month = t.cashbook_month and 
                        m.cashbook_year = t.cashbook_year and 
                        m.voucher_no = t.voucher_no and 
                        m.payment_status='L' and 
                        to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                        t.account_head_code in(200602,200820,200821,200822,200823,200824,200825,200826,200828,200829,200838,200839,200840,200850,200851,222301,222302,222303,222304,222305,222306,222307,222309)
                  union all
                  select 
                        m.accounting_unit_id , 
                        m.accounting_for_office_id , 
                        m.cashbook_month, 
                        m.cashbook_year,     
                        t.account_head_code,
                        t.CR_DR_INDICATOR, 
                        t.amount
                  from 
                        fas_receipt_master m ,
                        fas_receipt_transaction t
                  where 
                        m.accounting_unit_id = t.accounting_unit_id and 
                        m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                        m.cashbook_month = t.cashbook_month and 
                        m.cashbook_year = t.cashbook_year and 
                        m.receipt_no = t.receipt_no and 
                        m.receipt_status='L' and 
                        to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                        t.account_head_code in(200602,200820,200821,200822,200823,200824,200825,200826,200828,200829,200838,200839,200840,200850,200851,222301,222302,222303,222304,222305,222306,222307,222309)
            )
             group by accounting_unit_id , 
                      accounting_for_office_id , 
                      account_head_code,
                      CR_DR_INDICATOR
        )
        group by accounting_unit_id,
                 accounting_for_office_id , 
                 account_head_code order by accounting_unit_id
        )a,
        fas_mst_annexure_ii b 
        where a.row_id=b.row_id
        group by a.row_id,
                 unit_id,
                 power_consumption,workers_cost,materials,chemicals,rr_motors_pumpsets,pipe_line_burst,royalty,original_works,others,administrative_expenditure,cost_personnel_from,cost_personnel_to
                 
        union all
        
        select a.row_id,unit_id,
          power_consumption as achead1,workers_cost as achead2,materials as achead3,chemicals as achead4,rr_motors_pumpsets as achead5,
          pipe_line_burst as achead6,royalty as achead7,original_works as achead8,others as achead9,administrative_expenditure as achead10,cost_personnel_from||' to '||cost_personnel_to as achead11,
          sum(amt_achead1) as amt1,sum(amt_achead2) as amt2,sum(amt_achead3) as amt3,sum(amt_achead4) as amt4,sum(amt_achead5) as amt5,sum(amt_achead6) as amt6,sum(amt_achead7) as amt7,sum(amt_achead8) as amt8,sum(amt_achead9) as amt9,
          sum(amt_achead10) as amt10,sum(amt_achead11) as amt11 from
        (
          select 
            4 as row_id,
            accounting_unit_id as unit_id ,
            accounting_for_office_id,
            case when ( account_head_code = (select power_consumption from fas_mst_annexure_ii where row_id=4)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead1,
            case when ( account_head_code = (select workers_cost from fas_mst_annexure_ii where row_id=4)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead2,
            case when ( account_head_code = (select materials from fas_mst_annexure_ii where row_id=4)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead3, 
            case when ( account_head_code = (select chemicals from fas_mst_annexure_ii where row_id=4)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead4, 
            case when ( account_head_code = (select rr_motors_pumpsets from fas_mst_annexure_ii where row_id=4)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead5, 
            case when ( account_head_code = (select pipe_line_burst from fas_mst_annexure_ii where row_id=4)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead6, 
            case when ( account_head_code = (select royalty from fas_mst_annexure_ii where row_id=4)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead7, 
            case when ( account_head_code = (select original_works from fas_mst_annexure_ii where row_id=4)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead8,
            case when ( account_head_code = (select others from fas_mst_annexure_ii where row_id=4)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead9,
            case when ( account_head_code = (select administrative_expenditure from fas_mst_annexure_ii where row_id=4)) then 
              sum(amount)  
            else 
              0 
            end as amt_achead10,
            case when (account_head_code between (select cost_personnel_from from fas_mst_annexure_ii where row_id=4) and (select cost_personnel_to from fas_mst_annexure_ii where row_id=4)) then
              sum(amount)  
            else 
              0 
            end as amt_achead11
        from
        (
             select accounting_unit_id,accounting_for_office_id,account_head_code,CR_DR_INDICATOR,
                     sum(decode(CR_DR_INDICATOR,'CR',amount,0))as cr_amount,
                     sum(decode(CR_DR_INDICATOR,'DR',amount,0))as dr_amount,
                    (sum(decode(CR_DR_INDICATOR,'DR',amount,0))-sum(decode(CR_DR_INDICATOR,'CR',amount,0)))as amount  
             from
             (
                select 
                       m.accounting_unit_id , 
                       m.accounting_for_office_id , 
                       m.cashbook_month, 
                       m.cashbook_year,     
                       t.account_head_code,
                       t.CR_DR_INDICATOR, 
                       t.amount
                    from 
                       fas_journal_master m ,
                       fas_journal_transaction t
                    where 
                       m.accounting_unit_id = t.accounting_unit_id and 
                       m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                       m.cashbook_month = t.cashbook_month and 
                       m.cashbook_year = t.cashbook_year and 
                       m.voucher_no = t.voucher_no and 
                       m.journal_status='L' and 
                       to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                       t.account_head_code in(200605,201020,201022,201023,201024,201025,201026,201028,201029,201032,201038,201039,201040,201042,201050,201051,222501,222502,222503,222504,222505,222506,222507,222509)
                    union all 
                    select 
                        m.accounting_unit_id , 
                        m.accounting_for_office_id , 
                        m.cashbook_month, 
                        m.cashbook_year,     
                        t.account_head_code,
                        t.CR_DR_INDICATOR, 
                        t.amount
                      from 
                        fas_payment_master m ,
                        fas_payment_transaction t
                      where 
                        m.accounting_unit_id = t.accounting_unit_id and 
                        m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                        m.cashbook_month = t.cashbook_month and 
                        m.cashbook_year = t.cashbook_year and 
                        m.voucher_no = t.voucher_no and 
                        m.payment_status='L' and 
                       to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                        t.account_head_code in(200605,201020,201022,201023,201024,201025,201026,201028,201029,201032,201038,201039,201040,201042,201050,201051,222501,222502,222503,222504,222505,222506,222507,222509)
                  union all
                  select 
                        m.accounting_unit_id , 
                        m.accounting_for_office_id , 
                        m.cashbook_month, 
                        m.cashbook_year,     
                        t.account_head_code,
                        t.CR_DR_INDICATOR, 
                        t.amount
                  from 
                        fas_receipt_master m ,
                        fas_receipt_transaction t
                  where 
                        m.accounting_unit_id = t.accounting_unit_id and 
                        m.ACCOUNTING_FOR_OFFICE_ID  = t.ACCOUNTING_FOR_OFFICE_ID and 
                        m.cashbook_month = t.cashbook_month and 
                        m.cashbook_year = t.cashbook_year and 
                        m.receipt_no = t.receipt_no and 
                        m.receipt_status='L' and 
                       to_date(m.cashbook_month ||'-'|| + m.cashbook_year, 'mm-yyyy') BETWEEN to_date(  1  || '-' || 2012 ,   'mm-yyyy')  AND to_date( 12 ||'-' || 2013 , 'mm-yyyy') and
                        t.account_head_code in(200605,201020,201022,201023,201024,201025,201026,201028,201029,201032,201038,201039,201040,201042,201050,201051,222501,222502,222503,222504,222505,222506,222507,222509)
            )
             group by accounting_unit_id , 
                      accounting_for_office_id , 
                      account_head_code,
                      CR_DR_INDICATOR
        )        
        group by accounting_unit_id,
                 accounting_for_office_id , 
                 account_head_code order by accounting_unit_id
        )a,
        fas_mst_annexure_ii b 
        where a.row_id=b.row_id
        group by a.row_id,
                 unit_id,
                 power_consumption,workers_cost,materials,chemicals,rr_motors_pumpsets,pipe_line_burst,royalty,original_works,others,administrative_expenditure,cost_personnel_from,cost_personnel_to
)
order by row_id,unit_id]]></queryString>

