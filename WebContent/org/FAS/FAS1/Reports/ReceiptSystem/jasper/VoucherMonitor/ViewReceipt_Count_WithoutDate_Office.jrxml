<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ViewReceipt_Count_WithoutDate_Office"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountingunitName" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountofficeName" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String"/>
	<parameter name="CR_ENTRIES" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="DR_ENTRIES" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 'Cash Remittance' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_RECEIPT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}::int  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and CREATED_BY_MODULE='CR' and RECEIPT_STATUS!='C' AND REMITTANCE_STATUS='Y' AND REMITTANCE_IN_CURR_MONTH ='Y') as opt1 
union all        
select 'Cash Receipt' as doctype,total_count,totAmt  as peritem,cast(cast(2 as numeric)*(cast(totAmt as numeric(10,2))) as numeric(10,2)) as Totamt from (select COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_RECEIPT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}::int  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int  and CREATED_BY_MODULE='CR' and RECEIPT_STATUS!='C') as opt2
union all
select 'Bank Receipt' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_RECEIPT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}::int  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int  and CREATED_BY_MODULE='BR' and RECEIPT_STATUS!='C') as opt3
union all
select 'Pending Bill payment' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_PAYMENT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}::int  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int  and CREATED_BY_MODULE='BPP' and PAYMENT_STATUS!='C' ) as opt4
union all
select 'Final Heads' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_PAYMENT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}::int  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int  and CREATED_BY_MODULE='BPF' and PAYMENT_STATUS!='C'   ) as opt5
union all
select 'Nil Payment' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_PAYMENT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}::int  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int  and CREATED_BY_MODULE='NL' and PAYMENT_STATUS!='C' ) as opt6
union all
select 'General Journal' as doctype,total_count,totAmt  as peritem,totAmt from 
(
    select count(voucher_no) as total_count,sum(total) as totAmt from 
    ( 
      select VOUCHER_NO,total from 
          (
          select b.VOUCHER_NO,(select coalesce(sum(a.amount),0) from FAS_JOURNAL_TRANSACTION a 
          where  a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID and a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID and
          a.CASHBOOK_YEAR=b.CASHBOOK_YEAR and a.CASHBOOK_MONTH=b.CASHBOOK_MONTH and 
          a.VOUCHER_NO=b.VOUCHER_NO and a.cr_dr_indicator='DR' ) as total
      from FAS_JOURNAL_MASTER b where b.ACCOUNTING_UNIT_ID=$P{accountingunitid}::int
      and b.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int and b.CASHBOOK_YEAR=$P{txtCB_Year}::int and b.CASHBOOK_MONTH=$P{txtCB_Month}::int 
      and b.CREATED_BY_MODULE='GJV' and b.JOURNAL_STATUS!='C') as opt722
      ) as opt71
 ) as opt821

union all
select 'Liabilty Journal' as doctype,total_count,totAmt  as peritem,totAmt from 
(
    select count(voucher_no) as total_count,sum(total) as totAmt from 
    ( 
      select VOUCHER_NO,total from 
          (
          select b.VOUCHER_NO,(select coalesce(sum(a.amount),0) from FAS_JOURNAL_TRANSACTION a 
          where  a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID and a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID and
          a.CASHBOOK_YEAR=b.CASHBOOK_YEAR and a.CASHBOOK_MONTH=b.CASHBOOK_MONTH and 
          a.VOUCHER_NO=b.VOUCHER_NO and a.cr_dr_indicator='DR' ) as total
      from FAS_JOURNAL_MASTER b where b.ACCOUNTING_UNIT_ID=$P{accountingunitid}::int
      and b.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int and b.CASHBOOK_YEAR=$P{txtCB_Year}::int and b.CASHBOOK_MONTH=$P{txtCB_Month}::int 
      and b.CREATED_BY_MODULE='LJV' and b.JOURNAL_STATUS!='C') as opt11
      ) as opt21
 ) as opt31
union all 
select 'Fund Transfer' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_FUND_TRF_FROM_OFFICE where ACCOUNTING_UNIT_ID=$P{accountingunitid}::int  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int  and TRANSFER_STATUS!='C') as opt411
union all 
select 'Fund Receipt' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_FUND_RECEIPT_BY_OFFICE where ACCOUNTING_UNIT_ID=$P{accountingunitid}::int  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int  and RECEIPT_STATUS!='C') as opt511
union all
select 'Self-cheque' as doctype,total_count,totAmt  as peritem,cast(cast(2 as numeric)*(cast(totAmt as numeric(10,2))) as numeric(10,2)) as Totamt from (select COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_RECEIPT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}::int  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int  and CREATED_BY_MODULE='SC' and RECEIPT_STATUS!='C')as opt611
union all 
select 'Inter-Bank-Transfer' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_INTER_BANK_TRF_AT_HO where ACCOUNTING_UNIT_ID=$P{accountingunitid}::int  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::int and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int  and TRANSFER_STATUS!='C') as opt711]]></queryString>

	<field name="doctype" class="java.lang.String"/>
	<field name="total_count" class="java.lang.Long"/>
	<field name="peritem" class="java.math.BigDecimal"/>
	<field name="totamt" class="java.math.BigDecimal"/>

	<variable name="SUM_PERITEM_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{peritem}]]></variableExpression>
	</variable>
	<variable name="SUM_TOTAMT_1" class="java.lang.Integer" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Integer($V{SUM_PERITEM_1}.intValue() + $V{CashonHand}.intValue() + $P{CR_ENTRIES}.intValue() + $P{DR_ENTRIES}.intValue())]]></variableExpression>
		<initialValueExpression><![CDATA[$V{SUM_TOTAMT_1}.valueOf(0)]]></initialValueExpression>
	</variable>
	<variable name="CashonHand" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{SUM_TOTAMT}.subtract( $V{SUM_PERITEM_1} )]]></variableExpression>
	</variable>
	<variable name="SUM_TOTAMT" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{totamt}]]></variableExpression>
	</variable>
