<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="BillStatusReportNew"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1154"
		 pageHeight="842"
		 columnWidth="1094"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="monthwords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="year" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfceId" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="fromdate" isForPrompting="false" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="false" class="java.util.Date"/>
	<parameter name="fromdate1" isForPrompting="false" class="java.util.Date"/>
	<parameter name="todate1" isForPrompting="false" class="java.util.Date"/>
	<parameter name="query" isForPrompting="true" class="java.lang.String"/>
	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<parameter name="page_no" isForPrompting="false" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT MM.ACCOUNTING_UNIT_ID,
  MM.ACCOUNTING_UNIT_OFFICE_ID,
  MM.CASHBOOK_MONTH,
  mm.CASHBOOK_YEAR,
  MM.STATUS,
  mM.BILL_NO,
  MM.NET_AMOUNT,
  TO_CHAR(mM.BILL_DATE,'DD/MM/YY')         AS BillDate,
  TO_CHAR(MM.BILL_SCRUTINY_DATE,'DD/MM/YY')AS SCRUTINYDATE,
  (SELECT u.accounting_unit_name
  FROM FAS_MST_ACCT_UNITS U
  WHERE U.Accounting_Unit_Id      = mM.Accounting_Unit_Id
  AND U.Accounting_Unit_Office_Id = Mm.Accounting_Unit_Office_Id
  )AS Unitname,
  (SELECT F1.Bill_Major_Type_Desc
  FROM FAS_BILL_MAJOR_TYPES F1
  WHERE F1.Bill_Major_Type_Code=Mm.Bill_Major_Type
  )AS Majordesc,
  (SELECT f2.bill_minor_type_desc
  FROM FAS_BILL_MINOR_TYPES_MST F2
  WHERE F2.BILL_MAJOR_TYPE_CODE=MM.BILL_MAJOR_TYPE
  AND F2.Bill_Minor_Type_Code  =Mm.Bill_Minor_Type_Code
  )AS Minordesc,
  (SELECT F3.Bill_Sub_Type_Desc
  FROM FAS_BILL_SUB_TYPES F3
  WHERE MM.BILL_MAJOR_TYPE    =F3.BILL_MAJOR_TYPE_CODE
  AND Mm.bill_minor_type_code =f3.bill_minor_type_code
  AND Mm.BILL_SUB_TYPE_CODE   =F3.BILL_SUB_TYPE_CODE
  )                                      AS SUBDESC,
  TO_CHAR(MM.PASS_ORDER_DATE,'DD/MM/YY') AS PASS_ORDER_DATE,
  MM.SANCTION_PROC_NO,
  MM.NET_AMOUNT,
  MM.NET_AMOUNT AS TOTAL_AMOUNT,
  MM.PASS_ORDER_BY,
  MM.PASS_ORDER_AMOUNT,
  TO_CHAR(MM.PRE_AUDIT_DATE,'DD/MM/YY')       AS AUDITDATE,
  TO_CHAR(MM.TREASURY_VERIFY_DATE,'DD/MM/YY') AS MTCTRESARYUPDATE,
  TO_CHAR(MM.MTC_70_REGISTER_DATE,'DD/MM/YY') AS MTC70ENTRYDATE,
  (SELECT DISTINCT t.PVR_NO
  FROM FAS_MEMO_OF_PAYMENT_TRN T,
    FAS_MEMO_OF_PAYMENT_MST TT
  WHERE TT.ACCOUNTING_UNIT_ID    =T.ACCOUNTING_UNIT_ID
  AND TT.ACCOUNTING_FOR_OFFICE_ID=T.ACCOUNTING_FOR_OFFICE_ID
  AND T.CASHBOOK_MONTH           = TT.CASHBOOK_MONTH
  AND T.CASHBOOK_YEAR            = TT.CASHBOOK_YEAR
  AND T.BILL_NO                  =TT.BILL_NO
  AND T.ACCOUNTING_UNIT_ID       =MM.ACCOUNTING_UNIT_ID
  AND t.BILL_NO                  =MM.BILL_NO
  AND tt.bill_date               =mm.bill_date
  AND TT.STATUS                  ='L'
  ) AS VOUCHER_NO,
  (SELECT DISTINCT TO_CHAR(T.PVR_DATE,'DD/MM/YY')
  FROM FAS_MEMO_OF_PAYMENT_TRN T,
    FAS_MEMO_OF_PAYMENT_MST TT
  WHERE TT.ACCOUNTING_UNIT_ID    =T.ACCOUNTING_UNIT_ID
  AND TT.ACCOUNTING_FOR_OFFICE_ID=T.ACCOUNTING_FOR_OFFICE_ID
  AND T.CASHBOOK_MONTH           = TT.CASHBOOK_MONTH
  AND T.CASHBOOK_YEAR            = TT.CASHBOOK_YEAR
  AND T.BILL_NO                  =TT.BILL_NO
  AND T.ACCOUNTING_UNIT_ID       =MM.ACCOUNTING_UNIT_ID
  AND t.BILL_NO                  =MM.BILL_NO
  AND tt.bill_date               =mm.bill_date
  AND TT.STATUS                  ='L'
  ) AS PAYMENTVOCHERDATE,
  (SELECT DISTINCT PMST.PASS_ORDER_NO
  FROM FAS_PASS_ORDER_TRN PTRN,
    FAS_PASS_ORDER_MST PMST
  WHERE PTRN.ACCOUNTING_UNIT_ID    =PMST.ACCOUNTING_UNIT_ID
  AND PTRN.ACCOUNTING_FOR_OFFICE_ID=PMST.ACCOUNTING_FOR_OFFICE_ID
  AND PTRN.CASHBOOK_MONTH          =PMST.CASHBOOK_MONTH
  AND PTRN.CASHBOOK_YEAR           =PMST.CASHBOOK_YEAR
  AND PTRN.PASS_ORDER_NO           =PMST.PASS_ORDER_NO
  AND PMST.ACCOUNTING_UNIT_ID      =MM.ACCOUNTING_UNIT_ID
  AND PTRN.BILL_NO                 =MM.BILL_NO
  AND PTRN.bill_date               =mm.bill_date
  AND PMST.STATUS                  ='L'
  ) AS PASS_ORDER_NO,
  (SELECT DISTINCT TO_CHAR(PMST.APPROVED_DATE,'DD/MM/YY')
  FROM FAS_PASS_ORDER_TRN PTRN,
    FAS_PASS_ORDER_MST PMST
  WHERE PTRN.ACCOUNTING_UNIT_ID    =PMST.ACCOUNTING_UNIT_ID
  AND PTRN.ACCOUNTING_FOR_OFFICE_ID=PMST.ACCOUNTING_FOR_OFFICE_ID
  AND PTRN.CASHBOOK_MONTH          =PMST.CASHBOOK_MONTH
  AND PTRN.CASHBOOK_YEAR           =PMST.CASHBOOK_YEAR
  AND PTRN.PASS_ORDER_NO           =PMST.PASS_ORDER_NO
  AND PMST.ACCOUNTING_UNIT_ID      =MM.ACCOUNTING_UNIT_ID
  AND PTRN.BILL_NO                 =MM.BILL_NO
  AND PTRN.bill_date               =mm.bill_date
  AND PMST.STATUS                  ='L'
  ) AS APPROVEDDATE,
  (SELECT DISTINCT C1.CHEQUE_NO
  FROM FAS_CHEQUE_MEMO_MST c1,
    FAS_CHEQUE_MEMO_TRN C
  WHERE c.ACCOUNTING_UNIT_ID     =C1.ACCOUNTING_UNIT_ID
  AND C.ACCOUNTING_FOR_OFFICE_ID =C1.ACCOUNTING_FOR_OFFICE_ID
  AND C.CASHBOOK_MONTH           =C1.CASHBOOK_MONTH
  AND C.CASHBOOK_YEAR            =C1.CASHBOOK_YEAR
  AND C1.CHEQUE_MEMO_NO          = C.CHEQUE_MEMO_NO
  AND C.ACCOUNTING_UNIT_ID       =MM.ACCOUNTING_UNIT_ID
  AND C.BILL_NO                  =MM.BILL_NO
  AND c.bill_date                =mm.bill_date
  AND C1.STATUS                  ='L'
  ) AS CHEQUE_NO,
  (SELECT DISTINCT TO_CHAR(C1.CHEQUE_MEMO_DATE,'DD/MM/YY')
  FROM FAS_CHEQUE_MEMO_MST c1,
    FAS_CHEQUE_MEMO_TRN C
  WHERE c.ACCOUNTING_UNIT_ID     =C1.ACCOUNTING_UNIT_ID
  AND C.ACCOUNTING_FOR_OFFICE_ID =C1.ACCOUNTING_FOR_OFFICE_ID
  AND C.CASHBOOK_MONTH           =C1.CASHBOOK_MONTH
  AND C.CASHBOOK_YEAR            =C1.CASHBOOK_YEAR
  AND C1.CHEQUE_MEMO_NO          = C.CHEQUE_MEMO_NO
  AND C.ACCOUNTING_UNIT_ID       =MM.ACCOUNTING_UNIT_ID
  AND C.BILL_NO                  =MM.BILL_NO
  AND C1.STATUS                  ='L'
  AND c.bill_date                =mm.bill_date
  ) AS CHEQUEDATE
FROM
  (SELECT *
  FROM FAS_BILL_REGISTER_MASTER mm
  WHERE mm.ACCOUNTING_UNIT_ID =$P{UnitId}
$P!{query}
 
  AND mm.STATUS               ='L'
  AND mm.bill_date            < '01-Apr-15'
  UNION ALL
  SELECT *
  FROM FAS_BILL_REGISTER_MASTERNEW mm
  WHERE mm.ACCOUNTING_UNIT_ID =$P{UnitId}
$P!{query}
  AND mm.STATUS               ='L'
  )mm
order by  mM.BILL_NO]]></queryString>

