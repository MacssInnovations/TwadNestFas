	<field name="PASS_ORDER_NO" class="java.math.BigDecimal"/>
	<field name="APPROVEDDATE" class="java.lang.String"/>
	<field name="CHEQUE_NO" class="java.lang.String"/>
	<field name="CHEQUEDATE" class="java.lang.String"/>

