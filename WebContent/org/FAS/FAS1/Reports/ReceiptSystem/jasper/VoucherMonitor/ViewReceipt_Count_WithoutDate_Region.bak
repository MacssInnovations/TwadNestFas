<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ViewReceipt_Count_WithoutDate_Region"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountingunitName" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountofficeName" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="txtRegionId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="CR_ENTRIES" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="DR_ENTRIES" isForPrompting="false" class="java.lang.Integer"/>
	<queryString><![CDATA[select  t.ACCOUNTING_UNIT_NAME,s.ACCOUNTING_UNIT_ID,s.ACCOUNTING_FOR_OFFICE_ID,s.doctype,s.total_count,peritem,s.totAmt from (
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Cash Receipt' as doctype,total_count,totAmt  as peritem,cast(cast(2 as numeric)*(cast(totAmt as numeric(10,2))) as numeric(10,2)) as Totamt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_RECEIPT_MASTER where  ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int)  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and CREATED_BY_MODULE='CR' and RECEIPT_STATUS!='C'   group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID)ab
union all
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Bank Receipt' as doctype,total_count,totAmt  as peritem,totAmt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_RECEIPT_MASTER where ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int)  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and CREATED_BY_MODULE='BR' and RECEIPT_STATUS!='C'   group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID)ab
union all
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Pending Bill payment' as doctype,total_count,totAmt  as peritem,totAmt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_PAYMENT_MASTER where ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int)  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and CREATED_BY_MODULE='BPP' and PAYMENT_STATUS!='C'   group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID)ab
union all
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Final Heads' as doctype,total_count,totAmt  as peritem,totAmt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_PAYMENT_MASTER where ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int)  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and CREATED_BY_MODULE='BPF' and PAYMENT_STATUS!='C'    group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID )ab
union all
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Nil Payment' as doctype,total_count,totAmt  as peritem,totAmt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_PAYMENT_MASTER where ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int)  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and CREATED_BY_MODULE='NL' and PAYMENT_STATUS!='C'   group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID )ab
union all
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,'General Journal' as doctype,total_count,totAmt  as peritem,totAmt from 
(
  select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,count(voucher_no) as total_count,sum(total) as totAmt from 
  ( 
      select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,VOUCHER_NO,total from 
      (
       select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,b.VOUCHER_NO,(select coalesce(sum(a.amount),0) from FAS_JOURNAL_TRANSACTION a 
                where a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID and a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID and
                a.CASHBOOK_YEAR=b.CASHBOOK_YEAR and a.CASHBOOK_MONTH=b.CASHBOOK_MONTH and 
                a.VOUCHER_NO=b.VOUCHER_NO and a.cr_dr_indicator='DR' ) as total
                from FAS_JOURNAL_MASTER b where 
                b.ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int)  and b.CASHBOOK_YEAR=$P{txtCB_Year}::int and b.CASHBOOK_MONTH=$P{txtCB_Month}::int
		and b.CREATED_BY_MODULE='GJV' and b.JOURNAL_STATUS!='C' 
      )ab
  )ab group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID
)ab

union all
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,'Liabilty Journal' as doctype,total_count,totAmt  as peritem,totAmt from 
(
  select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,count(voucher_no) as total_count,sum(total) as totAmt from 
  ( 
      select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,VOUCHER_NO,total from 
      (
       select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,b.VOUCHER_NO,(select coalesce(sum(a.amount),0) from FAS_JOURNAL_TRANSACTION a 
                where a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID and a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID and
                a.CASHBOOK_YEAR=b.CASHBOOK_YEAR and a.CASHBOOK_MONTH=b.CASHBOOK_MONTH and 
                a.VOUCHER_NO=b.VOUCHER_NO and a.cr_dr_indicator='DR' ) as total
                from FAS_JOURNAL_MASTER b where 
                b.ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int)  and b.CASHBOOK_YEAR=$P{txtCB_Year}::int and b.CASHBOOK_MONTH=$P{txtCB_Month}::int
		and b.CREATED_BY_MODULE='LJV' and b.JOURNAL_STATUS!='C' 
      )ab
  )ab group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID
)ab
union all 
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Fund Transfer Banking' as doctype,total_count,totAmt  as peritem,totAmt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(VOUCHER_NO)  as total_count ,sum(TOTAL_AMOUNT) as totAmt from FAS_FUND_TRF_FROM_HO_MASTER where ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int) and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and TRANSFER_STATUS!='C' group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID )ab
union all 
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Fund Transfer' as doctype,total_count,totAmt  as peritem,totAmt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_FUND_TRF_FROM_OFFICE where ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int) and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and TRANSFER_STATUS!='C' group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID )ab
union all 
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Fund Receipt Banking' as doctype,total_count,totAmt  as peritem,totAmt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_FUND_RECEIPT_BY_HO where ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int)  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int    and RECEIPT_STATUS!='C' group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID )ab
union all 
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Fund Receipt' as doctype,total_count,totAmt  as peritem,totAmt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_FUND_RECEIPT_BY_OFFICE where ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int)  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and RECEIPT_STATUS!='C' group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID )ab
union all
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Self-Cheque' as doctype,total_count,totAmt  as peritem,cast(cast(2 as numeric)*(cast(totAmt as numeric(10,2))) as numeric(10,2)) as Totamt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_RECEIPT_MASTER where ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int)  and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and CREATED_BY_MODULE='SC' and RECEIPT_STATUS!='C'   group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID)ab
union all 
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, 'Inter-Bank-Transfer' as doctype,total_count,totAmt  as peritem,totAmt from (select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID, COUNT(VOUCHER_NO)  as total_count ,sum(TOTAL_AMOUNT) as totAmt from FAS_INTER_BANK_TRF_AT_HO where ACCOUNTING_FOR_OFFICE_ID in (select office_id from COM_MST_ALL_OFFICES_VIEW where region_office_id=$P{txtRegionId}::int) and CASHBOOK_YEAR=$P{txtCB_Year}::int and CASHBOOK_MONTH=$P{txtCB_Month}::int   and TRANSFER_STATUS!='C' group by ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID )ab
) s,FAS_MST_ACCT_UNITS t  where s.ACCOUNTING_UNIT_ID=t.ACCOUNTING_UNIT_ID order by t.ACCOUNTING_UNIT_NAME]]></queryString>

	<field name="accounting_unit_name" class="java.lang.String"/>
	<field name="accounting_unit_id" class="java.math.BigDecimal"/>
	<field name="accounting_for_office_id" class="java.math.BigDecimal"/>
	<field name="doctype" class="java.lang.String"/>
	<field name="total_count" class="java.lang.Long"/>
	<field name="peritem" class="java.lang.Double"/>
	<field name="totamt" class="java.lang.Double"/>

	<variable name="SUM_PERITEM_1" class="java.lang.Double" resetType="Group" resetGroup="AccUnit" calculation="Sum">
		<variableExpression><![CDATA[$F{peritem}]]></variableExpression>
	</variable>
	<variable name="SUM_TOTAMT_1" class="java.lang.Double" resetType="Group" resetGroup="AccUnit" calculation="Sum">
		<variableExpression><![CDATA[$F{totamt}]]></variableExpression>
	</variable>
	<variable name="SUM_TOTAMT_2" class="java.math.BigDecimal" resetType="Group" resetGroup="AccUnit" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal($V{SUM_PERITEM_1}.doubleValue() + $V{CashonHand}.doubleValue() + $P{CR_ENTRIES}.doubleValue() + $P{DR_ENTRIES}.doubleValue())]]></variableExpression>
	</variable>
	<variable name="CashonHand" class="java.lang.Double" resetType="Group" resetGroup="AccUnit" calculation="Nothing">
		<variableExpression><![CDATA[new Double($V{SUM_PERITEM_1}.doubleValue() == 0 ? 0 : ($V{SUM_TOTAMT_1}.doubleValue()-$V{SUM_PERITEM_1}.doubleValue()))]]></variableExpression>
	</variable>

