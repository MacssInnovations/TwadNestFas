	<parameter name="regionid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="regionname" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supplementno" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT n.ACCOUNTING_UNIT_ID,
  n.ACCOUNTING_UNIT_NAME,
  CM_credit,
  CM_debit,
  tb_date
FROM
  (SELECT a.ACCOUNTING_UNIT_ID,
    SUM(CURRENT_MONTH_CREDIT) AS CM_credit,
    SUM(CURRENT_MONTH_DEBIT)  AS CM_DEBIT,
    A.UPDATED_DATE as tb_date
  FROM FAS_TRIAL_BALANCE_SJV_CMP A
  WHERE a.CASHBOOK_YEAR = $P{cashbookyear}
    AND CASHBOOK_MONTH  = $P{cashbookmonth}
    AND a.supplement_no       = $P{supplementno}
  GROUP BY a.ACCOUNTING_UNIT_ID, A.UPDATED_DATE
  ) m,
  FAS_MST_ACCT_UNITS n
WHERE m.ACCOUNTING_UNIT_ID=n.ACCOUNTING_UNIT_ID
ORDER BY m.accounting_unit_id]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="CM_CREDIT" class="java.math.BigDecimal"/>
	<field name="CM_DEBIT" class="java.math.BigDecimal"/>
	<field name="TB_DATE" class="java.sql.Timestamp"/>

	<variable name="CR_Amt_GrantTotal" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CM_CREDIT}]]></variableExpression>
	</variable>
	<variable name="DR_Amt_GrantTotal" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CM_DEBIT}]]></variableExpression>
	</variable>
