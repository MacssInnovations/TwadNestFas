<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="BillStatusReport1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="932"
		 pageHeight="842"
		 columnWidth="872"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="monthwords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfceId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="formdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[SELECT
m.Accounting_Unit_Id,
  m.Accounting_Unit_Office_Id,
 m.Cashbook_Month,
 m.CASHBOOK_YEAR,
 M.STATUS,
 M.BILL_NO,
 M.NET_AMOUNT,
 TO_CHAR(M.BILL_DATE,'DD/MM/YY')as BillDate,
 to_char(M.BILL_SCRUTINY_DATE,'DD/MM/YY')as ScrutinyDate,
  (SELECT u.accounting_unit_name
  FROM Fas_Mst_Acct_Units U
  WHERE U.Accounting_Unit_Id      = M.Accounting_Unit_Id
  AND U.Accounting_Unit_Office_Id = M.Accounting_Unit_Office_Id
  )AS Unitname,
  (SELECT F1.Bill_Major_Type_Desc
  FROM Fas_Bill_Major_Types F1
  WHERE F1.Bill_Major_Type_Code=M.Bill_Major_Type
  )AS Majordesc,
  (SELECT f2.bill_minor_type_desc
  FROM Fas_Bill_Minor_Types_Mst F2
  WHERE F2.Bill_Major_Type_Code=M.Bill_Major_Type
  AND F2.Bill_Minor_Type_Code  =M.Bill_Minor_Type_Code
  )AS Minordesc,
  (SELECT F3.Bill_Sub_Type_Desc
  FROM FAS_BILL_SUB_TYPES f3
  WHERE M.BILL_MAJOR_TYPE    =f3.bill_major_type_code
  AND M.bill_minor_type_code =f3.bill_minor_type_code
  AND M.BILL_SUB_TYPE_CODE   =F3.BILL_SUB_TYPE_CODE
  )AS Subdesc,
M.PASS_ORDER_DATE,
  M.SANCTION_PROC_NO,
  M.NET_AMOUNT,
  M.PASS_ORDER_BY,
  M.PASS_ORDER_AMOUNT,
  PMST.PASS_ORDER_NO,
  --TO_CHAR(PMST.APPROVED_DATE,'DD/MM/YY')AS APPROVEDDATE,
 TO_CHAR(MTC.MTC70_ENTRY_DATE,'DD/MM/YY')AS MTC70ENTRYDATE,
 TO_CHAR(M.PRE_AUDIT_DATE,'DD/MM/YY')AS AUDITDATE,
 TO_CHAR(M.TREASURY_VERIFY_DATE,'DD/MM/YY')AS MTCTRESARYUPDATE,
 C.CHEQUE_NO,
 TO_CHAR(C.CHEQUE_MEMO_DATE,'DD/MM/YY')AS CHEQUEDATE,
 P.VOUCHER_NO,
 P.TOTAL_AMOUNT,
 TO_CHAR(P.PAYMENT_DATE,'DD/MM/YY')AS paymentVocherDate
FROM FAS_BILL_REGISTER_MASTER M
INNER JOIN FAS_PASS_ORDER_MST PMST
ON M.ACCOUNTING_UNIT_ID        =PMST.ACCOUNTING_UNIT_ID
AND M.ACCOUNTING_UNIT_OFFICE_ID=PMST.ACCOUNTING_FOR_OFFICE_ID
AND M.CASHBOOK_MONTH           =PMST.CASHBOOK_MONTH
AND M.CASHBOOK_YEAR            =PMST.CASHBOOK_YEAR
AND M.ACCOUNTING_UNIT_ID       =23
--AND M.CASHBOOK_MONTH           =1
--AND M.CASHBOOK_YEAR            =2015
and To_Date((m.Cashbook_Month
||'-'
|| m.Cashbook_Year),'mm-yyyy') BETWEEN To_Date(3
||'-'
||2013,'mm-yyyy')
AND to_date(8
||'-'
||2015,'mm-yyyy')
--AND TO_DATE('01/'|| M.CASHBOOK_MONTH||'/'|| M.CASHBOOK_YEAR ,'DD/MM/YYYY')
--BETWEEN ('01/02/2014','DD/MM/YYYY') AND ('01/05/2014','DD/MM/YYYY')
AND M.STATUS                   ='L'
AND M.BILL_TYPE                ='WSP'
INNER JOIN FAS_PASS_ORDER_TRN PTRN
ON PTRN.ACCOUNTING_UNIT_ID       =PMST.ACCOUNTING_UNIT_ID
AND PTRN.ACCOUNTING_FOR_OFFICE_ID=PMST.ACCOUNTING_FOR_OFFICE_ID
AND PTRN.CASHBOOK_MONTH          =PMST.CASHBOOK_MONTH
AND PTRN.CASHBOOK_YEAR           =PMST.CASHBOOK_YEAR
AND M.SANCTION_PROC_NO           =PTRN.SANCTION_PROC_NO
AND M.NET_AMOUNT                 =PTRN.BILL_AMOUNT
AND M.PASS_ORDER_DATE=PMST.PASS_ORDER_DATE
INNER JOIN FAS_MTC70_REGISTER MTC
ON M.ACCOUNTING_UNIT_ID        =MTC.ACCOUNTING_UNIT_ID
AND M.ACCOUNTING_UNIT_OFFICE_ID=MTC.ACCOUNTING_FOR_OFFICE_ID
AND M.CASHBOOK_MONTH=MTC.CASHBOOK_MONTH
AND M.CASHBOOK_YEAR=MTC.CASHBOOK_YEAR
AND M.BILL_NO=MTC.BILL_NO
INNER JOIN FAS_CHEQUE_MEMO_MST C
ON M.ACCOUNTING_UNIT_ID        =C.ACCOUNTING_UNIT_ID
AND M.ACCOUNTING_UNIT_OFFICE_ID=C.ACCOUNTING_FOR_OFFICE_ID
AND M.CASHBOOK_MONTH=C.CASHBOOK_MONTH
AND M.CASHBOOK_YEAR=C.CASHBOOK_YEAR
AND M.NET_AMOUNT=C.CHEQUE_AMOUNT
INNER JOIN FAS_PAYMENT_MASTER P
ON M.ACCOUNTING_UNIT_ID        =P.ACCOUNTING_UNIT_ID
AND M.ACCOUNTING_UNIT_OFFICE_ID=P.ACCOUNTING_FOR_OFFICE_ID
AND M.CASHBOOK_MONTH=P.CASHBOOK_MONTH
AND M.CASHBOOK_YEAR=P.CASHBOOK_YEAR
and M.NET_AMOUNT=P.TOTAL_AMOUNT]]></queryString>

