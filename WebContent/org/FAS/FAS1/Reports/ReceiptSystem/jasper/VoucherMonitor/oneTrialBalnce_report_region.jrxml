	<field name="ACCOUNTING_UNIT_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="CM_CREDIT" class="java.math.BigDecimal"/>
	<field name="CM_DEBIT" class="java.math.BigDecimal"/>
	<field name="UPDATED_DATE" class="java.sql.Timestamp"/>

	<variable name="CR_Amt_GrantTotal" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
