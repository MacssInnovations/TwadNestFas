	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtRegionId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT n.ACCOUNTING_UNIT_ID,
  n.ACCOUNTING_UNIT_OFFICE_ID,
  n.ACCOUNTING_UNIT_NAME,
  CM_credit,
  CM_debit,
  m.date_updated as updated_date
FROM
  (SELECT a.ACCOUNTING_UNIT_ID,
    SUM(CURRENT_MONTH_CREDIT) AS CM_credit,
    SUM(CURRENT_MONTH_DEBIT)  AS CM_debit,
    a.date_updated
  FROM FAS_TRIAL_BALANCE a,
    (SELECT ACCOUNTING_UNIT_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH
    FROM FAS_TRIAL_BALANCE_STATUS
    WHERE ACCOUNTING_UNIT_ID IN
      (SELECT ACCOUNTING_UNIT_ID
      FROM FAS_MST_ACCT_UNIT_OFFICES
      WHERE ACCOUNTING_FOR_OFFICE_ID IN
        (SELECT office_id
        FROM COM_MST_ALL_OFFICES_VIEW
        WHERE region_office_id=$P{txtRegionId}
        )
      )
    AND CASHBOOK_YEAR =$P{txtCB_Year}
    AND CASHBOOK_MONTH=$P{txtCB_Month}
    AND TB_STATUS     ='Y'
    ) b
  WHERE a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID
  AND a.CASHBOOK_YEAR       =b.CASHBOOK_YEAR
  AND a.CASHBOOK_MONTH      =b.CASHBOOK_MONTH
  GROUP BY a.ACCOUNTING_UNIT_ID, a.date_updated
  ) m,
  FAS_MST_ACCT_UNITS n
WHERE m.ACCOUNTING_UNIT_ID=n.ACCOUNTING_UNIT_ID
order by n.ACCOUNTING_UNIT_ID]]></queryString>

