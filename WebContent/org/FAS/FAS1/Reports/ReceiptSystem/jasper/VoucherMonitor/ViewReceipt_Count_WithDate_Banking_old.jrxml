<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ViewReceipt_Count_WithDate_Banking_old"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<parameter name="accountingunitName" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountofficeName" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="CR_ENTRIES" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="DR_ENTRIES" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT 'Cash Remittance' AS doctype,
  total_count,
  totAmt                                                                 AS peritem,
  Totamt
FROM
  (SELECT COUNT(RECEIPT_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_RECEIPT_MASTER
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND CREATED_BY_MODULE       ='CR'
  AND RECEIPT_STATUS!         ='C'
  AND REMITTANCE_STATUS        ='Y'
  AND REMITTANCE_IN_CURR_MONTH ='Y'
  AND RECEIPT_DATE BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
select 'Cash Receipt' as doctype,total_count,totAmt  as peritem,cast(cast(2 as number)*(cast(totAmt as number(10,2))) as number(10,2)) as Totamt from (select COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_RECEIPT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}  and CREATED_BY_MODULE='CR' and RECEIPT_STATUS!='C' and  RECEIPT_DATE between $P{txtfrom} and $P{txtto} )
union all
select 'Bank Receipt' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_RECEIPT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} and CREATED_BY_MODULE='BR' and RECEIPT_STATUS!='C' and  RECEIPT_DATE between $P{txtfrom} and $P{txtto} )
union all
select 'Pending Bill payment' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_PAYMENT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}  and CREATED_BY_MODULE='BPP' and PAYMENT_STATUS!='C' and  PAYMENT_DATE between $P{txtfrom} and $P{txtto} )
union all
select 'Final Heads' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_PAYMENT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}  and CREATED_BY_MODULE='BPF' and PAYMENT_STATUS!='C' and  PAYMENT_DATE between $P{txtfrom} and $P{txtto}   )
union all
select 'Nil Payment' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(VOUCHER_NO)  as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_PAYMENT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}  and CREATED_BY_MODULE='NL' and PAYMENT_STATUS!='C' and  PAYMENT_DATE between $P{txtfrom} and $P{txtto} )
union all
select 'General Journal' as doctype,total_count,totAmt  as peritem,totAmt from 
(
    select count(voucher_no) as total_count,sum(total) as totAmt from 
    ( 
      select VOUCHER_NO,total from 
          (
          select b.VOUCHER_NO,(select nvl(sum(a.amount),0) from FAS_JOURNAL_TRANSACTION a 
          where  a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID and a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID and
          a.CASHBOOK_YEAR=b.CASHBOOK_YEAR and a.CASHBOOK_MONTH=b.CASHBOOK_MONTH and 
          a.VOUCHER_NO=b.VOUCHER_NO and a.cr_dr_indicator='DR' ) as total
      from FAS_JOURNAL_MASTER b where b.ACCOUNTING_UNIT_ID=$P{accountingunitid}
      and b.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} 
      and (b.VOUCHER_DATE between $P{txtfrom} and $P{txtto} ) and b.CREATED_BY_MODULE='GJV' and b.JOURNAL_STATUS!='C')
      )
 )

union all
select 'Liabilty Journal' as doctype,total_count,totAmt  as peritem,totAmt from 
(
    select count(voucher_no) as total_count,sum(total) as totAmt from 
    ( 
      select VOUCHER_NO,total from 
          (
          select b.VOUCHER_NO,(select nvl(sum(a.amount),0) from FAS_JOURNAL_TRANSACTION a 
          where  a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID and a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID and
          a.CASHBOOK_YEAR=b.CASHBOOK_YEAR and a.CASHBOOK_MONTH=b.CASHBOOK_MONTH and 
          a.VOUCHER_NO=b.VOUCHER_NO and a.cr_dr_indicator='DR' ) as total
      from FAS_JOURNAL_MASTER b where b.ACCOUNTING_UNIT_ID=$P{accountingunitid}
      and b.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} 
      and (b.VOUCHER_DATE between $P{txtfrom} and $P{txtto} ) and b.CREATED_BY_MODULE='LJV' and b.JOURNAL_STATUS!='C')
      )
 )
union all 
select 'Fund Transfer' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(VOUCHER_NO)  as total_count ,sum(TOTAL_AMOUNT) as totAmt from FAS_FUND_TRF_FROM_HO_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}  and TRANSFER_STATUS!='C' and  DATE_OF_TRANSFER between $P{txtfrom} and $P{txtto} )
union all 
select 'Fund Receipt' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_FUND_RECEIPT_BY_HO where ACCOUNTING_UNIT_ID=$P{accountingunitid}  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}  and RECEIPT_STATUS!='C' and  RECEIPT_DATE between $P{txtfrom} and $P{txtto} )
union all
select 'Self-Cheque' as doctype,total_count,totAmt  as peritem,cast(cast(2 as number)*(cast(totAmt as number(10,2))) as number(10,2)) as Totamt from (select COUNT(RECEIPT_NO) as total_count,sum(TOTAL_AMOUNT) as totAmt from FAS_RECEIPT_MASTER where ACCOUNTING_UNIT_ID=$P{accountingunitid}  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}   and CREATED_BY_MODULE='SC' and RECEIPT_STATUS!='C' and  RECEIPT_DATE between $P{txtfrom} and $P{txtto} )
union all 
select 'Inter-Bank-Transfer' as doctype,total_count,totAmt  as peritem,totAmt from (select COUNT(VOUCHER_NO)  as total_count ,sum(TOTAL_AMOUNT) as totAmt from FAS_INTER_BANK_TRF_AT_HO where ACCOUNTING_UNIT_ID=$P{accountingunitid}  and ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}   and TRANSFER_STATUS!='C' and  DATE_OF_TRANSFER between $P{txtfrom} and $P{txtto} )]]></queryString>

	<field name="DOCTYPE" class="java.lang.String"/>
	<field name="TOTAL_COUNT" class="java.math.BigDecimal"/>
	<field name="PERITEM" class="java.math.BigDecimal"/>
	<field name="TOTAMT" class="java.math.BigDecimal"/>

	<variable name="SUM_PERITEM_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{PERITEM}]]></variableExpression>
	</variable>
	<variable name="SUM_TOTAMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAMT}]]></variableExpression>
	</variable>
	<variable name="CashonHand" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{TOTAMT}.subtract($F{PERITEM})]]></variableExpression>
	</variable>
