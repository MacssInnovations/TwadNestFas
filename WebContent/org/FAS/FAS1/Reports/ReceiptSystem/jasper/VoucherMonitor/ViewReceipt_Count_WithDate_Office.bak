<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ViewReceipt_Count_WithDate_Office"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="594"
		 pageHeight="842"
		 columnWidth="534"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<parameter name="accountingunitName" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountofficeName" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DR_ENTRIES" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="CR_ENTRIES" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT 'Cash Remittance' AS doctype,
  total_count,
  totAmt                                                                 AS peritem,
  Totamt
FROM
  (SELECT COUNT(RECEIPT_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_RECEIPT_MASTER
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND CREATED_BY_MODULE       ='CR'
  AND RECEIPT_STATUS!         ='C'
  AND REMITTANCE_STATUS        ='Y'
  AND REMITTANCE_IN_CURR_MONTH ='Y'
  AND RECEIPT_DATE BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
      

SELECT 'Cash Receipt' AS doctype,
  total_count,
  totAmt                                                                 AS peritem,
  CAST(CAST(2 AS NUMBER)*(CAST(totAmt AS NUMBER(10,2))) AS NUMBER(10,2)) AS Totamt
FROM
  (SELECT COUNT(RECEIPT_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_RECEIPT_MASTER
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND CREATED_BY_MODULE       ='CR'
  AND RECEIPT_STATUS!         ='C'
  AND RECEIPT_DATE BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
SELECT 'Bank Receipt' AS doctype,
  total_count,
  totAmt AS peritem,
  totAmt
FROM
  (SELECT COUNT(RECEIPT_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_RECEIPT_MASTER
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND CREATED_BY_MODULE       ='BR'
  AND RECEIPT_STATUS!         ='C'
  AND RECEIPT_DATE BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
SELECT 'Pending Bill payment' AS doctype,
  total_count,
  totAmt AS peritem,
  totAmt
FROM
  (SELECT COUNT(VOUCHER_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_PAYMENT_MASTER
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND CREATED_BY_MODULE       ='BPP'
  AND PAYMENT_STATUS!         ='C'
  AND PAYMENT_DATE BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
SELECT 'Final Heads' AS doctype,
  total_count,
  totAmt AS peritem,
  totAmt
FROM
  (SELECT COUNT(VOUCHER_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_PAYMENT_MASTER
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND CREATED_BY_MODULE       ='BPF'
  AND PAYMENT_STATUS!         ='C'
  AND PAYMENT_DATE BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
SELECT 'Nil Payment' AS doctype,
  total_count,
  totAmt AS peritem,
  totAmt
FROM
  (SELECT COUNT(VOUCHER_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_PAYMENT_MASTER
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND CREATED_BY_MODULE       ='NL'
  AND PAYMENT_STATUS!         ='C'
  AND PAYMENT_DATE BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
SELECT 'General Journal' AS doctype,
  total_count,
  totAmt AS peritem,
  totAmt
FROM
  (SELECT COUNT(voucher_no) AS total_count,
    SUM(total)              AS totAmt
  FROM
    (SELECT VOUCHER_NO,
      total
    FROM
      (SELECT b.VOUCHER_NO,
        (SELECT NVL(SUM(a.amount),0)
        FROM FAS_JOURNAL_TRANSACTION a
        WHERE a.ACCOUNTING_UNIT_ID    =b.ACCOUNTING_UNIT_ID
        AND a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID
        AND a.CASHBOOK_YEAR           =b.CASHBOOK_YEAR
        AND a.CASHBOOK_MONTH          =b.CASHBOOK_MONTH
        AND a.VOUCHER_NO              =b.VOUCHER_NO
        AND a.cr_dr_indicator         ='DR'
        ) AS total
      FROM FAS_JOURNAL_MASTER b
      WHERE b.ACCOUNTING_UNIT_ID    =$P{accountingunitid}
      AND B.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
      AND (b.VOUCHER_DATE BETWEEN $P{txtfrom} AND $P{txtto} )
      AND b.CREATED_BY_MODULE='GJV'
      AND b.JOURNAL_STATUS!  ='C'
      )
    )
  )
UNION ALL
SELECT 'Liabilty Journal' AS doctype,
  total_count,
  totAmt AS peritem,
  totAmt
FROM
  (SELECT COUNT(voucher_no) AS total_count,
    SUM(total)              AS totAmt
  FROM
    (SELECT VOUCHER_NO,
      total
    FROM
      (SELECT b.VOUCHER_NO,
        (SELECT NVL(SUM(a.amount),0)
        FROM FAS_JOURNAL_TRANSACTION a
        WHERE a.ACCOUNTING_UNIT_ID    =b.ACCOUNTING_UNIT_ID
        AND a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID
        AND a.CASHBOOK_YEAR           =b.CASHBOOK_YEAR
        AND a.CASHBOOK_MONTH          =b.CASHBOOK_MONTH
        AND a.VOUCHER_NO              =b.VOUCHER_NO
        AND a.cr_dr_indicator         ='DR'
        ) AS total
      FROM FAS_JOURNAL_MASTER b
      WHERE b.ACCOUNTING_UNIT_ID    =$P{accountingunitid}
      AND b.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
      AND (b.VOUCHER_DATE BETWEEN $P{txtfrom} AND $P{txtto} )
      AND b.CREATED_BY_MODULE='LJV'
      AND b.JOURNAL_STATUS!  ='C'
      )
    )
  )
UNION ALL
SELECT 'Fund Transfer' AS doctype,
  total_count,
  totAmt AS peritem,
  totAmt
FROM
  (SELECT COUNT(VOUCHER_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_FUND_TRF_FROM_OFFICE
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND TRANSFER_STATUS!        ='C'
  AND DATE_OF_TRANSFER BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
SELECT 'Fund Receipt' AS doctype,
  total_count,
  totAmt AS peritem,
  totAmt
FROM
  (SELECT COUNT(RECEIPT_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_FUND_RECEIPT_BY_OFFICE
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND RECEIPT_STATUS!         ='C'
  AND RECEIPT_DATE BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
SELECT 'Self-Cheque' AS doctype,
  total_count,
  totAmt                                                                 AS peritem,
  CAST(CAST(2 AS NUMBER)*(CAST(totAmt AS NUMBER(10,2))) AS NUMBER(10,2)) AS Totamt
FROM
  (SELECT COUNT(RECEIPT_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_RECEIPT_MASTER
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND CREATED_BY_MODULE       ='SC'
  AND RECEIPT_STATUS!         ='C'
  AND RECEIPT_DATE BETWEEN $P{txtfrom} AND $P{txtto}
  )
UNION ALL
SELECT 'Inter-Bank-Transfer' AS doctype,
  total_count,
  totAmt AS peritem,
  totAmt
FROM
  (SELECT COUNT(VOUCHER_NO) AS total_count,
    SUM(TOTAL_AMOUNT)       AS totAmt
  FROM FAS_INTER_BANK_TRF_AT_HO
  WHERE ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND TRANSFER_STATUS!        ='C'
  AND DATE_OF_TRANSFER BETWEEN $P{txtfrom} AND $P{txtto}
  )]]></queryString>

	<field name="DOCTYPE" class="java.lang.String"/>
	<field name="TOTAL_COUNT" class="java.math.BigDecimal"/>
	<field name="PERITEM" class="java.math.BigDecimal"/>
	<field name="TOTAMT" class="java.math.BigDecimal"/>

	<variable name="SUM_totAmt_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAMT}]]></variableExpression>
	</variable>
	<variable name="SUM_SUM_totAmt_1_1" class="java.math.BigDecimal" resetType="Page" calculation="Sum">
		<variableExpression><![CDATA[$V{SUM_totAmt_1}]]></variableExpression>
	</variable>
	<variable name="SUM_SUM_totAmt_1_2" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$V{SUM_totAmt_1}]]></variableExpression>
	</variable>
	<variable name="SUM_PERITEM_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{PERITEM}]]></variableExpression>
	</variable>
	<variable name="SUM_TOTAMT_1" class="java.lang.Integer" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Integer($V{SUM_PERITEM_1}.intValue() + $V{CashonHand}.intValue() + $P{CR_ENTRIES}.intValue() + $P{DR_ENTRIES}.intValue())]]></variableExpression>
	</variable>
	<variable name="CashonHand" class="java.lang.Double" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new Double($V{SUM_PERITEM_1}.doubleValue() == 0 ? 0 : ($V{SUM_TOTAMT}.doubleValue()-$V{SUM_PERITEM_1}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="SUM_TOTAMT" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAMT}]]></variableExpression>
	</variable>
