<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ListOfReceipts_CashSl"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="850"
		 pageHeight="842"
		 columnWidth="790"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="recType" isForPrompting="true" class="java.lang.String"/>
	<parameter name="recNofrom" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="recNoto" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT recTrans.ACCOUNT_HEAD_CODE ,
  acchead.ACCOUNT_HEAD_DESC ,
  recMas.ACCOUNTING_UNIT_ID ,
  recMas.CREATED_BY_MODULE,
  CASE
    WHEN recMas.CREATED_BY_MODULE='CR'
    THEN 'By cash,on account of...'
    WHEN recMas.CREATED_BY_MODULE='BR'
    THEN 'By Bank,on account of...'
  END AS flag,
  recMas.ACCOUNTING_FOR_OFFICE_ID,
  accUint.ACCOUNTING_UNIT_NAME,
  Office.OFFICE_NAME ,
  Office.CITY_TOWN_NAME ,
  TO_CHAR(recMas.RECEIPT_DATE,'DD/MM/YYYY') AS RECEIPT_DATE,
  recMas.RECEIPT_NO,
  recMas.RECEIVED_FROM,
  recMas.TOTAL_AMOUNT AS TOT_AMT_NO,
  recTrans.PARTICULARS,
  recTrans.AMOUNT                AS TRNS_AMOUNT,
  numtochar(recMas.TOTAL_AMOUNT) AS TOT_AMT_CHAR,
  recTrans.SUB_LEDGER_TYPE_CODE,
recTrans.SUB_LEDGER_CODE,

 (SELECT S.Sub_Ledger_Type_Desc
  FROM com_mst_sl_types s
  WHERE s.SUB_LEDGER_TYPE_CODE=recTrans.Sub_Ledger_Type_Code
  )AS sl_desc,
 
  (SELECT l.SL_CODENAME
  FROM SL_TYPE_CODE_NAME_VIEW_M l
  WHERE L.Sl_Type=recTrans.Sub_Ledger_Type_Code
  AND L.Sl_Code  =recTrans.Sub_Ledger_Code
  )AS code_desc
FROM FAS_RECEIPT_MASTER recMas,
  COM_MST_OFFICES Office,
  FAS_MST_ACCT_UNITS accUint,
  FAS_RECEIPT_TRANSACTION recTrans ,
  COM_MST_ACCOUNT_HEADS acchead
WHERE recMas.ACCOUNTING_UNIT_ID    =recTrans.ACCOUNTING_UNIT_ID
AND recMas.ACCOUNTING_FOR_OFFICE_ID=recTrans.ACCOUNTING_FOR_OFFICE_ID
AND recMas.CASHBOOK_YEAR           =recTrans.CASHBOOK_YEAR
AND recMas.CASHBOOK_MONTH          =recTrans.CASHBOOK_MONTH
AND recMas.RECEIPT_NO              =recTrans.RECEIPT_NO
AND recMas.ACCOUNTING_UNIT_ID      =accUint.ACCOUNTING_UNIT_ID
AND recMas.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID
AND recTrans.ACCOUNT_HEAD_CODE     =acchead.ACCOUNT_HEAD_CODE 
AND recMas.receipt_status!='C' 
AND recMas.ACCOUNTING_UNIT_ID      =$P{acc_unit_id}
AND recMas.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}
AND recMas.CASHBOOK_YEAR           =$P{yr}
AND recMas.CASHBOOK_MONTH          =$P{mon}
AND recMas.receipt_no BETWEEN $P{recNofrom} AND $P{recNoto} $P!{recType}]]></queryString>

