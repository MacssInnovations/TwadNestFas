<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="RegisterChequeReport_HO"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="907"
		 pageHeight="595"
		 columnWidth="847"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="banksql" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="acc_no" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select
*
from 
(

------------------------ Payment ------------------
select
     voucher_no as "voucher_no",
    trf_date as "trf_date",     
    account_no as "account_no", 
     b_id as "b_id",
     br_id as "br_id",
     Acc_details as "Acc_details",  
     amt_paid_to as "amt_paid_to",      
    CHEQUE_DD_NO as "cheque_dd_no",   
   CHEQUE_DD_DATE as "cheque_dd_date",   
     (dr_AMt::int-cr_AMt::int) as "AMOUNT",       
     particulars as "particulars",
     transfer_type as "transfer_type", 
     accounting_unit_name as "accounting_unit_name",
     office_short_name,
     branch_name,
    BANK_NAME as "BANK_NAME", 
     micr_code  
     from
(select
     a.voucher_no,
     a.payment_date as trf_date,     
     a.account_no, 
     a.bank_id as b_id,
     a.branch_id  br_id,
     (b.account_head_code ||'-' || g.account_head_desc) AS Acc_details, 
     a.paid_to as amt_paid_to,     
     b.CHEQUE_DD_NO,
     b.CHEQUE_DD_DATE,
   
--decode(b.CR_DR_INDICATOR,'DR',b.amount,0) as dr_AMt, 
  case when  b.CR_DR_INDICATOR='DR' then b.amount=0 end   as dr_AMt,
---decode(b.CR_DR_INDICATOR,'CR',b.amount,0) as cr_AMt,
case when  b.CR_DR_INDICATOR='CR' then b.amount=0 end   as cr_AMt,
    -- b.amount,
     b.particulars,
     '' as transfer_type,  
     c.accounting_unit_name,
     d.office_short_name,
     e.branch_name, 
     f.BANK_NAME, 
     e.micr_code 
from 
     fas_payment_master a,
     fas_payment_transaction b,
     fas_mst_acct_units c,
     com_mst_offices d,
     fas_mst_bank_branches e,
     com_mst_account_heads g,
     fas_mst_banks f
where 
    a.cashbook_month=b.cashbook_month 
and a.cashbook_year=b.cashbook_year
and a.accounting_unit_id=b.accounting_unit_id 
and a.accounting_for_office_id=b.accounting_for_office_id
and a.voucher_no=b.voucher_no
and c.accounting_unit_id=a.accounting_unit_id
and d.office_id=a.accounting_for_office_id 
and e.bank_id=a.bank_id 
and e.branch_id=a.branch_id 
and f.bank_id=e.bank_id 
AND b.account_head_code       =g.account_head_code
and a.payment_status<>'C' 
and a.payment_type='B' and A.Created_By_Module!='SC'
and a.cashbook_year=$P{cashbookyear}::int
and a.cashbook_month=$P{cashbookmonth}::int  
and a.accounting_unit_id=$P{accountingunitid}::int
and a.accounting_for_office_id=$P{accountofficeid}::int



) as opt1
union all

---------------- Receipt ------------------

select
     a.receipt_no as voucher_no,
     a.receipt_date as trf_date,
     a.account_no,
     a.bank_id as b_id,
     a.branch_id as br_id,
     (b.account_head_code
    ||'-'
    || g.account_head_desc) AS Acc_details ,
     ' ' as amt_paid_to,
     b.CHEQUE_DD_NO,
     b.CHEQUE_DD_DATE,
     b.amount,
     b.particulars,
     '' as transfer_type, 
     c.accounting_unit_name,
     d.office_short_name,
     e.branch_name,
     f.BANK_NAME, 
     e.micr_code 
from 
     fas_receipt_master a,
     fas_receipt_transaction b,
     fas_mst_acct_units c,
     com_mst_offices d,
     fas_mst_bank_branches e,
     com_mst_account_heads g,
     fas_mst_banks f
where 
    a.cashbook_month=b.cashbook_month 
and a.cashbook_year=b.cashbook_year
and a.accounting_unit_id=b.accounting_unit_id 
and a.accounting_for_office_id=b.accounting_for_office_id
and a.receipt_no=b.receipt_no
and c.accounting_unit_id=a.accounting_unit_id
and d.office_id=a.accounting_for_office_id 
and e.bank_id=a.bank_id 
and e.branch_id=a.branch_id 
and f.bank_id=e.bank_id 
AND b.account_head_code=g.account_head_code
and a.receipt_status<>'C' 
and a.created_by_module='SC' 
and a.cashbook_year=$P{cashbookyear}::int
and a.cashbook_month=$P{cashbookmonth}::int 
and a.accounting_unit_id=$P{accountingunitid}::int
and a.accounting_for_office_id=$P{accountofficeid}::int



union all


------------ IBT -------------------------
select
     a.voucher_no,
     a.date_of_transfer as trf_date,
     a.FROM_ACCOUNT_NO  as ACCOUNT_NO , 
     a.from_bank_id as b_id,
     a.from_branch_id as br_id,
     (a.dr_account_head_code
    ||'-'
    || g.account_head_desc) AS Acc_details ,
     ' ' as amt_paid_to,
     a.CHEQUE_DD_NO,
     a.CHEQUE_DD_DATE,
     a.total_amount as amount,
     a.particulars,
     '' as transfer_type, 
     c.accounting_unit_name,
     d.office_short_name,
     e.branch_name,
     f.BANK_NAME, 
     e.micr_code 
from 
     fas_inter_bank_trf_at_ho a,
     fas_mst_acct_units c,
     com_mst_offices d,
     fas_mst_bank_branches e,
     com_mst_account_heads g,
     fas_mst_banks f
where 
    c.accounting_unit_id=a.accounting_unit_id
and d.office_id=a.accounting_for_office_id 
and e.bank_id=a.from_bank_id 
and e.branch_id=a.from_branch_id 
and f.bank_id=e.bank_id 
and a.dr_account_head_code=g.account_head_code
and a.transfer_status<>'C' 
and a.cashbook_year=$P{cashbookyear}::int
and a.cashbook_month=$P{cashbookmonth}::int 
and a.accounting_unit_id=$P{accountingunitid}::int
and a.accounting_for_office_id=$P{accountofficeid}::int


union all 


-------------- Fund Transfer from HO ----------------------
Select 
     a.VOUCHER_NO ,
     a.DATE_OF_TRANSFER  as trf_date,
     a.HO_ACCOUNT_NO as ACCOUNT_NO,
     a.HO_BANK_ID   as b_id ,
     a.HO_BRANCH_ID as br_id ,
     (b.account_head_code
    ||'-'
    || g.account_head_desc) AS Acc_details ,
     d1.office_short_name as amt_paid_to ,          
     b.CHEQUE_DD_NO,
     b.CHEQUE_DD_DATE ,
     b.AMOUNT  ,
     b.PARTICULARS ,
     '' as transfer_type, 
     c.accounting_unit_name,
     d.office_short_name,
     e.branch_name,
     f.BANK_NAME, 
     e.micr_code  
from 
     FAS_FUND_TRF_FROM_HO_MASTER   a,
     FAS_FUND_TRF_FROM_HO_TRN   b ,
     fas_mst_acct_units  c,
     com_mst_offices  d,
     com_mst_offices  d1,
     fas_mst_bank_branches  e,
	 com_mst_account_heads g,
     fas_mst_banks  f
where 
           a.cashbook_month     =  b.cashbook_month 
       and a.cashbook_year      =  b.cashbook_year
       and a.accounting_unit_id =  b.accounting_unit_id 
       and a.accounting_for_office_id = b.accounting_for_office_id
       and a.voucher_no         =  b.voucher_no       
       and c.accounting_unit_id =  a.accounting_unit_id
       and d.office_id          =  a.accounting_for_office_id 
       and d1.office_id         =  b.TRANSFER_TO_OFFICE_ID        
       and e.bank_id            =  a.HO_BANK_ID	
       and e.branch_id          =  a.HO_BRANCH_ID	
       and f.bank_id            =  e.bank_id    
	   and b.account_head_code=g.account_head_code	   
       and a.TRANSFER_STATUS <>'C' 
       and a.cashbook_year=$P{cashbookyear}::int
       and a.cashbook_month=$P{cashbookmonth}::int 
       and a.accounting_unit_id=$P{accountingunitid}::int
       and a.accounting_for_office_id=$P{accountofficeid}::int
      
       
       
union all 



---------------------- Fund Transfer from Office  --------------------
Select 
     a.VOUCHER_NO ,
     a.DATE_OF_TRANSFER as trf_date,
     a.OFFICE_ACCOUNT_NO  as ACCOUNT_NO,
     a.OFFICE_BANK_ID as b_id ,
     a.OFFICE_BRANCH_ID ,
	 (a.dr_account_head_code
    ||'-'
    || g.account_head_desc) AS Acc_details ,
     ' '  as paid_to ,
     a.CHEQUE_DD_NO  ,
     a.CHEQUE_DD_DATE  ,
     a.TOTAL_AMOUNT  ,
     a.PARTICULARS ,
 --    decode(a.REMITTANCE_TYPE,'U','Unspent','C','Collection') as transfer_type ,
case 
	when a.REMITTANCE_TYPE = 'U' then 'Unspent'
	when a.REMITTANCE_TYPE = 'C' then 'Collection'
end as transfer_type,

     c.accounting_unit_name,
     d.office_short_name,
     e.branch_name,
     f.BANK_NAME, 
     e.micr_code  
from 
     FAS_FUND_TRF_FROM_OFFICE  a,
     fas_mst_acct_units c,
     com_mst_offices d,
     fas_mst_bank_branches e,
	 com_mst_account_heads g,
     fas_mst_banks f
where
         c.accounting_unit_id=a.accounting_unit_id
     and d.office_id=a.accounting_for_office_id 
     and e.bank_id=a.OFFICE_BANK_ID	
     and e.branch_id=a.OFFICE_BRANCH_ID	
     and f.bank_id=e.bank_id 
	 and a.dr_account_head_code=g.account_head_code
     and a.TRANSFER_STATUS <>'C' 
     and a.cashbook_year=$P{cashbookyear}::int
     and a.cashbook_month=$P{cashbookmonth}::int
     and a.accounting_unit_id=$P{accountingunitid}::int
     and a.accounting_for_office_id=$P{accountofficeid}::int
   
       
      
) as opt2
---$P!{acc_no}
order by b_id,account_no,trf_date,voucher_no]]></queryString>

	<field name="voucher_no" class="java.math.BigDecimal"/>
	<field name="trf_date" class="java.sql.Date"/>
	<field name="account_no" class="java.math.BigDecimal"/>
	<field name="b_id" class="java.math.BigDecimal"/>
	<field name="br_id" class="java.math.BigDecimal"/>
	<field name="Acc_details" class="java.lang.String"/>
	<field name="amt_paid_to" class="java.lang.String"/>
	<field name="cheque_dd_no" class="java.lang.String"/>
	<field name="cheque_dd_date" class="java.sql.Date"/>
	<field name="AMOUNT" class="java.lang.Double"/>
	<field name="particulars" class="java.lang.String"/>
	<field name="transfer_type" class="java.lang.String"/>
	<field name="accounting_unit_name" class="java.lang.String"/>
	<field name="office_short_name" class="java.lang.String"/>
	<field name="branch_name" class="java.lang.String"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="micr_code" class="java.math.BigDecimal"/>

	<variable name="SUM_AMOUNT_1" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="SUM_AMOUNT_2" class="java.lang.Double" resetType="Group" resetGroup="VOUCHER" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="SUM_AMOUNT_3" class="java.lang.Double" resetType="Group" resetGroup="BANK" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>

		<group  name="BANK" isStartNewPage="true" isReprintHeaderOnEachPage="true" >
			<groupExpression><![CDATA[$F{BANK_NAME}]]></groupExpression>
			<groupHeader>
			<band height="20"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="4"
						y="1"
						width="408"
						height="18"
						forecolor="#3366FF"
						key="textField-10"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement>
						<font pdfFontName="Helvetica-Bold" size="12" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{BANK_NAME}]]></textFieldExpression>
				</textField>
			</band>
			</groupHeader>
			<groupFooter>
			<band height="26"  isSplitAllowed="true" >
				<line direction="TopDown">
					<reportElement
						x="0"
						y="7"
						width="847"
						height="1"
						key="line-3"/>
					<graphicElement stretchType="NoStretch"/>
				</line>
				<textField isStretchWithOverflow="true" pattern="##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="685"
						y="8"
						width="91"
						height="18"
						key="textField"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Right">
						<font size="12"/>
					</textElement>
				<textFieldExpression   class="java.lang.Double"><![CDATA[$V{SUM_AMOUNT_3}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement
						x="491"
						y="8"
						width="165"
						height="18"
						key="staticText-26"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Center">
						<font size="12"/>
					</textElement>
				<text><![CDATA[TOTAL AMOUNT]]></text>
				</staticText>
			</band>
			</groupFooter>
		</group>
		<group  name="acc_n" >
			<groupExpression><![CDATA[$F{account_no}]]></groupExpression>
			<groupHeader>
			<band height="20"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="4"
						y="1"
						width="266"
						height="18"
						key="textField"/>
					<box></box>
					<textElement>
						<font pdfFontName="Helvetica-Bold" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$F{account_no}]]></textFieldExpression>
				</textField>
			</band>
			</groupHeader>
			<groupFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<group  name="CHEQUE" >
			<groupExpression><![CDATA[$F{cheque_dd_no}]]></groupExpression>
			<groupHeader>
			<band height="20"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="5"
						y="1"
						width="103"
						height="19"
						key="staticText-15"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font pdfFontName="Helvetica-Bold" size="12" isBold="true"/>
					</textElement>
				<text><![CDATA[Cheque No]]></text>
				</staticText>
				<textField isStretchWithOverflow="false" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="115"
						y="1"
						width="103"
						height="19"
						forecolor="#3366FF"
						key="textField-7"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement verticalAlignment="Middle">
						<font pdfFontName="Helvetica-Bold" size="12" isBold="true" isItalic="false"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{cheque_dd_no}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement
						x="218"
						y="1"
						width="55"
						height="18"
						key="staticText-23"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement>
						<font/>
					</textElement>
				<text><![CDATA[Paid to:]]></text>
				</staticText>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="273"
						y="1"
						width="383"
						height="19"
						forecolor="#3366FF"
						key="textField-8"
						isPrintRepeatedValues="false"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Left" verticalAlignment="Top">
						<font pdfFontName="Helvetica-Bold" size="12" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{amt_paid_to}]]></textFieldExpression>
				</textField>
			</band>
			</groupHeader>
			<groupFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<group  name="VOUCHER" >
			<groupExpression><![CDATA[$F{voucher_no}]]></groupExpression>
			<groupHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupHeader>
			<groupFooter>
			<band height="20"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" pattern="##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="685"
						y="1"
						width="90"
						height="18"
						key="textField-6"
						isPrintRepeatedValues="false"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Right">
						<font size="12"/>
					</textElement>
				<textFieldExpression   class="java.lang.Double"><![CDATA[$V{SUM_AMOUNT_2}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement
						x="501"
						y="1"
						width="165"
						height="18"
						key="staticText-25"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Center">
						<font size="12"/>
					</textElement>
				<text><![CDATA[TOTAL AMOUNT]]></text>
				</staticText>
			</band>
			</groupFooter>
		</group>
		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="1"  isSplitAllowed="true" >
			</band>
		</title>
		<pageHeader>
			<band height="164"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="570"
						y="10"
						width="63"
						height="26"
						key="staticText-2"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font pdfFontName="Helvetica-Bold" isBold="true"/>
					</textElement>
				<text><![CDATA[Print Date:]]></text>
				</staticText>
				<textField isStretchWithOverflow="false" pattern="dd/MM/yyyy" isBlankWhenNull="false" evaluationTime="Report" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
