	<field name="micr_code" class="java.lang.String"/>

	<variable name="SUM_AMOUNT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_AMOUNT_2" class="java.math.BigDecimal" resetType="Group" resetGroup="VOUCHER" calculation="Sum">
		<variableExpression><![CDATA[$F{AMT}]]></variableExpression>
	</variable>
	<variable name="sumamount" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMT}]]></variableExpression>
	</variable>
	<variable name="counting" class="java.lang.Integer" resetType="None" calculation="DistinctCount">
		<variableExpression><![CDATA[$F{cheque_dd_no}]]></variableExpression>
	</variable>
	<variable name="total_amount" class="java.math.BigDecimal" resetType="Group" resetGroup="CHEQUE" calculation="Sum">
		<variableExpression><![CDATA[$F{AMT}]]></variableExpression>
	</variable>

