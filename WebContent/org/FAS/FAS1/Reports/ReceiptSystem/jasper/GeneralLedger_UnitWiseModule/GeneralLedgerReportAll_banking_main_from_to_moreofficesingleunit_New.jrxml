<jasperReport
		 name="GeneralLedgerReportAll_banking_main_from_to_moreofficesingleunit_New"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="567"
		 columnSpacing="0"
		 leftMargin="14"
