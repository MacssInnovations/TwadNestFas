	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue_from" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue_to" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT a.CR_DR_INDICATOR,
  a.RECEIPT_NO,
  a.AMOUNT,
  a.CR_AMOUNT,
  a.DR_AMOUNT,
  a.TYPE,
  TO_CHAR(a.DATE_G,'DD-MM-YYYY') AS gl_date ,
  a.PARTICULARS,
  a.MONTH_OPENING_BALANCE,
  a.MONTH_OPENING_CR_DR_IND,
  a.ACCOUNT_HEAD_CODE,
  a.MONTH,
  a.DOCTYPE,
  a.YEAR,
  a.ACCOUNTING_UNIT_ID,
  a.ACCOUNTING_FOR_OFFICE_ID,
  a.CASHBOOK_YEAR,
  a.CASHBOOK_MONTH ,
  a.MONTH_IN_WORDS,
  accunit.accounting_unit_name,
  office.office_name,
  acc.account_head_desc
FROM GENERAL_LEDGER_REPORT_TMP_CP a ,
  FAS_MST_ACCT_UNITS accunit,
  COM_MST_OFFICES office ,
  COM_MST_ACCOUNT_HEADS acc
WHERE 
to_date(a.cashbook_month||'-'||a.cashbook_year,'mm-yyyy') between  to_date(1||'-'||2011,'mm-yyyy') and 
to_date(1||'-'||2012,'mm-yyyy')  
 AND  
 (a.accounting_for_office_id IN
  (SELECT ACCOUNTING_FOR_OFFICE_ID
  FROM FAS_MST_ACCT_UNIT_OFFICES
  WHERE accounting_unit_id=a.ACCOUNTING_UNIT_ID
  )
or 
  a.accounting_for_office_id IN
      (
      select OFFICE_OLD_CODE from COM_MST_OFFICES where OFFICE_ID in (
      SELECT ACCOUNTING_FOR_OFFICE_ID
      FROM FAS_MST_ACCT_UNIT_OFFICES
      WHERE accounting_unit_id=a.ACCOUNTING_UNIT_ID
      )
)
)
AND office.office_id IN
  (SELECT ACCOUNTING_FOR_OFFICE_ID
  FROM fas_mst_acct_unit_offices
  WHERE accounting_unit_id=a.ACCOUNTING_UNIT_ID
  )
AND accunit.accounting_unit_id=a.ACCOUNTING_UNIT_ID
AND acc.account_head_code     = a.account_head_code
ORDER BY a.cashbook_year,
  a.cashbook_month ,
  a.ACCOUNT_HEAD_CODE,
  gl_date
]]></queryString>

