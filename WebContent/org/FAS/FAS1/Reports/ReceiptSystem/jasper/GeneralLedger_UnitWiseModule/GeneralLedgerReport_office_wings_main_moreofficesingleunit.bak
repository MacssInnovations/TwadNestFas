<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GeneralLedgerReport_office_wings_main_moreofficesingleunit"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="821"
		 pageHeight="842"
		 columnWidth="761"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[-- Single Month + Single Account Head +  Offices
-- 1. Receipt Master and Transaction , CR Heads
-- 2. Journal Master and Transaction , CR Heads , GJV and LJV
-- 3. Journal Master and Transaction, DR Heads , GJV and LJV
-- 4. Payment Master and Transaction , DR Heads
-- 5. Recipt Master , DR Heads
-- 6. Payment Master , CR Heads
-- 7. Fund Receipt By HO , CR Heads -- Commented
-- 8. Fund Receipt By Ho , DR Heads -- Commented
-- 9. Fund Transfer from HO master and Transaciton , CR heads
-- 10. Fund Transfer from HO Master
-- 11. Fund Receipt by Office , CR heads
-- 12. Fund Receipt By Office , DR Heads
-- 13. IBT , CR heads
-- 14. IBT , DR Heads
SELECT  glt.accounting_for_office_id,
  glt.Accounting_Unit_Id,
  (SELECT ACCOUNTING_UNIT_NAME
  FROM FAS_MST_ACCT_UNITS
  WHERE ACCOUNTING_UNIT_ID=glt.Accounting_Unit_Id
  )AS acc_unit_name,
  (SELECT OFFICE_NAME
  FROM COM_MST_OFFICES
  WHERE office_id=glt.accounting_for_office_id
  ) AS off_name,
  cramt,
  dramt,
  ind,
  recpno ,
  amt,
  doctype,
  type1,
  date1,
  particul,
  --  glt.account_head_code
  (
  SELECT ACCOUNT_HEAD_DESC
  FROM com_mst_account_heads
  WHERE ACCOUNT_HEAD_CODE=glt.account_head_code
  )                                  AS ACCOUNT_HEAD_DESC,
  TO_CHAR(glt.month_opening_balance) AS monthopen,
  glt.month_opening_bal_dr_cr_ind    AS monthind ,
  TO_CHAR(glt.month_closing_balance) AS monthclose,
  glt.MONTH_CLOSING_BAL_DR_CR_IND    AS monthind_close,
  sl_type_code ,
  (SELECT sub_ledger_type_desc
  FROM com_mst_sl_types
  WHERE sub_ledger_type_code = sl_type_code
  ) AS sl_type_code_desc,
  Sl_Code,
  -- Supplier 1f
  CASE
    WHEN sl_type_code = 1
    THEN
      (SELECT SUPPLIER_NAME
      FROM COM_SUPPLIER_SL_MST
      WHERE accounting_unit_id      =$P{accountingunitid}
      AND ACCOUNTING_FOR_OFFICE_ID IN
        (SELECT ACCOUNTING_FOR_OFFICE_ID
        FROM FAS_MST_ACCT_UNIT_OFFICES
        WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
        )
      AND supplier_id = sl_code
      )
    ELSE ( --- Firms 2
      CASE
        WHEN sl_type_code = 2
        THEN
          (SELECT FIRMS_NAME
          FROM COM_FIRMS_SL_MST
          WHERE accounting_unit_id      =$P{accountingunitid}
          AND ACCOUNTING_FOR_OFFICE_ID IN
            (SELECT ACCOUNTING_FOR_OFFICE_ID
            FROM FAS_MST_ACCT_UNIT_OFFICES
            WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
            )
          AND firms_id =sl_code
          )
        ELSE ( --- Assests 3
          CASE
            WHEN sl_type_code=3
            THEN
              (SELECT ASSET_DESCRIPTION
              FROM COM_MST_ASSETS_SL
              WHERE accounting_unit_id      =$P{accountingunitid}
              AND ACCOUNTING_FOR_OFFICE_ID IN
                (SELECT ACCOUNTING_FOR_OFFICE_ID
                FROM FAS_MST_ACCT_UNIT_OFFICES
                WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
                )
              AND asset_code = sl_code
              )
            ELSE ( --- Offices 5
              CASE
                WHEN sl_type_code = 5
                THEN
                  (SELECT OFFICE_NAME
                  FROM COM_MST_OFFICES
                  WHERE OFFICE_ID=sl_code
                  )
                ELSE ( -- Bank 6
                  CASE
                    WHEN sl_type_code = 6
                    THEN
                      (SELECT TO_CHAR(bank_ac_no)
                      FROM fas_mst_bank_balance
                      WHERE ACCOUNTING_UNIT_ID  =$P{accountingunitid}
                      AND BANK_AC_NO_ALIAS_CODE = sl_code
                      )
                    ELSE ( -- Employees 7
                      CASE
                        WHEN sl_type_code= 7
                        THEN
                          (SELECT e.EMPLOYEE_NAME
                            ||'.'
                            ||e.EMPLOYEE_INITIAL
                            ||'-'
                            || d.DESIGNATION AS ENAME
                          FROM HRM_MST_EMPLOYEES e,
                            HRM_EMP_CURRENT_POSTING c,
                            HRM_MST_DESIGNATIONS d
                          WHERE c.DESIGNATION_ID=d.DESIGNATION_ID
                          AND c.EMPLOYEE_ID     =e.EMPLOYEE_ID
                          AND c.OFFICE_ID      IN
                            (SELECT ACCOUNTING_FOR_OFFICE_ID
                            FROM FAS_MST_ACCT_UNIT_OFFICES
                            WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
                            )
                          AND e.EMPLOYEE_ID =sl_code
                          )
                        ELSE (
                          -- OTHER DEPARTMENTS
                          CASE
                            WHEN sl_type_code= 9
                            THEN
                              (SELECT dep.OTHER_DEPT_NAME
                                || '-'
                                || off.OTHER_DEPT_OFFICE_NAME AS OTHER_DEPT_OFF_NAME
                              FROM HRM_MST_OTHER_DEPTS dep,
                                HRM_MST_OTHER_DEPT_OFFICES OFF
                              WHERE dep.OTHER_DEPT_ID           =off.OTHER_DEPT_ID
                              AND off.other_dept_office_alias_id= sl_code
                              )
                            ELSE (
                              -- PROJECT
                              CASE
                                WHEN sl_type_code=10
                                THEN
                                  (SELECT PROJECT_NAME
                                  FROM pms_mst_projects_view
                                  WHERE OFFICE_ID IN
                                    (SELECT ACCOUNTING_FOR_OFFICE_ID
                                    FROM FAS_MST_ACCT_UNIT_OFFICES
                                    WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
                                    )
                                  AND PROJECT_ID = sl_code
                                  )
                                ELSE (
                                  -- CONTRACTORS
                                  CASE
                                    WHEN sl_type_code=11
                                    THEN
                                      (SELECT CONTRACTOR_NAME
                                      FROM pms_mst_contractors_view
                                      WHERE (OFFICE_ID IN
                                        (SELECT ACCOUNTING_FOR_OFFICE_ID
                                        FROM FAS_MST_ACCT_UNIT_OFFICES
                                        WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
                                        )
                                      OR OFFICE_ID IN
                                        (SELECT REGION_OFFICE_ID
                                        FROM com_mst_all_offices_view
                                        WHERE office_id IN
                                          (SELECT ACCOUNTING_FOR_OFFICE_ID
                                          FROM FAS_MST_ACCT_UNIT_OFFICES
                                          WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
                                          )
                                        UNION ALL
                                        SELECT CIRCLE_OFFICE_ID
                                        FROM com_mst_all_offices_view
                                        WHERE office_id IN
                                          (SELECT ACCOUNTING_FOR_OFFICE_ID
                                          FROM FAS_MST_ACCT_UNIT_OFFICES
                                          WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
                                          )
                                        ))
                                      AND CONTRACTOR_ID= sl_code
                                      )
                                  END )
                              END )
                          END )
                      END )
                  END )
              END )
          END )
      END )
  END AS sl_code_name
FROM
  (
  -- 1. Receipt Master and Transaction , CR Heads
  SELECT a.account_head_code AS acchead,
    a.cr_dr_indicator        AS ind,
    a.receipt_no             AS recpno ,
    TO_CHAR(A.AMOUNT)        AS AMT,
    --a.amount                 AS cramt,
    --0                        AS dramt,
    CASE
    	WHEN a.cr_dr_indicator = 'DR'
    	THEN a.amount
    	ELSE 0
    	END AS dramt,
   	 CASE
    	WHEN a.cr_dr_indicator = 'CR'
    	THEN a.amount
    	ELSE 0
    	END      AS cramt,
    'R'                      AS doctype,
    NULL                     AS type1,
    b.receipt_date           AS date1,
    a.particulars            AS particul,
    a.SUB_LEDGER_TYPE_CODE   AS sl_type_code,
    A.Sub_Ledger_Code        AS Sl_Code,
    A.Accounting_Unit_Id,
    a.accounting_for_office_id,
    A.Cashbook_Year,
    a.cashbook_month
  FROM fas_receipt_transaction a,
    fas_receipt_master b
  WHERE a.accounting_unit_id      =b.accounting_unit_id
  AND a.cashbook_year             =b.cashbook_year
  AND a.cashbook_month            =b.cashbook_month
  AND a.receipt_no                =b.receipt_no
  AND a.accounting_for_office_id  =b.ACCOUNTING_FOR_OFFICE_ID
  AND b.receipt_status           <>'C'
  AND a.accounting_unit_id        =$P{accountingunitid}
  AND a.accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
    )
  AND a.cashbook_year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND A.CASHBOOK_MONTH BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
  --AND a.cr_dr_indicator  ='CR'
  AND a.account_head_code= ($P{accountheadcode})
UNION ALL

SELECT distinct b.account_head_code AS acchead,
    b.cr_dr_indicator        AS ind,
    b.receipt_no             AS recpno ,
    TO_CHAR(b.TOTAL_AMOUNT)        AS AMT,
    --a.amount                 AS cramt,
    --0                        AS dramt,
    CASE
    	WHEN b.cr_dr_indicator = 'DR'
    	THEN b.TOTAL_AMOUNT
    	ELSE 0
    	END AS dramt,
   	 CASE
    	WHEN b.cr_dr_indicator = 'CR'
    	THEN b.TOTAL_AMOUNT
    	ELSE 0
    	END      AS cramt,
    'R'                      AS doctype,
    NULL                     AS type1,
    b.receipt_date           as date1,
    b.remarks                AS particul,
    b.SUB_LEDGER_TYPE_CODE   AS sl_type_code,
    b.Sub_Ledger_Code        AS Sl_Code,
    b.Accounting_Unit_Id,
    b.accounting_for_office_id,
    b.Cashbook_Year,
    b.cashbook_month
  FROM fas_receipt_transaction a,
    fas_receipt_master b
  WHERE a.accounting_unit_id      =b.accounting_unit_id
  AND a.cashbook_year             =b.cashbook_year
  AND a.cashbook_month            =b.cashbook_month
  AND a.receipt_no                =b.receipt_no
  AND a.accounting_for_office_id  =b.ACCOUNTING_FOR_OFFICE_ID
  AND b.receipt_status           <>'C'
  AND b.accounting_unit_id        =$P{accountingunitid}
  AND b.accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
    )
  AND b.cashbook_year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND b.CASHBOOK_MONTH BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
  --AND a.cr_dr_indicator  ='CR'
  AND b.account_head_code= ($P{accountheadcode})

  UNION ALL
  -- 2. Journal Master and Transaction , CR Heads , GJV and LJV
  SELECT a.account_head_code AS acchead,
    a.cr_dr_indicator        AS ind,
    a.voucher_no             AS recpno,
    TO_CHAR(A.AMOUNT)        AS AMT,
    --a.amount                 AS cramt,
    --0                        AS dramt,
    CASE
    	WHEN a.cr_dr_indicator = 'DR'
    	THEN a.amount
    	ELSE 0
    	END AS dramt,
   	 CASE
    	WHEN a.cr_dr_indicator = 'CR'
    	THEN a.amount
    	ELSE 0
    	END      AS cramt,
    'J'                      AS doctype,
    b.journal_type_code      AS type1,
    b.voucher_date           AS date1,
    a.particulars            AS particul,
    a.SUB_LEDGER_TYPE_CODE   AS sl_type_code,
    A.Sub_Ledger_Code        AS Sl_Code,
    A.Accounting_Unit_Id,
    a.accounting_for_office_id,
    A.Cashbook_Year,
    a.cashbook_month
  FROM fas_journal_transaction a,
    fas_journal_master b
  WHERE a.accounting_unit_id      =b.accounting_unit_id
  AND a.cashbook_year             =b.cashbook_year
  AND a.cashbook_month            =b.cashbook_month
  AND a.voucher_no                =b.voucher_no
  AND a.accounting_for_office_id  =b.ACCOUNTING_FOR_OFFICE_ID
  AND b.journal_status           <>'C'
  AND a.accounting_unit_id        =$P{accountingunitid}
  AND a.accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
    )
  AND a.cashbook_year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND a.cashbook_month BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
  AND A.ACCOUNT_HEAD_CODE  =$P{accountheadcode}
  --AND a.cr_dr_indicator    ='CR'
  AND b.created_by_module IN ('GJV','LJV')
 
  UNION ALL
  -- 4. Payment Master and Transaction , DR Heads
  SELECT a.account_head_code AS acchead,
    a.cr_dr_indicator        AS ind,
    a.voucher_no             AS recpno,
    TO_CHAR(A.AMOUNT)        AS AMT,
    --0                        AS cramt,
    --a.amount                 AS dramt,
    CASE
    	WHEN a.cr_dr_indicator = 'DR'
    	THEN a.amount
    	ELSE 0
    	END AS dramt,
   	 CASE
    	WHEN a.cr_dr_indicator = 'CR'
    	THEN a.amount
    	ELSE 0
    	END      AS cramt,
    'P'                      AS doctype,
    NULL                     AS type1,
    b.payment_date           AS date1,
    a.particulars            AS particul,
    a.SUB_LEDGER_TYPE_CODE   AS sl_type_code,
    A.Sub_Ledger_Code        AS Sl_Code,
    A.Accounting_Unit_Id,
    a.accounting_for_office_id,
    A.Cashbook_Year,
    a.cashbook_month
  FROM fas_payment_transaction a,
    fas_payment_master b
  WHERE a.accounting_unit_id      =b.accounting_unit_id
  AND a.cashbook_year             =b.cashbook_year
  AND a.cashbook_month            =b.cashbook_month
  AND a.voucher_no                =b.voucher_no
  AND a.accounting_for_office_id  =b.ACCOUNTING_FOR_OFFICE_ID
  AND b.payment_status           <>'C'
  AND a.accounting_unit_id        =$P{accountingunitid}
  AND a.accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
    )
  AND a.cashbook_year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND A.CASHBOOK_MONTH BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
  --AND a.cr_dr_indicator   ='DR'
  AND a.account_head_code =$P{accountheadcode}
 UNION ALL

SELECT distinct b.account_head_code AS acchead,
    b.cr_dr_indicator        AS ind,
    b.voucher_no             AS recpno,
    TO_CHAR(b.TOTAL_AMOUNT)        AS AMT,
    --0                        AS cramt,
    --a.amount                 AS dramt,
    CASE
    	WHEN b.cr_dr_indicator = 'DR'
    	THEN b.TOTAL_AMOUNT
    	ELSE 0
    	END AS dramt,
   	 CASE
    	WHEN b.cr_dr_indicator = 'CR'
    	THEN b.TOTAL_AMOUNT
    	ELSE 0
    	END      AS cramt,
    'P'                      AS doctype,
    NULL                     AS type1,
    b.payment_date           AS date1,
    b.remarks                AS particul,
    b.SUB_LEDGER_TYPE_CODE   AS sl_type_code,
    b.Sub_Ledger_Code        AS Sl_Code,
    b.Accounting_Unit_Id,
    b.accounting_for_office_id,
    b.Cashbook_Year,
    b.cashbook_month
  FROM fas_payment_transaction a,
    fas_payment_master b
  WHERE a.accounting_unit_id      =b.accounting_unit_id
  AND a.cashbook_year             =b.cashbook_year
  AND a.cashbook_month            =b.cashbook_month
  AND a.voucher_no                =b.voucher_no
  AND a.accounting_for_office_id  =b.ACCOUNTING_FOR_OFFICE_ID
  AND b.payment_status           <>'C'
  AND b.accounting_unit_id        =$P{accountingunitid}
  AND b.accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
    )
  AND b.cashbook_year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND b.CASHBOOK_MONTH BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
  --AND a.cr_dr_indicator   ='DR'
  AND b.account_head_code =$P{accountheadcode}

  UNION ALL
  -- 11. Fund Receipt by Office , CR heads
  SELECT cr_account_head_code AS acchead,
    'CR'                      AS ind,
    receipt_no                AS recpno,
    TO_CHAR(TOTAL_AMOUNT)     AS amt,
    0                         AS dramt,
    total_amount              AS cramt,    
    'FR'                      AS doctype,
    NULL                      AS type1,
    receipt_date              AS date1,
    PARTICULARS               AS particul ,
    0                         AS sl_type_code,
    0                         AS Sl_Code,
    Accounting_Unit_Id,
    accounting_for_office_id,
    Cashbook_Year,
    cashbook_month
  FROM FAS_FUND_RECEIPT_BY_OFFICE
  WHERE receipt_status         <>'C'
  AND accounting_unit_id        =$P{accountingunitid}
  AND accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
    )
  AND cashbook_year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND cashbook_month BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
  AND cr_account_head_code =$P{accountheadcode}
  UNION ALL
  --12.  Fund Receipt By Office , DR Heads
  SELECT dr_account_head_code AS acchead,
    'DR'                      AS ind,
    receipt_no                AS recpno,
    TO_CHAR(TOTAL_AMOUNT)     AS amt,
    total_amount              AS dramt,
    0                         AS cramt,    
    'FR'                      AS doctype,
    NULL                      AS type1,
    receipt_date              AS date1,
    PARTICULARS               AS particul ,
    0                         AS sl_type_code,
    0                         AS Sl_Code,
    Accounting_Unit_Id,
    accounting_for_office_id,
    Cashbook_Year,
    cashbook_month
  FROM FAS_FUND_RECEIPT_BY_OFFICE
  WHERE receipt_status         <>'C'
  AND accounting_unit_id        =$P{accountingunitid}
  AND accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
    )
  AND cashbook_year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND cashbook_month BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
  AND DR_ACCOUNT_HEAD_CODE =$P{accountheadcode}
 UNION ALL
 SELECT cr_account_head_code AS acchead,
    'CR'                      AS ind,
    voucher_no                AS recpno,
    TO_CHAR(TOTAL_AMOUNT)     AS amt,    
    0                         AS dramt,
    total_amount              AS cramt,
    'FT'                      AS doctype,
    NULL                      AS type1,
    DATE_OF_TRANSFER          AS date1,
    PARTICULARS               AS particul,
    0                         AS sl_type_code,
    0                         AS sl_code,
    Accounting_Unit_Id,
    accounting_for_office_id,
    CASHBOOK_YEAR,
    cashbook_month
  FROM FAS_FUND_TRF_FROM_OFFICE
  WHERE transfer_status        <>'C'
  AND accounting_unit_id        = ($P{accountingunitid})
  AND accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE accounting_unit_id=$P{accountingunitid}
    )
  AND cashbook_year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND CASHBOOK_MONTH BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
  AND cr_account_head_code =$P{accountheadcode}
  UNION ALL
  -- 10. Fund Transfer from Office , DR Heads
  SELECT dr_account_head_code AS acchead,
    'DR'                      AS ind,
    voucher_no                AS recpno,
    TO_CHAR(TOTAL_AMOUNT)     AS amt,    
    TOTAL_AMOUNT              AS dramt,
    0                         AS cramt,
    'FT'                      AS doctype,
    NULL                      AS type1,
    DATE_OF_TRANSFER          AS date1,
    PARTICULARS               AS particul,
    0                         AS sl_type_code,
    0                         AS sl_code,
    Accounting_Unit_Id,
    accounting_for_office_id,
    CASHBOOK_YEAR,
    cashbook_month
  FROM FAS_FUND_TRF_FROM_OFFICE
  WHERE transfer_status        <>'C'
  AND accounting_unit_id        = ($P{accountingunitid})
  AND accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE accounting_unit_id=$P{accountingunitid}
    )
  AND CASHBOOK_YEAR BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND CASHBOOK_MONTH BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})   
  AND dr_account_head_code =$P{accountheadcode}
  UNION ALL
  -- 13. IBT , CR heads
  SELECT cr_account_head_code AS acchead,
    'CR' ind,
    voucher_no            AS recpno,
    TO_CHAR(TOTAL_AMOUNT) AS amt,
    0                     AS dramt,
    total_amount          AS cramt,    
    'IBT'                 AS doctype,
    NULL                  AS type1,
    date_of_transfer      AS date1,
    particulars           AS particul,
    0                     AS sl_type_code,
    0                     AS Sl_Code,
    Accounting_Unit_Id,
    accounting_for_office_id,
    Cashbook_Year,
    cashbook_month
  FROM fas_inter_bank_trf_at_ho
  WHERE transfer_status        <>'C'
  AND accounting_unit_id        = $P{accountingunitid}
  AND accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
    )
  AND cashbook_year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND cashbook_month BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
  AND cr_account_head_code =$P{accountheadcode}
  UNION ALL
  -- 14. IBT DR Heads
  SELECT dr_account_head_code AS acchead,
    'DR' ind,
    voucher_no            AS recpno,
    TO_CHAR(TOTAL_AMOUNT) AS amt,
    total_amount          AS dramt,
    0                     AS cramt,    
    'IBT'                 AS doctype,
    NULL                  AS type1,
    date_of_transfer      AS date1,
    particulars           AS particul ,
    0                     AS sl_type_code,
    0                     AS Sl_Code,
    Accounting_Unit_Id,
    accounting_for_office_id,
    Cashbook_Year,
    cashbook_month
  FROM fas_inter_bank_trf_at_ho
  WHERE transfer_status        <>'C'
  AND accounting_unit_id        = $P{accountingunitid}
  AND accounting_for_office_id IN
    (SELECT ACCOUNTING_FOR_OFFICE_ID
    FROM FAS_MST_ACCT_UNIT_OFFICES
    WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
    )
  AND cashbook_year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
  AND cashbook_month BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
  AND Dr_Account_Head_Code =$P{accountheadcode}
  ),
  fas_general_ledger glt
WHERE Acchead =Glt.Account_Head_Code
  --And Accounting_Unit_Id                      =Glt.Accounting_Unit_Id
AND Cashbook_Year                 =Glt.Year
AND cashbook_month                =Glt.month
AND Glt.Accounting_Unit_Id        =$P{accountingunitid}
AND Glt.Account_Head_Code         =$P{accountheadcode}
AND glt.accounting_for_office_id IN
  (SELECT ACCOUNTING_FOR_OFFICE_ID
  FROM FAS_MST_ACCT_UNIT_OFFICES
  WHERE ACCOUNTING_UNIT_ID=$P{accountingunitid}
  )
  --AND glt.accounting_for_office_id=6896
AND glt.year BETWEEN ($P{cashbookyear}) AND ($P{cashbookyear})
AND glt.month BETWEEN ($P{cashbookmonth}) AND ($P{cashbookmonth})
ORDER BY off_name,
doctype,
  recpno,
  date1]]></queryString>

