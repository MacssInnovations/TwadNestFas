	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
      a.ACCOUNTING_UNIT_ID,
      b.ACCOUNTING_UNIT_OFFICE_ID,
      b.ACCOUNTING_UNIT_NAME,
      a.UPDATED_BY_USER_ID,
      a.TB_UNFREEZE_DATE
from 
      FAS_TRIAL_BALANCE_LOG a,
      FAS_MST_ACCT_UNITS b
where
      a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID and      
      CASHBOOK_YEAR=$P{cashbookyear} and
      CASHBOOK_MONTH=$P{cashbookmonth} and
      TB_UNFREEZE_DATE is not null and
      ACCOUNTING_UNIT_OFFICE_ID in
      (
		$P!{officeid}       
      )
order by
	a.ACCOUNTING_UNIT_ID]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="TB_UNFREEZE_DATE" class="java.sql.Timestamp"/>
	<field name="UPDATED_BY_USER_ID" class="java.lang.String"/>

