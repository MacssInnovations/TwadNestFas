<jasperReport
		 name="TrialBalance_1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1045"
		 pageHeight="831"
		 columnWidth="985"
		 columnSpacing="0"
		 leftMargin="30"
