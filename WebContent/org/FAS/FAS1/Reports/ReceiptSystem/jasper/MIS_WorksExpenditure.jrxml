<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="MIS_WorksExpenditure"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="financial_year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthinwords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="from_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select works_group_description,program_description,scheme_description,works_scheme_id,order1,order2,order3,
       sum(cr_funds_from_year) as cr_amt_yr,
       sum(dr_funds_from_month)as dr_amt_mon,
       sum(dr_funds_from_year)as dr_amt_yr
from
(
  select works_group_description,program_description,scheme_description,works_scheme_id,fas_ac_head_code,order1,order2,order3,cashbook_month,cashbook_year,
         sum(current_month_credit) as cr_funds_from_year,
         case when (to_date(cashbook_month ||'-'|| + cashbook_year, 'mm-yyyy')=to_date( $P{to_cashbookmonth}   || '-' || $P{to_cashbookyear} ,   'mm-yyyy')) then
            sum(current_month_debit)
         else 0 end as dr_funds_from_month,
         sum(current_month_debit) as dr_funds_from_year
  from
  (
    select a.works_scheme_id,
         b.works_program_id,
         c.works_group_id,
         works_group_description,
         program_description,
         scheme_description,
         fas_ac_head_code,
         d.order_no as order1,c.order_no as order2,b.order_no as order3
    from
         mis_fas_heads_schemes a,
         mis_works_schemes b,
         mis_works_program c,
         mis_works_group d
    where
         a.works_scheme_id=b.works_schemes_id and
         b.works_program_id=c.works_program_id and
         c.works_group_id=d.works_group_id and
         a.process_flag!='DELETED' and
         b.process_flag!='DELETED' and
         c.process_flag!='DELETED' and
         d.process_flag!='DELETED'
  )a,
  fas_trial_balance b
  where 
      a.fas_ac_head_code=b.account_head_code and
      to_date(cashbook_month ||'-'|| + cashbook_year, 'mm-yyyy') BETWEEN to_date(  $P{from_cashbookmonth}  || '-' || $P{from_cashbookyear} ,   'mm-yyyy')  AND to_date( $P{to_cashbookmonth} ||'-' || $P{to_cashbookyear} , 'mm-yyyy')
  group by
      works_group_description,program_description,scheme_description,works_scheme_id,fas_ac_head_code,cashbook_month,cashbook_year,order1,order2,order3
)
group by
      works_group_description,program_description,scheme_description,works_scheme_id,order1,order2,order3
order by order1,order2,order3,works_group_description,program_description]]></queryString>

