	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="regionid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="supplementno" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 

  a.ACCOUNTING_UNIT_ID, 
  a.ACCOUNTING_UNIT_OFFICE_ID, 
  a.ACCOUNTING_UNIT_NAME 
  
from 

  FAS_MST_ACCT_UNITS a 
  
where 

 a.ACCOUNTING_UNIT_OFFICE_ID in 
 (
    select 
       b.office_id
    from 
       com_mst_offices b 
    where office_status_id not in ('CL','RD','NC')
       
  )and 
  
  a.ACCOUNTING_UNIT_ID not in 
  (
    select 
        c.ACCOUNTING_UNIT_ID 
    from 
        FAS_TRIAL_BALANCE_STATUS_SJV c 
    where 
        c.CASHBOOK_MONTH=$P{cashbookmonth} and 
        c.cashbook_year=$P{cashbookyear} and 
        c.supplement_no = $P{supplementno} 
        
   )   
and a.ACCOUNTING_UNIT_ID!=888
order by a.ACCOUNTING_UNIT_ID]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>

