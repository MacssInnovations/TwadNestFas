	<field name="cheque_or_dd" class="java.lang.String"/>
	<field name="cheque_dd_no" class="java.lang.String"/>
	<field name="cheque_dd_date" class="java.sql.Date"/>

	<variable name="SUM_UNSPENT_AMOUNT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{unspent_amount}]]></variableExpression>
	</variable>
	<variable name="SUM_COLLECTION_AMOUNT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{collection_amount}]]></variableExpression>
	</variable>
	<variable name="SUM_TOTAL_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
