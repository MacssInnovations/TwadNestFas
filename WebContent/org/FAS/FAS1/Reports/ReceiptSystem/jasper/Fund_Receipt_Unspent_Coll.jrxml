<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Fund_Receipt_Unspent_Coll"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="595"
		 columnWidth="818"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="bank_id" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT accounting_unit_id,
  accounting_for_office_id,
  cashbook_year,
  cashbook_month,
  received_from_office_id,
  office_bank_id,
  bank_name,
  acct_unit_id,
  acct_for_office_id,
  ACCT_UNIT_NAME,
  SUM(UNSPENT_AMOUNT)                          AS UNSPENT_AMOUNT ,
  SUM(COLLECTION_AMOUNT)                       AS COLLECTION_AMOUNT,
  SUM(OTHER)                                   AS OTHER,
  (SUM(unspent_amount)+SUM(collection_amount)+SUM(OTHER)) AS total,
  cheque_or_dd,
  cheque_dd_no,
  cheque_dd_date
FROM
  (SELECT accounting_unit_id,
    accounting_for_office_id,
    cashbook_year,
    cashbook_month,
    received_from_office_id,
    office_bank_id,
    acct_unit_id,
    ACCT_FOR_OFFICE_ID,
    acct_unit_name,
    receipt_type,
 --SUM(DECODE(trim(receipt_type),'U',amount,0)) AS unspent_amount,
   case when trim(receipt_type)='U'then sum(amount) else 0 end as unspent_amount,
   -- SUM(DECODE(TRIM(RECEIPT_TYPE),'C',AMOUNT,0)) AS COLLECTION_AMOUNT,
   case when trim (receipt_type)='C'then sum(amount) else 0 end as COLLECTION_AMOUNT,
    CASE
      WHEN TRIM(RECEIPT_TYPE) NOT LIKE 'U'
      AND TRIM(RECEIPT_TYPE) NOT LIKE 'C'
      THEN AMOUNT
      ELSE 0
    END AS OTHER,
    CASE
      WHEN TRIM(RECEIPT_TYPE) LIKE 'U'
      THEN 'U'
      WHEN TRIM(RECEIPT_TYPE) LIKE 'C'
      THEN 'C'
      ELSE 'O'
    END AS type,
    cheque_or_dd,
    cheque_dd_no,
    cheque_dd_date
  FROM
    (SELECT accounting_unit_id,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      received_from_office_id,
      receipt_type,
      office_bank_id,
      acct_unit_id,
      acct_for_office_id,
      acct_unit_name,
      SUM(total_amount) AS amount,
      cheque_or_dd,
      cheque_dd_no,
      cheque_dd_date
    FROM
      (SELECT accounting_unit_id,
        accounting_for_office_id,
        cashbook_year,
        cashbook_month,
        received_from_office_id,
        receipt_type,
        office_bank_id,
             -- DECODEcoalesce(other_acct_unit_id1,'',other_acct_unit_id,other_acct_unit_id1)   AS acct_unit_id,
	   case when other_acct_unit_id1=0 then other_acct_unit_id else other_acct_unit_id1 end as acct_unit_id,
      --  DECODE(acc_unit_id1,'',acc_unit_id,acc_unit_id1)                        AS acct_for_office_id,
	   case when acc_unit_id1=0 then acc_unit_id else acc_unit_id1 end as acct_for_office_id,
       -- DECODE(acc_unit_office_id1,'',accounting_unit_name,acc_unit_office_id1) AS acct_unit_name,
  		case when acc_unit_office_id1='' then accounting_unit_name else acc_unit_office_id1 end as acct_unit_name,
        total_amount,
        cheque_or_dd,
        cheque_dd_no,
        cheque_dd_date
      FROM
        (SELECT *
        FROM
          (SELECT accounting_unit_id,
            accounting_for_office_id,
            cashbook_year,
            cashbook_month,
            received_from_office_id,
            receipt_type,
            office_bank_id,
            receipt_status,
            total_amount,
            received_from_ho_unit_id,
            cheque_or_dd,
            cheque_dd_no,
            cheque_dd_date
          FROM fas_fund_receipt_by_ho
          WHERE receipt_status='L'
          ) a
        LEFT OUTER JOIN
          (SELECT accounting_unit_id  AS other_acct_unit_id,
            accounting_unit_office_id AS acc_unit_id,
            accounting_unit_name
          FROM fas_mst_acct_units
          ) b
        ON a.received_from_office_id  =b.acc_unit_id
        AND a.received_from_ho_unit_id=b.other_acct_unit_id
        ) xx
      LEFT OUTER JOIN
        (SELECT accounting_unit_id  AS other_acct_unit_id1,
          accounting_unit_office_id AS acc_unit_id1,
          accounting_unit_name      AS acc_unit_office_id1
        FROM fas_mst_acct_units
        WHERE accounting_unit_office_id NOT IN (5000)
        ) c
      ON xx.received_from_office_id=c.acc_unit_id1
      ) yy
    GROUP BY accounting_unit_id,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      received_from_office_id,
      receipt_type,
      office_bank_id,
      acct_unit_id,
      acct_for_office_id,
      acct_unit_name,
      cheque_or_dd,
      cheque_dd_no,
      cheque_dd_date
    ) zz
  GROUP BY accounting_unit_id,
    accounting_for_office_id,
    cashbook_year,
    cashbook_month,
    received_from_office_id,
    office_bank_id,
    acct_unit_id,
    ACCT_FOR_OFFICE_ID,
    acct_unit_name,
    receipt_type,
    CASE
      WHEN TRIM(RECEIPT_TYPE) NOT LIKE 'U'
      AND TRIM(RECEIPT_TYPE) NOT LIKE 'C'
      THEN AMOUNT
      ELSE 0
    END,
    CASE
      WHEN TRIM(RECEIPT_TYPE) LIKE 'U'
      THEN 'U'
      WHEN TRIM(RECEIPT_TYPE) LIKE 'C'
      THEN 'C'
      ELSE 'O'
    END,
    cheque_or_dd,
    cheque_dd_no,
    cheque_dd_date
  ) aa
LEFT OUTER JOIN
  ( SELECT bank_id,bank_name FROM fas_mst_banks
  ) bb
ON AA.OFFICE_BANK_ID           =BB.BANK_ID
WHERE AA.ACCOUNTING_UNIT_ID    =$P{acc_unit_id}::int
AND AA.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}::int
AND aa.cashbook_month          =$P{mon}::int
AND aa.cashbook_year           =$P{yr}::int
AND aa.office_bank_id          =$P{bank_id}::int
GROUP BY accounting_unit_id,
  accounting_for_office_id,
  cashbook_year,
  cashbook_month,
  received_from_office_id,
  office_bank_id,
  bank_name,
  acct_unit_id,
  acct_for_office_id,
  ACCT_UNIT_NAME,
  cheque_or_dd,
  cheque_dd_no,
  cheque_dd_date
ORDER BY aa.acct_unit_id]]></queryString>

	<field name="accounting_unit_id" class="java.math.BigDecimal"/>
	<field name="accounting_for_office_id" class="java.math.BigDecimal"/>
	<field name="cashbook_year" class="java.math.BigDecimal"/>
