	<queryString><![CDATA[select 
cashbook_year,
cashbook_month,
document_date,
DOCUMENT_NO,
DOCUMENT_TYPE,
cheque_or_dd,
cheque_dd_no,
cheque_dd_date,
amount,
REMARKS,
received_cheque,
CREA_PAY_VOU,
received_cheque_or_dd,
RECEIVED_CHEQUE_NO,
received_cheque_date,
RECEIVED_CHEQUE_AMOUNT,
recieved_date,
cheq_dishonour_date,
REVERT_CHEQDISHONOUR_STATUS,
 (SELECT U.Accounting_Unit_Name
  FROM Fas_Mst_Acct_Units U
  where u.accounting_unit_id=a.accounting_unit_id
  ) as unitname
from FAS_CHEQUE_DISHONOUR a $P!{unitqry}
$P!{qry}
order by a.accounting_unit_id,a.document_date DESC ,a.document_no ASC]]></queryString>

