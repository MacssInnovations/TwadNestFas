<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPF_VoucherWise_withMonth_HeadWise_Abstract1_date"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="842"
		 columnWidth="818"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[SELECT
  (SELECT accounting_unit_name
  FROM fas_mst_acct_units
  WHERE accounting_unit_id = unitid
  ) AS unitname,
  accounting_for_office_id,
  cashbook_month,
  cashbook_year,
  doc_no,
  doc_date,
  (SELECT account_head_desc
  FROM com_mst_account_heads
  WHERE account_head_code = acchead
  ) account_head_desc,
  debit_amt,
  credit_amt,
  PARTICULARS,
  -(debit_amt - credit_amt ) AS net_amt,
  CASE
    WHEN -(debit_amt - credit_amt ) > 0
    THEN ' (CR)'
    ELSE ' (DR)'
  END AS net_amt_ind,
  acchead,
  Unitid,
  doc_type,Type_Desc,code_desc
FROM
  (SELECT accounting_unit_id AS unitid ,
    accounting_for_office_id,
    cashbook_month,
    cashbook_year,
    doc_no,
    doc_date,
    account_head_code AS acchead,
    CASE
      WHEN cr_dr_indicator ='DR'
      THEN amount
      ELSE 0
    END AS debit_amt,
    CASE
      WHEN cr_dr_indicator ='CR'
      THEN amount
      ELSE 0
    END AS credit_amt ,
    Particulars,
    doc_type,Type_Desc,code_desc
  FROM
    (
    -- Receipt
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.receipt_no   AS doc_no,
      m.RECEIPT_DATE AS doc_date,
      t.account_head_code,
      t.amount,
      t.CR_DR_INDICATOR,
      T.Particulars,
      'R' AS doc_type,
      (Select S.Sub_Ledger_Type_Desc From Com_Mst_Sl_Types S Where S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code)As Type_Desc,
   (select V.Sl_Codename from Sl_Type_Code_Name_View_M v where V.Sl_Type=T.Sub_Ledger_Type_Code and V.Sl_Code=T.Sub_Ledger_Code)as code_desc
    FROM fas_receipt_master m,
      fas_receipt_transaction t
    WHERE m.ACCOUNTING_UNIT_ID     = t.ACCOUNTING_UNIT_ID
    AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
   
    AND m.CASHBOOK_YEAR            = t.CASHBOOK_YEAR
    AND m.CASHBOOK_MONTH           = t.CASHBOOK_MONTH
    AND m.RECEIPT_NO               = t.RECEIPT_NO
    AND m.RECEIPT_STATUS           ='L'
    AND m.RECEIPT_DATE between $P{fromdate} and $P{todate}    
    AND t.account_head_code        = $P{accountheadcode}
    
    UNION ALL
    
    -- Payment
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.VOUCHER_NO   AS doc_no ,
      m.PAYMENT_DATE AS doc_date,
      t.account_head_code,
      t.amount,
      t.CR_DR_INDICATOR,
      T.Particulars,
      'P' AS doc_type,
      (Select S.Sub_Ledger_Type_Desc From Com_Mst_Sl_Types S Where S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code)As Type_Desc,
   (select V.Sl_Codename from Sl_Type_Code_Name_View_M v where V.Sl_Type=T.Sub_Ledger_Type_Code and V.Sl_Code=T.Sub_Ledger_Code)as code_desc
    FROM fas_payment_master m,
      fas_payment_transaction t
    WHERE m.ACCOUNTING_UNIT_ID     = t.ACCOUNTING_UNIT_ID
    AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID

    AND m.CASHBOOK_YEAR            = t.CASHBOOK_YEAR
    AND m.CASHBOOK_MONTH           = t.CASHBOOK_MONTH
    AND m.VOUCHER_NO               = t.VOUCHER_NO
    AND m.PAYMENT_STATUS           ='L'
    AND  m.PAYMENT_DATE between $P{fromdate} and $P{todate} 
    AND t.account_head_code        = $P{accountheadcode}
    
    UNION ALL
    
    -- Journal
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.VOUCHER_NO   AS doc_no,
      m.VOUCHER_DATE AS doc_date,
      t.account_head_code,
      t.amount,
      t.CR_DR_INDICATOR,
      t.PARTICULARS,
      'J' As Doc_Type,
      (Select S.Sub_Ledger_Type_Desc From Com_Mst_Sl_Types S Where S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code)As Type_Desc,
   (select V.Sl_Codename from Sl_Type_Code_Name_View_M v where V.Sl_Type=T.Sub_Ledger_Type_Code and V.Sl_Code=T.Sub_Ledger_Code)as code_desc
    FROM fas_journal_master m,
      fas_journal_transaction t
    WHERE m.ACCOUNTING_UNIT_ID     = t.ACCOUNTING_UNIT_ID
    AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
 
    AND m.CASHBOOK_YEAR            = t.CASHBOOK_YEAR
    AND m.CASHBOOK_MONTH           = t.CASHBOOK_MONTH
    AND m.VOUCHER_NO               = t.VOUCHER_NO
    AND m.JOURNAL_STATUS           = 'L'
    AND m.VOUCHER_DATE between $P{fromdate} and $P{todate}
    AND t.account_head_code        = $P{accountheadcode}
 and m.CREATED_BY_MODULE in ('GJV','LJV')
    
    UNION ALL
    
    --FUND RECEIPT BY HO
    SELECT accounting_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      cashbook_month,
      cashbook_year,
      RECEIPT_NO   AS doc_no ,
      RECEIPT_DATE AS doc_date,
      dr_account_head_code,
      TOTAL_AMOUNT,
      'DR' AS CR_DR_INDICATOR ,
      Particulars,
      'FR By HO' AS doc_type,
      '-' As Type_Desc,
  '-' As code_desc
    FROM fas_fund_receipt_by_ho
    WHERE RECEIPT_DATE between $P{fromdate} and $P{todate}
    AND receipt_status       ='L'
    AND DR_ACCOUNT_HEAD_CODE = $P{accountheadcode}
   

UNION ALL

   

    --FUND RECEIPT BY HO

    SELECT accounting_unit_id,

      ACCOUNTING_FOR_OFFICE_ID,

      cashbook_month,

      cashbook_year,

      RECEIPT_NO   AS doc_no ,

      RECEIPT_DATE AS doc_date,

      Cr_account_head_code,

      TOTAL_AMOUNT,

      'CR' AS CR_DR_INDICATOR ,

      PARTICULARS,

      'FR By HO' As Doc_Type,
      '-' As Type_Desc,
  '-' As code_desc

    FROM fas_fund_receipt_by_ho

    WHERE  RECEIPT_DATE between $P{fromdate} and $P{todate}

    AND receipt_status       ='L'

    AND CR_ACCOUNT_HEAD_CODE = $P{accountheadcode}
    
    UNION ALL
    
    -- FUND RECEIPT BY OFFICE
    SELECT accounting_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      cashbook_month,
      cashbook_year,
      RECEIPT_NO   AS doc_no ,
      RECEIPT_DATE AS doc_date,
      dr_account_head_code,
      TOTAL_AMOUNT,
      'DR' AS CR_DR_INDICATOR ,
      PARTICULARS ,
      'FR By Off' As Doc_Type,
      '-' As Type_Desc,
  '-' As code_desc
    FROM fas_fund_receipt_by_office
    WHERE RECEIPT_DATE between $P{fromdate} and $P{todate}
    AND receipt_status       ='L'
    AND DR_ACCOUNT_HEAD_CODE = $P{accountheadcode}

UNION ALL
    
    -- FUND RECEIPT BY OFFICE
    SELECT accounting_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      cashbook_month,
      cashbook_year,
      RECEIPT_NO   AS doc_no ,
      RECEIPT_DATE AS doc_date,
      cr_account_head_code,
      TOTAL_AMOUNT,
      'CR' AS CR_DR_INDICATOR ,
      PARTICULARS ,
      'FR By Off' As Doc_Type,
      '-' As Type_Desc,
  '-' As code_desc
    FROM fas_fund_receipt_by_office
    WHERE  RECEIPT_DATE between $P{fromdate} and $P{todate}
    AND receipt_status       ='L'
    AND CR_ACCOUNT_HEAD_CODE = $P{accountheadcode}
    -- Receipt Master entry inclusion
    
    UNION ALL
    
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.receipt_no   AS doc_no,
      m.RECEIPT_DATE AS doc_date,
      m.account_head_code,
      m.total_amount,
      'DR' AS CR_DR_INDICATOR,
      M.Remarks,
      'Receipt' As Doc_Type,
      '-' As Type_Desc,
  '-' As code_desc
      
    FROM fas_receipt_master m
    WHERE m.RECEIPT_STATUS  ='L'
    AND RECEIPT_DATE between $P{fromdate} and $P{todate}
    AND m.account_head_code = $P{accountheadcode}
    
    UNION ALL
    
    -- End
    -- Payment
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.VOUCHER_NO   AS doc_no ,
      m.PAYMENT_DATE AS doc_date,
      m.account_head_code,
      m.total_amount,
      'CR' AS CR_DR_INDICATOR,
      M.Remarks,
      'Payment' AS doc_type,
     '-' As Type_Desc,
      '-' As code_desc
    FROM fas_payment_master m
    WHERE m.PAYMENT_STATUS  ='L'
    AND m.PAYMENT_DATE between $P{fromdate} and $P{todate}
    AND m.account_head_code = $P{accountheadcode}
    
    
    -- new added on 9.9.10
    -- IBT Details
    --IBT TRANSFER
    
    UNION ALL
    
    SELECT ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_MONTH,
      CASHBOOK_YEAR,
      VOUCHER_NO       AS doc_no,
      DATE_OF_TRANSFER AS doc_date,
      CR_ACCOUNT_HEAD_CODE,
      TOTAL_AMOUNT,
      'CR' AS CR_DR_INDICATOR ,
      Particulars ,
      'IBT Trf' As Doc_Type,
      '-' As Type_Desc,
  '-' As code_desc
      
    FROM FAS_INTER_BANK_TRF_AT_HO
    WHERE  DATE_OF_TRANSFER  between $P{fromdate} and $P{todate}
    AND TRANSFER_STATUS      = 'L'
    AND CR_ACCOUNT_HEAD_CODE = $P{accountheadcode}
    --IBT RECEIPT
    
    UNION ALL
    
    SELECT ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_MONTH,
      CASHBOOK_YEAR,
      VOUCHER_NO       AS doc_no,
      DATE_OF_TRANSFER AS doc_date,
      DR_ACCOUNT_HEAD_CODE,
      TOTAL_AMOUNT,
      'DR' AS CR_DR_INDICATOR ,
      Particulars ,
      'IBT receipt' As Doc_Type,
      '-' As Type_Desc,
  '-' As code_desc
      
    FROM FAS_INTER_BANK_TRF_AT_HO
    WHERE  DATE_OF_TRANSFER  between $P{fromdate} and $P{todate}
    AND TRANSFER_STATUS      = 'L'
    AND DR_ACCOUNT_HEAD_CODE = $P{accountheadcode}
    
    UNION ALL
    
    --FUND TRANSFER FROM OFFICE
    SELECT accounting_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      cashbook_month,
      cashbook_year,
      VOUCHER_NO       AS doc_no,
      DATE_OF_TRANSFER AS doc_date,
      dr_account_head_code,
      TOTAL_AMOUNT,
      'DR' AS CR_DR_INDICATOR ,
      Particulars ,
      'FT from Off' AS doc_type,
      '-' As Type_Desc,
  '-' As code_desc
    FROM FAS_FUND_TRF_FROM_OFFICE
    WHERE   DATE_OF_TRANSFER between $P{fromdate} and $P{todate} 
    AND TRANSFER_STATUS      = 'L'
    AND DR_ACCOUNT_HEAD_CODE = $P{accountheadcode}

 UNION ALL
    
    --FUND TRANSFER FROM OFFICE
    SELECT accounting_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      cashbook_month,
      cashbook_year,
      VOUCHER_NO       AS doc_no,
      DATE_OF_TRANSFER AS doc_date,
      cr_account_head_code,
      TOTAL_AMOUNT,
      'CR' AS CR_DR_INDICATOR ,
      PARTICULARS ,
      'FT from Off' As Doc_Type,
      '-' As Type_Desc,
  '-' As code_desc
    FROM FAS_FUND_TRF_FROM_OFFICE
    WHERE  DATE_OF_TRANSFER between $P{fromdate} and $P{todate} 
    AND TRANSFER_STATUS      = 'L'
    AND CR_ACCOUNT_HEAD_CODE = $P{accountheadcode}    
    --Fund Transfer from HO Master
UNION ALL
    
    
    SELECT accounting_unit_id,
      ACCOUNTING_FOR_OFFICE_ID,
      cashbook_month,
      cashbook_year,
      VOUCHER_NO       AS doc_no,
      DATE_OF_TRANSFER AS doc_date,
      account_head_code,
      total_amount,
      'CR' as CR_DR_INDICATOR,
      Remarks,
      'FT from HO' AS doc_type,
      '-' As Type_Desc,
  '-' As code_desc
      
    FROM FAS_FUND_TRF_FROM_HO_MASTER 
    WHERE DATE_OF_TRANSFER between $P{fromdate} and $P{todate}
    AND TRANSFER_STATUS          = 'L'
    AND ACCOUNT_HEAD_CODE        = $P{accountheadcode}

    UNION ALL
    
    -- FUND TRANSFER FROM HO TRANSACTION
    SELECT m.accounting_unit_id,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.cashbook_month,
      m.cashbook_year,
      m.VOUCHER_NO       AS doc_no,
      m.DATE_OF_TRANSFER AS doc_date,
      t.account_head_code,
      t.AMOUNT,
      t.CR_DR_INDICATOR,
      T.Particulars,
     'FT from HO' AS doc_type,
     '-' As Type_Desc,
     '-' As code_desc
    FROM FAS_FUND_TRF_FROM_HO_MASTER m,
      FAS_FUND_TRF_FROM_HO_TRN t
    WHERE m.accounting_unit_id     = t.accounting_unit_id
    AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID

    AND m.CASHBOOK_MONTH           =t.cashbook_month
    AND m.cashbook_year            =t.cashbook_year
    AND m.voucher_no               = t.voucher_no
    AND m.DATE_OF_TRANSFER between $P{fromdate} and $P{todate}
    AND m.TRANSFER_STATUS          = 'L'
    AND t.ACCOUNT_HEAD_CODE        = $P{accountheadcode}
    )
  )
 order by unitid,doc_date, net_amt
]]></queryString>

	<field name="UNITNAME" class="java.lang.String"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="DOC_NO" class="java.math.BigDecimal"/>
	<field name="DOC_DATE" class="java.sql.Timestamp"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="DEBIT_AMT" class="java.math.BigDecimal"/>
	<field name="CREDIT_AMT" class="java.math.BigDecimal"/>
	<field name="PARTICULARS" class="java.lang.String"/>
	<field name="NET_AMT" class="java.math.BigDecimal"/>
	<field name="NET_AMT_IND" class="java.lang.String"/>
	<field name="ACCHEAD" class="java.math.BigDecimal"/>
	<field name="UNITID" class="java.math.BigDecimal"/>
	<field name="DOC_TYPE" class="java.lang.String"/>
	<field name="TYPE_DESC" class="java.lang.String"/>
	<field name="CODE_DESC" class="java.lang.String"/>

	<variable name="dr_amt" class="java.math.BigDecimal" resetType="Group" resetGroup="Unitwise" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_AMT}]]></variableExpression>
	</variable>
	<variable name="cr_amt" class="java.math.BigDecimal" resetType="Group" resetGroup="Unitwise" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_AMT}]]></variableExpression>
	</variable>
	<variable name="Net_amt" class="java.math.BigDecimal" resetType="Group" resetGroup="Unitwise" calculation="Nothing">
		<variableExpression><![CDATA[$V{dr_amt}.subtract($V{cr_amt})]]></variableExpression>
	</variable>
	<variable name="SlNo" class="java.lang.String" resetType="None" incrementType="Group" incrementGroup="Unitwise" calculation="Nothing">
		<variableExpression><![CDATA[$V{SlNo}]]></variableExpression>
	</variable>
	<variable name="tot_dr_amt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT_AMT}]]></variableExpression>
	</variable>
	<variable name="tot_cr_amt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT_AMT}]]></variableExpression>
	</variable>
	<variable name="tot_net_amt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{NET_AMT}]]></variableExpression>
	</variable>

		<group  name="Unitwise" >
			<groupExpression><![CDATA[$F{UNITID}]]></groupExpression>
			<groupHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupHeader>
			<groupFooter>
			<band height="22"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="true" pattern="###0" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="70"
						y="3"
						width="481"
						height="12"
						key="textField-6"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement>
						<font/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{UNITNAME}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" pattern="#,##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="712"
						y="3"
						width="79"
						height="12"
						key="textField-9"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Right">
						<font/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$V{Net_amt}.abs()]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="792"
						y="2"
						width="26"
						height="14"
						key="textField-10"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Left">
						<font/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{NET_AMT_IND}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" pattern="#,##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="551"
						y="3"
						width="77"
						height="13"
						key="textField"/>
					<box></box>
					<textElement textAlignment="Right">
						<font/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$V{dr_amt}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" pattern="#,##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="642"
						y="4"
						width="70"
