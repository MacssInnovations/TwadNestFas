<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPF_VoucherWise_withMonth_Headoffice"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="992"
		 pageHeight="842"
		 columnWidth="932"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sortingorder" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select                               
  ( select 
       accounting_unit_name 
    from 
       fas_mst_acct_units 
    where 
        accounting_unit_id = unitid )  
  as unitname, 
  accounting_for_office_id, 
  cashbook_month, 
  cashbook_year,
  doc_no, 
  doc_date, 
  (select
    account_head_desc 
   from
    com_mst_account_heads 
   where 
    account_head_code = acchead
  ) account_head_desc, 
  debit_amt, 
  credit_amt, 
  PARTICULARS, 
  -(debit_amt - credit_amt ) as net_amt, 
  case when -(debit_amt - credit_amt ) > 0 then 
     abs( -(debit_amt - credit_amt )) || ' (CR)' 
  else 
    abs( -(debit_amt - credit_amt )) || ' (DR)' 
  end as net_amt_ind,   
  acchead,
  unitid,
  Doc_Type, Type_Desc,
    code_desc
from 
(

select 
  accounting_unit_id as unitid , 
  accounting_for_office_id, 
  cashbook_month, 
  cashbook_year,
  doc_no, 
  doc_date, 
  account_head_code as acchead, 
  case when cr_dr_indicator ='DR' then 
    amount 
  else 
    0 
  end as debit_amt, 
  case when cr_dr_indicator ='CR' then 
    amount 
  else 
    0 
  end as credit_amt , 
  PARTICULARS,
  Doc_Type, Type_Desc,
    code_desc
 
from 
( 
  
-- Receipt 

select 
   m.accounting_unit_id, 
   m.ACCOUNTING_FOR_OFFICE_ID, 
   m.cashbook_month, 
   m.cashbook_year, 
   m.receipt_no as doc_no, 
   m.RECEIPT_DATE as doc_date, 
   t.account_head_code, 
   t.amount, 
   t.CR_DR_INDICATOR, 
   t.PARTICULARS,
   'R' As Doc_Type,
   (Select S.Sub_Ledger_Type_Desc From Com_Mst_Sl_Types S Where S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code)As Type_Desc,
      (select V.Sl_Codename from Sl_Type_Code_Name_View_M v where V.Sl_Type=T.Sub_Ledger_Type_Code and V.Sl_Code=T.Sub_Ledger_Code)as code_desc
from 
  fas_receipt_master m, 
  fas_receipt_transaction t
where 
  m.ACCOUNTING_UNIT_ID = t.ACCOUNTING_UNIT_ID and 
  m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID and 
 
  m.CASHBOOK_YEAR = t.CASHBOOK_YEAR and 
  m.CASHBOOK_MONTH = t.CASHBOOK_MONTH and 
  m.RECEIPT_NO = t.RECEIPT_NO and 
  m.RECEIPT_STATUS='L' and 
  m.cashbook_month= $P{cb_mon}::int and 
  m.cashbook_year= $P{cb_year}::int and 
  t.account_head_code = $P{accountheadcode}::int
     
union all 


-- Payment 
select 
   m.accounting_unit_id, 
   m.ACCOUNTING_FOR_OFFICE_ID,
   m.cashbook_month, 
   m.cashbook_year, 
   m.VOUCHER_NO as doc_no , 
   m.PAYMENT_DATE as doc_date, 
   t.account_head_code, 
   t.amount, 
   t.CR_DR_INDICATOR, 
   t.PARTICULARS,
   'P' As Doc_Type,
   (Select S.Sub_Ledger_Type_Desc From Com_Mst_Sl_Types S Where S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code)As Type_Desc,
      (select V.Sl_Codename from Sl_Type_Code_Name_View_M v where V.Sl_Type=T.Sub_Ledger_Type_Code and V.Sl_Code=T.Sub_Ledger_Code)as code_desc
from 
  fas_payment_master m, 
  fas_payment_transaction t
where 
  m.ACCOUNTING_UNIT_ID = t.ACCOUNTING_UNIT_ID and 
  m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID and 
 
  m.CASHBOOK_YEAR = t.CASHBOOK_YEAR and 
  m.CASHBOOK_MONTH = t.CASHBOOK_MONTH and 
  m.VOUCHER_NO = t.VOUCHER_NO and 
  m.PAYMENT_STATUS='L' and 
  m.cashbook_month= $P{cb_mon}::int and 
  m.cashbook_year= $P{cb_year}::int and 
  t.account_head_code = $P{accountheadcode}::int
  
union all 

-- Journal 

select 
   m.accounting_unit_id, 
   m.ACCOUNTING_FOR_OFFICE_ID, 
   m.cashbook_month, 
   m.cashbook_year, 
   m.VOUCHER_NO as doc_no,
   m.VOUCHER_DATE as doc_date, 
   t.account_head_code, 
   t.amount, 
   t.CR_DR_INDICATOR, 
   t.PARTICULARS,
   'J' as doc_type,
    (Select S.Sub_Ledger_Type_Desc From Com_Mst_Sl_Types S Where S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code)As Type_Desc,
      (select V.Sl_Codename from Sl_Type_Code_Name_View_M v where V.Sl_Type=T.Sub_Ledger_Type_Code and V.Sl_Code=T.Sub_Ledger_Code)as code_desc
from 
  fas_journal_master m, 
  fas_journal_transaction t
where 
  m.ACCOUNTING_UNIT_ID = t.ACCOUNTING_UNIT_ID and 
  m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID and 
 
  m.CASHBOOK_YEAR = t.CASHBOOK_YEAR and 
  m.CASHBOOK_MONTH = t.CASHBOOK_MONTH and 
  m.VOUCHER_NO = t.VOUCHER_NO and 
  m.JOURNAL_STATUS = 'L' and 
  m.cashbook_month = $P{cb_mon}::int and   
  m.cashbook_year = $P{cb_year}::int and   
  t.account_head_code = $P{accountheadcode}::int
  And M.Created_By_Module In ('GJV','LJV')
 
union all 
  
  
--FUND RECEIPT BY HO   
select 
   accounting_unit_id, 
   ACCOUNTING_FOR_OFFICE_ID, 
   cashbook_month, 
   cashbook_year, 
   RECEIPT_NO as doc_no , 
   RECEIPT_DATE as doc_date, 
   cr_account_head_code, 
   TOTAL_AMOUNT, 
   'DR' as CR_DR_INDICATOR , 
    PARTICULARS,
    'FR By HO' As Doc_Type,
     '-' As Type_Desc,
    '-' As code_desc
from 
   fas_fund_receipt_by_ho 
where 
   CASHBOOK_MONTH = $P{cb_mon}::int and 
   CASHBOOK_YEAR = $P{cb_year}::int and    
   receipt_status='L' and    
   DR_ACCOUNT_HEAD_CODE = $P{accountheadcode}::int      
   
union all 
   
-- FUND RECEIPT BY OFFICE 
select 
  accounting_unit_id, 
  ACCOUNTING_FOR_OFFICE_ID, 
  cashbook_month, 
  cashbook_year, 
  RECEIPT_NO as doc_no , 
  RECEIPT_DATE as doc_date,
  cr_account_head_code, 
  TOTAL_AMOUNT, 
  'CR' as CR_DR_INDICATOR , 
  Particulars ,
  'FR By HO' as doc_type,
   '-' As Type_Desc,
    '-' As code_desc
from 
  fas_fund_receipt_by_office 
where 
   CASHBOOK_MONTH = $P{cb_mon}::int and 
   CASHBOOK_YEAR = $P{cb_year}::int and    
   receipt_status='L' and 
   cR_ACCOUNT_HEAD_CODE = $P{accountheadcode}::int
  
  
union all 



--FUND TRANSFER FROM OFFICE 
select 
  accounting_unit_id, 
  ACCOUNTING_FOR_OFFICE_ID, 
  cashbook_month, 
  cashbook_year, 
  VOUCHER_NO as doc_no,
  DATE_OF_TRANSFER as doc_date, 
  dr_account_head_code, 
  TOTAL_AMOUNT, 
  'DR' as CR_DR_INDICATOR , 
  PARTICULARS ,
  'FT from Off' as doc_type,
   '-' As Type_Desc,
    '-' As code_desc
from 
   FAS_FUND_TRF_FROM_OFFICE 
where 
   CASHBOOK_MONTH = $P{cb_mon}::int and 
   CASHBOOK_YEAR = $P{cb_year}::int and    
   TRANSFER_STATUS = 'L' and 
   dR_ACCOUNT_HEAD_CODE = $P{accountheadcode}::int
  
     
union all 

-- FUND TRANSFER FROM HO TRANSACTION 
select 
  m.accounting_unit_id, 
  m.ACCOUNTING_FOR_OFFICE_ID, 
  m.cashbook_month, 
  m.cashbook_year, 
  m.VOUCHER_NO as doc_no, 
  m.DATE_OF_TRANSFER as doc_date, 
  t.account_head_code, 
  t.AMOUNT, 
  t.CR_DR_INDICATOR, 
  t.PARTICULARS,
  ( 'FT from HO' ||' to '|| (Select Accounting_Unit_Name From Fas_Mst_Acct_Units Where Accounting_Unit_Office_Id= T.Transfer_To_Office_Id) )
  as doc_type,
   '-' As Type_Desc,
    '-' As code_desc
from    
   FAS_FUND_TRF_FROM_HO_MASTER m,
   FAS_FUND_TRF_FROM_HO_TRN t
where 
   m.accounting_unit_id = t.accounting_unit_id and 
   m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID and 
  
   m.CASHBOOK_MONTH=t.cashbook_month and 
   m.cashbook_year=t.cashbook_year and 
   m.voucher_no = t.voucher_no and 
   m.CASHBOOK_MONTH = $P{cb_mon}::int and 
   m.CASHBOOK_YEAR = $P{cb_year}::int and   
   m.TRANSFER_STATUS = 'L' and    
   t.ACCOUNT_HEAD_CODE = $P{accountheadcode}::int
 )ab
) ab
--  order by doc_date, net_amt
--  order by unitid , doc_date
 --$P!{sortingorder}]]></queryString>

	<field name="unitname" class="java.lang.String"/>
	<field name="accounting_for_office_id" class="java.math.BigDecimal"/>
	<field name="cashbook_month" class="java.math.BigDecimal"/>
	<field name="cashbook_year" class="java.math.BigDecimal"/>
	<field name="doc_no" class="java.math.BigDecimal"/>
	<field name="doc_date" class="java.sql.Date"/>
