<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Untitled_report_1GPF_VoucherWise_withMonth_unitWise_Abstract1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="842"
		 columnWidth="818"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="2" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT unitid,unitname,
  acchead,
  account_head_desc,
  SUM(debit_amt) AS debit_amt,
  sum(credit_amt)as credit_amt,
  net_amt,
  net_amt_ind
FROM
  (SELECT
    (SELECT accounting_unit_name
    FROM fas_mst_acct_units
    WHERE accounting_unit_id = unitid
    ) AS unitname,
    accounting_for_office_id,
    cashbook_month,
    cashbook_year,
    (SELECT account_head_desc
    FROM com_mst_account_heads
    WHERE account_head_code = acchead
    ) account_head_desc,
    debit_amt,
    credit_amt,
    PARTICULARS,
    -(debit_amt - credit_amt ) AS net_amt,
    CASE
      WHEN -(debit_amt - credit_amt ) > 0
      THEN ' (CR)'
      ELSE ' (DR)'
    END AS net_amt_ind,
    acchead,
    unitid,
    Doc_Type,
    Type_Desc,
    code_desc
  FROM
    (SELECT accounting_unit_id AS unitid ,
      accounting_for_office_id,
      cashbook_month,
      cashbook_year,
      doc_no,
      doc_date,
      account_head_code AS acchead,
      CASE
        WHEN cr_dr_indicator ='DR'
        THEN amount
        ELSE 0
      END AS debit_amt,
      CASE
        WHEN cr_dr_indicator ='CR'
        THEN amount
        ELSE 0
      END AS credit_amt ,
      PARTICULARS,
      Doc_Type,
      Type_Desc,
      code_desc
    FROM
      (
      
      SELECT m.accounting_unit_id,
        m.ACCOUNTING_FOR_OFFICE_ID,
        m.cashbook_month,
        m.cashbook_year,
        m.receipt_no   AS doc_no,
        m.RECEIPT_DATE AS doc_date,
        t.account_head_code,
        t.amount,
        t.CR_DR_INDICATOR,
        T.Particulars,
        'R' AS Doc_Type,
        (SELECT S.Sub_Ledger_Type_Desc
        FROM Com_Mst_Sl_Types S
        WHERE S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code
        )AS Type_Desc,
        (SELECT V.Sl_Codename
        FROM Sl_Type_Code_Name_View_M v
        WHERE V.Sl_Type=T.Sub_Ledger_Type_Code
        AND V.Sl_Code  =T.Sub_Ledger_Code
        )AS code_desc
      FROM fas_receipt_master m,
        fas_receipt_transaction t
      WHERE m.ACCOUNTING_UNIT_ID     = t.ACCOUNTING_UNIT_ID
      AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
      AND m.CASHBOOK_YEAR            = t.CASHBOOK_YEAR
      AND m.CASHBOOK_MONTH           = t.CASHBOOK_MONTH
      AND m.RECEIPT_NO               = t.RECEIPT_NO
      AND m.RECEIPT_STATUS           ='L'
      AND m.cashbook_month           = $P{cb_mon}
      AND m.cashbook_year            =$P{cb_year}
      AND t.account_head_code        =$P{accountheadcode}
      UNION ALL
      
      SELECT m.accounting_unit_id,
        m.ACCOUNTING_FOR_OFFICE_ID,
        m.cashbook_month,
        m.cashbook_year,
        m.VOUCHER_NO   AS doc_no ,
        m.PAYMENT_DATE AS doc_date,
        t.account_head_code,
        t.amount,
        t.CR_DR_INDICATOR,
        T.Particulars,
        'P' AS doc_type,
        (SELECT S.Sub_Ledger_Type_Desc
        FROM Com_Mst_Sl_Types S
        WHERE S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code
        )AS Type_Desc,
        (SELECT V.Sl_Codename
        FROM Sl_Type_Code_Name_View_M v
        WHERE V.Sl_Type=T.Sub_Ledger_Type_Code
        AND V.Sl_Code  =T.Sub_Ledger_Code
        )AS code_desc
      FROM fas_payment_master m,
        fas_payment_transaction t
      WHERE m.ACCOUNTING_UNIT_ID     = t.ACCOUNTING_UNIT_ID
      AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
      AND m.CASHBOOK_YEAR            = t.CASHBOOK_YEAR
      AND m.CASHBOOK_MONTH           = t.CASHBOOK_MONTH
      AND m.VOUCHER_NO               = t.VOUCHER_NO
      AND m.PAYMENT_STATUS           ='L'
      AND m.cashbook_month           = $P{cb_mon}
      AND m.cashbook_year            =$P{cb_year}
      AND t.account_head_code        =$P{accountheadcode}
      UNION ALL
      
      SELECT m.accounting_unit_id,
        m.ACCOUNTING_FOR_OFFICE_ID,
        m.cashbook_month,
        m.cashbook_year,
        m.VOUCHER_NO   AS doc_no,
        m.VOUCHER_DATE AS doc_date,
        t.account_head_code,
        t.amount,
        t.CR_DR_INDICATOR,
        T.Particulars,
        'J' AS doc_type,
        (SELECT S.Sub_Ledger_Type_Desc
        FROM Com_Mst_Sl_Types S
        WHERE S.Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code
        )AS Type_Desc,
        (SELECT V.Sl_Codename
        FROM Sl_Type_Code_Name_View_M v
        WHERE V.Sl_Type=T.Sub_Ledger_Type_Code
        AND V.Sl_Code  =T.Sub_Ledger_Code
        )AS code_desc
      FROM fas_journal_master m,
        fas_journal_transaction t
      WHERE m.ACCOUNTING_UNIT_ID     = t.ACCOUNTING_UNIT_ID
      AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
      AND m.CASHBOOK_YEAR            = t.CASHBOOK_YEAR
      AND m.CASHBOOK_MONTH           = t.CASHBOOK_MONTH
      AND m.VOUCHER_NO               = t.VOUCHER_NO
      AND m.JOURNAL_STATUS           = 'L'
      AND m.cashbook_month           = $P{cb_mon}
      AND m.cashbook_year            =$P{cb_year}
      AND t.account_head_code        =$P{accountheadcode}
      AND m.CREATED_BY_MODULE       IN ('GJV','LJV')
      UNION ALL
      
      SELECT accounting_unit_id,
        ACCOUNTING_FOR_OFFICE_ID,
        cashbook_month,
        cashbook_year,
        RECEIPT_NO   AS doc_no ,
        RECEIPT_DATE AS doc_date,
        dr_account_head_code,
        TOTAL_AMOUNT,
        'DR' AS CR_DR_INDICATOR ,
        Particulars,
        'FR By HO' AS Doc_Type,
        '-'        AS Type_Desc,
        '-'        AS code_desc
      FROM fas_fund_receipt_by_ho
      WHERE CASHBOOK_MONTH     = $P{cb_mon}
      AND CASHBOOK_YEAR        =$P{cb_year}
      AND receipt_status       ='L'
      AND DR_ACCOUNT_HEAD_CODE =$P{accountheadcode}
      UNION ALL
      
      SELECT accounting_unit_id,
        ACCOUNTING_FOR_OFFICE_ID,
        cashbook_month,
        cashbook_year,
        RECEIPT_NO   AS doc_no ,
        RECEIPT_DATE AS doc_date,
        Cr_account_head_code,
        TOTAL_AMOUNT,
        'CR' AS CR_DR_INDICATOR ,
        PARTICULARS,
        'FR By HO' AS doc_type,
        '-'        AS Type_Desc,
        '-'        AS code_desc
      FROM fas_fund_receipt_by_ho
      WHERE CASHBOOK_MONTH     = $P{cb_mon}
      AND CASHBOOK_YEAR        =$P{cb_year}
      AND receipt_status       ='L'
      AND CR_ACCOUNT_HEAD_CODE =$P{accountheadcode}
      UNION ALL
      
      SELECT accounting_unit_id,
        ACCOUNTING_FOR_OFFICE_ID,
        cashbook_month,
        cashbook_year,
        RECEIPT_NO   AS doc_no ,
        RECEIPT_DATE AS doc_date,
        dr_account_head_code,
        TOTAL_AMOUNT,
        'DR' AS CR_DR_INDICATOR ,
        Particulars ,
        'FR By Off' AS doc_type,
        '-'         AS Type_Desc,
        '-'         AS code_desc
      FROM fas_fund_receipt_by_office
      WHERE CASHBOOK_MONTH     = $P{cb_mon}
      AND CASHBOOK_YEAR        =$P{cb_year}
      AND receipt_status       ='L'
      AND DR_ACCOUNT_HEAD_CODE =$P{accountheadcode}
      UNION ALL
      
      SELECT accounting_unit_id,
        ACCOUNTING_FOR_OFFICE_ID,
        cashbook_month,
        cashbook_year,
        RECEIPT_NO   AS doc_no ,
        RECEIPT_DATE AS doc_date,
        cr_account_head_code,
        TOTAL_AMOUNT,
        'CR' AS CR_DR_INDICATOR ,
        Particulars ,
        'FR By Off' AS doc_type,
        '-'         AS Type_Desc,
        '-'         AS code_desc
      FROM fas_fund_receipt_by_office
      WHERE CASHBOOK_MONTH     = $P{cb_mon}
      AND CASHBOOK_YEAR        =$P{cb_year}
      AND receipt_status       ='L'
      AND CR_ACCOUNT_HEAD_CODE =$P{accountheadcode}
      
      UNION ALL
      SELECT m.accounting_unit_id,
        m.ACCOUNTING_FOR_OFFICE_ID,
        m.cashbook_month,
        m.cashbook_year,
        m.receipt_no   AS doc_no,
        m.RECEIPT_DATE AS doc_date,
        m.account_head_code,
        m.total_amount,
        'DR' AS CR_DR_INDICATOR,
        M.Remarks,
        'Receipt' AS Doc_Type,
        '-'       AS Type_Desc,
        '-'       AS code_desc
      FROM fas_receipt_master m
      WHERE m.RECEIPT_STATUS  ='L'
      AND m.cashbook_month    = $P{cb_mon}
      AND m.cashbook_year     =$P{cb_year}
      AND m.account_head_code =$P{accountheadcode}
      UNION ALL
      
      SELECT m.accounting_unit_id,
        m.ACCOUNTING_FOR_OFFICE_ID,
        m.cashbook_month,
        m.cashbook_year,
        m.VOUCHER_NO   AS doc_no ,
        m.PAYMENT_DATE AS doc_date,
        m.account_head_code,
        m.total_amount,
        'CR' AS CR_DR_INDICATOR,
        m.remarks,
        'Payment' AS Doc_Type,
        '-'       AS Type_Desc,
        '-'       AS code_desc
      FROM fas_payment_master m
      WHERE m.PAYMENT_STATUS  ='L'
      AND m.cashbook_month    = $P{cb_mon}
      AND m.cashbook_year     =$P{cb_year}
      AND m.account_head_code =$P{accountheadcode}
     
      UNION ALL
      SELECT ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_MONTH,
        CASHBOOK_YEAR,
        VOUCHER_NO       AS doc_no,
        DATE_OF_TRANSFER AS doc_date,
        CR_ACCOUNT_HEAD_CODE,
        TOTAL_AMOUNT,
        'CR' AS CR_DR_INDICATOR ,
        PARTICULARS ,
        'IBT Trf' AS Doc_Type,
        '-'       AS Type_Desc,
        '-'       AS code_desc
      FROM FAS_INTER_BANK_TRF_AT_HO
      WHERE CASHBOOK_MONTH     = $P{cb_mon}
      AND CASHBOOK_YEAR        =$P{cb_year}
      AND TRANSFER_STATUS      = 'L'
      AND CR_ACCOUNT_HEAD_CODE =$P{accountheadcode}
      
      UNION ALL
      SELECT ACCOUNTING_UNIT_ID,
        ACCOUNTING_FOR_OFFICE_ID,
        CASHBOOK_MONTH,
        CASHBOOK_YEAR,
        VOUCHER_NO       AS doc_no,
        DATE_OF_TRANSFER AS doc_date,
        DR_ACCOUNT_HEAD_CODE,
        TOTAL_AMOUNT,
        'DR' AS CR_DR_INDICATOR ,
        PARTICULARS ,
        'IBT receipt' AS Doc_Type,
        '-'           AS Type_Desc,
        '-'           AS code_desc
      FROM FAS_INTER_BANK_TRF_AT_HO
      WHERE CASHBOOK_MONTH     = $P{cb_mon}
      AND CASHBOOK_YEAR        =$P{cb_year}
      AND TRANSFER_STATUS      = 'L'
      AND DR_ACCOUNT_HEAD_CODE =$P{accountheadcode}
      UNION ALL
      
      SELECT accounting_unit_id,
        ACCOUNTING_FOR_OFFICE_ID,
        cashbook_month,
        cashbook_year,
        VOUCHER_NO       AS doc_no,
        DATE_OF_TRANSFER AS doc_date,
        dr_account_head_code,
        TOTAL_AMOUNT,
        'DR' AS CR_DR_INDICATOR ,
        PARTICULARS ,
        'FT from Off' AS Doc_Type,
        '-'           AS Type_Desc,
        '-'           AS code_desc
      FROM FAS_FUND_TRF_FROM_OFFICE
      WHERE CASHBOOK_MONTH     = $P{cb_mon}
      AND CASHBOOK_YEAR        =$P{cb_year}
      AND TRANSFER_STATUS      = 'L'
      AND DR_ACCOUNT_HEAD_CODE =$P{accountheadcode}
      UNION ALL
      
      SELECT accounting_unit_id,
        ACCOUNTING_FOR_OFFICE_ID,
        cashbook_month,
        cashbook_year,
        VOUCHER_NO       AS doc_no,
        DATE_OF_TRANSFER AS doc_date,
        cr_account_head_code,
        TOTAL_AMOUNT,
        'CR' AS CR_DR_INDICATOR ,
        PARTICULARS ,
        'FT from Off' AS Doc_Type,
        '-'           AS Type_Desc,
        '-'           AS code_desc
      FROM FAS_FUND_TRF_FROM_OFFICE
      WHERE CASHBOOK_MONTH     = $P{cb_mon}
      AND CASHBOOK_YEAR        =$P{cb_year}
      AND TRANSFER_STATUS      = 'L'
      AND CR_ACCOUNT_HEAD_CODE =$P{accountheadcode}
      
      UNION ALL
      SELECT accounting_unit_id,
        ACCOUNTING_FOR_OFFICE_ID,
        cashbook_month,
        cashbook_year,
        VOUCHER_NO       AS doc_no,
        DATE_OF_TRANSFER AS doc_date,
        account_head_code,
        total_amount,
        'CR' AS CR_DR_INDICATOR,
        Remarks,
        'FT from HO' AS doc_type,
        '-'          AS Type_Desc,
        '-'          AS code_desc
      FROM FAS_FUND_TRF_FROM_HO_MASTER
      WHERE CASHBOOK_MONTH  = $P{cb_mon}
      AND CASHBOOK_YEAR     =$P{cb_year}
      AND TRANSFER_STATUS   = 'L'
      AND ACCOUNT_HEAD_CODE =$P{accountheadcode}
      UNION ALL
      
      SELECT m.accounting_unit_id,
        m.ACCOUNTING_FOR_OFFICE_ID,
        m.cashbook_month,
        m.cashbook_year,
        m.VOUCHER_NO       AS doc_no,
        m.DATE_OF_TRANSFER AS doc_date,
        t.account_head_code,
        t.AMOUNT,
        t.CR_DR_INDICATOR,
        t.PARTICULARS,
        'FT from HO' AS Doc_Type,
        '-'          AS Type_Desc,
        '-'          AS code_desc
      FROM FAS_FUND_TRF_FROM_HO_MASTER m,
        FAS_FUND_TRF_FROM_HO_TRN t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID =t.ACCOUNTING_FOR_OFFICE_ID
      AND m.CASHBOOK_MONTH           =t.cashbook_month
      AND m.cashbook_year            =t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.CASHBOOK_MONTH           = $P{cb_mon}
      AND m.CASHBOOK_YEAR            =$P{cb_year}
      AND m.TRANSFER_STATUS          = 'L'
      AND t.ACCOUNT_HEAD_CODE        =$P{accountheadcode}
      )
    )
  ORDER BY unitid,
    doc_date
  )
  group by unitid,unitname,
  acchead,
  account_head_desc,
  net_amt,
  net_amt_ind]]></queryString>

	<field name="UNITID" class="java.math.BigDecimal"/>
	<field name="UNITNAME" class="java.lang.String"/>
	<field name="ACCHEAD" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="DEBIT_AMT" class="java.math.BigDecimal"/>
	<field name="CREDIT_AMT" class="java.math.BigDecimal"/>
	<field name="NET_AMT" class="java.math.BigDecimal"/>
	<field name="NET_AMT_IND" class="java.lang.String"/>

