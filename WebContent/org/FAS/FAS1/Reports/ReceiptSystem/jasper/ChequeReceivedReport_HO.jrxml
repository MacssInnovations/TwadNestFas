<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ChequeReceivedReport_HO"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="808"
		 columnSpacing="0"
		 leftMargin="17"
		 rightMargin="17"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="acc_no" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select
      * 
from
(
 
 select
        a.receipt_no,
        a.receipt_date,
        a.challan_date,
        a.received_from as money_rec_from ,
        (b.account_head_code ||'-'|| c.account_head_desc) as Acc_details ,        
        b.amount as amt,
        b.particulars,
        (b.CHEQUE_OR_DD ||'-'|| b.CHEQUE_DD_NO ||'-'|| to_char(b.CHEQUE_DD_DATE,'DD/MM/YYYY') ||'-'|| b.BANK_NAME ) as All_details,
        b.BANK_MICR_CODE  as m_code,
        d.accounting_unit_name,
        f.office_short_name ,a.account_no

from 
       fas_receipt_master a,
       fas_receipt_transaction b,
       com_mst_account_heads c,
       fas_mst_acct_units d,
       com_mst_offices f 

where
a.cashbook_month=b.cashbook_month 
and a.cashbook_year=b.cashbook_year
and a.accounting_unit_id=b.accounting_unit_id and
a.accounting_for_office_id=b.accounting_for_office_id and

b.account_head_code=c.account_head_code and 
d.accounting_unit_id=a.accounting_unit_id and
a.accounting_for_office_id=f.office_id and
a.receipt_no=b.receipt_no and
a.receipt_status<>'C' and 
a.receipt_type='B' and 
a.cashbook_year=($P{cashbookyear}) and 
a.cashbook_month= ($P{cashbookmonth})  and
a.accounting_unit_id= ($P{accountingunitid}) and 
a.accounting_for_office_id=($P{accountofficeid})
 

union all

 select 
        a.receipt_no,
        a.receipt_date,
        a.challan_date,
        (select  ACCOUNTING_UNIT_NAME from FAS_MST_ACCT_UNITS where ACCOUNTING_UNIT_ID=a.RECEIVED_FROM_OFFICE_ID ) as money_rec_from ,
        (a.DR_ACCOUNT_HEAD_CODE ||'-'||  c.account_head_desc) as Acc_details ,        
        a.TOTAL_AMOUNT as amt,	
        a.PARTICULARS,	
        (a.CHEQUE_OR_DD ||'-'|| a.CHEQUE_DD_NO ||'-'|| to_char(a.CHEQUE_DD_DATE,'DD/MM/YYYY') ||'-'|| g.BRANCH_NAME ) as All_details,
        to_char(g.MICR_CODE) as m_code, 
        d.accounting_unit_name,
        f.office_short_name ,a.office_account_no as account_no

  from 
        FAS_FUND_RECEIPT_BY_HO  a ,
        com_mst_account_heads c,
        fas_mst_acct_units d,
        com_mst_offices f ,
        FAS_MST_BANK_BRANCHES  g
 
  where
        a.cashbook_year= ($P{cashbookyear}) and 
	a.cashbook_month= ($P{cashbookmonth}) and
	a.accounting_unit_id= ($P{accountingunitid}) and 
	a.accounting_for_office_id=($P{accountofficeid}) and 
        a.receipt_status<>'C' and 
        a.dr_account_head_code=c.account_head_code and 
        d.accounting_unit_id=a.accounting_unit_id and
        a.accounting_for_office_id=f.office_id and
        a.HO_BANK_ID= g.BANK_ID  and 
        a.HO_BRANCH_ID =g.BRANCH_ID 
 
 ) $P!{acc_no}
 order by    account_no,receipt_date,receipt_no]]></queryString>

