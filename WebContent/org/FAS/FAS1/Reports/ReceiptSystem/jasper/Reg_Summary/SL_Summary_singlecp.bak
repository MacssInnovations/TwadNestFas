	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="unitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth_from_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cbmonth_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth_to_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supplement_no" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="headcode" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT YEAR,
  MONTH,
  mon_yr_disp,
  mon_yr,
  acc_code,
  (SELECT account_head_desc
  FROM com_mst_account_heads
  WHERE account_head_code= acc_code
  ) AS acc_code_desc,
  sltype,
  (SELECT SUB_LEDGER_TYPE_DESC
  FROM COM_MST_SL_TYPES
  WHERE sub_ledger_type_code= sltype
  ) AS sl_type_desc,
  slcode,
  (SELECT SL_CODENAME
  FROM SL_TYPE_CODE_NAME_VIEW_M
  WHERE SL_TYPE= sltype
  AND sl_code  =slcode
  ) AS sl_code_desc ,
  MONTH_OPENING_BALANCE,
  MONTH_OPENING_BAL_DR_CR_IND,
  CURRENT_MONTH_DEBIT,
  CURRENT_MONTH_CREDIT,
  MONTH_CLOSING_BALANCE,
  MONTH_CLOSING_BAL_DR_CR_IND,
  accounting_unit_name,
  supplement_no,
  supplement_no_ord
FROM
  (SELECT YEAR,
    MONTH,
    ( MONTH
    ||'/'
    || YEAR ) AS mon_yr_disp,
    to_date( MONTH
    || '/'
    || YEAR ,'mm/yyyy')  AS mon_yr,
    ACCOUNT_HEAD_CODE    AS acc_code,
    SUB_LEDGER_TYPE_CODE AS sltype,
    SUB_LEDGER_CODE      AS slcode,
    MONTH_OPENING_BALANCE,
    MONTH_OPENING_BAL_DR_CR_IND,
    CURRENT_MONTH_DEBIT,
    CURRENT_MONTH_CREDIT,
    MONTH_CLOSING_BALANCE,
    MONTH_CLOSING_BAL_DR_CR_IND,
    '' AS supplement_no,
    0  AS supplement_no_ord
  FROM FAS_SUB_LEDGER_MASTER
  Where Accounting_Unit_Id     = $P{unitId}
 AND to_date(MONTH
    ||'-'
    || + YEAR, 'mm-yyyy') BETWEEN to_date( ( $P{cbmonth_from} )
    || '-'
    || ( $P{cbyear_from} ) , 'mm-yyyy')
  AND to_date( ( $P{cbmonth_to} )
    ||'-'
    || ( $P{cbyear_to} ) , 'mm-yyyy')
  AND account_head_code IN ( $P{headcode} )
  UNION ALL
  SELECT YEAR,
    MONTH,
    ( MONTH
    ||'/'
    || YEAR ) AS mon_yr_disp,
    to_date( MONTH
    || '/'
    || YEAR ,'mm/yyyy')  AS mon_yr,
    ACCOUNT_HEAD_CODE    AS acc_code,
    SUB_LEDGER_TYPE_CODE AS sltype,
    SUB_LEDGER_CODE      AS slcode,
    MONTH_OPENING_BALANCE,
    MONTH_OPENING_BAL_DR_CR_IND,
    CURRENT_MONTH_DEBIT,
    CURRENT_MONTH_CREDIT,
    MONTH_CLOSING_BALANCE,
    MONTH_CLOSING_BAL_DR_CR_IND,
    'S-'
    || TO_CHAR(supplement_no) AS supplement_no,
    supplement_no             AS supplement_no_ord
  FROM FAS_SUB_LEDGER_MASTER_SJV
  Where Accounting_Unit_Id     = $P{unitId}
  AND MONTH                    =$P{cbmonth_to} 
  AND YEAR                     =$P{cbyear_to}
  AND account_head_code       IN ( $P{headcode})
  AND supplement_no <= $P{supplement_no}
  ),
  (SELECT accounting_unit_name
  FROM fas_mst_acct_units
  WHERE accounting_unit_id= $P{unitId}
  )
ORDER BY sltype,
  slcode,
  acc_code,
  mon_yr,
  supplement_no_ord]]></queryString>

