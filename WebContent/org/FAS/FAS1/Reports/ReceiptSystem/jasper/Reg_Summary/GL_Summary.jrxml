<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GL_Summary"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="headcode" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 
  current_month_debit, 
  current_month_credit, 
  cb_month, 
  cb_year, 
  cum_cr,
  cum_dr, 
  month_ob_dr,
  month_ob_cr,
  month_opening_balance,
  month_opening_bal_dr_cr_ind,
  month_closing_balance, 
  month_closing_bal_dr_cr_ind,     
  (month_ob_dr + current_month_debit ) as net_dr,
  (month_ob_cr + current_month_credit ) as net_cr,
  ( select account_head_desc from com_mst_account_heads where account_head_code = $P{headcode} ) as account_head_desc
from 
(
select 
  current_month_debit,
  current_month_credit,
  cb_month, 
  cb_year,
  ( select 
         sum(current_month_credit) 
    from 
       fas_trial_balance
    where 
        accounting_unit_id=$P{unitid} 
    and to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{month_from})  || '-' || ($P{year_from}) ,   'mm-yyyy')  AND to_date( (cb_month) ||'-' || (cb_year) , 'mm-yyyy')
    and account_head_code=$P{headcode} 
  ) as cum_cr,
 
  ( select 
         sum(current_month_debit) 
    from 
       fas_trial_balance
    where 
       accounting_unit_id=$P{unitid} 
    and to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{month_from})  || '-' || ($P{year_from}) ,   'mm-yyyy')  AND to_date( (cb_month) ||'-' || (cb_year) , 'mm-yyyy')
    and account_head_code=$P{headcode} 
  ) as cum_dr,
   
   month_ob_dr,
   month_ob_cr, 
   month_opening_balance,
   month_opening_bal_dr_cr_ind, 
   month_closing_balance, 
   month_closing_bal_dr_cr_ind   
  
from 
(
select 
  current_month_debit,
  current_month_credit,
  cashbook_month as cb_month, 
  cashbook_year as cb_year
from 
    fas_trial_balance 
where 
    accounting_unit_id=$P{unitid} 
and account_head_code=$P{headcode}
and to_date(cashbook_month ||'-'|| + cashbook_year,   'mm-yyyy') BETWEEN to_date(  ($P{month_from})  || '-' || ($P{year_from}) ,   'mm-yyyy')  AND to_date( ($P{month_to}) ||'-' || ($P{year_to}) , 'mm-yyyy')
)as h,

(select
  case when month_opening_bal_dr_cr_ind ='CR' then 
     month_opening_balance
  else
     0 
  end as month_ob_cr, 
  case when month_opening_bal_dr_cr_ind ='DR' then 
     month_opening_balance
  else
     0 
  end as month_ob_dr, 
  month_opening_balance,
  month_opening_bal_dr_cr_ind
   
from
   fas_general_ledger 
where 
    accounting_unit_id=$P{unitid} 
and month= $P{month_from}             -- from month
and year=$P{year_from}            -- from year 
and account_head_code=$P{headcode}
)as hh, 

(
 select
  month_closing_balance,
  month_closing_bal_dr_cr_ind   
 from
   fas_general_ledger 
 where 
    accounting_unit_id=$P{unitid} 
 and month = $P{month_to}        -- to month
 and year = $P{year_to}      -- to year
 and account_head_code=$P{headcode}
)as j

)as k]]></queryString>

