		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="unitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth_from_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cbmonth_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth_to_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supplement_no" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select
    year, 
    month, 
    mon_yr_disp as "MON_YR_DISP",
    mon_yr, 
    acc_code as "ACC_CODE", 
    ( select account_head_desc  from com_mst_account_heads where account_head_code= acc_code ) as "ACC_CODE_DESC", 
    sltype as "SLTYPE",
    ( SELECT  SUB_LEDGER_TYPE_DESC FROM COM_MST_SL_TYPES  where  sub_ledger_type_code= sltype ) as "SL_TYPE_DESC", 
    slcode as "SLCODE",      
    ( SELECT SL_CODENAME
      FROM SL_TYPE_CODE_NAME_VIEW_M 
      where SL_TYPE= sltype
      and sl_code=slcode) as "SL_CODE_DESC" , 
    MONTH_OPENING_BALANCE as "MONTH_OPENING_BALANCE",
    MONTH_OPENING_BAL_DR_CR_IND as "MONTH_OPENING_BAL_DR_CR_IND",
    CURRENT_MONTH_DEBIT as "CURRENT_MONTH_DEBIT",
    CURRENT_MONTH_CREDIT as "CURRENT_MONTH_CREDIT",
    MONTH_CLOSING_BALANCE as "MONTH_CLOSING_BALANCE",
    MONTH_CLOSING_BAL_DR_CR_IND as "MONTH_CLOSING_BAL_DR_CR_IND", 
    accounting_unit_name as "ACCOUNTING_UNIT_NAME", 
    supplement_no as "SUPPLEMENT_NO", 
    supplement_no_ord
from 
(

SELECT  
  year, 
  month,
  ( month ||'/' || year ) as mon_yr_disp, 
  to_date(  month || '/' || year ,'mm/yyyy') as mon_yr, 
  ACCOUNT_HEAD_CODE as acc_code,
  SUB_LEDGER_TYPE_CODE as sltype,
  SUB_LEDGER_CODE as slcode,  
  MONTH_OPENING_BALANCE,
  MONTH_OPENING_BAL_DR_CR_IND,
  CURRENT_MONTH_DEBIT,
  CURRENT_MONTH_CREDIT,
  MONTH_CLOSING_BALANCE,
  MONTH_CLOSING_BAL_DR_CR_IND, 
  '' as supplement_no, 
  0 as supplement_no_ord
  
FROM FAS_SUB_LEDGER_MASTER 
where accounting_unit_id= $P{unitId}::int
and accounting_for_office_id = $P{officeId}::int
and to_date(month ||'-'|| + year,   'mm-yyyy') BETWEEN to_date(  ( $P{cbmonth_from} )  || '-' || ( $P{cbyear_from} ) ,   'mm-yyyy')  AND to_date( ( $P{cbmonth_to}  ) ||'-' || ( $P{cbyear_to} ) , 'mm-yyyy')
--and account_head_code in (  222109 ) 
--and sub_ledger_code=335 
--and sub_ledger_type_code = 10  

union all 

SELECT  
  year, 
  month,
  ( month ||'/' || year ) as mon_yr_disp, 
  to_date(  month || '/' || year ,'mm/yyyy') as mon_yr, 
  ACCOUNT_HEAD_CODE as acc_code,
  SUB_LEDGER_TYPE_CODE as sltype,
  SUB_LEDGER_CODE as slcode,  
  MONTH_OPENING_BALANCE,
  MONTH_OPENING_BAL_DR_CR_IND,
  CURRENT_MONTH_DEBIT,
  CURRENT_MONTH_CREDIT,
  MONTH_CLOSING_BALANCE,
  MONTH_CLOSING_BAL_DR_CR_IND, 
  'S-' || (supplement_no)::varchar as supplement_no,  
  supplement_no as supplement_no_ord
  
FROM FAS_SUB_LEDGER_MASTER_SJV
where accounting_unit_id= $P{unitId}::int
and accounting_for_office_id = $P{officeId}::int
and month=$P{cbmonth_to}::int    -- to month 
and year=$P{cbyear_to}::int  -- to year 
--and account_head_code in (  222109 ) 
--and sub_ledger_code=335 
--and sub_ledger_type_code = 10  
and supplement_no <= $P{supplement_no}::int 


) as opt1, 
(
select accounting_unit_name from fas_mst_acct_units
where accounting_unit_id= $P{unitId}::int
)as opt2
order by sltype,slcode, acc_code, mon_yr, supplement_no_ord]]></queryString>

