<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="FAS_Annexure-I"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="955"
		 pageHeight="595"
		 columnWidth="895"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="from_cashbk_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbk_yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="row1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_cashbk_yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbk_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_varying" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT row_id,
  unit_id,
  (SELECT accounting_unit_name
  FROM fas_mst_acct_units
  WHERE accounting_unit_id=unit_id
  ) AS accounting_unit_name,
  achead1,
  achead2,
  achead3,
  achead4,
  achead5,
  achead6,
  achead7,
  achead8,
  achead9,
  achead10,
  achead11,
  amt1,
  amt2,
  amt3,
  amt4,
  amt5,
  amt6,
  amt7,
  amt8,
  amt9,
 (amt1+amt2+amt3+amt4+amt5+amt6+amt7+amt8+amt9) AS total1,
  amt10,
  amt11,
 (amt1+amt2+amt3+amt4+amt5+amt6+amt7+amt8+amt9+amt10+amt11)AS total12
FROM
  (SELECT a.row_id,
    unit_id,
    power_consumption          AS achead1,
    workers_cost               AS achead2,
    materials                  AS achead3,
    chemicals                  AS achead4,
    rr_motors_pumpsets         AS achead5,
    pipe_line_burst            AS achead6,
    royalty                    AS achead7,
    original_works             AS achead8,
    OTHERS                     AS achead9,
    administrative_expenditure AS achead10,
    cost_personnel_from
    ||' to '
    ||cost_personnel_to AS achead11,
    SUM(amt_achead1)    AS amt1,
    SUM(amt_achead2)    AS amt2,
    SUM(amt_achead3)    AS amt3,
    SUM(amt_achead4)    AS amt4,
    SUM(amt_achead5)    AS amt5,
    SUM(amt_achead6)    AS amt6,
    SUM(amt_achead7)    AS amt7,
    SUM(amt_achead8)    AS amt8,
    SUM(amt_achead9)    AS amt9,
    SUM(amt_achead10)   AS amt10,
    SUM(amt_achead11)   AS amt11
  FROM
    (SELECT 1            AS row_id,
      accounting_unit_id AS unit_id ,
      accounting_for_office_id,
      CASE
        WHEN ( account_head_code =
          (SELECT power_consumption FROM fas_mst_annexure_ii WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead1,
      CASE
        WHEN ( account_head_code =
          (SELECT workers_cost FROM fas_mst_annexure_ii WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead2,
      CASE
        WHEN ( account_head_code =
          (SELECT materials FROM fas_mst_annexure_ii WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead3,
      CASE
        WHEN ( account_head_code =
          (SELECT chemicals FROM fas_mst_annexure_ii WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead4,
      CASE
        WHEN ( account_head_code =
          (SELECT rr_motors_pumpsets FROM fas_mst_annexure_ii WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead5,
      CASE
        WHEN ( account_head_code =
          (SELECT pipe_line_burst FROM fas_mst_annexure_ii WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead6,
      CASE
        WHEN ( account_head_code =
          (SELECT royalty FROM fas_mst_annexure_ii WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead7,
      CASE
        WHEN ( account_head_code =
          (SELECT original_works FROM fas_mst_annexure_ii WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead8,
      CASE
        WHEN ( account_head_code =
          (SELECT OTHERS FROM fas_mst_annexure_ii WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead9,
      CASE
        WHEN ( account_head_code =
          (SELECT administrative_expenditure FROM fas_mst_annexure_ii WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead10,
      CASE
        WHEN (account_head_code BETWEEN
          (SELECT cost_personnel_from FROM fas_mst_annexure_ii WHERE row_id=1
          )
        AND (SELECT cost_personnel_to FROM fas_mst_annexure_ii WHERE row_id=1))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead11
    FROM
      (SELECT accounting_unit_id,
        accounting_for_office_id,
        account_head_code,
        CR_DR_INDICATOR,
        SUM(DECODE(CR_DR_INDICATOR,'CR',amount,0))                                             AS cr_amount,
        SUM(DECODE(CR_DR_INDICATOR,'DR',amount,0))                                             AS dr_amount,
        (SUM(DECODE(CR_DR_INDICATOR,'DR',amount,0))-SUM(DECODE(CR_DR_INDICATOR,'CR',amount,0)))AS amount
      FROM
        (SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_journal_master m ,
          fas_journal_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.voucher_no               = t.voucher_no
        AND m.journal_status           ='L'
        AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200604,201120,201122,201124,201125,201126,201129,201138,201139,201151,222601,222602,222604,222605,222606,222607,222608,222609)
        UNION ALL
        SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_payment_master m ,
          fas_payment_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.voucher_no               = t.voucher_no
        AND m.payment_status           ='L'
    AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200604,201120,201122,201124,201125,201126,201129,201138,201139,201151,222601,222602,222604,222605,222606,222607,222608,222609)
        UNION ALL
        SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_receipt_master m ,
          fas_receipt_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.receipt_no               = t.receipt_no
        AND m.receipt_status           ='L'
          AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200604,201120,201122,201124,201125,201126,201129,201138,201139,201151,222601,222602,222604,222605,222606,222607,222608,222609)
        )
      GROUP BY accounting_unit_id ,
        accounting_for_office_id ,
        account_head_code,
        CR_DR_INDICATOR
      )
    GROUP BY accounting_unit_id,
      accounting_for_office_id ,
      account_head_code
    ORDER BY accounting_unit_id
    )a,
    fas_mst_annexure_ii b
  WHERE a.row_id=b.row_id
  GROUP BY a.row_id,
    unit_id,
    power_consumption,
    workers_cost,
    materials,
    chemicals,
    rr_motors_pumpsets,
    pipe_line_burst,
    royalty,
    original_works,
    OTHERS,
    administrative_expenditure,
    cost_personnel_from,
    cost_personnel_to
  UNION ALL
  SELECT a.row_id,
    unit_id,
    power_consumption          AS achead1,
    workers_cost               AS achead2,
    materials                  AS achead3,
    chemicals                  AS achead4,
    rr_motors_pumpsets         AS achead5,
    pipe_line_burst            AS achead6,
    royalty                    AS achead7,
    original_works             AS achead8,
    OTHERS                     AS achead9,
    administrative_expenditure AS achead10,
    cost_personnel_from
    ||' to '
    ||cost_personnel_to AS achead11,
    SUM(amt_achead1)    AS amt1,
    SUM(amt_achead2)    AS amt2,
    SUM(amt_achead3)    AS amt3,
    SUM(amt_achead4)    AS amt4,
    SUM(amt_achead5)    AS amt5,
    SUM(amt_achead6)    AS amt6,
    SUM(amt_achead7)    AS amt7,
    SUM(amt_achead8)    AS amt8,
    SUM(amt_achead9)    AS amt9,
    SUM(amt_achead10)   AS amt10,
    SUM(amt_achead11)   AS amt11
  FROM
    (SELECT 2            AS row_id,
      accounting_unit_id AS unit_id ,
      accounting_for_office_id,
      CASE
        WHEN ( account_head_code =
          (SELECT power_consumption FROM fas_mst_annexure_ii WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead1,
      CASE
        WHEN ( account_head_code =
          (SELECT workers_cost FROM fas_mst_annexure_ii WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead2,
      CASE
        WHEN ( account_head_code =
          (SELECT materials FROM fas_mst_annexure_ii WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead3,
      CASE
        WHEN ( account_head_code =
          (SELECT chemicals FROM fas_mst_annexure_ii WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead4,
      CASE
        WHEN ( account_head_code =
          (SELECT rr_motors_pumpsets FROM fas_mst_annexure_ii WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead5,
      CASE
        WHEN ( account_head_code =
          (SELECT pipe_line_burst FROM fas_mst_annexure_ii WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead6,
      CASE
        WHEN ( account_head_code =
          (SELECT royalty FROM fas_mst_annexure_ii WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead7,
      CASE
        WHEN ( account_head_code =
          (SELECT original_works FROM fas_mst_annexure_ii WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead8,
      CASE
        WHEN ( account_head_code =
          (SELECT OTHERS FROM fas_mst_annexure_ii WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead9,
      CASE
        WHEN ( account_head_code =
          (SELECT administrative_expenditure FROM fas_mst_annexure_ii WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead10,
      CASE
        WHEN (account_head_code BETWEEN
          (SELECT cost_personnel_from FROM fas_mst_annexure_ii WHERE row_id=2
          )
        AND (SELECT cost_personnel_to FROM fas_mst_annexure_ii WHERE row_id=2))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead11
    FROM
      (SELECT accounting_unit_id,
        accounting_for_office_id,
        account_head_code,
        CR_DR_INDICATOR,
        SUM(DECODE(CR_DR_INDICATOR,'CR',amount,0))                                             AS cr_amount,
        SUM(DECODE(CR_DR_INDICATOR,'DR',amount,0))                                             AS dr_amount,
        (SUM(DECODE(CR_DR_INDICATOR,'DR',amount,0))-SUM(DECODE(CR_DR_INDICATOR,'CR',amount,0)))AS amount
      FROM
        (SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_journal_master m ,
          fas_journal_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.voucher_no               = t.voucher_no
        AND m.journal_status           ='L'
    AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200601,200720,200721,200722,200723,200724,200725,200726,200728,200729,200738,200740,200742,200750,200751,200752,222201,222202,222203,222204,222205,222206,222207,222208,222209)
        UNION ALL
        SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_payment_master m ,
          fas_payment_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.voucher_no               = t.voucher_no
        AND m.payment_status           ='L'
    AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200601,200720,200721,200722,200723,200724,200725,200726,200728,200729,200738,200740,200742,200750,200751,200752,222201,222202,222203,222204,222205,222206,222207,222208,222209)
        UNION ALL
        SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_receipt_master m ,
          fas_receipt_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.receipt_no               = t.receipt_no
        AND m.receipt_status           ='L'
    AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200601,200720,200721,200722,200723,200724,200725,200726,200728,200729,200738,200740,200742,200750,200751,200752,222201,222202,222203,222204,222205,222206,222207,222208,222209)
        )
      GROUP BY accounting_unit_id ,
        accounting_for_office_id ,
        account_head_code,
        CR_DR_INDICATOR
      )
    GROUP BY accounting_unit_id,
      accounting_for_office_id ,
      account_head_code
    ORDER BY accounting_unit_id
    )a,
    fas_mst_annexure_ii b
  WHERE a.row_id=b.row_id
  GROUP BY a.row_id,
    unit_id,
    power_consumption,
    workers_cost,
    materials,
    chemicals,
    rr_motors_pumpsets,
    pipe_line_burst,
    royalty,
    original_works,
    OTHERS,
    administrative_expenditure,
    cost_personnel_from,
    cost_personnel_to
  UNION ALL
  SELECT a.row_id,
    unit_id,
    power_consumption          AS achead1,
    workers_cost               AS achead2,
    materials                  AS achead3,
    chemicals                  AS achead4,
    rr_motors_pumpsets         AS achead5,
    pipe_line_burst            AS achead6,
    royalty                    AS achead7,
    original_works             AS achead8,
    OTHERS                     AS achead9,
    administrative_expenditure AS achead10,
    cost_personnel_from
    ||' to '
    ||cost_personnel_to AS achead11,
    SUM(amt_achead1)    AS amt1,
    SUM(amt_achead2)    AS amt2,
    SUM(amt_achead3)    AS amt3,
    SUM(amt_achead4)    AS amt4,
    SUM(amt_achead5)    AS amt5,
    SUM(amt_achead6)    AS amt6,
    SUM(amt_achead7)    AS amt7,
    SUM(amt_achead8)    AS amt8,
    SUM(amt_achead9)    AS amt9,
    SUM(amt_achead10)   AS amt10,
    SUM(amt_achead11)   AS amt11
  FROM
    (SELECT 3            AS row_id,
      accounting_unit_id AS unit_id ,
      accounting_for_office_id,
      CASE
        WHEN ( account_head_code =
          (SELECT power_consumption FROM fas_mst_annexure_ii WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead1,
      CASE
        WHEN ( account_head_code =
          (SELECT workers_cost FROM fas_mst_annexure_ii WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead2,
      CASE
        WHEN ( account_head_code =
          (SELECT materials FROM fas_mst_annexure_ii WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead3,
      CASE
        WHEN ( account_head_code =
          (SELECT chemicals FROM fas_mst_annexure_ii WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead4,
      CASE
        WHEN ( account_head_code =
          (SELECT rr_motors_pumpsets FROM fas_mst_annexure_ii WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead5,
      CASE
        WHEN ( account_head_code =
          (SELECT pipe_line_burst FROM fas_mst_annexure_ii WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead6,
      CASE
        WHEN ( account_head_code =
          (SELECT royalty FROM fas_mst_annexure_ii WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead7,
      CASE
        WHEN ( account_head_code =
          (SELECT original_works FROM fas_mst_annexure_ii WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead8,
      CASE
        WHEN ( account_head_code =
          (SELECT OTHERS FROM fas_mst_annexure_ii WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead9,
      CASE
        WHEN ( account_head_code =
          (SELECT administrative_expenditure FROM fas_mst_annexure_ii WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead10,
      CASE
        WHEN (account_head_code BETWEEN
          (SELECT cost_personnel_from FROM fas_mst_annexure_ii WHERE row_id=3
          )
        AND (SELECT cost_personnel_to FROM fas_mst_annexure_ii WHERE row_id=3))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead11
    FROM
      (SELECT accounting_unit_id,
        accounting_for_office_id,
        account_head_code,
        CR_DR_INDICATOR,
        SUM(DECODE(CR_DR_INDICATOR,'CR',amount,0))                                             AS cr_amount,
        SUM(DECODE(CR_DR_INDICATOR,'DR',amount,0))                                             AS dr_amount,
        (SUM(DECODE(CR_DR_INDICATOR,'DR',amount,0))-SUM(DECODE(CR_DR_INDICATOR,'CR',amount,0)))AS amount
      FROM
        (SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_journal_master m ,
          fas_journal_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.voucher_no               = t.voucher_no
        AND m.journal_status           ='L'
    AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200602,200820,200821,200822,200823,200824,200825,200826,200828,200829,200838,200839,200840,200850,200851,222301,222302,222303,222304,222305,222306,222307,222309)
        UNION ALL
        SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_payment_master m ,
          fas_payment_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.voucher_no               = t.voucher_no
        AND m.payment_status           ='L'
    AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200602,200820,200821,200822,200823,200824,200825,200826,200828,200829,200838,200839,200840,200850,200851,222301,222302,222303,222304,222305,222306,222307,222309)
        UNION ALL
        SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_receipt_master m ,
          fas_receipt_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.receipt_no               = t.receipt_no
        AND m.receipt_status           ='L'
    AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200602,200820,200821,200822,200823,200824,200825,200826,200828,200829,200838,200839,200840,200850,200851,222301,222302,222303,222304,222305,222306,222307,222309)
        )
      GROUP BY accounting_unit_id ,
        accounting_for_office_id ,
        account_head_code,
        CR_DR_INDICATOR
      )
    GROUP BY accounting_unit_id,
      accounting_for_office_id ,
      account_head_code
    ORDER BY accounting_unit_id
    )a,
    fas_mst_annexure_ii b
  WHERE a.row_id=b.row_id
  GROUP BY a.row_id,
    unit_id,
    power_consumption,
    workers_cost,
    materials,
    chemicals,
    rr_motors_pumpsets,
    pipe_line_burst,
    royalty,
    original_works,
    OTHERS,
    administrative_expenditure,
    cost_personnel_from,
    cost_personnel_to
  UNION ALL
  SELECT a.row_id,
    unit_id,
    power_consumption          AS achead1,
    workers_cost               AS achead2,
    materials                  AS achead3,
    chemicals                  AS achead4,
    rr_motors_pumpsets         AS achead5,
    pipe_line_burst            AS achead6,
    royalty                    AS achead7,
    original_works             AS achead8,
    OTHERS                     AS achead9,
    administrative_expenditure AS achead10,
    cost_personnel_from
    ||' to '
    ||cost_personnel_to AS achead11,
    SUM(amt_achead1)    AS amt1,
    SUM(amt_achead2)    AS amt2,
    SUM(amt_achead3)    AS amt3,
    SUM(amt_achead4)    AS amt4,
    SUM(amt_achead5)    AS amt5,
    SUM(amt_achead6)    AS amt6,
    SUM(amt_achead7)    AS amt7,
    SUM(amt_achead8)    AS amt8,
    SUM(amt_achead9)    AS amt9,
    SUM(amt_achead10)   AS amt10,
    SUM(amt_achead11)   AS amt11
  FROM
    (SELECT 4            AS row_id,
      accounting_unit_id AS unit_id ,
      accounting_for_office_id,
      CASE
        WHEN ( account_head_code =
          (SELECT power_consumption FROM fas_mst_annexure_ii WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead1,
      CASE
        WHEN ( account_head_code =
          (SELECT workers_cost FROM fas_mst_annexure_ii WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead2,
      CASE
        WHEN ( account_head_code =
          (SELECT materials FROM fas_mst_annexure_ii WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead3,
      CASE
        WHEN ( account_head_code =
          (SELECT chemicals FROM fas_mst_annexure_ii WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead4,
      CASE
        WHEN ( account_head_code =
          (SELECT rr_motors_pumpsets FROM fas_mst_annexure_ii WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead5,
      CASE
        WHEN ( account_head_code =
          (SELECT pipe_line_burst FROM fas_mst_annexure_ii WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead6,
      CASE
        WHEN ( account_head_code =
          (SELECT royalty FROM fas_mst_annexure_ii WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead7,
      CASE
        WHEN ( account_head_code =
          (SELECT original_works FROM fas_mst_annexure_ii WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead8,
      CASE
        WHEN ( account_head_code =
          (SELECT OTHERS FROM fas_mst_annexure_ii WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead9,
      CASE
        WHEN ( account_head_code =
          (SELECT administrative_expenditure FROM fas_mst_annexure_ii WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead10,
      CASE
        WHEN (account_head_code BETWEEN
          (SELECT cost_personnel_from FROM fas_mst_annexure_ii WHERE row_id=4
          )
        AND (SELECT cost_personnel_to FROM fas_mst_annexure_ii WHERE row_id=4))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead11
    FROM
      (SELECT accounting_unit_id,
        accounting_for_office_id,
        account_head_code,
        CR_DR_INDICATOR,
        SUM(DECODE(CR_DR_INDICATOR,'CR',amount,0))                                             AS cr_amount,
        SUM(DECODE(CR_DR_INDICATOR,'DR',amount,0))                                             AS dr_amount,
        (SUM(DECODE(CR_DR_INDICATOR,'DR',amount,0))-SUM(DECODE(CR_DR_INDICATOR,'CR',amount,0)))AS amount
      FROM
        (SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_journal_master m ,
          fas_journal_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.voucher_no               = t.voucher_no
        AND m.journal_status           ='L'
    AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200605,201020,201022,201023,201024,201025,201026,201028,201029,201032,201038,201039,201040,201042,201050,201051,222501,222502,222503,222504,222505,222506,222507,222509)
        UNION ALL
        SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_payment_master m ,
          fas_payment_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.voucher_no               = t.voucher_no
        AND m.payment_status           ='L'
     AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200605,201020,201022,201023,201024,201025,201026,201028,201029,201032,201038,201039,201040,201042,201050,201051,222501,222502,222503,222504,222505,222506,222507,222509)
        UNION ALL
        SELECT m.accounting_unit_id ,
          m.accounting_for_office_id ,
          m.cashbook_month,
          m.cashbook_year,
          t.account_head_code,
          t.CR_DR_INDICATOR,
          t.amount
        FROM fas_receipt_master m ,
          fas_receipt_transaction t
        WHERE m.accounting_unit_id     = t.accounting_unit_id
        AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
        AND m.cashbook_month           = t.cashbook_month
        AND m.cashbook_year            = t.cashbook_year
        AND m.receipt_no               = t.receipt_no
        AND m.receipt_status           ='L'
    AND to_date(m.cashbook_month
          ||'-'
          || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date(1
          || '-'
          || 2012 , 'mm-yyyy')
        AND to_date( 12
          ||'-'
          || 2012 , 'mm-yyyy')
        AND t.account_head_code IN(200605,201020,201022,201023,201024,201025,201026,201028,201029,201032,201038,201039,201040,201042,201050,201051,222501,222502,222503,222504,222505,222506,222507,222509)
        )
      GROUP BY accounting_unit_id ,
        accounting_for_office_id ,
        account_head_code,
        CR_DR_INDICATOR
      )
    GROUP BY accounting_unit_id,
      accounting_for_office_id ,
      account_head_code
    ORDER BY accounting_unit_id
    )a,
    fas_mst_annexure_ii b
  WHERE a.row_id=b.row_id
  GROUP BY a.row_id,
    unit_id,
    power_consumption,
    workers_cost,
    materials,
    chemicals,
    rr_motors_pumpsets,
    pipe_line_burst,
    royalty,
    original_works,
    OTHERS,
    administrative_expenditure,
    cost_personnel_from,
    cost_personnel_to
  )
ORDER BY row_id,
  unit_id]]></queryString>

