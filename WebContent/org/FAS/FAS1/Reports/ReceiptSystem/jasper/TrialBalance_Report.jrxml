<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="TrialBalance_Report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1044"
		 pageHeight="831"
		 columnWidth="984"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_monthvalue" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select
    a.accounting_unit_id AS "ACCOUNTING_UNIT_ID", 
    a.account_head_code AS "ACCOUNT_HEAD_CODE",
    a.debit_opening_balance as "DEBIT_OPENING_BALANCE",
    a.credit_opening_balance AS "CREDIT_OPENING_BALANCE",
    a.current_month_debit AS "CURRENT_MONTH_DEBIT",
    a.current_month_credit AS "CURRENT_MONTH_CREDIT",
    a.debit_closing_balance AS "DEBIT_CLOSING_BALANCE",
    a.credit_closing_balance AS "CREDIT_CLOSING_BALANCE",
    b.account_head_desc AS "ACCOUNT_HEAD_DESC",
    d.accounting_unit_name AS "ACCOUNTING_UNIT_NAME",
    (x)::varchar as "X",
    (y)::varchar as "Y"
from 
    fas_trial_balance a,
    com_mst_account_heads b,
    fas_mst_acct_units d,
( select 
       sum(current_month_debit) as x,
       sum(current_month_credit) as y 
    from 
       fas_trial_balance_cmp 
   where 
        cashbook_month between ($P{from_cashbookmonth}::int) and 
                                                   ($P{to_cashbookmonth}::int) and
         cashbook_year between  ($P{from_cashbookyear}::int) and
                                                  ($P{to_cashbookyear}::int) and 
         accounting_unit_id=($P{accountingunitid}::int)
) as opt1
where
a.account_head_code=b.account_head_code and
a.accounting_unit_id=d.accounting_unit_id and
a.cashbook_month between ($P{from_cashbookmonth}::int)  and ($P{to_cashbookmonth}::int)  and 
a.cashbook_year  between  ($P{from_cashbookyear}::int) and  ($P{to_cashbookyear}::int) and
a.accounting_unit_id=($P{accountingunitid}::int)

order  by a.account_head_code]]></queryString>

