	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="fromfinyear" isForPrompting="true" class="java.lang.String"/>
	<parameter name="tofinyear" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unit" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT X.account_head_code AS account_head_code,
  X.accounting_unit_id     AS accounting_unit_id,
  X.fin_year               AS fin_year,
  X.current_month_debit    AS current_month_debit,
  X.current_month_credit   AS current_month_credit,
  Y.ACCOUNTING_UNIT_NAME   AS ACCOUNTING_UNIT_NAME,
  c.ACCOUNT_HEAD_DESC      AS ACCOUNT_HEAD_DESC
FROM
  (SELECT a.account_head_code,
    a.accounting_unit_id,
    fin_year,
    SUM(a.current_month_debit)  AS current_month_debit,
    SUM(a.current_month_credit) AS current_month_credit
  FROM FAS_TRAIL_BALANCE_DATA_9507 a
  WHERE fin_year BETWEEN $P{fromfinyear} AND $P{tofinyear}
    GROUP BY a.fin_year,
    a.accounting_unit_id,
    a.account_head_code
  ORDER BY a.fin_year,
    a.accounting_unit_id,
    a.account_head_code
  ) X
LEFT OUTER JOIN
  (SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_UNIT_NAME
  FROM FAS_MST_ACCNT_UNIT_OLD9507 b
  ) Y
ON X.ACCOUNTING_UNIT_ID=Y.ACCOUNTING_UNIT_ID
LEFT OUTER JOIN
  ( SELECT ACCOUNT_HEAD_CODE,ACCOUNT_HEAD_DESC FROM com_mst_account_heads
  )c
ON X.account_head_code=c.ACCOUNT_HEAD_CODE]]></queryString>

