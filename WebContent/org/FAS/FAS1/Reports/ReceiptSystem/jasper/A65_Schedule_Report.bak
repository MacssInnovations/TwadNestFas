	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
      a.accounting_unit_id,
      (select accounting_unit_name from fas_mst_acct_units where accounting_unit_id=a.accounting_unit_id) as unit_name,
      a.cheque_number,
      a.cheque_date,
      a.cheque_amount,
      a.dd_in_favour_of,
      a.dd_number,
      a.dd_date,
      a.dd_amount,
      a.commission_charges,
      b.voucher_no,    
      b.cheque_dd_date,
      a.remarks      
from
(
        SELECT m.accounting_unit_id,
          m.accounting_for_office_id,
          m.cashbook_year,
          m.cashbook_month,
          m.voucher_no,
          m.cheque_date,
          m.cheque_number,
          m.cheque_amount,
          m.remarks,
          t.dd_number,
          t.dd_date,
          t.dd_amount,
	  t.commission_charges,
          t.dd_in_favour_of
        FROM fas_yourself_cheque_mst m,
          fas_yourself_cheque_trans t
        WHERE m.accounting_unit_id = t.accounting_unit_id
         AND m.accounting_for_office_id = t.accounting_for_office_id
         AND m.cashbook_year = t.cashbook_year
         AND m.cashbook_month = t.cashbook_month
         AND m.voucher_no = t.voucher_no
         AND m.accounting_unit_id =$P{acc_unit_id}
         AND m.accounting_for_office_id =$P{off_id}
         AND m.cashbook_year =$P{yr}
         AND m.cashbook_month =$P{mon}
)a
left outer join
(
        SELECT m.accounting_unit_id,
          m.accounting_for_office_id,
          m.cashbook_year,
          m.cashbook_month,
          t.voucher_no,
          t.cheque_dd_no,
          t.cheque_dd_date
        FROM fas_payment_master m,
             fas_payment_transaction t
        WHERE m.accounting_unit_id = t.accounting_unit_id
         AND m.accounting_for_office_id = t.accounting_for_office_id
         AND m.cashbook_year = t.cashbook_year
         AND m.cashbook_month = t.cashbook_month
         AND m.voucher_no = t.voucher_no
         AND m.accounting_unit_id =$P{acc_unit_id}
         AND m.accounting_for_office_id =$P{off_id}
         AND m.cashbook_year =$P{yr}
         AND m.cashbook_month =$P{mon}
         AND m.payment_status='L'
         AND t.cheque_or_dd='D'
)b
on a.accounting_unit_id = b.accounting_unit_id
   AND a.accounting_for_office_id = b.accounting_for_office_id
   AND a.cashbook_year = b.cashbook_year
   AND a.cashbook_month = b.cashbook_month
   AND a.voucher_no = b.voucher_no
   AND a.dd_number::varchar=b.cheque_dd_no
order by 
     cheque_number,
     cheque_date]]></queryString>

