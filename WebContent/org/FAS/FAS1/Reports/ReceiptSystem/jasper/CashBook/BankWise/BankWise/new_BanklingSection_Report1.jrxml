<jasperReport
		 name="new_BanklingSection_Report1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="842"
		 columnWidth="818"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="Str_dt" isForPrompting="false" class="java.lang.String"/>
	<parameter name="acpara" isForPrompting="false" class="java.lang.String"/>
	<parameter name="txtfrom" isForPrompting="false" class="java.lang.String"/>
	<parameter name="txtto" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[(SELECT 1                      AS type,
  'Fund Transfer Data from HO' AS head,
  M.Accounting_Unit_Id ,
  M.Accounting_For_Office_Id,
  M.Cashbook_Year ,
  M.Cashbook_Month ,
  T.Voucher_No Vrno,
  T.Sl_No Slno,
  T.Transfer_To_Office_Id Off_Id,
  O.Office_Name Off_Name ,
  T.Account_Head_Code Head_Code,
  T.Office_Account_No Acc_No,
  M.Total_Amount,
  t.AMOUNT amount,
  T.Cheque_Dd_No ,
  t.CHEQUE_OR_DD
  ||'-'
  || T.Cheque_Dd_No                      AS Chedd,
  TO_CHAR(t.CHEQUE_DD_DATE,'DD/MM/YYYY') AS cheDDdate,
  DECODE(T.Particulars,NULL,'--',T.Particulars)Particulars
FROM FAS_FUND_TRF_FROM_HO_MASTER m,
  FAS_FUND_TRF_FROM_HO_TRN t,
  Com_Mst_Offices O
WHERE M.Accounting_Unit_Id    =T.Accounting_Unit_Id
AND M.Accounting_For_Office_Id=T.Accounting_For_Office_Id
AND M.Cashbook_Year           =T.Cashbook_Year
AND M.Cashbook_Month          =T.Cashbook_Month
AND M.VOUCHER_NO              =T.VOUCHER_NO
AND t.ACCOUNTING_UNIT_ID      =$P{accountingunitid}
AND T.Transfer_To_Office_Id   =O.Office_Id
AND T.Accounting_For_Office_Id=$P{accountingofficeid}
AND T.Cashbook_Year           =$P{txtCB_Year}
AND T.Cashbook_Month          =$P{txtCB_Month}
)
UNION ALL
  (SELECT 2                       AS type,
    'Inter Bank Transfer from HO' AS head,
    M.Accounting_Unit_Id ,
    M.Accounting_For_Office_Id,
    M.Cashbook_Year ,
    M.Cashbook_Month ,
    m.VOUCHER_NO Vrno,
    0 Slno,
    M.From_Bank_Id Off_Id,
    bk.BANK_NAME
    ||'-'
    ||'-'
    || m.FROM_ACCOUNT_NO Off_NAME,
    M.Dr_Account_Head_Code Head_Code,
    M.From_Account_No AS Acc_No,
    M.Total_Amount    AS Total_Amount,
    m.TOTAL_AMOUNT    AS AMOUNT,
    M.Cheque_Dd_No ,
    M.CHEQUE_OR_DD
    ||'-'
    || M.Cheque_Dd_No                      AS Chedd,
    TO_CHAR(M.CHEQUE_DD_DATE,'DD/MM/YYYY') AS cheDDdate,
    m.PARTICULARS
  FROM FAS_INTER_BANK_TRF_AT_HO m,
    FAS_MST_BANKS bk,
    FAS_MST_BANK_BRANCHES br
  WHERE M.Accounting_Unit_Id    =$P{accountingunitid}
  AND m.ACCOUNTING_FOR_OFFICE_ID=$P{accountingofficeid}
  AND M.Cashbook_Year           =$P{txtCB_Year}
  AND M.Cashbook_Month          =$P{txtCB_Month}
  AND m.TRANSFER_STATUS         ='L'
  AND m.FROM_BANK_ID            =br.BANK_ID
  AND m.FROM_BRANCH_ID          =br.BRANCH_ID
  AND M.From_Bank_Id            =Bk.Bank_Id
  )
UNION ALL
  (SELECT 3                  AS type,
    'Final Payments from HO' AS head,
    M.Accounting_Unit_Id ,
    M.Accounting_For_Office_Id,
    M.Cashbook_Year ,
    M.Cashbook_Month ,
    T.Voucher_No Vrno ,
    T.Sl_No Slno ,
    0 AS off_id,
    M.Paid_To Off_Name,
    T.Account_Head_Code AS Head_Code,
    t.account_no        AS Acc_No,
    M.Total_Amount      AS Total_Amount,
    T.Amount,
    T.Cheque_Dd_No ,
    t.CHEQUE_OR_DD
    ||'-'
    || T.Cheque_Dd_No                      AS Chedd,
    TO_CHAR(T.Cheque_Dd_Date,'DD/MM/YYYY') AS Chedddate,
    T.Particulars
  FROM Fas_Payment_Master M,
    Fas_Payment_Transaction T
  WHERE M.Accounting_Unit_Id    =T.Accounting_Unit_Id
  AND M.Accounting_For_Office_Id=T.Accounting_For_Office_Id
  AND M.Cashbook_Year           =T.Cashbook_Year
  AND M.Cashbook_Month          =T.Cashbook_Month
  AND M.Voucher_No              =T.Voucher_No
  AND M.Accounting_Unit_Id      =$P{accountingunitid}
  AND M.Accounting_For_Office_Id=$P{accountingofficeid}
  AND M.Cashbook_Year           =$P{txtCB_Year}
  AND M.Cashbook_Month          =$P{txtCB_Month}
  AND Payment_Status            ='L'
  AND M.Created_By_Module       ='BPF'
  )
UNION ALL
  (SELECT $P{txtCB_Month}       AS type,
    'Fund Receipt Data from HO' AS head,
    M.Accounting_Unit_Id ,
    M.Accounting_For_Office_Id,
    M.Cashbook_Year ,
    M.Cashbook_Month ,
    t.receipt_no Vrno,
    T.Sl_No Slno,
    --  SUB_LEDGER_TYPE_CODE ,
    --  (SELECT SL_CODENAME
    --  FROM SL_TYPE_CODE_NAME_VIEW_M
    --  WHERE SL_TYPE=SUB_LEDGER_TYPE_CODE
    --  AND SL_CODE  =SUB_LEDGER_CODE
    --  ) AS SLNAME ,
    0 AS Off_Id,
    M.Received_From Off_Name,
    T.Account_Head_Code Head_Code,
    M.Account_No   AS Acc_No,
    M.Total_Amount AS Total_Amount,
    T.Amount,
    T.Cheque_Dd_No,
    t.CHEQUE_OR_DD
    ||'-'
    || T.Cheque_Dd_No                      AS Chedd,
    TO_CHAR(T.Cheque_Dd_Date,'DD/MM/YYYY') AS Chedddate,
    T.Particulars
  FROM Fas_Receipt_Master m,
    FAS_RECEIPT_TRANSACTION t
  WHERE M.Accounting_Unit_Id    =T.Accounting_Unit_Id
  AND M.Accounting_For_Office_Id=T.Accounting_For_Office_Id
  AND M.Cashbook_Year           =T.Cashbook_Year
  AND M.Cashbook_Month          =T.Cashbook_Month
  AND m.receipt_no              =t.receipt_no
  AND M.Accounting_Unit_Id      =$P{accountingunitid}
  AND M.Accounting_For_Office_Id=$P{accountingofficeid}
  AND M.Cashbook_Year           =$P{txtCB_Year}
  AND M.Cashbook_Month          =$P{txtCB_Month}
  AND M.Created_By_Module       ='BR'
  AND m.Receipt_Status          ='L'
  )
UNION ALL
  (SELECT $P{accountingunitid}    AS type,
    'Inter Bank Transfer from HO' AS head,
    M.Accounting_Unit_Id ,
    M.Accounting_For_Office_Id,
    M.Cashbook_Year ,
    M.Cashbook_Month ,
    m.VOUCHER_NO Vrno,
    0 Slno,
    m.to_bank_id Off_Id,
    bk.BANK_NAME
    ||'-'
    ||'-'
    || m.to_account_no Off_NAME,
    m.cr_account_head_code Head_Code,
    m.to_account_no AS Acc_No,
    M.Total_Amount  AS Total_Amount,
    m.TOTAL_AMOUNT  AS AMOUNT,
    M.Cheque_Dd_No,
    M.CHEQUE_OR_DD
    ||'-'
    || M.Cheque_Dd_No                      AS Chedd,
    TO_CHAR(M.CHEQUE_DD_DATE,'DD/MM/YYYY') AS cheDDdate,
    m.PARTICULARS
  FROM FAS_INTER_BANK_TRF_AT_HO m,
    FAS_MST_BANKS bk,
    FAS_MST_BANK_BRANCHES br
  WHERE M.Accounting_Unit_Id    =$P{accountingunitid}
  AND m.ACCOUNTING_FOR_OFFICE_ID=$P{accountingofficeid}
  AND M.Cashbook_Year           =$P{txtCB_Year}
  AND M.Cashbook_Month          =$P{txtCB_Month}
  AND m.TRANSFER_STATUS         ='L'
  AND M.To_Bank_Id              =Br.Bank_Id
  AND M.To_Branch_Id            =Br.Branch_Id
  AND M.To_Bank_Id              =Bk.Bank_Id
  )
UNION ALL
  (SELECT 6                AS type,
    'Fund Receipt from HO' AS head,
    M.Accounting_Unit_Id ,
    M.Accounting_For_Office_Id,
    M.Cashbook_Year ,
    M.Cashbook_Month ,
    m.receipt_no Vrno,
    0 Slno,
    m.received_from_office_id Off_Id,
    bk.BANK_NAME
    ||'-'
    ||'-'
    || M.Office_Account_No Off_Name,
    m.cr_account_head_code Head_Code,
    M.OFFICE_ACCOUNT_NO AS Acc_No,
    M.Total_Amount      AS Total_Amount,
    m.TOTAL_AMOUNT      AS AMOUNT,
    M.Cheque_Dd_No ,
    M.CHEQUE_OR_DD
    ||'-'
    || M.Cheque_Dd_No                    AS Chedd,
    TO_CHAR(M.RECEIPT_DATE,'DD/MM/YYYY') AS cheDDdate,
    m.PARTICULARS
  FROM FAS_FUND_RECEIPT_BY_HO m,
    FAS_MST_BANKS bk,
    FAS_MST_BANK_BRANCHES br
  WHERE M.Accounting_Unit_Id    =$P{accountingunitid}
  AND m.ACCOUNTING_FOR_OFFICE_ID=$P{accountingofficeid}
  AND M.Cashbook_Year           =$P{txtCB_Year}
  AND M.Cashbook_Month          =$P{txtCB_Month}
  AND m.RECEIPT_STATUS          ='L'
  AND m.HO_BANK_ID              =br.BANK_ID
  AND M.Ho_Branch_Id            =Br.Branch_Id
  AND M.Ho_Bank_Id              =Bk.Bank_Id
  )
ORDER BY Cheque_Dd_No ,
  Vrno,
  Off_Id ,
  Slno]]></queryString>

	<field name="TYPE" class="java.math.BigDecimal"/>
	<field name="HEAD" class="java.lang.String"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
