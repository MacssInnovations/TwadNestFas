<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="CBREceipt_bankwise"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="870"
		 pageHeight="850"
		 columnWidth="812"
		 columnSpacing="0"
		 leftMargin="29"
		 rightMargin="29"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunit_name" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="bankOpeningBal_for_COL" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="bankOpeningBal_for_OPR" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="Str_dt" isForPrompting="true" class="java.lang.String"/>
	<parameter name="acpara" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT b.ACCOUNTING_UNIT_NAME,
  a.ACCOUNTING_UNIT_ID,
  a.ACCOUNTING_FOR_OFFICE_ID,
  a.CASHBOOK_YEAR,
  a.CASHBOOK_MONTH,
  a.vouDate,
  A.Recno,A.Acno,
  Decode(A.Recpart,Null,'-',A.Recpart)Recpart, A.Recrecfrom,
  A.Recacchead,a.Dr_head,
  A.Recamt,A.Cr_Amt,A.Dr_Amt,
  a.recCheqDD_no,a.dr_part,
  a.recChequeDD_date,  A.Bid,
  (SELECT K.Bank_Name FROM Fas_Mst_Banks K WHERE K.Bank_Id=A.Bid
  )As Bank_Name,  
  A.Bran_Id,
  (Select D.Branch_Name From FAS_MST_BANK_BRANCHES D
where a.Bid=d.bank_id and A.Bran_Id             =d.Bank_Id)branch_name,
  c.Ac_Operational_Mode_Id,
  Bank.Bank_Short_Name,
  A.Type,
  CASE
    WHEN Type='R'
    THEN A.Recamt
    ELSE 0
  END AS Rec_Amt,
  CASE
    WHEN Type='P'
    THEN A.Recamt
    ELSE 0
  End As Pay_Amt,
  Typedec,
  Bank.Bank_Short_Name||' '|| c.Ac_Operational_Mode_Id||' '||b.ACCOUNTING_UNIT_NAME as details
FROM
  (SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.receipt_date                                    AS vouDate,
    t.receipt_no                                      AS recNo,
    t.particulars                                     AS recPart,
    T.Account_Head_Code                               As Recacchead,
      m.ACCOUNT_HEAD_CODE as Dr_head,
    DECODE(t.cr_dr_indicator,'CR',t.amount,-t.amount) AS recAmt,
     M.Total_Amount Dr_Amt,
    t.amount cr_amt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no) AS recCheqDD_no,
    t.cheque_dd_date  AS recChequeDD_date,
    M.Received_From   AS Recrecfrom,
    M.Account_No      AS Acno,
    M.Bank_Id         As Bid,
    m.branch_id as bran_id,
    'R'               AS type,
    'R1'              As Typedec,
    m.REMARKS dr_part
  FROM FAS_RECEIPT_MASTER m,
    FAS_RECEIPT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.receipt_no               = m.receipt_no
  AND M.Receipt_Status!          ='C'
  AND M.Created_By_Module       IN('CR','SC') 
  --1
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.receipt_date                                    AS vouDate,
    t.receipt_no                                      AS recNo,
    t.particulars                                     AS recPart,
    T.Account_Head_Code                               As Recacchead,
      m.ACCOUNT_HEAD_CODE as Dr_head,
    Decode(T.Cr_Dr_Indicator,'CR',T.Amount,-T.Amount) As Recamt,
     m.total_amount dr_amt,
    t.amount cr_amt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no) AS recCheqDD_no,
    t.cheque_dd_date  AS recChequeDD_date,
    M.Received_From   AS Recrecfrom,
    m.ACCOUNT_NO      AS acno,
    M.Bank_Id         As Bid,
    m.branch_id as bran_id,
    'R'               AS type,
    'R2'              As Typedec,
     m.REMARKS dr_part
  FROM FAS_RECEIPT_MASTER m,
    FAS_RECEIPT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.receipt_no               = m.receipt_no
  AND M.Receipt_Status!          ='C'
  AND M.Created_By_Module        ='BR' 
  --2
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.payment_date                                    AS vouDate,
    t.voucher_no                                      AS recNo,
    t.particulars                                     AS recPart,
    T.Account_Head_Code                               As Recacchead,
     m.ACCOUNT_HEAD_CODE as Dr_head,
    DECODE(t.cr_dr_indicator,'DR',t.amount,-t.amount) AS recAmt,
     M.Total_Amount Dr_Amt,
   t.amount cr_amt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no) AS recCheqDD_no,
    t.cheque_dd_date  AS recChequeDD_date,
    M.Paid_To         AS Recrecfrom,
    m.ACCOUNT_NO      AS acno,
    M.Bank_Id         As Bid,
    m.branch_id as bran_id,
    'P'               AS type,
    'P1'              As Typedec,
     m.REMARKS dr_part
  FROM FAS_PAYMENT_MASTER m,
    FAS_PAYMENT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND M.Payment_Status!          ='C'
  AND M.Created_By_Module       IN ('BPP','BPF','NP')
  UNION ALL
  --3
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.payment_date                                    AS vouDate,
    t.voucher_no                                      AS recNo,
    t.particulars                                     AS recPart,
    T.Account_Head_Code                               As Recacchead,
     m.ACCOUNT_HEAD_CODE as Dr_head,
    DECODE(t.cr_dr_indicator,'DR',t.amount,-t.amount) AS recAmt,
     M.Total_Amount Dr_Amt,
   t.amount cr_amt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no) AS recCheqDD_no,
    t.cheque_dd_date  AS recChequeDD_date,
    M.Paid_To         AS Recrecfrom,
    m.ACCOUNT_NO      AS acno,
    M.Bank_Id         As Bid,
    m.branch_id AS   bran_id,

    'P'               AS type,
    'P2'              As Typedec,
     m.REMARKS dr_part
  FROM FAS_PAYMENT_MASTER m,
    FAS_PAYMENT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND M.Payment_Status!          ='C'
  AND M.Created_By_Module       IN ('SC') 
  UNION ALL
  --4
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    DATE_OF_TRANSFER     AS vouDate,
    VOUCHER_NO           AS recNo,
    Particulars          As Recpart,
    null As Recacchead,    
    Dr_Account_Head_Code  as Dr_head,
    TOTAL_AMOUNT         AS recAmt,
    Total_Amount         As dr_Amt,   
    0 as cr_amt,
    DECODE(cheque_or_dd
    || '-'
    ||cheque_dd_no,'-',NULL,cheque_or_dd
    || '-'
    ||cheque_dd_no)              AS recCheqDD_no,
    cheque_dd_date               AS recChequeDD_date,
    TO_CHAR('Interbank Receipt') AS Recrecfrom,
    TO_ACCOUNT_NO                AS acno,
    To_Bank_Id                   As Bid,
    to_branch_id as   bran_id,
    'R'                          AS type,
    'R3'                         As Typedec,
   PARTICULARS dr_part
  FROM Fas_Inter_Bank_Trf_At_Ho
  WHERE Transfer_Status!='C'
  UNION ALL
  --5
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    Date_Of_Transfer     AS Voudate,
    Voucher_No           AS Recno,
    Particulars          AS Recpart,
    Cr_Account_Head_Code AS Recacchead,      
    null  as Dr_head,
    Total_Amount         As Recamt,
     0         As dr_Amt,   
   Total_Amount as cr_amt,
    DECODE(cheque_or_dd
    || '-'
    ||cheque_dd_no,'-',NULL,cheque_or_dd
    || '-'
    ||Cheque_Dd_No)               AS Reccheqdd_No,
    cheque_dd_date                AS recChequeDD_date,
    TO_CHAR('Interbank Transfer') AS Recrecfrom,
    FROM_ACCOUNT_NO               AS acno,
    From_Bank_Id                    As Bid,
     from_branch_id as bran_id,
    'P'                           AS type ,
    'P3'                          As Typedec,
    PARTICULARS dr_part
  FROM Fas_Inter_Bank_Trf_At_Ho
  WHERE Transfer_Status!='C'
  UNION ALL
  --6
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    receipt_date         AS vouDate,
    receipt_no           AS recNo,
    particulars          AS recPart,
   
     Null As Recacchead,    
    DR_ACCOUNT_HEAD_CODE  as Dr_head,
    Total_Amount         As Recamt,
     Total_Amount         As Dr_Amt,   
    0 as cr_amt,
    DECODE(cheque_or_dd
    || '-'
    ||cheque_dd_no,'-',NULL,cheque_or_dd
    || '-'
    ||cheque_dd_no)         AS recCheqDD_no,
    cheque_dd_date          AS recChequeDD_date,
    TO_CHAR('Fund Receipt') AS Recrecfrom,
    HO_ACCOUNT_NO           AS acno,
    Ho_Bank_Id              As Bid,
    ho_branch_id as bran_id,
    'R'                     AS type ,
    'R4'                    As Typedec,
     PARTICULARS dr_part
  FROM Fas_Fund_Receipt_By_Ho
  WHERE Receipt_Status! ='C'
  UNION ALL
  --7
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.DATE_OF_TRANSFER  AS vouDate,
    T.Voucher_No        AS Recno,
    T.Particulars       AS Recpart,
    T.Account_Head_Code AS Recacchead,
     
    null  as Dr_head,
    T.Amount            As Recamt,
      0 As Dr_Amt,
    Total_Amount as cr_amt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||T.Cheque_Dd_No)        AS Reccheqdd_No,
    T.Cheque_Dd_Date         AS Recchequedd_Date,
    TO_CHAR('Fund Transfer') AS Recrecfrom,
    HO_ACCOUNT_NO            AS acno,
    Ho_Bank_Id               As Bid,
    m.ho_branch_id as bran_id,
    'P'                      AS type ,
    'P5'                     As Typedec,
     REMARKS dr_part
  FROM FAS_FUND_TRF_FROM_HO_MASTER m,
    FAS_FUND_TRF_FROM_HO_TRN t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND T.Voucher_No               = M.Voucher_No
  AND Transfer_Status!           ='C'  
  )A
Inner Join Fas_Mst_Acct_Units B
ON A.accounting_unit_id =B.ACCOUNTING_UNIT_ID
INNER JOIN Fas_Mst_Bank_Balance C
On A.Acno = C.Bank_Ac_No
INNER JOIN Fas_Mst_Banks Bank
On C.Bank_Id             =Bank.Bank_Id
And A.Accounting_Unit_Id      =$P{accountingunitid}

$P!{Str_dt}
Order By 
 -- b.ACCOUNTING_UNIT_id,
  A.Voudate,
  A.Recno,A.Acno]]></queryString>

	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="VOUDATE" class="java.sql.Timestamp"/>
	<field name="RECNO" class="java.math.BigDecimal"/>
	<field name="ACNO" class="java.math.BigDecimal"/>
	<field name="RECPART" class="java.lang.String"/>
	<field name="RECRECFROM" class="java.lang.String"/>
	<field name="RECACCHEAD" class="java.math.BigDecimal"/>
	<field name="DR_HEAD" class="java.math.BigDecimal"/>
	<field name="RECAMT" class="java.math.BigDecimal"/>
	<field name="CR_AMT" class="java.math.BigDecimal"/>
	<field name="DR_AMT" class="java.math.BigDecimal"/>
	<field name="RECCHEQDD_NO" class="java.lang.String"/>
	<field name="DR_PART" class="java.lang.String"/>
	<field name="RECCHEQUEDD_DATE" class="java.sql.Timestamp"/>
	<field name="BID" class="java.math.BigDecimal"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="BRAN_ID" class="java.math.BigDecimal"/>
	<field name="BRANCH_NAME" class="java.lang.String"/>
	<field name="AC_OPERATIONAL_MODE_ID" class="java.lang.String"/>
	<field name="BANK_SHORT_NAME" class="java.lang.String"/>
	<field name="TYPE" class="java.lang.String"/>
	<field name="REC_AMT" class="java.math.BigDecimal"/>
	<field name="PAY_AMT" class="java.math.BigDecimal"/>
	<field name="TYPEDEC" class="java.lang.String"/>
	<field name="DETAILS" class="java.lang.String"/>

	<variable name="SUM_RECAMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{RECAMT}]]></variableExpression>
	</variable>
	<variable name="closing_bal_COL" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{SUM_RECAMT_1}.doubleValue()) +( $P{bankOpeningBal_for_COL}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="sum_payment_bankwise" class="java.math.BigDecimal" resetType="Group" resetGroup="vouc_id" calculation="Sum">
		<variableExpression><![CDATA[$F{PAY_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_REC_AMT" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{RECAMT}]]></variableExpression>
	</variable>
	<variable name="SUN_DR_AMT" class="java.math.BigDecimal" resetType="Report" incrementType="Group" incrementGroup="vouc_id" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>

		<group  name="findClosingBal" >
			<groupExpression><![CDATA[]]></groupExpression>
			<groupHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupHeader>
			<groupFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<group  name="officewise" isStartNewPage="true" >
			<groupExpression><![CDATA[$F{ACCOUNTING_FOR_OFFICE_ID}]]></groupExpression>
			<groupHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupHeader>
			<groupFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<group  name="bank_wise" >
			<groupExpression><![CDATA[$F{BID}]]></groupExpression>
			<groupHeader>
			<band height="17"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="true" pattern="##0.00" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="1"
						y="0"
						width="340"
						height="17"
						key="textField"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement>
						<font/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA["Bank Name  : "+$F{BANK_NAME}]]></textFieldExpression>
				</textField>
				<line direction="TopDown">
					<reportElement
						x="0"
						y="0"
						width="0"
						height="17"
						key="line-46"/>
					<graphicElement stretchType="NoStretch"/>
				</line>
				<line direction="TopDown">
					<reportElement
						x="812"
						y="0"
						width="0"
						height="17"
						key="line-48"/>
					<graphicElement stretchType="NoStretch"/>
				</line>
			</band>
			</groupHeader>
			<groupFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<group  name="acc_wise" >
			<groupExpression><![CDATA[$F{ACNO}]]></groupExpression>
			<groupHeader>
			<band height="13"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="true" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="0"
						width="812"
						height="13"
						key="textField"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement>
						<font/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA["Account No :"+$F{ACNO}]]></textFieldExpression>
				</textField>
				<line direction="TopDown">
					<reportElement
						x="0"
						y="0"
						width="0"
						height="13"
						key="line-47"/>
					<graphicElement stretchType="NoStretch"/>
				</line>
				<line direction="TopDown">
					<reportElement
						x="812"
						y="0"
						width="0"
						height="13"
						key="line-49"/>
					<graphicElement stretchType="NoStretch"/>
				</line>
			</band>
			</groupHeader>
			<groupFooter>
			<band height="1"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<group  name="vouc_id" >
			<groupExpression><![CDATA[$F{RECNO}]]></groupExpression>
			<groupHeader>
			<band height="21"  isSplitAllowed="true" >
				<line direction="TopDown">
					<reportElement
						x="0"
						y="0"
						width="0"
						height="21"
						key="line-29"
						stretchType="RelativeToTallestObject"
						isPrintWhenDetailOverflows="true"/>
					<graphicElement stretchType="RelativeToTallestObject"/>
				</line>
				<line direction="TopDown">
					<reportElement
						x="812"
						y="0"
						width="0"
						height="20"
						key="line-30"
						stretchType="RelativeToTallestObject"
						isPrintWhenDetailOverflows="true"/>
					<graphicElement stretchType="RelativeToTallestObject"/>
				</line>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="101"
						y="2"
						width="378"
						height="18"
						key="textField-6"
						stretchType="RelativeToTallestObject"
						isPrintWhenDetailOverflows="true"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement>
						<font size="9"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{DR_PART}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" pattern="dd/MM/yyyy" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="2"
						y="2"
						width="60"
						height="18"
						key="textField-7"
						stretchType="RelativeToTallestObject"
