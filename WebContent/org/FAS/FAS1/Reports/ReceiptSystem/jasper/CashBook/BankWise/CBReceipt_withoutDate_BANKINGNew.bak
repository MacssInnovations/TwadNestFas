					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$V{sum_receipt_bankwise}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement
						x="329"
						y="2"
						width="118"
						height="18"
						key="staticText-49"/>
