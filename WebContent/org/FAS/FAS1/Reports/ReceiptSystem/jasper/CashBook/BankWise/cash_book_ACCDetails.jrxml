<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="cash_book_ACCDetails"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1125"
		 pageHeight="842"
		 columnWidth="1065"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="AllSectionsNoDetail"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountingunit_name" isForPrompting="false" class="java.lang.String"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtAcc_No" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="bankOpeningBal_for_COL" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="bankOpeningBal_for_OPR" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="PassBook_OB" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="PassBook_CB" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="acpara" isForPrompting="false" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT DISTINCT a.acno,
  a.bid,
  a.voudate,
  b.OFFICE_NAME,
  (SELECT k.bank_name FROM fas_mst_banks k WHERE k.bank_id=a.bid
  )                  AS bank_name ,
  SUM(coalesce (Recamt,0)) AS "Recamt",
  SUM(coalesce (Payamt,0))::numeric as "Payamt"
FROM
  (SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.receipt_date                                    AS vouDate,
    t.receipt_no                                      AS recNo,
    t.particulars                                     AS recPart,
    t.account_head_code                               AS recAcchead,
   CASE WHEN t.cr_dr_indicator='CR' THEN t.amount ELSE -t.amount END AS recAmt,
   case 
		when (t.cheque_or_dd|| '-'||t.cheque_dd_no='-')   then null else t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no end AS recCheqDD_no,
    
    t.cheque_dd_date  AS recChequeDD_date,
    m.received_from   AS recRecFrom,
    NULL::numeric   AS payNo,
    NULL::varchar     AS payPart,
    NULL::numeric   AS payAcchead,
    NULL::numeric   AS payAmt,
    NULL::varchar    AS payCheqDD_no,
    NULL::date     AS payChequeDD_date,
    NULL::varchar     AS payrefno,
    NULL::varchar     AS payPaidto,
    m.bank_id         AS bid,
    m.ACCOUNT_NO      AS acno
  FROM FAS_RECEIPT_MASTER m,
    FAS_RECEIPT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.receipt_no               = m.receipt_no
  AND m.receipt_status!='C'
  AND m.created_by_module       IN('CR','SC')
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.receipt_date                                    AS vouDate,
    t.receipt_no                                      AS recNo,
    t.particulars                                     AS recPart,
    t.account_head_code                               AS recAcchead,
    CASE WHEN t.cr_dr_indicator='CR' THEN t.amount ELSE -t.amount END AS recAmt,
   case 
		when (t.cheque_or_dd|| '-'||t.cheque_dd_no='-')   then null else t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no end AS recCheqDD_no,
    t.cheque_dd_date  AS recChequeDD_date,
    m.received_from   AS recRecFrom,
    NULL::numeric   AS payNo,
    NULL::varchar     AS payPart,
    NULL::numeric   AS payAcchead,
    NULL::numeric   AS payAmt,
    NULL::varchar     AS payCheqDD_no,
    NULL::date     AS payChequeDD_date,
    NULL::varchar     AS payrefno,
    NULL::varchar     AS payPaidto,
    m.bank_id         AS bid,
    m.ACCOUNT_NO      AS acno
  FROM FAS_RECEIPT_MASTER m,
    FAS_RECEIPT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.receipt_no               = m.receipt_no
  AND m.receipt_status!='C'
  AND m.created_by_module ='BR'
  --- Receipt By Office
  UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    RECEIPT_DATE         AS vouDate,
    RECEIPT_NO           AS recNo,
    particulars          AS recPart,
    DR_ACCOUNT_HEAD_CODE AS recAcchead,
    TOTAL_AMOUNT         AS recAmt,
   case 
		when (cheque_or_dd|| '-'||cheque_dd_no='-')   then null else 
   	cheque_or_dd|| '-'||cheque_dd_no end AS recCheqDD_no,
    cheque_dd_date                   AS recChequeDD_date,
    'Head Office - Chennai'::varchar  AS recRecFrom,
    NULL::numeric                  AS payNo,
    NULL::varchar                    AS payPart,
    NULL::numeric                 AS payAcchead,
    NULL::numeric                  AS payAmt,
    NULL::varchar                    AS payCheqDD_no,
    NULL::date                    AS payChequeDD_date,
    NULL::varchar                    AS payrefno,
    NULL::varchar                    AS payPaidto,
    OFFICE_BANK_ID                   AS bid,
    OFFICE_ACCOUNT_NO                AS acno
  FROM FAS_FUND_RECEIPT_BY_OFFICE
  WHERE Receipt_Status!='C'
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.payment_date                                    AS vouDate,
    NULL::numeric                                   AS recNo,
    NULL::varchar                                     AS recPart,
    NULL::numeric                                   AS recAcchead,
    NULL::numeric                                   AS recAmt,
    NULL::varchar                                     AS recCheqDD_no,
    NULL::date                                     AS recChequeDD_date,
    NULL::varchar                                     AS recRecFrom,
    t.voucher_no ::numeric                                     AS payNo,
    t.particulars                                     AS payPart,
    t.account_head_code                              AS payAcchead,
     CASE WHEN t.cr_dr_indicator='DR' THEN t.amount ELSE -t.amount END AS payAmt,
    --DECODE(t.cr_dr_indicator,'DR',t.amount,-t.amount) AS payAmt,
    case 
		when (t.cheque_or_dd|| '-'||t.cheque_dd_no='-')   then null else t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no end AS payCheqDD_no,
    t.cheque_dd_date  AS payChequeDD_date,
    t.REFERENCE_NO    AS payrefno,
    m.paid_to         AS payPaidto,
    m.bank_id         AS bid,
    m.ACCOUNT_NO      AS acno
  FROM FAS_PAYMENT_MASTER m,
    FAS_PAYMENT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND m.PAYMENT_status!='C'
  AND m.created_by_module IN ('BPP','BPF','NP')
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    M.Payment_Date AS Voudate,
    --
    NULL::numeric AS recNo,
    NULL::varchar   AS recPart,
    NULL::numeric AS recAcchead,
    NULL::numeric AS recAmt,
    NULL::varchar   AS recCheqDD_no,
    NULL::date   AS recChequeDD_date,
    NULL::varchar   AS Recrecfrom,
    --
    t.voucher_no                                      AS payNo,
    t.particulars                                     AS payPart,
    t.account_head_code                               AS payAcchead,
   CASE WHEN t.cr_dr_indicator='DR' THEN t.amount ELSE -t.amount END AS payAmt,
   case 
		when (t.cheque_or_dd|| '-'||t.cheque_dd_no='-')   then null else t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no end AS payCheqDD_no,
    t.cheque_dd_date  AS payChequeDD_date,
    t.REFERENCE_NO    AS payrefno,
    m.paid_to         AS payPaidto,
    rM.Bank_Id        AS Bid,
    rm.ACCOUNT_NO     AS acno
  FROM Fas_Payment_Master M,
    Fas_Payment_Transaction T,
    Fas_Receipt_Master Rm
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND m.PAYMENT_status!='C'
  AND M.Created_By_Module       IN ('SC')
  AND M.Selfcheque_Receipt_No    = Rm.Receipt_No
  AND M.Payment_Date             = Rm.Receipt_Date
  UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    DATE_OF_TRANSFER     AS vouDate,
    VOUCHER_NO           AS recNo,
    particulars          AS recPart,
    DR_ACCOUNT_HEAD_CODE AS recAcchead,
    TOTAL_AMOUNT         AS recAmt,
   case 
		when (cheque_or_dd|| '-'||cheque_dd_no='-')   then null else cheque_or_dd
    || '-'
    ||cheque_dd_no end AS recChequeDD_date,

    cheque_dd_date               AS recChequeDD_date,
    'Interbank Receipt'::varchar AS recRecFrom,
    NULL::numeric              AS payNo,
    NULL::varchar                AS payPart,
    NULL::numeric              AS payAcchead,
    NULL::numeric              AS payAmt,
    NULL::varchar               AS payCheqDD_no,
    NULL::date                AS payChequeDD_date,
    NULL::varchar                AS payrefno,
    NULL::varchar                AS payPaidto,
    TO_BANK_ID                   AS bid,
    TO_ACCOUNT_NO                AS acno
  FROM FAS_INTER_BANK_TRF_AT_HO
  WHERE TRANSFER_STATUS!='C'
  -- AND TO_BANK_ID        =2
  UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    DATE_OF_TRANSFER     AS vouDate,
    NULL::numeric      AS recNo,
    NULL::varchar        AS recPart,
    NULL::numeric      AS recAcchead,
    NULL::numeric      AS recAmt,
    NULL::varchar        AS recCheqDD_no,
    NULL::date        AS recChequeDD_date,
    NULL::varchar        AS recRecFrom,
    voucher_no           AS payNo,
    particulars          AS payPart,
    CR_ACCOUNT_HEAD_CODE AS payAcchead,
    TOTAL_AMOUNT         AS payAmt,
   case 
		when (cheque_or_dd|| '-'||cheque_dd_no='-')   then null else cheque_or_dd
    || '-'
    ||cheque_dd_no end AS payCheqDD_no,

    cheque_dd_date                AS payChequeDD_date,
    NULL                 AS payrefno,
    'Interbank Transfer' AS payPaidto,
    FROM_BANK_ID                  AS bid,
    FROM_ACCOUNT_NO               AS acno
  FROM FAS_INTER_BANK_TRF_AT_HO
  WHERE TRANSFER_STATUS!='C'
  --  AND FROM_BANK_ID      =2
  UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    receipt_date         AS vouDate,
    receipt_no           AS recNo,
    particulars          AS recPart,
    DR_ACCOUNT_HEAD_CODE AS recAcchead,
    TOTAL_AMOUNT         AS recAmt,
    case 
		when (cheque_or_dd|| '-'||cheque_dd_no='-')   then null else cheque_or_dd
    || '-'
    ||cheque_dd_no end AS payCheqDD_no,
    cheque_dd_date  AS recChequeDD_date,
    --to_char('Fund Receipt') as recRecFrom,
    (
    SELECT u.OFFICE_NAME
    FROM COM_MST_OFFICES u
    WHERE u.OFFICE_ID=Received_From_Office_Id
    )               AS Recrecfrom,
    NULL::numeric AS payNo,
    NULL::varchar   AS payPart,
    NULL::numeric AS payAcchead,
    NULL::numeric AS payAmt,
    NULL::varchar   AS payCheqDD_no,
    NULL::date   AS payChequeDD_date,
    NULL::varchar   AS payrefno,
    NULL::varchar   AS payPaidto,
    HO_BANK_ID      AS bid,
    HO_ACCOUNT_NO   AS acno
  FROM FAS_FUND_RECEIPT_BY_HO
  WHERE RECEIPT_STATUS!='C'
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.DATE_OF_TRANSFER  AS vouDate,
    NULL::numeric     AS recNo,
    NULL::varchar       AS recPart,
    NULL::numeric     AS recAcchead,
    NULL::numeric     AS recAmt,
    NULL::varchar       AS recCheqDD_no,
    NULL::date       AS recChequeDD_date,
    NULL::varchar       AS recRecFrom,
    t.voucher_no        AS payNo,
    t.particulars       AS payPart,
    t.ACCOUNT_HEAD_CODE AS payAcchead,
    t.AMOUNT            AS payAmt,
    case 
		when (cheque_or_dd|| '-'||cheque_dd_no='-')   then null else cheque_or_dd
    || '-'
    ||cheque_dd_no end AS payCheqDD_no,

    t.cheque_dd_date  AS paychequedd_date,
    NULL     AS payRefno,
    --to_char('Fund Transfer') as payPaidto
    (
    SELECT u.OFFICE_NAME
    FROM COM_MST_OFFICES u
    WHERE u.office_id=transfer_to_office_id
    )             AS payPaidto,
    HO_BANK_ID    AS bid,
    HO_ACCOUNT_NO AS acno
  FROM FAS_FUND_TRF_FROM_HO_MASTER m,
    FAS_FUND_TRF_FROM_HO_TRN t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND TRANSFER_STATUS!='C'
    UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
  ACCOUNTING_FOR_OFFICE_ID,
  CASHBOOK_YEAR,
  CASHBOOK_MONTH,
  Date_Of_Transfer     AS Voudate,
  NULL::numeric      AS Recno,
  NULL::varchar        AS Recpart,
  NULL::numeric      AS Recacchead,
  NULL::numeric      AS Recamt,
  NULL::varchar        AS recCheqDD_no,
  NULL::date        AS recChequeDD_date,
  NULL::varchar        AS Recrecfrom,
  VOUCHER_NO           AS payNo,
  particulars          AS payPart,
  DR_ACCOUNT_HEAD_CODE AS payAcchead,
  Total_Amount         As Payamt,
    case 
		when (cheque_or_dd|| '-'||cheque_dd_no='-')   then null else cheque_or_dd
    || '-'
    ||cheque_dd_no end AS payCheqDD_no,

  cheque_dd_date  AS payChequeDD_date,
  NULL::varchar AS Paypaidto,
  NULL::varchar AS Payrefno,
  OFFICE_BANK_ID    AS bid,
  OFFICE_ACCOUNT_NO AS acno
FROM FAS_FUND_TRF_FROM_OFFICE
Where Transfer_Status!='C'
  ) A,
  Com_Mst_Offices B
Where A.Accounting_For_Office_Id=B.Office_Id
And A.Accounting_Unit_Id        =$P{accountingunitid}::numeric
And A.Cashbook_Year             =$P{txtCB_Year}::numeric
And A.Cashbook_Month            =$P{txtCB_Month}::numeric
AND A.Acno                      =$P{txtAcc_No}::numeric
GROUP BY A.Acno,
  A.Bid,
  A.Voudate,
  B.Office_Name
Order By A.Acno,
  a.voudate]]></queryString>

	<field name="acno" class="java.math.BigDecimal"/>
	<field name="bid" class="java.math.BigDecimal"/>
	<field name="voudate" class="java.util.Date"/>
	<field name="office_name" class="java.lang.String"/>
	<field name="bank_name" class="java.lang.String"/>
	<field name="Recamt" class="java.math.BigDecimal"/>
	<field name="Payamt" class="java.math.BigDecimal"/>

	<variable name="Rec_Amt_Sum" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{Recamt}]]></variableExpression>
	</variable>
	<variable name="Pay_Amt_Sum" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{Payamt}]]></variableExpression>
	</variable>
	<variable name="Total_Abstract" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($P{bankOpeningBal_for_COL}.doubleValue())+($V{Rec_Amt_Sum}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="CB_Abstract" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{Total_Abstract}.doubleValue())-($V{Pay_Amt_Sum}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="closing_bal_COL" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{Rec_Amt_Sum}.doubleValue()) +( $P{bankOpeningBal_for_COL}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="closing_bal_OPR" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{Pay_Amt_Sum}.doubleValue()) -( $P{bankOpeningBal_for_OPR}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="tot_Recamt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
	</variable>
	<variable name="tot_Payamt" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<initialValueExpression><![CDATA[new BigDecimal(0.0)]]></initialValueExpression>
	</variable>
	<variable name="new" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{tot_Payamt}!=null?$V{tot_Payamt}:(new BigDecimal(0.00))]]></variableExpression>
	</variable>
		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="1"  isSplitAllowed="true" >
			</band>
		</title>
		<pageHeader>
			<band height="140"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						mode="Opaque"
						x="0"
						y="5"
						width="1065"
						height="27"
						key="staticText-20"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Times New Roman" pdfFontName="Helvetica-Bold" size="16" isBold="true"/>
					</textElement>
				<text><![CDATA[TAMILNADU WATER SUPPLY AND DRAINAGE BOARD]]></text>
				</staticText>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="3"
						y="73"
						width="1051"
						height="20"
						key="textField"/>
					<box></box>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font pdfFontName="Helvetica-Bold" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{bank_name}+" - "+$F{acno}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="55"
						width="1065"
						height="18"
						key="textField-3"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Center">
						<font/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{office_name}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="37"
						width="1065"
						height="18"
						key="textField-4"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Center">
						<font pdfFontName="Helvetica-Bold" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA["CASH BOOK FOR THE MONTH OF"+$P{monthInWords}+" - "+$P{txtCB_Year}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="3"
						y="55"
						width="329"
						height="18"
						key="textField-7"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement>
						<font pdfFontName="Helvetica-Bold" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA["Accounting Unit Name: "+$P{accountingunit_name}]]></textFieldExpression>
				</textField>
				<staticText>
