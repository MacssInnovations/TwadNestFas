<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="CashBookReceipt_withoutDate_BANKING"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="870"
		 pageHeight="850"
		 columnWidth="860"
		 columnSpacing="0"
		 leftMargin="5"
		 rightMargin="5"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunit_name" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="bankOpeningBal_for_COL" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="bankOpeningBal_for_OPR" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT b.OFFICE_NAME,c.opening_balance as ob_passbook,c.closing_balance as cb_passbook,
  a.ACCOUNTING_UNIT_ID,
  a.ACCOUNTING_FOR_OFFICE_ID,
  a.CASHBOOK_YEAR,
  a.CASHBOOK_MONTH,
  a.vouDate,
  a.recNo,
  decode(a.recpart,null,'-',a.recpart)as recpart,
  a.recAcchead,
  a.recamt,
  DECODE(a.reccheqdd_no,NULL,'-',a.reccheqdd_no)as reccheqdd_no,
  decode(to_char(a.recchequedd_date,'DD/MM/YYYY'),null,'-',a.recchequedd_date)as recchequedd_date,
  DECODE(a.recRecFrom,NULL,'-',a.recRecFrom)as recRecFrom,
  a.payNo,
  DECODE(a.payPart,NULL,'-',a.payPart)as payPart,
  a.payAcchead,
  a.payAmt,
  a.payCheqDD_no,
  a.paychequedd_date,
  a.payrefno,
  DECODE(a.paypaidto,NULL,'-',a.paypaidto)as paypaidto,a.bid,
  (select k.bank_name from fas_mst_banks k where k.bank_id=a.bid)as bank_name
FROM
  (SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.receipt_date                                    AS vouDate,
    t.receipt_no                                      AS recNo,
    t.particulars                                     AS recPart,
    t.account_head_code                               AS recAcchead,
    DECODE(t.cr_dr_indicator,'CR',t.amount,-t.amount) AS recAmt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no) AS recCheqDD_no,
    t.cheque_dd_date  AS recChequeDD_date,
    m.received_from   AS recRecFrom,
    to_number(NULL)   AS payNo,
    TO_CHAR(NULL)     AS payPart,
    to_number(NULL)   AS payAcchead,
    to_number(NULL)   AS payAmt,
    TO_CHAR(NULL)     AS payCheqDD_no,
    to_date(NULL)     AS payChequeDD_date,
    to_char(null)     as payrefno,
    TO_CHAR(NULL)     AS payPaidto,m.bank_id as bid,m.ACCOUNT_NO as acno
  FROM FAS_RECEIPT_MASTER m,
    FAS_RECEIPT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.receipt_no               = m.receipt_no
  AND m.receipt_status!          ='C'
  AND m.created_by_module       IN('CR','SC')
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.receipt_date                                    AS vouDate,
    t.receipt_no                                      AS recNo,
    t.particulars                                     AS recPart,
    t.account_head_code                               AS recAcchead,
    DECODE(t.cr_dr_indicator,'CR',t.amount,-t.amount) AS recAmt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no) AS recCheqDD_no,
    t.cheque_dd_date  AS recChequeDD_date,
    m.received_from   AS recRecFrom,
    to_number(NULL)   AS payNo,
    TO_CHAR(NULL)     AS payPart,
    to_number(NULL)   AS payAcchead,
    to_number(NULL)   AS payAmt,
    TO_CHAR(NULL)     AS payCheqDD_no,
    to_date(NULL)     AS payChequeDD_date,
    to_char(null)     as payrefno,
    TO_CHAR(NULL)     AS payPaidto,m.bank_id as bid,m.ACCOUNT_NO as acno
  FROM FAS_RECEIPT_MASTER m,
    FAS_RECEIPT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.receipt_no               = m.receipt_no
  AND m.receipt_status!          ='C'
 -- AND m.bank_id                  =2
  AND m.created_by_module        ='BR'
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.payment_date                                    AS vouDate,
    to_number(NULL)                                   AS recNo,
    TO_CHAR(NULL)                                     AS recPart,
    to_number(NULL)                                   AS recAcchead,
    to_number(NULL)                                   AS recAmt,
    TO_CHAR(NULL)                                     AS recCheqDD_no,
    to_date(NULL)                                     AS recChequeDD_date,
    TO_CHAR(NULL)                                     AS recRecFrom,
    t.voucher_no                                      AS payNo,
    t.particulars                                     AS payPart,
    t.account_head_code                               AS payAcchead,
    DECODE(t.cr_dr_indicator,'DR',t.amount,-t.amount) AS payAmt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no) AS payCheqDD_no,
    t.cheque_dd_date  AS payChequeDD_date,
    to_char(null)     as payrefno,
    m.paid_to         AS payPaidto,m.bank_id as bid,m.ACCOUNT_NO as acno
  FROM FAS_PAYMENT_MASTER m,
    FAS_PAYMENT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND m.PAYMENT_status!          ='C'
 -- AND m.bank_id                  =2
  AND m.created_by_module       IN ('BPP','BPF','NP')
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.payment_date                                    AS vouDate,
    to_number(NULL)                                   AS recNo,
    TO_CHAR(NULL)                                     AS recPart,
    to_number(NULL)                                   AS recAcchead,
    to_number(NULL)                                   AS recAmt,
    TO_CHAR(NULL)                                     AS recCheqDD_no,
    to_date(NULL)                                     AS recChequeDD_date,
    TO_CHAR(NULL)                                     AS recRecFrom,
    t.voucher_no                                      AS payNo,
    t.particulars                                     AS payPart,
    t.account_head_code                               AS payAcchead,
    DECODE(t.cr_dr_indicator,'DR',t.amount,-t.amount) AS payAmt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no) AS payCheqDD_no,
    t.cheque_dd_date  AS payChequeDD_date,
    to_char(null)     as payrefno,
    m.paid_to         AS payPaidto,m.bank_id as bid,m.ACCOUNT_NO as acno
  FROM FAS_PAYMENT_MASTER m,
    FAS_PAYMENT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND m.PAYMENT_status!          ='C'
  AND m.created_by_module       IN ('SC')
  UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    DATE_OF_TRANSFER     AS vouDate,
    VOUCHER_NO           AS recNo,
    particulars          AS recPart,
    DR_ACCOUNT_HEAD_CODE AS recAcchead,
    TOTAL_AMOUNT         AS recAmt,
    DECODE(cheque_or_dd
    || '-'
    ||cheque_dd_no,'-',NULL,cheque_or_dd
    || '-'
    ||cheque_dd_no)              AS recCheqDD_no,
    cheque_dd_date               AS recChequeDD_date,
    TO_CHAR('Interbank Receipt') AS recRecFrom,
    to_number(NULL)              AS payNo,
    TO_CHAR(NULL)                AS payPart,
    to_number(NULL)              AS payAcchead,
    to_number(NULL)              AS payAmt,
    TO_CHAR(NULL)                AS payCheqDD_no,
    to_date(NULL)                AS payChequeDD_date,
    to_char(null)                as payrefno,
    TO_CHAR(NULL)                AS payPaidto,TO_BANK_ID as bid,TO_ACCOUNT_NO as acno
  FROM FAS_INTER_BANK_TRF_AT_HO
  WHERE TRANSFER_STATUS!='C'
 -- AND TO_BANK_ID        =2
  UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    DATE_OF_TRANSFER     AS vouDate,
    to_number(NULL)      AS recNo,
    TO_CHAR(NULL)        AS recPart,
    to_number(NULL)      AS recAcchead,
    to_number(NULL)      AS recAmt,
    TO_CHAR(NULL)        AS recCheqDD_no,
    to_date(NULL)        AS recChequeDD_date,
    TO_CHAR(NULL)        AS recRecFrom,
    voucher_no           AS payNo,
    particulars          AS payPart,
    CR_ACCOUNT_HEAD_CODE AS payAcchead,
    TOTAL_AMOUNT         AS payAmt,
    DECODE(cheque_or_dd
    || '-'
    ||cheque_dd_no,'-',NULL,cheque_or_dd
    || '-'
    ||cheque_dd_no)               AS payCheqDD_no,
    cheque_dd_date                AS payChequeDD_date,
    to_char(null)                 as payrefno,
    TO_CHAR('Interbank Transfer') AS payPaidto,FROM_BANK_ID as bid,FROM_ACCOUNT_NO as acno
  FROM FAS_INTER_BANK_TRF_AT_HO
  WHERE TRANSFER_STATUS!='C'
--  AND FROM_BANK_ID      =2
  UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    receipt_date         AS vouDate,
    receipt_no           AS recNo,
    particulars          AS recPart,
    DR_ACCOUNT_HEAD_CODE AS recAcchead,
    TOTAL_AMOUNT         AS recAmt,
    DECODE(cheque_or_dd
    || '-'
    ||cheque_dd_no,'-',NULL,cheque_or_dd
    || '-'
    ||cheque_dd_no) AS recCheqDD_no,
    cheque_dd_date  AS recChequeDD_date,
    --to_char('Fund Receipt') as recRecFrom,
    (
    SELECT u.OFFICE_NAME
    FROM COM_MST_OFFICES u
    WHERE u.OFFICE_ID=Received_From_Office_Id
    )               AS Recrecfrom,
    to_number(NULL) AS payNo,
    TO_CHAR(NULL)   AS payPart,
    to_number(NULL) AS payAcchead,
    to_number(NULL) AS payAmt,
    TO_CHAR(NULL)   AS payCheqDD_no,
    to_date(NULL)   AS payChequeDD_date,
    to_char(null)   as payrefno,
    TO_CHAR(NULL)   AS payPaidto,HO_BANK_ID as bid,HO_ACCOUNT_NO as acno
  FROM FAS_FUND_RECEIPT_BY_HO
  WHERE RECEIPT_STATUS!='C'
 -- AND HO_BANK_ID       =2
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.DATE_OF_TRANSFER  AS vouDate,
    to_number(NULL)     AS recNo,
    TO_CHAR(NULL)       AS recPart,
    to_number(NULL)     AS recAcchead,
    to_number(NULL)     AS recAmt,
    TO_CHAR(NULL)       AS recCheqDD_no,
    to_date(NULL)       AS recChequeDD_date,
    TO_CHAR(NULL)       AS recRecFrom,
    t.voucher_no        AS payNo,
    t.particulars       AS payPart,
    t.ACCOUNT_HEAD_CODE AS payAcchead,
    t.AMOUNT            AS payAmt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no) AS payCheqDD_no,
    t.cheque_dd_date  as paychequedd_date,
    TO_CHAR(NULL)     AS payRefno,
    --to_char('Fund Transfer') as payPaidto
    (
    SELECT u.OFFICE_NAME
    FROM COM_MST_OFFICES u
    where u.office_id=transfer_to_office_id
    )AS payPaidto,HO_BANK_ID as bid,HO_ACCOUNT_NO as acno
  FROM FAS_FUND_TRF_FROM_HO_MASTER m,
    FAS_FUND_TRF_FROM_HO_TRN t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND TRANSFER_STATUS!           ='C'
 -- AND HO_BANK_ID                 =2
  ) a ,
  COM_MST_OFFICES b,FAS_MST_BANK_BALANCE c
where a.accounting_unit_id    =$P{accountingunitid}
AND a.CASHBOOK_YEAR           =$P{txtCB_Year}
and a.cashbook_month          =$P{txtCB_Month}
and a.accounting_for_office_id=b.office_id  
and a.bid = c.bank_id
and a.acno = c.bank_ac_no
ORDER BY a.bid,b.OFFICE_NAME,
  a.vouDate,
  a.recno,
  a.payNo]]></queryString>

	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="OB_PASSBOOK" class="java.math.BigDecimal"/>
	<field name="CB_PASSBOOK" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="VOUDATE" class="java.sql.Timestamp"/>
	<field name="RECNO" class="java.math.BigDecimal"/>
	<field name="RECPART" class="java.lang.String"/>
	<field name="RECACCHEAD" class="java.math.BigDecimal"/>
	<field name="RECAMT" class="java.math.BigDecimal"/>
	<field name="RECCHEQDD_NO" class="java.lang.String"/>
	<field name="RECCHEQUEDD_DATE" class="java.lang.String"/>
	<field name="RECRECFROM" class="java.lang.String"/>
	<field name="PAYNO" class="java.math.BigDecimal"/>
	<field name="PAYPART" class="java.lang.String"/>
	<field name="PAYACCHEAD" class="java.math.BigDecimal"/>
	<field name="PAYAMT" class="java.math.BigDecimal"/>
	<field name="PAYCHEQDD_NO" class="java.lang.String"/>
	<field name="PAYCHEQUEDD_DATE" class="java.sql.Timestamp"/>
	<field name="PAYREFNO" class="java.lang.String"/>
	<field name="PAYPAIDTO" class="java.lang.String"/>
	<field name="BID" class="java.math.BigDecimal"/>
	<field name="BANK_NAME" class="java.lang.String"/>

	<variable name="SUM_RECAMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{RECAMT}]]></variableExpression>
	</variable>
	<variable name="SUM_PAYAMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{PAYAMT}]]></variableExpression>
	</variable>
	<variable name="closing_bal_COL" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{SUM_RECAMT_1}.doubleValue()) +( $P{bankOpeningBal_for_COL}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="closing_bal_OPR" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{SUM_PAYAMT_1}.doubleValue()) -( $P{bankOpeningBal_for_OPR}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="sum_receipt_bankwise" class="java.math.BigDecimal" resetType="Group" resetGroup="bankid" calculation="Sum">
		<variableExpression><![CDATA[$F{RECAMT}]]></variableExpression>
	</variable>
	<variable name="sum_payment_bankwise" class="java.math.BigDecimal" resetType="Group" resetGroup="bankid" calculation="Sum">
		<variableExpression><![CDATA[$F{PAYAMT}]]></variableExpression>
	</variable>
	<variable name="Total_Abstract" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($P{bankOpeningBal_for_COL}.doubleValue())+($V{SUM_RECAMT_1}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="CB_Abstract" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{Total_Abstract}.doubleValue())-($V{SUM_PAYAMT_1}.doubleValue()))]]></variableExpression>
	</variable>

		<group  name="findClosingBal" >
			<groupExpression><![CDATA[]]></groupExpression>
			<groupHeader>
			<band height="3"  isSplitAllowed="true" >
			</band>
			</groupHeader>
			<groupFooter>
			<band height="28"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="150"
						y="6"
						width="92"
						height="22"
						key="staticText-34"/>
					<box>					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
