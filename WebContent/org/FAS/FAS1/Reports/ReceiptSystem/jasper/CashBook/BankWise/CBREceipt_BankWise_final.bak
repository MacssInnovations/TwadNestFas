<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="CBREceipt_BankWise_final"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="926"
		 pageHeight="850"
		 columnWidth="868"
		 columnSpacing="0"
		 leftMargin="29"
		 rightMargin="29"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunit_name" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="bankOpeningBal_for_COL" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="bankOpeningBal_for_OPR" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="Str_dt" isForPrompting="true" class="java.lang.String"/>
	<parameter name="acpara" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT G.Accounting_Unit_Id,
  b.ACCOUNTING_UNIT_NAME,
  g.paid_to,
  g.sub_ledger_type_code,
  g.cashbook_year,
  g.cashbook_month,
  g.vouDate,
  g.Account_Head_Code ,
  g.Voucher_No,
  g.Reccheqdd_No,
  g.Recchequedd_Date,
  g.Bank_Id,
  (SELECT K.Bank_Name FROM Fas_Mst_Banks K WHERE K.Bank_Id=g.Bank_Id
  )AS Bank_Name,
  (SELECT D.Branch_Name
  FROM Fas_Mst_Bank_Branches D
  WHERE G.Bank_Id =D.Bank_Id
  AND g.Branch_Id =D.Bank_Id
  )branch_name,
  g.Branch_Id,
  g.ACCOUNT_NO,
  g.document_type,
  g.CR_DR_INDICATOR,
  g.dr_amt,
  g.cr_amt,
  g.amount,
  G.Particulars,
  g.particular_from,
  g.sup_no
FROM(
  (SELECT a.accounting_unit_id,
    b.paid_to AS paid_to,
    a.sub_ledger_type_code,
    a.cashbook_year,
    a.cashbook_month,
    b.payment_date AS vouDate,
    a.Account_Head_Code ,
    B.Voucher_No AS Voucher_No,
    b.Bank_Id,
    b.Branch_Id,
    B.Account_No,
    DECODE(a.cheque_or_dd
    || '-'
    ||a.cheque_dd_no,'-',NULL,a.cheque_or_dd
    || '-'
    ||A.Cheque_Dd_No) AS Reccheqdd_No,
    a.Cheque_Dd_Date  AS Recchequedd_Date,
    'P'               AS document_type,
    a.CR_DR_INDICATOR,
    CASE
      WHEN a.CR_DR_INDICATOR = 'DR'
      THEN a.amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN a.CR_DR_INDICATOR = 'CR'
      THEN a.amount
      ELSE 0
    END      AS cr_amt,
    a.amount AS amount,
    a.particulars,
    a.particulars particular_from,
    0 AS sup_no
  FROM fas_payment_transaction a,
    fas_payment_master b
  WHERE a.accounting_unit_id     = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.voucher_no               = b.voucher_no
  AND B.Payment_Status          <>'C'
  AND b.Created_By_Module       IN ('BPP','BPF','NP','SC')
    --  AND A.Cashbook_Year            =2012
    --  AND a.cashbook_month           =4
  )
UNION ALL
  (SELECT b.accounting_unit_id,
    b.paid_to AS paid_to,
    b.sub_ledger_type_code,
    B.cashbook_year,
    B.cashbook_month,
    b.payment_date AS vouDate,
    B.Account_Head_Code ,
    B.Voucher_No AS Voucher_No,
    b.Bank_Id,
    b.Branch_Id,
    b.ACCOUNT_NO,
    (SELECT  distinct DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.Cheque_Dd_No) 
  FROM fas_payment_transaction t
  WHERE  T.Accounting_Unit_Id         = B.Accounting_Unit_Id
  AND T.Cashbook_Month             = B.Cashbook_Month
  AND T.Cashbook_Year              = B.Cashbook_Year
  AND T.Voucher_No                 = B.Voucher_No
  )AS Reccheqdd_No,
    NULL AS Recchequedd_Date,
    'P'  AS Document_Type,
    'CR' AS Cr_Dr_Indicator,
    CASE
      WHEN CR_DR_INDICATOR = 'DR'
      THEN B.TOTAL_AMOUNT
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN CR_DR_INDICATOR = 'CR'
      THEN B.TOTAL_AMOUNT
      ELSE 0
    END            AS Cr_Amt,
    b.total_amount AS amount,
    B.Remarks      AS Particulars,
    b.paid_to particular_from,
    0 AS sup_no
  FROM fas_payment_master b
  WHERE B.Payment_Status <>'C'
    --   AND b.cashbook_year    IN (2009,2010,2011,2012,2013,2014)
    --  AND b.Cashbook_Year      =2012
    --  AND B.Cashbook_Month     =4
  AND b.Created_By_Module IN ('BPP','BPF','NP','SC')
  )
UNION ALL
  (SELECT a.accounting_unit_id,
    b.received_from AS paid_to,
    a.sub_ledger_type_code,
    a.cashbook_year,
    a.cashbook_month,
    b.receipt_date AS vouDate,
    a.account_head_code ,
    B.Receipt_No AS Voucher_No ,
    b.Bank_Id,
    B.Branch_Id,
    b.ACCOUNT_NO,
    DECODE(a.cheque_or_dd
    || '-'
    ||a.cheque_dd_no,'-',NULL,a.cheque_or_dd
    || '-'
    ||A.Cheque_Dd_No) AS Reccheqdd_No,
    a.Cheque_Dd_Date  AS Recchequedd_Date,
    'R'               AS document_type,
    a.CR_DR_INDICATOR,
    CASE
      WHEN a.CR_DR_INDICATOR = 'DR'
      THEN a.amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN a.CR_DR_INDICATOR = 'CR'
      THEN a.amount
      ELSE 0
    END      AS cr_amt,
    a.amount AS amount,
    A.Particulars,
    a.particulars particular_from,
    0 AS sup_no
  FROM fas_receipt_transaction a,
    fas_receipt_master b
  WHERE a.accounting_unit_id     = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.receipt_no               = b.receipt_no
  AND B.Receipt_Status          <>'C'
    --  AND A.Cashbook_Year            =2012
    --  AND A.Cashbook_Month           =4
  AND b.Created_By_Module IN('CR','SC','BR')
    -- AND a.cashbook_year           IN (2009,2010,2011,2012,2013,2014)
  )
UNION ALL
  (SELECT b.accounting_unit_id,
    b.received_from AS paid_to,
    b.sub_ledger_type_code,
    B.cashbook_year,
    b.cashbook_month,
    b.receipt_date AS vouDate,
    b.account_head_code ,
    b.receipt_no AS voucher_no ,
    b.Bank_Id,
    B.Branch_Id,
    B.Account_No,
   -- NULL AS Reccheqdd_No,
    (SELECT  distinct DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.Cheque_Dd_No) 
  FROM fas_receipt_transaction t
  WHERE  T.Accounting_Unit_Id         = B.Accounting_Unit_Id
  AND T.Cashbook_Month             = B.Cashbook_Month
  AND T.Cashbook_Year              = B.Cashbook_Year
  And T.receipt_no                 = B.receipt_no
  )AS Reccheqdd_No,
    NULL AS Recchequedd_Date,
    'R'  AS document_type,
    b.CR_DR_INDICATOR,
    CASE
      WHEN b.CR_DR_INDICATOR = 'DR'
      THEN b.TOTAL_AMOUNT
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN b.CR_DR_INDICATOR = 'CR'
      THEN b.TOTAL_AMOUNT
      ELSE 0
    END            AS cr_amt,
    B.Total_Amount AS Amount,
    B.Remarks      AS Particulars,
    b.received_from particular_from,
    0 AS sup_no
  FROM fas_receipt_master b
  WHERE B.Receipt_Status <>'C'
    --  AND b.Cashbook_Year      =2012
    --  AND B.Cashbook_Month     =4
  AND b.Created_By_Module IN('CR','SC','BR')
    --   AND b.cashbook_year    IN (2009,2010,2011,2012,2013,2014)
  )
UNION ALL
  (SELECT Accounting_Unit_Id,
    'yourself' AS Paid_To,
    0          AS sub_ledger_type_code,
    cashbook_year,
    cashbook_month,
    Date_Of_Transfer     AS vouDate,
    CR_ACCOUNT_HEAD_CODE AS account_head_code,
    Voucher_No           AS Voucher_No,
    Bank_Id,
    Branch_Id,
    Account_No,
    Reccheqdd_No,
    Recchequedd_Date,
    document_type,
    cr_dr_indicator,
    CASE
      WHEN cr_dr_indicator = 'DR'
      THEN amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN cr_dr_indicator = 'CR'
      THEN amount
      ELSE 0
    END AS cr_amt,
    amount,
    Particulars,
    particular_from,
    0 AS sup_no
  FROM
    (SELECT a.accounting_unit_id,
      '' AS sub_ledger_type_code_desc,
      CR_ACCOUNT_HEAD_CODE,
      Date_Of_Transfer,
      '' AS paid_received,
      a.cashbook_year,
      a.cashbook_month,
      Date_Of_Transfer  AS vouDate,
      a.VOUCHER_NO      AS voucher_no,
      a.From_Bank_Id    AS Bank_Id,
      a.From_Branch_Id  AS Branch_Id,
      A.From_Account_No AS Account_No,
      DECODE(a.cheque_or_dd
      || '-'
      ||a.cheque_dd_no,'-',NULL,a.cheque_or_dd
      || '-'
      ||A.Cheque_Dd_No) AS Reccheqdd_No,
      a.Cheque_Dd_Date  AS Recchequedd_Date,
      'IBT'             AS document_type,
      'CR'              AS cr_dr_indicator,
      Total_Amount      AS Amount,
      a.Particulars,
      'IBT Yourself' particular_from
    FROM fas_inter_bank_trf_at_ho a
    WHERE A.Transfer_Status <>'C'
      -- AND a.cashbook_year     IN (2009,2010,2011,2012,2013,2014)
      --    AND A.Cashbook_Year =2012
      --    AND a.cashbook_month=4
    )
  )
UNION ALL
  (SELECT a.accounting_unit_id,
    '' AS paid_to,
    0  AS sub_ledger_type_code,
    a.cashbook_year,
    a.cashbook_month,
    a.DATE_OF_TRANSFER     AS vouDate,
    a.DR_ACCOUNT_HEAD_CODE AS account_head_code,
    A.Voucher_No           AS Voucher_No,
    a.From_Bank_Id         AS Bank_Id,
    a.From_Branch_Id       AS Branch_Id,
    A.From_Account_No      AS Account_No,
    DECODE(a.cheque_or_dd
    || '-'
    ||a.cheque_dd_no,'-',NULL,a.cheque_or_dd
    || '-'
    ||A.Cheque_Dd_No) AS Reccheqdd_No,
    a.Cheque_Dd_Date  AS Recchequedd_Date,
    'IBT'             AS document_type,
    'DR'              AS CR_DR_INDICATOR,
    a.TOTAL_AMOUNT    AS dr_amt,
    0                 AS cr_amt,
    a.total_amount    AS amount,
    A.Particulars,
    a.particulars particular_from,
    0 AS sup_no
  FROM fas_inter_bank_trf_at_ho a
  WHERE A.Transfer_Status='L'
    -- And A.Cashbook_Year   In (2009,2010,2011,2012,2013,2014)
  AND A.Cashbook_Year =2012
  AND a.cashbook_month=4
  )
UNION ALL
  (SELECT b.accounting_unit_id,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    b.cashbook_year,
    b.cashbook_month,
    b.RECEIPT_DATE         AS vouDate,
    b.CR_ACCOUNT_HEAD_CODE AS account_head_code,
    B.Receipt_No           AS Voucher_No,
    b.Ho_Bank_Id Bank_Id,
    b.Ho_Branch_Id Branch_Id,
    b.HO_ACCOUNT_NO account_no,
    DECODE(b.cheque_or_dd
    || '-'
    ||b.cheque_dd_no,'-',NULL,b.cheque_or_dd
    || '-'
    ||b.Cheque_Dd_No) AS Reccheqdd_No,
    b.Cheque_Dd_Date  AS Recchequedd_Date,
    'FT'              AS document_type,
    'CR'              AS Cr_Dr_Indicator,
    0                 AS dr_amt,
    b.total_amount    AS cr_amt,
    b.total_amount    AS amount,
    B.Particulars,
    'Fund Receipt' particular_from,
    0 AS sup_no
  FROM fas_fund_receipt_by_ho b
  WHERE B.Receipt_Status <>'C'
    --AND b.cashbook_year    IN (2009,2010,2011,2012,2013,2014)
  AND b.Cashbook_Year =2012
  AND b.cashbook_month=4
  )
UNION ALL
  (SELECT b.accounting_unit_id,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    b.cashbook_year,
    b.cashbook_month,
    b.RECEIPT_DATE         AS vouDate,
    b.DR_ACCOUNT_HEAD_CODE AS account_head_code,
    B.Receipt_No           AS Voucher_No,
    b.Ho_Bank_Id Bank_Id,
    b.Ho_Branch_Id Branch_Id,
    b.HO_ACCOUNT_NO account_no,
    DECODE(b.cheque_or_dd
    || '-'
    ||b.cheque_dd_no,'-',NULL,b.cheque_or_dd
    || '-'
    ||B.Cheque_Dd_No) AS Reccheqdd_No,
    b.Cheque_Dd_Date  AS Recchequedd_Date,
    'FRH'             AS Document_Type,
    'DR'              AS Cr_Dr_Indicator,
    B.Total_Amount    AS Dr_Amt,
    0                 AS cr_amt,
    b.total_amount    AS amount,
    B.Particulars,
    (SELECT u.OFFICE_NAME
    FROM Com_Mst_Offices U
    WHERE U.Office_Id=b.Received_From_Office_Id
    ) AS particular_from,
    0 AS sup_no
  FROM fas_fund_receipt_by_ho b
  WHERE B.Receipt_Status <>'C'
    -- AND b.cashbook_year    IN (2009,2010,2011,2012,2013,2014)
    --  AND b.Cashbook_Year =2012
    --  AND b.cashbook_month=4
  )
UNION ALL
  (SELECT a.accounting_unit_id,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    a.cashbook_year,
    a.cashbook_month,
    b.date_of_transfer AS vouDate,
    a.account_head_code ,
    B.Voucher_No AS Voucher_No,
    b.Ho_Bank_Id Bank_Id,
    b.Ho_Branch_Id Branch_Id,
    b.Ho_Account_No Account_No,
    DECODE(a.cheque_or_dd
    || '-'
    ||a.cheque_dd_no,'-',NULL,a.cheque_or_dd
    || '-'
    ||a.Cheque_Dd_No) AS Reccheqdd_No,
    a.Cheque_Dd_Date  AS Recchequedd_Date,
    'FTH'             AS Document_Type,
    'DR'              AS CR_DR_INDICATOR,
    CASE
      WHEN a.CR_DR_INDICATOR = 'DR'
      THEN a.amount
      ELSE 0
    END AS dr_amt,
    CASE
      WHEN a.CR_DR_INDICATOR = 'CR'
      THEN a.amount
      ELSE 0
    END      AS cr_amt,
    a.amount AS amount,
    A.Particulars,
    'Fund Transfer' AS particular_from,
    0               AS sup_no
  FROM fas_fund_trf_from_ho_trn a,
    fas_fund_trf_from_ho_master b
  WHERE a.accounting_unit_id     = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.voucher_no               = b.voucher_no
  AND B.Transfer_Status         <>'C'
    --  AND A.Cashbook_Year            =2012
    --  AND a.cashbook_month           =4
    -- AND a.cashbook_year           IN (2009,2010,2011,2012,2013,2014)
  )
UNION ALL
  (SELECT a.accounting_unit_id,
    '' AS paid_to,
    6  AS sub_ledger_type_code,
    a.cashbook_year,
    a.cashbook_month,
    b.date_of_transfer AS vouDate,
    b.account_head_code ,
    B.Voucher_No AS Voucher_No,
    b.Ho_Bank_Id Bank_Id,
    b.Ho_Branch_Id Branch_Id,
    b.Ho_Account_No Account_No,
    DECODE(a.cheque_or_dd
    || '-'
    ||a.cheque_dd_no,'-',NULL,a.cheque_or_dd
    || '-'
    ||a.Cheque_Dd_No) AS Reccheqdd_No,
    a.Cheque_Dd_Date  AS Recchequedd_Date,
    'FTH'             AS Document_Type,
    'CR'              AS CR_DR_INDICATOR,
    0                 AS dr_amt,
    a.amount          AS cr_amt,
    a.amount          AS amount,
    A.Particulars,
    (SELECT Accounting_Unit_Name
    FROM Fas_Mst_Acct_Units
    WHERE Accounting_Unit_Office_Id=a.Transfer_To_Office_Id
    ) AS particular_from,
    0 AS sup_no
  FROM fas_fund_trf_from_ho_trn a,
    fas_fund_trf_from_ho_master b
  WHERE a.accounting_unit_id     = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.cashbook_year            = b.cashbook_year
  AND a.cashbook_month           = b.cashbook_month
  AND a.voucher_no               = b.voucher_no
  AND B.Transfer_Status         <>'C'
    --  AND A.Cashbook_Year            =2012
    --  AND a.cashbook_month           =4
    -- And A.Cashbook_Year           In (2009,2010,2011,2012,2013,2014)
  ))g
INNER JOIN Fas_Mst_Acct_Units B
ON g.accounting_unit_id =B.ACCOUNTING_UNIT_ID
INNER JOIN Fas_Mst_Bank_Balance C
ON g.account_no = C.Bank_Ac_No
INNER JOIN Fas_Mst_Banks Bank
ON C.Bank_Id             =Bank.Bank_Id
AND G.Accounting_Unit_Id =$P{accountingunitid}
$P!{Str_dt}
$P!{acpara}
ORDER BY g.vouDate,G.Reccheqdd_No,g.CR_DR_INDICATOR,g.Voucher_No]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="PAID_TO" class="java.lang.String"/>
	<field name="SUB_LEDGER_TYPE_CODE" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="VOUDATE" class="java.sql.Timestamp"/>
	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="VOUCHER_NO" class="java.math.BigDecimal"/>
	<field name="RECCHEQDD_NO" class="java.lang.String"/>
	<field name="RECCHEQUEDD_DATE" class="java.sql.Timestamp"/>
	<field name="BANK_ID" class="java.math.BigDecimal"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="BRANCH_NAME" class="java.lang.String"/>
	<field name="BRANCH_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_NO" class="java.math.BigDecimal"/>
	<field name="DOCUMENT_TYPE" class="java.lang.String"/>
	<field name="CR_DR_INDICATOR" class="java.lang.String"/>
	<field name="DR_AMT" class="java.math.BigDecimal"/>
	<field name="CR_AMT" class="java.math.BigDecimal"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>
	<field name="PARTICULARS" class="java.lang.String"/>
	<field name="PARTICULAR_FROM" class="java.lang.String"/>
	<field name="SUP_NO" class="java.math.BigDecimal"/>

	<variable name="SUM_RECAMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>
	<variable name="closing_bal_COL" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{SUM_RECAMT_1}.doubleValue()) +( $P{bankOpeningBal_for_COL}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="sum_payment_bankwise" class="java.math.BigDecimal" resetType="Group" resetGroup="cheque_id" calculation="Sum">
		<variableExpression><![CDATA[$F{ACCOUNT_HEAD_CODE}]]></variableExpression>
	</variable>
	<variable name="SUM_REC_AMT" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>
	<variable name="SUN_DR_AMT" class="java.math.BigDecimal" resetType="Report" incrementType="Group" incrementGroup="cheque_id" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMT}]]></variableExpression>
	</variable>
	<variable name="cr_amt_chq" class="java.math.BigDecimal" resetType="Group" resetGroup="cheque_id" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMT}]]></variableExpression>
	</variable>
	<variable name="dr_amt_chq" class="java.math.BigDecimal" resetType="Group" resetGroup="cheque_id" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>

		<group  name="findClosingBal" >
			<groupExpression><![CDATA[]]></groupExpression>
			<groupHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupHeader>
			<groupFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<group  name="dtae_group" isStartNewPage="true" >
			<groupExpression><![CDATA[$F{CASHBOOK_MONTH}]]></groupExpression>
			<groupHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupHeader>
			<groupFooter>
			<band height="1"  isSplitAllowed="true" >
				<line direction="TopDown">
					<reportElement
