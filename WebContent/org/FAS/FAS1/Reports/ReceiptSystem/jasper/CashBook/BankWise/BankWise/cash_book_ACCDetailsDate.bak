<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="cash_book_ACCDetailsDate"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1108"
		 pageHeight="842"
		 columnWidth="1048"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtCB_Year" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accountingunit_name" isForPrompting="false" class="java.lang.String"/>
	<parameter name="txtCB_Month" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtfrom" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="acpara" isForPrompting="false" class="java.lang.String"/>
	<parameter name="txtAcc_No" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="bankOpeningBal_for_COL" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="bankOpeningBal_for_OPR" isForPrompting="false" class="java.lang.Double">
		<defaultValueExpression ><![CDATA[new Double(0)]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[Select distinct
  a.acno,a.bid,a.voudate,b.OFFICE_NAME,(SELECT k.bank_name FROM fas_mst_banks k WHERE k.bank_id=a.bid
    )AS bank_name ,sum(c.opening_balance) as ob_passbook,sum(c.closing_balance) as cb_passbook,
    sum(recAmt) as recAmt,sum(payAmt)payAmt
  FROM
    (SELECT t.ACCOUNTING_UNIT_ID,
      t.ACCOUNTING_FOR_OFFICE_ID,
      t.CASHBOOK_YEAR,
      t.CASHBOOK_MONTH,
      m.receipt_date                                    AS vouDate,
      t.receipt_no                                      AS recNo,
      t.particulars                                     AS recPart,
      t.account_head_code                               AS recAcchead,
      DECODE(t.cr_dr_indicator,'CR',t.amount,-t.amount) AS recAmt,
      DECODE(t.cheque_or_dd
      || '-'
      ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
      || '-'
      ||t.cheque_dd_no) AS recCheqDD_no,
      t.cheque_dd_date  AS recChequeDD_date,
      m.received_from   AS recRecFrom,
      to_number(NULL)   AS payNo,
      TO_CHAR(NULL)     AS payPart,
      to_number(NULL)   AS payAcchead,
      to_number(NULL)   AS payAmt,
      TO_CHAR(NULL)     AS payCheqDD_no,
      to_date(NULL)     AS payChequeDD_date,
      TO_CHAR(NULL)     AS payrefno,
      TO_CHAR(NULL)     AS payPaidto,
      m.bank_id         AS bid,
      m.ACCOUNT_NO      AS acno
    FROM FAS_RECEIPT_MASTER m,
      FAS_RECEIPT_TRANSACTION t
    WHERE t.accounting_unit_id     = m.accounting_unit_id
    AND t.accounting_for_office_id = m.accounting_for_office_id
    AND t.cashbook_year            = m.cashbook_year
    AND t.cashbook_month           = m.cashbook_month
    AND t.receipt_no               = m.receipt_no
    AND m.receipt_status!          ='C'
    AND m.created_by_module       IN('CR','SC')
    UNION ALL
    SELECT t.ACCOUNTING_UNIT_ID,
      t.ACCOUNTING_FOR_OFFICE_ID,
      t.CASHBOOK_YEAR,
      t.CASHBOOK_MONTH,
      m.receipt_date                                    AS vouDate,
      t.receipt_no                                      AS recNo,
      t.particulars                                     AS recPart,
      t.account_head_code                               AS recAcchead,
      DECODE(t.cr_dr_indicator,'CR',t.amount,-t.amount) AS recAmt,
      DECODE(t.cheque_or_dd
      || '-'
      ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
      || '-'
      ||t.cheque_dd_no) AS recCheqDD_no,
      t.cheque_dd_date  AS recChequeDD_date,
      m.received_from   AS recRecFrom,
      to_number(NULL)   AS payNo,
      TO_CHAR(NULL)     AS payPart,
      to_number(NULL)   AS payAcchead,
      to_number(NULL)   AS payAmt,
      TO_CHAR(NULL)     AS payCheqDD_no,
      to_date(NULL)     AS payChequeDD_date,
      TO_CHAR(NULL)     AS payrefno,
      TO_CHAR(NULL)     AS payPaidto,
      m.bank_id         AS bid,
      m.ACCOUNT_NO      AS acno
    FROM FAS_RECEIPT_MASTER m,
      FAS_RECEIPT_TRANSACTION t
    WHERE t.accounting_unit_id     = m.accounting_unit_id
    AND t.accounting_for_office_id = m.accounting_for_office_id
    AND t.cashbook_year            = m.cashbook_year
    AND t.cashbook_month           = m.cashbook_month
    AND t.receipt_no               = m.receipt_no
    AND m.receipt_status!          ='C'
      -- AND m.bank_id                  =2
    AND m.created_by_module ='BR'
    UNION ALL
    SELECT t.ACCOUNTING_UNIT_ID,
      t.ACCOUNTING_FOR_OFFICE_ID,
      t.CASHBOOK_YEAR,
      t.CASHBOOK_MONTH,
      m.payment_date                                    AS vouDate,
      to_number(NULL)                                   AS recNo,
      TO_CHAR(NULL)                                     AS recPart,
      to_number(NULL)                                   AS recAcchead,
      to_number(NULL)                                   AS recAmt,
      TO_CHAR(NULL)                                     AS recCheqDD_no,
      to_date(NULL)                                     AS recChequeDD_date,
      TO_CHAR(NULL)                                     AS recRecFrom,
      t.voucher_no                                      AS payNo,
      t.particulars                                     AS payPart,
      t.account_head_code                               AS payAcchead,
      DECODE(t.cr_dr_indicator,'DR',t.amount,-t.amount) AS payAmt,
      DECODE(t.cheque_or_dd
      || '-'
      ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
      || '-'
      ||t.cheque_dd_no) AS payCheqDD_no,
      t.cheque_dd_date  AS payChequeDD_date,
      TO_CHAR(NULL)     AS payrefno,
      m.paid_to         AS payPaidto,
      m.bank_id         AS bid,
      m.ACCOUNT_NO      AS acno
    FROM FAS_PAYMENT_MASTER m,
      FAS_PAYMENT_TRANSACTION t
    WHERE t.accounting_unit_id     = m.accounting_unit_id
    AND t.accounting_for_office_id = m.accounting_for_office_id
    AND t.cashbook_year            = m.cashbook_year
    AND t.cashbook_month           = m.cashbook_month
    AND t.voucher_no               = m.voucher_no
    AND m.PAYMENT_status!          ='C'
      -- AND m.bank_id                  =2
    AND m.created_by_module IN ('BPP','BPF','NP')
    UNION ALL
    SELECT t.ACCOUNTING_UNIT_ID,
      t.ACCOUNTING_FOR_OFFICE_ID,
      t.CASHBOOK_YEAR,
      t.CASHBOOK_MONTH,
      M.Payment_Date                                    As Voudate,

      to_number(NULL)                                   AS recNo,
      TO_CHAR(NULL)                                     AS recPart,
      to_number(NULL)                                   AS recAcchead,
      to_number(NULL)                                   AS recAmt,
      TO_CHAR(NULL)                                     AS recCheqDD_no,
      to_date(NULL)                                     AS recChequeDD_date,
      To_Char(Null)                                     As Recrecfrom,
      
      t.voucher_no                                      AS payNo,
      t.particulars                                     AS payPart,
      t.account_head_code                               AS payAcchead,
      DECODE(t.cr_dr_indicator,'DR',t.amount,-t.amount) AS payAmt,
      DECODE(t.cheque_or_dd
      || '-'
      ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
      || '-'
      ||t.cheque_dd_no) AS payCheqDD_no,
      t.cheque_dd_date  AS payChequeDD_date,
      TO_CHAR(NULL)     AS payrefno,
      m.paid_to         AS payPaidto,
      m.bank_id         AS bid,
      m.ACCOUNT_NO      AS acno
    FROM FAS_PAYMENT_MASTER m,
      FAS_PAYMENT_TRANSACTION t
    WHERE t.accounting_unit_id     = m.accounting_unit_id
    AND t.accounting_for_office_id = m.accounting_for_office_id
    AND t.cashbook_year            = m.cashbook_year
    AND t.cashbook_month           = m.cashbook_month
    AND t.voucher_no               = m.voucher_no
    AND m.PAYMENT_status!          ='C'
    AND m.created_by_module       IN ('SC')
    UNION ALL
    SELECT ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      DATE_OF_TRANSFER     AS vouDate,
      VOUCHER_NO           AS recNo,
      particulars          AS recPart,
      DR_ACCOUNT_HEAD_CODE AS recAcchead,
      TOTAL_AMOUNT         AS recAmt,
      DECODE(cheque_or_dd
      || '-'
      ||cheque_dd_no,'-',NULL,cheque_or_dd
      || '-'
      ||cheque_dd_no)              AS recCheqDD_no,
      cheque_dd_date               AS recChequeDD_date,
      TO_CHAR('Interbank Receipt') AS recRecFrom,
      to_number(NULL)              AS payNo,
      TO_CHAR(NULL)                AS payPart,
      to_number(NULL)              AS payAcchead,
      to_number(NULL)              AS payAmt,
      TO_CHAR(NULL)                AS payCheqDD_no,
      to_date(NULL)                AS payChequeDD_date,
      TO_CHAR(NULL)                AS payrefno,
      TO_CHAR(NULL)                AS payPaidto,
      TO_BANK_ID                   AS bid,
      TO_ACCOUNT_NO                AS acno
    FROM FAS_INTER_BANK_TRF_AT_HO
    WHERE TRANSFER_STATUS!='C'
    -- AND TO_BANK_ID        =2
    UNION ALL
    SELECT ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      DATE_OF_TRANSFER     AS vouDate,
      to_number(NULL)      AS recNo,
      TO_CHAR(NULL)        AS recPart,
      to_number(NULL)      AS recAcchead,
      to_number(NULL)      AS recAmt,
      TO_CHAR(NULL)        AS recCheqDD_no,
      to_date(NULL)        AS recChequeDD_date,
      TO_CHAR(NULL)        AS recRecFrom,
      voucher_no           AS payNo,
      particulars          AS payPart,
      CR_ACCOUNT_HEAD_CODE AS payAcchead,
      TOTAL_AMOUNT         AS payAmt,
      DECODE(cheque_or_dd
      || '-'
      ||cheque_dd_no,'-',NULL,cheque_or_dd
      || '-'
      ||cheque_dd_no)               AS payCheqDD_no,
      cheque_dd_date                AS payChequeDD_date,
      TO_CHAR(NULL)                 AS payrefno,
      TO_CHAR('Interbank Transfer') AS payPaidto,
      FROM_BANK_ID                  AS bid,
      FROM_ACCOUNT_NO               AS acno
    FROM FAS_INTER_BANK_TRF_AT_HO
    WHERE TRANSFER_STATUS!='C'
    --  AND FROM_BANK_ID      =2
    UNION ALL
    SELECT ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      receipt_date         AS vouDate,
      receipt_no           AS recNo,
      particulars          AS recPart,
      DR_ACCOUNT_HEAD_CODE AS recAcchead,
      TOTAL_AMOUNT         AS recAmt,
      DECODE(cheque_or_dd
      || '-'
      ||cheque_dd_no,'-',NULL,cheque_or_dd
      || '-'
      ||cheque_dd_no) AS recCheqDD_no,
      cheque_dd_date  AS recChequeDD_date,
      --to_char('Fund Receipt') as recRecFrom,
      (
      SELECT u.OFFICE_NAME
      FROM COM_MST_OFFICES u
      WHERE u.OFFICE_ID=Received_From_Office_Id
      )               AS Recrecfrom,
      to_number(NULL) AS payNo,
      TO_CHAR(NULL)   AS payPart,
      to_number(NULL) AS payAcchead,
      to_number(NULL) AS payAmt,
      TO_CHAR(NULL)   AS payCheqDD_no,
      to_date(NULL)   AS payChequeDD_date,
      TO_CHAR(NULL)   AS payrefno,
      TO_CHAR(NULL)   AS payPaidto,
      HO_BANK_ID      AS bid,
      HO_ACCOUNT_NO   AS acno
    FROM FAS_FUND_RECEIPT_BY_HO
    WHERE RECEIPT_STATUS!='C'
    -- AND HO_BANK_ID       =2
    UNION ALL
    SELECT t.ACCOUNTING_UNIT_ID,
      t.ACCOUNTING_FOR_OFFICE_ID,
      t.CASHBOOK_YEAR,
      t.CASHBOOK_MONTH,
      m.DATE_OF_TRANSFER  AS vouDate,
      to_number(NULL)     AS recNo,
      TO_CHAR(NULL)       AS recPart,
      to_number(NULL)     AS recAcchead,
      to_number(NULL)     AS recAmt,
      TO_CHAR(NULL)       AS recCheqDD_no,
      to_date(NULL)       AS recChequeDD_date,
      TO_CHAR(NULL)       AS recRecFrom,
      t.voucher_no        AS payNo,
      t.particulars       AS payPart,
      t.ACCOUNT_HEAD_CODE AS payAcchead,
      t.AMOUNT            AS payAmt,
      DECODE(t.cheque_or_dd
      || '-'
      ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
      || '-'
      ||t.cheque_dd_no) AS payCheqDD_no,
      t.cheque_dd_date  AS paychequedd_date,
      TO_CHAR(NULL)     AS payRefno,
      --to_char('Fund Transfer') as payPaidto
      (
      SELECT u.OFFICE_NAME
      FROM COM_MST_OFFICES u
      WHERE u.office_id=transfer_to_office_id
      )             AS payPaidto,
      HO_BANK_ID    AS bid,
      HO_ACCOUNT_NO AS acno
    FROM FAS_FUND_TRF_FROM_HO_MASTER m,
      FAS_FUND_TRF_FROM_HO_TRN t
    WHERE t.accounting_unit_id     = m.accounting_unit_id
    AND t.accounting_for_office_id = m.accounting_for_office_id
    AND t.cashbook_year            = m.cashbook_year
    AND t.cashbook_month           = m.cashbook_month
    AND t.voucher_no               = m.voucher_no
    AND TRANSFER_STATUS!           ='C'
      -- AND HO_BANK_ID                 =2
    ) a, COM_MST_OFFICES b,FAS_MST_BANK_BALANCE c
where a.accounting_unit_id    =$P{accountingunitid}
and a.acno=$P{txtAcc_No}
AND a.voudate BETWEEN to_date($P{txtfrom},'DD/MM/YYYY') AND to_date($P{txtto},'DD/MM/YYYY')
and a.accounting_for_office_id=b.office_id  
and a.bid = c.bank_id
and a.acno = c.bank_ac_no
GROUP BY a.acno,a.bid,a.voudate,b.OFFICE_NAME
 
order by a.acno,a.voudate]]></queryString>

	<field name="ACNO" class="java.math.BigDecimal"/>
	<field name="BID" class="java.math.BigDecimal"/>
	<field name="VOUDATE" class="java.sql.Timestamp"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="OB_PASSBOOK" class="java.math.BigDecimal"/>
	<field name="CB_PASSBOOK" class="java.math.BigDecimal"/>
	<field name="RECAMT" class="java.math.BigDecimal"/>
	<field name="PAYAMT" class="java.math.BigDecimal"/>

	<variable name="Rec_Amt_Sum" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{RECAMT}]]></variableExpression>
	</variable>
	<variable name="Pay_Amt_Sum" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{PAYAMT}]]></variableExpression>
	</variable>
	<variable name="CB_Abstract" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{Total_Abstract}.doubleValue())-($V{Pay_Amt_Sum}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="Total_Abstract" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($P{bankOpeningBal_for_COL}.doubleValue())+($V{Rec_Amt_Sum}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="closing_bal_COL" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{Rec_Amt_Sum}.doubleValue()) +( $P{bankOpeningBal_for_COL}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="closing_bal_OPR" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new BigDecimal(($V{Pay_Amt_Sum}.doubleValue()) -( $P{bankOpeningBal_for_OPR}.doubleValue()))]]></variableExpression>
	</variable>
		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
