	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT bank_id,BANK_NAME,b_amt as b,c_amt as c,(b_amt+c_amt) as total from
(select 
  b,c,m.bank_id as bank_1,n.bank_id as bank_2,(case when m.bank_id is null then n.bank_id else m.bank_id end)as bank_id,BANK_NAME,
  (case when b is null then 0 else b end)as b_amt,(case when c is null then 0 else c end)as c_amt
from (

(SELECT SUM( CASE WHEN x.receipt_type = 'B' THEN x.total_amount ELSE 0 END) AS b,
 bank_id      
FROM fas_receipt_master x
WHERE 
 
x.cashbook_month =$P{cashbookmonth}
  AND x.cashbook_year =$P{cashbookyear}
  and x.receipt_status = 'L' 
  and x.created_by_module ='BR'
  and x.bank_id > 0
GROUP BY  x.bank_id 
ORDER BY  x.bank_id 
 ) m
left outer join
(SELECT SUM( CASE WHEN y.PAYMENT_TYPE = 'C' THEN y.total_amount ELSE 0 END) AS c, 
       
 bank_id      
FROM fas_payment_master y
WHERE 

y.cashbook_month =$P{cashbookmonth}
  AND y.cashbook_year =$P{cashbookyear}
  and y.payment_status = 'L' 
  and Y.created_by_module='CRM'
  and Y.bank_id > 0
GROUP BY  y.bank_id 
ORDER BY  y.bank_id 
) n 
on m.bank_id=n.bank_id
)

left outer join 

(
  select 
       BANK_ID, 
       BANK_NAME
 from 
      FAS_MST_BANKS     

) mm
on m.BANK_ID=mm.BANK_ID 
order by bank_id
)]]></queryString>

	<field name="BANK_ID" class="java.math.BigDecimal"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="B" class="java.math.BigDecimal"/>
	<field name="C" class="java.math.BigDecimal"/>
	<field name="TOTAL" class="java.math.BigDecimal"/>

	<variable name="SUM_C_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{C}]]></variableExpression>
	</variable>
	<variable name="SUM_B_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{B}]]></variableExpression>
	</variable>
	<variable name="SUM_TOTAL_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
	</variable>
