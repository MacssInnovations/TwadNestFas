<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ListOfReportAccountWise_withoutDate_office"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="898"
		 pageHeight="595"
		 columnWidth="870"
		 columnSpacing="0"
		 leftMargin="14"
		 rightMargin="14"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="false" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="false" class="java.util.Date"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select * from 
(

SELECT   
        decode(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',10,'Project', 11,'Contractors',12,'Scheme Owner',13,'Beneficiary','-') as sub_ledger_type_code_desc,
        d.ACCOUNT_HEAD_DESC,
        c.office_name,
        b.paid_to as paid_received,
           
   (  select sl_codeName from SL_TYPE_CODE_NAME_VIEW 
      where  sl_type=a.sub_ledger_type_code 
         and sl_code=a.SUB_LEDGER_CODE
   ) as slcode,
         b.payment_date AS datevalue,
         b.voucher_no as voucher_no,
         'P' AS document_type,
         a.cr_dr_indicator,
          
         case when a.cr_dr_indicator = 'DR' then
               a.amount 
               else
               0  
             END as dr_amt,
               
          case when a.cr_dr_indicator = 'CR' then
                  a.amount 
               else
               0 
             END  as cr_amt,
                  
          a.amount as amt,
          a.particulars 
 
 FROM 
          fas_payment_transaction a,
          fas_payment_master b,
          COM_MST_OFFICES c,
          COM_MST_ACCOUNT_HEADS d
WHERE 
    a.accounting_unit_id = b.accounting_unit_id
AND a.accounting_for_office_id = b.accounting_for_office_id 
AND a.cashbook_year = b.cashbook_year
AND a.cashbook_month = b.cashbook_month 
AND a.voucher_no= b.voucher_no 
AND b.payment_status<>'C' 
and b.cashbook_year=$P{txtCB_Year}  
and b.cashbook_month= $P{txtCB_Month}
and a.accounting_unit_id = $P{accountingunitid} 
AND a.accounting_for_office_id = $P{accountofficeid}
AND a.account_head_code = $P{accountheadcode}
AND c.office_id=a.accounting_for_office_id 
and a.ACCOUNT_HEAD_CODE=d.account_head_code 







UNION all 









SELECT 
             decode(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',
10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary','-')as sub_ledger_type_code_desc,
            d.ACCOUNT_HEAD_DESC,
            c.office_name,
            b.received_from  as paid_received,
           
    (
          select 
                sl_codeName 
          from 
                SL_TYPE_CODE_NAME_VIEW 
          where 
                sl_type=a.sub_ledger_type_code 
         and sl_code=a.SUB_LEDGER_CODE
     ) as slcode,
     
        b.receipt_date AS datevalue,
        b.receipt_no as voucher_no,
        'R' as documenttype,
        a.cr_dr_indicator,
         
        case when a.cr_dr_indicator = 'DR' then
               a.amount 
               else
               0  
             END as dr_amt,
               
        case when a.cr_dr_indicator = 'CR' then
               a.amount 
               else
               0 
             END  as cr_amt,
                           
         a.amount as amt,
         a.particulars 
       
FROM 
        fas_receipt_transaction a,
        fas_receipt_master b,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where
a.accounting_unit_id = b.accounting_unit_id AND 
a.accounting_for_office_id = b.accounting_for_office_id AND 
a.cashbook_year = b.cashbook_year AND 
a.cashbook_month = b.cashbook_month AND 
a.receipt_no= b.receipt_no AND 
b.receipt_status<>'C' and
b.cashbook_year=$P{txtCB_Year}  and 
b.cashbook_month= $P{txtCB_Month} and 
a.accounting_unit_id = $P{accountingunitid} AND
a.accounting_for_office_id = $P{accountofficeid} AND
a.account_head_code = $P{accountheadcode} AND 
c.office_id=a.accounting_for_office_id and 
a.ACCOUNT_HEAD_CODE=d.account_head_code 







UNION all







SELECT 
  
decode(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary','-')as sub_ledger_type_code_desc,

d.ACCOUNT_HEAD_DESC,
c.office_name,
' ' as paid_received,

(
  select 
          sl_codeName
  from 
        SL_TYPE_CODE_NAME_VIEW 
  where
        sl_type=a.sub_ledger_type_code and 
        sl_code=a.SUB_LEDGER_CODE
) as slcode,
b.voucher_date AS datevalue,
b.voucher_no as voucher_no ,
'J' AS document_type,
a.cr_dr_indicator,

         case when a.cr_dr_indicator = 'DR' then
               a.amount 
               else
               0  
             END as dr_amt,
               
          case when a.cr_dr_indicator = 'CR' then
                  a.amount 
               else
               0 
          END  as cr_amt,           
                  
  a.amount as amt,
  a.particulars 

 FROM 

fas_journal_transaction a,
fas_journal_master b,
COM_MST_OFFICES c,
COM_MST_ACCOUNT_HEADS d 

where

a.accounting_unit_id=b.accounting_unit_id and 
a.accounting_for_office_id = b.accounting_for_office_id AND 
a.cashbook_year = b.cashbook_year AND 
a.cashbook_month = b.cashbook_month AND 
a.voucher_no= b.voucher_no AND 
b.journal_status<>'C' and
b.cashbook_year=$P{txtCB_Year}  and b.cashbook_month= $P{txtCB_Month} and 
a.accounting_unit_id= $P{accountingunitid} and 
a.accounting_for_office_id= $P{accountofficeid}and
a.ACCOUNT_HEAD_CODE=$P{accountheadcode} AND 
c.office_id=a.accounting_for_office_id and a.ACCOUNT_HEAD_CODE=d.account_head_code







union all 









select
     distinct(sub_ledger_type_code_desc) as sub_ledger_type_code_desc,
     ACCOUNT_HEAD_DESC,
     office_name,
     paid_to as paid_received,
     slcode,
     datevalue,
     voucher_no,
     document_type,
     cr_dr_indicator,      
      
      CASE WHEN cr_dr_indicator = 'DR' THEN
               TOTAL_AMOUNT
           ELSE
               0  
           END as dr_amt,
               
     case when cr_dr_indicator = 'CR' then
               TOTAL_AMOUNT
               else
               0  
           end as cr_amt,
           
     TOTAL_AMOUNT as amt ,
     REMARKS  as particulars
from
(
 SELECT   
               decode(b.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'ChequeBooks',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',10,'Project',
11,'Contractors',12,'Scheme Owner',13,'Beneficiary','-') as sub_ledger_type_code_desc,
             d.ACCOUNT_HEAD_DESC,
             c.office_name,
             b.paid_to,
           
   (
      select 
                 sl_codeName 
      from 
                 SL_TYPE_CODE_NAME_VIEW 
      where 
                 sl_type=b.sub_ledger_type_code 
          and sl_code=b.SUB_LEDGER_CODE
   ) as   slcode,
          b.payment_date AS datevalue,
          b.voucher_no as voucher_no,
          'P' AS document_type,
          b.cr_dr_indicator,
          b.TOTAL_AMOUNT,
          b.REMARKS 
 
 FROM     
          fas_payment_transaction a,  
          fas_payment_master b,
          COM_MST_OFFICES c,
          COM_MST_ACCOUNT_HEADS d
WHERE 
    
       a.ACCOUNTING_UNIT_ID !=b.ACCOUNTING_UNIT_ID
 and   a.ACCOUNTING_FOR_OFFICE_ID != b.ACCOUNTING_FOR_OFFICE_ID
 and   a.CASHBOOK_YEAR != b.CASHBOOK_YEAR
 and   a.CASHBOOK_MONTH != b.CASHBOOK_MONTH
 and   a.VOUCHER_NO !=b.VOUCHER_NO
 and   a.ACCOUNT_HEAD_CODE !=b.ACCOUNT_HEAD_CODE
 

and b.payment_status<>'C' 
and b.cashbook_year=$P{txtCB_Year}  
and b.cashbook_month=$P{txtCB_Month}
and b.accounting_unit_id = $P{accountingunitid} 
AND b.accounting_for_office_id = $P{accountofficeid}
AND b.account_head_code = $P{accountheadcode}
AND c.office_id=b.accounting_for_office_id 
and b.ACCOUNT_HEAD_CODE=d.account_head_code 
)







union all 







select 
     distinct(sub_ledger_type_code_desc) as sub_ledger_type_code_desc,
     ACCOUNT_HEAD_DESC,
     office_name,
     paid_received,
     slcode,
     datevalue,
     voucher_no,
     document_type,
     cr_dr_indicator,
     
      CASE WHEN cr_dr_indicator = 'DR' THEN
               TOTAL_AMOUNT
           ELSE
               0  
           END as dr_amt,
               
     case when cr_dr_indicator = 'CR' then
               TOTAL_AMOUNT
               else
               0  
           end as cr_amt,    
     
     TOTAL_AMOUNT as amt ,
     REMARKS  as particulars

from

( SELECT 
          decode(b.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'OtherDepartments',
          10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary','-')as sub_ledger_type_code_desc,
          d.ACCOUNT_HEAD_DESC,
          c.office_name,
          b.received_from  as paid_received,
       (  select sl_codeName from SL_TYPE_CODE_NAME_VIEW  where sl_type=b.sub_ledger_type_code and sl_code=b.SUB_LEDGER_CODE  ) as slcode,
            b.receipt_date AS datevalue,
        b.receipt_no as voucher_no,
        'R' as document_type,
        b.cr_dr_indicator,
        b.TOTAL_AMOUNT ,
        b.REMARKS 
       
FROM 
        fas_receipt_transaction a,
        fas_receipt_master b,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where

       a.ACCOUNTING_UNIT_ID !=b.ACCOUNTING_UNIT_ID
 and   a.ACCOUNTING_FOR_OFFICE_ID != b.ACCOUNTING_FOR_OFFICE_ID
 and   a.CASHBOOK_YEAR != b.CASHBOOK_YEAR
 and   a.CASHBOOK_MONTH != b.CASHBOOK_MONTH
 and   a.RECEIPT_NO !=b.RECEIPT_NO                      
 and   a.ACCOUNT_HEAD_CODE !=b.ACCOUNT_HEAD_CODE and 

b.receipt_status<>'C' and
b.cashbook_year=$P{txtCB_Year}  and 
b.cashbook_month= $P{txtCB_Month} and 
b.accounting_unit_id = $P{accountingunitid} AND
b.accounting_for_office_id = $P{accountofficeid} AND
b.account_head_code = $P{accountheadcode} AND
c.office_id=b.accounting_for_office_id and 
b.ACCOUNT_HEAD_CODE=d.account_head_code 
)




union all 





SELECT 
       '' as sub_ledger_type_code_desc,
       d.ACCOUNT_HEAD_DESC,
       c.office_name,
       '' as paid_received,
       '' as slcode,
       a.RECEIPT_DATE AS datevalue,
       a.RECEIPT_NO as voucher_no,
       'FR' as document_type,
       'CR' as cr_dr_indicator, 
       0 as dr_amt, 
       a.total_amount as cr_amt,    
       a.TOTAL_AMOUNT as amt,
       a.PARTICULARS  
       
FROM 
        FAS_FUND_RECEIPT_BY_OFFICE a,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where

       a.receipt_status<>'C' 
 and   a.cashbook_year=$P{txtCB_Year} 
 and   a.cashbook_month=$P{txtCB_Month}
 and   a.accounting_unit_id = $P{accountingunitid} 
 AND   a.accounting_for_office_id = $P{accountofficeid}
 AND   a.CR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}
 AND   c.office_id=a.accounting_for_office_id 
 and   a.CR_ACCOUNT_HEAD_CODE=d.account_head_code 


union all 



SELECT 
       '' as sub_ledger_type_code_desc,
       d.ACCOUNT_HEAD_DESC,
       c.office_name,
       '' as paid_received,
       '' as slcode,
       a.RECEIPT_DATE AS datevalue,
       a.RECEIPT_NO as voucher_no,
       'FR' as document_type,
       'DR' as cr_dr_indicator, 
       a.total_amount as dr_amt, 
       0 as cr_amt,    
       a.TOTAL_AMOUNT as amt,
       a.PARTICULARS  
       
FROM 
        FAS_FUND_RECEIPT_BY_OFFICE a,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where

       a.receipt_status<>'C' 
 and   a.cashbook_year=$P{txtCB_Year} 
 and   a.cashbook_month= $P{txtCB_Month}
 and   a.accounting_unit_id = $P{accountingunitid} 
 AND   a.accounting_for_office_id = $P{accountofficeid}
 AND   a.DR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}
 AND   c.office_id=a.accounting_for_office_id 
 and   a.DR_ACCOUNT_HEAD_CODE=d.account_head_code 



union all 
  

 

select 
   '' as sub_ledger_type_code_desc,
   d.ACCOUNT_HEAD_DESC,
   c.office_name,
   '' as paid_received,
   '' as slcode,
   a.DATE_OF_TRANSFER as datevalue,
   a.VOUCHER_NO as voucher_no,
   'FT' as document_type,
   'DR' as cr_dr_indicator, 
   a.total_amount as dr_amt, 
   0 as cr_amt,    
   a.TOTAL_AMOUNT as amt,
   a.PARTICULARS  
   
from 
   fas_fund_trf_from_office a, 
   COM_MST_OFFICES c,
   COM_MST_ACCOUNT_HEADS d 
where
       a.TRANSFER_STATUS<>'C' 
 and   a.cashbook_year=$P{txtCB_Year} 
 and   a.cashbook_month= $P{txtCB_Month}
 and   a.accounting_unit_id = $P{accountingunitid}
 AND   a.accounting_for_office_id = $P{accountofficeid}
 AND   a.DR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}
 AND   c.office_id=a.accounting_for_office_id 
 and   a.DR_ACCOUNT_HEAD_CODE=d.account_head_code 
   
   
union all



select 
   '' as sub_ledger_type_code_desc,
   d.ACCOUNT_HEAD_DESC,
   c.office_name,
   '' as paid_received,
   '' as slcode,
   a.DATE_OF_TRANSFER as datevalue,
   a.VOUCHER_NO as voucher_no,
   'FT' as document_type,
   'CR' as cr_dr_indicator, 
   0 as dr_amt,    
   a.total_amount as cr_amt, 
   a.TOTAL_AMOUNT as amt,
   a.PARTICULARS  
   
from 
   fas_fund_trf_from_office a, 
   COM_MST_OFFICES c,
   COM_MST_ACCOUNT_HEADS d 
where
       a.TRANSFER_STATUS<>'C' 
 and   a.cashbook_year=$P{txtCB_Year} 
 and   a.cashbook_month= $P{txtCB_Month}
 and   a.accounting_unit_id = $P{accountingunitid} 
 AND   a.accounting_for_office_id = $P{accountofficeid}
 AND   a.CR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}
 AND   c.office_id=a.accounting_for_office_id 
 and   a.CR_ACCOUNT_HEAD_CODE=d.account_head_code 
 
 
 union all 
 -- IBT Cr 
 
select 
     distinct(sub_ledger_type_code_desc) as sub_ledger_type_code_desc,
     ACCOUNT_HEAD_DESC,
     office_name,
     paid_received,
     slcode,
     datevalue,
     voucher_no,
     document_type,
     cr_dr_indicator,
       
     CASE WHEN cr_dr_indicator = 'DR' THEN
               TOTAL_AMOUNT
           ELSE
               0  
           END as dr_amt,
               
     case when cr_dr_indicator = 'CR' then
               TOTAL_AMOUNT
               else
               0  
           end as cr_amt,
       
     
     to_char(TOTAL_AMOUNT) as amt ,
     PARTICULARS 

from

( SELECT 
       '' as sub_ledger_type_code_desc,
       d.ACCOUNT_HEAD_DESC,
       c.office_name,
       '' as paid_received,
       '' as slcode,
       DATE_OF_TRANSFER AS datevalue,
       VOUCHER_NO as voucher_no,
       'IBT' as document_type,
       'CR' as cr_dr_indicator, 
       TOTAL_AMOUNT ,
       PARTICULARS  
       
FROM 
        fas_inter_bank_trf_at_ho a,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where

       a.TRANSFER_STATUS<>'C' 
 and   a.cashbook_year = $P{txtCB_Year}
 and   a.cashbook_month = $P{txtCB_Month}
 and   a.accounting_unit_id = $P{accountingunitid}
 AND   a.accounting_for_office_id = $P{accountofficeid}
 AND   a.CR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}
 AND   c.office_id=a.accounting_for_office_id 
 and   a.CR_ACCOUNT_HEAD_CODE=d.account_head_code 

)

union all 
-- IBT Dr

select 
     distinct(sub_ledger_type_code_desc) as sub_ledger_type_code_desc,
     ACCOUNT_HEAD_DESC,
     office_name,
     paid_received,
     slcode,
     datevalue,
     voucher_no,
     document_type,
     cr_dr_indicator,
       
     CASE WHEN cr_dr_indicator = 'DR' THEN
               TOTAL_AMOUNT
           ELSE
               0  
           END as dr_amt,
               
     case when cr_dr_indicator = 'CR' then
               TOTAL_AMOUNT
               else
               0  
           end as cr_amt,
       
     
     to_char(TOTAL_AMOUNT) as amt ,
     PARTICULARS 

from

( SELECT 
       '' as sub_ledger_type_code_desc,
       d.ACCOUNT_HEAD_DESC,
       c.office_name,
       '' as paid_received,
       '' as slcode,
       DATE_OF_TRANSFER AS datevalue,
       VOUCHER_NO as voucher_no,
       'IBT' as document_type,
       'DR' as cr_dr_indicator, 
       TOTAL_AMOUNT ,
       PARTICULARS  
       
FROM 
        fas_inter_bank_trf_at_ho a,
        COM_MST_OFFICES c,
        COM_MST_ACCOUNT_HEADS d 
where

       a.TRANSFER_STATUS<>'C' 
 and   a.cashbook_year = $P{txtCB_Year}
 and   a.cashbook_month = $P{txtCB_Month}
 and   a.accounting_unit_id = $P{accountingunitid}
 AND   a.accounting_for_office_id = $P{accountofficeid}
 AND   a.DR_ACCOUNT_HEAD_CODE =  $P{accountheadcode}
 AND   c.office_id=a.accounting_for_office_id 
 and   a.DR_ACCOUNT_HEAD_CODE=d.account_head_code 

)


 
 
 
 
)

order by  document_type , voucher_no , datevalue]]></queryString>

	<field name="SUB_LEDGER_TYPE_CODE_DESC" class="java.lang.String"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="PAID_RECEIVED" class="java.lang.String"/>
	<field name="SLCODE" class="java.lang.String"/>
	<field name="DATEVALUE" class="java.sql.Timestamp"/>
	<field name="VOUCHER_NO" class="java.math.BigDecimal"/>
	<field name="DOCUMENT_TYPE" class="java.lang.String"/>
	<field name="CR_DR_INDICATOR" class="java.lang.String"/>
	<field name="DR_AMT" class="java.math.BigDecimal"/>
	<field name="CR_AMT" class="java.math.BigDecimal"/>
	<field name="AMT" class="java.lang.String"/>
	<field name="PARTICULARS" class="java.lang.String"/>

	<variable name="SUM_AMT_1" class="java.lang.String" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_DR_INDICATOR_1" class="java.lang.String" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_DR_INDICATOR}]]></variableExpression>
	</variable>
	<variable name="SUM_DR_AMT_1" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMT}]]></variableExpression>
	</variable>
	<variable name="SUM_CR_AMT_1" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
