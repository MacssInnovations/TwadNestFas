	<parameter name="unitqry" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select document_date,
cashbook_year,
cashbook_month,
document_date,
DOCUMENT_TYPE,
DOCUMENT_NO,
cheque_or_dd,
CHEQUE_DD_NO,
cheque_dd_date,
AMOUNT,
remarks,
issue_cheque,
CREA_PAY_VOU,
issue_cheque_or_dd,
ISSUE_CHEQUE_NO,
issue_cheque_date,
issue_cheque_amount,
CHEQ_CANCEL_DATE,
REVERT_CHEQCANCEL_STATUS,
 (SELECT U.Accounting_Unit_Name
  FROM Fas_Mst_Acct_Units U
  where u.accounting_unit_id=a.accounting_unit_id
  ) as unitname
from FAS_CHEQUE_CANCEL a 
$P!{unitqry}
$P!{qry}
order by a.accounting_unit_id ,a.document_date DESC ,a.document_no ASC]]></queryString>

