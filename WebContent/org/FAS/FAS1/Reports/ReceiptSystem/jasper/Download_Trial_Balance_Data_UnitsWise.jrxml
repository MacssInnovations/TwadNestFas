	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select
   ACCOUNTING_UNIT_ID, 
   ACCOUNTING_FOR_OFFICE_ID, 
   ACCOUNT_HEAD_CODE, 
   DEBIT_OPENING_BALANCE,
   CREDIT_OPENING_BALANCE, 
   CURRENT_MONTH_DEBIT, 
   CURRENT_MONTH_CREDIT, 
   DEBIT_CLOSING_BALANCE, 
   CREDIT_CLOSING_BALANCE,
   UPDATED_BY_USER_ID,
   UPDATED_DATE, 
   DATE_UPDATED,
  ( select accounting_unit_name from fas_mst_acct_units where accounting_unit_id = $P{unitid} ) as acc_name
from fas_trial_balance
where cashbook_year=$P{cashbookyear}
and cashbook_month= $P{cashbookmonth}
and accounting_unit_id = $P{unitid} 
and accounting_unit_id in 
( 
  select accounting_unit_id from fas_trial_balance_status 
  where cashbook_year=$P{cashbookyear}
    and cashbook_month= $P{cashbookmonth}
    and accounting_unit_id = $P{unitid} 
)
order by accounting_unit_id,
         account_head_code]]></queryString>

