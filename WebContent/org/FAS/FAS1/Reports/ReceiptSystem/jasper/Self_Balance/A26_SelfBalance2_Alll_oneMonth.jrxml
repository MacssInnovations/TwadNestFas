	<parameter name="cashbookyear_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="UnitName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue_from" isForPrompting="true" class="java.lang.String"/>
	<parameter name="OfficeName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue_to" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sl_type" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select test1.* from(
SELECT *
FROM
  (SELECT (s.ACCOUNTING_UNIT_ID)    AS ACCOUNTING_UNIT_ID ,
    (s.ACCOUNTING_FOR_OFFICE_ID )   AS ACCOUNTING_FOR_OFFICE_ID,
    (s.FINANCIAL_YEAR)              AS FINANCIAL_YEAR,
    (s.YEAR)                        AS YEAR,
    (s.MONTH)                       AS MONTH,
    (s.ACCOUNT_HEAD_CODE)               AS ACCOUNT_HEAD_CODE,
    (s.SUB_LEDGER_TYPE_CODE)        AS SUB_LEDGER_TYPE_CODE,
    (s.SUB_LEDGER_CODE)             AS SUB_LEDGER_CODE,
    (v.SUB_LEDGER_TYPE_DESC)        AS SUB_LEDGER_TYPE_DESC,
    (s.MONTH_OPENING_BALANCE)           AS MONTH_OPENING_BALANCE ,
    (s.MONTH_OPENING_BAL_DR_CR_IND) AS MONTH_OPENING_BAL_DR_CR_IND,
    (s.MONTH_CLOSING_BALANCE)           AS MONTH_CLOSING_BALANCE,
    (s.MONTH_CLOSING_BAL_DR_CR_IND) AS MONTH_CLOSING_BAL_DR_CR_IND,
    (s.vouType)                     AS vouType,
    (s.vouNO)                       AS vouNO,
    (s.vouDate)                         AS vouDate,
    (s.BILL_NO)                     AS BILL_NO,
    (s.BILL_DATE)                       AS BILL_DATE,
    (s.AGREEMENT_NO)                AS AGREEMENT_NO,
    (s.PARTICULARS)                 AS PARTICULARS,
    (s.CREDIT_AMOUNT)                   AS CREDIT_AMOUNT,
    (s.DEBIT_AMOUNT)                    AS DEBIT_AMOUNT,
    (h.ACCOUNT_HEAD_DESC)           AS ACCOUNT_HEAD_DESC
  FROM
    (SELECT m.ACCOUNTING_UNIT_ID,
      m.ACCOUNTING_FOR_OFFICE_ID,
      m.FINANCIAL_YEAR,
      m.YEAR,
      m.MONTH,
      m.ACCOUNT_HEAD_CODE,
      m.SUB_LEDGER_TYPE_CODE,
      m.SUB_LEDGER_CODE,
      m.MONTH_OPENING_BALANCE,
      m.MONTH_OPENING_BAL_DR_CR_IND,
      m.CURRENT_MONTH_DEBIT,
      m.CURRENT_MONTH_CREDIT,
      m.MONTH_CLOSING_BALANCE,
      m.MONTH_CLOSING_BAL_DR_CR_IND,
      t.CR_VOUCHER_TYPE
      || t.DR_VOUCHER_TYPE AS vouType,
      t.CR_VOUCHER_NO::varchar
      || t.DR_VOUCHER_NO::varchar AS vouNO,
      t.CR_VOUCHER_DATE::varchar
      || t.DR_VOUCHER_DATE::varchar AS vouDate,
      t.BILL_NO,
      t.BILL_DATE,
      t.AGREEMENT_NO,
      ( t.PARTICULARS ) AS PARTICULARS ,
      t.CREDIT_AMOUNT,
      t.DEBIT_AMOUNT
    FROM FAS_SUB_LEDGER_MASTER m,
      FAS_SUB_LEDGER_TRANSACTION t
    WHERE m.ACCOUNTING_UNIT_ID    =t.ACCOUNTING_UNIT_ID
    AND m.ACCOUNTING_FOR_OFFICE_ID=t.ACCOUNTING_FOR_OFFICE_ID
    AND m.FINANCIAL_YEAR          =t.FINANCIAL_YEAR
    AND m.YEAR                    =t.YEAR
    AND m.MONTH                   =t.MONTH
    AND m.ACCOUNT_HEAD_CODE       =t.ACCOUNT_HEAD_CODE
    AND m.SUB_LEDGER_TYPE_CODE    =t.SUB_LEDGER_TYPE_CODE
    AND m.SUB_LEDGER_CODE         =t.SUB_LEDGER_CODE
    ) s,
    COM_MST_SL_TYPES v,
    COM_MST_ACCOUNT_HEADS h
  WHERE s.SUB_LEDGER_TYPE_CODE  =v.SUB_LEDGER_TYPE_CODE
  AND s.ACCOUNT_HEAD_CODE       =h.ACCOUNT_HEAD_CODE
  AND s.ACCOUNTING_UNIT_ID      =$P{accountingunitid}::numeric
  AND s.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::numeric
  AND s.MONTH                   =$P{cashbookmonth_from}::numeric
  AND s.YEAR                    =$P{cashbookyear_from}::numeric
$P!{sl_type}
  ) x
LEFT OUTER JOIN
  (SELECT (sl_type) AS sl_type,
    (sl_code)       AS sl_code,
    ( sl_codename ) AS SLCODE_NAME
  FROM SL_TYPE_CODE_NAME_VIEW_M
  ) y
ON x.SUB_LEDGER_TYPE_CODE = y.SL_TYPE
AND x.SUB_LEDGER_CODE     =y.SL_CODE
ORDER BY SUB_LEDGER_TYPE_CODE,
  SUB_LEDGER_CODE,
  ACCOUNT_HEAD_CODE)test1
  ]]></queryString>

