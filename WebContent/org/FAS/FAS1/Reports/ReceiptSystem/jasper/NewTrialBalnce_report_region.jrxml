	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtRegionId" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select xx.ACCOUNTING_UNIT_ID, xx.ACCOUNTING_UNIT_OFFICE_ID,  xx.ACCOUNTING_UNIT_NAME ,  xx.updated_date,
sum(yy.current_month_credit) as credit,  sum(yy.current_month_debit) as debit from 
(
select 

  a.ACCOUNTING_UNIT_ID, 
  a.ACCOUNTING_UNIT_OFFICE_ID, 
  a.ACCOUNTING_UNIT_NAME ,
  c.updated_date
from 

  FAS_MST_ACCT_UNITS a , FAS_TRIAL_BALANCE_STATUS c 
  
where 
a.ACCOUNTING_UNIT_ID=c.ACCOUNTING_UNIT_ID and
c.cashbook_month=$P{txtCB_Month} and c.cashbook_year=$P{txtCB_Year} and
 a.ACCOUNTING_UNIT_OFFICE_ID in 
 (
    select 
       b.office_id
    from 
       com_mst_offices b 
    
       
  )and 
  
  a.ACCOUNTING_UNIT_ID in 
  (
    select 
        c.ACCOUNTING_UNIT_ID 
    from 
        FAS_TRIAL_BALANCE_STATUS c 
    where 
        c.CASHBOOK_MONTH=$P{txtCB_Month} and 
        c.cashbook_year=$P{txtCB_Year}        
   )       

) xx
left outer join
(
select accounting_unit_id as acct_unit_id,current_month_credit, current_month_debit from FAS_TRIAL_BALANCE
where cashbook_year=$P{txtCB_Year} and cashbook_month=$P{txtCB_Month}
) yy
on xx.accounting_unit_id=yy.acct_unit_id
group by xx.ACCOUNTING_UNIT_ID, xx.ACCOUNTING_UNIT_OFFICE_ID,  xx.ACCOUNTING_UNIT_NAME ,  xx.updated_date
order by xx.ACCOUNTING_UNIT_ID]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="UPDATED_DATE" class="java.util.Date"/>
	<field name="CREDIT" class="java.math.BigDecimal"/>
	<field name="DEBIT" class="java.math.BigDecimal"/>

	<variable name="CR_Amt_GrantTotal" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT}]]></variableExpression>
	</variable>
	<variable name="DR_Amt_GrantTotal" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT}]]></variableExpression>
	</variable>

