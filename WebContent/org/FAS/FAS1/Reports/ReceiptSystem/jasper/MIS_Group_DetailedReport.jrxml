<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="MIS_Group_DetailedReport"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="842"
		 columnWidth="828"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="20"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="fin_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fin_month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="financial_year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="major_head_code" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select
     order_no,
     major_head_desc,
     level2_group_desc,
     fas_ac_head_code,
     account_head_desc,
     level2_orderno,
     region_office_id,
     office_id,
     office_name,
     case when (major_head_code='I' or major_head_code='A') then
               (sum(credit_closing_balance)-sum(debit_closing_balance)) 
          else  
                (sum(debit_closing_balance)-sum(credit_closing_balance)) 
     end as closing_balance
from
(      
      select
            case when major_head_code='I' or major_head_code='A' then 1
                  else  2
            end as order_no,
            major_head_code,
            major_head_desc,
            level2_group_desc,
            fas_ac_head_code,
            account_head_desc,
            level2_orderno,
            accounting_unit_id,
            debit_closing_balance,
            credit_closing_balance
      from
            v_fas_mis_monthly_grouping a,
            fas_trial_balance b
      where
            a.fas_ac_head_code=b.ACCOUNT_HEAD_CODE and
            major_head_code in($P!{major_head_code}) and
            cashbook_month=$P{fin_month} and
            cashbook_year=$P{fin_year}
)a
inner join
(
      select 
            accounting_unit_id,
            accounting_unit_office_id,
            decode(region_office_id,null,accounting_unit_office_id,region_office_id) as region_office_id
            
      from
            fas_mst_acct_units a,
            com_mst_all_offices_view b
      where
            a.accounting_unit_office_id=b.OFFICE_ID and
            accounting_unit_office_id in
            (
                select 
                      office_id
                from
                      com_mst_all_offices_view
                where 
                      office_level_id='HO' or
                      region_office_id in 
                      (
                          select 
                                office_id 
                          from 
                                com_mst_offices 
                          where office_level_id in('RN')
                      )
            )
)b on a.accounting_unit_id=b.accounting_unit_id
left outer join
(
    select 
        office_id,
        office_name
    from 
        com_mst_offices
)c on b.region_office_id=c.office_id
group by
      order_no,
      major_head_code,
      major_head_desc,
      level2_group_desc,
      fas_ac_head_code,
      account_head_desc,
      level2_orderno,
      office_id,
      office_name,
      region_office_id
order by
      order_no,major_head_desc,level2_orderno,fas_ac_head_code]]></queryString>

