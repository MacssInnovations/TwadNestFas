<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="FAS_Annexure-IV"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="850"
		 pageHeight="842"
		 columnWidth="790"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="from_cashbk_yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="from_cashbk_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_cashbk_yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="to_cashbk_mon" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT row_id as "ROW_ID",
  unit_id as "UNIT_ID",
  (SELECT accounting_unit_name
  FROM fas_mst_acct_units
  WHERE accounting_unit_id=unit_id
  ) AS "ACCOUNTING_UNIT_NAME",
  achead1 as "ACHEAD1",
  achead2 as "ACHEAD2",
  achead3 as "ACHEAD3",
  achead4 as "ACHEAD4",
  amt1 as "AMT1",
  amt2 as "AMT2",
  amt3 as "AMT3",
  amt4 as "AMT4",
  (amt3+amt4)AS "TOTAL"
FROM
  (SELECT a.row_id ,
    unit_id,
    demand_raised1
    ||' '
    ||demand_raised_indicator1 AS achead1,
    demand_raised2
    ||' '
    ||demand_raised_indicator2 AS achead2,
    water_charges_collection1
    ||' '
    ||water_charges_indicator1 AS achead3,
    water_charges_collection2
    ||' '
    ||water_charges_indicator2 AS achead4,
    SUM(amt_achead1)           AS amt1,
    SUM(amt_achead2)           AS amt2,
    SUM(amt_achead3)           AS amt3,
    SUM(amt_achead4)           AS amt4
  FROM
    (SELECT 1            AS row_id,
      accounting_unit_id AS unit_id ,
      accounting_for_office_id,
      CR_DR_INDICATOR,
      CASE
        WHEN ( account_head_code =
          (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=1
          )
        AND CR_DR_INDICATOR=
          (SELECT demand_raised_indicator1 FROM fas_mst_annexure_iv WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead1,
      CASE
        WHEN ( account_head_code =
          (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=1
          )
        AND CR_DR_INDICATOR=
          (SELECT demand_raised_indicator2 FROM fas_mst_annexure_iv WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead2,
      CASE
        WHEN ( account_head_code =
          (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=1
          )
        AND CR_DR_INDICATOR=
          (SELECT water_charges_indicator1 FROM fas_mst_annexure_iv WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead3,
      CASE
        WHEN ( account_head_code =
          (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=1
          )
        AND CR_DR_INDICATOR=
          (SELECT water_charges_indicator2 FROM fas_mst_annexure_iv WHERE row_id=1
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead4
    FROM
      (SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_journal_master m ,
        fas_journal_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.journal_status           ='L'
      AND ( t.account_head_code      =
        (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=1
        )
      AND cr_dr_indicator=
        (SELECT demand_raised_indicator1 FROM fas_mst_annexure_iv WHERE row_id=1
        )
      OR t.account_head_code=
        (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=1
        )
      AND cr_dr_indicator=
        (SELECT demand_raised_indicator2 FROM fas_mst_annexure_iv WHERE row_id=1
        )
      OR t.account_head_code=
        (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=1
        )
      AND cr_dr_indicator=
        (SELECT water_charges_indicator1 FROM fas_mst_annexure_iv WHERE row_id=1
        )
      OR t.account_head_code=
        (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=1
        )
      AND cr_dr_indicator=
        (SELECT water_charges_indicator2 FROM fas_mst_annexure_iv WHERE row_id=1
        ) )
      AND to_date(m.cashbook_month
        ||'-'
        || + m.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      UNION ALL
      SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_payment_master m ,
        fas_payment_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.payment_status           ='L'
      AND ( t.account_head_code      =
        (SELECT (
          CASE
            WHEN demand_indicator1='DR'
            THEN
              (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=1
              )
            ELSE 0
          END)AS demand1
        FROM
          (SELECT demand_raised_indicator1 AS demand_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=1
          ) as opt1
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN demand_indicator2='DR'
            THEN
              (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=1
              )
            ELSE 0
          END)AS demand2
        FROM
          (SELECT demand_raised_indicator2 AS demand_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=1
          ) as opt2
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator1='DR'
            THEN
              (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=1
              )
            ELSE 0
          END)AS collection1
        FROM
          (SELECT water_charges_indicator1 AS collection_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=1
          ) as opt3
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator2='DR'
            THEN
              (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=1
              )
            ELSE 0
          END)AS collection2
        FROM
          (SELECT water_charges_indicator2 AS collection_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=1
          ) as opt4
        ) )
      AND to_date(m.cashbook_month
        ||'-'
        || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      UNION ALL
      SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_receipt_master m ,
        fas_receipt_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.receipt_no               = t.receipt_no
      AND m.receipt_status           ='L'
      AND ( t.account_head_code      =
        (SELECT (
          CASE
            WHEN demand_indicator1='CR'
            THEN
              (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=1
              )
            ELSE 0
          END)AS demand1
        FROM
          (SELECT demand_raised_indicator1 AS demand_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=1
          ) as opt5 
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN demand_indicator2='CR'
            THEN
              (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=1
              )
            ELSE 0
          END)AS demand2
        FROM
          (SELECT demand_raised_indicator2 AS demand_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=1
          ) as opt6 
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator1='CR'
            THEN
              (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=1
              )
            ELSE 0
          END)AS collection1
        FROM
          (SELECT water_charges_indicator1 AS collection_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=1
          ) as opt7 
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator2='CR'
            THEN
              (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=1
              )
            ELSE 0
          END)AS collection2
        FROM
          (SELECT water_charges_indicator2 AS collection_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=1
          ) as opt8
        ) )
      AND to_date(t.cashbook_month
        ||'-'
        || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      ) as opt9
    GROUP BY accounting_unit_id,
      accounting_for_office_id ,
      account_head_code,
      CR_DR_INDICATOR
    ORDER BY accounting_unit_id
    )a,
    fas_mst_annexure_iv b
  WHERE a.row_id=b.row_id
  GROUP BY a.row_id,
    unit_id,
    demand_raised1,
    demand_raised_indicator1,
    demand_raised2,
    demand_raised_indicator2,
    water_charges_collection1,
    water_charges_indicator1,
    water_charges_collection2,
    water_charges_indicator2
  UNION ALL
  SELECT a.row_id,
    unit_id,
    demand_raised1
    ||' '
    ||demand_raised_indicator1 AS achead1,
    demand_raised2
    ||' '
    ||demand_raised_indicator2 AS achead2,
    water_charges_collection1
    ||' '
    ||water_charges_indicator1 AS achead3,
    water_charges_collection2
    ||' '
    ||water_charges_indicator2 AS achead4,
    SUM(amt_achead1)           AS amt1,
    SUM(amt_achead2)           AS amt2,
    SUM(amt_achead3)           AS amt3,
    SUM(amt_achead4)           AS amt4
  FROM
    (SELECT 2            AS row_id,
      accounting_unit_id AS unit_id ,
      accounting_for_office_id,
      CR_DR_INDICATOR,
      CASE
        WHEN ( account_head_code =
          (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=2
          )
        AND CR_DR_INDICATOR=
          (SELECT demand_raised_indicator1 FROM fas_mst_annexure_iv WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead1,
      CASE
        WHEN ( account_head_code =
          (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=2
          )
        AND CR_DR_INDICATOR=
          (SELECT demand_raised_indicator2 FROM fas_mst_annexure_iv WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead2,
      CASE
        WHEN ( account_head_code =
          (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=2
          )
        AND CR_DR_INDICATOR=
          (SELECT water_charges_indicator1 FROM fas_mst_annexure_iv WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead3,
      CASE
        WHEN ( account_head_code =
          (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=2
          )
        AND CR_DR_INDICATOR=
          (SELECT water_charges_indicator2 FROM fas_mst_annexure_iv WHERE row_id=2
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead4
    FROM
      (SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_journal_master m ,
        fas_journal_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.journal_status           ='L'
      AND ( t.account_head_code      =
        (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=2
        )
      AND cr_dr_indicator=
        (SELECT demand_raised_indicator1 FROM fas_mst_annexure_iv WHERE row_id=2
        )
      OR t.account_head_code=
        (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=2
        )
      AND cr_dr_indicator=
        (SELECT demand_raised_indicator2 FROM fas_mst_annexure_iv WHERE row_id=2
        )
      OR t.account_head_code=
        (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=2
        )
      AND cr_dr_indicator=
        (SELECT water_charges_indicator1 FROM fas_mst_annexure_iv WHERE row_id=2
        )
      OR t.account_head_code=
        (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=2
        )
      AND cr_dr_indicator=
        (SELECT water_charges_indicator2 FROM fas_mst_annexure_iv WHERE row_id=2
        ) )
      AND to_date(m.cashbook_month
        ||'-'
        || + m.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      UNION ALL
      SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_payment_master m ,
        fas_payment_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.payment_status           ='L'
      AND ( t.account_head_code      =
        (SELECT (
          CASE
            WHEN demand_indicator1='DR'
            THEN
              (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=2
              )
            ELSE 0
          END)AS demand1
        FROM
          (SELECT demand_raised_indicator1 AS demand_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=2
          ) as opt10
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN demand_indicator2='DR'
            THEN
              (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=2
              )
            ELSE 0
          END)AS demand2
        FROM
          (SELECT demand_raised_indicator2 AS demand_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=2
          ) as opt112
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator1='DR'
            THEN
              (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=2
              )
            ELSE 0
          END)AS collection1
        FROM
          (SELECT water_charges_indicator1 AS collection_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=2
          ) as opt13
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator2='DR'
            THEN
              (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=2
              )
            ELSE 0
          END)AS collection2
        FROM
          (SELECT water_charges_indicator2 AS collection_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=2
          ) as opt14
        ) )
      AND to_date(m.cashbook_month
        ||'-'
        || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      UNION ALL
      SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_receipt_master m ,
        fas_receipt_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.receipt_no               = t.receipt_no
      AND m.receipt_status           ='L'
      AND ( t.account_head_code      =
        (SELECT (
          CASE
            WHEN demand_indicator1='CR'
            THEN
              (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=2
              )
            ELSE 0
          END)AS demand1
        FROM
          (SELECT demand_raised_indicator1 AS demand_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=2
          ) as opt15
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN demand_indicator2='CR'
            THEN
              (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=2
              )
            ELSE 0
          END)AS demand2
        FROM
          (SELECT demand_raised_indicator2 AS demand_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=2
          ) as opt16
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator1='CR'
            THEN
              (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=2
              )
            ELSE 0
          END)AS collection1
        FROM
          (SELECT water_charges_indicator1 AS collection_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=2
          ) as opt17
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator2='CR'
            THEN
              (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=2
              )
            ELSE 0
          END)AS collection2
        FROM
          (SELECT water_charges_indicator2 AS collection_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=2
          ) as opt18
        ) )
      AND to_date(t.cashbook_month
        ||'-'
        || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      ) as opt19
    GROUP BY accounting_unit_id,
      accounting_for_office_id ,
      account_head_code,
      CR_DR_INDICATOR
    ORDER BY accounting_unit_id
    )a,
    fas_mst_annexure_iv b
  WHERE a.row_id=b.row_id
  GROUP BY a.row_id,
    unit_id,
    demand_raised1,
    demand_raised_indicator1,
    demand_raised2,
    demand_raised_indicator2,
    water_charges_collection1,
    water_charges_indicator1,
    water_charges_collection2,
    water_charges_indicator2
  UNION ALL
  SELECT a.row_id,
    unit_id,
    demand_raised1
    ||' '
    ||demand_raised_indicator1 AS achead1,
    demand_raised2
    ||' '
    ||demand_raised_indicator2 AS achead2,
    water_charges_collection1
    ||' '
    ||water_charges_indicator1 AS achead3,
    water_charges_collection2
    ||' '
    ||water_charges_indicator2 AS achead4,
    SUM(amt_achead1)           AS amt1,
    SUM(amt_achead2)           AS amt2,
    SUM(amt_achead3)           AS amt3,
    SUM(amt_achead4)           AS amt4
  FROM
    (SELECT 3            AS row_id,
      accounting_unit_id AS unit_id ,
      accounting_for_office_id,
      CR_DR_INDICATOR,
      CASE
        WHEN ( account_head_code =
          (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=3
          )
        AND CR_DR_INDICATOR=
          (SELECT demand_raised_indicator1 FROM fas_mst_annexure_iv WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead1,
      CASE
        WHEN ( account_head_code =
          (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=3
          )
        AND CR_DR_INDICATOR=
          (SELECT demand_raised_indicator2 FROM fas_mst_annexure_iv WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead2,
      CASE
        WHEN ( account_head_code =
          (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=3
          )
        AND CR_DR_INDICATOR=
          (SELECT water_charges_indicator1 FROM fas_mst_annexure_iv WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead3,
      CASE
        WHEN ( account_head_code =
          (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=3
          )
        AND CR_DR_INDICATOR=
          (SELECT water_charges_indicator2 FROM fas_mst_annexure_iv WHERE row_id=3
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead4
    FROM
      (SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_journal_master m ,
        fas_journal_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.journal_status           ='L'
      AND ( t.account_head_code      =
        (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=3
        )
      AND cr_dr_indicator=
        (SELECT demand_raised_indicator1 FROM fas_mst_annexure_iv WHERE row_id=3
        )
      OR t.account_head_code=
        (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=3
        )
      AND cr_dr_indicator=
        (SELECT demand_raised_indicator2 FROM fas_mst_annexure_iv WHERE row_id=3
        )
      OR t.account_head_code=
        (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=3
        )
      AND cr_dr_indicator=
        (SELECT water_charges_indicator1 FROM fas_mst_annexure_iv WHERE row_id=3
        )
      OR t.account_head_code=
        (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=3
        )
      AND cr_dr_indicator=
        (SELECT water_charges_indicator2 FROM fas_mst_annexure_iv WHERE row_id=3
        ) )
      AND to_date(m.cashbook_month
        ||'-'
        || + m.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      UNION ALL
      SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_payment_master m ,
        fas_payment_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.payment_status           ='L'
      AND ( t.account_head_code      =
        (SELECT (
          CASE
            WHEN demand_indicator1='DR'
            THEN
              (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=3
              )
            ELSE 0
          END)AS demand1
        FROM
          (SELECT demand_raised_indicator1 AS demand_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=3
          ) as opt20
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN demand_indicator2='DR'
            THEN
              (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=3
              )
            ELSE 0
          END)AS demand2
        FROM
          (SELECT demand_raised_indicator2 AS demand_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=3
          ) as opt21
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator1='DR'
            THEN
              (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=3
              )
            ELSE 0
          END)AS collection1
        FROM
          (SELECT water_charges_indicator1 AS collection_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=3
          ) as opt22
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator2='DR'
            THEN
              (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=3
              )
            ELSE 0
          END)AS collection2
        FROM
          (SELECT water_charges_indicator2 AS collection_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=3
          ) as opt23
        ) )
      AND to_date(m.cashbook_month
        ||'-'
        || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      UNION ALL
      SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_receipt_master m ,
        fas_receipt_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.receipt_no               = t.receipt_no
      AND m.receipt_status           ='L'
      AND ( t.account_head_code      =
        (SELECT (
          CASE
            WHEN demand_indicator1='CR'
            THEN
              (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=3
              )
            ELSE 0
          END)AS demand1
        FROM
          (SELECT demand_raised_indicator1 AS demand_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=3
          ) as opt24
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN demand_indicator2='CR'
            THEN
              (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=3
              )
            ELSE 0
          END)AS demand2
        FROM
          (SELECT demand_raised_indicator2 AS demand_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=3
          ) as opt25
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator1='CR'
            THEN
              (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=3
              )
            ELSE 0
          END)AS collection1
        FROM
          (SELECT water_charges_indicator1 AS collection_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=3
          ) as opt26
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator2='CR'
            THEN
              (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=3
              )
            ELSE 0
          END)AS collection2
        FROM
          (SELECT water_charges_indicator2 AS collection_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=3
          ) as opt27
        ) )
      AND to_date(t.cashbook_month
        ||'-'
        || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      ) as opt28
    GROUP BY accounting_unit_id,
      accounting_for_office_id ,
      account_head_code,
      CR_DR_INDICATOR
    ORDER BY accounting_unit_id
    )a,
    fas_mst_annexure_iv b
  WHERE a.row_id=b.row_id
  GROUP BY a.row_id,
    unit_id,
    demand_raised1,
    demand_raised_indicator1,
    demand_raised2,
    demand_raised_indicator2,
    water_charges_collection1,
    water_charges_indicator1,
    water_charges_collection2,
    water_charges_indicator2
  UNION ALL
  SELECT a.row_id,
    unit_id,
    demand_raised1
    ||' '
    ||demand_raised_indicator1 AS achead1,
    demand_raised2
    ||' '
    ||demand_raised_indicator2 AS achead2,
    water_charges_collection1
    ||' '
    ||water_charges_indicator1 AS achead3,
    water_charges_collection2
    ||' '
    ||water_charges_indicator2 AS achead4,
    SUM(amt_achead1)           AS amt1,
    SUM(amt_achead2)           AS amt2,
    SUM(amt_achead3)           AS amt3,
    SUM(amt_achead4)           AS amt4
  FROM
    (SELECT 4            AS row_id,
      accounting_unit_id AS unit_id ,
      accounting_for_office_id,
      CR_DR_INDICATOR,
      CASE
        WHEN ( account_head_code =
          (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=4
          )
        AND CR_DR_INDICATOR=
          (SELECT demand_raised_indicator1 FROM fas_mst_annexure_iv WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead1,
      CASE
        WHEN ( account_head_code =
          (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=4
          )
        AND CR_DR_INDICATOR=
          (SELECT demand_raised_indicator2 FROM fas_mst_annexure_iv WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead2,
      CASE
        WHEN ( account_head_code =
          (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=4
          )
        AND CR_DR_INDICATOR=
          (SELECT water_charges_indicator1 FROM fas_mst_annexure_iv WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead3,
      CASE
        WHEN ( account_head_code =
          (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=4
          )
        AND CR_DR_INDICATOR=
          (SELECT water_charges_indicator2 FROM fas_mst_annexure_iv WHERE row_id=4
          ))
        THEN SUM(amount)
        ELSE 0
      END AS amt_achead4
    FROM
      (SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_journal_master m ,
        fas_journal_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.journal_status           ='L'
      AND ( t.account_head_code      =
        (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=4
        )
      AND cr_dr_indicator=
        (SELECT demand_raised_indicator1 FROM fas_mst_annexure_iv WHERE row_id=4
        )
      OR t.account_head_code=
        (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=4
        )
      AND cr_dr_indicator=
        (SELECT demand_raised_indicator2 FROM fas_mst_annexure_iv WHERE row_id=4
        )
      OR t.account_head_code=
        (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=4
        )
      AND cr_dr_indicator=
        (SELECT water_charges_indicator1 FROM fas_mst_annexure_iv WHERE row_id=4
        )
      OR t.account_head_code=
        (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=4
        )
      AND cr_dr_indicator=
        (SELECT water_charges_indicator2 FROM fas_mst_annexure_iv WHERE row_id=4
        ) )
      AND to_date(m.cashbook_month
        ||'-'
        || + m.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      UNION ALL
      SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_payment_master m ,
        fas_payment_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.voucher_no               = t.voucher_no
      AND m.payment_status           ='L'
      AND ( t.account_head_code      =
        (SELECT (
          CASE
            WHEN demand_indicator1='DR'
            THEN
              (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=4
              )
            ELSE 0
          END)AS demand1
        FROM
          (SELECT demand_raised_indicator1 AS demand_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=4
          ) as opt30 
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN demand_indicator2='DR'
            THEN
              (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=4
              )
            ELSE 0
          END)AS demand2
        FROM
          (SELECT demand_raised_indicator2 AS demand_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=4
          ) as opt31
        ) 
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator1='DR'
            THEN
              (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=4
              )
            ELSE 0
          END)AS collection1
        FROM
          (SELECT water_charges_indicator1 AS collection_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=4
          ) as opt32
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator2='DR'
            THEN
              (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=4
              )
            ELSE 0
          END)AS collection2
        FROM
          (SELECT water_charges_indicator2 AS collection_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=4
          ) as opt33
        ) )
      AND to_date(m.cashbook_month
        ||'-'
        || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      UNION ALL
      SELECT m.accounting_unit_id ,
        m.accounting_for_office_id ,
        m.cashbook_month,
        m.cashbook_year,
        t.account_head_code,
        t.CR_DR_INDICATOR,
        t.amount
      FROM fas_receipt_master m ,
        fas_receipt_transaction t
      WHERE m.accounting_unit_id     = t.accounting_unit_id
      AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
      AND m.cashbook_month           = t.cashbook_month
      AND m.cashbook_year            = t.cashbook_year
      AND m.receipt_no               = t.receipt_no
      AND m.receipt_status           ='L'
      AND ( t.account_head_code      =
        (SELECT (
          CASE
            WHEN demand_indicator1='CR'
            THEN
              (SELECT demand_raised1 FROM fas_mst_annexure_iv WHERE row_id=4
              )
            ELSE 0
          END)AS demand1
        FROM
          (SELECT demand_raised_indicator1 AS demand_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=4
          ) as opt34
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN demand_indicator2='CR'
            THEN
              (SELECT demand_raised2 FROM fas_mst_annexure_iv WHERE row_id=4
              )
            ELSE 0
          END)AS demand2
        FROM
          (SELECT demand_raised_indicator2 AS demand_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=4
          ) as opt35
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator1='CR'
            THEN
              (SELECT water_charges_collection1 FROM fas_mst_annexure_iv WHERE row_id=4
              )
            ELSE 0
          END)AS collection1
        FROM
          (SELECT water_charges_indicator1 AS collection_indicator1
          FROM fas_mst_annexure_iv
          WHERE row_id=4
          ) as opt36
        )
      OR t.account_head_code=
        (SELECT (
          CASE
            WHEN collection_indicator2='CR'
            THEN
              (SELECT water_charges_collection2 FROM fas_mst_annexure_iv WHERE row_id=4
              )
            ELSE 0
          END)AS collection2
        FROM
          (SELECT water_charges_indicator2 AS collection_indicator2
          FROM fas_mst_annexure_iv
          WHERE row_id=4
          ) as opt37
        ) )
      AND to_date(t.cashbook_month
        ||'-'
        || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
        || '-'
        || ($P{from_cashbk_yr}) , 'mm-yyyy')
      AND to_date( ( $P{to_cashbk_mon} )
        ||'-'
        || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
      ) as opt38
    GROUP BY accounting_unit_id,
      accounting_for_office_id ,
      account_head_code,
      CR_DR_INDICATOR
    ORDER BY accounting_unit_id
    )a,
    fas_mst_annexure_iv b
  WHERE a.row_id=b.row_id
  GROUP BY a.row_id,
    unit_id,
    demand_raised1,
    demand_raised_indicator1,
    demand_raised2,
    demand_raised_indicator2,
    water_charges_collection1,
    water_charges_indicator1,
    water_charges_collection2,
    water_charges_indicator2
  ) as opt39
ORDER BY row_id,
  unit_id]]></queryString>

	<field name="ROW_ID" class="java.lang.Integer"/>
	<field name="UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="ACHEAD1" class="java.lang.String"/>
	<field name="ACHEAD2" class="java.lang.String"/>
	<field name="ACHEAD3" class="java.lang.String"/>
	<field name="ACHEAD4" class="java.lang.String"/>
	<field name="AMT1" class="java.math.BigDecimal"/>
	<field name="AMT2" class="java.math.BigDecimal"/>
	<field name="AMT3" class="java.math.BigDecimal"/>
	<field name="AMT4" class="java.math.BigDecimal"/>
	<field name="TOTAL" class="java.math.BigDecimal"/>

	<variable name="amt1_total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMT1}]]></variableExpression>
	</variable>
	<variable name="amt2_total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMT2}]]></variableExpression>
