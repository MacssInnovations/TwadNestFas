<jasperReport
		 name="View_Trial_Balance_SJV"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="623"
		 pageHeight="842"
		 columnWidth="563"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supplementno" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 
*
from 
(
select
   accounting_unit_id  ,
   account_head_code ,
   current_month_debit as "DR_AMT", 
   current_month_credit as "CR_AMT",
   (current_month_debit - current_month_credit) as "TOT_AMT"  
   
from 
  fas_trial_balance_supplement 
where 
  accounting_unit_id=$P{accountingunitid}::int and 
  cashbook_year=$P{cashbookyear}::int and 
  cashbook_month=$P{cashbookmonth}::int and 
  SUPPLEMENT_NO =  $P{supplementno}::int 
)  a  

left outer join 

( 
  select account_head_desc as "ACCOUNT_HEAD_DESC", account_head_code  from com_mst_account_heads 
)  b

on a.account_head_code = b.account_head_code 

left outer join 

(
  select accounting_unit_id , accounting_unit_name as "ACCOUNTING_UNIT_NAME"  from fas_mst_acct_units 
) c 

on a.accounting_unit_id = c.accounting_unit_id
order by a.account_head_code]]></queryString>

	<field name="accounting_unit_id" class="java.math.BigDecimal"/>
	<field name="account_head_code" class="java.math.BigDecimal"/>
	<field name="DR_AMT" class="java.math.BigDecimal"/>
	<field name="CR_AMT" class="java.math.BigDecimal"/>
	<field name="TOT_AMT" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>

	<variable name="SUM_DR_AMT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
