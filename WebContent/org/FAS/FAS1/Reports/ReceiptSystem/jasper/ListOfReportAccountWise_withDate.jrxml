<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ListOfReportAccountWise_withDate"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="814"
		 columnSpacing="0"
		 leftMargin="14"
		 rightMargin="14"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountheadcode" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[(SELECT decode(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque 
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme 
Owner',13,'Beneficiary','-') as sub_ledger_type_code,
d.ACCOUNT_HEAD_DESC,c.office_name,b.paid_to,a.sub_ledger_type_code,
(select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M where sl_type=a.sub_ledger_type_code and sl_code=a.SUB_LEDGER_CODE) as 
slcode,
b.payment_date AS datevalue,d.ACCOUNT_HEAD_CODE,
b.voucher_no as voucher_no,'P' AS document_type,to_char(a.amount) as amount,a.CR_DR_INDICATOR,a.particulars  FROM fas_payment_transaction a,
fas_payment_master b,COM_MST_OFFICES c,COM_MST_ACCOUNT_HEADS d WHERE 
a.accounting_unit_id = b.accounting_unit_id AND
a.accounting_for_office_id = b.accounting_for_office_id AND 
a.cashbook_year = b.cashbook_year AND 
a.cashbook_month = b.cashbook_month AND 
a.voucher_no= b.voucher_no AND 
b.payment_status<>'C' and 
b.cashbook_year=$P{txtCB_Year}  and b.cashbook_month=$P{txtCB_Month} and 
a.accounting_unit_id= $P{accountingunitid} and a.accounting_for_office_id= $P{accountofficeid} and
a.ACCOUNT_HEAD_CODE=$P{accountheadcode} and c.office_id=a.accounting_for_office_id and 
a.ACCOUNT_HEAD_CODE=d.account_head_code and b.payment_date between $P{txtfrom} and $P{txtto})
UNION all 
(SELECT decode(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque 
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme 
Owner',13,'Beneficiary','-')as sub_ledger_type_code,
d.ACCOUNT_HEAD_DESC,c.office_name,b.received_from,a.sub_ledger_type_code,
(select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M where sl_type=a.sub_ledger_type_code and sl_code=a.SUB_LEDGER_CODE) as 
slcode,
b.receipt_date AS datevalue,d.ACCOUNT_HEAD_CODE,
b.receipt_no as voucher_no ,'R',to_char(a.amount) as amount,a.CR_DR_INDICATOR,a.particulars  FROM fas_receipt_transaction a,
fas_receipt_master b,COM_MST_OFFICES c,COM_MST_ACCOUNT_HEADS d where
a.accounting_unit_id = b.accounting_unit_id AND 
a.accounting_for_office_id = b.accounting_for_office_id AND 
a.cashbook_year = b.cashbook_year AND 
a.cashbook_month = b.cashbook_month AND 
a.receipt_no= b.receipt_no AND 
b.receipt_status<>'C' and 
b.cashbook_year=$P{txtCB_Year}  and b.cashbook_month=$P{txtCB_Month} and 
a.accounting_unit_id= $P{accountingunitid} and a.accounting_for_office_id= $P{accountofficeid} AND
a.ACCOUNT_HEAD_CODE=$P{accountheadcode} and c.office_id=a.accounting_for_office_id and 
a.ACCOUNT_HEAD_CODE=d.account_head_code and b.receipt_date between $P{txtfrom} and $P{txtto})
UNION all
(SELECT decode(a.sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque 
Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme 
Owner',13,'Beneficiary','-')as sub_ledger_type_code,
d.ACCOUNT_HEAD_DESC,c.office_name,' ',a.sub_ledger_type_code,
(select sl_codeName from SL_TYPE_CODE_NAME_VIEW_M where sl_type=a.sub_ledger_type_code and sl_code=a.SUB_LEDGER_CODE) as 
slcode,
b.voucher_date AS datevalue,d.ACCOUNT_HEAD_CODE,
b.voucher_no as voucher_no ,'J' AS document_type,to_char(a.amount) as amount,a.CR_DR_INDICATOR,a.particulars  FROM fas_journal_transaction a,
fas_journal_master b,COM_MST_OFFICES c,COM_MST_ACCOUNT_HEADS d where
a.accounting_unit_id=b.accounting_unit_id and 
a.accounting_for_office_id = b.accounting_for_office_id AND 
a.cashbook_year = b.cashbook_year and
a.cashbook_month = b.cashbook_month and 
a.voucher_no= b.voucher_no and
b.journal_status<>'C' and 
b.cashbook_year=$P{txtCB_Year} and b.cashbook_month=$P{txtCB_Month} and 
a.accounting_unit_id=$P{accountingunitid} and a.accounting_for_office_id=$P{accountofficeid} and
a.ACCOUNT_HEAD_CODE=$P{accountheadcode} and c.office_id=a.accounting_for_office_id and 
a.ACCOUNT_HEAD_CODE=d.account_head_code and b.voucher_date between $P{txtfrom} and $P{txtto})
order by datevalue,voucher_no]]></queryString>

	<field name="SUB_LEDGER_TYPE_CODE" class="java.lang.String"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
