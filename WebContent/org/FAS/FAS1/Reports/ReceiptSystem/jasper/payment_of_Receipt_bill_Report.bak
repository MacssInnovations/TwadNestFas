<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="payment_of_Receipt_bill_Report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1019"
		 pageHeight="842"
		 columnWidth="959"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="heading" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT a.*,
  b.row_numm
FROM (
  (SELECT aa.Accounting_Unit_Id,
    aa.Accounting_For_Office_Id,
    (SELECT Uu.Accounting_Unit_Name
    FROM fas_mst_acct_units uu
    WHERE Uu.Accounting_Unit_Id=aa.Accounting_Unit_Id
    )AS orgunitname,
    aa.CASHBOOK_YEAR,
    aa.CASHBOOK_MONTH,
    aa.SL_NO,
    AA.RECEIPT_DATE,
    aa.RECEIPT_NO,
    aa.CHEQUE_DD_NO,
    aa.CHEQUE_DD_DATE,
    aa.AMOUNT,
    aa.SUB_LEDGER_TYPE_CODE,
    (SELECT S.Sub_Ledger_Type_Desc
    FROM com_mst_sl_types s
    WHERE s.SUB_LEDGER_TYPE_CODE=Aa.Sub_Ledger_Type_Code
    )AS sl_desc,
    aa.Sub_Ledger_Code,
    (SELECT l.SL_CODENAME
    FROM SL_TYPE_CODE_NAME_VIEW_M l
    WHERE L.Sl_Type=Aa.Sub_Ledger_Type_Code
    AND L.Sl_Code  =Aa.Sub_Ledger_Code
    AND rownum = 1
    )AS code_desc ,
    aa.cb_ref_no,
    aa.cb_ref_date,
    aa.cheque_or_dd ,
    aa.ljvamount,
    bb.VOUCHER_NO pay_no,
    bb.PAYMENT_DATE,
    bb.AMOUNT AS pay_amt,
    aa.multiple_pvrs,
    aa.account_head_code ,
    (SELECT h.account_head_desc
    FROM com_mst_account_heads h
    WHERE h.account_head_code= aa.account_head_code
    ) AS head_desc
  FROM
    (SELECT a.Accounting_Unit_Id,
      a.Accounting_For_Office_Id,
      a.CASHBOOK_YEAR,
      a.CASHBOOK_MONTH,
      b.SL_NO,
      A.RECEIPT_DATE,
      a.RECEIPT_NO,
      b.CHEQUE_DD_NO,
      b.CHEQUE_DD_DATE,
      b.AMOUNT,
      b.SUB_LEDGER_TYPE_CODE,
      b.Sub_Ledger_Code,
      b.cb_ref_no,
      b.cb_ref_date,
      b.cheque_or_dd ,
      b.AMOUNT AS ljvamount,
      b.multiple_pvrs,
      b.account_head_code
    FROM FAS_RECEIPT_MASTER a
    INNER JOIN FAS_RECEIPT_TRANSACTION b
    ON A.Accounting_Unit_Id       =B.Accounting_Unit_Id
    AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
    AND A.Cashbook_Year           =B.Cashbook_Year
    AND A.Cashbook_Month          =B.Cashbook_Month
    AND A.RECEIPT_NO              =B.RECEIPT_NO
    AND a.ACCOUNTING_UNIT_ID      =$P{unitid}
    AND a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
    AND A.CASHBOOK_MONTH          =$P{cashbookmonth}
    AND a.CASHBOOK_YEAR           =$P{cashbookyear}
    AND A.RECEIPT_STATUS          ='L'
    AND B.CR_DR_INDICATOR='CR'
         AND B.SUB_LEDGER_TYPE_CODE !=0
         AND B.SUB_LEDGER_CODE!=0
      --AND b.cheque_dd_date         IS NOT NULLf
      --AND b.cheque_dd_no            > 0
    AND ( b.multiple_pvrs IS NULL
    OR b.multiple_pvrs     = 'N')
    )AA
  LEFT OUTER JOIN
    (SELECT a1.ACCOUNTING_UNIT_ID ,
      a1.ACCOUNTING_FOR_OFFICE_ID,
      a1.CASHBOOK_YEAR,
      a1.CASHBOOK_MONTH,
      B1.SL_NO,
      b1.PAYABLE_VOUCHER_SLNO,
      a1.PAYMENT_DATE,
      a1.VOUCHER_NO,
      b1.CHEQUE_DD_NO,
      b1.CHEQUE_DD_DATE,
      b1.AMOUNT,
      a1.SUB_LEDGER_TYPE_CODE,
      A1.Sub_Ledger_Code,
      b1.PAYABLE_VOUCHER_NO,
      b1.PAYABLE_VOUCHER_DATE
    FROM FAS_PAYMENT_MASTER a1
    INNER JOIN FAS_PAYMENT_TRANSACTION b1
    ON A1.Accounting_Unit_Id       =B1.Accounting_Unit_Id
    AND A1.Accounting_For_Office_Id=B1.Accounting_For_Office_Id
    AND A1.Cashbook_Year           =B1.Cashbook_Year
    AND A1.CASHBOOK_MONTH          =B1.CASHBOOK_MONTH
    AND A1.VOUCHER_NO              =B1.VOUCHER_NO
    AND a1.CREATED_BY_MODULE       ='BPP'
    AND a1.PAYMENT_STATUS          ='L'
    AND a1.ACCOUNTING_UNIT_ID      =$P{unitid}
    AND a1.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
    )bb ON aa.Accounting_Unit_Id   =bb.Accounting_Unit_Id
  AND aa.Accounting_For_Office_Id  =bb.Accounting_For_Office_Id
  AND AA.RECEIPT_NO                = BB.PAYABLE_VOUCHER_NO
  AND aa.RECEIPT_DATE              = bb.PAYABLE_VOUCHER_DATE
  AND aa.SUB_LEDGER_TYPE_CODE      =bb.SUB_LEDGER_TYPE_CODE
  AND AA.SUB_LEDGER_CODE           =BB.SUB_LEDGER_CODE
  AND aa.CHEQUE_DD_NO              =bb.CHEQUE_DD_NO
  AND AA.CHEQUE_DD_DATE            =BB.CHEQUE_DD_DATE
 AND aa.SL_NO                     =bb.PAYABLE_VOUCHER_SLNO
  )
UNION ALL
  (SELECT aa.Accounting_Unit_Id,
    aa.Accounting_For_Office_Id,
    (SELECT Uu.Accounting_Unit_Name
    FROM fas_mst_acct_units uu
    WHERE Uu.Accounting_Unit_Id=aa.Accounting_Unit_Id
    )AS orgunitname,
    aa.CASHBOOK_YEAR,
    aa.CASHBOOK_MONTH,
    aa.SL_NO,
    AA.RECEIPT_DATE,
    aa.RECEIPT_NO,
    aa.CHEQUE_DD_NO,
    aa.CHEQUE_DD_DATE,
    aa.AMOUNT,
    aa.SUB_LEDGER_TYPE_CODE,
    (SELECT S.Sub_Ledger_Type_Desc
    FROM com_mst_sl_types s
    WHERE s.SUB_LEDGER_TYPE_CODE=Aa.Sub_Ledger_Type_Code
    )AS sl_desc,
    aa.Sub_Ledger_Code,
    (SELECT l.SL_CODENAME
    FROM SL_TYPE_CODE_NAME_VIEW_M l
    WHERE L.Sl_Type=Aa.Sub_Ledger_Type_Code
    AND L.Sl_Code  =Aa.Sub_Ledger_Code
    )AS code_desc ,
    aa.cb_ref_no,
    aa.cb_ref_date,
    aa.cheque_or_dd ,
    aa.ljvamount,
    bb.VOUCHER_NO pay_no,
    bb.PAYMENT_DATE,
    bb.AMOUNT AS pay_amt,
    aa.multiple_pvrs,
    aa.account_head_code ,
    (SELECT h.account_head_desc
    FROM com_mst_account_heads h
    WHERE h.account_head_code= aa.account_head_code
    ) AS head_desc
  FROM
    (SELECT a.Accounting_Unit_Id,
      a.Accounting_For_Office_Id,
      a.CASHBOOK_YEAR,
      a.CASHBOOK_MONTH,
      b.SL_NO,
      A.RECEIPT_DATE,
      a.RECEIPT_NO,
      b.CHEQUE_DD_NO,
      b.CHEQUE_DD_DATE,
      b.AMOUNT,
      b.SUB_LEDGER_TYPE_CODE,
      b.Sub_Ledger_Code,
      b.cb_ref_no,
      b.cb_ref_date,
      b.cheque_or_dd ,
      b.AMOUNT AS ljvamount,
      b.multiple_pvrs,
      b.account_head_code
    FROM FAS_RECEIPT_MASTER a
    INNER JOIN FAS_RECEIPT_TRANSACTION b
    ON A.Accounting_Unit_Id       =B.Accounting_Unit_Id
    AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
    AND A.Cashbook_Year           =B.Cashbook_Year
    AND A.Cashbook_Month          =B.Cashbook_Month
    AND A.RECEIPT_NO              =B.RECEIPT_NO
    AND a.ACCOUNTING_UNIT_ID      =$P{unitid}
    AND a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
    AND a.CASHBOOK_MONTH          =$P{cashbookmonth}
    AND a.CASHBOOK_YEAR           =$P{cashbookyear}
    AND A.RECEIPT_STATUS          ='L'
    AND B.CR_DR_INDICATOR='CR'
         AND B.SUB_LEDGER_TYPE_CODE !=0
         and b.Sub_Ledger_Code!=0
      --AND b.cheque_dd_date         IS NOT NULL
      --AND b.cheque_dd_no            > 0
    AND b.multiple_pvrs = 'Y'
    )AA
  LEFT OUTER JOIN
    (SELECT a1.ACCOUNTING_UNIT_ID ,
      a1.ACCOUNTING_FOR_OFFICE_ID,
      a1.CASHBOOK_YEAR,
      a1.CASHBOOK_MONTH,
      B1.SL_NO,
      b1.PAYABLE_VOUCHER_SLNO,
      a1.PAYMENT_DATE,
      a1.VOUCHER_NO,
      b1.CHEQUE_DD_NO,
      b1.CHEQUE_DD_DATE,
      b1.AMOUNT,
      a1.SUB_LEDGER_TYPE_CODE,
      A1.Sub_Ledger_Code,
      b1.PAYABLE_VOUCHER_NO,
      b1.PAYABLE_VOUCHER_DATE
    FROM FAS_PAYMENT_MASTER a1
    INNER JOIN FAS_PAYMENT_TRANSACTION b1
    ON A1.Accounting_Unit_Id       =B1.Accounting_Unit_Id
    AND A1.Accounting_For_Office_Id=B1.Accounting_For_Office_Id
    AND A1.Cashbook_Year           =B1.Cashbook_Year
    AND A1.CASHBOOK_MONTH          =B1.CASHBOOK_MONTH
    AND A1.VOUCHER_NO              =B1.VOUCHER_NO
    AND a1.CREATED_BY_MODULE       ='BPP'
    AND a1.PAYMENT_STATUS          ='L'
    AND a1.ACCOUNTING_UNIT_ID      =$P{unitid}
    AND a1.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
    )bb ON aa.Accounting_Unit_Id   =bb.Accounting_Unit_Id
  AND aa.Accounting_For_Office_Id  =bb.Accounting_For_Office_Id
  AND AA.RECEIPT_NO                = BB.PAYABLE_VOUCHER_NO
  AND AA.RECEIPT_DATE             = bb.PAYABLE_VOUCHER_DATE
  AND aa.SUB_LEDGER_TYPE_CODE      =bb.SUB_LEDGER_TYPE_CODE
  AND AA.SUB_LEDGER_CODE           =BB.SUB_LEDGER_CODE
AND aa.SL_NO                     =bb.PAYABLE_VOUCHER_SLNO
  )
ORDER BY Accounting_Unit_Id,
  ljvamount ) A
INNER JOIN
  (SELECT rownum AS row_numm,
    Sub_Ledger_Code
  FROM
    (SELECT DISTINCT Sub_Ledger_Code
    FROM (
      (SELECT aa.Accounting_Unit_Id,
        aa.Accounting_For_Office_Id,
        (SELECT Uu.Accounting_Unit_Name
        FROM fas_mst_acct_units uu
        WHERE Uu.Accounting_Unit_Id=aa.Accounting_Unit_Id
        )AS orgunitname,
        aa.CASHBOOK_YEAR,
        aa.CASHBOOK_MONTH,
        aa.SL_NO,
        AA.RECEIPT_DATE,
        aa.RECEIPT_NO,
        aa.CHEQUE_DD_NO,
        aa.CHEQUE_DD_DATE,
        aa.AMOUNT,
        aa.SUB_LEDGER_TYPE_CODE,
        (SELECT S.Sub_Ledger_Type_Desc
        FROM com_mst_sl_types s
        WHERE s.SUB_LEDGER_TYPE_CODE=Aa.Sub_Ledger_Type_Code
        )AS sl_desc,
        aa.Sub_Ledger_Code,
        (SELECT l.SL_CODENAME
        FROM SL_TYPE_CODE_NAME_VIEW_M l
        WHERE L.Sl_Type=Aa.Sub_Ledger_Type_Code
        AND L.Sl_Code  =Aa.Sub_Ledger_Code
        )AS code_desc ,
        aa.cb_ref_no,
        aa.cb_ref_date,
        aa.cheque_or_dd ,
        aa.ljvamount,
        bb.VOUCHER_NO pay_no,
        bb.PAYMENT_DATE,
        bb.AMOUNT AS pay_amt,
        aa.multiple_pvrs,
        aa.account_head_code ,
        (SELECT h.account_head_desc
        FROM com_mst_account_heads h
        WHERE h.account_head_code= aa.account_head_code
        ) AS head_desc
      FROM
        (SELECT a.Accounting_Unit_Id,
          a.Accounting_For_Office_Id,
          a.CASHBOOK_YEAR,
          a.CASHBOOK_MONTH,
          b.SL_NO,
          A.RECEIPT_DATE,
          a.RECEIPT_NO,
          b.CHEQUE_DD_NO,
          b.CHEQUE_DD_DATE,
          b.AMOUNT,
          b.SUB_LEDGER_TYPE_CODE,
          b.Sub_Ledger_Code,
          b.cb_ref_no,
          b.cb_ref_date,
          b.cheque_or_dd ,
          b.AMOUNT AS ljvamount,
          b.multiple_pvrs,
          b.account_head_code
        FROM FAS_RECEIPT_MASTER a
        INNER JOIN FAS_RECEIPT_TRANSACTION b
        ON A.Accounting_Unit_Id       =B.Accounting_Unit_Id
        AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
        AND A.Cashbook_Year           =B.Cashbook_Year
        AND A.CASHBOOK_MONTH          =B.CASHBOOK_MONTH
        AND A.RECEIPT_NO              =B.RECEIPT_NO                          ---RECEIPT_NO
        AND a.ACCOUNTING_UNIT_ID      =$P{unitid}
        AND a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
        AND a.CASHBOOK_MONTH          =$P{cashbookmonth}
        AND A.CASHBOOK_YEAR           =$P{cashbookyear}
        AND A.RECEIPT_STATUS          ='L'                                ----RECEIPT_STATUS
        AND B.CR_DR_INDICATOR='CR'
         AND B.SUB_LEDGER_TYPE_CODE !=0
         and b.Sub_Ledger_Code!=0
          --AND b.cheque_dd_date         IS NOT NULL
          -- AND b.cheque_dd_no            > 0
        AND ( b.multiple_pvrs IS NULL
        OR b.multiple_pvrs     = 'N')
        )AA
      LEFT OUTER JOIN
        (SELECT a1.ACCOUNTING_UNIT_ID ,
          a1.ACCOUNTING_FOR_OFFICE_ID,
          a1.CASHBOOK_YEAR,
          a1.CASHBOOK_MONTH,
          B1.SL_NO,
          b1.PAYABLE_VOUCHER_SLNO,
          a1.PAYMENT_DATE,
          a1.VOUCHER_NO,
          b1.CHEQUE_DD_NO,
          b1.CHEQUE_DD_DATE,
          b1.AMOUNT,
          a1.SUB_LEDGER_TYPE_CODE,
          A1.Sub_Ledger_Code,
          b1.PAYABLE_VOUCHER_NO,
          b1.PAYABLE_VOUCHER_DATE
        FROM FAS_PAYMENT_MASTER a1
        INNER JOIN FAS_PAYMENT_TRANSACTION b1
        ON A1.Accounting_Unit_Id       =B1.Accounting_Unit_Id
        AND A1.Accounting_For_Office_Id=B1.Accounting_For_Office_Id
        AND A1.Cashbook_Year           =B1.Cashbook_Year
        AND A1.CASHBOOK_MONTH          =B1.CASHBOOK_MONTH
        AND A1.VOUCHER_NO              =B1.VOUCHER_NO
        AND a1.CREATED_BY_MODULE       ='BPP'
        AND a1.PAYMENT_STATUS          ='L'
        AND a1.ACCOUNTING_UNIT_ID      =$P{unitid}
        AND a1.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
        )bb ON aa.Accounting_Unit_Id   =bb.Accounting_Unit_Id
      AND aa.Accounting_For_Office_Id  =bb.Accounting_For_Office_Id
      AND aa.RECEIPT_NO                = bb.PAYABLE_VOUCHER_NO
      AND aa.RECEIPT_DATE              = bb.PAYABLE_VOUCHER_DATE
      AND aa.SUB_LEDGER_TYPE_CODE      =bb.SUB_LEDGER_TYPE_CODE
      AND AA.SUB_LEDGER_CODE           =BB.SUB_LEDGER_CODE
      AND aa.CHEQUE_DD_NO              =bb.CHEQUE_DD_NO
      AND AA.CHEQUE_DD_DATE            =BB.CHEQUE_DD_DATE
   AND aa.SL_NO                     =bb.PAYABLE_VOUCHER_SLNO
      )
    UNION ALL
      (SELECT aa.Accounting_Unit_Id,
        aa.Accounting_For_Office_Id,
        (SELECT Uu.Accounting_Unit_Name
        FROM fas_mst_acct_units uu
        WHERE Uu.Accounting_Unit_Id=aa.Accounting_Unit_Id
        )AS orgunitname,
        aa.CASHBOOK_YEAR,
        aa.CASHBOOK_MONTH,
        aa.SL_NO,
        AA.RECEIPT_DATE,
        aa.RECEIPT_NO,
        aa.CHEQUE_DD_NO,
        aa.CHEQUE_DD_DATE,
        aa.AMOUNT,
        aa.SUB_LEDGER_TYPE_CODE,
        (SELECT S.Sub_Ledger_Type_Desc
        FROM com_mst_sl_types s
        WHERE s.SUB_LEDGER_TYPE_CODE=Aa.Sub_Ledger_Type_Code
        )AS sl_desc,
        aa.Sub_Ledger_Code,
        (SELECT l.SL_CODENAME
        FROM SL_TYPE_CODE_NAME_VIEW_M l
        WHERE L.Sl_Type=Aa.Sub_Ledger_Type_Code
        AND L.Sl_Code  =Aa.Sub_Ledger_Code
        )AS code_desc ,
        aa.cb_ref_no,
        aa.cb_ref_date,
        aa.cheque_or_dd ,
        aa.ljvamount,
        bb.VOUCHER_NO pay_no,
        bb.PAYMENT_DATE,
        bb.AMOUNT AS pay_amt,
        aa.multiple_pvrs,
        aa.account_head_code ,
        (SELECT h.account_head_desc
        FROM com_mst_account_heads h
        WHERE h.account_head_code= aa.account_head_code
        ) AS head_desc
      FROM
        (SELECT a.Accounting_Unit_Id,
          a.Accounting_For_Office_Id,
          a.CASHBOOK_YEAR,
          a.CASHBOOK_MONTH,
          b.SL_NO,
          A.RECEIPT_DATE,
          a.RECEIPT_NO,
          b.CHEQUE_DD_NO,
          b.CHEQUE_DD_DATE,
          b.AMOUNT,
          b.SUB_LEDGER_TYPE_CODE,
          b.Sub_Ledger_Code,
          b.cb_ref_no,
          b.cb_ref_date,
          b.cheque_or_dd ,
          b.AMOUNT AS ljvamount,
          b.multiple_pvrs,
          b.account_head_code
        FROM FAS_RECEIPT_MASTER a
        INNER JOIN FAS_RECEIPT_TRANSACTION b
        ON A.Accounting_Unit_Id       =B.Accounting_Unit_Id
        AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
        AND A.Cashbook_Year           =B.Cashbook_Year
        AND A.Cashbook_Month          =B.Cashbook_Month
        AND A.RECEIPT_NO              =B.RECEIPT_NO
        AND a.ACCOUNTING_UNIT_ID      =$P{unitid}
        AND a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
        AND a.CASHBOOK_MONTH          =$P{cashbookmonth}
        AND a.CASHBOOK_YEAR           =$P{cashbookyear}
        AND A.RECEIPT_STATUS          ='L'
        AND B.CR_DR_INDICATOR='CR'
         AND B.SUB_LEDGER_TYPE_CODE !=0
         and b.Sub_Ledger_Code!=0
          --AND b.cheque_dd_date         IS NOT NULL
          --AND b.cheque_dd_no            > 0
        AND b.multiple_pvrs = 'Y'
        )AA
      LEFT OUTER JOIN
        (SELECT a1.ACCOUNTING_UNIT_ID ,
          a1.ACCOUNTING_FOR_OFFICE_ID,
          a1.CASHBOOK_YEAR,
          a1.CASHBOOK_MONTH,
          B1.SL_NO,
          b1.PAYABLE_VOUCHER_SLNO,
          a1.PAYMENT_DATE,
          a1.VOUCHER_NO,
          b1.CHEQUE_DD_NO,
          b1.CHEQUE_DD_DATE,
          b1.AMOUNT,
          a1.SUB_LEDGER_TYPE_CODE,
          A1.Sub_Ledger_Code,
          b1.PAYABLE_VOUCHER_NO,
          b1.PAYABLE_VOUCHER_DATE
        FROM FAS_PAYMENT_MASTER a1
        INNER JOIN FAS_PAYMENT_TRANSACTION b1
        ON A1.Accounting_Unit_Id       =B1.Accounting_Unit_Id
        AND A1.Accounting_For_Office_Id=B1.Accounting_For_Office_Id
        AND A1.Cashbook_Year           =B1.Cashbook_Year
        AND A1.CASHBOOK_MONTH          =B1.CASHBOOK_MONTH
        AND A1.VOUCHER_NO              =B1.VOUCHER_NO
        AND a1.CREATED_BY_MODULE       ='BPP'
        AND a1.PAYMENT_STATUS          ='L'
        AND a1.ACCOUNTING_UNIT_ID      =$P{unitid}
        AND a1.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
        )bb ON aa.Accounting_Unit_Id   =bb.Accounting_Unit_Id
      AND aa.Accounting_For_Office_Id  =bb.Accounting_For_Office_Id
      AND aa.RECEIPT_NO                = bb.PAYABLE_VOUCHER_NO
      AND aa.RECEIPT_DATE              = bb.PAYABLE_VOUCHER_DATE
      AND aa.SUB_LEDGER_TYPE_CODE      =bb.SUB_LEDGER_TYPE_CODE
      AND AA.SUB_LEDGER_CODE           =BB.SUB_LEDGER_CODE
      AND aa.SL_NO                     =bb.PAYABLE_VOUCHER_SLNO
      ) )
    ORDER BY Sub_Ledger_Code
    )
  ) B ON A.SUB_LEDGER_CODE=B.SUB_LEDGER_CODE
ORDER BY A.RECEIPT_NO,
	A.SL_No,
  A.RECEIPT_DATE,
  A.Sub_Ledger_Code,
  A.SUB_LEDGER_TYPE_CODE
  --ORDER BY a.Accounting_Unit_Id,  A.Ljvamount,  A.RECEIPT_NO,  A.Cb_Ref_Date, a. pay_no]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="ORGUNITNAME" class="java.lang.String"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="SL_NO" class="java.math.BigDecimal"/>
	<field name="RECEIPT_DATE" class="java.sql.Timestamp"/>
	<field name="RECEIPT_NO" class="java.math.BigDecimal"/>
	<field name="CHEQUE_DD_NO" class="java.lang.String"/>
	<field name="CHEQUE_DD_DATE" class="java.sql.Timestamp"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>
	<field name="SUB_LEDGER_TYPE_CODE" class="java.math.BigDecimal"/>
	<field name="SL_DESC" class="java.lang.String"/>
	<field name="SUB_LEDGER_CODE" class="java.math.BigDecimal"/>
	<field name="CODE_DESC" class="java.lang.String"/>
	<field name="CB_REF_NO" class="java.math.BigDecimal"/>
	<field name="CB_REF_DATE" class="java.sql.Timestamp"/>
	<field name="CHEQUE_OR_DD" class="java.lang.String"/>
	<field name="LJVAMOUNT" class="java.math.BigDecimal"/>
	<field name="PAY_NO" class="java.math.BigDecimal"/>
	<field name="PAYMENT_DATE" class="java.sql.Timestamp"/>
	<field name="PAY_AMT" class="java.math.BigDecimal"/>
	<field name="MULTIPLE_PVRS" class="java.lang.String"/>
	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="HEAD_DESC" class="java.lang.String"/>
