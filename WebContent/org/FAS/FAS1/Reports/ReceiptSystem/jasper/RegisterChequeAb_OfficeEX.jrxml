<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="RegisterChequeAb_OfficeEX"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="736"
		 pageHeight="595"
		 columnWidth="736"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.Long"/>
	<queryString><![CDATA[SELECT *
FROM
  (
SELECT voucher_no,
   payment_date,
    bank_id,
   branch_id,
    amt_paid_to,
   CHEQUE_DD_NO,
    Cheque_Dd_Date,
    --sum(b.amount)as amt,
    (dr_amt-cr_amt)as amt,
    accounting_unit_name,
    office_short_name,
    branch_name,
    BANK_NAME,
    micr_code
    from
  (
SELECT a.voucher_no,
    a.payment_date,
    a.bank_id,
    a.branch_id,
    a.paid_to AS amt_paid_to,
    b.CHEQUE_DD_NO,
    B.Cheque_Dd_Date,
    --sum(b.amount)as amt,
 --sum(decode(b.CR_DR_INDICATOR,'CR',b.amount,0))as cr_amt,
 ---   sum(decode(b.CR_DR_INDICATOR,'DR',b.amount,0)) as dr_amt,
    sum(case when b.CR_DR_INDICATOR = 'CR' then b.amount end) as cr_amt,
  sum(case when b.CR_DR_INDICATOR = 'DR' then b.amount end) as dr_amt,

    c.accounting_unit_name,
    d.office_short_name,
    e.branch_name,
    f.BANK_NAME,
    e.micr_code
  FROM fas_payment_master a,
    fas_payment_transaction b,
    fas_mst_acct_units c,
    com_mst_offices d,
    fas_mst_bank_branches e,
    com_mst_account_heads g,
    fas_mst_banks f
  WHERE a.cashbook_month        =b.cashbook_month
  AND a.cashbook_year           =b.cashbook_year
  AND a.accounting_unit_id      =b.accounting_unit_id
  AND a.accounting_for_office_id=b.accounting_for_office_id
  AND a.voucher_no              =b.voucher_no
  AND c.accounting_unit_id      =a.accounting_unit_id
  AND d.office_id               =a.accounting_for_office_id
  AND e.bank_id                 =a.bank_id
  AND e.branch_id               =a.branch_id
  AND f.bank_id                 =e.bank_id
  AND b.account_head_code       =g.account_head_code
  AND a.payment_status         <>'C'
  AND a.payment_type            ='B'
  AND a.cashbook_year           =$P{cashbookyear}::int
  AND a.cashbook_month          =$P{cashbookmonth}::int
  AND a.accounting_unit_id      =$P{accountingunitid}::int
  And A.Accounting_For_Office_Id=$P{accountofficeid}::int
  and a.ACCOUNT_NO=$P{accNo}::numeric
    group by a.voucher_no,a.payment_date,
    A.Bank_Id,
    A.Branch_Id, a.paid_to,
    B.Cheque_Dd_No,
    B.Cheque_Dd_Date,
    c.accounting_unit_name,
    d.office_short_name,
    e.branch_name,
    F.Bank_Name,
    E.Micr_Code)as opt1
 union all
  SELECT a.VOUCHER_NO ,
    a.DATE_OF_TRANSFER AS payment_date,
    a.OFFICE_BANK_ID   AS bank_id ,
    a.OFFICE_BRANCH_ID AS branch_id,
    ' '                AS amt_paid_to ,
    a.CHEQUE_DD_NO ,
    a.CHEQUE_DD_DATE ,
    sum(a.TOTAL_AMOUNT)as amt,
    c.accounting_unit_name,
    d.office_short_name,
    e.branch_name,
    f.BANK_NAME,
    e.micr_code
  FROM FAS_FUND_TRF_FROM_OFFICE a,
    fas_mst_acct_units c,
    com_mst_offices d,
    fas_mst_bank_branches e,
    com_mst_account_heads g,
    fas_mst_banks f
  WHERE c.accounting_unit_id    =a.accounting_unit_id
  AND d.office_id               =a.accounting_for_office_id
  AND e.bank_id                 =a.OFFICE_BANK_ID
  AND e.branch_id               =a.OFFICE_BRANCH_ID
  AND f.bank_id                 =e.bank_id
  AND a.dr_account_head_code    = g.account_head_code
  AND a.TRANSFER_STATUS        <>'C'
  AND a.cashbook_year           =$P{cashbookyear}::int
  AND a.cashbook_month          =$P{cashbookmonth}::int
  AND a.accounting_unit_id      =$P{accountingunitid}::int
  And A.Accounting_For_Office_Id=$P{accountofficeid}::int
and a.OFFICE_ACCOUNT_NO=$P{accNo}::numeric
   Group By A.Voucher_No,A.Date_Of_Transfer,
    A.Office_Bank_Id,A.Office_Branch_Id,A.Cheque_Dd_No ,
    a.CHEQUE_DD_DATE ,
    c.accounting_unit_name,
    d.office_short_name,
    e.branch_name,
    F.Bank_Name,
    E.Micr_Code
union all
    ---------------- Receipt ------------------
  SELECT a.receipt_no AS voucher_no,
    A.Receipt_Date    As Payment_Date,
    A.Bank_Id,
    a.branch_id,
    ' '                     AS amt_paid_to,
    b.CHEQUE_DD_NO,
    B.Cheque_Dd_Date,
    SUM(b.amount)AS amt, 
    c.accounting_unit_name,
    d.office_short_name,
    e.branch_name,
    f.BANK_NAME,
    e.micr_code
  FROM fas_receipt_master a,
    fas_receipt_transaction b,
    fas_mst_acct_units c,
    com_mst_offices d,
    fas_mst_bank_branches e,
    com_mst_account_heads g,
    fas_mst_banks f
  WHERE a.cashbook_month        =b.cashbook_month
  AND a.cashbook_year           =b.cashbook_year
  AND a.accounting_unit_id      =b.accounting_unit_id
  AND a.accounting_for_office_id=b.accounting_for_office_id
  AND a.receipt_no              =b.receipt_no
  AND c.accounting_unit_id      =a.accounting_unit_id
  AND d.office_id               =a.accounting_for_office_id
  AND e.bank_id                 =a.bank_id
  AND e.branch_id               =a.branch_id
  AND f.bank_id                 =e.bank_id
  AND b.account_head_code       =g.account_head_code
  AND a.receipt_status         <>'C'
  AND a.created_by_module       ='SC'
  AND a.cashbook_year           =$P{cashbookyear}::int
  AND a.cashbook_month          =$P{cashbookmonth}::int
  AND a.accounting_unit_id      =$P{accountingunitid}::int
  And A.Accounting_For_Office_Id=$P{accountofficeid}::int
  And A.Account_No             In ($P{accNo}::numeric)
   Group By A.Receipt_No,
    A.Receipt_Date,
    A.Bank_Id,
    a.branch_id,
    b.CHEQUE_DD_NO,
    B.Cheque_Dd_Date,
    c.accounting_unit_name,
    d.office_short_name,
    e.branch_name,
    F.Bank_Name,
    e.micr_code
  ) as opt2
order by Cheque_Dd_No]]></queryString>

	<field name="voucher_no" class="java.math.BigDecimal"/>
	<field name="payment_date" class="java.sql.Date"/>
	<field name="bank_id" class="java.math.BigDecimal"/>
	<field name="branch_id" class="java.math.BigDecimal"/>
	<field name="amt_paid_to" class="java.lang.String"/>
	<field name="cheque_dd_no" class="java.lang.String"/>
