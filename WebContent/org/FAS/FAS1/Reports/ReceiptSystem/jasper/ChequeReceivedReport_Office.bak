<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ChequeReceivedReport_Office"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="808"
		 columnSpacing="0"
		 leftMargin="17"
		 rightMargin="17"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="acc_no" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select * from (SELECT one.*,
  two.Passbook_Date
FROM
  (SELECT a.receipt_no,
    a.receipt_date as "receipt_date",
    a.challan_date as "challan_date",
    A.Received_From As Money_Rec_From ,
    B.Account_Head_Code,
    (select H.Account_Head_Desc from com_mst_account_heads h where H.Account_Head_Code=b.Account_Head_Code)as Acc_details,
    
    b.amount                AS "amt",
    b.particulars as "particulars",
    b.CHEQUE_DD_NO AS "ddno",
    (b.CHEQUE_OR_DD
    ||'-'
    || b.CHEQUE_DD_NO
    ||'-'
    || TO_CHAR(b.CHEQUE_DD_DATE,'DD/MM/YYYY')
    ||'-'
    || b.BANK_NAME ) AS "all_details",
    d.accounting_unit_name as "accounting_unit_name",
    f.office_short_name,ACCOUNT_NO as "account_no"
  FROM fas_receipt_master a,
    fas_receipt_transaction b,
    com_mst_account_heads c,
    fas_mst_acct_units d,
    com_mst_offices f
  WHERE a.cashbook_month        =b.cashbook_month
  AND a.cashbook_year           =b.cashbook_year
  AND a.accounting_unit_id      =b.accounting_unit_id
  AND a.accounting_for_office_id=b.accounting_for_office_id
  AND b.account_head_code       =c.account_head_code
  AND d.accounting_unit_id      =a.accounting_unit_id
  AND a.accounting_for_office_id=f.office_id
  AND a.receipt_no              =b.receipt_no
  AND a.receipt_status         <>'C'
  AND a.receipt_type            ='B'
  AND a.cashbook_year           =($P{cashbookyear}::int)
  AND a.cashbook_month          = ($P{cashbookmonth}::int)
  AND a.accounting_unit_id      = ($P{accountingunitid}::int)
  AND a.accounting_for_office_id=($P{accountofficeid}::int) 

  UNION ALL
  SELECT a.receipt_no,
    a.receipt_date,
    a.challan_date,
    '' As Money_Rec_From ,
    A.Dr_Account_Head_Code,
    (select H.Account_Head_Desc from com_mst_account_heads h where H.Account_Head_Code=A.Dr_Account_Head_Code)as Acc_details,
  
    a.TOTAL_AMOUNT          AS amt,
    a.PARTICULARS,
    a.CHEQUE_DD_NO AS ddno,
    (a.CHEQUE_OR_DD
    ||'-'
    || a.CHEQUE_DD_NO
    ||'-'
    || TO_CHAR(a.CHEQUE_DD_DATE,'DD/MM/YYYY') 
    ||'-'
    || g.BANK_NAME ) AS All_details,

    d.accounting_unit_name,
    f.office_short_name,OFFICE_ACCOUNT_NO as ACCOUNT_NO
  From Fas_Fund_Receipt_By_Office A ,
    fas_mst_acct_units d,
    com_mst_offices f ,
    fas_mst_banks g
  WHERE a.cashbook_year         = ($P{cashbookyear}::int)
  AND a.cashbook_month          = ($P{cashbookmonth}::int)
  AND a.accounting_unit_id      = ($P{accountingunitid}::int)
  AND a.accounting_for_office_id= ($P{accountofficeid}::int) 
  And A.Receipt_Status         <>'C'
  AND d.accounting_unit_id      =a.accounting_unit_id
  AND a.accounting_for_office_id=f.office_id
  AND a.HO_BANK_ID              = g.BANK_ID

  )One 
LEFT OUTER JOIN
  (SELECT Passbook_Date,Cheque_Dd_No FROM Fas_Brs_Transaction
  )Two 
ON One.Ddno::int=Two.Cheque_Dd_No  
)one1
 ---$P!{acc_no}
ORDER BY one1.account_no,one1.receipt_date,one1.receipt_no]]></queryString>

	<field name="receipt_no" class="java.math.BigDecimal"/>
	<field name="receipt_date" class="java.sql.Date"/>
	<field name="challan_date" class="java.sql.Date"/>
	<field name="money_rec_from" class="java.lang.String"/>
	<field name="account_head_code" class="java.math.BigDecimal"/>
	<field name="acc_details" class="java.lang.String"/>
	<field name="amt" class="java.math.BigDecimal"/>
	<field name="particulars" class="java.lang.String"/>
	<field name="ddno" class="java.lang.String"/>
	<field name="all_details" class="java.lang.String"/>
	<field name="accounting_unit_name" class="java.lang.String"/>
	<field name="office_short_name" class="java.lang.String"/>
	<field name="account_no" class="java.math.BigDecimal"/>
	<field name="passbook_date" class="java.sql.Date"/>

	<variable name="g_total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{amt}]]></variableExpression>
	</variable>

