<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ChequeAbstractReport_OfficeEX"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="651"
		 pageHeight="595"
		 columnWidth="651"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<parameter name="acc_no" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT *
FROM
  (SELECT b.CHEQUE_DD_NO,
    B.Cheque_Dd_Date,
    SUM(B.Amount)AS Total_Amt,
    A.Receipt_Date,
    A.Received_From AS Off_Id,
    (SELECT U.Accounting_Unit_Name
    FROM Fas_Mst_Acct_Units U
    WHERE U.Accounting_Unit_Id=A.Accounting_Unit_Id
    )AS Accounting_Unit_Name,
    (SELECT V.Bank_Name FROM fas_mst_banks v WHERE V.Bank_Id=A.Bank_Id
    )AS Bank_Name,a.ACCOUNT_NO
  FROM fas_receipt_master a,
    fas_receipt_transaction b
  WHERE a.cashbook_month        =b.cashbook_month
  AND a.cashbook_year           =b.cashbook_year
  AND a.accounting_unit_id      =b.accounting_unit_id
  AND a.accounting_for_office_id=b.accounting_for_office_id
  AND a.receipt_no              =b.receipt_no
  AND a.receipt_status         <>'C'
  AND a.cashbook_year           =$P{cashbookyear}::int
  AND a.cashbook_month          =$P{cashbookmonth}::int
  AND A.Accounting_Unit_Id      =$P{accountingunitid}::int
  AND A.Accounting_For_Office_Id=$P{accountofficeid}::int 

  AND a.receipt_type            ='B'
  GROUP BY B.Cheque_Dd_No,
    B.Cheque_Dd_Date,
    A.Receipt_Date,
    A.Received_From,
    A.Accounting_Unit_Id,
    a.Bank_Id,a.ACCOUNT_NO
  UNION ALL
  SELECT a.CHEQUE_DD_NO ,
    A.Cheque_Dd_Date ,
    SUM(A.Total_Amount)AS Total_Amt,
    A.Receipt_Date,
    '' AS Off_Id,
    (SELECT U.Accounting_Unit_Name
    FROM Fas_Mst_Acct_Units U
    WHERE U.Accounting_Unit_Id=A.Accounting_Unit_Id
    )AS Accounting_Unit_Name,
    (SELECT V.Bank_Name FROM fas_mst_banks v WHERE V.Bank_Id=A.OFFICE_BANK_ID
    )AS Bank_Name,a.OFFICE_ACCOUNT_NO as    ACCOUNT_NO
  FROM FAS_FUND_RECEIPT_BY_OFFICE a
  WHERE a.RECEIPT_STATUS       <>'C'
  AND a.cashbook_year           =$P{cashbookyear}::int
  AND a.cashbook_month          =$P{cashbookmonth}::int
  AND A.Accounting_Unit_Id      =$P{accountingunitid}::int
  AND A.Accounting_For_Office_Id=$P{accountofficeid}::int 

  GROUP BY A.Cheque_Dd_No ,
    A.Cheque_Dd_Date ,
    A.Receipt_Date,
    A.Accounting_Unit_Id,
    A.Office_Bank_Id,a.OFFICE_ACCOUNT_NO 
  )as opt1 where ACCOUNT_NO=$P!{acc_no}
 ---$P!{acc_no}
ORDER BY ACCOUNT_NO ,Receipt_Date,
  Cheque_Dd_No,
  Cheque_Dd_Date]]></queryString>

