	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT
  cashbook_year,
  decode(cashbook_month,1,'January',2,'Feburary',3,'March',4,'April',5,'May',6,'June',7,
  'July',8,'August',9,'September',10,'October',11,'November',12,'December') as mon ,
  
  cashbook_month,
  
  tb_status,
  tb_date,
  updated_by_user_id,
  updated_date
FROM fas_tb_closure
where cashbook_year = $P{cashbookyear}
order by cashbook_month]]></queryString>

