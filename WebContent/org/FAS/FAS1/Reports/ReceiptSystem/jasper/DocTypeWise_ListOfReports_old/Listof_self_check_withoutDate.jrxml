	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select accounting_unit_id,accounting_unit_name,accounting_for_office_id,office_name,payment_date,cashbook_year,cashbook_month,voucher_no,account_head_code,
account_head_desc,sub_ledger_code,paid_to,total_amount,created_by_module,payment_status,remarks,
decode(sub_ledger_type_code,1,'Supplier',2,'Firms',3,'Assets',4,'Cheque Books',5,'Offices',6,'Bank',7,'Employees',8,'-',9,'Other Departments',10,'Project',11,'Contractors',12,'Scheme Owner',13,'Beneficiary',14,'TWAD','-')as sub_ledger_type_code
from
(
select accounting_unit_id,accounting_for_office_id,payment_date,cashbook_year,cashbook_month,voucher_no,account_head_code,
sub_ledger_type_code,sub_ledger_code,paid_to,total_amount,created_by_module,payment_status,remarks from
fas_payment_master
where created_by_module='SC' and payment_status='L'
) a
left outer join
(
select account_head_code as acc_head_code,account_head_desc from com_mst_account_heads
) b
on a.account_head_code=b.acc_head_code
left outer join
(
select office_id,office_name from com_mst_offices
) c
on a.accounting_for_office_id=c.office_id
left outer join
(
select accounting_unit_id as acc_unit_id,accounting_unit_name from FAS_MST_ACCT_UNITS
) d
on a.accounting_unit_id=d.acc_unit_id
where a.accounting_unit_id=$P{accountingunitid} and a.accounting_for_office_id=$P{accountofficeid} and
cashbook_month=$P{txtCB_Month} and cashbook_year=$P{txtCB_Year}
order by payment_date,voucher_no,account_head_code]]></queryString>

