<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Annexure-III(a)"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="935"
		 pageHeight="595"
		 columnWidth="875"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="from_cashbk_yr" isForPrompting="true" class="java.lang.String"/>
	<parameter name="from_cashbk_mon" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_cashbk_yr" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_cashbk_mon" isForPrompting="true" class="java.lang.String"/>
	<parameter name="from_monthInWords" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT unit_id,
  (SELECT accounting_unit_name
  FROM fas_mst_acct_units
  WHERE accounting_unit_id=unit_id
  )                                     AS "ACCOUNTING_UNIT_NAME",
  SUM(amt_160502cr)                     AS "AMT_160502CR",
  SUM(amt_160502dr)                     AS "AMT_160502DR",
  SUM(amt_780406dr)                     AS "AMT_780406DR",
  SUM(amt_160611cr)                     AS "AMT_160611CR",
  SUM(amt_160611dr)                     AS "AMT_160611DR",
  SUM(amt_780406cr)                     AS "AMT_780406CR" , 
  SUM(amt_782406dr)                     AS "AMT_782406DR",
   SUM(amt_782406cr)                     AS "AMT_782406CR" ,
  CASE
    WHEN ( SUM(amt_780406dr)-SUM(amt_780406cr)>0)
    THEN    SUM(amt_780406dr)-SUM(amt_780406cr)
      ||' DR'
    WHEN ( SUM(amt_780406dr)-SUM(amt_780406cr)=0)
    THEN    SUM(amt_780406dr)-SUM(amt_780406cr)
      ||''
    ELSE (SUM(amt_780406dr)-SUM(amt_780406cr))
      || ' CR'
  END AS "NET_780406" ,
  
  CASE
    WHEN ( SUM(amt_782406dr)-SUM(amt_782406cr)>0)
    THEN    SUM(amt_782406dr)-SUM(amt_782406cr)
      ||' DR'
    WHEN ( SUM(amt_782406dr)-SUM(amt_782406cr)=0)
    THEN    SUM(amt_782406dr)-SUM(amt_782406cr)
      ||''
    ELSE -(SUM(amt_782406dr)-SUM(amt_782406cr))
      || ' CR'
  END AS "NET_782406",
  
  SUM(amt_160611cr) + (SUM(amt_782406dr)-SUM(amt_782406cr)) AS "TOT",
  case when SUM(amt_160611cr) + (SUM(amt_782406dr)-SUM(amt_782406cr))>0
  then SUM(amt_160611cr) + (SUM(amt_782406dr)-SUM(amt_782406cr))
  when SUM(amt_160611cr) + (SUM(amt_782406dr)-SUM(amt_782406cr))=0
  then SUM(amt_160611cr) + (SUM(amt_782406dr)-SUM(amt_782406cr))
  else -(SUM(amt_160611cr) + (SUM(amt_782406dr)-SUM(amt_782406cr))) end as final_tot,
  CASE
    WHEN ( (-(SUM(amt_160502dr)-SUM(amt_160502cr)))>0)
    THEN    -(SUM(amt_160502dr)-SUM(amt_160502cr))
      ||' CR'
    WHEN ( (-(SUM(amt_160502dr)-SUM(amt_160502cr)))=0)
    THEN    -(SUM(amt_160502dr)-SUM(amt_160502cr))
      ||''
    ELSE (SUM(amt_160502dr)-SUM(amt_160502cr))
      || ' DR'
  END AS "NETINDICATOR" ,
  CASE
    WHEN ( (               -(SUM(amt_160502dr)-SUM(amt_160502cr)))>0)
    THEN                   -(SUM(amt_160502dr)-SUM(amt_160502cr))-(SUM(amt_780406dr)-SUM(amt_780406cr))
    WHEN ( (               -(SUM(amt_160502dr)-SUM(amt_160502cr)))=0)
    THEN                   -(SUM(amt_160502dr)-SUM(amt_160502cr))-(SUM(amt_780406dr)-SUM(amt_780406cr))
    ELSE (SUM(amt_160502dr)-SUM(amt_160502cr))-(SUM(amt_780406dr)-SUM(amt_780406cr))
  END AS "DIFFERENCE" ,
  CASE
    WHEN ( (-(SUM(amt_160611dr)-SUM(amt_160611cr)))>0)
    THEN    -(SUM(amt_160611dr)-SUM(amt_160611cr))
      ||' CR'
    WHEN ( (-(SUM(amt_160611dr)-SUM(amt_160611cr)))=0)
    THEN    -(SUM(amt_160611dr)-SUM(amt_160611cr))
      ||''
    ELSE (SUM(amt_160611dr)-SUM(amt_160611cr))
      ||' DR'
  END AS "NETINDICATORONE"
FROM
  (SELECT accounting_unit_id AS unit_id ,
    accounting_for_office_id,
    cashbook_month,
    cashbook_year ,
    CASE
      WHEN ( account_head_code = 160502
      AND CR_DR_INDICATOR      ='CR' )
      THEN SUM(amount)
      ELSE 0
    END AS amt_160502cr,
    CASE
      WHEN ( account_head_code = 160502
      AND CR_DR_INDICATOR      ='DR' )
      THEN SUM(amount)
      ELSE 0
    END AS amt_160502dr,
    CASE
      WHEN ( account_head_code = 780406
      AND CR_DR_INDICATOR      ='DR' )
      THEN SUM(amount)
      ELSE 0
    END AS amt_780406dr ,
    CASE
      WHEN ( account_head_code = 160611
      AND CR_DR_INDICATOR      ='CR' )
      THEN SUM(amount)
      ELSE 0
    END AS amt_160611cr ,
    CASE
      WHEN ( account_head_code = 160611
      AND CR_DR_INDICATOR      ='DR' )
      THEN SUM(amount)
      ELSE 0
    END AS amt_160611dr ,
    CASE
      WHEN ( account_head_code = 780406
      AND CR_DR_INDICATOR      ='CR' )
      THEN SUM(amount)
      ELSE 0
    END AS amt_780406cr,
     CASE
      WHEN ( account_head_code = 782406
      AND CR_DR_INDICATOR      ='DR' )
      THEN SUM(amount)
      ELSE 0
    END AS amt_782406dr ,
     CASE
      WHEN ( account_head_code = 782406
      AND CR_DR_INDICATOR      ='CR' )
      THEN SUM(amount)
      ELSE 0
    END AS amt_782406cr
    
  FROM
    (SELECT m.accounting_unit_id ,
      m.accounting_for_office_id ,
      m.cashbook_month,
      m.cashbook_year,
      t.account_head_code,
      t.CR_DR_INDICATOR,
      t.amount
    FROM fas_journal_master m ,
      fas_journal_transaction t
    WHERE m.accounting_unit_id     = t.accounting_unit_id
    AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
    AND m.cashbook_month           = t.cashbook_month
    AND m.cashbook_year            = t.cashbook_year
    AND m.voucher_no               = t.voucher_no
    AND m.journal_status           ='L'
    AND ( ( t.account_head_code    = 160502
    AND t.CR_DR_INDICATOR          ='CR' )
    OR ( t.account_head_code       = 160502
    AND t.CR_DR_INDICATOR          ='DR' )
    OR ( t.account_head_code       = 780406
    AND t.CR_DR_INDICATOR          ='DR' )
    OR ( t.account_head_code       = 160611
    AND t.CR_DR_INDICATOR          ='CR' )
    OR ( t.account_head_code       = 160611
    AND t.CR_DR_INDICATOR          ='DR' )
    OR ( t.account_head_code       = 780406
    AND t.CR_DR_INDICATOR          ='CR' )
     OR ( t.account_head_code       = 782406
    AND t.CR_DR_INDICATOR          ='DR' )
     OR ( t.account_head_code       = 782406
    AND t.CR_DR_INDICATOR          ='CR' )
    )
    AND to_date(m.cashbook_month
      ||'-'
      || + m.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
      || '-'
      || ($P{from_cashbk_yr}) , 'mm-yyyy')
    AND to_date( ( $P{to_cashbk_mon} )
      ||'-'
      || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
    UNION ALL
    SELECT m.accounting_unit_id ,
      m.accounting_for_office_id ,
      m.cashbook_month,
      m.cashbook_year,
      t.account_head_code,
      t.CR_DR_INDICATOR,
      t.amount
    FROM fas_payment_master m ,
      fas_payment_transaction t
    WHERE m.accounting_unit_id     = t.accounting_unit_id
    AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
    AND m.cashbook_month           = t.cashbook_month
    AND m.cashbook_year            = t.cashbook_year
    AND m.voucher_no               = t.voucher_no
    AND m.payment_status           ='L'
    AND ( ( t.account_head_code    = 160502
    AND t.CR_DR_INDICATOR          ='CR' )
    OR ( t.account_head_code       = 160502
    AND t.CR_DR_INDICATOR          ='DR' )
    OR ( t.account_head_code       = 780406
    AND t.CR_DR_INDICATOR          ='DR' )
    OR ( t.account_head_code       = 160611
    AND t.CR_DR_INDICATOR          ='CR' )
    OR ( t.account_head_code       = 160611
    AND t.CR_DR_INDICATOR          ='DR' )
    OR ( t.account_head_code       = 780406
    AND t.CR_DR_INDICATOR          ='CR' ) 
      OR ( t.account_head_code       = 782406
    AND t.CR_DR_INDICATOR          ='DR' )
     OR ( t.account_head_code       = 782406
    AND t.CR_DR_INDICATOR          ='CR' )
    )
    AND to_date(m.cashbook_month
      ||'-'
      || + m.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
      || '-'
      || ($P{from_cashbk_yr}) , 'mm-yyyy')
    AND to_date( ( $P{to_cashbk_mon} )
      ||'-'
      || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
    UNION ALL
    SELECT m.accounting_unit_id ,
      m.accounting_for_office_id ,
      m.cashbook_month,
      m.cashbook_year,
      t.account_head_code,
      t.CR_DR_INDICATOR,
      t.amount
    FROM fas_receipt_master m ,
      fas_receipt_transaction t
    WHERE m.accounting_unit_id     = t.accounting_unit_id
    AND m.ACCOUNTING_FOR_OFFICE_ID = t.ACCOUNTING_FOR_OFFICE_ID
    AND m.cashbook_month           = t.cashbook_month
    AND m.cashbook_year            = t.cashbook_year
    AND m.receipt_no               = t.receipt_no
    AND m.receipt_status           ='L'
    AND ( ( t.account_head_code    = 160502
    AND t.CR_DR_INDICATOR          ='CR' )
    OR ( t.account_head_code       = 160502
    AND t.CR_DR_INDICATOR          ='DR' )
    OR ( t.account_head_code       = 780406
    AND t.CR_DR_INDICATOR          ='DR' )
    OR ( t.account_head_code       = 160611
    AND t.CR_DR_INDICATOR          ='CR' )
    OR ( t.account_head_code       = 160611
    AND t.CR_DR_INDICATOR          ='DR' )
    OR ( t.account_head_code       = 780406
    AND t.CR_DR_INDICATOR          ='CR' ) 
      OR ( t.account_head_code       = 782406
    AND t.CR_DR_INDICATOR          ='DR' )
     OR ( t.account_head_code       = 782406
    AND t.CR_DR_INDICATOR          ='CR' )
    )
    AND to_date(t.cashbook_month
      ||'-'
      || + t.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{from_cashbk_mon} )
      || '-'
      || ($P{from_cashbk_yr}) , 'mm-yyyy')
    AND to_date( ( $P{to_cashbk_mon} )
      ||'-'
      || ( $P{to_cashbk_yr} ) , 'mm-yyyy')
    ) as pay1
  GROUP BY accounting_unit_id,
    accounting_for_office_id ,
    cashbook_month,
    cashbook_year,
    account_head_code,
    CR_DR_INDICATOR
  ) as pay2
GROUP BY unit_id
ORDER BY unit_id]]></queryString>

	<field name="unit_id" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="AMT_160502CR" class="java.math.BigDecimal"/>
