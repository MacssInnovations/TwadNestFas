<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Works_Expenditure_new_SJV1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="regionid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="regionname" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[-- Work Expenditure Regular SJV 

 
select 

subacheadcode as subaccheadcode,
subacheadcode || '31' as account_head_code1, 
accounting_unit_id,
accounting_unit_name,
accounting_for_office_id,
cashbook_year,
cashbook_month,
sub2_desc , 
sub2_code, 
work_amt1 as w_amt,  
centage_amt1 as c_amt,
(work_amt1 + centage_amt1) as amount,
account_head_desc

from 
(

select 

subacheadcode,
accounting_unit_id,
accounting_unit_name,
accounting_for_office_id,
cashbook_year,
cashbook_month,
sub2_desc , 
sub2_code, 
sum(work_amt1) as work_amt1,  
sum(centage_amt1) as centage_amt1


from 
(


select 
acc,
substr(acc,0,4) as subacheadcode,
accounting_unit_id,
accounting_unit_name,
accounting_for_office_id,
cashbook_year,
cashbook_month,
sub2_desc , 
sub2_code, 
(w_dr_amt - w_cr_amt) as work_amt1  ,  
(c_dr_amt - c_cr_amt) as centage_amt1 

from 
(


select 
acc,
accounting_unit_id,
accounting_unit_name,
accounting_for_office_id,
cashbook_year,
cashbook_month,
ident ,
cr_dr_indicator, 
sub2_desc , 
sub2_code, 

sum(case when ident='W' and cr_dr_indicator='CR' then amount else 0 end ) as w_cr_amt, 
sum(case when ident='W' and cr_dr_indicator='DR' then amount else 0 end ) as w_dr_amt, 
sum(case when ident='C' and cr_dr_indicator='CR' then amount else 0 end ) as c_cr_amt, 
sum(case when ident='C' and cr_dr_indicator='DR' then amount else 0 end ) as c_dr_amt 

from 
( -- 1 




SELECT 
  a.ACCOUNT_HEAD_CODE,
  a.accounting_unit_id,
  b.accounting_unit_name,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.amount,
  a.cr_dr_indicator, 
  'W' AS ident,
  (
   SELECT 
         d.sub_head_desc
   FROM 
       com_mst_account_heads c,
       com_mst_sub_heads d
   WHERE 
       d.sub_head_code = c.sub_head2_code
   AND c.major_head_code = 'L'
   AND c.minor_head_code = 183
   AND c.sub_head1_code = 31
   AND c.account_head_code = a.account_head_code)AS sub2_desc,
   (
   SELECT 
         d.sub_head_code
   FROM 
       com_mst_account_heads c,
       com_mst_sub_heads d
   WHERE 
       d.sub_head_code = c.sub_head2_code
   AND c.major_head_code = 'L'
   AND c.minor_head_code = 183
   AND c.sub_head1_code = 31
   AND c.account_head_code = a.account_head_code)AS sub2_code

FROM 
     fas_journal_transaction a,
     fas_mst_acct_units b
WHERE
     b.accounting_unit_id = a.accounting_unit_id
 AND a.cashbook_year = $P{cashbookyear}
 and a.cashbook_month= $P{cashbookmonth}
 and a.ACCOUNTING_FOR_OFFICE_ID in ( select office_id from COM_MST_ALL_OFFICES_VIEW 
      where region_office_id= $P{regionid} )
 AND 
   a.account_head_code IN
  (SELECT account_head_code
   FROM com_mst_account_heads
   WHERE major_head_code = 'L'
   AND minor_head_code = 183
   AND sub_head1_code = 31
   AND sub_head2_code > 0)

UNION ALL

SELECT 
  a.ACCOUNT_HEAD_CODE,
  a.accounting_unit_id,
  b.accounting_unit_name,
  a.accounting_for_office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.amount,
  a.cr_dr_indicator, 
  'C' ident,
    (SELECT d.sub_head_desc
   FROM com_mst_account_heads c,
     com_mst_sub_heads d
   WHERE d.sub_head_code = c.sub_head2_code
   AND c.major_head_code = 'L'
   AND c.minor_head_code = 183
   AND c.sub_head1_code = 32
   AND c.account_head_code = a.account_head_code) AS sub2_desc,
   
   (SELECT d.sub_head_code
   FROM com_mst_account_heads c,
     com_mst_sub_heads d
   WHERE d.sub_head_code = c.sub_head2_code
   AND c.major_head_code = 'L'
   AND c.minor_head_code = 183
   AND c.sub_head1_code = 32
   AND c.account_head_code = a.account_head_code) AS sub2_code

FROM 
    fas_journal_transaction a,
    FAS_MST_ACCT_UNITS b  
  WHERE
    b.accounting_unit_id = a.accounting_unit_id
 and a.cashbook_year = $P{cashbookyear}
 and a.cashbook_month= $P{cashbookmonth} 
 and a.ACCOUNTING_FOR_OFFICE_ID in ( select office_id from COM_MST_ALL_OFFICES_VIEW 
    where region_office_id= $P{regionid} )
 AND
   a.account_head_code IN
  (SELECT account_head_code
   FROM com_mst_account_heads
   WHERE major_head_code = 'L'
   AND minor_head_code = 183
   AND sub_head1_code = 32
   AND sub_head2_code > 0)

   
) -- 1 
group by 

  acc,
  accounting_unit_id,
  accounting_unit_name,
  accounting_for_office_id,
  cashbook_year,
  cashbook_month,  
  ident,
  sub2_desc , 
  sub2_code, 
  cr_dr_indicator 
)
)

group by 
subacheadcode,
accounting_unit_id,
accounting_unit_name,
accounting_for_office_id,
cashbook_year,
cashbook_month,
sub2_desc , 
sub2_code 


) a

left outer join  
com_mst_account_heads on com_mst_account_heads.ACCOUNT_HEAD_CODE= (subacheadcode || '31') 

order by  sub2_code, account_head_code1, accounting_unit_id]]></queryString>

