<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="RegisterChequeAbstractReport_HO"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="878"
		 pageHeight="595"
		 columnWidth="818"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT *
FROM
  (SELECT a.voucher_no,
    a.payment_date,
    a.bank_id,
    a.branch_id,
	(b.account_head_code ||'-' || g.account_head_desc) AS Acc_details ,
    a.paid_to AS amt_paid_to,
    b.CHEQUE_DD_NO,
    b.CHEQUE_DD_DATE,     
    b.amount,
    b.particulars,
    c.accounting_unit_name,
    d.office_short_name,
    e.branch_name,
    f.BANK_NAME,
    e.micr_code
  FROM fas_payment_master a,
    fas_payment_transaction b,
    fas_mst_acct_units c,
    com_mst_offices d,
    fas_mst_bank_branches e,
    com_mst_account_heads g,
    fas_mst_banks f    
  WHERE a.cashbook_month        =b.cashbook_month
  AND a.cashbook_year           =b.cashbook_year
  AND a.accounting_unit_id      =b.accounting_unit_id
  AND a.accounting_for_office_id=b.accounting_for_office_id
  AND a.voucher_no              =b.voucher_no
  AND c.accounting_unit_id      =a.accounting_unit_id
  AND d.office_id               =a.accounting_for_office_id
  AND b.account_head_code       =g.account_head_code
  AND e.bank_id                 =a.bank_id
  AND e.branch_id               =a.branch_id
  AND f.bank_id                 =e.bank_id
  AND a.payment_status         <>'C'
  AND a.payment_type            ='B'
  AND a.cashbook_year           =($P{cashbookyear})
  AND a.cashbook_month          =($P{cashbookmonth})
  AND a.accounting_unit_id      =($P{accountingunitid})
  AND a.accounting_for_office_id=($P{accountofficeid})
  UNION ALL
  SELECT a.voucher_no,
    a.date_of_transfer AS payment_date,
    a.from_bank_id     AS bank_id,
    a.from_branch_id   AS branch_id,
	(a.dr_account_head_code
    ||'-'
    || g.account_head_desc) AS Acc_details ,
    ' '                AS amt_paid_to,    
    a.CHEQUE_DD_NO,
    a.CHEQUE_DD_DATE,
    a.total_amount AS amount,
    a.particulars,
    c.accounting_unit_name,
    d.office_short_name,
    e.branch_name,
    f.BANK_NAME,
    e.micr_code
  FROM fas_inter_bank_trf_at_ho a,
    fas_mst_acct_units c,
    com_mst_offices d,
    fas_mst_bank_branches e,
    com_mst_account_heads g,
    fas_mst_banks f
  WHERE c.accounting_unit_id    =a.accounting_unit_id
  AND d.office_id               =a.accounting_for_office_id
  AND e.bank_id                 =a.from_bank_id
  AND e.branch_id               =a.from_branch_id
  AND f.bank_id                 =e.bank_id
  AND a.dr_account_head_code    =g.account_head_code
  AND a.transfer_status        <>'C'
  AND a.cashbook_year           =($P{cashbookyear})
  AND a.cashbook_month          =($P{cashbookmonth})
  AND a.accounting_unit_id      =($P{accountingunitid})
  AND a.accounting_for_office_id=($P{accountofficeid})
  UNION ALL
  SELECT a.receipt_no AS voucher_no,
    a.receipt_date    AS payment_date,
    a.bank_id         AS bank_id,
    a.branch_id,    
    (b.account_head_code
    ||'-'
    || g.account_head_desc) AS Acc_details ,
	' ' AS amt_paid_to,
    b.CHEQUE_DD_NO,
    b.CHEQUE_DD_DATE,
    b.amount,
    b.particulars,
    c.accounting_unit_name,
    d.office_short_name,
    e.branch_name,
    f.BANK_NAME,
    e.micr_code
  FROM fas_receipt_master a,
    fas_receipt_transaction b,
    fas_mst_acct_units c,
    com_mst_offices d,
    com_mst_account_heads g,
    fas_mst_bank_branches e,
    fas_mst_banks f
  WHERE a.cashbook_month        =b.cashbook_month
  AND a.cashbook_year           =b.cashbook_year
  AND a.accounting_unit_id      =b.accounting_unit_id
  AND a.accounting_for_office_id=b.accounting_for_office_id
  AND a.receipt_no              =b.receipt_no
  AND c.accounting_unit_id      =a.accounting_unit_id
  AND d.office_id               =a.accounting_for_office_id
  AND e.bank_id                 =a.bank_id
  AND e.branch_id               =a.branch_id
  AND f.bank_id                 =e.bank_id
  AND b.account_head_code        = g.account_head_code
  AND a.receipt_status         <>'C'
  AND a.created_by_module       ='SC'
  AND a.cashbook_year           =($P{cashbookyear})
  AND a.cashbook_month          =($P{cashbookmonth})
  AND a.accounting_unit_id      =($P{accountingunitid})
  AND a.accounting_for_office_id=($P{accountofficeid})
  UNION ALL
  SELECT a.VOUCHER_NO ,
    a.DATE_OF_TRANSFER AS payment_date,
    a.HO_BANK_ID       AS bank_id ,
    a.HO_BRANCH_ID     AS branch_id ,
    (b.account_head_code
    ||'-'
    || g.account_head_desc) AS Acc_details ,
    d1.office_short_name    AS amt_paid_to ,
    b.CHEQUE_DD_NO,
    b.CHEQUE_DD_DATE ,
    b.AMOUNT ,
    b.PARTICULARS ,
    c.accounting_unit_name,
    d.office_short_name,
    e.branch_name,
    f.BANK_NAME,
    e.micr_code
  FROM FAS_FUND_TRF_FROM_HO_MASTER a,
    FAS_FUND_TRF_FROM_HO_TRN b ,
    fas_mst_acct_units c,
    com_mst_offices d,
    com_mst_offices d1,
    com_mst_account_heads g,
    fas_mst_bank_branches e,
    fas_mst_banks f
  WHERE a.cashbook_month         = b.cashbook_month
  AND a.cashbook_year            = b.cashbook_year
  AND a.accounting_unit_id       = b.accounting_unit_id
  AND a.accounting_for_office_id = b.accounting_for_office_id
  AND a.voucher_no               = b.voucher_no
  AND c.accounting_unit_id       = a.accounting_unit_id
  AND d.office_id                = a.accounting_for_office_id
  AND d1.office_id               = b.TRANSFER_TO_OFFICE_ID
  AND e.bank_id                  = a.HO_BANK_ID
  AND e.branch_id                = a.HO_BRANCH_ID
  AND f.bank_id                  = e.bank_id
  AND b.account_head_code        = g.account_head_code
  AND a.TRANSFER_STATUS         <>'C'
  AND a.cashbook_year            =($P{cashbookyear})
  AND a.cashbook_month           =($P{cashbookmonth})
  AND a.accounting_unit_id       =($P{accountingunitid})
  AND a.accounting_for_office_id =($P{accountofficeid})
  )
ORDER BY bank_id,
  payment_date,
  voucher_no]]></queryString>

	<field name="VOUCHER_NO" class="java.math.BigDecimal"/>
	<field name="PAYMENT_DATE" class="java.sql.Timestamp"/>
	<field name="BANK_ID" class="java.math.BigDecimal"/>
