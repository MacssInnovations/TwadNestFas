	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="OFFICE_SHORT_NAME" class="java.lang.String"/>
	<field name="BRANCH_NAME" class="java.lang.String"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="MICR_CODE" class="java.math.BigDecimal"/>

	<variable name="SUM_AMOUNT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="SUM_AMOUNT_2" class="java.math.BigDecimal" resetType="Group" resetGroup="VOUCHER" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="sumamount" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="counting" class="java.lang.Integer" resetType="None" calculation="DistinctCount">
		<variableExpression><![CDATA[$F{CHEQUE_DD_NO}]]></variableExpression>
	</variable>
	<variable name="sub_total" class="java.math.BigDecimal" resetType="Group" resetGroup="CHEQUE" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>

