	<variable name="SUM_CURR_NET_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CURR_NET}]]></variableExpression>
	</variable>
	<variable name="SUM_YEAR_NET_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{YEAR_NET_REGSJV1}]]></variableExpression>
	</variable>
