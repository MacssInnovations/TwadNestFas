<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPF_Abstract_Headoffice_sjv"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="849"
		 pageHeight="842"
		 columnWidth="789"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cb_mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cb_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month_value" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql1" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sql2" isForPrompting="true" class="java.lang.String"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sup_no" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="f_yr" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="t_yr" isForPrompting="false" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT distinct year_account_head_code,
 year_account_head_code1,
  account_head_des,
  prtgrp,
  year_dr_sjv,
  year_cr_sjv,
  year_dr_reg,
  year_cr_reg,
  total_dr,
  total_cr,
  year_net_disp_regsjv1,
  year_net_regsjv1,
  current_month_debit,
  current_month_credit,
  curr_net_disp,
  curr_net,
  month_closure_stat
FROM
  ( SELECT year_account_head_code,year_account_head_code1,
    (SELECT account_head_desc
    FROM com_mst_account_heads
    WHERE account_head_code = year_account_head_code
    )                  As Account_Head_Des,
    ( $P!{sql1} )       AS prtgrp,
    --year_dr            AS year_dr_sjv,
   -- year_cr            AS year_cr_sjv,
   -- year_dr1           AS year_dr_reg,
   -- year_cr1           AS year_cr_reg,
   decode (year_dr,Null,0,year_dr) AS year_dr_sjv,
    decode (year_cr,Null,0,year_cr)  AS year_cr_sjv,
    decode (year_dr1,Null,0,year_dr1) AS year_dr_reg,
     decode (year_cr1,Null,0,year_cr1) AS year_cr_reg,
    (year_dr+year_dr1) AS total_dr1,
    (year_cr+year_cr1) AS total_cr1,
    NVL(year_dr,0)     AS year_dr,
    NVL(year_cr,0)     AS year_cr,
    CASE
      WHEN ( year_dr     - year_cr ) > 0
      THEN NVL(( year_dr - year_cr ),0)
        || ' Dr'
      ELSE NVL(( year_cr - year_dr ),0)
        || ' Cr'
    END                          AS year_net_disp,
    NVL(( year_cr - year_dr ),0) AS year_net,
    NVL((year_dr  +year_dr1),0)  AS total_dr,
    NVL((year_cr  +year_cr1),0)  AS total_cr,
    CASE
      WHEN ( (year_dr    +year_dr1) - (year_cr+year_cr1) ) > 0
      THEN NVL(( (year_dr+year_dr1) - (year_cr+year_cr1) ),0)
        || ' Dr'
      ELSE NVL(( (year_cr+year_cr1) - (year_dr+year_dr1) ),0)
        || ' Cr'
    END                                                AS year_net_disp_regsjv1,
    NVL(( (year_cr+year_cr1) - (year_dr+year_dr1) ),0) AS year_net_regsjv1,
    NVL(current_month_debit,0)                         AS current_month_debit,
    NVL(current_month_credit,0)                        AS current_month_credit,
    CASE
      WHEN ( current_month_debit     - current_month_credit ) > 0
      THEN NVL(( current_month_debit - current_month_credit ),0)
        || ' Dr'
      ELSE NVL(( current_month_credit - current_month_debit ),0)
        || ' Cr'
    END                                                   AS curr_net_disp,
    NVL(( current_month_credit - current_month_debit ),0) AS curr_net
  FROM
    (SELECT   year_account_head_code1,
    decode (year_dr,NULL,0,year_dr)as year_dr,
    decode (year_cr,NULL,0,year_cr)as year_cr, 
    account_head_code,
    decode (current_month_debit,NULL,0,current_month_debit)as current_month_debit, 
    decode (current_month_credit,NULL,0,current_month_credit)as current_month_credit, 
    year_account_head_code,
    year_dr1,
    year_cr1
    FROM
      (SELECT account_head_code   AS year_account_head_code1,
        SUM(current_month_debit)  AS year_dr,
        SUM(current_month_credit) AS year_cr
      FROM FAS_TRIAL_BALANCE_SJV_CMP
      WHERE to_date(cashbook_month
        ||'-'
        ||  cashbook_year, 'mm-yyyy') BETWEEN
        
           to_date( '04'
            || '-'
            || ($P{f_yr}) , 'mm-yyyy')
         
      AND to_date ($P{cb_mon}
        ||'-'
        || $P{t_yr} , 'mm-yyyy')
      
      AND account_head_code IN ( select account_head_code from fas_mst_sections_groups_heads where section_id=16  )
      AND SUPPLEMENT_NO     <=$P{sup_no}
      GROUP BY account_head_code
      )a
      --added on 21Mar2012  left to right 12Nov13
    right OUTER JOIN
      (SELECT account_head_code   AS year_account_head_code,
        SUM(current_month_debit)  AS year_dr1,
        SUM(CURRENT_MONTH_CREDIT) AS YEAR_CR1
      FROM FAS_TRIAL_BALANCE_SJV_CMP
      WHERE to_date(cashbook_month
        ||'-'
        ||  cashbook_year, 'mm-yyyy') BETWEEN
        
           to_date( '04'
            || '-'
            || ($P{f_yr}) , 'mm-yyyy')
         
      AND to_date ( $P{cb_mon}
        ||'-'
        || $P{t_yr} , 'mm-yyyy')
      
      AND account_head_code IN ( $P!{sql2}  )
      GROUP BY account_head_code
      )c
    ON a.year_account_head_code1 = c.year_account_head_code
    LEFT OUTER JOIN
      (SELECT account_head_code,
        SUM(current_month_debit)  AS current_month_debit,
        SUM(current_month_credit) AS current_month_credit
      FROM FAS_TRIAL_BALANCE_SJV_CMP
      WHERE account_head_code IN ( $P!{sql2}  )
      
      AND cashbook_month = $P{cb_mon}
      AND cashbook_year  = $P{cb_year}
      AND SUPPLEMENT_NO  =$P{sup_no}
      Group By Account_Head_Code
     )B
    ON a.year_account_head_code1 = b.account_head_code
    
    

    Left Outer Join
    (
      
      
      SELECT account_head_code,
        SUM(current_month_debit)  AS current_month_debit,
        SUM(CURRENT_MONTH_CREDIT) AS CURRENT_MONTH_CREDIT
      FROM FAS_TRIAL_BALANCE_SJV_CMP
      WHERE account_head_code IN ( $P!{sql2}  )
      
      AND cashbook_month = $P{cb_mon}
      AND cashbook_year  = $P{cb_year}
   
      Group By Account_Head_Code
      
    )Bb
 
      On C.Year_Account_Head_Code = Bb.Account_Head_Code
     
    
    
    )
  ),
  (SELECT
    CASE
      WHEN (SELECT tb_status
        FROM fas_tb_closure
        WHERE cashbook_year=$P{cb_year}
        AND cashbook_month = $P{cb_mon}
        AND tb_status      ='Y' ) = 'Y'
      THEN ''
      ELSE 'TENTATIVE FIGURES'
    END AS month_closure_stat
  FROM dual
  )
ORDER BY prtgrp,
  year_account_head_code]]></queryString>

	<field name="YEAR_ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="YEAR_ACCOUNT_HEAD_CODE1" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_DES" class="java.lang.String"/>
