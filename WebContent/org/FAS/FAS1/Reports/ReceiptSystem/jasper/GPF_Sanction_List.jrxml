<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPF_Sanction_List"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="765"
		 pageHeight="842"
		 columnWidth="705"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="office_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="monthinWords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT master_san.HRMS_SANCTION_ID,
  master_san.BILL_MAJOR_TYPE_CODE,
  (SELECT BILL_MAJOR_TYPE_DESC
  FROM FAS_BILL_MAJOR_TYPES
  WHERE BILL_MAJOR_TYPE_CODE=master_san.BILL_MAJOR_TYPE_CODE
  )AS major_desc,
  master_san.BILL_MINOR_TYPE_CODE,
  (SELECT BILL_MINOR_TYPE_DESC
  FROM FAS_BILL_MINOR_TYPES_MST
  WHERE BILL_MAJOR_TYPE_CODE=master_san.BILL_MAJOR_TYPE_CODE
  AND BILL_MINOR_TYPE_CODE  =master_san.BILL_MINOR_TYPE_CODE
  )AS minor_desc,
  master_san.BILL_SUB_TYPE_CODE,
   (SELECT BILL_SUB_TYPE_DESC
  FROM FAS_BILL_SUB_TYPES
  WHERE BILL_MAJOR_TYPE_CODE=master_san.BILL_MAJOR_TYPE_CODE
  AND BILL_MINOR_TYPE_CODE  =master_san.BILL_MINOR_TYPE_CODE
  and BILL_SUB_TYPE_CODE=master_san.BILL_SUB_TYPE_CODE
  )AS sub_desc,
  master_san.EMPLOYEE_ID,
  (select EMPLOYEE_INITIAL||'.'||EMPLOYEE_NAME from HRM_MST_EMPLOYEES where EMPLOYEE_ID= master_san.EMPLOYEE_ID)as emp_name,
  master_san.GPF_NO,
  master_san.DESIGNATION_ID,
  (select DESIGNATION from HRM_MST_DESIGNATIONS where DESIGNATION_ID= master_san.DESIGNATION_ID)as desig,
  master_san.OFFICE_ID,
  (select OFFICE_NAME from COM_MST_OFFICES where OFFICE_ID=master_san.OFFICE_ID)as office_desc,
  master_san.SANCTION_PROC_NO,
  master_san.SANCTION_PROC_DATE,
  master_san.SANCTIONED_AMOUNT,
  master_tran.PAYMENT_HEAD_OF_AC,
  master_tran.PAYMENT_AMOUNT,
  master_tran.REMARKS
  
FROM
  (SELECT HRMS_SANCTION_ID,
    BILL_MAJOR_TYPE_CODE,
    BILL_MINOR_TYPE_CODE,
    BILL_SUB_TYPE_CODE,
    EMPLOYEE_ID,
    GPF_NO,
    DESIGNATION_ID,
    OFFICE_ID,
    SANCTION_PROC_NO,
    SANCTION_PROC_DATE,
    SANCTIONED_AMOUNT
  FROM HRM_SANCTIONS_BILLS_LINK_MST
  WHERE OFFICE_ID=$P{office_id}
  ) master_san
JOIN
  (SELECT HRMS_SANCTION_ID,
    BILL_MAJOR_TYPE_CODE,
    BILL_MINOR_TYPE_CODE,
    BILL_SUB_TYPE_CODE,
    EMPLOYEE_ID,
    GPF_NO,
    DESIGNATION_ID,
    REMARKS,
    PAYMENT_HEAD_OF_AC,
    PAYMENT_AMOUNT,
    OFFICE_ID
  FROM HRM_SANCTIONS_BILLS_LINK_TRN
  WHERE OFFICE_ID=$P{office_id}
  ) master_tran
ON master_san.HRMS_SANCTION_ID       = master_san.HRMS_SANCTION_ID
AND master_san.BILL_MAJOR_TYPE_CODE  = master_san.BILL_MAJOR_TYPE_CODE
AND master_tran.BILL_MINOR_TYPE_CODE = master_san.BILL_MINOR_TYPE_CODE
AND master_tran.BILL_SUB_TYPE_CODE   = master_san.BILL_SUB_TYPE_CODE
AND master_tran.EMPLOYEE_ID          = master_san.EMPLOYEE_ID
AND master_tran.GPF_NO               = master_san.GPF_NO
AND master_tran.designation_id       = master_san.designation_id
AND master_tran.office_id            = master_san.office_id]]></queryString>

