	<parameter name="heading" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select (SELECT Uu.Accounting_Unit_Name
  FROM fas_mst_acct_units uu
  WHERE UU.ACCOUNTING_UNIT_ID=A.ACCOUNTING_UNIT_ID
  )AS ORGUNITNAME,
   A.CASHBOOK_YEAR,
   A.CASHBOOK_MONTH,
   A.VOUCHER_NO,
   A.VOUCHER_DATE,
   B.SL_NO,
    A.JOURNAL_TYPE_CODE,
  (SELECT S.Sub_Ledger_Type_Desc
  FROM com_mst_sl_types s
  WHERE S.SUB_LEDGER_TYPE_CODE=A.JOURNAL_TYPE_CODE
  )AS sl_desc,
    A.Sub_Ledger_Code,
  (SELECT l.SL_CODENAME
  FROM SL_TYPE_CODE_NAME_VIEW_M L
  WHERE L.Sl_Type=b.Sub_Ledger_Type_Code
  AND L.SL_CODE  =A.SUB_LEDGER_CODE
  )AS CODE_DESC,
  B.CHEQUE_DD_NO,
  B.CHEQUE_DD_DATE,
 b.AMOUNT AS ljvamount,
  B.CB_REF_NO,
  B.CB_REF_DATE,
b.PARTICULARS
    
  
  
   FROM FAS_JOURNAL_MASTER A,
   FAS_JOURNAL_TRANSACTION B
   WHERE
   A.Accounting_Unit_Id       =B.Accounting_Unit_Id
AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
AND A.Cashbook_Year           =B.Cashbook_Year
AND A.Cashbook_Month          =B.Cashbook_Month
AND A.VOUCHER_NO              =B.VOUCHER_NO
AND A.ACCOUNTING_UNIT_ID      =$P{unitid}
AND a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
AND A.CASHBOOK_MONTH          =$P{cashbookmonth}
AND A.CASHBOOK_YEAR           =$P{cashbookyear}
AND A.CB_REF_TYPE='P'
AND A.JOURNAL_STATUS='L'
AND B.CB_REF_NO !=0]]></queryString>

	<field name="ORGUNITNAME" class="java.lang.String"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="VOUCHER_NO" class="java.math.BigDecimal"/>
