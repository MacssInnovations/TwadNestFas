	<parameter name="letNo" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select accounting_unit_name, office_id,ref_no,ref_date,remarks,office_name,trnrefno,trnrefdate,HO_REF_NO,HO_REF_DATE,
REASON,office_address1,bank_name,office_address2,city_town_name,AMOUNT,trnofficeid,
fund_type,cheque_dd_no,cheque_dd_date,cheque_amount,FUND_REQUESTED from
(
select * from
(
select x1.cheque_amount,x1.accounting_unit_id,x1.office_id as offid,x1.ref_no,x1.ref_date,x1.remarks,z1.AMOUNT,x1.HO_BANK_ID,y1.bank_name,z1.FUND_REQUESTED,z1.HO_REF_NO,z1.HO_REF_DATE,z1.REASON,
z1.ref_no as trnrefno,z1.ref_date as trnrefdate,z1.fund_type,z1.cheque_dd_no,z1.cheque_dd_date,z1.office_id as trnofficeid from fund_allotment_master x1, fas_bank_list y1,fund_allotment_transaction z1
where x1.ho_bank_id=y1.bank_id and x1.accounting_unit_id=z1.accounting_unit_id and x1.cashbook_year=z1.cashbook_year
and x1.cashbook_month=z1.cashbook_month and x1.voucher_no=z1.voucher_no
)x
left outer join
(
select accounting_unit_id as accunitid,accounting_unit_name from fas_mst_acct_units
)y
on x.accounting_unit_id=y.accunitid
)a
left outer join 
(
select office_id,office_name,office_address1,office_address2,city_town_name,Office_pin_code
from com_mst_offices 
)b
on b.office_id=a.trnofficeid 

where trnrefno= '$P!{letNo}'  and fund_type='C'
)xy
left outer join
(
select a.employee_name as ename,a.employee_id as eid from HRM_MST_EMPLOYEES a,HRM_EMP_CURRENT_POSTING b where a.employee_id=b.employee_id
and b.designation_id=2 and b.office_id=5000

) z
on 1=1]]></queryString>

