	<parameter name="letNo" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select accounting_unit_name, office_id,ref_no,ref_date,remarks,office_name,trnrefno,
office_address1,bank_name,office_address2,city_town_name,designation,AMOUNT,trnofficeid,
fund_type,cheque_dd_no,cheque_dd_date from
(
select * from
(
select x1.accounting_unit_id,x1.office_id as offid,x1.ref_no,x1.ref_date,x1.remarks,z1.AMOUNT,x1.HO_BANK_ID,y1.bank_name,
z1.ref_no as trnrefno,z1.fund_type,z1.cheque_dd_no,z1.cheque_dd_date,z1.office_id as trnofficeid from fas_fund_allotment_master x1, fas_bank_list y1,fas_fund_allotment_transaction z1
where x1.ho_bank_id=y1.bank_id and x1.accounting_unit_id=z1.accounting_unit_id and x1.cashbook_year=z1.cashbook_year
and x1.cashbook_month=z1.cashbook_month
)x
left outer join
(
select accounting_unit_id as accunitid,accounting_unit_name from fas_mst_acct_units
)y
on x.accounting_unit_id=y.accunitid
)a
left outer join 
(
select office_id,office_name,office_address1,office_address2,city_town_name,Office_pin_code
from com_mst_offices 
)b
on b.office_id=a.trnofficeid 
left outer join
(
select * from
(
select designation_id,office_id as offid1,employee_id from HR_MST_EMP_CURRENT_POSTING
) c
left join 
(
select designation_id as desigid,designation from hrm_mst_designations 
)d
on d.desigid= c.designation_id
)e
on e.offid1=a.offid
)
where trnrefno in ($P!{letNo})]]></queryString>

