	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select
     accUnit.ACCOUNTING_UNIT_NAME , 
     Office.OFFICE_NAME ,  
     a.ACCOUNTING_UNIT_ID , 
     to_char(a.CHEQUE_DD_DATE,'DD/MM/YYYY') AS cheque_date , 
     a.ACCOUNTING_FOR_OFFICE_ID ,
     a.CHEQUE_DD_NO , 
     a.TOTAL_AMOUNT ,
     b.RECEIPT_NO , 
     to_char(b.RECEIPT_DATE,'DD/MM/YYYY') AS receipt_date  
from  
    FAS_FUND_TRF_FROM_OFFICE  a , 
    FAS_FUND_RECEIPT_BY_HO    b ,
    COM_MST_OFFICES           Office , 
    FAS_MST_ACCT_UNITS        accUnit
where 
 accUnit.ACCOUNTING_UNIT_ID = $P{acc_unit_id}   and
 Office.OFFICE_ID           = $P{off_id}        and 
 a.ACCOUNTING_UNIT_ID       = $P{acc_unit_id}   and   
 a.ACCOUNTING_FOR_OFFICE_ID = $P{off_id}        and 
 a.CASHBOOK_YEAR            = $P{yr}            and 
 a.CASHBOOK_MONTH           = $P{mon}           and 
 a.ACCOUNTING_FOR_OFFICE_ID = b.RECEIVED_FROM_OFFICE_ID and 
 a.CASHBOOK_YEAR            = b.CASHBOOK_YEAR   and 
 a.CASHBOOK_MONTH           = b.CASHBOOK_MONTH  and 
 a.CHEQUE_DD_NO             = b.CHEQUE_DD_NO    and
 a.TOTAL_AMOUNT             = b.TOTAL_AMOUNT    and 
 a.CHEQUE_DD_DATE           = b.CHEQUE_DD_DATE]]></queryString>

