	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 
   accUnit.ACCOUNTING_UNIT_NAME , 
   off_id.OFFICE_NAME ,  
   hotrn.CHEQUE_DD_NO  ,
   to_char(hotrn.CHEQUE_DD_DATE,'DD/MM/YYYY') AS cheque_date  ,
   hotrn.AMOUNT    , 
   office.RECEIPT_NO  ,
   to_char(office.RECEIPT_DATE,'DD/MM/YYYY') AS receipt_date 
from 
   FAS_FUND_TRF_FROM_HO_MASTER  homas ,
   FAS_FUND_TRF_FROM_HO_TRN     hotrn ,
   FAS_FUND_RECEIPT_BY_OFFICE   office , 
   COM_MST_OFFICES              off_id , 
   FAS_MST_ACCT_UNITS           accUnit
where 
   accUnit.ACCOUNTING_UNIT_ID     = $P{acc_unit_id}   and
   off_id.OFFICE_ID               = $P{off_id}        and 
   homas.ACCOUNTING_UNIT_ID       = $P{acc_unit_id}   and   
   homas.ACCOUNTING_FOR_OFFICE_ID = $P{off_id}        and 
   homas.CASHBOOK_YEAR            = $P{yr}            and 
   homas.CASHBOOK_MONTH           = $P{mon}           and 

   homas.ACCOUNTING_UNIT_ID       =  hotrn.ACCOUNTING_UNIT_ID       and 
   homas.ACCOUNTING_FOR_OFFICE_ID =  hotrn.ACCOUNTING_FOR_OFFICE_ID and 
   homas.CASHBOOK_YEAR            =  hotrn.CASHBOOK_YEAR            and 
   homas.CASHBOOK_MONTH           =  hotrn.CASHBOOK_MONTH           and 
   homas.VOUCHER_NO               =  hotrn.VOUCHER_NO               and 
   homas.TRANSFER_STATUS          <> 'C'                            and 

   hotrn.TRANSFER_TO_OFFICE_ID    =  office.ACCOUNTING_FOR_OFFICE_ID and 
   hotrn.CASHBOOK_YEAR            =  office.CASHBOOK_YEAR            and 
   hotrn.CASHBOOK_MONTH           =  office.CASHBOOK_MONTH           and
   hotrn.CHEQUE_DD_NO             =  office.CHEQUE_DD_NO             and
   hotrn.CHEQUE_DD_DATE           =  office.CHEQUE_DD_DATE           and  
   hotrn.AMOUNT                   =  office.TOTAL_AMOUNT]]></queryString>

	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
