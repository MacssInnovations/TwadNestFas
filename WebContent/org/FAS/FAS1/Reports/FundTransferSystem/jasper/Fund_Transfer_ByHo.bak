	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="vouNO" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select  accUint.ACCOUNTING_UNIT_NAME,
        Office.OFFICE_NAME as main_office,
        Office_2.OFFICE_NAME ||' '|| (select ACCOUNTING_UNIT_NAME from FAS_MST_ACCT_UNITS where ACCOUNTING_UNIT_ID=FTrs.TRANSFERED_TO_HO_UNIT_ID ) as sub_office,
        Office.CITY_TOWN_NAME ,        
        to_char(FMas.DATE_OF_TRANSFER,'DD/MM/YYYY') as DATEOFTRANSFER,
        FMas.VOUCHER_NO,
        FMas.TOTAL_AMOUNT as TOT_AMT_NO,
	FTrs.AMOUNT as TRNS_AMOUNT, FTrs.PARTICULARS,
        numtochar(FMas.TOTAL_AMOUNT) as TOT_AMT_CHAR  
        from FAS_FUND_TRF_FROM_HO_MASTER FMas,COM_MST_OFFICES Office,COM_MST_OFFICES Office_2,
        FAS_MST_ACCT_UNITS accUint,FAS_FUND_TRF_FROM_HO_TRN FTrs ,
        COM_MST_ACCOUNT_HEADS acchead where 
        FMas.ACCOUNTING_UNIT_ID=FTrs.ACCOUNTING_UNIT_ID and 
        FMas.ACCOUNTING_FOR_OFFICE_ID=FTrs.ACCOUNTING_FOR_OFFICE_ID and 
        FMas.CASHBOOK_YEAR=FTrs.CASHBOOK_YEAR and
        FMas.CASHBOOK_MONTH=FTrs.CASHBOOK_MONTH and 
        FMas.VOUCHER_NO=FTrs.VOUCHER_NO and
        FTrs.ACCOUNT_HEAD_CODE=acchead.ACCOUNT_HEAD_CODE and
        FMas.ACCOUNTING_UNIT_ID=accUint.ACCOUNTING_UNIT_ID and
        FMas.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID and 
        FTrs.TRANSFER_TO_OFFICE_ID=Office_2.OFFICE_ID and 
	FMas.ACCOUNTING_UNIT_ID=$P{acc_unit_id}  and FMas.ACCOUNTING_FOR_OFFICE_ID=$P{off_id} and
	FMas.CASHBOOK_YEAR=$P{yr} and FMas.CASHBOOK_MONTH=$P{mon} and FMas.VOUCHER_NO=$P{vouNO}]]></queryString>

