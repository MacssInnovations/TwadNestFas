<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="imporTemp_statement"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="793"
		 pageHeight="842"
		 columnWidth="733"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Advance_Type" isForPrompting="true" class="java.lang.String"/>
	<parameter name="UnitName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supplement_no" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select
          a.ACCOUNTING_UNIT_ID, 
          a.ACCOUNTING_FOR_OFFICE_ID,
          a.CASHBOOK_YEAR, 
          a.SUB_LEDGER_CODE,
          a.PAYMENT_DATE,
          a.VOUCHER_NO,
          a.REMARKS,
          SL_NO,
          AMT_SANCTIONED, 
          AMT_SPENT,
          AMT_SANCTIONED- case when (AMT_SPENT=null) then 0 else AMT_SPENT end  as outstandingAmt,
		
          c.ENAME
          
        from
      (
        select distinct
              mst.ACCOUNTING_UNIT_ID,
              mst.ACCOUNTING_FOR_OFFICE_ID,
              mst.CASHBOOK_YEAR,
              mst.CASHBOOK_MONTH,
              mst.PAYMENT_DATE,
              mst.VOUCHER_NO,
              mst.REMARKS,
              trn.SUB_LEDGER_CODE,
              trn.SL_NO,
              sum(trn.AMOUNT) as AMT_SANCTIONED
          from
              FAS_PAYMENT_MASTER mst,
              FAS_PAYMENT_TRANSACTION trn
          where
              mst.ACCOUNTING_UNIT_ID=trn.ACCOUNTING_UNIT_ID and
              mst.ACCOUNTING_FOR_OFFICE_ID=trn.ACCOUNTING_FOR_OFFICE_ID and
              mst.CASHBOOK_YEAR=trn.CASHBOOK_YEAR and
              mst.CASHBOOK_MONTH=trn.CASHBOOK_MONTH and
              mst.VOUCHER_NO=trn.VOUCHER_NO and
              mst.PAYMENT_STATUS!='C' and
              (mst.MODE_OF_CREATION=$P{Advance_Type} or mst.MODE_OF_CREATION='IT') and
              mst.ACCOUNTING_UNIT_ID=$P{accountingunitid} and
              mst.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} and
              mst.CASHBOOK_MONTH=$P{cashbookmonth} and 
              mst.CASHBOOK_YEAR=$P{cashbookyear}
             
          group by mst.ACCOUNTING_UNIT_ID, mst.ACCOUNTING_FOR_OFFICE_ID, mst.CASHBOOK_YEAR, mst.CASHBOOK_MONTH, mst.PAYMENT_DATE, mst.VOUCHER_NO, mst.REMARKS, trn.SUB_LEDGER_CODE, trn.SL_NO
)a
left outer join
(
select distinct mst.ACCOUNTING_UNIT_ID,
              mst.ACCOUNTING_FOR_OFFICE_ID,          
              trn.SUB_LEDGER_CODE,
              trn.CB_REF_NO,
              trn.CB_REF_DATE,
              sum(trn.AMOUNT) as AMT_SPENT
          from
              FAS_JOURNAL_MASTER mst,
              FAS_JOURNAL_TRANSACTION trn
          where
              mst.ACCOUNTING_UNIT_ID=trn.ACCOUNTING_UNIT_ID and
              mst.ACCOUNTING_FOR_OFFICE_ID=trn.ACCOUNTING_FOR_OFFICE_ID and
              mst.CASHBOOK_YEAR=trn.CASHBOOK_YEAR and
              mst.CASHBOOK_MONTH=trn.CASHBOOK_MONTH and
              mst.VOUCHER_NO=trn.VOUCHER_NO and
              mst.JOURNAL_STATUS!='C' and
              (mst.MODE_OF_CREATION=$P{Advance_Type} or mst.MODE_OF_CREATION='IT') and
              trn.CR_DR_INDICATOR='DR'
		$P!{supplement_no}
          group by
              mst.ACCOUNTING_UNIT_ID,
              mst.ACCOUNTING_FOR_OFFICE_ID,           
              trn.SUB_LEDGER_CODE,
              trn.CB_REF_NO,
              trn.CB_REF_DATE
)b
on a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID and
         a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID and
         to_char(a.PAYMENT_DATE,'dd-mm-yy')=to_char(b.CB_REF_DATE,'dd-mm-yy') and
         a.VOUCHER_NO=b.CB_REF_NO and a.SUB_LEDGER_CODE=b.SUB_LEDGER_CODE
 left outer join        
( select
              emp.EMPLOYEE_ID,
              emp.EMPLOYEE_NAME||'.'||emp.EMPLOYEE_INITIAL||'-'|| design.DESIGNATION as ENAME,
              post.EMPLOYEE_STATUS_ID
         from HRM_MST_EMPLOYEES emp,
              HRM_EMP_CURRENT_POSTING post,
              HRM_MST_DESIGNATIONS design
         where
              post.DESIGNATION_ID=design.DESIGNATION_ID  and
              emp.EMPLOYEE_ID=post.EMPLOYEE_ID and
              post.EMPLOYEE_STATUS_ID in('WKG','DPN')
)c
on a.SUB_LEDGER_CODE=c.EMPLOYEE_ID]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CASHBOOK_YEAR" class="java.math.BigDecimal"/>
