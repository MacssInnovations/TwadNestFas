	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Advance_Type" isForPrompting="true" class="java.lang.String"/>
	<parameter name="UnitName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="Mode" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT pay_mst.VOUCHER_NO,
  pay_mst.ACCOUNT_HEAD_CODE ||' & '||
  com_mst.account_head_desc as headDesc,
  pay_mst.PAYMENT_TYPE,
  pay_trn.SUB_LEDGER_TYPE_CODE,
 (select SUB_LEDGER_TYPE_DESC from COM_MST_SL_TYPES cc 
   where  pay_trn.SUB_LEDGER_TYPE_CODE=cc.SUB_LEDGER_TYPE_CODE) typeDesc,
 pay_trn.SUB_LEDGER_CODE,
 (select SL_CODENAME from SL_TYPE_CODE_NAME_VIEW_M sl_view 
 where pay_trn.SUB_LEDGER_TYPE_CODE=sl_view.SL_TYPE and 
 pay_trn.SUB_LEDGER_CODE=sl_view.SL_CODE) codeDesc,
  pay_mst.CR_DR_INDICATOR,
  pay_mst.TOTAL_TRN_RECORDS,
  pay_mst.TOTAL_AMOUNT,
  pay_mst.MODE_OF_CREATION,
  pay_mst.CREATED_BY_MODULE,
  pay_trn.CHEQUE_OR_DD,
  pay_trn.CHEQUE_DD_NO,
  pay_trn.CHEQUE_DD_DATE,
  pay_trn.WD_PURPOSE_ID,
  (select WD_PURPOSE_DESC from FAS_WD_PURPOSE_MST pur_id where 
  pay_trn.WD_PURPOSE_ID=pur_id.WD_PURPOSE_ID)purposeDesc
  
FROM FAS_PAYMENT_MASTER pay_mst,FAS_PAYMENT_TRANSACTION pay_trn,
com_mst_account_heads com_mst

WHERE pay_mst.ACCOUNTING_UNIT_ID    = pay_trn.ACCOUNTING_UNIT_ID
and pay_mst.ACCOUNTING_FOR_OFFICE_ID    = pay_trn.ACCOUNTING_FOR_OFFICE_ID
and pay_mst.cashbook_year    = pay_trn.cashbook_year
and pay_mst.cashbook_month    = pay_trn.cashbook_month
and pay_mst.VOUCHER_NO    = pay_trn.VOUCHER_NO
and pay_mst.ACCOUNT_HEAD_CODE    = com_mst.ACCOUNT_HEAD_CODE

and pay_mst.ACCOUNTING_UNIT_ID    =$P{accountingunitid}
AND pay_mst.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
AND pay_mst.cashbook_year           =$P{cashbookyear}
AND pay_mst.cashbook_month          =$P{cashbookmonth}
and pay_mst.created_by_module=$P{Advance_Type}
ORDER BY VOUCHER_NO]]></queryString>

