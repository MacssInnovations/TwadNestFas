<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Imprest_Register_Rep"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1016"
		 pageHeight="842"
		 columnWidth="968"
		 columnSpacing="0"
		 leftMargin="28"
		 rightMargin="20"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Advance_Type" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select aaa.ACCOUNTING_UNIT_ID,aaa.ACCOUNTING_FOR_OFFICE_ID,aaa.SUB_LEDGER_CODE,
       aaa.CASHBOOK_YEAR,aaa.PAYMENT_DATE,aaa.VOUCHER_NO,aaa.SL_NO,aaa.AMT_SANCTIONED,
       aaa.AMT_SPENT,bbb.journal_vou_no,bbb.journal_vou_dt,bbb.journal_vou_amt,
       aaa.AMT_REMITTES,aaa.RECEIPT_DATE,aaa.BALANCE,aaa.fin_res,
       CASE
when aaa.fin_res='Pending' then aaa.Balance
else 0
end as tot_bal,   
aaa.ORIGINATING_UNIT,
       aaa.ENAME
from
( select
          a.ACCOUNTING_UNIT_ID, 
          a.ACCOUNTING_FOR_OFFICE_ID,
          a.CASHBOOK_YEAR, 
          a.SUB_LEDGER_CODE,
          a.PAYMENT_DATE,
          a.VOUCHER_NO,
          SL_NO,
          AMT_SANCTIONED, 
          AMT_SPENT,
          AMT_RECEIPT as AMT_REMITTES,
          C.RECEIPT_DATE,
          AMT_SANCTIONED-(decode(AMT_SPENT,null,0,AMT_SPENT)+decode(AMT_RECEIPT,null,0,AMT_RECEIPT)) as BALANCE,
          case when(AMT_SANCTIONED-(decode(AMT_SPENT,null,0,AMT_SPENT)+decode(AMT_RECEIPT,null,0,AMT_RECEIPT)) > 0 ) then 'Pending' else 'Cleared' end as fin_res,
          d.ACCOUNTING_UNIT_NAME as ORIGINATING_UNIT,
          e.ENAME
        from
      (
        select distinct
              mst.ACCOUNTING_UNIT_ID,
              mst.ACCOUNTING_FOR_OFFICE_ID,
              mst.CASHBOOK_YEAR,
              mst.CASHBOOK_MONTH,
              mst.PAYMENT_DATE,
              mst.VOUCHER_NO,
              trn.SUB_LEDGER_CODE,
              trn.SL_NO,
              sum(trn.AMOUNT) as AMT_SANCTIONED
          from
              FAS_PAYMENT_MASTER mst,
              FAS_PAYMENT_TRANSACTION trn
          where
              mst.ACCOUNTING_UNIT_ID=trn.ACCOUNTING_UNIT_ID and
              mst.ACCOUNTING_FOR_OFFICE_ID=trn.ACCOUNTING_FOR_OFFICE_ID and
              mst.CASHBOOK_YEAR=trn.CASHBOOK_YEAR and
              mst.CASHBOOK_MONTH=trn.CASHBOOK_MONTH and
              mst.VOUCHER_NO=trn.VOUCHER_NO and
              mst.PAYMENT_STATUS!='C' and
              (mst.MODE_OF_CREATION=rtrim($P{Advance_Type} ) or mst.MODE_OF_CREATION='IT') and
              mst.ACCOUNTING_UNIT_ID=$P{accountingunitid} and
              mst.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid} and
              to_date((mst.CASHBOOK_MONTH ||'-'|| mst.CASHBOOK_YEAR),'mm-yyyy') between to_date($P{cashbookmonth}||'-'||$P{cashbookyear},'mm-yyyy') and to_date($P{cashbookmonth_to}||'-'||$P{cashbookyear_to},'mm-yyyy')    
          group by
              mst.ACCOUNTING_UNIT_ID,
              mst.ACCOUNTING_FOR_OFFICE_ID,
              mst.CASHBOOK_YEAR,
              mst.CASHBOOK_MONTH,
              mst.PAYMENT_DATE,
              mst.VOUCHER_NO,
              trn.SL_NO,
              trn.SUB_LEDGER_CODE
)a
left outer join
(
select distinct mst.ACCOUNTING_UNIT_ID,
              mst.ACCOUNTING_FOR_OFFICE_ID,          
              trn.SUB_LEDGER_CODE,
              trn.CB_REF_NO,
              trn.CB_REF_DATE,
              sum(trn.AMOUNT) as AMT_SPENT
          from
              FAS_JOURNAL_MASTER mst,
              FAS_JOURNAL_TRANSACTION trn
          where
              mst.ACCOUNTING_UNIT_ID=trn.ACCOUNTING_UNIT_ID and
              mst.ACCOUNTING_FOR_OFFICE_ID=trn.ACCOUNTING_FOR_OFFICE_ID and
              mst.CASHBOOK_YEAR=trn.CASHBOOK_YEAR and
              mst.CASHBOOK_MONTH=trn.CASHBOOK_MONTH and
              mst.VOUCHER_NO=trn.VOUCHER_NO and
              mst.JOURNAL_STATUS!='C' and
              (mst.MODE_OF_CREATION=rtrim($P{Advance_Type} ) or mst.MODE_OF_CREATION='IT') and
              trn.CR_DR_INDICATOR='CR'
          group by
              mst.ACCOUNTING_UNIT_ID,
              mst.ACCOUNTING_FOR_OFFICE_ID,           
              trn.SUB_LEDGER_CODE,
              trn.CB_REF_NO,
              trn.CB_REF_DATE
)b
on a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID and
         a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID and
         to_char(a.PAYMENT_DATE,'dd-mm-yy')=to_char(b.CB_REF_DATE,'dd-mm-yy') and
         a.VOUCHER_NO=b.CB_REF_NO and a.SUB_LEDGER_CODE=b.SUB_LEDGER_CODE
left outer join
(
 select distinct
              mst.ACCOUNTING_UNIT_ID,
              mst.ACCOUNTING_FOR_OFFICE_ID,
              mst.RECEIPT_DATE,
              mst.RECEIVABLE_VOUCHER_NO,
              mst.RECEIVABLE_VOUCHER_DATE,
              trn.SUB_LEDGER_CODE,      
              sum(trn.AMOUNT) as AMT_RECEIPT
          from
              FAS_RECEIPT_MASTER mst,
              FAS_RECEIPT_TRANSACTION trn
          where
              mst.ACCOUNTING_UNIT_ID=trn.ACCOUNTING_UNIT_ID and
              mst.ACCOUNTING_FOR_OFFICE_ID=trn.ACCOUNTING_FOR_OFFICE_ID and
              mst.CASHBOOK_YEAR=trn.CASHBOOK_YEAR and
              mst.CASHBOOK_MONTH=trn.CASHBOOK_MONTH and
              mst.RECEIPT_NO=trn.RECEIPT_NO and
              mst.RECEIPT_STATUS!='C' and
              (mst.MODE_OF_CREATION=rtrim($P{Advance_Type} ) or mst.MODE_OF_CREATION='IT')
          group by
              mst.ACCOUNTING_UNIT_ID,
              mst.ACCOUNTING_FOR_OFFICE_ID,       
              mst.RECEIPT_DATE,
              mst.RECEIVABLE_VOUCHER_NO,
              mst.RECEIVABLE_VOUCHER_DATE,
              trn.SUB_LEDGER_CODE
)c
 on a.ACCOUNTING_UNIT_ID=c.ACCOUNTING_UNIT_ID and
         a.ACCOUNTING_FOR_OFFICE_ID=c.ACCOUNTING_FOR_OFFICE_ID and
         to_char(a.PAYMENT_DATE,'dd-mm-yy')=to_char(c.RECEIVABLE_VOUCHER_DATE,'dd-mm-yy') and
         a.VOUCHER_NO=c.RECEIVABLE_VOUCHER_NO and
         a.SUB_LEDGER_CODE=c.SUB_LEDGER_CODE
 left outer join
      (
         select ACCOUNTING_UNIT_ID,ACCOUNTING_UNIT_NAME from FAS_MST_ACCT_UNITS   
      )d
      on a.ACCOUNTING_UNIT_ID=d.ACCOUNTING_UNIT_ID
      left outer join
      (
         select
              emp.EMPLOYEE_ID,
              emp.EMPLOYEE_NAME||'.'||emp.EMPLOYEE_INITIAL||'-'|| design.DESIGNATION as ENAME,
              post.EMPLOYEE_STATUS_ID
         from HRM_MST_EMPLOYEES emp,
              HRM_EMP_CURRENT_POSTING post,
              HRM_MST_DESIGNATIONS design
         where
              post.DESIGNATION_ID=design.DESIGNATION_ID  and
              emp.EMPLOYEE_ID=post.EMPLOYEE_ID and
              post.EMPLOYEE_STATUS_ID in('WKG','DPN','TRT')
      )e
      on
         a.SUB_LEDGER_CODE=e.EMPLOYEE_ID
      order by
         ENAME,
         CASHBOOK_YEAR,
         PAYMENT_DATE,
         VOUCHER_NO
         )aaa
         left outer join
(
      select distinct
            mst.ACCOUNTING_UNIT_ID,
            mst.ACCOUNTING_FOR_OFFICE_ID,
            mst.VOUCHER_NO as journal_vou_no,
            mst.VOUCHER_DATE as journal_vou_dt,
            trn.SUB_LEDGER_CODE,
            trn.CB_REF_NO,
            trn.CB_REF_DATE,
            sum(trn.AMOUNT) as journal_vou_amt
      from
          FAS_JOURNAL_MASTER mst,
          FAS_JOURNAL_TRANSACTION trn
      where
          mst.ACCOUNTING_UNIT_ID=trn.ACCOUNTING_UNIT_ID and
          mst.ACCOUNTING_FOR_OFFICE_ID=trn.ACCOUNTING_FOR_OFFICE_ID and
          mst.CASHBOOK_YEAR=trn.CASHBOOK_YEAR and
          mst.CASHBOOK_MONTH=trn.CASHBOOK_MONTH and
          mst.VOUCHER_NO=trn.VOUCHER_NO and
          mst.JOURNAL_STATUS!='C' and
          (mst.MODE_OF_CREATION=rtrim($P{Advance_Type} ) or mst.MODE_OF_CREATION='IT') and
          trn.CR_DR_INDICATOR='CR'
      group by
          mst.ACCOUNTING_UNIT_ID,
          mst.ACCOUNTING_FOR_OFFICE_ID,     
          mst.VOUCHER_NO ,
          mst.VOUCHER_DATE ,
          trn.SUB_LEDGER_CODE,
          trn.CB_REF_NO,
          trn.CB_REF_DATE
)bbb
 on aaa.ACCOUNTING_UNIT_ID=bbb.ACCOUNTING_UNIT_ID and
         aaa.ACCOUNTING_FOR_OFFICE_ID=bbb.ACCOUNTING_FOR_OFFICE_ID and
         to_char(aaa.PAYMENT_DATE,'dd-mm-yy')=to_char(bbb.CB_REF_DATE,'dd-mm-yy') and
         aaa.VOUCHER_NO=bbb.CB_REF_NO and aaa.SUB_LEDGER_CODE=bbb.SUB_LEDGER_CODE]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_FOR_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="SUB_LEDGER_CODE" class="java.math.BigDecimal"/>
