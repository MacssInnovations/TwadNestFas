<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="IT_Advance_CashAcc_Report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="992"
		 pageHeight="992"
		 columnWidth="932"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Advance_Type" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unitName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="yeartype" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supplement_no" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select distinct tab1.VOUCHER_NO as pay_vr_no,tab1.PAYMENT_DATE,
CASE
    WHEN CREATED_BY_MODULE='SC'
    THEN scAmt else 0
  END AS schemeamt,
  CASE
    WHEN CREATED_BY_MODULE='BPF'
    THEN bpfAmt else 0
  END AS paymentamt,
  CASE
    WHEN CREATED_BY_MODULE='SC'
    THEN jrnl_sc_Amt else 0
  END AS selfChequeJrnlAmt,
  CASE
    WHEN CREATED_BY_MODULE='BPF'
    THEN jrnl_Imp_Amt else 0
  END AS imprestJrnlAmt,
  concat(concat(tab1.emp_name,' - '),tab1.DESIGNATION) as desig,
  case 
  when jVNO is null
  then 0
  else jVNO 
  end as jrnlVoucherNo,
  case when (tab2.VOUCHER_DATE is null) then '-' else tab2.VOUCHER_DATE::varchar end as VOUCHER_DATE,

  case when (tab2.ACCOUNT_HEAD_CODE is null) then '-' 
  	else concat(concat(tab2.ACCOUNT_HEAD_CODE,' & '),tab2.ACCOUNT_HEAD_DESC) end as headdesc,

case when (tab2.CR_DR_INDICATOR is null) then '-' else tab2.CR_DR_INDICATOR end as CR_DR_INDICATOR

from
(SELECT pay_mst.VOUCHER_NO ,pay_trn.sl_no,pay_mst.MODE_OF_CREATION,
      pay_mst.CREATED_BY_MODULE,pay_mst.PAYMENT_DATE,
      pay_trn.AMOUNT AS scAmt,pay_trn.AMOUNT AS bpfAmt, pay_trn.SUB_LEDGER_CODE,
      e1.EMPLOYEE_ID,concat(concat(e1.EMPLOYEE_PREFIX,'.'),
concat(concat(e1.EMPLOYEE_INITIAL,'.'),e1.EMPLOYEE_NAME)) as emp_name,d1.DESIGNATION,
pay_mst.ACCOUNTING_UNIT_ID, pay_mst.ACCOUNTING_FOR_OFFICE_ID,pay_mst.CASHBOOK_YEAR,
 pay_mst.CASHBOOK_MONTH
    FROM FAS_PAYMENT_MASTER pay_mst,FAS_PAYMENT_TRANSACTION pay_trn,
    HRM_MST_EMPLOYEES e1,HRM_EMP_CURRENT_POSTING p1,hrm_mst_designations d1
    WHERE 
     pay_mst.ACCOUNTING_UNIT_ID=$P{accountingunitid}
    AND pay_mst.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
    AND pay_mst.CASHBOOK_YEAR=$P{cashbookyear} 
    AND pay_mst.CASHBOOK_MONTH =$P{cashbookmonth}
    AND pay_trn.ACCOUNTING_UNIT_ID    =pay_mst.ACCOUNTING_UNIT_ID
    AND pay_trn.ACCOUNTING_FOR_OFFICE_ID=pay_mst.ACCOUNTING_FOR_OFFICE_ID
    AND pay_trn.CASHBOOK_YEAR           =pay_mst.CASHBOOK_YEAR
    AND pay_trn.CASHBOOK_MONTH          =pay_mst.CASHBOOK_MONTH
    AND pay_trn.VOUCHER_NO              =pay_mst.VOUCHER_NO
    AND pay_trn.SUB_LEDGER_CODE         =e1.employee_id
    AND e1.employee_id                  =p1.employee_id
    and p1.designation_id               =d1.designation_id
    AND pay_mst.MODE_OF_CREATION        =$P{Advance_Type}
    )tab1
    left outer join
    
 (SELECT mst_jrnl.VOUCHER_NO as jVNO,mst_jrnl.VOUCHER_DATE,trn_jrnl.AMOUNT as jrnl_sc_Amt,
 trn_jrnl.AMOUNT as jrnl_Imp_Amt,
 trn_jrnl.ACCOUNT_HEAD_CODE,trn_jrnl.CR_DR_INDICATOR,trn_jrnl.CB_REF_NO,
 acc_hcode.ACCOUNT_HEAD_DESC,mst_jrnl.ACCOUNTING_UNIT_ID,
 mst_jrnl.ACCOUNTING_FOR_OFFICE_ID,mst_jrnl.CASHBOOK_YEAR,
 mst_jrnl.CASHBOOK_MONTH,trn_jrnl.SUB_LEDGER_CODE
    FROM FAS_JOURNAL_MASTER mst_jrnl,FAS_JOURNAL_TRANSACTION trn_jrnl,
    COM_MST_ACCOUNT_HEADS acc_hcode
    WHERE 
    mst_jrnl.ACCOUNTING_UNIT_ID=$P{accountingunitid} 
    AND mst_jrnl.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}   
    AND trn_jrnl.ACCOUNTING_UNIT_ID    =mst_jrnl.ACCOUNTING_UNIT_ID
    AND trn_jrnl.ACCOUNTING_FOR_OFFICE_ID=mst_jrnl.ACCOUNTING_FOR_OFFICE_ID
    AND trn_jrnl.CASHBOOK_YEAR           =mst_jrnl.CASHBOOK_YEAR
    AND trn_jrnl.CASHBOOK_MONTH          =mst_jrnl.CASHBOOK_MONTH
    and trn_jrnl.VOUCHER_NO              =mst_jrnl.VOUCHER_NO
    and trn_jrnl.CR_DR_INDICATOR='CR'
    and  trn_jrnl.ACCOUNT_HEAD_CODE =acc_hcode.ACCOUNT_HEAD_CODE
    $P!{supplement_no}
    )tab2
    on tab1.VOUCHER_NO=tab2.CB_REF_NO 
    and tab1.ACCOUNTING_UNIT_ID=tab2.ACCOUNTING_UNIT_ID 
    and tab1.ACCOUNTING_FOR_OFFICE_ID=tab2.ACCOUNTING_FOR_OFFICE_ID 
    and tab1.SUB_LEDGER_CODE=tab2.SUB_LEDGER_CODE]]></queryString>

