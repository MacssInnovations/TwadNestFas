	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Accountno" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="heading" isForPrompting="false" class="java.lang.String"/>
	<parameter name="txtFrom_date" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtTo_date" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[SELECT a.TO_BANK_ID,a.from_bank_id,a.FROM_ACCOUNT_NO,
(select c.BANK_NAME FROM FAS_MST_BANKS c WHERE c.BANK_ID=a.from_bank_id ) as frombankname,
  (SELECT b.BANK_NAME FROM FAS_MST_BANKS b WHERE b.BANK_ID=a.TO_BANK_ID
  )AS To_BANK_NAME,
  a.TO_ACCOUNT_NO,
  a.CHEQUE_DD_DATE,
  a.CHEQUE_DD_NO,
  a.TOTAL_AMOUNT
FROM FAS_INTER_BANK_TRF_AT_HO a
WHERE a.ACCOUNTING_UNIT_ID    =$P{unitid}
AND a.ACCOUNTING_FOR_OFFICE_ID=$P{officeid}
and DATE_OF_TRANSFER between $P{txtFrom_date} and $P{txtTo_date}
and a.FROM_ACCOUNT_NO=$P{Accountno}]]></queryString>

	<field name="TO_BANK_ID" class="java.math.BigDecimal"/>
	<field name="FROM_BANK_ID" class="java.math.BigDecimal"/>
	<field name="FROM_ACCOUNT_NO" class="java.math.BigDecimal"/>
	<field name="FROMBANKNAME" class="java.lang.String"/>
	<field name="TO_BANK_NAME" class="java.lang.String"/>
