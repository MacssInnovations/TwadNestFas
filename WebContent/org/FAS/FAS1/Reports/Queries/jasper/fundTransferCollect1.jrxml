<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="fundTransferCollect1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="905"
		 pageHeight="842"
		 columnWidth="845"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="year1" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year2" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year3" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year4" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select trn.account_head_code as debitheadcode,
sum(trn.amount)as debitAmt,
trn.cashbook_year,
trn.cashbook_month,
trn.office_account_no as debitAccnt,
trn.voucher_no,
trn.transfer_to_office_id,
to_char(mst.date_of_transfer) ,
r.cr_account_head_code as creditheadcode,
r.office_account_no as creditaccnt,
to_char(r.receipt_date) as receiptdate,
B.Bank_Short_Name,
R.Accounting_Unit_Id,
trn.cheque_dd_date,
R.Office_Bank_Id,
r.receipt_no,
sum(r.total_amount) as creditAmt,
fas.accounting_unit_id || '-' || fas.accounting_unit_name as unitName
FROM Fas_Fund_Trf_From_Ho_Master Mst
INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
ON Mst.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
AND mst.accounting_for_office_id=trn.accounting_for_office_id
AND Mst.Cashbook_Year           =Trn.Cashbook_Year
AND Mst.Cashbook_Month          =Trn.Cashbook_Month
And Mst.Voucher_No              =Trn.Voucher_No
AND Mst.Transfer_Status         ='L'
And Trn.Auto_Status             ='Y'
and To_Date((trn.cashbook_month
    || '-'
    || trn.cashbook_year),'mm-yyyy') Between To_Date(04
    || '-'
    ||$P{year1},'mm-yyyy')
  AND To_Date(03
    ||'-'
    ||$P{year2},'mm-yyyy')
  
 inner join Fas_Fund_Receipt_By_Office R
on r.accounting_for_office_id=trn.transfer_to_office_id
 and r.receipt_status='L'
 AND R.Cheque_Dd_Date         =Trn.Cheque_Dd_Date
AND R.Cheque_Dd_No           =Trn.Cheque_Dd_No
and r.trf_sl_no=trn.sl_no
and To_Date((r.cashbook_month
    || '-'
    || r.cashbook_year),'mm-yyyy') Between To_Date(04
    || '-'
    ||$P{year3},'mm-yyyy')
  AND To_Date(03
    ||'-'
    ||$P{year4},'mm-yyyy')
  
    INNER JOIN Fas_Mst_Acct_Units Fas
ON fas.accounting_unit_id=r.accounting_unit_id
    INNER JOIN Fas_Mst_Banks B
On B.Bank_Id=Trn.Office_Bank_Id
and b.bank_id=r.office_bank_id

   group by trn.account_head_code, trn.cashbook_year, trn.cashbook_month, trn.office_account_no, trn.voucher_no, trn.transfer_to_office_id, mst.date_of_transfer, r.cr_account_head_code, r.office_account_no, to_char(r.receipt_date), B.Bank_Short_Name, R.Accounting_Unit_Id, trn.cheque_dd_date, R.Office_Bank_Id, r.receipt_no, fas.accounting_unit_id || '-' || fas.accounting_unit_name
 order by r.accounting_unit_id,Mst.Date_Of_Transfer]]></queryString>

