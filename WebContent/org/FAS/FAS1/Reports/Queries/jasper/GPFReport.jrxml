	<parameter name="cashbook_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbook_month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.ACCOUNTING_UNIT_ID,b.ACCOUNTING_UNIT_NAME,a.ACCOUNT_HEAD_CODE,c.ACCOUNT_HEAD_DESC,a.CASHBOOK_YEAR,
a.CASHBOOK_MONTH,a.CURRENT_MONTH_DEBIT,a.CURRENT_MONTH_CREDIT,d.SECTION,d.PRTGRP,(a.CURRENT_MONTH_DEBIT+a.CURRENT_MONTH_CREDIT) as net
from FAS_TRIAL_BALANCE a,FAS_MST_ACCT_UNITS b,COM_MST_ACCOUNT_HEADS c,fas_ho_gpf d 
where  a.ACCOUNT_HEAD_CODE =d.ACCOUNT_HEAD_CODE and 
CASHBOOK_YEAR=$P{cashbook_year} and CASHBOOK_MONTH=$P{cashbook_month}  and a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID
and a.ACCOUNT_HEAD_CODE=c.ACCOUNT_HEAD_CODE 
order by ACCOUNT_HEAD_CODE,ACCOUNTING_UNIT_ID]]></queryString>

