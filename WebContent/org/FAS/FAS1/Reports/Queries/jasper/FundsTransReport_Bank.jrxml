	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="bankid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select a.ACCOUNTING_UNIT_ID,c.ACCOUNTING_UNIT_NAME,a.DATE_OF_TRANSFER,a.TOTAL_AMOUNT,a.REMITTANCE_TYPE,
(a.CHEQUE_OR_DD||'-'||a.CHEQUE_DD_NO||','||a.CHEQUE_DD_DATE) as bankdet,a.PARTICULARS,b.BANK_NAME FROM FAS_FUND_TRF_FROM_OFFICE a,
fas_bank_list b,FAS_MST_ACCT_UNITS c where a.OFFICE_BANK_ID=b.bank_id and a.ACCOUNTING_UNIT_ID=c.ACCOUNTING_UNIT_ID and 
TRANSFER_STATUS='L' and CHEQ_CANCEL_STATUS is null and a.CASHBOOK_YEAR=$P{cashbookyear} and a.CASHBOOK_MONTH=$P{cashbookmonth}
and office_bank_id=$P{bankid} order by DATE_OF_TRANSFER]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="DATE_OF_TRANSFER" class="java.sql.Timestamp"/>
