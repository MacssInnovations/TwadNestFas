<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="fundTransfer"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="899"
		 pageHeight="842"
		 columnWidth="839"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="year1" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year2" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[Select Distinct Trn.Account_Head_Code,
Trn.Account_Head_Code As Debitedhead,
sum(Trn.Amount) As DebitedAmt,
R.Accounting_Unit_Id,
sum(R.Total_Amount) As CreditedAmt,
R.Cr_Account_Head_Code as creditedhead,
  Trn.Accounting_Unit_Id,
  Trn.Accounting_For_Office_Id,
  trn.transfer_to_office_id,
  Trn.Cashbook_Month,
  Trn.Cashbook_Year,
  to_char(R.Receipt_Date,'DD/mm/yyyy')as Receipt_Date,
  Fas.Accounting_Unit_Id || '-' ||
  Fas.Accounting_Unit_Name As Unitname,
 B.Bank_Id || '-' || B.Bank_Name As Bankname,
 Accnt.Bank_Ac_No,
 Trn.Voucher_No,
 R.Trf_Voucher_No,
 Trn.Cheque_Dd_No,
 Trn.Cheque_Dd_Date,
 R.Cheque_Dd_No,
 R.Cheque_Dd_Date,
 R.Accounting_Unit_Id,
Trn.Sl_No,
r.trf_sl_no
 
FROM Fas_Fund_Trf_From_Ho_Master Mst
INNER JOIN Fas_Fund_Trf_From_Ho_Trn Trn
ON Mst.Accounting_Unit_Id       =Trn.Accounting_Unit_Id
AND mst.accounting_for_office_id=trn.accounting_for_office_id
AND Mst.Cashbook_Year           =Trn.Cashbook_Year
AND Mst.Cashbook_Month          =Trn.Cashbook_Month
And Mst.Voucher_No              =Trn.Voucher_No

AND Mst.Transfer_Status         ='L'
And Trn.Auto_Status             ='Y'
and To_Date((trn.cashbook_month
    || '-'
    || trn.cashbook_year),'mm-yyyy') Between To_Date(04
    || '-'
    ||$P{year1},'mm-yyyy')
  AND To_Date(03
    ||'-'
    ||$P{year2},'mm-yyyy')
inner JOIN FAS_FUND_RECEIPT_BY_OFFICE r
On R.Accounting_For_Office_Id=Trn.Transfer_To_Office_Id

And R.Cheque_Dd_Date=Trn.Cheque_Dd_Date
And R.Cheque_Dd_No=Trn.Cheque_Dd_No
And R.Trf_Cb_Month=Trn.Cashbook_Month
And R.Trf_Cb_Year=trn.Cashbook_Year
And R.Trf_Voucher_No=Trn.Voucher_No
And R.Office_Account_No=Trn.Office_Account_No
And R.Cr_Account_Head_Code=Trn.Account_Head_Code
and r.trf_sl_no=trn.sl_no
and To_Date((r.cashbook_month
   || '-'
   ||r.cashbook_year),'mm-yyyy') Between To_Date(04
    || '-'
    || $P{year1},'mm-yyyy')
  AND To_Date(03
    ||'-'
   || $P{year2},'mm-yyyy')
And R.Receipt_Status         ='L'
--And R.Receipt_Date Between '01-APR-2012' And '31-MAR-2013'
--And R.Receipt_Date> '31-MAR-2013'
--AND R.Receipt_Date<='01-APR-2013'
INNER JOIN Fas_Mst_Banks B
ON B.Bank_Id=Trn.Office_Bank_Id
Inner Join Fas_Mst_Acct_Units Fas
ON fas.accounting_unit_id=r.accounting_unit_id
INNER JOIN Fas_Mst_Bank_Branches Branch
ON Branch.Branch_Id=Trn.Office_Branch_Id
Inner Join Fas_Office_Bank_Ac_Current Accnt
On Accnt.Bank_Ac_No=R.Office_Account_No GROUP BY Trn.Account_Head_Code, Trn.Account_Head_Code, R.Accounting_Unit_Id, R.Cr_Account_Head_Code, Trn.Accounting_Unit_Id, Trn.Accounting_For_Office_Id, trn.transfer_to_office_id, Trn.Cashbook_Month, Trn.Cashbook_Year, to_char(R.Receipt_Date,'DD/mm/yyyy'), Fas.Accounting_Unit_Id || '-' ||
  Fas.Accounting_Unit_Name, B.Bank_Id || '-' || B.Bank_Name, Accnt.Bank_Ac_No, Trn.Voucher_No, R.Trf_Voucher_No, Trn.Cheque_Dd_No, Trn.Cheque_Dd_Date, R.Cheque_Dd_No, R.Cheque_Dd_Date, R.Accounting_Unit_Id, Trn.Sl_No, r.trf_sl_no
Order By r.accounting_unit_id,trn.cashbook_year,trn.Cashbook_Month]]></queryString>

