	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="rectype" isForPrompting="true" class="java.lang.String"/>
	<parameter name="param" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="bankid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select recieved_office,office_name,VoucherNo,RECEIPT_DATE,amount,bankdet,bname,ho_bank_id,particulars from
(
select a.RECEIVED_FROM_OFFICE_ID as recieved_office,a.RECEIPT_NO as VoucherNo,a.RECEIPT_DATE,a.ho_bank_id,
a.TOTAL_AMOUNT as amount,(a.CHEQUE_OR_DD||'-'||a.CHEQUE_DD_NO||','||a.CHEQUE_DD_DATE) as bankdet,b.bank_name as bname, 
a.particulars from fas_fund_receipt_by_ho a,fas_bank_list b 
where a.ho_bank_id=b.bank_id and a.RECEIPT_TYPE=$P{rectype} and a.RECEIPT_STATUS='L'
and a.cashbook_month=$P{cashbookmonth}
and a.cashbook_year=$P{cashbookyear}
and a.accounting_unit_id=$P{accountingunitid}
and a.ho_bank_id=$P{bankid}
order by a.RECEIPT_DATE
)x
inner join
(
select office_name,office_id from com_mst_offices 
)y
on x.recieved_office=y.office_id
order by recieved_office,RECEIPT_DATE,VoucherNo]]></queryString>

	<field name="RECIEVED_OFFICE" class="java.math.BigDecimal"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="VOUCHERNO" class="java.math.BigDecimal"/>
	<field name="RECEIPT_DATE" class="java.sql.Timestamp"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>
	<field name="BANKDET" class="java.lang.String"/>
