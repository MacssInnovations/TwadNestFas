<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="GPF_Abstract_subreport1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="535"
		 pageHeight="802"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="CashBook_Year" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select sum(DR_YEAR),sum(CR_YEAR),case when sum(net_sum)< 0 then
(-sum(net_sum)) || 'CR' else sum(net_sum) || '' end as grand_total from(

select
     sum(CURRENT_MONTH_DEBIT) as DR_YEAR,
     sum(CURRENT_MONTH_CREDIT) as CR_YEAR,
     cashbook_year,
     case when ( sum(CURRENT_MONTH_DEBIT)-sum(CURRENT_MONTH_CREDIT))<0 then
     (-(sum(CURRENT_MONTH_DEBIT)-sum(CURRENT_MONTH_CREDIT))) || '(CR)'
    else ( sum(CURRENT_MONTH_DEBIT)-sum(CURRENT_MONTH_CREDIT)) || '' 
    end as NET_YEAR,
    ( sum(CURRENT_MONTH_DEBIT)-sum(CURRENT_MONTH_CREDIT)) as net_sum,
    ACCOUNT_HEAD_CODE 
  from 
    FAS_TRIAL_BALANCE_CMP  where 
     CASHBOOK_YEAR=$P{CashBook_Year}
 and ACCOUNT_HEAD_CODE in (select ACCOUNT_HEAD_CODE from FAS_HO_GPF)
group by ACCOUNT_HEAD_CODE,cashbook_year
)]]></queryString>

	<field name="SUM(DR_YEAR)" class="java.math.BigDecimal"/>
	<field name="SUM(CR_YEAR)" class="java.math.BigDecimal"/>
	<field name="GRAND_TOTAL" class="java.lang.String"/>

