	<parameter name="cashbook_year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbook_month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select
 unit_id,
 ( select accounting_unit_name from fas_mst_acct_units where accounting_unit_id=unit_id) as accounting_unit_name, 
 sum(amt_222101) as amt_222101, 
 sum(amt_222102) as amt_222102,
 sum(amt_222103) as amt_222103,
 sum(amt_222104) as amt_222104 , 
 sum(amt_222105) as amt_222105,
 sum(amt_222106) as amt_222106,
 sum(amt_222107) as amt_222107, 
 sum(amt_222108) as amt_222108,
 sum(amt_222109) as amt_222109,
 sum(amt_222101)+sum(amt_222102)+sum(amt_222103)+sum(amt_222104)+sum(amt_222105)+sum(amt_222106)+sum(amt_222107)+sum(amt_222108)+sum(amt_222109) as tot
 from
(
select 
    accounting_unit_id as unit_id ,
  
  Account_Head_Code,
  case when ( account_head_code = 222101  ) then 
  sum(tot)  
  else 
  0 
  end as amt_222101, 
  
  case when ( account_head_code = 222102  ) then 
  sum(tot)  
  else 
  0 
  end as amt_222102 , 
  
  case when ( account_head_code = 222103 ) then 
  sum(tot)  
  else 
  0 
  end as amt_222103 , 
  
  case when ( account_head_code = 222104  ) then 
  sum(tot)  
  else 
  0 
  end as amt_222104 , 
  case when ( account_head_code = 222105  ) then 
  sum(tot)  
  else 
  0 
  end as amt_222105, 
  
  case when ( account_head_code = 222106  ) then 
  sum(tot)  
  else 
  0 
  end as amt_222106 , 
  
  case when ( account_head_code = 222107 ) then 
  sum(tot)  
  else 
  0 
  end as amt_222107 , 
  
  case when ( account_head_code = 222108  ) then 
  sum(tot)  
  else 
  0 
  end as amt_222108 ,   
  case when ( account_head_code = 222109  ) then 
  sum(tot)  
  else 
  0 
  end as amt_222109 
    
from
  (
 select 
  accounting_unit_id,ACCOUNT_HEAD_CODE,
(dramount-cramount) as tot
  from
 ( 
 select accounting_unit_id,ACCOUNT_HEAD_CODE,
 sum(decode(CR_DR_INDICATOR,'CR',AMOUNT,0)) as cramount,
sum(decode(CR_DR_INDICATOR,'DR',AMOUNT,0)) as dramount 
  from FAS_JOURNAL_TRANSACTION where 
  
 cashbook_year = $P{cashbook_year}
 AND cashbook_month = $P{cashbook_month}
 AND ( ACCOUNT_HEAD_CODE =222101 or ACCOUNT_HEAD_CODE=222102 or ACCOUNT_HEAD_CODE=222103 
 or ACCOUNT_HEAD_CODE=222104 or ACCOUNT_HEAD_CODE=222105 or ACCOUNT_HEAD_CODE=222106 or ACCOUNT_HEAD_CODE=222107
 or ACCOUNT_HEAD_CODE=222108 or ACCOUNT_HEAD_CODE=222109)
 group by accounting_unit_id,ACCOUNT_HEAD_CODE
 order by ACCOUNT_HEAD_CODE
 ) 
 union all
 select 
  accounting_unit_id,ACCOUNT_HEAD_CODE,
(dramount-cramount) as tot
  from
 (
 select accounting_unit_id,ACCOUNT_HEAD_CODE,
  sum(decode(CR_DR_INDICATOR,'CR',AMOUNT,0)) as cramount,
sum(decode(CR_DR_INDICATOR,'DR',AMOUNT,0)) as dramount 
  from FAS_PAYMENT_TRANSACTION where 
 
 cashbook_year = $P{cashbook_year}
 AND cashbook_month = $P{cashbook_month}
 AND ( ACCOUNT_HEAD_CODE =222101 or ACCOUNT_HEAD_CODE=222102 or ACCOUNT_HEAD_CODE=222103 
 or ACCOUNT_HEAD_CODE=222104 or ACCOUNT_HEAD_CODE=222105 or ACCOUNT_HEAD_CODE=222106 or ACCOUNT_HEAD_CODE=222107
 or ACCOUNT_HEAD_CODE=222108 or ACCOUNT_HEAD_CODE=222109)
 group by accounting_unit_id,ACCOUNT_HEAD_CODE
)
  union all
 select 
  accounting_unit_id,ACCOUNT_HEAD_CODE,
(dramount-cramount) as tot
  from
 (
 select accounting_unit_id,ACCOUNT_HEAD_CODE,
  sum(decode(CR_DR_INDICATOR,'CR',AMOUNT,0)) as cramount,
sum(decode(CR_DR_INDICATOR,'DR',AMOUNT,0)) as dramount 
  from FAS_RECEIPT_TRANSACTION where 
 
 cashbook_year = $P{cashbook_year}
 AND cashbook_month = $P{cashbook_month}
 AND ( ACCOUNT_HEAD_CODE =222101 or ACCOUNT_HEAD_CODE=222102 or ACCOUNT_HEAD_CODE=222103 
 or ACCOUNT_HEAD_CODE=222104 or ACCOUNT_HEAD_CODE=222105 or ACCOUNT_HEAD_CODE=222106 or ACCOUNT_HEAD_CODE=222107
 or ACCOUNT_HEAD_CODE=222108 or ACCOUNT_HEAD_CODE=222109)
 group by accounting_unit_id,ACCOUNT_HEAD_CODE
)
 ) z  
 group by accounting_unit_id,ACCOUNT_HEAD_CODE
 )
 group by unit_id
order by unit_id]]></queryString>

