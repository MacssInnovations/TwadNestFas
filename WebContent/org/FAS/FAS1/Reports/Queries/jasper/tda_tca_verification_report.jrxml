<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="tda_tca_verification_report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="850"
		 pageHeight="842"
		 columnWidth="790"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="year1" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select * from (Select Unit_Id,
(select U.Accounting_Unit_Name from Fas_Mst_Acct_Units u where U.Accounting_Unit_Id=unit_id)as unit_name,
Cashbook_Month,
Case When Cashbook_Month=1 Then 'January' 
      When Cashbook_Month=2 Then 'February' 
      When Cashbook_Month=3 Then 'March' 
      When Cashbook_Month=4 Then 'April' 
      When Cashbook_Month=5 Then 'May' 
      When Cashbook_Month=6 Then 'June' 
      When Cashbook_Month=7 Then 'July' 
      When Cashbook_Month=8 Then 'August' 
      When Cashbook_Month=9 Then 'September' 
      When Cashbook_Month=10 Then 'October' 
      When Cashbook_Month=11 Then 'November' 
      When Cashbook_Month=12 Then 'December' 
      end as month_desc,
  Account_Head_Code,
  Trn_Dr,
  Trn_Cr,
  Tda_Dr,
  Tda_Cr,
  Trn_Net,
  Tda_Net,
  (Trn_Net-tda_net)AS difference
From
  (SELECT aaa.Accounting_Unit_Id as unit_id,Aaa.Cashbook_Month,
    Aaa.Account_Head_Code,
    Aaa.Trn_Dr,
    Aaa.Trn_Cr,
    Bbb.Tda_Dr,
    Bbb.Tda_Cr,
    CASE
      WHEN Aaa.Trn_Dr>Aaa.Trn_Cr
      THEN (Aaa.Trn_Dr-Aaa.Trn_Cr)
      WHEN Aaa.Trn_Cr>Aaa.Trn_Dr
      THEN (Aaa.Trn_Cr-Aaa.Trn_Dr)
      ELSE 0
    END AS Trn_Net,
    CASE
      WHEN Bbb.Tda_Dr>Bbb.Tda_Cr
      THEN (Bbb.Tda_Dr-Bbb.Tda_Cr)
      WHEN Bbb.Tda_Cr>Bbb.Tda_Dr
      THEN (Bbb.Tda_Cr-Bbb.Tda_Dr)
      ELSE 0
    END AS Tda_Net
  From
    (SELECT Accounting_Unit_Id,Cashbook_Month,
      Account_Head_Code,
      SUM(dr_Amount)AS trn_dr,
      SUM(cr_amount)AS trn_cr
    FROM
      (SELECT Accounting_Unit_Id,Cashbook_Month,
        Account_Head_Code,
        SUM(dr_Amount)AS dr_Amount,
        SUM(cr_amount)AS cr_amount
      FROM
        (Select B.Cashbook_Month,
          B.Account_Head_Code,B.Accounting_Unit_Id,
          CASE
            WHEN B.Cr_Dr_Indicator='DR'
            THEN SUM(B.Amount)
            ELSE 0
          END AS dr_Amount,
          CASE
            WHEN b.Cr_Dr_Indicator='CR'
            THEN SUM(B.Amount)
            ELSE 0
          END AS cr_amount
        FROM fas_journal_master a,
          Fas_Journal_Transaction b
        WHERE A.Accounting_Unit_Id    =b.Accounting_Unit_Id
        AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
        AND A.Cashbook_Year           =B.Cashbook_Year
        AND A.Cashbook_Month          =B.Cashbook_Month
        AND A.Voucher_No              =B.Voucher_No
        AND A.Journal_Status          ='L'
        AND A.Journal_Type_Code      IN (62,63,65,66)
        And A.Mode_Of_Creation        ='A'
        AND B.Cashbook_Year           = $P{year1}
        And B.Account_Head_Code      In (900108,900109,901001,901002)
        GROUP BY B.Accounting_Unit_Id,B.Cashbook_Month,
          B.Account_Head_Code,
          B.Cr_Dr_Indicator
        UNION ALL
        Select B.Cashbook_Month,
          B.Account_Head_Code,B.Accounting_Unit_Id,
          CASE
            WHEN B.Cr_Dr_Indicator='DR'
            THEN SUM(B.Amount)
            ELSE 0
          END AS dr_Amount,
          CASE
            WHEN b.Cr_Dr_Indicator='CR'
            THEN SUM(B.Amount)
            ELSE 0
          END AS cr_amount
        FROM fas_journal_master a,
          Fas_Journal_Transaction b
        WHERE A.Accounting_Unit_Id    =b.Accounting_Unit_Id
        AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
        AND A.Cashbook_Year           =B.Cashbook_Year
        AND A.Cashbook_Month          =B.Cashbook_Month
        AND A.Voucher_No              =B.Voucher_No
        AND A.Journal_Status          ='L'
        And A.Journal_Type_Code      In (54)
        AND B.Cashbook_Year           = $P{year1}
        And B.Account_Head_Code      In (900108,900109,901001,901002)
        GROUP BY B.Accounting_Unit_Id,B.Cashbook_Month,
          B.Account_Head_Code,
          B.Cr_Dr_Indicator
        )Group By Accounting_Unit_Id,Cashbook_Month,
        Account_Head_Code
        --Order By Accounting_Unit_Id,Cashbook_Month,Account_Head_Code
      Union All
      SELECT B.Accounting_Unit_Id,B.Cashbook_Month,
        B.Account_Head_Code,
        CASE
          WHEN B.Cr_Dr_Indicator='DR'
          THEN SUM(B.Amount)
          ELSE 0
        END AS dr_Amount,
        CASE
          WHEN b.Cr_Dr_Indicator='CR'
          THEN SUM(B.Amount)
          ELSE 0
        END AS cr_amount
      FROM FAS_PAYMENT_MASTER a,
        FAS_PAYMENT_TRANSACTION b
      WHERE A.Accounting_Unit_Id    =b.Accounting_Unit_Id
      AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
      AND A.Cashbook_Year           =B.Cashbook_Year
      AND A.Cashbook_Month          =B.Cashbook_Month
      AND A.Voucher_No              =B.Voucher_No
      And A.Payment_Status          ='L'
      AND B.Cashbook_Year           =$P{year1}
      And B.Account_Head_Code      In (900108,900109,901001,901002)
      GROUP BY B.Accounting_Unit_Id,B.Cashbook_Month,
        B.Account_Head_Code,
        B.Cr_Dr_Indicator
      Union All
      SELECT B.Accounting_Unit_Id,B.Cashbook_Month,
        B.Account_Head_Code,
        CASE
          WHEN B.Cr_Dr_Indicator='DR'
          THEN SUM(B.Amount)
          ELSE 0
        END AS dr_Amount,
        CASE
          WHEN b.Cr_Dr_Indicator='CR'
          THEN SUM(B.Amount)
          ELSE 0
        END AS cr_amount
      FROM FAS_RECEIPT_MASTER a,
        FAS_RECEIPT_TRANSACTION b
      WHERE A.Accounting_Unit_Id    =b.Accounting_Unit_Id
      AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
      AND A.Cashbook_Year           =B.Cashbook_Year
      AND A.Cashbook_Month          =B.Cashbook_Month
      AND A.RECEIPT_NO              =B.RECEIPT_NO
      And A.Receipt_Status          ='L'
      AND B.Cashbook_Year           =$P{year1}
      And B.Account_Head_Code      In (900108,900109,901001,901002)
      GROUP BY B.Accounting_Unit_Id,B.Cashbook_Month,
        B.Account_Head_Code,
        B.Cr_Dr_Indicator
      )
    GROUP BY Accounting_Unit_Id,Cashbook_Month,
      Account_Head_Code
    ORDER BY Accounting_Unit_Id,Cashbook_Month,
      Account_Head_Code
    )aaa
  Left Outer Join
    (SELECT Accounting_Unit_Id,Cashbook_Month,
      Account_Head_Code,
      SUM(dr_Amount)AS tda_dr,
      SUM(cr_amount)AS tda_cr
    FROM
      (
      SELECT B.Accounting_Unit_Id,B.Cashbook_Month,
  B.Account_Head_Code,
  CASE
    WHEN B.Cr_Dr_Indicator='DR'
    THEN SUM(B.Amount)
    ELSE 0
  END AS dr_Amount,
  CASE
    WHEN b.Cr_Dr_Indicator='CR'
    THEN SUM(B.Amount)
    ELSE 0
  END AS cr_amount
FROM Fas_Tda_Tca_Raised_Mst A,
  Fas_Tda_Tca_Raised_Trn B
WHERE A.Accounting_Unit_Id    =b.Accounting_Unit_Id
AND A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
AND A.Cashbook_Year           =B.Cashbook_Year
AND A.Cashbook_Month          =B.Cashbook_Month
AND A.Voucher_No              =B.Voucher_No
And A.Status                  ='L'
AND B.Cashbook_Year           =$P{year1}
And B.Account_Head_Code      In (900108,900109,901001,901002)
GROUP BY B.Accounting_Unit_Id,B.Cashbook_Month,
  B.Account_Head_Code,
  B.Cr_Dr_Indicator
Order By B.Accounting_Unit_Id,B.Cashbook_Month,
  b.Account_Head_Code
      )
    GROUP BY Accounting_Unit_Id,Cashbook_Month,
      Account_Head_Code
    ORDER BY Accounting_Unit_Id,Cashbook_Month,
      Account_Head_Code
    )Bbb
  On aaa.Accounting_Unit_Id=bbb.Accounting_Unit_Id
  and Aaa.Cashbook_Month    =Bbb.Cashbook_Month
  And Aaa.Account_Head_Code=Bbb.Account_Head_Code
  ))where difference!=0 and Cashbook_Month >$P{month}
order by Unit_Id,Cashbook_Month]]></queryString>

	<field name="UNIT_ID" class="java.math.BigDecimal"/>
	<field name="UNIT_NAME" class="java.lang.String"/>
	<field name="CASHBOOK_MONTH" class="java.math.BigDecimal"/>
	<field name="MONTH_DESC" class="java.lang.String"/>
	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="TRN_DR" class="java.math.BigDecimal"/>
	<field name="TRN_CR" class="java.math.BigDecimal"/>
	<field name="TDA_DR" class="java.math.BigDecimal"/>
	<field name="TDA_CR" class="java.math.BigDecimal"/>
	<field name="TRN_NET" class="java.math.BigDecimal"/>
	<field name="TDA_NET" class="java.math.BigDecimal"/>
	<field name="DIFFERENCE" class="java.math.BigDecimal"/>


