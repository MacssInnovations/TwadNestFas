		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="bankid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select ACCOUNTING_FOR_OFFICE_ID,office_name,VoucherNo,RECEIPT_DATE,amount,bankdet,particulars,bname from
(
select a.ACCOUNTING_FOR_OFFICE_ID,(a.RECEIPT_NO) as VoucherNo,a.RECEIPT_DATE,
a.TOTAL_AMOUNT as amount,(a.CHEQUE_OR_DD||'-'||a.CHEQUE_DD_NO||'-'||a.CHEQUE_DD_DATE) as bankdet,
b.bank_name as bname, 
a.particulars from fas_fund_receipt_by_office a,fas_bank_list b 
where a.ho_bank_id=b.bank_id and a.RECEIPT_STATUS='L'
and a.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}::numeric
and a.receipt_date between $P{fromdate}::date and $P{todate}::date
and a.accounting_unit_id=$P{accountingunitid}::numeric
and a.ho_bank_id=$P{bankid}::numeric
order by a.RECEIPT_DATE
)x
inner join
(
select office_name,office_id from com_mst_offices 
)y
on x.ACCOUNTING_FOR_OFFICE_ID=y.office_id
order by ACCOUNTING_FOR_OFFICE_ID,RECEIPT_DATE,VoucherNo]]></queryString>

	<field name="accounting_for_office_id" class="java.math.BigDecimal"/>
	<field name="office_name" class="java.lang.String"/>
	<field name="voucherno" class="java.math.BigDecimal"/>
	<field name="receipt_date" class="java.sql.Date"/>
	<field name="amount" class="java.math.BigDecimal"/>
	<field name="bankdet" class="java.lang.String"/>
	<field name="particulars" class="java.lang.String"/>
	<field name="bname" class="java.lang.String"/>

	<variable name="SUM_AMOUNT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="office" calculation="Sum">
