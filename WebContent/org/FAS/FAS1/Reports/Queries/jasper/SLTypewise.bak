	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select account_head_code,account_head_desc,sub_ledger_type_desc from
(
select account_head_code,account_head_desc from com_mst_account_heads 
)a
inner join 
(
select sub_ledger_type_code,account_head_code as acchcode from fas_applicable_sl_type 
)b
on a.account_head_code=b.acchcode
inner join 
(
select sub_ledger_type_code as sltype,sub_ledger_type_desc from com_mst_sl_types
)c
on b.sub_ledger_type_code=c.sltype

order by sub_ledger_type_code]]></queryString>

	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_DESC" class="java.lang.String"/>
	<field name="SUB_LEDGER_TYPE_DESC" class="java.lang.String"/>


