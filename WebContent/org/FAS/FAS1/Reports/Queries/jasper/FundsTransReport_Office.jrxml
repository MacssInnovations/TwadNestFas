	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select ACCOUNTING_FOR_OFFICE_ID,office_name,Voucher_No,date_of_transfer,amount,bankdet,particulars,bname from
(
select a.ACCOUNTING_FOR_OFFICE_ID,a.VOUCHER_NO,a.DATE_OF_TRANSFER,
a.TOTAL_AMOUNT as amount,(a.CHEQUE_OR_DD||'-'||a.CHEQUE_DD_NO||'-'||a.CHEQUE_DD_DATE) as bankdet, 
b.bank_name as bname,
a.particulars from FAS_FUND_TRF_FROM_OFFICE a,fas_bank_list b 
where a.office_bank_id=b.bank_id and Transfer_Status!='C'
and a.DATE_OF_TRANSFER between $P{fromdate}::date and $P{todate}::date
and a.accounting_unit_id=$P{accountingunitid}::int
)x
inner join
(
select office_name,office_id from com_mst_offices 
)y
on x.ACCOUNTING_FOR_OFFICE_ID=y.office_id
order by Voucher_No,date_of_transfer]]></queryString>

	<field name="accounting_for_office_id" class="java.math.BigDecimal"/>
	<field name="office_name" class="java.lang.String"/>
