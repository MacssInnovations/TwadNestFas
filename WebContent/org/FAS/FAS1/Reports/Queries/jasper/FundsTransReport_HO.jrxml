	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="bankid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select TRANSFER_TO_OFFICE_ID,office_name,VOUCHER_NO,DATE_OF_TRANSFER,amount,bankdet,particulars,bname from
(
select a.TRANSFER_TO_OFFICE_ID,a.VOUCHER_NO,c.DATE_OF_TRANSFER,
a.AMOUNT as amount,(a.CHEQUE_OR_DD||'-'||a.CHEQUE_DD_NO||','||a.CHEQUE_DD_DATE) as bankdet, 
b.bank_name as bname,
a.particulars from FAS_FUND_TRF_FROM_HO_TRN a,fas_bank_list b ,FAS_FUND_TRF_FROM_HO_MASTER c
where a.office_bank_id=b.bank_id and a.VOUCHER_NO=c.VOUCHER_NO 
 and a.ACCOUNTING_UNIT_ID=c.ACCOUNTING_UNIT_ID 
and a.ACCOUNTING_FOR_OFFICE_ID= c.ACCOUNTING_FOR_OFFICE_ID and 
a.CASHBOOK_YEAR=c.CASHBOOK_YEAR and
a.CASHBOOK_MONTH=c.CASHBOOK_MONTH and c.TRANSFER_STATUS!='C'
and c.DATE_OF_TRANSFER between $P{fromdate} and $P{todate} 
and a.office_bank_id=$P{bankid} 
)x
inner join
(
select office_name,office_id from com_mst_offices 
)y
on x.TRANSFER_TO_OFFICE_ID=y.office_id
order by VOUCHER_NO,DATE_OF_TRANSFER]]></queryString>

