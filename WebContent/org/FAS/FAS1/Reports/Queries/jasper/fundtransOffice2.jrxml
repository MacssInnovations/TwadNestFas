<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="fundtransOffice2"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="784"
		 pageHeight="842"
		 columnWidth="724"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="year1" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year2" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year3" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year4" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT a.office_id,
  a.cashbook_year,
  a.cashbook_month,
  a.amt1,
  a.cr_account_head_code,
  b.office_id,
  b.cr_account_head_code,
  b.amt,
  b.amt-a.amt1 AS notaccnt,
  fas.accounting_unit_id
  || '-'
  ||fas.accounting_unit_name AS unitname,
  bankname.bank_id
  || '-'
  || bankname.bank_name AS bankname,a.cheque_dd_no
FROM
  (SELECT nvl(o.cheque_dd_no,0) cheque_dd_no ,

    o.CHEQUE_OR_DD,
    o.accounting_unit_id,
    O.ACCOUNTING_FOR_OFFICE_ID AS office_id,
    o.ho_bank_id,
    o.VOUCHER_NO,
    O.cashbook_year,
    O.cashbook_month,
    o.cr_account_head_code,
    o.cheque_dd_date,
    SUM(O.total_amount)AS amt1
  FROM FAS_FUND_TRF_FROM_OFFICE o
  WHERE To_Date((cashbook_month
    || '-'
    || cashbook_year),'mm-yyyy') BETWEEN To_Date(04
    || '-'
    ||$P{year1},'mm-yyyy')
  AND To_Date(03
    ||'-'
    ||$P{year2},'mm-yyyy')
  AND o.transfer_status ='L'
 GROUP BY nvl(o.cheque_dd_no,0), o.CHEQUE_OR_DD, o.accounting_unit_id, O.ACCOUNTING_FOR_OFFICE_ID, o.ho_bank_id, o.VOUCHER_NO, O.cashbook_year, O.cashbook_month, o.cr_account_head_code, o.cheque_dd_date
  )a
INNER JOIN Fas_Mst_Acct_Units Fas
ON a.Accounting_Unit_Id=Fas.Accounting_Unit_Id
INNER JOIN FAS_BANK_LIST Bankname
ON Bankname.Bank_Id=a.HO_BANK_ID
INNER JOIN
  (SELECT nvl(h.cheque_dd_no,0) cheque_dd_no ,
    h.CHEQUE_OR_DD,
    o.date_of_transfer,
    h.accounting_unit_id,
    h.RECEIVED_FROM_OFFICE_ID AS office_id ,
    h.cashbook_year,
    h.cashbook_month,
    h.cr_account_head_code,
    h.cheque_dd_date,
    h.trf_voucher_no,
    SUM( h.total_amount)AS amt
  FROM FAS_FUND_RECEIPT_BY_HO h
  INNER JOIN FAS_FUND_TRF_FROM_OFFICE o
  ON h.RECEIVED_FROM_OFFICE_ID=o.ACCOUNTING_FOR_OFFICE_ID
  AND o.total_amount          = h.total_amount
  AND o.date_of_transfer      =h.cheque_dd_date
  AND o.transfer_status       ='L'
  AND( (o.cheque_dd_no        = h.cheque_dd_no)
  OR (h.cheque_dd_no         IS NULL))
  AND To_Date((h.cashbook_month
    || '-'
    ||h. cashbook_year),'mm-yyyy') BETWEEN To_Date(04
    || '-'
    ||$P{year3},'mm-yyyy')
  AND To_Date(03
    ||'-'
    ||$P{year4},'mm-yyyy')
  GROUP BY nvl(h.cheque_dd_no,0), h.CHEQUE_OR_DD, o.date_of_transfer, h.accounting_unit_id, h.RECEIVED_FROM_OFFICE_ID, h.cashbook_year, h.cashbook_month, h.cr_account_head_code, h.cheque_dd_date, h.trf_voucher_no
  )b ON a.office_id =b.office_id
AND a.CHEQUE_OR_DD  =b.CHEQUE_OR_DD
AND a.cheque_dd_date=b.cheque_dd_date
and a.cheque_dd_no =b.cheque_dd_no
and a.VOUCHER_NO=b.trf_voucher_no

ORDER BY bankname.bank_id
  || '-'
  || bankname.bank_name,
  fas.accounting_unit_id
  || '-'
  ||fas.accounting_unit_name]]></queryString>

