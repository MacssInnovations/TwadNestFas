	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="fdate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="tdate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fy" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="CashBook_Year" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 
* 
from 
(
select 
   accounting_unit_id, 
   account_head_code, 
   current_month_debit, 
   current_month_credit,      
   case when (CURRENT_MONTH_DEBIT - CURRENT_MONTH_CREDIT)<0 then 
      (CURRENT_MONTH_CREDIT-CURRENT_MONTH_DEBIT)|| '(CR)'
   else 
      (CURRENT_MONTH_DEBIT-CURRENT_MONTH_CREDIT) || '' end  as net,
     (CURRENT_MONTH_DEBIT-CURRENT_MONTH_CREDIT)  as net1        
from 
(
select  
     a.account_head_code,
     a.accounting_unit_id, 
    sum(a.current_month_debit) as current_month_debit, 
    sum(a.current_month_credit) as current_month_credit 
 from 
    FAS_TRIAL_BALANCE a        
 where 
     to_date(a.CASHBOOK_MONTH||'-'||a.CASHBOOK_YEAR,'MM-YYYY')
between to_date($P{fdate},'MM-YYYY') and to_date($P{tdate},'MM-YYYY')
 and a.account_head_code in ( select account_head_code from fas_ho_gpf) 
 group by a.accounting_unit_id , a.account_head_code 
 order by a.accounting_unit_id, a.account_head_code 
)
) a

left outer join 

( 
   select g.ACCOUNT_HEAD_CODE, g.SECTION , g.PRTGRP from FAS_HO_GPF g 
   
)b 

 on 
 a.account_head_code =b.account_head_code
 left outer join
 (
 select ACCOUNTING_UNIT_ID,ACCOUNTING_UNIT_NAME from FAS_MST_ACCT_UNITS
 ) c
 on a.ACCOUNTING_UNIT_ID=c.ACCOUNTING_UNIT_ID
 left outer join
 (
 select ACCOUNT_HEAD_CODE,ACCOUNT_HEAD_DESC from COM_MST_ACCOUNT_HEADS
 ) d
 on a.ACCOUNT_HEAD_CODE=d.ACCOUNT_HEAD_CODE
 
 
 
 
 left outer join
 
 ( 
      select 
account_head_code, 
net1_dr_cr, 
net1 as snet
from 
(
select 
  account_head_code,
  case when net1<0 then 
    'CR' 
  else 
    'DR'
  end as net1_dr_cr, 
  
  case when net1 >= 0 then 
    net1 
  else 
    net1 * -1 
  end as net1
from 
(

select 
  account_head_code, 
  sum(net1) as net1 
from 
(
select 
   accounting_unit_id, 
   account_head_code, 
   current_month_debit, 
   current_month_credit,      
   case when (CURRENT_MONTH_DEBIT - CURRENT_MONTH_CREDIT)<0 then 
      (CURRENT_MONTH_CREDIT-CURRENT_MONTH_DEBIT)|| '(CR)'
   else 
      (CURRENT_MONTH_DEBIT-CURRENT_MONTH_CREDIT) || '' end  as net,
     (CURRENT_MONTH_DEBIT-CURRENT_MONTH_CREDIT)  as net1        
from 
(
select  
     a.account_head_code,
     a.accounting_unit_id, 
    sum(a.current_month_debit) as current_month_debit, 
    sum(a.current_month_credit) as current_month_credit 
 from 
    FAS_TRIAL_BALANCE a        
 where 
     to_date(a.CASHBOOK_MONTH||'-'||a.CASHBOOK_YEAR,'MM-YYYY')
between to_date('04-2007' ,'MM-YYYY') and to_date('03-2008','MM-YYYY')
 and a.account_head_code in ( select account_head_code from fas_ho_gpf) 
 group by a.accounting_unit_id , a.account_head_code 
 order by a.accounting_unit_id, a.account_head_code 
)
)
group by account_head_code
)
) 
)e 
on e.account_head_code = a.ACCOUNT_HEAD_CODE]]></queryString>

