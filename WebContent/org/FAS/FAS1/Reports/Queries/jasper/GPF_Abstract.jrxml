	<parameter name="CashBook_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["D:\\arun\\twadbuild27_30Apr08\\twadbuild27\\public_html\\org\\FAS\\FAS1\\Reports\\Queries\\jasper\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select * from(
select ACCOUNT_HEAD_CODE,CASHBOOK_YEAR,CASHBOOK_MONTH,
sum(CURRENT_MONTH_DEBIT) as DR_MONTH,sum(CURRENT_MONTH_CREDIT) AS CR_MONTH,
case when (SUM(CURRENT_MONTH_DEBIT)-SUM(CURRENT_MONTH_CREDIT))<0 
then (-(SUM(CURRENT_MONTH_DEBIT)-SUM(CURRENT_MONTH_CREDIT)))|| '(CR)'
 else (SUM(CURRENT_MONTH_DEBIT)-SUM(CURRENT_MONTH_CREDIT)) || '' end  as net,
(SUM(CURRENT_MONTH_DEBIT)-SUM(CURRENT_MONTH_CREDIT))as net_month
from FAS_TRIAL_BALANCE_CMP where 
CASHBOOK_YEAR=$P{CashBook_Year} and ACCOUNT_HEAD_CODE in (select ACCOUNT_HEAD_CODE from FAS_HO_GPF)
group by ACCOUNT_HEAD_CODE,CASHBOOK_YEAR,CASHBOOK_MONTH
ORDER BY ACCOUNT_HEAD_CODE,CASHBOOK_YEAR,CASHBOOK_MONTH
) x
left outer join
(
select ACCOUNT_HEAD_CODE,ACCOUNT_HEAD_DESC from COM_MST_ACCOUNT_HEADS
) y

on x.ACCOUNT_HEAD_CODE=y.ACCOUNT_HEAD_CODE
left outer join
(
select ACCOUNT_HEAD_CODE,SECTION,PRTGRP from FAS_HO_GPF
) yy
on yy.ACCOUNT_HEAD_CODE=x.ACCOUNT_HEAD_CODE
left outer join
(select sum(CURRENT_MONTH_DEBIT) as DR_YEAR,sum(CURRENT_MONTH_CREDIT) as CR_YEAR,cashbook_year,
case when ( sum(CURRENT_MONTH_DEBIT)-sum(CURRENT_MONTH_CREDIT))<0 then
(-(sum(CURRENT_MONTH_DEBIT)-sum(CURRENT_MONTH_CREDIT))) || '(CR)'
else ( sum(CURRENT_MONTH_DEBIT)-sum(CURRENT_MONTH_CREDIT)) || '' end as NET_YEAR,
( sum(CURRENT_MONTH_DEBIT)-sum(CURRENT_MONTH_CREDIT)) as net_sum,
ACCOUNT_HEAD_CODE from FAS_TRIAL_BALANCE_CMP where CASHBOOK_YEAR=$P{CashBook_Year}
and ACCOUNT_HEAD_CODE in (select ACCOUNT_HEAD_CODE from FAS_HO_GPF)
group by ACCOUNT_HEAD_CODE,cashbook_year
) z
on x.ACCOUNT_HEAD_CODE=z.ACCOUNT_HEAD_CODE and z.ACCOUNT_HEAD_CODE=y.ACCOUNT_HEAD_CODE
order by x.ACCOUNT_HEAD_CODE,x.CASHBOOK_YEAR,x.CASHBOOK_MONTH]]></queryString>

