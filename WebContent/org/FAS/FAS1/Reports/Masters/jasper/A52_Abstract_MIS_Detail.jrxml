	<variable name="DepTotal" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[($F{DEP_PREV_YEAR}.add( $F{DEPRE_REC_AC} )).add( $F{DEPRE_ALLOWED_YR} )]]></variableExpression>
	</variable>
	<variable name="CBQty" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[($F{OPEN_BAL_QTY}.add( $F{RECIEPTS_YEAR_QTY} )).subtract( $F{ISSUES_YEAR_QTY} )]]></variableExpression>
	</variable>
	<variable name="CBValue" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[($F{OPENING_BAL_VALUE}.add( $F{RECIEPTS_YR_VALUE} )).subtract( $F{ISSUES_YEAR_QTY} )]]></variableExpression>
	</variable>
	<variable name="TotalQty" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{OPEN_BAL_QTY}.add( $F{RECIEPTS_YEAR_QTY} )]]></variableExpression>
	</variable>
