<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="A52_Abstract_MIS_Detail"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="1275"
		 pageHeight="1417"
		 columnWidth="1215"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.zoom" value="1.0" />
	<property name="ireport.x" value="0" />
	<property name="ireport.y" value="52" />
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="financialyear" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="assetmajclass" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="querp" isForPrompting="true" class="java.lang.String"/>
	<parameter name="circleQry" isForPrompting="false" class="java.lang.String"/>
	<parameter name="queryAsset" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT asset_minor_class_code,
  asset_code,
  DECODE(open_bal_qty,NULL,0,open_bal_qty)             AS open_bal_qty,
  DECODE(opening_bal_value,NULL,0,opening_bal_value)   AS opening_bal_value,
  DECODE(RECIEPTS_YEAR_QTY,NULL,0,RECIEPTS_YEAR_QTY)   AS RECIEPTS_YEAR_QTY,
  DECODE(reciepts_yr_value,NULL,0,reciepts_yr_value)   AS reciepts_yr_value,
  DECODE(ISSUES_YEAR_QTY,NULL,0,ISSUES_YEAR_QTY)       AS ISSUES_YEAR_QTY,
  DECODE(issues_yr_value,NULL,0,issues_yr_value)       AS issues_yr_value,
  DECODE(DEP_PREV_YEAR,NULL,0,DEP_PREV_YEAR)           AS DEP_PREV_YEAR,
  DECODE(depre_rec_ac,NULL,0,depre_rec_ac)             AS depre_rec_ac,
  DECODE(depre_allowed_yr,NULL,0,depre_allowed_yr)     AS depre_allowed_yr,
  DECODE(depre_tr_ac,NULL,0,depre_tr_ac)               AS depre_tr_ac,
  DECODE(DEPRE_UPTO_DATE,NULL,0,DEPRE_UPTO_DATE)       AS DEPRE_UPTO_DATE,
  DECODE(net_depre_cost,NULL,0,net_depre_cost)         AS net_depre_cost,
  decode(app_pre_yr,null,0,app_pre_yr) as app_pre_yr,
  DECODE(app_grant_recieved,NULL,0,app_grant_recieved) AS app_grant_recieved,
  DECODE(appro_during_yr,NULL,0,appro_during_yr)       AS appro_during_yr,
  DECODE(app_grant_tr,NULL,0,app_grant_tr)             AS app_grant_tr,
  DECODE(app_grant_uptodate,NULL,0,app_grant_uptodate) AS app_grant_uptodate,
  DECODE(remarks,NULL,'--',remarks)                    AS remarks,
  DECODE(particulars,NULL,'--',particulars)            AS particulars,
  DECODE(app_pre_yr,NULL,0,app_pre_yr)                 AS app_pre_yr,
  DECODE(app_grant_recieved,NULL,0,app_grant_recieved) AS app_grant_recieved,
  DECODE(appro_during_yr,NULL,0,appro_during_yr)       AS appro_during_yr,
  DECODE(app_grant_tr,NULL,0,app_grant_tr)             AS app_grant_tr,
  DECODE(app_grant_uptodate,NULL,0,app_grant_uptodate) AS app_grant_uptodate,
  b.accounting_unit_name,(select office_name from COM_MST_OFFICES where OFFICE_ID=a.ACCOUNTING_UNIT_OFFICE_ID)as officeName,
(select ASSET_MAJOR_CLASS_DESC from FAS_MST_ASSETS_CLASS where asset_major_class_code=a.asset_major_class_code)as majorDesc,
(select accounting_unit_name from fas_mst_acct_units where ACCOUNTING_UNIT_ID=$P{accunitid}) as MainUnitname
FROM fas_a52_register a INNER JOIN fas_asset_val_ac_render_units c
ON a.ACCOUNTING_UNIT_ID =c.Acct_Rendering_Unit_Id
and A.ACCOUNTING_UNIT_OFFICE_ID=C.RENDERING_UNIT_OFFICE_ID
inner join fas_mst_acct_units b  on
a.accounting_unit_id     =b.accounting_unit_id
AND a.financial_year             =$P{financialyear}
$P!{circleQry}
$P!{querp}
$P!{queryAsset} order by a.accounting_unit_id,a.accounting_unit_office_id,a.asset_major_class_code]]></queryString>

