	<queryString><![CDATA[select a.*,b.office_name from
(
select rownum,OFFICE_ID,PROJECT_ID,PROJECT_NAME,WING_ID,SCH_STATUS_DESC,CATEGORY_DESC,SCH_SNO from PMS_MST_PROJECTS_VIEW where STATUS='L'
)a
inner join
(
select office_id,office_name from com_mst_offices
)b
on a.office_id=b.office_id

order by a.OFFICE_ID,a.SCH_SNO,a.PROJECT_ID]]></queryString>

