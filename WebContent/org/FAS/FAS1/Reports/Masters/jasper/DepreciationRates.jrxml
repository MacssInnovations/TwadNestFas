	<queryString><![CDATA[select * from 
(select ASSET_CLASS_CODE,FINANCIAL_YEAR,DEPRECIATION_RATE from COM_MST_DEPRECIATION_RATES) a
inner join
(select ASSET_CLASS_CODE,ASSET_CLASS_DESC,ASSET_TYPE_CODE from COM_MST_ASSETS_CLASS) b
on a.ASSET_CLASS_CODE=b.ASSET_CLASS_CODE
inner join
(select ASSET_TYPE_CODE,ASSET_TYPE_DESC from COM_MST_ASSETS_TYPE) c
on b.ASSET_TYPE_CODE=c.ASSET_TYPE_CODE
order by a.FINANCIAL_YEAR,b.ASSET_TYPE_CODE,a.ASSET_CLASS_CODE]]></queryString>

