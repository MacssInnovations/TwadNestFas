	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="financialyear" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="assetmajclass" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="querp" isForPrompting="true" class="java.lang.String"/>
	<parameter name="queryAsset" isForPrompting="true" class="java.lang.String"/>
	<parameter name="circleQry" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT 
  asset_code,
  DECODE(open_bal_qty,NULL,0,open_bal_qty)             AS open_bal_qty,
  DECODE(opening_bal_value,NULL,0,opening_bal_value)   AS opening_bal_value,
  DECODE(RECIEPTS_YEAR_DR_QTY,NULL,0,RECIEPTS_YEAR_DR_QTY)   AS RECIEPTS_YEAR_DR_QTY,
   DECODE(RECIEPTS_YEAR_CR_QTY,NULL,0,RECIEPTS_YEAR_CR_QTY)   AS RECIEPTS_YEAR_CR_QTY,
  DECODE(RECIEPTS_YR_DR_VALUE,NULL,0,RECIEPTS_YR_DR_VALUE)   AS RECIEPTS_YR_DR_VALUE,
    DECODE(RECIEPTS_YR_CR_VALUE,NULL,0,RECIEPTS_YR_CR_VALUE)   AS RECIEPTS_YR_CR_VALUE,
    
  DECODE(ISSUES_YEAR_DR_QTY,NULL,0,ISSUES_YEAR_DR_QTY)       AS ISSUES_YEAR_DR_QTY,
  DECODE(ISSUES_YEAR_CR_QTY,NULL,0,ISSUES_YEAR_CR_QTY)       AS ISSUES_YEAR_CR_QTY,
    DECODE(ISSUES_YR_DR_VALUE,NULL,0,ISSUES_YR_DR_VALUE)       AS ISSUES_YR_DR_VALUE,
  DECODE(ISSUES_YR_CR_VALUE,NULL,0,ISSUES_YR_CR_VALUE)       AS ISSUES_YR_CR_VALUE,
  
  
decode(dep_prev_year,null,decode(app_pre_yr,null,0,app_pre_yr),0,decode(app_pre_yr,null,0,app_pre_yr),dep_prev_year)as dep_prev_year,
  --decode(depre_upto_date,null,decode(APPRO_UPTO_DATE,null,0,APPRO_UPTO_DATE),0,decode(APPRO_UPTO_DATE,null,0,APPRO_UPTO_DATE),depre_upto_date)as depre_upto_date,
 depre_upto_date,
  decode(DEPRE_ALLOWED_YR_DR,null,decode(APPRO_ALLOWED_YR_DR,null,0,APPRO_ALLOWED_YR_DR),0,decode(APPRO_ALLOWED_YR_DR,null,0,APPRO_ALLOWED_YR_DR),DEPRE_ALLOWED_YR_DR)as DEPRE_ALLOWED_YR_DR,
  decode(DEPRE_ALLOWED_YR_CR,null,decode(APPRO_ALLOWED_YR_CR,null,0,APPRO_ALLOWED_YR_CR),0,decode(APPRO_ALLOWED_YR_CR,null,0,APPRO_ALLOWED_YR_CR),DEPRE_ALLOWED_YR_CR)as DEPRE_ALLOWED_YR_CR,
  
  decode(depre_rec_ac,null,decode(APP_REC_AC,null,0,APP_REC_AC),0,decode(APP_REC_AC,null,0,APP_REC_AC),depre_rec_ac)as depre_rec_ac,
 decode(depre_tr_ac,null,decode(APPRO_TR_AC,null,0,APPRO_TR_AC),0,decode(APPRO_TR_AC,null,0,APPRO_TR_AC),depre_tr_ac)as depre_tr_ac,
  DECODE(net_depre_cost,NULL,0,net_depre_cost)         AS net_depre_cost,
  DECODE(remarks,NULL,'--',remarks)                    AS remarks,
  b.accounting_unit_name,
 case when a.accounting_unit_office_id!=5000 then
(SELECT OFFICE_NAME FROM com_mst_offices where OFFICE_ID=a.accounting_unit_office_id)
else 
(select accounting_unit_name from FAS_MST_ACCT_UNITS where ACCOUNTING_UNIT_OFFICE_ID=a.accounting_unit_office_id )
end as officeName,
(select ASSET_MAJOR_CLASS_DESC from FAS_MST_ASSETS_CLASS where asset_major_class_code=a.asset_major_class_code)as majorDesc,
(select accounting_unit_name from fas_mst_acct_units where ACCOUNTING_UNIT_ID=$P{accunitid}) as MainUnitname
FROM FAS_A52_REGISTER_EDIT a INNER JOIN fas_asset_val_ac_render_units c
ON a.ACCOUNTING_UNIT_ID =c.Acct_Rendering_Unit_Id
and A.ACCOUNTING_UNIT_OFFICE_ID=C.RENDERING_UNIT_OFFICE_ID
and a.office_wing_sino =c.office_wing_sino
inner join fas_mst_acct_units b  on
a.accounting_unit_id     =b.accounting_unit_id
AND a.financial_year             =$P{financialyear}
$P!{circleQry}
$P!{queryAsset}
$P!{querp} 
order by a.asset_major_class_code,a.accounting_unit_office_id,c.ACCT_UNIT_ID_RENDERED_FOR,a.asset_code
--a.accounting_unit_id,]]></queryString>

