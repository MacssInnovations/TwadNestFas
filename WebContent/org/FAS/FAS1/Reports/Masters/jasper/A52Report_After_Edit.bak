	<variable name="tot_qty" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{OPEN_BAL_QTY}.add( $F{RECIEPTS_YEAR_DR_QTY} ).subtract($F{RECIEPTS_YEAR_CR_QTY} )]]></variableExpression>
	</variable>
	<variable name="tot_value" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
