	<parameter name="accounting_for_office_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accounting_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select 
   sl.ASSET_CODE  ,
   sl.ALIAS_CODE  , 
   sl.ASSET_DESCRIPTION , 
   ( nvl(sl.MONTH_OF_PURCHASE,0) ||' / '|| nvl(sl.YEAR_OF_PURCHASE,0) ) as my_of_purchase ,  
   sl.ORIGINAL_COST , 
   sl.CURRENT_VALUE ,

   class.ASSET_CLASS_DESC , 
   type.ASSET_TYPE_DESC  
   
from 
   COM_MST_ASSETS_SL     sl , 
   COM_MST_ASSETS_CLASS  class , 
   COM_MST_ASSETS_TYPE   type 

where
   sl.ACCOUNTING_UNIT_ID       =   $P{accounting_unit_id}             and 
   sl.ACCOUNTING_FOR_OFFICE_ID =   $P{accounting_for_office_id}       and

   sl.ASSET_TYPE_CODE          =   type.ASSET_TYPE_CODE               and
   sl.ASSET_CLASS_CODE         =   class.ASSET_CLASS_CODE

order by  type.ASSET_TYPE_DESC,class.ASSET_CLASS_DESC, sl.ASSET_CODE asc]]></queryString>

