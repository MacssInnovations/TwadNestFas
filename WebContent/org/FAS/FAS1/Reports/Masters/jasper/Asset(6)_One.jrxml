	<parameter name="Unit_Code" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fin_year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="major" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT reg.ACCOUNTING_UNIT_ID,
  reg.ASSET_MAJOR_CLASS_CODE,
  (SELECT ACCOUNTING_UNIT_NAME
  FROM FAS_MST_ACCT_UNITS acct
  WHERE acct.ACCOUNTING_UNIT_ID=reg.ACCOUNTING_UNIT_ID
  )AS ACCOUNTING_UNIT_Desc,
  (SELECT ASSET_MAJOR_CLASS_DESC
  FROM FAS_MST_ASSETS_CLASS
  WHERE ASSET_MAJOR_CLASS_CODE=reg.ASSET_MAJOR_CLASS_CODE
  )AS ASSET_MAJOR_CLASS_Desc,
  --(SELECT ACCOUNT_HEAD_CODE
 -- FROM FAS_ASSET_AC_HEADS
 -- WHERE ASSET_MAJOR_CLASS_CODE=reg.ASSET_MAJOR_CLASS_CODE
  --)                                       AS FAS_ASSET_AC_HEADS,
 OPENING_BAL_VALUE                AS ori_cost,
DEPRE_ALLOWED_YR                 AS for_the_year,
(DEPRE_ALLOWED_YR+DEP_PREV_YEAR) AS up_to_date,
NET_DEPRE_COST                   AS dep_cost,
  PARTICULARS
FROM FAS_A52_REGISTER reg
WHERE ACCOUNTING_UNIT_ID =57
AND FINANCIAL_YEAR       ='2011-12'


order by reg.ASSET_MAJOR_CLASS_CODE]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ASSET_MAJOR_CLASS_CODE" class="java.math.BigDecimal"/>
