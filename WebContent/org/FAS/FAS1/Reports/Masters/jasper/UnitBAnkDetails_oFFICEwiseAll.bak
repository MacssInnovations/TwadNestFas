	<parameter name="qry" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Oper_Mode" isForPrompting="false" class="java.lang.String"/>
	<parameter name="status" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT ACCOUNTING_UNIT_ID,
(SELECT u.accounting_unit_name FROM fas_mst_acct_units U WHERE u.accounting_unit_id=BB.ACCOUNTING_UNIT_ID )accounting_unit_name,
  BANK_ID,
  (SELECT BANK_SHORT_NAME FROM FAS_MST_BANKS br WHERE br.bank_id=bb.bank_id
  )AS BANK_NAME,
  BRANCH_ID,
  (SELECT BRANCH_NAME
  FROM FAS_MST_BANK_BRANCHES br
  WHERE br.bank_id =bb.bank_id
  AND br.branch_id = bb.branch_id
  )AS BRANCH_NAME,
  BANK_AC_TYPE_ID,
  (SELECT ACCOUNT_TYPE FROM FAS_MST_BANK_AC_TYPES T WHERE t.account_type_id= BB.BANK_AC_TYPE_ID)ACCOUNT_TYPE,
  AC_OPERATIONAL_MODE_ID,
  (SELECT AC_OPERATIONAL_MODE
  FROM FAS_MST_AC_OPER_MODES M
  WHERE m.ac_operational_mode_id=bb.ac_operational_mode_id
  )                                     AS AC_OPERATIONAL_MODE,
 AC_OPENING_DATE,
  INITIAL_DEPOSIT_AMT,
  STATUS,
  CLOSED_DATE,
  BANK_AC_NO
FROM FAS_MST_BANK_BALANCE bb

$P!{qry}
ORDER BY ACCOUNTING_UNIT_ID,STATUS,ac_operational_mode_id,BANK_ID]]></queryString>

