left outer join
(select MAJOR_HEAD_CODE,MAJOR_HEAD_DESC from COM_MST_MAJOR_HEADS ) b
on a.MAJOR_HEAD_CODE=b.MAJOR_HEAD_CODE
left outer join
(select MAJOR_HEAD_CODE,MINOR_HEAD_CODE,MINOR_HEAD_DESC from COM_MST_MINOR_HEADS 
MINOR_HEAD_CODE) c
on a.MINOR_HEAD_CODE =c.MINOR_HEAD_CODE
order by a.MAJOR_HEAD_CODE,a.MINOR_HEAD_CODE,ACCOUNT_HEAD_CODE]]></queryString>

