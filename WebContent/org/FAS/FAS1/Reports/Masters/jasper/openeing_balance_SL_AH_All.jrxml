		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,ACCOUNT_HEAD_CODE,SUB_LEDGER_TYPE_CODE,SUB_LEDGER_CODE,FINANCIAL_YEAR,YEAR,MONTH, UPTO_DEBIT_BALANCE,UPTO_CREDIT_BALANCE,
CURRENT_MONTH_DEBIT,CURRENT_MONTH_CREDIT,to_char(MONTH_CLOSING_BALANCE)as close_bal,
MONTH_CLOSING_BAL_DR_CR_IND from FAS_SUB_LEDGER_MASTER
) a
inner join
(select (ACCOUNT_HEAD_CODE||'-'||ACCOUNT_HEAD_DESC)as accnt_head_name,ACCOUNT_HEAD_CODE,ACCOUNT_HEAD_DESC from COM_MST_ACCOUNT_HEADS b
) b 
on a.ACCOUNT_HEAD_CODE=b.ACCOUNT_HEAD_CODE
inner join
( select OFFICE_NAME,office_id from com_mst_offices c
) c 
on a.ACCOUNTING_FOR_OFFICE_ID=c.office_id
inner join
(select ACCOUNTING_UNIT_NAME,ACCOUNTING_UNIT_ID from ACCOUNTING_UNITS_DATA d
)d 
on a.ACCOUNTING_UNIT_ID=d.ACCOUNTING_UNIT_ID
inner join
(select SUB_LEDGER_TYPE_CODE,SUB_LEDGER_TYPE_DESC from COM_MST_SL_TYPES
)e 
on a.SUB_LEDGER_TYPE_CODE=e.SUB_LEDGER_TYPE_CODE
inner join
(select SL_TYPE,SL_CODE,SL_CODENAME from SL_TYPE_CODE_NAME_VIEW_M
)f 
on a.SUB_LEDGER_CODE=f.SL_CODE and e.SUB_LEDGER_TYPE_CODE=f.SL_TYPE
where a.ACCOUNTING_FOR_OFFICE_ID in($P{accountofficeid})
and a.ACCOUNTING_UNIT_ID in ($P{accountingunitid})

and a.year in ($P{cashbookyear})
and a.month in ($P{cashbookmonth})
order by a.ACCOUNTING_FOR_OFFICE_ID,SUB_LEDGER_TYPE_CODE,SUB_LEDGER_CODE]]></queryString>

