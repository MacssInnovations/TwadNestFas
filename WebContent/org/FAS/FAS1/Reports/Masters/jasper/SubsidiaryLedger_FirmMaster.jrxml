	<queryString><![CDATA[select * from
(
select ACCOUNTING_UNIT_ID,ACCOUNTING_FOR_OFFICE_ID,FIRMS_ID,FIRMS_NAME,decode(FIRMS_ADDRESS,null,'-',FIRMS_ADDRESS)FIRMS_ADDRESS,
decode(FIRMS_PHONE,null,0,FIRMS_PHONE)FIRMS_PHONE,decode(FIRMS_FAX,null,0,FIRMS_FAX)FIRMS_FAX,
decode(FIRMS_EMAIL_ID,null,'-',FIRMS_EMAIL_ID)FIRMS_EMAIL_ID from COM_FIRMS_SL_MST
) a
inner join
(
select ACCOUNTING_UNIT_ID,ACCOUNTING_UNIT_NAME,ACCOUNTING_UNIT_OFFICE_ID from FAS_MST_ACCT_UNITS 
) b
on a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID 
inner join
(
select OFFICE_ID,OFFICE_NAME from COM_MST_OFFICES
) c
on a.ACCOUNTING_FOR_OFFICE_ID=c.OFFICE_ID
ORDER BY a.ACCOUNTING_FOR_OFFICE_ID]]></queryString>

