	<parameter name="finyear" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select ACCOUNTING_UNIT_ID,
accounting_for_office_id,
financial_year,
a52_status_val,
a52_date_val,
a52_status_qty,
A52_DATE_QTY,
(SELECT cc.Accounting_Unit_Name
  FROM fas_mst_acct_units cc
  where cc.accounting_unit_id=a.accounting_unit_id
  )as unitname
from FAS_A52_AA52_VERIFY_STATUS a where a52_status_qty='Y' 
and FINANCIAL_YEAR=$P{finyear} order by ACCOUNTING_UNIT_ID]]></queryString>

