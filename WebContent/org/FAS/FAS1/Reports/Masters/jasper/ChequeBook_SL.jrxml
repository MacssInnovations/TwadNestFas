	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[SELECT *
FROM
  (SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    BANK_ID,
    BRANCH_ID,
    ACCOUNT_NO,
    CHEQUE_BOOK_CODE,
    NO_OF_LEAVES,
    START_LEAF_NO,
    END_LEAF_NO,
    VERIFIED_BY,
    (SELECT EMPLOYEE_NAME
    FROM HRM_MST_EMPLOYEES un
    WHERE un.EMPLOYEE_ID=VERIFIED_BY
    ) AS verified
  FROM COM_MST_CHEQUE_BOOKS_SL
  ) a
INNER JOIN
  (SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_UNIT_NAME,
    ACCOUNTING_UNIT_OFFICE_ID
  FROM FAS_MST_ACCT_UNITS
  ) b
ON a.ACCOUNTING_UNIT_ID=b.ACCOUNTING_UNIT_ID
INNER JOIN
  ( SELECT OFFICE_ID,OFFICE_NAME FROM COM_MST_OFFICES
  ) c
ON a.ACCOUNTING_FOR_OFFICE_ID=c.OFFICE_ID
INNER JOIN
  ( SELECT BANK_ID,BANK_NAME FROM FAS_MST_BANKS
  ) d
ON a.BANK_ID=d.BANK_ID
INNER JOIN
  ( SELECT BANK_ID,BRANCH_ID,BRANCH_NAME FROM FAS_MST_BANK_BRANCHES
  ) e
ON d.BANK_ID   =e.BANK_ID
AND a.BRANCH_ID=e.BRANCH_ID
LEFT OUTER JOIN
  (SELECT ACCOUNTING_UNIT_ID,
    BANK_ID,
    BRANCH_ID,
    BANK_AC_NO,
    AC_OPERATIONAL_MODE_ID
  FROM FAS_MST_BANK_BALANCE
  )s
ON a.ACCOUNTING_UNIT_ID=s.ACCOUNTING_UNIT_ID
AND a.BANK_ID          =s.BANK_ID
AND a.BRANCH_ID        =s.BRANCH_ID
AND a.ACCOUNT_NO       =s.BANK_AC_NO
ORDER BY a.ACCOUNTING_UNIT_ID,
  a.BANK_ID,
  a.BRANCH_ID,
  a.ACCOUNT_NO,
  a.CHEQUE_BOOK_CODE]]></queryString>

