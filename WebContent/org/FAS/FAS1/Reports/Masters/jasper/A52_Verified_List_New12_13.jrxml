	<parameter name="finyear" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select rownum as slno,ver_unit,ver_off,status,unitid,officeid,officename,circleid,circle_name from 
(select 
rownum as slno,
  a.accounting_unit_id ver_unit,
  a.accounting_for_office_id ver_off,
  decode(a.accounting_for_office_id,null,'Pending','Completed') as status,
   b.acct_unit_id_rendered_for as unitid,
  b.rendering_unit_office_id as officeid,
  (select s.office_name from com_mst_offices s where s.office_id=b.rendering_unit_office_id)as officename,
  b.acct_rendering_unit_id   as circleid,
  (select u.accounting_unit_name from fas_mst_acct_units u where u.accounting_unit_id=b.acct_rendering_unit_id)as circle_name
from FAS_A52_REGISTER_STATUS a
right outer JOIN fas_asset_val_ac_render_units b
on (a.accounting_for_office_id=b.rendering_unit_office_id
and a.accounting_unit_id      =b.acct_unit_id_rendered_for and a.financial_year        =$P{finyear} and a.A52_STATUS_UNIT         ='Y')
order by circleid,officeid)]]></queryString>

	<field name="SLNO" class="java.math.BigDecimal"/>
	<field name="VER_UNIT" class="java.math.BigDecimal"/>
	<field name="VER_OFF" class="java.math.BigDecimal"/>
	<field name="STATUS" class="java.lang.String"/>
	<field name="UNITID" class="java.math.BigDecimal"/>
