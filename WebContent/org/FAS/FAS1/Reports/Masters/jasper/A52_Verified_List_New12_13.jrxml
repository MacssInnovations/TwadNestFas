	<style 
		name="statusFreeze"
		isDefault="true"
	>

		<conditionalStyle>
			<conditionExpression><![CDATA[new Boolean($F{STATUS}.equalsIgnoreCase("Completed") == true)]]></conditionExpression>
			<style 
				name="statusFreeze"
				isDefault="false"
				mode="Opaque"
				forecolor="#48CA2D"
			>
			</style>
		</conditionalStyle>
			<conditionalStyle>
				<conditionExpression><![CDATA[new Boolean($F{STATUS}.equalsIgnoreCase("Pending") == true)]]></conditionExpression>
				<style 
					name="statusFreeze"
					isDefault="false"
					mode="Opaque"
					forecolor="#F92301"
