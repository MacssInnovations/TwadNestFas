<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="AA52_Verified_List_New"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<style 
		name="statusCheck"
		isDefault="true"
	>

		<conditionalStyle>
			<conditionExpression><![CDATA[new Boolean($F{STATUS}.equalsIgnoreCase("Completed") == true)]]></conditionExpression>
			<style 
				name="statusCheck"
				isDefault="false"
				mode="Opaque"
				forecolor="#328B1C"
			>
			</style>
		</conditionalStyle>
			<conditionalStyle>
				<conditionExpression><![CDATA[new Boolean($F{STATUS}.equalsIgnoreCase("Pending") == true)]]></conditionExpression>
				<style 
					name="statusCheck"
					isDefault="false"
					mode="Opaque"
					forecolor="#F11016"
				>
				</style>
			</conditionalStyle>
	</style>
	<style 
		name="Common"
		isDefault="false"
		forecolor="#150909"
	>
	</style>

	<parameter name="finyear" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select rownum as slno,ver_unit,ver_off,status,unitid,officeid,officename,circleid,circle_name from 
(select 
rownum as slno,
  a.accounting_unit_id ver_unit,
  a.accounting_for_office_id ver_off,
  decode(a.accounting_for_office_id,null,'Pending','Completed') as status,
   b.acct_unit_id_rendered_for as unitid,
  b.rendering_unit_office_id as officeid,
  (select s.office_name from com_mst_offices s where s.office_id=b.rendering_unit_office_id)as officename,
  b.acct_rendering_unit_id   as circleid,
  (select u.accounting_unit_name from fas_mst_acct_units u where u.accounting_unit_id=b.acct_rendering_unit_id)as circle_name
from FREEZE_AA52_STATUS a
right outer JOIN fas_asset_val_ac_render_units b
on (a.accounting_for_office_id=b.rendering_unit_office_id
and a.accounting_unit_id      =b.acct_unit_id_rendered_for and a.financial_year        =$P{finyear}
and a.AA52_STATUS_UNIT          ='Y')
order by circleid,officeid)]]></queryString>

	<field name="SLNO" class="java.math.BigDecimal"/>
	<field name="VER_UNIT" class="java.math.BigDecimal"/>
	<field name="VER_OFF" class="java.math.BigDecimal"/>
	<field name="STATUS" class="java.lang.String"/>
	<field name="UNITID" class="java.math.BigDecimal"/>
	<field name="OFFICEID" class="java.math.BigDecimal"/>
	<field name="OFFICENAME" class="java.lang.String"/>
	<field name="CIRCLEID" class="java.math.BigDecimal"/>
	<field name="CIRCLE_NAME" class="java.lang.String"/>


		<group  name="circleid" >
			<groupExpression><![CDATA[$F{CIRCLEID}]]></groupExpression>
