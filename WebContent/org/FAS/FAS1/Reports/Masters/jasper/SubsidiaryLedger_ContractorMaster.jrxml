	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="date" isForPrompting="false" class="java.util.Date"/>
	<queryString><![CDATA[SELECT *
FROM
  (SELECT OFFICE_ID,
    CONTRACTOR_ID,
    CONTRACTOR_NAME,
    DECODE(ADDRESS,NULL,'-',ADDRESS)ADDRESS,
    decode(phone,null,'-',phone)phone,
    DECODE(EMAIL,NULL,'-',EMAIL)EMAIL
  FROM PMS_CONT_REQUEST_REGN
  ) a
INNER JOIN
  ( SELECT OFFICE_ID,OFFICE_NAME FROM COM_MST_OFFICES
  ) b
on a.office_id=b.office_id
WHERE A.OFFICE_ID=$P{officeid}]]></queryString>

