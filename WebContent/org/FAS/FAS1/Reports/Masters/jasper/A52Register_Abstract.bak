	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="financialyear" isForPrompting="true" class="java.lang.String"/>
	<parameter name="accunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="assetmajclass" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="querp" isForPrompting="true" class="java.lang.String"/>
	<parameter name="queryAsset" isForPrompting="true" class="java.lang.String"/>
	<parameter name="circleQry" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT asset_major_class_code,ACCOUNTING_UNIT_ID,
 (SELECT cc.Accounting_Unit_Name
  FROM fas_mst_acct_units cc
  WHERE CC.ACCOUNTING_UNIT_ID=A.ACCOUNTING_UNIT_ID
  )AS unitname,
 (SELECT bb.ASSET_MAJOR_CLASS_DESC
  FROM FAS_MST_ASSETS_CLASS bb
  WHERE BB.ASSET_MAJOR_CLASS_CODE=A.ASSET_MAJOR_CLASS_CODE
  )AS asset_MAJOR_CLASS_DESC,
decode(SUM(OPEN_BAL_QTY),null,0,SUM(OPEN_BAL_QTY))AS OPEN_BAL_QTY,
decode(SUM(OPENING_BAL_VALUE),null,0,SUM(OPENING_BAL_VALUE))AS OPENING_BAL_VALUE,
decode(SUM(RECIEPTS_YEAR_DR_QTY),null,0,SUM(RECIEPTS_YEAR_DR_QTY))AS RECIEPTS_YEAR_DR_QTY,
decode(SUM(RECIEPTS_YEAR_CR_QTY),null,0,SUM(RECIEPTS_YEAR_CR_QTY))AS RECIEPTS_YEAR_CR_QTY,
decode(SUM(RECIEPTS_YR_DR_VALUE),null,0,SUM(RECIEPTS_YR_DR_VALUE))AS RECIEPTS_YR_DR_VALUE,
decode(SUM(RECIEPTS_YR_CR_VALUE),null,0,SUM(RECIEPTS_YR_CR_VALUE))AS RECIEPTS_YR_CR_VALUE,
decode(SUM(ISSUES_YEAR_DR_QTY),null,0,SUM(ISSUES_YEAR_DR_QTY))AS ISSUES_YEAR_DR_QTY,
decode(SUM(ISSUES_YEAR_CR_QTY),null,0,SUM(ISSUES_YEAR_CR_QTY)) AS ISSUES_YEAR_CR_QTY,
decode(SUM(ISSUES_YR_DR_VALUE),null,0,SUM(ISSUES_YR_DR_VALUE))AS ISSUES_YR_DR_VALUE,
decode(SUM(ISSUES_YR_CR_VALUE),null,0,SUM(ISSUES_YR_CR_VALUE)) AS ISSUES_YR_CR_VALUE,



 
decode(sum(dep_prev_year),null,decode(sum(app_pre_yr),null,0,sum(app_pre_yr)),0,decode(sum(app_pre_yr),null,0,sum(app_pre_yr)),sum(dep_prev_year))as dep_prev_year,
--decode(sum(depre_upto_date),null,decode(sum(APPRO_UPTO_DATE),null,0,sum(APPRO_UPTO_DATE)),0,decode(sum(APPRO_UPTO_DATE),null,0,sum(APPRO_UPTO_DATE)),sum(depre_upto_date))as depre_upto_date,
 sum( decode((Depre_Upto_Date),0,Appro_Upto_Date,Depre_Upto_Date)) as Depre_Upto_Date,
decode(sum(DEPRE_ALLOWED_YR_DR),null,decode(sum(APPRO_ALLOWED_YR_DR),null,0,sum(APPRO_ALLOWED_YR_DR)),0,decode(sum(APPRO_ALLOWED_YR_DR),null,0,sum(APPRO_ALLOWED_YR_DR)),sum(DEPRE_ALLOWED_YR_DR))as DEPRE_ALLOWED_YR_DR,
decode(sum(DEPRE_ALLOWED_YR_CR),null,decode(sum(APPRO_ALLOWED_YR_CR),null,0,sum(APPRO_ALLOWED_YR_CR)),0,decode(sum(APPRO_ALLOWED_YR_CR),null,0,sum(APPRO_ALLOWED_YR_CR)),sum(DEPRE_ALLOWED_YR_CR))as DEPRE_ALLOWED_YR_CR,
 
 decode(sum(depre_rec_ac),null,decode(sum(APP_REC_AC),null,0,sum(APP_REC_AC)),0,decode(sum(APP_REC_AC),null,0,sum(APP_REC_AC)),sum(depre_rec_ac))as depre_rec_ac,
 decode(sum(depre_tr_ac),null,decode(sum(APPRO_TR_AC),null,0,sum(APPRO_TR_AC)),0,decode(sum(APPRO_TR_AC),null,0,sum(APPRO_TR_AC)),sum(depre_tr_ac))as depre_tr_ac,
 
 

--decode(SUM(DEP_PREV_YEAR),null,0,SUM(DEP_PREV_YEAR))AS DEP_PREV_YEAR,
--decode(SUM(DEPRE_REC_AC),null,0,SUM(DEPRE_REC_AC))AS DEPRE_REC_AC,
--decode(SUM(DEPRE_ALLOWED_YR),null,0,SUM(DEPRE_ALLOWED_YR))AS DEPRE_ALLOWED_YR,
--decode(SUM(DEPRE_TR_AC),null,0,SUM(DEPRE_TR_AC))AS DEPRE_TR_AC,
--decode(SUM(DEPRE_UPTO_DATE),null,0,SUM(DEPRE_UPTO_DATE))AS DEPRE_UPTO_DATE,
--
--DECODE(SUM(APP_PRE_YR),NULL,0,SUM(APP_PRE_YR))AS APP_PRE_YR,
--DECODE(SUM(APP_GRANT_RECIEVED),NULL,0,SUM(APP_GRANT_RECIEVED))AS APP_GRANT_RECIEVED,
--DECODE(SUM(APPRO_DURING_YR),NULL,0,SUM(APPRO_DURING_YR))AS APPRO_DURING_YR,
--DECODE(SUM(APP_GRANT_TR),NULL,0,SUM(APP_GRANT_TR))AS APP_GRANT_TR,
--decode(SUM(APP_GRANT_UPTODATE),null,0,SUM(APP_GRANT_UPTODATE))AS APP_GRANT_UPTODATE


DECODE(SUM(NET_DEPRE_COST),NULL,0,SUM(NET_DEPRE_COST))AS NET_DEPRE_COST

FROM FAS_A52_REGISTER_EDIT a INNER JOIN fas_asset_val_ac_render_units c
on a.accounting_unit_id =c.acct_rendering_unit_id
and A.ACCOUNTING_UNIT_OFFICE_ID=C.RENDERING_UNIT_OFFICE_ID
and a.office_wing_sino =c.office_wing_sino
WHERE  $P!{circleQry}
FINANCIAL_YEAR = $P{financialyear}
group by ASSET_MAJOR_CLASS_CODE,ACCOUNTING_UNIT_ID
order by ASSET_MAJOR_CLASS_CODE]]></queryString>

	<field name="ASSET_MAJOR_CLASS_CODE" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="UNITNAME" class="java.lang.String"/>
	<field name="ASSET_MAJOR_CLASS_DESC" class="java.lang.String"/>
	<field name="OPEN_BAL_QTY" class="java.math.BigDecimal"/>
	<field name="OPENING_BAL_VALUE" class="java.math.BigDecimal"/>
	<field name="RECIEPTS_YEAR_DR_QTY" class="java.math.BigDecimal"/>
	<field name="RECIEPTS_YEAR_CR_QTY" class="java.math.BigDecimal"/>
	<field name="RECIEPTS_YR_DR_VALUE" class="java.math.BigDecimal"/>
	<field name="RECIEPTS_YR_CR_VALUE" class="java.math.BigDecimal"/>
	<field name="ISSUES_YEAR_DR_QTY" class="java.math.BigDecimal"/>
	<field name="ISSUES_YEAR_CR_QTY" class="java.math.BigDecimal"/>
	<field name="ISSUES_YR_DR_VALUE" class="java.math.BigDecimal"/>
	<field name="ISSUES_YR_CR_VALUE" class="java.math.BigDecimal"/>
	<field name="DEP_PREV_YEAR" class="java.math.BigDecimal"/>
	<field name="DEPRE_UPTO_DATE" class="java.math.BigDecimal"/>
	<field name="DEPRE_ALLOWED_YR_DR" class="java.math.BigDecimal"/>
	<field name="DEPRE_ALLOWED_YR_CR" class="java.math.BigDecimal"/>
	<field name="DEPRE_REC_AC" class="java.math.BigDecimal"/>
	<field name="DEPRE_TR_AC" class="java.math.BigDecimal"/>
	<field name="NET_DEPRE_COST" class="java.math.BigDecimal"/>

	<variable name="tot_qty" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{OPEN_BAL_QTY}.add( $F{RECIEPTS_YEAR_DR_QTY} ).subtract($F{RECIEPTS_YEAR_CR_QTY} )]]></variableExpression>
	</variable>
	<variable name="tot_value" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{OPENING_BAL_VALUE}.add( $F{RECIEPTS_YR_DR_VALUE} ).subtract($F{RECIEPTS_YR_CR_VALUE} )]]></variableExpression>
	</variable>
	<variable name="cb_qty" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{tot_qty}.subtract( $F{ISSUES_YEAR_CR_QTY} ).add($F{ISSUES_YEAR_DR_QTY} )]]></variableExpression>
	</variable>
	<variable name="cb_value" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$V{tot_value}.subtract( $F{ISSUES_YR_CR_VALUE} ).add($F{ISSUES_YR_DR_VALUE} )]]></variableExpression>
	</variable>
	<variable name="tot_dep_or_app" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[($F{DEP_PREV_YEAR}.add( $F{DEPRE_REC_AC} )).add( $F{DEPRE_ALLOWED_YR_CR} ).subtract( $F{DEPRE_ALLOWED_YR_DR})]]></variableExpression>
	</variable>
	<variable name="grand_ob_qty_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{OPEN_BAL_QTY}]]></variableExpression>
	</variable>
	<variable name="grand_ob_value_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{OPENING_BAL_VALUE}]]></variableExpression>
	</variable>
	<variable name="grand_rec_dr_qty_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{RECIEPTS_YEAR_DR_QTY}]]></variableExpression>
	</variable>
	<variable name="grand_rec_cr_qty_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{RECIEPTS_YEAR_CR_QTY}]]></variableExpression>
	</variable>
	<variable name="grand_rec_dr_val_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{RECIEPTS_YR_DR_VALUE}]]></variableExpression>
	</variable>
	<variable name="grand_rec_cr_val_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{RECIEPTS_YR_CR_VALUE}]]></variableExpression>
	</variable>
	<variable name="grand_tot_qty_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$V{tot_qty}]]></variableExpression>
	</variable>
	<variable name="grand_tot_value_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$V{tot_value}]]></variableExpression>
	</variable>
	<variable name="grand_iss_dr_qty_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{ISSUES_YEAR_DR_QTY}]]></variableExpression>
	</variable>
	<variable name="grand_iss_cr_qty_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{ISSUES_YEAR_CR_QTY}]]></variableExpression>
	</variable>
	<variable name="grand_iss_dr_val_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{ISSUES_YR_DR_VALUE}]]></variableExpression>
	</variable>
	<variable name="grand_iss_cr_val_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{ISSUES_YR_CR_VALUE}]]></variableExpression>
	</variable>
	<variable name="grand_cb_qty_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$V{cb_qty}]]></variableExpression>
	</variable>
	<variable name="grand_cb_value_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$V{cb_value}]]></variableExpression>
	</variable>
	<variable name="grand_dep_pre_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEP_PREV_YEAR}]]></variableExpression>
	</variable>
	<variable name="grand_dep_rec_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPRE_REC_AC}]]></variableExpression>
	</variable>
	<variable name="grand_dep_allow_dr_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPRE_ALLOWED_YR_DR}]]></variableExpression>
	</variable>
	<variable name="grand_dep_allow_cr_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPRE_ALLOWED_YR_CR}]]></variableExpression>
	</variable>
	<variable name="grand_tot_dep_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$V{tot_dep_or_app}]]></variableExpression>
	</variable>
	<variable name="grand_dep_tr_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPRE_TR_AC}]]></variableExpression>
	</variable>
	<variable name="grand_dep_upto_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPRE_UPTO_DATE}]]></variableExpression>
	</variable>
	<variable name="grand_netcost_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{NET_DEPRE_COST}]]></variableExpression>
	</variable>
