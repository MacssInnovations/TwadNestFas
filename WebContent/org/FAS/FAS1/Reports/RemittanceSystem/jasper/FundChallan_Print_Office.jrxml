	<parameter name="challanDate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="cmbAcc_UnitCode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cmbOffice_code" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="challanNo" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select d.accounting_unit_name,b.bank_name,c.branch_name,a.OFFICE_ACCOUNT_NO,
trim(to_char(a.TOTAL_AMOUNT,'99999999999999.99')) as TOTAL_AMOUNT,numtochar(a.TOTAL_AMOUNT) 
as amt_words,a.challan_no,a.challan_date from FAS_FUND_RECEIPT_BY_OFFICE a,fas_mst_banks b,fas_mst_bank_branches c,
FAS_MST_ACCT_UNITS d 
where  a.OFFICE_BANK_ID=b.bank_id and a.OFFICE_BRANCH_ID=c.branch_id and a.OFFICE_BANK_ID=c.bank_id  
and a.accounting_unit_id=d.accounting_unit_id  
and a.accounting_unit_id=$P{cmbAcc_UnitCode} and a.accounting_for_office_id=$P{cmbOffice_code} 
and a.challan_no=$P{challanNo} and  a.challan_date=$P{challanDate}]]></queryString>

