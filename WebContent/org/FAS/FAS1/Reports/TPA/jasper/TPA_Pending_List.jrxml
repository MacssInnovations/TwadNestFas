	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="unitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="tpatype" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthwords" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.*,b.ACCOUNTING_UNIT_NAME as orgin_unit,c.accounting_unit_name as accepting_unit from
(select mst.VOUCHER_DATE,mst.ACCOUNTING_UNIT_ID,mst.TRF_ACCOUNTING_UNIT_ID,mst.particulars,trn.AMOUNT,
mst.REASON_FOR_NOT_ACCEPTING,decode(mst.acceptance_status,null,'P',mst.acceptance_status) as status,mst.accept_voucher_date from fas_tpa_master mst,FAS_TPA_TRANSACTION trn where mst.status='L' and 
mst.ACCOUNTING_UNIT_ID=trn.ACCOUNTING_UNIT_ID and mst.accounting_for_office_id=trn.accounting_for_office_id
and mst.cashbook_month=trn.cashbook_month and mst.cashbook_year=trn.cashbook_year and mst.VOUCHER_NO=trn.VOUCHER_NO
and mst.ACCOUNTING_UNIT_ID=$P{unitid} and mst.accounting_for_office_id=$P{officeid} and mst.cashbook_month=$P{cashmonth} and mst.cashbook_year=$P{cashyear} 
and mst.tpa_type=$P{tpatype} and trn.sl_no=1 and  (mst.acceptance_status='N' or mst.acceptance_status is null) )a
left outer join FAS_MST_ACCT_UNITS b on a.ACCOUNTING_UNIT_ID=b.accounting_unit_id  
left outer join FAS_MST_ACCT_UNITS c on c.ACCOUNTING_UNIT_ID=a.TRF_ACCOUNTING_UNIT_ID]]></queryString>

