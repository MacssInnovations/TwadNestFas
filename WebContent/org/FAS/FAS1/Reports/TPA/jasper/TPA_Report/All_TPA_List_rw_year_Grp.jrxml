<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="All_TPA_List_rw_year_Grp"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="992"
		 pageHeight="842"
		 columnWidth="932"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cashyear_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashmonth_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthinwords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="officeCode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashmonth_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashyear_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="type_prf" isForPrompting="false" class="java.lang.String"/>
	<parameter name="heading" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select mst.ACCOUNTING_UNIT_ID,
mst.ACCOUNTING_FOR_OFFICE_ID,
mst.CASHBOOK_MONTH,
mst.CASHBOOK_YEAR,
mst.VOUCHER_NO,
mst.TPA_TYPE,
mst.VOUCHER_DATE,
mst.TRF_ACCOUNTING_UNIT_ID,
(SELECT ACCOUNTING_UNIT_NAME
    FROM FAS_MST_ACCT_UNITS unit
    Where Unit.Accounting_Unit_Id=Mst.ACCOUNTING_UNIT_ID
    )As Orgname,
      Mst.Trf_Accounting_Unit_Id,
      (SELECT ACCOUNTING_UNIT_NAME
    FROM FAS_MST_ACCT_UNITS unit
    WHERE unit.ACCOUNTING_UNIT_ID=mst.TRF_ACCOUNTING_UNIT_ID
    )AS acceptedName,
mst.PARTICULARS,
(CASE when mst.ACCEPTANCE_STATUS='Y'
    then 'Accept'
    else 'Pending'
  end) as ACCEPTANCE_STATUS,
mst.DATE_OF_ACCEPTANCE,
mst.ORGIN_VOUCHER_NO,
mst.ORGIN_VOUCHER_DATE,
mst.ACCEPT_VOUCHER_NO,
mst.ACCEPT_VOUCHER_DATE,
mst.status,
mst2.tpa_type as acceptype,
mst2.voucher_no as accptvochno,
mst2.voucher_date as accptvochdate,
(CASE when mst2.acceptance_status='Y'
    then 'Accept'
    else 'Pending'
  end) as accptstatus,
trn.SL_NO,
trn.ACCOUNT_HEAD_CODE,
trn.CR_DR_INDICATOR,
trn.SUB_LEDGER_TYPE_CODE,
trn.SUB_LEDGER_CODE,
trn.AMOUNT,
trn.particulars as particulars1
from fas_tpa_master mst 
join fas_tpa_master mst2 
on mst.trf_accounting_unit_id=mst2.accounting_unit_id
--and mst.accounting_unit_id=mst2.trf_accounting_unit_id
and mst.accepting_slno=mst2.voucher_no
and mst.accepting_date=mst2.voucher_date
and mst.acceptance_status='Y'
,fas_tpa_transaction trn
where To_Date((mst.CASHBOOK_MONTH
  ||'-'
  || mst.CASHBOOK_YEAR),'mm-yyyy') BETWEEN To_Date($P{cashmonth_from}
  ||'-'
  ||$P{cashyear_from},'mm-yyyy')
AND to_date($P{cashmonth_to}
  ||'-'
  ||$P{cashyear_to},'mm-yyyy') and
$P!{type_prf}
 and 
 mst.accounting_for_office_id in (SELECT office_id
FROM COM_MST_ALL_OFFICES_VIEW
WHERE region_office_id =$P{officeCode}) and
trn.accounting_unit_id = mst.accounting_unit_id and
trn.accounting_for_office_id = mst.accounting_for_office_id AND 
trn.cashbook_month = mst.cashbook_month AND 
trn.cashbook_year = mst.cashbook_year AND 
trn.voucher_no = mst.voucher_no]]></queryString>

