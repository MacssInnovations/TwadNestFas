	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select 
       tb.ACCOUNTING_UNIT_ID , 
       accunit.ACCOUNTING_UNIT_NAME  , 
       tb.CASHBOOK_YEAR  , 
       tb.CASHBOOK_MONTH  , 
       tb.ACCOUNT_HEAD_CODE , 
       tb.DEBIT_OPENING_BALANCE   as dr_opening_bal ,
       tb.CREDIT_OPENING_BALANCE  as cr_opening_bal ,
       tb.CURRENT_MONTH_DEBIT     as current_month_dr ,
       tb.CURRENT_MONTH_CREDIT    as current_month_cr ,
       tb.DEBIT_CLOSING_BALANCE   as dr_closing_bal ,
      tb.CREDIT_CLOSING_BALANCE  as cr_closing_bal 
from 
       FAS_TRIAL_BALANCE tb,  FAS_MST_ACCT_UNITS accunit
where 
       tb.ACCOUNTING_UNIT_ID = $P{acc_unit_id}
   and tb.CASHBOOK_YEAR  = $P{yr}
   and tb.CASHBOOK_MONTH = $P{mon}
   and accunit.ACCOUNTING_UNIT_ID=$P{acc_unit_id}]]></queryString>

