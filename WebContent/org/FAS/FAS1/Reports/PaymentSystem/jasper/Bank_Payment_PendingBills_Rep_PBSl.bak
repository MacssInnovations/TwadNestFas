	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="recType" isForPrompting="true" class="java.lang.String"/>
	<parameter name="recNofrom" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="recNoto" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT payTrans.ACCOUNT_HEAD_CODE ,
  acchead.ACCOUNT_HEAD_DESC ,
  payMas.ACCOUNTING_UNIT_ID ,
  payMas.ACCOUNTING_FOR_OFFICE_ID,
  accUint.ACCOUNTING_UNIT_NAME,
  Office.OFFICE_NAME ,
  Office.CITY_TOWN_NAME ,
  TO_CHAR(payMas.PAYMENT_DATE,'DD/MM/YYYY') AS PAYMENT_DATE,
  payMas.VOUCHER_NO,
  payMas.PAID_TO,
  payMas.TOTAL_AMOUNT AS TOT_AMT_NO,
  payTrans.PARTICULARS,
  payTrans.AMOUNT                AS TRNS_AMOUNT,
  numtochar(payMas.TOTAL_AMOUNT) AS TOT_AMT_CHAR,
  payTrans.SUB_LEDGER_TYPE_CODE,
payTrans.SUB_LEDGER_CODE,

 (SELECT S.Sub_Ledger_Type_Desc
  FROM com_mst_sl_types s
  WHERE s.SUB_LEDGER_TYPE_CODE=payTrans.Sub_Ledger_Type_Code
  )AS sl_desc,
 
  (SELECT l.SL_CODENAME
  FROM SL_TYPE_CODE_NAME_VIEW_M l
  WHERE L.Sl_Type=payTrans.Sub_Ledger_Type_Code
  AND L.Sl_Code  =payTrans.Sub_Ledger_Code
  )AS code_desc
FROM FAS_PAYMENT_MASTER payMas,
  COM_MST_OFFICES Office,
  FAS_MST_ACCT_UNITS accUint,
  FAS_PAYMENT_TRANSACTION payTrans ,
  COM_MST_ACCOUNT_HEADS acchead
WHERE payMas.ACCOUNTING_UNIT_ID    =payTrans.ACCOUNTING_UNIT_ID
AND payMas.ACCOUNTING_FOR_OFFICE_ID=payTrans.ACCOUNTING_FOR_OFFICE_ID
AND payMas.CASHBOOK_YEAR           =payTrans.CASHBOOK_YEAR
AND payMas.CASHBOOK_MONTH          =payTrans.CASHBOOK_MONTH
AND payMas.VOUCHER_NO              =payTrans.VOUCHER_NO
AND payMas.ACCOUNTING_UNIT_ID      =accUint.ACCOUNTING_UNIT_ID
AND payMas.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID
AND payTrans.ACCOUNT_HEAD_CODE     =acchead.ACCOUNT_HEAD_CODE
 and paymas.payment_status !='C'
AND payMas.ACCOUNTING_UNIT_ID      =$P{acc_unit_id}
AND payMas.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}
AND payMas.CASHBOOK_YEAR           =$P{yr}
AND payMas.CASHBOOK_MONTH          =$P{mon}
AND payMas.VOUCHER_NO BETWEEN $P{recNofrom} AND $P{recNoto}
AND payMas.CREATED_BY_MODULE=$P{recType}]]></queryString>

