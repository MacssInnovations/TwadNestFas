	<queryString><![CDATA[select payTrans.ACCOUNT_HEAD_CODE as "ACCOUNT_HEAD_CODE",
        acchead.ACCOUNT_HEAD_DESC as "ACCOUNT_HEAD_DESC" ,
        payMas.ACCOUNTING_UNIT_ID ,
        payMas.ACCOUNTING_FOR_OFFICE_ID,
        accUint.ACCOUNTING_UNIT_NAME as "ACCOUNTING_UNIT_NAME",
        Office.OFFICE_NAME as "OFFICE_NAME",
        Office.CITY_TOWN_NAME ,        
        to_char(payMas.PAYMENT_DATE,'DD/MM/YYYY') as "PAYMENT_DATE",
        payMas.VOUCHER_NO as "VOUCHER_NO",
        payMas.PAID_TO as "PAID_TO",
        payMas.TOTAL_AMOUNT as "TOT_AMT_NO", payTrans.PARTICULARS as "PARTICULARS",
	payTrans.AMOUNT as "TRNS_AMOUNT", 
        numtochar(payMas.TOTAL_AMOUNT) as "TOT_AMT_CHAR"  
        from FAS_PAYMENT_MASTER payMas,COM_MST_OFFICES Office,
        FAS_MST_ACCT_UNITS accUint,FAS_PAYMENT_TRANSACTION payTrans ,
        COM_MST_ACCOUNT_HEADS acchead where 
        payMas.ACCOUNTING_UNIT_ID=payTrans.ACCOUNTING_UNIT_ID and 
        payMas.ACCOUNTING_FOR_OFFICE_ID=payTrans.ACCOUNTING_FOR_OFFICE_ID and 
        payMas.CASHBOOK_YEAR=payTrans.CASHBOOK_YEAR and
        payMas.CASHBOOK_MONTH=payTrans.CASHBOOK_MONTH and 
        payMas.VOUCHER_NO=payTrans.VOUCHER_NO and
        payMas.ACCOUNTING_UNIT_ID=accUint.ACCOUNTING_UNIT_ID 
        and payMas.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID and
        payTrans.ACCOUNT_HEAD_CODE=acchead.ACCOUNT_HEAD_CODE 
	and payMas.ACCOUNTING_UNIT_ID=$P{acc_unit_id}::int  and payMas.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}::int
	and payMas.CASHBOOK_YEAR=$P{yr}::int and payMas.CASHBOOK_MONTH=$P{mon}::int and payMas.VOUCHER_NO=$P{vouNO}::int 
	and payMas.CREATED_BY_MODULE=$P{recType}::varchar]]></queryString>

