	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="vou_no" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT a.voucher_no,bid,(select bank_name from fas_bank_list where bank_id=bid)bname,
  remarks,
  bank_account_no,
  cheque_number
  ||'         '
  ||cheque_date AS cheque,
  cheque_amount,
  dd_number,
  dd_in_favour_of,
  dd_amount,
  to_date(dd_date,'dd/mm/yyyy')dd_date,
  commission_charges
FROM (
  (SELECT voucher_no,
    bank_account_no,
    cheque_number,
    cheque_date,
    cheque_amount,
    remarks,
    ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH
  FROM FAS_YOURSELF_CHEQUE_MST where
ACCOUNTING_UNIT_ID=$P{accountingunitid}
AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
AND CASHBOOK_YEAR=$P{txtCB_Year}
AND CASHBOOK_MONTH=$P{txtCB_Month}
AND VOUCHER_NO=$P{vou_no}
  )a
LEFT OUTER JOIN
  (SELECT dd_number,
    dd_amount,
    dd_date,
    commission_charges,
    dd_in_favour_of,
    VOUCHER_NO,
    ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,(

select distinct bank_id from fas_mst_bank_balance WHERE accounting_unit_id=$P{accountingunitid})bid,
    CASHBOOK_MONTH
  FROM FAS_YOURSELF_CHEQUE_TRANS where
ACCOUNTING_UNIT_ID=$P{accountingunitid}
AND ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
AND CASHBOOK_YEAR=$P{txtCB_Year}
AND CASHBOOK_MONTH=$P{txtCB_Month}
AND VOUCHER_NO=$P{vou_no}
  )b
ON a.ACCOUNTING_UNIT_ID       =b.ACCOUNTING_UNIT_ID
AND a.ACCOUNTING_FOR_OFFICE_ID=b.ACCOUNTING_FOR_OFFICE_ID
AND a.CASHBOOK_YEAR           =b.CASHBOOK_YEAR
AND a.CASHBOOK_MONTH          =b.CASHBOOK_MONTH
AND a.VOUCHER_NO              =b.VOUCHER_NO )]]></queryString>

