		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="recType" isForPrompting="true" class="java.lang.String"/>
	<parameter name="intmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="intyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="imagepath" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select JourTrans.ACCOUNT_HEAD_CODE ||'--'|| acchead.ACCOUNT_HEAD_DESC as accCodeDesc, 
        JourMas.ACCOUNTING_UNIT_ID ,
        JourMas.ACCOUNTING_FOR_OFFICE_ID,
Jourmas.Remarks,
        accUint.ACCOUNTING_UNIT_NAME, Office.OFFICE_NAME ,Office.CITY_TOWN_NAME,        
        to_char(JourMas.VOUCHER_DATE,'DD/MM/YYYY') as VOUCHER_DATE,JourMas.VOUCHER_NO,
	JourTrans.SL_NO,
	JourTrans.PARTICULARS,
	JourTrans.CR_DR_INDICATOR, to_char(JourTrans.AMOUNT,'99999999999999.99') as TRNS_AMOUNT ,
	JourTrans.AMOUNT,Case When Jourtrans.Cr_Dr_Indicator='CR' Then Jourtrans.Amount Else 0 End As Cr_Total,
  Case When Jourtrans.Cr_Dr_Indicator='DR' Then Jourtrans.Amount Else 0 End As dr_Total,
   JourTrans.SUB_LEDGER_TYPE_CODE,
JourTrans.SUB_LEDGER_CODE,

 (SELECT S.Sub_Ledger_Type_Desc
  FROM com_mst_sl_types s
  WHERE s.SUB_LEDGER_TYPE_CODE=JourTrans.Sub_Ledger_Type_Code
  )AS sl_desc,
 
  (SELECT l.SL_CODENAME
  FROM SL_TYPE_CODE_NAME_VIEW_M l
  WHERE L.Sl_Type=JourTrans.Sub_Ledger_Type_Code
  AND L.Sl_Code  =JourTrans.Sub_Ledger_Code
  )AS code_desc
	from FAS_JOURNAL_MASTER JourMas,COM_MST_OFFICES Office,
        FAS_MST_ACCT_UNITS accUint,FAS_JOURNAL_TRANSACTION JourTrans,
        COM_MST_ACCOUNT_HEADS acchead where 
        JourMas.ACCOUNTING_UNIT_ID=JourTrans.ACCOUNTING_UNIT_ID and 
        JourMas.ACCOUNTING_FOR_OFFICE_ID=JourTrans.ACCOUNTING_FOR_OFFICE_ID and 
        JourMas.CASHBOOK_YEAR=JourTrans.CASHBOOK_YEAR and
        JourMas.CASHBOOK_MONTH=JourTrans.CASHBOOK_MONTH and 
        JourMas.VOUCHER_NO=JourTrans.VOUCHER_NO and
        JourMas.ACCOUNTING_UNIT_ID=accUint.ACCOUNTING_UNIT_ID 
        and JourMas.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID and
        JourTrans.ACCOUNT_HEAD_CODE=acchead.ACCOUNT_HEAD_CODE and  journal_status!='C' 
	and JourMas.ACCOUNTING_UNIT_ID=$P{acc_unit_id}  and JourMas.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}
	and JourMas.CASHBOOK_YEAR=$P{intyear} and JourMas.CASHBOOK_MONTH=$P{intmonth} 
$P!{recType}]]></queryString>

