	</variable>
	<variable name="AccHeadDescription" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{ACCOUNT_HEAD_CODE}.toString()+'-'+$F{ACCHEAD_DESC}]]></variableExpression>
	</variable>
	<variable name="Total_CRAmount" class="java.math.BigDecimal" resetType="Group" resetGroup="SL code type" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="Grand_Total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>

