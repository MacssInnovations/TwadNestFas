	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="txtCB_Month" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtfrom" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtto" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT M.Accounting_Unit_Id AS Unit_Id ,
  A.Accounting_Unit_Name,
  to_date(M.Voucher_Date)AS voucher_Date,
  T.Account_Head_Code ,
  (SELECT ACCOUNT_HEAD_DESC
  FROM com_mst_account_heads
  WHERE ACCOUNT_HEAD_CODE = t.Account_Head_Code
  )            AS acchead_desc,
  m.VOUCHER_NO AS voc_no ,
  T.Amount ,
  T.Cr_Dr_Indicator,
  M.JOURNAL_TYPE_CODE,
  (SELECT JOURNAL_TYPE_DESC
  FROM fas_mst_journal_type
  WHERE JOURNAL_TYPE_CODE = M.JOURNAL_TYPE_CODE
  )AS journal_type_desc,
  T.Sub_Ledger_Type_Code,
  (SELECT SL_CODENAME
  FROM Sl_Type_Code_Name_View_M
  WHERE Sl_Type = M.Journal_Type_Code
  AND Sl_Code   =M.Sub_Ledger_Code
  )AS SLTypedesc
FROM FAS_JOURNAL_MASTER m,
  FAS_JOURNAL_TRANSACTION t ,
  Fas_Mst_Acct_Units A,
  Fas_Mst_Journal_Type B
WHERE m.accounting_unit_id =t.accounting_unit_id
AND m.cashbook_year        = t.cashbook_year
AND m.cashbook_month       = t.cashbook_month
AND m.VOUCHER_NO           = t.VOUCHER_NO
AND M.Journal_Status       ='L'
AND M.Created_By_Module    ='LJV'
AND (t.account_head_code   =550102
OR T.Account_Head_Code     =550602)
AND T.Cb_Ref_Date         IS NULL
AND t.cb_ref_no            =0
AND M.Accounting_Unit_Id   = A.Accounting_Unit_Id
AND M.Journal_Type_Code    =B.Journal_Type_Code
And M.Accounting_Unit_Id =$P{accountingunitid}
AND M.Voucher_Date BETWEEN to_date($P{txtfrom},'DD/MM/YYYY') AND to_date($P{txtto},'DD/MM/YYYY')
ORDER BY M.JOURNAL_TYPE_CODE,
  T.Account_Head_Code,
  M.Voucher_No,
  M.Voucher_Date]]></queryString>

	<field name="UNIT_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="VOUCHER_DATE" class="java.sql.Timestamp"/>
	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="ACCHEAD_DESC" class="java.lang.String"/>
