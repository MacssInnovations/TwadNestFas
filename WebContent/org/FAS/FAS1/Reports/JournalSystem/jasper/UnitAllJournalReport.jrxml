	<parameter name="year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT M.Accounting_Unit_Id AS Unit_Id ,
  A.Accounting_Unit_Name,
  m.cashbook_year ,
  m.ACCOUNTING_FOR_OFFICE_ID ,
  a.ACCOUNTING_UNIT_OFFICE_ID,
  M.Cashbook_Month ,
  m.REMARKS,
  M.Voucher_Date,
  m.JOURNAL_TYPE_CODE,
  (SELECT ACCOUNTING_UNIT_NAME
  FROM FAS_MST_ACCT_UNITS unit
  WHERE Accounting_Unit_Id=M.ACCOUNTING_UNIT_ID
  )AS Orgname,
  (SELECT JOURNAL_TYPE_DESC
  FROM FAS_MST_JOURNAL_TYPE
  WHERE JOURNAL_TYPE_CODE=m.JOURNAL_TYPE_CODE
  ) AS journal_desc,
  t.account_head_code ,
  m.VOUCHER_NO AS voc_no ,
  T.Amount ,
  T.Cr_Dr_Indicator,
  T.SL_NO,
  T.Sub_Ledger_Type_Code,
  (SELECT Sub_Ledger_Type_Desc
  FROM Com_Mst_Sl_Types
  WHERE Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code
  )AS Typedesc,
  (SELECT SL_CODENAME
  FROM SL_TYPE_CODE_NAME_VIEW_M
  WHERE SL_CODE=T.SL_NO
  AND SL_TYPE  =T.Sub_Ledger_Type_Code
  )AS Sl_desc
FROM FAS_JOURNAL_MASTER m,
  FAS_JOURNAL_TRANSACTION t ,
  Fas_Mst_Acct_Units A,
  Fas_Mst_Journal_Type B
WHERE m.accounting_unit_id      =t.accounting_unit_id
AND T.Cr_Dr_Indicator           ='CR'
AND m.cashbook_year             = t.cashbook_year
AND m.cashbook_month            = t.cashbook_month
AND m.VOUCHER_NO                = t.VOUCHER_NO
AND M.Journal_Status            ='L'
AND M.ACCOUNTING_FOR_OFFICE_ID  = A.ACCOUNTING_UNIT_OFFICE_ID
AND M.ACCOUNTING_FOR_OFFICE_ID IN
  (SELECT office_id FROM COM_MST_ALL_OFFICES_VIEW
  )
AND m.CashBook_year       =2012
AND m.CashBook_Month      =8
AND M.Journal_Type_Code   =B.Journal_Type_Code
AND m.accounting_unit_id IN
  (SELECT Accounting_Unit_Id
  FROM FAS_TRIAL_BALANCE_STATUS
  WHERE Tb_Status   ='Y'
  AND Cashbook_Year =M.Cashbook_Year
  AND Cashbook_Month=M.Cashbook_Month
  )
ORDER BY Unit_Id,
  m.cashbook_year]]></queryString>

