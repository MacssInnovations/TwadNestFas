<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Journal"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="757"
		 pageHeight="842"
		 columnWidth="697"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="recType" isForPrompting="true" class="java.lang.String"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="recNofrom" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="recNoto" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="imagepath" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT JourTrans.ACCOUNT_HEAD_CODE
  ||'--'
  || acchead.ACCOUNT_HEAD_DESC AS accCodeDesc,
  JourMas.ACCOUNTING_UNIT_ID ,
  JourMas.ACCOUNTING_FOR_OFFICE_ID,  
  accUint.ACCOUNTING_UNIT_NAME,
  Office.OFFICE_NAME ,
  Office.CITY_TOWN_NAME,
  TO_CHAR(JourMas.VOUCHER_DATE,'DD/MM/YYYY') AS VOUCHER_DATE,
  JourMas.VOUCHER_NO,
  JourTrans.SL_NO,
  JourTrans.PARTICULARS,
  JourTrans.CR_DR_INDICATOR,
  TO_CHAR(JourTrans.AMOUNT,'99999999999999.99') AS TRNS_AMOUNT ,  
  JourTrans.AMOUNT,
  CASE
    WHEN Jourtrans.CR_DR_INDICATOR='CR'
    THEN JourTrans.AMOUNT
    ELSE 0
  END AS cramount,
  CASE
    WHEN Jourtrans.CR_DR_INDICATOR='DR'
    THEN JourTrans.AMOUNT
    ELSE 0
  END AS dramount,
  JourMas.Remarks,
  decode(Jourtrans.SUB_LEDGER_TYPE_CODE,0,'',Jourtrans.SUB_LEDGER_TYPE_CODE)
  ||'--'
  ||
  (SELECT sub_ledger_type_desc
  FROM com_mst_sl_types
  WHERE SUB_LEDGER_TYPE_CODE=Jourtrans.SUB_LEDGER_TYPE_CODE
  ) AS SL_DESC,
  decode(Jourtrans.sub_ledger_code,0,'',Jourtrans.sub_ledger_code)
  ||'--'
  ||
  (SELECT sl_codename
  FROM sl_type_code_name_view_M
  WHERE sl_type=Jourtrans.sub_ledger_type_code
  AND SL_CODE  =Jourtrans.SUB_LEDGER_CODE
  AND rownum  <=1
  ) AS sl_code_desc
FROM FAS_JOURNAL_MASTER JourMas,
  COM_MST_OFFICES Office,
  FAS_MST_ACCT_UNITS accUint,
  FAS_JOURNAL_TRANSACTION JourTrans,
  COM_MST_ACCOUNT_HEADS acchead
WHERE JourMas.ACCOUNTING_UNIT_ID    =JourTrans.ACCOUNTING_UNIT_ID
AND JourMas.ACCOUNTING_FOR_OFFICE_ID=JourTrans.ACCOUNTING_FOR_OFFICE_ID
AND JourMas.CASHBOOK_YEAR           =JourTrans.CASHBOOK_YEAR
AND JourMas.CASHBOOK_MONTH          =JourTrans.CASHBOOK_MONTH
AND JourMas.VOUCHER_NO              =JourTrans.VOUCHER_NO
AND JourMas.ACCOUNTING_UNIT_ID      =accUint.ACCOUNTING_UNIT_ID
AND JourMas.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID
AND JourTrans.ACCOUNT_HEAD_CODE     =acchead.ACCOUNT_HEAD_CODE
AND JourMas.JOURNAL_STATUS         !='C'
AND JourMas.ACCOUNTING_UNIT_ID=$P{acc_unit_id}  
AND JourMas.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}
AND JourMas.CASHBOOK_YEAR=$P{yr}
AND JourMas.CASHBOOK_MONTH=$P{mon} 
AND jourmas.voucher_no between $P{recNofrom} AND  $P{recNoto}
$P!{recType}]]></queryString>

