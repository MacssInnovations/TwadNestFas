<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Abstract_Journal_Book"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="heading" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select ACCOUNT_HEAD_CODE as "ACCOUNT_HEAD_CODE",accCodeDesc as "ACCCODEDESC",ACCOUNTING_UNIT_NAME as "ACCOUNTING_UNIT_NAME",office_name as "OFFICE_NAME",sum(TRNS_AMOUNT) as transum, 
sum(CR_TRNS_AMOUNT) as "CRTRANSUM" , sum(DR_TRNS_AMOUNT) as "DRSTRANSUM"
from 
(
select  JourTrans.ACCOUNT_HEAD_CODE,
        acchead.ACCOUNT_HEAD_DESC as accCodeDesc,
        JourTrans.AMOUNT as TRNS_AMOUNT,

 case when (JourTrans.CR_DR_INDICATOR='CR') then JourTrans.AMOUNT   END as CR_TRNS_AMOUNT, 
case when (JourTrans.CR_DR_INDICATOR='DR') then JourTrans.AMOUNT   END as DR_TRNS_AMOUNT, 
        
        accUint.ACCOUNTING_UNIT_NAME,office.office_name,
        JourTrans.CR_DR_INDICATOR
             
        
        from 
               FAS_JOURNAL_MASTER JourMas,
               FAS_JOURNAL_TRANSACTION JourTrans,
              
               COM_MST_ACCOUNT_HEADS accHead,COM_MST_OFFICES Office, FAS_MST_ACCT_UNITS accUint
        
        where
            JourTrans.ACCOUNTING_UNIT_ID=accUint.ACCOUNTING_UNIT_ID 
        and JourTrans.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID 
        and JourTrans.ACCOUNTING_UNIT_ID=$P{acc_unit_id}::int 
        and JourTrans.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}::int
	and JourTrans.CASHBOOK_YEAR=$P{yr}::int 
        and JourTrans.CASHBOOK_MONTH=$P{mon}::int
        and JourTrans.ACCOUNTING_UNIT_ID=JourMas.ACCOUNTING_UNIT_ID
        and JourTrans.ACCOUNTING_FOR_OFFICE_ID=JourMas.ACCOUNTING_FOR_OFFICE_ID
        and JourTrans.CASHBOOK_MONTH=JourMas.CASHBOOK_MONTH
        and JourTrans.CASHBOOK_YEAR=JourMas.CASHBOOK_YEAR
        and JourTrans.VOUCHER_NO=JourMas.VOUCHER_NO
	and accHead.ACCOUNT_HEAD_CODE=JourTrans.ACCOUNT_HEAD_CODE
        and JourMas.JOURNAL_STATUS<>'C'  
  
   ) as JRNL
    group by ACCOUNT_HEAD_CODE,accCodeDesc,ACCOUNTING_UNIT_NAME,office_name
    order by ACCOUNT_HEAD_CODE]]></queryString>

	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="ACCCODEDESC" class="java.lang.String"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="transum" class="java.math.BigDecimal"/>
	<field name="CRTRANSUM" class="java.math.BigDecimal"/>
	<field name="DRSTRANSUM" class="java.math.BigDecimal"/>

	<variable name="TotalCR" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CRTRANSUM}]]></variableExpression>
	</variable>
	<variable name="TotalDR" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DRSTRANSUM}]]></variableExpression>
	</variable>

