	<field name="SUB_LEDGER_TYPE_CODE" class="java.math.BigDecimal"/>
	<field name="SLTYPEDESC" class="java.lang.String"/>

	<variable name="TotalCR" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="Head_desc" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{SLTYPEDESC}==null?new String("--"):$F{SLTYPEDESC}]]></variableExpression>
	</variable>
	<variable name="AccHeadDescription" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{ACCOUNT_HEAD_CODE}.toString()+'-'+$F{ACCHEAD_DESC}]]></variableExpression>
	</variable>
	<variable name="Total CR Amount" class="java.math.BigDecimal" resetType="Group" resetGroup="SL Type Code" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<variable name="grand Total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>

