<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Journal_Report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="736"
		 pageHeight="842"
		 columnWidth="676"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="vouNO" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="vouType" isForPrompting="true" class="java.lang.String"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select JourTrans.ACCOUNT_HEAD_CODE ||'--'|| acchead.ACCOUNT_HEAD_DESC as "ACCCODEDESC", 
        JourMas.ACCOUNTING_UNIT_ID ,
        JourMas.ACCOUNTING_FOR_OFFICE_ID,
	JourMas.REMARKS as "REMARKS",
        accUint.ACCOUNTING_UNIT_NAME as "ACCOUNTING_UNIT_NAME", Office.OFFICE_NAME as "OFFICE_NAME",Office.CITY_TOWN_NAME,        
        to_char(JourMas.VOUCHER_DATE,'DD/MM/YYYY') as "VOUCHER_DATE",JourMas.VOUCHER_NO as "VOUCHER_NO",
	JourTrans.PARTICULARS as "PARTICULARS",
	JourTrans.CR_DR_INDICATOR as "CR_DR_INDICATOR", to_char(JourTrans.AMOUNT,'99999999999999.99') as "TRNS_AMOUNT" ,
	JourTrans.AMOUNT as "AMOUNT",
Case When Jourtrans.Cr_Dr_Indicator='CR' Then Jourtrans.Amount Else 0 End  as "CR_AMT",
  Case When Jourtrans.Cr_Dr_Indicator='DR' Then Jourtrans.Amount else 0 End as "DR_AMT",
	case 
	when (JOURTRANS.SUB_LEDGER_TYPE_CODE=0) then '' 
	else JOURTRANS.SUB_LEDGER_TYPE_CODE::varchar
	end
	||'--' ||
  (SELECT sub_ledger_type_desc
  FROM com_mst_sl_types
  WHERE SUB_LEDGER_TYPE_CODE=JOURTRANS.SUB_LEDGER_TYPE_CODE
  ) AS "SL_DESC",
   case 
	when (JOURTRANS.sub_ledger_code=0) then ''
	else JOURTRANS.sub_ledger_code::varchar
	end
  ||'--'||
  (SELECT sl_codename
  FROM sl_type_code_name_view_M
  WHERE sl_type=JOURTRANS.sub_ledger_type_code
  AND SL_CODE  =JOURTRANS.SUB_LEDGER_CODE
 limit 1
  ) AS "SL_CODE_DESC"
	from FAS_JOURNAL_MASTER JourMas,COM_MST_OFFICES Office,
        FAS_MST_ACCT_UNITS accUint,FAS_JOURNAL_TRANSACTION JourTrans,
        COM_MST_ACCOUNT_HEADS acchead where 
        JourMas.ACCOUNTING_UNIT_ID=JourTrans.ACCOUNTING_UNIT_ID and 
        JourMas.ACCOUNTING_FOR_OFFICE_ID=JourTrans.ACCOUNTING_FOR_OFFICE_ID and 
        JourMas.CASHBOOK_YEAR=JourTrans.CASHBOOK_YEAR and
        JourMas.CASHBOOK_MONTH=JourTrans.CASHBOOK_MONTH and 
        JourMas.VOUCHER_NO=JourTrans.VOUCHER_NO and
        JourMas.ACCOUNTING_UNIT_ID=accUint.ACCOUNTING_UNIT_ID 
        and JourMas.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID and
        JourTrans.ACCOUNT_HEAD_CODE=acchead.ACCOUNT_HEAD_CODE 
	and JourMas.ACCOUNTING_UNIT_ID=$P{acc_unit_id}::int  and JourMas.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}::int
	and JourMas.CASHBOOK_YEAR=$P{yr}::int and JourMas.CASHBOOK_MONTH=$P{mon}::int and JourMas.VOUCHER_NO=$P{vouNO}::int 
	and JourMas.CREATED_BY_MODULE=$P{vouType}::varchar]]></queryString>

	<field name="ACCCODEDESC" class="java.lang.String"/>
