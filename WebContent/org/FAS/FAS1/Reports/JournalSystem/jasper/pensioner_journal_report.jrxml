<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="pensioner_journal_report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1176"
		 pageHeight="842"
		 columnWidth="1116"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="listtype" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="grouptype" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="penfamily" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select --p.office_id,
(select s.office_name from com_mst_offices s where s.office_id=p.OFFICE_ID)as offName,
  ppo_no,
  (pensioner_name ||'-'||PENSIONER_INITIAL) as penName,
  NO_OF_PROCESSED_DAYS,
  PENSION_AMT,
  DP_AMT,
  DA_AMT,
  MA_AMT,
  (OTHER_EARNINGS1+OTHER_EARNINGS2+OTHER_EARNINGS3)as OTHER_EARNINGS,
  HF_AMT,
  PFSF_AMT,
  IT_AMT,
  ADHOC_AMT,
  (OTHER_DEDUCTIONS1+OTHER_DEDUCTIONS2+OTHER_DEDUCTIONS3)other_deductions,
  FESTIVAL_AMT,
  PAY_REV_AMT,
  DA_ARR_AMT,
  DCRG_ARR_AMT,
  COMM_ARR_AMT,
  GROSS_PAY,
  NET_PAY,
  PAYMENT_MODE,
  SALARY_BANK_ID,
  SALARY_BRANCH_ID,
  BANK_AC_NO,
  ORIGINAL_PENSION,
  FEST_INSTALLMENTS_OVER_SOFAR,
  FEST_TOTAL_INSTALLMETS,
  IT_INSTALLMENTS_OVER_SOFAR,
  IT_TOTAL_INSTALLMETS,
  ADHOC_INSTALLMENTS_OVER_SOFAR,
  ADHOC_TOTAL_INSTALLMETS,
  BANK_NAME,
  BRANCH_NAME,
  addl_pension
FROM FAS_INTEGRATION_PEN_PAY_FINAL p
WHERE OFFICE_ID     =$P{accountofficeid}
AND PROCESS_YEAR    =$P{cashbookyear}
AND PROCESS_MONTH   =$P{cashbookmonth}
AND CHK_LIST_TYPE_ID=$P{listtype}
and CHK_LIST_GRP_ID=$P{grouptype}
and PEN_FAMILYPEN_FLAG=$P{penfamily}]]></queryString>

