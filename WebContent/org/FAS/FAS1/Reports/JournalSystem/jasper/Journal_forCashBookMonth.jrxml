<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Journal_forCashBookMonth"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="acc_unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="supplement_no" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select  JourTrans.ACCOUNT_HEAD_CODE ||'--'|| acchead.ACCOUNT_HEAD_DESC as "ACCCODEDESC",JourTrans.AMOUNT as TRNS_AMOUNT,
  --      decode(JourTrans.CR_DR_INDICATOR,'CR',JourTrans.AMOUNT) as CR_TRNS_AMOUNT,
	case when  JourTrans.CR_DR_INDICATOR='CR' then JourTrans.AMOUNT=0 end   as "CR_TRNS_AMOUNT",
---	decode(JourTrans.CR_DR_INDICATOR,'DR',JourTrans.AMOUNT) as DR_TRNS_AMOUNT,
	case when JourTrans.CR_DR_INDICATOR='DR' then JourTrans.AMOUNT else 0 end   as "DR_TRNS_AMOUNT",
        accUint.ACCOUNTING_UNIT_NAME as "ACCOUNTING_UNIT_NAME", Office.OFFICE_NAME as "OFFICE_NAME" ,Office.CITY_TOWN_NAME,
        JourTrans.CR_DR_INDICATOR,JourTrans.SUB_LEDGER_TYPE_CODE,
        sl.JOURNAL_TYPE_DESC as "JOURNAL_TYPE_DESC",JourTrans.VOUCHER_NO as "VOUCHER_NO",
	JourMas.VOUCHER_DATE as "VOUCHER_DATE",JourTrans.PARTICULARS as "PARTICULARS"
        from FAS_JOURNAL_MASTER JourMas,FAS_JOURNAL_TRANSACTION JourTrans,FAS_MST_JOURNAL_TYPE sl,
        COM_MST_ACCOUNT_HEADS accHead,COM_MST_OFFICES Office, FAS_MST_ACCT_UNITS accUint
        where  JourTrans.ACCOUNTING_UNIT_ID=accUint.ACCOUNTING_UNIT_ID 
        and JourTrans.ACCOUNTING_FOR_OFFICE_ID=Office.OFFICE_ID and
	JourTrans.ACCOUNTING_UNIT_ID=$P{acc_unit_id}::int and JourTrans.ACCOUNTING_FOR_OFFICE_ID=$P{off_id}::int
	and JourTrans.CASHBOOK_YEAR=$P{yr}::int and JourTrans.CASHBOOK_MONTH=$P{mon}::int
        and JourMas.SUPPLEMENT_NO=$P{supplement_no}::int
        and JourTrans.ACCOUNTING_UNIT_ID=JourMas.ACCOUNTING_UNIT_ID
        and JourTrans.ACCOUNTING_FOR_OFFICE_ID=JourMas.ACCOUNTING_FOR_OFFICE_ID
        and JourTrans.CASHBOOK_MONTH=JourMas.CASHBOOK_MONTH
        and JourTrans.CASHBOOK_YEAR=JourMas.CASHBOOK_YEAR
        and JourTrans.VOUCHER_NO=JourMas.VOUCHER_NO
	and accHead.ACCOUNT_HEAD_CODE=JourTrans.ACCOUNT_HEAD_CODE
        and JourMas.JOURNAL_TYPE_CODE=sl.JOURNAL_TYPE_CODE and JourMas.JOURNAL_STATUS<>'C'
        and JourMas.CREATED_BY_MODULE in ('SJV')  
  order by JourMas.VOUCHER_DATE,JourTrans.VOUCHER_NO,JourTrans.ACCOUNT_HEAD_CODE]]></queryString>

	<field name="ACCCODEDESC" class="java.lang.String"/>
	<field name="trns_amount" class="java.math.BigDecimal"/>
