	<parameter name="txtCB_Year_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Year_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="officeCode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthInWords_to" isForPrompting="true" class="java.lang.String"/>
	<parameter name="txtCB_Month_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtCB_Month_to" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT M.Accounting_Unit_Id AS Unit_Id ,A.Accounting_Unit_Name,
  m.cashbook_year ,m.ACCOUNTING_FOR_OFFICE_ID ,a.ACCOUNTING_UNIT_OFFICE_ID,
  M.Cashbook_Month ,m.REMARKS,
  M.Voucher_Date,m.JOURNAL_TYPE_CODE,
  (SELECT ACCOUNTING_UNIT_NAME
    FROM FAS_MST_ACCT_UNITS unit
    Where Accounting_Unit_Id=M.ACCOUNTING_UNIT_ID
    )As Orgname,
  (select JOURNAL_TYPE_DESC from FAS_MST_JOURNAL_TYPE where JOURNAL_TYPE_CODE=m.JOURNAL_TYPE_CODE) as journal_desc,
  t.account_head_code ,
  m.VOUCHER_NO AS voc_no ,
  T.Amount ,
  T.Cr_Dr_Indicator,T.SL_NO,
  T.Sub_Ledger_Type_Code,
  (SELECT Sub_Ledger_Type_Desc
  FROM Com_Mst_Sl_Types
  WHERE Sub_Ledger_Type_Code=T.Sub_Ledger_Type_Code
  )AS Typedesc,
 (select SL_CODENAME from SL_TYPE_CODE_NAME_VIEW_M where SL_CODE=T.SL_NO and SL_TYPE=T.Sub_Ledger_Type_Code)AS sl_desc
 from FAS_JOURNAL_MASTER m,
  FAS_JOURNAL_TRANSACTION t ,
  Fas_Mst_Acct_Units A,
  Fas_Mst_Journal_Type B
WHERE m.accounting_unit_id =t.accounting_unit_id
and  T.Cr_Dr_Indicator='CR' 
AND m.cashbook_year        = t.cashbook_year
AND m.cashbook_month       = t.cashbook_month
and m.ACCOUNTING_FOR_OFFICE_ID=$P{officeCode}
AND m.VOUCHER_NO           = t.VOUCHER_NO
AND m.JOURNAL_STATUS       ='L'

And M.ACCOUNTING_FOR_OFFICE_ID  = A.ACCOUNTING_UNIT_OFFICE_ID
and  M.ACCOUNTING_FOR_OFFICE_ID in
 (SELECT office_id
FROM COM_MST_ALL_OFFICES_VIEW
WHERE region_office_id =$P{officeCode}
)
and To_Date((m.Cashbook_Month
  ||'-'
  || m.Cashbook_Year),'mm-yyyy') BETWEEN To_Date($P{txtCB_Month_from}
  ||'-'
  ||$P{txtCB_Year_from},'mm-yyyy')
AND to_date($P{txtCB_Month_to}
  ||'-'
  ||$P{txtCB_Year_to},'mm-yyyy') 
AND M.Journal_Type_Code       =B.Journal_Type_Code
AND m.accounting_unit_id IN
  (Select Accounting_Unit_Id
  FROM FAS_TRIAL_BALANCE_STATUS
  Where Tb_Status   ='Y'
 And Cashbook_Year =M.Cashbook_Year
AND cashbook_month=M.Cashbook_Month
  )Order By Unit_Id,
voc_no,T.sl_no]]></queryString>

