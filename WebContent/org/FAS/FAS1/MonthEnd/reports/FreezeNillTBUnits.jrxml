	<parameter name="cashbookyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthinwords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT a.ACCOUNTING_UNIT_ID ,
  (SELECT ACCOUNTING_UNIT_NAME
  FROM FAS_MST_ACCT_UNITS
  WHERE ACCOUNTING_UNIT_ID=a.ACCOUNTING_UNIT_ID
  )AS accname,a.UPDATED_DATE
FROM fas_trial_balance_status a
WHERE cashbook_year   =$P{cashbookyear}
AND cashbook_month    =$P{cashbookmonth}
AND NIL_TB_STATUS ='Y']]></queryString>

