	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonthwords" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select b.accounting_unit_id,
(case when (length(b.accounting_unit_id)=1) then concat('00',b.accounting_unit_id)  
when (length(b.accounting_unit_id)=2) then concat('0',b.accounting_unit_id)  
when (length(b.accounting_unit_id)=3) then concat('',b.accounting_unit_id)
end )as unitid,
(select accounting_unit_name from fas_mst_acct_units f where f.accounting_unit_id=b.accounting_unit_id)as unitname,
accounting_for_office_id,
CB_YEAR,
cb_month,
ps_year,
ps_month,
verified,
VERIFIED_DATE,
bank_ac_no,
bank_id,
BRANCH_ID,
bank_ac_type_id,
AC_OPERATIONAL_MODE_ID,
remarks,
PS_DATE,
pb_balance,
(select bank_short_name from FAS_MST_BANKS a where a.bank_id=b.bank_id) as bankname,
(select branch_name from FAS_MST_BANK_BRANCHES a1 where a1.bank_id=b.bank_id
and a1.BRANCH_ID=b.BRANCH_ID) as branchName,
CR_DR_TYPE from brs_bank_balance_update b where cb_year=$P{cbyear} and
CB_MONTH=$P{cbmonth} order by ACCOUNTING_UNIT_ID]]></queryString>

