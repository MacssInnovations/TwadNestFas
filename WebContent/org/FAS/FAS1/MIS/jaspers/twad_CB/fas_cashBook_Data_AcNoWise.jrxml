	<field name="REC_SL_TYPE" class="java.math.BigDecimal"/>
	<field name="REC_SL_CODE" class="java.math.BigDecimal"/>
	<field name="PAID_SL_TYPE" class="java.math.BigDecimal"/>
	<field name="PAID_SL_CODE" class="java.math.BigDecimal"/>
	<field name="RSL_TYPE_DESC" class="java.lang.String"/>
	<field name="PSL_TYPE_DESC" class="java.lang.String"/>
	<field name="RSL_CODE_DESC" class="java.lang.String"/>
	<field name="PSL_CODE_DESC" class="java.lang.String"/>
	<field name="BANK_NAME" class="java.lang.String"/>
	<field name="ACNO" class="java.math.BigDecimal"/>

	<variable name="sumAc_rec" class="java.math.BigDecimal" resetType="None" calculation="Sum">
		<variableExpression><![CDATA[$F{RECAMT}]]></variableExpression>
	</variable>
	<variable name="sumAc_paid" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{PAYAMT}]]></variableExpression>
	</variable>

