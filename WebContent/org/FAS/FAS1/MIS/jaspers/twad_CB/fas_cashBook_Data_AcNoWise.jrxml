<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="fas_cashBook_Data_AcNoWise"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="962"
		 pageHeight="842"
		 columnWidth="902"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="monthInWords" isForPrompting="false" class="java.lang.String"/>
	<parameter name="txtCB_Year" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="accountingunit_name" isForPrompting="false" class="java.lang.String"/>
	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<parameter name="sub_qry" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT u.ACCOUNTING_UNIT_NAME,b.OFFICE_NAME,
  a.ACCOUNTING_UNIT_ID,
  a.ACCOUNTING_FOR_OFFICE_ID,
  a.CASHBOOK_YEAR,
  a.CASHBOOK_MONTH,
  a.vouDate,
  a.recNo,
  a.recPart,
  a.recAcchead,
  a.recAmt,
  a.recCheqDD_no,
  a.recChequeDD_date,
  a.recRecFrom,
  a.payNo,
  a.payPart,
  a.payAcchead,
  a.payAmt,
  a.payCheqDD_no,
  a.payChequeDD_date,
  a.payRefno,
  a.payPaidto,
  a.bid,
  a.rec_sl_type,
  a.rec_sl_code,
  a.paid_sl_type,
  a.paid_sl_code,
  (SELECT Sub_Ledger_Type_Desc
  FROM Com_Mst_Sl_Types al
  WHERE AL.SUB_LEDGER_TYPE_CODE=a.rec_sl_type
  )RSl_Type_Desc,
  (SELECT Sub_Ledger_Type_Desc
  FROM Com_Mst_Sl_Types sl
  WHERE sL.SUB_LEDGER_TYPE_CODE=a.paid_sl_type
  )pSl_Type_Desc,
  (SELECT SL_CODENAME
  FROM SL_TYPE_CODE_NAME_VIEW_M vl
  WHERE SL_TYPE=a.rec_sl_type
  AND SL_CODE  =a.rec_sl_code
  )RSl_Code_Desc,
  (SELECT SL_CODENAME
  FROM SL_TYPE_CODE_NAME_VIEW_M sV
  WHERE SL_TYPE=a.paid_sl_type
  AND SL_CODE  =a.paid_sl_code
  )PSl_Code_Desc,
  --Sl.Sub_Ledger_Type_Desc AS RSl_Type_Desc,
  --ST.Sub_Ledger_Type_Desc AS PSl_Type_Desc,
  --  Vi.Sl_Codename          AS Sl_Name,
  k.bank_name AS bank_name,
  a.acno
FROM
  (SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.receipt_date                                    AS vouDate,
    t.receipt_no                                      AS recNo,
    t.particulars                                     AS recPart,
    t.account_head_code                               AS recAcchead,
    DECODE(t.cr_dr_indicator,'CR',t.amount,-t.amount) AS recAmt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no)      AS recCheqDD_no,
    t.cheque_dd_date       AS recChequeDD_date,
    m.received_from        AS recRecFrom,
    to_number(NULL)        AS payNo,
    TO_CHAR(NULL)          AS payPart,
    to_number(NULL)        AS payAcchead,
    to_number(NULL)        AS payAmt,
    TO_CHAR(NULL)          AS payCheqDD_no,
    to_date(NULL)          AS payChequeDD_date,
    TO_CHAR(NULL)          AS payRefno,
    TO_CHAR(NULL)          AS payPaidto,
    m.bank_id              AS bid,
    t.SUB_LEDGER_TYPE_CODE AS rec_sl_type,
    t.SUB_LEDGER_CODE      AS rec_sl_code,
    to_number(NULL)        AS paid_sl_type,
    to_number(NULL)        AS paid_sl_code,
    m.ACCOUNT_NO           AS acno
  FROM FAS_RECEIPT_MASTER m,
    FAS_RECEIPT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.receipt_no               = m.receipt_no
  AND m.receipt_status!          ='C'
  AND m.created_by_module       IN('CR','SC')
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.receipt_date                                    AS vouDate,
    t.receipt_no                                      AS recNo,
    t.particulars                                     AS recPart,
    t.account_head_code                               AS recAcchead,
    DECODE(t.cr_dr_indicator,'CR',t.amount,-t.amount) AS recAmt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no)      AS recCheqDD_no,
    t.cheque_dd_date       AS recChequeDD_date,
    m.received_from        AS recRecFrom,
    to_number(NULL)        AS payNo,
    TO_CHAR(NULL)          AS payPart,
    to_number(NULL)        AS payAcchead,
    to_number(NULL)        AS payAmt,
    TO_CHAR(NULL)          AS payCheqDD_no,
    to_date(NULL)          AS payChequeDD_date,
    TO_CHAR(NULL)          AS payRefno,
    TO_CHAR(NULL)          AS payPaidto,
    m.bank_id              AS bid,
    t.SUB_LEDGER_TYPE_CODE AS rec_sl_type,
    t.SUB_LEDGER_CODE      AS rec_sl_code,
    to_number(NULL)        AS paid_sl_type,
    to_number(NULL)        AS paid_sl_code,
    m.ACCOUNT_NO           AS acno
  FROM FAS_RECEIPT_MASTER m,
    FAS_RECEIPT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.receipt_no               = m.receipt_no
  AND m.receipt_status!          ='C'
    -- AND m.bank_id                  =2
  AND m.created_by_module ='BR'
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.payment_date                                    AS vouDate,
    to_number(NULL)                                   AS recNo,
    TO_CHAR(NULL)                                     AS recPart,
    to_number(NULL)                                   AS recAcchead,
    to_number(NULL)                                   AS recAmt,
    TO_CHAR(NULL)                                     AS recCheqDD_no,
    to_date(NULL)                                     AS recChequeDD_date,
    TO_CHAR(NULL)                                     AS recRecFrom,
    t.voucher_no                                      AS payNo,
    t.particulars                                     AS payPart,
    t.account_head_code                               AS payAcchead,
    DECODE(t.cr_dr_indicator,'DR',t.amount,-t.amount) AS payAmt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no)      AS payCheqDD_no,
    t.cheque_dd_date       AS payChequeDD_date,
    TO_CHAR(NULL)          AS payRefno,
    m.paid_to              AS payPaidto,
    m.bank_id              AS bid,
    to_number(NULL)        AS rec_sl_type,
    to_number(NULL)        AS rec_sl_code,
    t.SUB_LEDGER_TYPE_CODE AS paid_sl_type,
    t.SUB_LEDGER_CODE      AS paid_sl_code,
    m.ACCOUNT_NO           AS acno
  FROM FAS_PAYMENT_MASTER m,
    FAS_PAYMENT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND m.PAYMENT_status!          ='C'
    -- AND m.bank_id                  =2
  AND m.created_by_module IN ('BPP','BPF','NP')
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.payment_date                                    AS vouDate,
    to_number(NULL)                                   AS recNo,
    TO_CHAR(NULL)                                     AS recPart,
    to_number(NULL)                                   AS recAcchead,
    to_number(NULL)                                   AS recAmt,
    TO_CHAR(NULL)                                     AS recCheqDD_no,
    to_date(NULL)                                     AS recChequeDD_date,
    TO_CHAR(NULL)                                     AS recRecFrom,
    t.voucher_no                                      AS payNo,
    t.particulars                                     AS payPart,
    t.account_head_code                               AS payAcchead,
    DECODE(t.cr_dr_indicator,'DR',t.amount,-t.amount) AS payAmt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no)      AS payCheqDD_no,
    t.cheque_dd_date       AS payChequeDD_date,
    TO_CHAR(NULL)          AS payRefno,
    m.paid_to              AS payPaidto,
    m.bank_id              AS bid,
    to_number(NULL)        AS rec_sl_type,
    to_number(NULL)        AS rec_sl_code,
    t.SUB_LEDGER_TYPE_CODE AS paid_sl_type,
    t.SUB_LEDGER_CODE      AS paid_sl_code,
    m.ACCOUNT_NO           AS acno
  FROM FAS_PAYMENT_MASTER m,
    FAS_PAYMENT_TRANSACTION t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND m.PAYMENT_status!          ='C'
  AND m.created_by_module       IN ('SC')
  UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    DATE_OF_TRANSFER     AS vouDate,
    VOUCHER_NO           AS recNo,
    particulars          AS recPart,
    DR_ACCOUNT_HEAD_CODE AS recAcchead,
    TOTAL_AMOUNT         AS recAmt,
    DECODE(cheque_or_dd
    || '-'
    ||cheque_dd_no,'-',NULL,cheque_or_dd
    || '-'
    ||cheque_dd_no)              AS recCheqDD_no,
    cheque_dd_date               AS recChequeDD_date,
    TO_CHAR('Interbank Receipt') AS recRecFrom,
    to_number(NULL)              AS payNo,
    TO_CHAR(NULL)                AS payPart,
    to_number(NULL)              AS payAcchead,
    to_number(NULL)              AS payAmt,
    TO_CHAR(NULL)                AS payCheqDD_no,
    to_date(NULL)                AS payChequeDD_date,
    TO_CHAR(NULL)                AS payRefno,
    TO_CHAR(NULL)                AS payPaidto,
    TO_BANK_ID                   AS bid,
    to_number(NULL)              AS rec_sl_type,
    to_number(NULL)              AS rec_sl_code,
    to_number(NULL)              AS paid_sl_type,
    to_number(NULL)              AS paid_sl_code,
    TO_ACCOUNT_NO                AS acno
  FROM FAS_INTER_BANK_TRF_AT_HO
  WHERE TRANSFER_STATUS!='C'
  -- AND TO_BANK_ID        =2
  UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    DATE_OF_TRANSFER     AS vouDate,
    to_number(NULL)      AS recNo,
    TO_CHAR(NULL)        AS recPart,
    to_number(NULL)      AS recAcchead,
    to_number(NULL)      AS recAmt,
    TO_CHAR(NULL)        AS recCheqDD_no,
    to_date(NULL)        AS recChequeDD_date,
    TO_CHAR(NULL)        AS recRecFrom,
    voucher_no           AS payNo,
    particulars          AS payPart,
    CR_ACCOUNT_HEAD_CODE AS payAcchead,
    TOTAL_AMOUNT         AS payAmt,
    DECODE(cheque_or_dd
    || '-'
    ||cheque_dd_no,'-',NULL,cheque_or_dd
    || '-'
    ||cheque_dd_no)               AS payCheqDD_no,
    cheque_dd_date                AS payChequeDD_date,
    TO_CHAR(NULL)                 AS payRefno,
    TO_CHAR('Interbank Transfer') AS payPaidto,
    FROM_BANK_ID                  AS bid,
    to_number(NULL)               AS rec_sl_type,
    to_number(NULL)               AS rec_sl_code,
    to_number(NULL)               AS paid_sl_type,
    to_number(NULL)               AS paid_sl_code,
    FROM_ACCOUNT_NO               AS acno
  FROM FAS_INTER_BANK_TRF_AT_HO
  WHERE TRANSFER_STATUS!='C'
  --  AND FROM_BANK_ID      =2
  UNION ALL
  SELECT ACCOUNTING_UNIT_ID,
    ACCOUNTING_FOR_OFFICE_ID,
    CASHBOOK_YEAR,
    CASHBOOK_MONTH,
    receipt_date         AS vouDate,
    receipt_no           AS recNo,
    particulars          AS recPart,
    DR_ACCOUNT_HEAD_CODE AS recAcchead,
    TOTAL_AMOUNT         AS recAmt,
    DECODE(cheque_or_dd
    || '-'
    ||cheque_dd_no,'-',NULL,cheque_or_dd
    || '-'
    ||cheque_dd_no) AS recCheqDD_no,
    cheque_dd_date  AS recChequeDD_date,
    --to_char('Fund Receipt') as recRecFrom,
    (
    SELECT u.OFFICE_NAME
    FROM COM_MST_OFFICES u
    WHERE u.OFFICE_ID=Received_From_Office_Id
    )               AS Recrecfrom,
    to_number(NULL) AS payNo,
    TO_CHAR(NULL)   AS payPart,
    to_number(NULL) AS payAcchead,
    to_number(NULL) AS payAmt,
    TO_CHAR(NULL)   AS payCheqDD_no,
    to_date(NULL)   AS payChequeDD_date,
    TO_CHAR(NULL)   AS payRefno,
    TO_CHAR(NULL)   AS payPaidto,
    HO_BANK_ID      AS bid,
    to_number(NULL) AS rec_sl_type,
    to_number(NULL) AS rec_sl_code,
    to_number(NULL) AS paid_sl_type,
    to_number(NULL) AS paid_sl_code,
    HO_ACCOUNT_NO   AS acno
  FROM FAS_FUND_RECEIPT_BY_HO
  WHERE RECEIPT_STATUS!='C'
  -- AND HO_BANK_ID       =2
  UNION ALL
  SELECT t.ACCOUNTING_UNIT_ID,
    t.ACCOUNTING_FOR_OFFICE_ID,
    t.CASHBOOK_YEAR,
    t.CASHBOOK_MONTH,
    m.DATE_OF_TRANSFER  AS vouDate,
    to_number(NULL)     AS recNo,
    TO_CHAR(NULL)       AS recPart,
    to_number(NULL)     AS recAcchead,
    to_number(NULL)     AS recAmt,
    TO_CHAR(NULL)       AS recCheqDD_no,
    to_date(NULL)       AS recChequeDD_date,
    TO_CHAR(NULL)       AS recRecFrom,
    t.voucher_no        AS payNo,
    t.particulars       AS payPart,
    t.ACCOUNT_HEAD_CODE AS payAcchead,
    t.AMOUNT            AS payAmt,
    DECODE(t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no,'-',NULL,t.cheque_or_dd
    || '-'
    ||t.cheque_dd_no) AS payCheqDD_no,
    t.cheque_dd_date  AS payChequeDD_date,
    TO_CHAR(NULL)     AS payRefno,
    -- to_char('Fund Transfer') as payPaidto
    (
    SELECT u.OFFICE_NAME
    FROM COM_MST_OFFICES u
    WHERE u.OFFICE_ID=TRANSFER_TO_OFFICE_ID
    )               AS payPaidto,
    HO_BANK_ID      AS bid,
    to_number(NULL) AS rec_sl_type,
    to_number(NULL) AS rec_sl_code,
    to_number(NULL) AS paid_sl_type,
    to_number(NULL) AS paid_sl_code,
    HO_ACCOUNT_NO   AS acno
  FROM FAS_FUND_TRF_FROM_HO_MASTER m,
    FAS_FUND_TRF_FROM_HO_TRN t
  WHERE t.accounting_unit_id     = m.accounting_unit_id
  AND t.accounting_for_office_id = m.accounting_for_office_id
  AND t.cashbook_year            = m.cashbook_year
  AND t.cashbook_month           = m.cashbook_month
  AND t.voucher_no               = m.voucher_no
  AND TRANSFER_STATUS!           ='C'
    -- AND HO_BANK_ID                 =2
  ) a
  inner join fas_mst_acct_units u
  on a.ACCOUNTING_UNIT_ID=u.ACCOUNTING_UNIT_iD
INNER JOIN COM_MST_OFFICES b
ON a.ACCOUNTING_FOR_OFFICE_ID=b.office_id
INNER JOIN fas_mst_banks k
ON k.bank_id=a.bid
  --INNER JOIN Com_Mst_Sl_Types Sl
  --ON Sl.Sub_Ledger_Type_Code=A.rec_sl_type
  --INNER JOIN Com_Mst_Sl_Types ST
  --ON ST.Sub_Ledger_Type_Code=A.paid_sl_type
WHERE 
-- a.ACCOUNTING_UNIT_ID =5 AND
$P!{sub_qry}

ORDER BY a.bid,a.acno,a.ACCOUNTING_UNIT_ID,a.vouDate,
  b.OFFICE_NAME, 
  a.recNo,
  a.payNo]]></queryString>

	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
