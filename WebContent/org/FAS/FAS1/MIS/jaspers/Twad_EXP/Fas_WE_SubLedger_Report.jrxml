	<property name="ireport.scriptlethandling" value="2" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[Select 1 As Data_Tb,
  to_number(Fh.Projectid) as projectId,
   Pr.Projectname,
  Fh.Programid,
  Pg.Programname,
  fh.Schemeid,
  Ps.Schemename,
  V.Account_Head_Code,
  Fh.Headofaccount,
  Sub_Ledger_Type_Code,
  Sub_Ledger_Code,
  Cashbook_Year,
  CASHBOOK_MONTH,
  DOCUMENT_TYPE,
  SUM(dr_amt)DR_AMOUNT,
  SUM(CR_AMT)CR_AMOUNT,
  Sum(Dr_Amt)-Sum(Cr_Amt) As Net_Amt ,
    Fh.Activityid,
    Ac.Activityname,
  CASE Fh.activityid
    WHEN '1'
    THEN Sum(Dr_Amt)-Sum(Cr_Amt)
  End As Funds,
  CASE Fh.activityid
    WHEN '2'
    THEN Sum(Dr_Amt)-Sum(Cr_Amt)
  End As Works_Expenditure,
  CASE Fh.activityid
    WHEN '3'
    THEN Sum(Dr_Amt)-Sum(Cr_Amt)
  End As Centage,
  CASE Fh.activityid
    WHEN '4'
    THEN Sum(Dr_Amt)-Sum(Cr_Amt)
  End As Interest_Charged,
  CASE Fh.activityid
    WHEN '15'
    THEN Sum(Dr_Amt)-Sum(Cr_Amt)
  END AS Materials,
  Fin_Year,
  SUB_LEDGER_TYPE_DESC,
  SLDESC
FROM Fas_Wrkexp_View V
Inner Join Headofaccounts Fh
On V.Account_Head_Code=Fh.Accountcode
Inner Join Activity1 Ac
on Fh.Activityid=Ac.Activityid
INNER JOIN Project Pr
ON Fh.Projectid=Pr.Projectid
INNER JOIN Program Pg
On Fh.Programid=Pg.Programid
	INNER JOIN Schemes Ps 
    		On Fh.Projectid =Ps.Projectid 
    		And Fh.Programid=Ps.Programid 
    		AND fh.Schemeid =Ps.Schemeid 
And Cmonth Between '01-APR-2011' And '01-AUG-2013'
AND Fh.Minorgroupingid='1166'
Group By 
--Data_Tb,
  to_number (Fh.Projectid),
   Pr.Projectname,
  Fh.Programid,
  Pg.Programname,
  fh.Schemeid,
  Ps.Schemename,
  V.Account_Head_Code,
  Fh.Headofaccount,
  Sub_Ledger_Type_Code,
  Sub_Ledger_Code,
  Cashbook_Year,
  CASHBOOK_MONTH,
  DOCUMENT_TYPE,

    Fh.Activityid,
    Ac.Activityname,
--  CASE Fh.activityid
--    WHEN '1'
--    THEN Sum(Dr_Amt)-Sum(Cr_Amt)
--  End As Funds,
--  CASE Fh.activityid
--    WHEN '2'
--    THEN Sum(Dr_Amt)-Sum(Cr_Amt)
--  End As Works_Expenditure,
--  CASE Fh.activityid
--    WHEN '3'
--    THEN Sum(Dr_Amt)-Sum(Cr_Amt)
--  End As Centage,
--  CASE Fh.activityid
--    WHEN '4'
--    THEN Sum(Dr_Amt)-Sum(Cr_Amt)
--  End As Interest_Charged,
--  CASE Fh.activityid
--    WHEN '15'
--    THEN Sum(Dr_Amt)-Sum(Cr_Amt)
--  END AS Materials,
  Fin_Year,
  SUB_LEDGER_TYPE_DESC,
  SLDESC
Order By 
  to_number (Fh.Projectid),Sub_Ledger_Type_Code,
  Sub_Ledger_Code,
  Cashbook_Year,
  CASHBOOK_MONTH,
  Fin_Year,
  Account_Head_Code]]></queryString>

