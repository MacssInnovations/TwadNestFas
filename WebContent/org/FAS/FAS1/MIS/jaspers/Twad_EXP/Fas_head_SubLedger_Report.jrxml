	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[Select 
--1                  AS Data_Tb,
  to_number(Fh.Projectid) AS Projectid,
  Pr.Projectname,
  Fh.Programid,
  Pg.Programname,
  Fh.Schemeid,
 Ps.Schemename,
  V.Account_Head_Code,
 Fh.Headofaccount,
  Sub_Ledger_Type_Code,
  Sub_Ledger_Code,
  SUM(dr_amt)DR_AMOUNT,
  SUM(CR_AMT)CR_AMOUNT,
  Sum(Dr_Amt)-Sum(Cr_Amt) As Net_Amt ,
 Fh.Activityid,
  Ac.Activityname,
  CASE Fh.activityid
    WHEN '1'
    THEN SUM(Dr_Amt)-SUM(Cr_Amt)
  END AS Funds,
  CASE Fh.activityid
    WHEN '2'
    THEN SUM(Dr_Amt)-SUM(Cr_Amt)
  END AS Works_Expenditure,
  CASE Fh.activityid
    WHEN '3'
    THEN SUM(Dr_Amt)-SUM(Cr_Amt)
  END AS Centage,
  CASE Fh.activityid
    WHEN '4'
    THEN SUM(Dr_Amt)-SUM(Cr_Amt)
  END AS Interest_Charged,
  CASE Fh.activityid
    WHEN '15'
    THEN SUM(Dr_Amt)-SUM(Cr_Amt)
  End As Materials,
  Fin_Year,
 SUB_LEDGER_TYPE_DESC,
 SLDESC
FROM Fas_Wrkexp_View V
INNER JOIN Headofaccounts Fh
ON V.Account_Head_Code=Fh.Accountcode
INNER JOIN Activity1 Ac
ON Fh.Activityid=Ac.Activityid
INNER JOIN Project Pr
ON Fh.Projectid=Pr.Projectid
INNER JOIN Program Pg
ON Fh.Programid=Pg.Programid
INNER JOIN Schemes Ps
ON Fh.Projectid =Ps.Projectid
AND Fh.Programid=Ps.Programid
AND fh.Schemeid =Ps.Schemeid
AND Cmonth BETWEEN '01-APR-2012' AND '02-MAR-2013'
AND Fh.Minorgroupingid='1166'
Group By To_Number (Fh.Projectid),
 Pr.Projectname,
  Fh.Programid,
 Pg.Programname,
  Fh.Schemeid,
 Ps.Schemename,
  V.Account_Head_Code,
  Fh.Headofaccount,
  Sub_Ledger_Type_Code,
   Sub_Ledger_Code,
 Fh.Activityid,
  Ac.Activityname,
  Fin_Year, 
 SUB_LEDGER_TYPE_DESC,
 Sldesc
ORDER BY to_number (Fh.Projectid), Fh.Schemeid,v.Account_Head_Code,
  Sub_Ledger_Type_Code,
  Sub_Ledger_Code,
  Fin_Year
  ]]></queryString>

