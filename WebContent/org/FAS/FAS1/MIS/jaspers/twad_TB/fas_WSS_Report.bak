	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<parameter name="year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="head1" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[Select 1 as t_data, Mm.Accounting_Unit_Id,u.Accounting_Unit_name,
mm.schemeid,
s.schemename,
  Sum(W_C)WR,
  Sum(Aa_Col)Aa_Col,
  Sum(Cop)Cop,
  Sum(Ad_Exp)AE,
  Sum(Fld_Mait_Exp)FM,
   Sum(W_C)-Sum(Aa_Col)As Balance,
    Sum(Cop)+Sum(Ad_Exp)+Sum(Fld_Mait_Exp) As Tot_exp,
    Sum(W_C)-(Sum(Cop)+Sum(Ad_Exp)+Sum(Fld_Mait_Exp)) as pro_loss
FROM
  (SELECT T.Accounting_Unit_Id,
    T.Account_Head_Code,t.schemeid,
    t.Maintid,
    SUM(T.Net),
    CASE
      WHEN T.Account_Head_Code LIKE '160101'
      Or T.Account_Head_Code Like '160201'
      OR T.Account_Head_Code LIKE '160501'
      THEN SUM(T.Net)
      ELSE 0
    END W_C,
    CASE
      WHEN T.Account_Head_Code LIKE '782401'
      OR T.Account_Head_Code LIKE '782402'
      OR T.Account_Head_Code LIKE '782404'
      OR T.Account_Head_Code LIKE '782405'
      THEN SUM(T.Net)
      ELSE 0
    END Aa_Col,
    CASE
      WHEN T.Maintid LIKE 'Cost'
      OR T.Maintid LIKE 'Estt'
      THEN SUM(T.Net)
      ELSE 0
    END Cop,
    CASE
      WHEN T.Maintid LIKE 'Admin'
      THEN SUM(T.Net)
      ELSE 0
    END Ad_Exp,
    CASE
      WHEN T.Maintid NOT LIKE 'Cost'
      AND T.Maintid NOT LIKE 'Estt'
      AND T.Maintid NOT LIKE 'Admin'
      AND T.Maintid NOT LIKE 'a'
      THEN SUM(t.net)
      ELSE 0
    END Fld_Mait_Exp
  FROM
    (SELECT H.Minorgroupingid,
      V.Accounting_Unit_Id,
      V.Account_Head_Code,
      h.Annualgroupingid,
      A.Annualgroupingname,
       h.schemeid,
       --sch.schemename,
      M.Minorgroupingname,
      trim(H.Maintid) Maintid,
    --  SUM(V.cr_Amt)-SUM(v.dr_amt) net
   -- FROM View_Fas_Trial_Cp V
   SUM(V.cr_Amt)-SUM(v.dr_amt) net
    FROM View_Fas_Trial_Cp V
    INNER JOIN Fas_Headofaccounts H
    ON V.Account_Head_Code=H.Accountcode
    INNER JOIN Annualgrouping A
    ON h.Annualgroupingid=a.Annualgroupingid
    INNER JOIN Minorgrouping M
    ON H.Minorgroupingid  =M.Minorgroupingid
  --  inner join schemes sch
   -- on h.schemeid=sch.schemeid
    AND H.Annualgroupingid='A1001'
    AND V.Fin_Year        =$P{year}
    GROUP BY  H.Minorgroupingid,
      V.Accounting_Unit_Id,
      V.Account_Head_Code,
      h.Annualgroupingid,
      A.Annualgroupingname,
      h.schemeid,
      --,sch.schemename,
      M.Minorgroupingname,
     Maintid,
      V.Account_Head_Code
    --ORDER BY V.Account_Head_Code,
    --  V.Accounting_Unit_Id
    UNION ALL
    SELECT H.Minorgroupingid,
      V.Accounting_Unit_Id,
      V.Account_Head_Code,
      h.Annualgroupingid,
      A.Annualgroupingname,
     h.schemeid,
  --  sch.schemename,
      M.Minorgroupingname,
      'a' Maintid,
      SUM(V.cr_Amt)-SUM(v.dr_amt) net
    FROM View_Fas_Trial_Cp V
    INNER JOIN Fas_Headofaccounts H
    ON V.Account_Head_Code=H.Accountcode
    INNER JOIN Annualgrouping A
    ON h.Annualgroupingid=a.Annualgroupingid
    INNER JOIN Minorgrouping M
    ON H.Minorgroupingid =M.Minorgroupingid
   --  inner join schemes sch
  --  on h.schemeid=sch.schemeid
      --  And H.Annualgroupingid='A1001'
    AND H.Accountcode IN (160101,160201,160501,782401,782402,782404,782405)
  -- AND H.Accountcode like '160_0%'
  --   AND H.Accountcode like '782_0%' and h.annualgroupingid in ('B0501','D0301')
    AND V.Fin_Year     =$P{year}
    GROUP BY  H.Minorgroupingid,
      V.Accounting_Unit_Id,
      V.Account_Head_Code,
      h.Annualgroupingid,
      A.Annualgroupingname,
      h.schemeid,
    --,sch.schemename,
      M.Minorgroupingname,
     Maintid,
      V.Account_Head_Code
      --      order by  V.Account_Head_Code,V.Accounting_Unit_Id
    )T where t.net !=0 
  GROUP BY T.Accounting_Unit_Id,
    T.Account_Head_Code,t.schemeid,
    t.Maintid
  ORDER BY T.Accounting_Unit_Id,
    T.Account_Head_Code,t.schemeid
  )Mm inner join fas_mst_acct_units u
  on mm.Accounting_Unit_Id=u.Accounting_Unit_Id
  left outer join schemes s
  on mm.schemeid=s.schemeid  
GROUP BY Mm.Accounting_Unit_Id,u.Accounting_Unit_name,mm.schemeid,s.schemename
ORDER BY mm.Accounting_Unit_Id
]]></queryString>

