	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="sup_query" isForPrompting="false" class="java.lang.String"/>
	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<parameter name="head1" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT 1 as t_data,t.account_head_code,
  t.Account_Head_Desc,
  SUM(t.DR_AMOUNT) DR_AMOUNT,
  SUM(t.CR_AMOUNT) CR_AMOUNT,
  SUM(t.Dr_vel_6868) Dr_vel_6868,
  SUM(t.Cr_vel_6868) Cr_vel_6868,
  SUM(t.Dr_coim_6869) Dr_coim_6869,
  SUM(t.Cr_coim_6869) Cr_coim_6869,
  SUM(t.Dr_Mad_6870) Dr_Mad_6870,
  SUM(t.Cr_Mad_6870) Cr_Mad_6870,
  SUM(t.Dr_Thj_6871) Dr_Thj_6871,
  SUM(t.Cr_Thj_6871) Cr_Thj_6871,
  SUM(t.Dr_Hog_6777) Dr_Hog_6777,
  SUM(t.Cr_Hog_6777) Cr_Hog_6777,
  t.fin_year
FROM
  (SELECT v.account_head_code,
    C.Account_Head_Desc,
    SUM(dr_amt)DR_AMOUNT,
    SUM(CR_AMT)CR_AMOUNT,
    SUM(Dr_Amt)-SUM(Cr_Amt) AS Net_Amt ,
    rv.REGID,
    CASE
      WHEN rv.REGID=6868
      THEN SUM(dr_amt)
      ELSE 0
    END Dr_vel_6868,
    CASE
      WHEN rv.REGID=6868
      THEN SUM(cr_amt)
      ELSE 0
    END Cr_vel_6868,
    CASE
      WHEN rv.REGID=6869
      THEN SUM(dr_amt)
      ELSE 0
    END Dr_coim_6869,
    CASE
      WHEN rv.REGID=6869
      THEN SUM(cr_amt)
      ELSE 0
    END Cr_coim_6869,
    CASE
      WHEN rv.REGID=6870
      THEN SUM(dr_amt)
      ELSE 0
    END Dr_Mad_6870,
    CASE
      WHEN rv.REGID=6870
      THEN SUM(cr_amt)
      ELSE 0
    END Cr_Mad_6870,
    CASE
      WHEN rv.REGID=6871
      THEN SUM(dr_amt)
      ELSE 0
    END Dr_Thj_6871,
    CASE
      WHEN rv.REGID=6871
      THEN SUM(cr_amt)
      ELSE 0
    END Cr_Thj_6871,
    CASE
      WHEN rv.REGID=6777
      THEN SUM(dr_amt)
      ELSE 0
    END Dr_Hog_6777,
    CASE
      WHEN rv.REGID=6777
      THEN SUM(cr_amt)
      ELSE 0
    END Cr_Hog_6777,
    fin_year
  FROM FAS_REGTB_VIEW V
  INNER JOIN com_mst_account_heads c
  ON V.Account_Head_Code=C.Account_Head_Code
  INNER JOIN fas_headofaccounts hh
  ON V.Account_Head_Code=Hh.Accountcode
  INNER JOIN region_cir_div_view RV
  ON rv.didid=v.accounting_for_office_id
$P!{sup_query}    
  GROUP BY v.account_head_code,
    C.Account_Head_Desc,
    rv.REGID,
    fin_year
  )t
GROUP BY t.account_head_code,
  t.Account_Head_Desc,
  t.fin_year
ORDER BY t.account_head_code]]></queryString>

