	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<parameter name="year" isForPrompting="false" class="java.lang.String"/>
	<parameter name="head1" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[Select 1 as t_Data,Mm.Accounting_Unit_Id,U.Accounting_Unit_Name,
  Sum(Mm.Wat_Chrg_Raised) Wr,
  Sum(Mm.Cop) Cop,
  Sum(Mm.Adexp) Ae,
  Sum(Mm.Fld_Maint)Fm,
  Sum(Mm.Cop)+Sum(Mm.Adexp)+Sum(Mm.Fld_Maint) As Tot_Exp,
  Sum(Mm.Wat_Chrg_Raised)-(Sum(Mm.Cop)+Sum(Mm.Adexp)+Sum(Mm.Fld_Maint)) as pro_loss  
FROM
  (SELECT T.Accounting_Unit_Id ,
    T.Minorgroupingid,
    CASE
      WHEN T.Minorgroupingid='1322'
      THEN SUM(T.Net)
      ELSE 0
    END WAT_CHRG_RAISED,
    CASE
      WHEN T.Minorgroupingid='1441'
      THEN SUM(T.Net)
      ELSE 0
    END Cop,
    CASE
      WHEN T.Minorgroupingid='1442'
      THEN SUM(T.Net)
      ELSE 0
    END Adexp,
    CASE
      WHEN T.Minorgroupingid='1443'
      THEN SUM(T.Net)
      ELSE 0
    END Fld_Maint
  FROM
    (SELECT H.Minorgroupingid,
      V.Accounting_Unit_Id,
      V.Account_Head_Code,
      h.Annualgroupingid,
      A.Annualgroupingname,
      M.Minorgroupingname,
      SUM(V.dr_Amt)-SUM(cr_amt) net
    FROM View_Fas_Trial_Cp V
    INNER JOIN Fas_Headofaccounts H
    ON V.Account_Head_Code=H.Accountcode
    INNER JOIN Annualgrouping A
    ON h.Annualgroupingid=a.Annualgroupingid
    INNER JOIN Minorgrouping M
    ON H.Minorgroupingid  =M.Minorgroupingid
    AND H.Annualgroupingid='A1002'
      -- H.Accountcode=160502
    AND V.Fin_Year='2011-2012'
    GROUP BY H.Minorgroupingid,
      V.Accounting_Unit_Id,
      V.Account_Head_Code,
      h.Annualgroupingid,
      A.Annualgroupingname,
      M.Minorgroupingname,
      V.Account_Head_Code
    UNION ALL
    SELECT H.Minorgroupingid,
      V.Accounting_Unit_Id,
      V.Account_Head_Code,
      h.Annualgroupingid,
      A.Annualgroupingname,
      M.Minorgroupingname,
      SUM(V.cr_Amt)-SUM(dr_amt)net
    FROM View_Fas_Trial_Cp V
    INNER JOIN Fas_Headofaccounts H
    ON V.Account_Head_Code=H.Accountcode
    INNER JOIN Annualgrouping A
    ON h.Annualgroupingid=a.Annualgroupingid
    INNER JOIN Minorgrouping M
    ON H.Minorgroupingid =M.Minorgroupingid
      --And  H.Annualgroupingid='A1002'
    AND H.Accountcode=160502
    AND V.Fin_Year   ='2011-2012'
    GROUP BY H.Minorgroupingid,
      V.Accounting_Unit_Id,
      V.Account_Head_Code,
      h.Annualgroupingid,
      A.Annualgroupingname,
      M.Minorgroupingname
    )T
  GROUP BY T.Accounting_Unit_Id ,
    T.Minorgroupingid
  )Mm Inner Join Fas_Mst_Acct_Units U On
  mm.Accounting_Unit_Id=U.Accounting_Unit_Id
GROUP BY mm.Accounting_Unit_Id,U.Accounting_Unit_Name
ORDER BY mm.Accounting_Unit_Id]]></queryString>

