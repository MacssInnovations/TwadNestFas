<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Work_Expr_Report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="623"
		 pageHeight="842"
		 columnWidth="563"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="2" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[Select 
a.Data_Tb,a.Projectid,
A.Projectname,
a.Programid,a.Programname,
Sum(A.Dr_Amount)Dr_Amount,
Sum(A.Cr_Amount) Cr_Amount,
Sum(A.Net_Amt) Net_Amt,
a.  Fin_Year from
(Select 1 As Data_Tb,Fh.Projectid,
Pr.Projectname,
Case When Length(Fh.Programid)<2 Then '0'||Fh.Programid
Else Fh.Programid End Programid,Pg.Programname,
v.account_head_code,
  SUM(dr_amt)DR_AMOUNT,
  SUM(CR_AMT)CR_AMOUNT,
  SUM(dr_amt)-SUM(cr_amt) AS net_amt ,
  Fin_Year
From View_Fas_Trial V Inner Join Fas_Headofaccounts Fh
On V.Account_Head_Code=Fh.Accountcode
Inner Join Project Pr
on Fh.Projectid=Pr.Projectid
Inner Join Program Pg
on Fh.Programid=Pg.Programid
and Cmonth Between '01-APR-2012' And '02-MAR-2013'
And Fh.Minorgroupingid='1166'
Group By Fh.Projectid,Pr.Projectname,
Fh.Programid,Pg.Programname,V.Account_Head_Code, Fin_Year
)A
Group By a.Data_Tb,A.Projectid,A.Projectname,
a.PROGRAMID,a.Programname,a.Fin_Year
Order By  A.Projectid,
a.Programid]]></queryString>

	<field name="DATA_TB" class="java.math.BigDecimal"/>
	<field name="PROJECTID" class="java.lang.String"/>
	<field name="PROJECTNAME" class="java.lang.String"/>
	<field name="PROGRAMID" class="java.lang.String"/>
	<field name="PROGRAMNAME" class="java.lang.String"/>
	<field name="DR_AMOUNT" class="java.math.BigDecimal"/>
	<field name="CR_AMOUNT" class="java.math.BigDecimal"/>
	<field name="NET_AMT" class="java.math.BigDecimal"/>
	<field name="FIN_YEAR" class="java.lang.String"/>

