<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Twad_os_Summary_Dteails"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="651"
		 pageHeight="735"
		 columnWidth="591"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="fin_year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="type" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fin" isForPrompting="false" class="java.lang.String"/>
	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<parameter name="xml" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT test1.*,
  test2.*
FROM
  (SELECT reg,
    off1.OFFICE_ID AS regid,
    cir,
    off2.OFFICE_ID AS cirid ,
    div,
    off3.OFFICE_ID AS didid,
    (select ACCOUNTING_UNIT_ID from FAS_MST_ACCT_UNITS where ACCOUNTING_UNIT_OFFICE_ID= off3.OFFICE_ID)as unit_id
  FROM
    (SELECT REGION_OFFICE_ID,
      CIRCLE_OFFICE_ID,
      OFFICE_LEVEL_ID,
      OFFICE_ID ,
      OFFICE_NAME AS reg
    FROM COM_MST_ALL_OFFICES_VIEW
    WHERE OFFICE_LEVEL_ID='RN'
    )Off1
  JOIN
    (SELECT REGION_OFFICE_ID,
      OFFICE_LEVEL_ID,
      OFFICE_ID,
      OFFICE_NAME AS cir
    FROM COM_MST_ALL_OFFICES_VIEW
    WHERE OFFICE_LEVEL_ID='CL'
    )off2
  ON off2.REGION_OFFICE_ID=off1.OFFICE_ID
  JOIN
    (SELECT REGION_OFFICE_ID,
      CIRCLE_OFFICE_ID,
      OFFICE_LEVEL_ID,
      OFFICE_ID,
      OFFICE_NAME AS div
    FROM COM_MST_ALL_OFFICES_VIEW
    WHERE OFFICE_LEVEL_ID='DN'
    )off3
  ON off3.REGION_OFFICE_ID =off1.OFFICE_ID
  AND off3.CIRCLE_OFFICE_ID=off2.OFFICE_ID
  ORDER BY off1.office_id,
    off2.office_id,
    off3.office_id
  )test1
JOIN
  (SELECT aa.ACCOUNTING_UNIT_ID,
  (SELECT ACCOUNTING_UNIT_NAME
  FROM FAS_MST_ACCT_UNITS
  WHERE ACCOUNTING_UNIT_ID= aa.ACCOUNTING_UNIT_ID
  )AS unit_name,
  aa.LB_TYPE,AA.PROGRAM_ID,
  case aa.LB_TYPE 
when 'C' then 'Corporation'  
when 'T' then 'Townpanchayat'  
when 'M' then 'Municipality'  
when 'O' then 'Others'  
  end as LB_TYPE_DESC,
  (select IMISCLASSIFICATION from IMISGROUPING where ID=AA.PROGRAM_ID)as program_desc,
  SUM(aa.TIE_UP_AMT)                        AS TIE_UP_AMT,
  SUM(aa.EXP_BOOKED_UPTO_CUR_MAR)           AS EXP_BOOKED_UPTO_CUR_MAR,
  SUM(aa.bills_pending)                     AS bills_pending,
  SUM(aa.AMT_RECEIVED_UPTO_CUR_MAR)         AS AMT_RECEIVED_UPTO_CUR_MAR,
  DECODE(SUM(ft),NULL,0,SUM(ft))            AS fund_Tie,
  DECODE(SUM(Exp_bk),NULL,0,SUM(Exp_bk))    AS Exp_book,
  DECODE(SUM(Exp_Paid),NULL,0,SUM(Exp_Paid))AS Exp_Paid
FROM
  (SELECT a.ACCOUNTING_UNIT_ID,
    a.LB_TYPE,
   A.PROGRAM_ID,
    a.TIE_UP_AMT,
    a.EXP_BOOKED_UPTO_CUR_MAR,
    a.bills_pending,
    a.AMT_RECEIVED_UPTO_CUR_MAR,
    CASE
      WHEN (a.TIE_UP_AMT-a.AMT_RECEIVED_UPTO_CUR_MAR)<0
      THEN 0
      ELSE (a.TIE_UP_AMT-a.AMT_RECEIVED_UPTO_CUR_MAR)
    END AS ft,
    CASE
      WHEN (a.EXP_BOOKED_UPTO_CUR_MAR-a.AMT_RECEIVED_UPTO_CUR_MAR)<0
      THEN 0
      ELSE (a.EXP_BOOKED_UPTO_CUR_MAR-a.AMT_RECEIVED_UPTO_CUR_MAR)
    END AS Exp_bk,
    CASE
      WHEN (a.bills_pending-a.AMT_RECEIVED_UPTO_CUR_MAR)<0
      THEN 0
      ELSE (a.bills_pending-a.AMT_RECEIVED_UPTO_CUR_MAR)
    END AS Exp_Paid
  FROM twad_board_outstandings a
  WHERE YEAR     =$P{fin_year}
  AND a.lb_type IN ('M','T','C')
  )aa
GROUP BY aa.ACCOUNTING_UNIT_ID,aa.LB_TYPE,
    aa.PROGRAM_ID
ORDER BY aa.ACCOUNTING_UNIT_ID,
  aa.LB_TYPE,aa.PROGRAM_ID
  )test2
ON test1.unit_id=test2.ACCOUNTING_UNIT_ID
$P!{xml}
 ORDER BY test2.ACCOUNTING_UNIT_ID,
  test2.LB_TYPE, test2.PROGRAM_ID]]></queryString>

