	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="fin_year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="type" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fin" isForPrompting="false" class="java.lang.String"/>
	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT a.*,case when (a.TIE_UP_AMT-a.AMT_RECEIVED_UPTO_CUR_MAR)<0 then 0
else (a.TIE_UP_AMT-a.AMT_RECEIVED_UPTO_CUR_MAR)
end as ft,
case when (a.EXP_BOOKED_UPTO_CUR_MAR-a.AMT_RECEIVED_UPTO_CUR_MAR)<0 then 0
else (a.EXP_BOOKED_UPTO_CUR_MAR-a.AMT_RECEIVED_UPTO_CUR_MAR)
end as Exp_bk,
case when (a.BILLS_PENDING-a.AMT_RECEIVED_UPTO_CUR_MAR)<0 then 0
else (a.BILLS_PENDING-a.AMT_RECEIVED_UPTO_CUR_MAR)
end as Exp_Paid,
  (SELECT ACCOUNTING_UNIT_NAME
  FROM FAS_MST_ACCT_UNITS
  WHERE ACCOUNTING_UNIT_ID=a.ACCOUNTING_UNIT_ID
  )AS unit_Desc,
  (SELECT IMISCLASSIFICATION FROM IMISGROUPING WHERE ID=a.PROGRAM_ID
  )AS program_desc
FROM twad_board_outstandings a
WHERE ACCOUNTING_UNIT_ID=$P{unit_id}
AND YEAR                =$P{fin_year}
AND OUTSTANDING_TYPE    =$P{type}
ORDER BY slno]]></queryString>

