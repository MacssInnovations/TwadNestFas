	<field name="EXP_PAID" class="java.math.BigDecimal"/>

	<variable name="sum_Ft" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{FUND_TIE}]]></variableExpression>
	</variable>
	<variable name="sum_Bk" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
