	<parameter name="fin_year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="type" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fin" isForPrompting="false" class="java.lang.String"/>
	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT aa.LB_TYPE,
case  when aa.LB_TYPE='M' then 'Municipality'
when aa.LB_TYPE='M' then 'Municipality'
when aa.LB_TYPE='C' then 'Corporation'
when aa.LB_TYPE='T' then 'Townpanchayat'
when aa.LB_TYPE='O' then 'Others' end as LB_TYPE_DESC, 
   sum(aa.TIE_UP_AMT)as TIE_UP_AMT,
   sum(aa.EXP_BOOKED_UPTO_CUR_MAR)as EXP_BOOKED_UPTO_CUR_MAR,
   sum(aa.bills_pending) as bills_pending,
   sum(aa.AMT_RECEIVED_UPTO_CUR_MAR)as AMT_RECEIVED_UPTO_CUR_MAR,
 
  DECODE(SUM(ft),NULL,0,SUM(ft))            AS fund_Tie,
  DECODE(SUM(Exp_bk),NULL,0,SUM(Exp_bk))    AS Exp_book,
  DECODE(SUM(Exp_Paid),NULL,0,SUM(Exp_Paid))AS Exp_Paid
FROM
  (SELECT a.LB_TYPE,
    a.TIE_UP_AMT,a.EXP_BOOKED_UPTO_CUR_MAR,a.bills_pending,a.AMT_RECEIVED_UPTO_CUR_MAR,
    CASE
      WHEN (a.TIE_UP_AMT-a.AMT_RECEIVED_UPTO_CUR_MAR)<0
      THEN 0
      ELSE (a.TIE_UP_AMT-a.AMT_RECEIVED_UPTO_CUR_MAR)
    END AS ft,
    CASE
      WHEN (a.EXP_BOOKED_UPTO_CUR_MAR-a.AMT_RECEIVED_UPTO_CUR_MAR)<0
      THEN 0
      ELSE (a.EXP_BOOKED_UPTO_CUR_MAR-a.AMT_RECEIVED_UPTO_CUR_MAR)
    END AS Exp_bk,
    CASE
      WHEN (a.bills_pending-a.AMT_RECEIVED_UPTO_CUR_MAR)<0
      THEN 0
      ELSE (a.bills_pending-a.AMT_RECEIVED_UPTO_CUR_MAR)
    END AS Exp_Paid
  FROM twad_board_outstandings a
  WHERE YEAR     =$P{fin_year}
  AND a.lb_type IN ('M','T','C')
  )aa
GROUP BY aa.LB_TYPE
ORDER BY aa.LB_TYPE]]></queryString>

