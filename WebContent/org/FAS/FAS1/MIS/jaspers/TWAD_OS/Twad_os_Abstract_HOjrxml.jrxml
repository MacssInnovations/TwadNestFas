	</variable>
	<variable name="tot_Ft" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{FUND_TIE}]]></variableExpression>
	</variable>
	<variable name="tot_Bk" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
