<jasperReport
		 name="Twad_os_Abstract"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="623"
		 pageHeight="735"
		 columnWidth="563"
		 columnSpacing="0"
