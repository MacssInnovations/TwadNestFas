	<variable name="tot" class="java.math.BigDecimal" resetType="Group" incrementType="Group" incrementGroup="unitwise" resetGroup="unitwise" calculation="Sum">
		<variableExpression><![CDATA[$F{APR}.add( $F{MAY} ).add($F{JUN}).add($F{JUL}).add($F{AUG}).add($F{SEP}).add($F{OCT}).add($F{NOV}).add($F{DEC}).add($F{JAN}).add($F{FEB}).add($F{MAR})]]></variableExpression>
	</variable>
