<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="EXPND_Rpt_Yearwise"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1016"
		 pageHeight="842"
		 columnWidth="1016"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[SELECT x.accounting_unit_id,
  x.unitdesc AS uname,
  x.account_head_code,
  x.Headdesc,
  MAX(
  CASE
    WHEN x.cashbook_month=4
    THEN tot
    ELSE 0
  END )AS APR,
  MAX(
  CASE
    WHEN x.cashbook_month=5
    THEN tot
    ELSE 0
  END )AS MAY,
  MAX(
  CASE
    WHEN x.cashbook_month=6
    THEN tot
    ELSE 0
  END )AS JUN,
  MAX(
  CASE
    WHEN x.cashbook_month=7
    THEN tot
    ELSE 0
  END )AS Jul,
  MAX(
  CASE
    WHEN x.CASHBOOK_MONTH=8
    THEN tot
    ELSE 0
  END )AS AUG,
  MAX(
  CASE
    WHEN cashbook_month=9
    THEN tot
    ELSE 0
  END )AS SEP,
  MAX(
  CASE
    WHEN x.CASHBOOK_MONTH=10
    THEN tot
    ELSE 0
  END )AS OCT,
  MAX(
  CASE
    WHEN x.CASHBOOK_MONTH=11
    THEN tot
    ELSE 0
  END )AS NOV,
  MAX(
  CASE
    WHEN x.CASHBOOK_MONTH=12
    THEN tot
    ELSE 0
  END )AS DEC,
  MAX(
  CASE
    WHEN x.CASHBOOK_MONTH=1
    THEN tot
    ELSE 0
  END )AS JAN,
  MAX(
  CASE
    WHEN x.CASHBOOK_MONTH=2
    THEN tot
    ELSE 0
  END )AS FEB,
  MAX(
  CASE
    WHEN x.CASHBOOK_MONTH=3
    THEN tot
    ELSE 0
  END ) AS mar
FROM
  (SELECT DISTINCT a.accounting_unit_id,
    a.unitdesc,
    a.offc,
    a.account_head_code,
    a.Headdesc,
    a.cashbook_month,
    a.cashbook_year,
    a.current_month_credit,
    a.current_month_debit,
    (SUM(a.current_month_debit)-SUM(a.current_month_credit)) AS tot
  FROM
    (SELECT t.accounting_unit_id,
      (SELECT acc.accounting_unit_name
      FROM fas_mst_acct_units acc
      WHERE acc.accounting_unit_id=t.accounting_unit_id
      ) AS unitdesc,
      (SELECT acc.accounting_unit_office_id
      FROM fas_mst_acct_units acc
      WHERE acc.accounting_unit_id=t.accounting_unit_id
      ) AS offc,
      T.Account_Head_Code,
      (SELECT S.Account_Head_Desc
      FROM Com_Mst_Account_Heads S
      WHERE s.account_head_code=t.account_head_code
      )AS headdesc,
      t.cashbook_month,
      t.cashbook_year,
      t.current_month_credit,
      t.current_month_debit
    FROM FAS_TRIAL_BALANCE_CMP t
    WHERE To_Date((Cashbook_Month
      ||'-'
      || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
      ||'-'
      ||2020,'mm-yyyy')
    AND to_date(3
      ||'-'
      ||2021,'mm-yyyy')
    UNION ALL
    SELECT t.accounting_unit_id,
      (SELECT acc.accounting_unit_name
      FROM fas_mst_acct_units acc
      WHERE acc.accounting_unit_id=t.accounting_unit_id
      ) AS unitdesc,
      (SELECT acc.accounting_unit_office_id
      FROM fas_mst_acct_units acc
      WHERE acc.accounting_unit_id=t.accounting_unit_id
      ) AS offc,
      T.Account_Head_Code,
      (SELECT S.Account_Head_Desc
      FROM Com_Mst_Account_Heads S
      WHERE s.account_head_code=t.account_head_code
      )AS Headdesc,
      t.cashbook_month,
      t.cashbook_year,
      t.current_month_credit,
      t.current_month_debit
    FROM fas_trial_balance_sjv_cmp t
    WHERE Cashbook_Year=2021
    AND cashbook_month =3
    AND supplement_no <=1
    )a
  JOIN
    (SELECT account_head_code,
      ACCOUNT_HEAD_DESC,
      major_head_code
    FROM com_mst_account_heads
    WHERE major_head_code='E'
    ORDER BY account_head_code
    )b
  ON a.account_head_code=b.account_head_code
  AND a.offc            =5000
  GROUP BY a.accounting_unit_id,
    a.unitdesc,
    a.offc,
    a.account_head_code,
    a.Headdesc,
    a.cashbook_month,
    a.cashbook_year,
    a.current_month_credit,
    a.current_month_debit
  UNION ALL
  SELECT DISTINCT a.accounting_unit_id,
    a.unitdesc,
    a.offc,
    a.account_head_code,
    a.Headdesc,
    a.cashbook_month,
    a.cashbook_year,
    a.current_month_credit,
    a.current_month_debit,
    (SUM(a.current_month_debit)-SUM(a.current_month_credit)) AS tot
  FROM
    (SELECT t.accounting_unit_id,
      (SELECT acc.accounting_unit_name
      FROM fas_mst_acct_units acc
      WHERE acc.accounting_unit_id=t.accounting_unit_id
      ) AS unitdesc,
      (SELECT acc.accounting_unit_office_id
      FROM fas_mst_acct_units acc
      WHERE acc.accounting_unit_id=t.accounting_unit_id
      ) AS offc,
      T.Account_Head_Code,
      (SELECT S.Account_Head_Desc
      FROM Com_Mst_Account_Heads S
      WHERE s.account_head_code=t.account_head_code
      )AS Headdesc,
      t.cashbook_month,
      t.cashbook_year,
      t.current_month_credit,
      t.current_month_debit
    FROM FAS_TRIAL_BALANCE_CMP t
    WHERE To_Date((Cashbook_Month
      ||'-'
      || Cashbook_Year),'mm-yyyy') BETWEEN To_Date(4
      ||'-'
      ||2020,'mm-yyyy')
    AND to_date(3
      ||'-'
      ||2021,'mm-yyyy')
    UNION ALL
    SELECT t.accounting_unit_id,
      (SELECT acc.accounting_unit_name
      FROM fas_mst_acct_units acc
      WHERE acc.accounting_unit_id=t.accounting_unit_id
      ) AS unitdesc,
      (SELECT acc.accounting_unit_office_id
      FROM fas_mst_acct_units acc
      WHERE acc.accounting_unit_id=t.accounting_unit_id
      ) AS offc,
      T.Account_Head_Code,
      (SELECT S.Account_Head_Desc
      FROM Com_Mst_Account_Heads S
      WHERE s.account_head_code=t.account_head_code
      )AS Headdesc,
      t.cashbook_month,
      t.Cashbook_Year,
      t.current_month_credit,
      t.current_month_debit
    FROM fas_trial_balance_sjv_cmp t
    WHERE Cashbook_Year=2021
    AND cashbook_month =3
    AND supplement_no <=1
    )a
  JOIN
    (SELECT account_head_code,
      ACCOUNT_HEAD_DESC,
      major_head_code
    FROM com_mst_account_heads
    WHERE major_head_code='E'
    ORDER BY account_head_code
    )b
  ON a.account_head_code   =b.account_head_code
  AND a.offc!              =5000
  AND a.account_head_code IN (201525,201325,201367,201510)
  GROUP BY a.accounting_unit_id,
    a.unitdesc,
    a.offc,
    a.account_head_code,
    a.Headdesc,
    a.cashbook_month,
    a.cashbook_year,
    a.current_month_credit,
    a.current_month_debit
  ORDER BY accounting_unit_id,
    account_head_code,
    cashbook_year,
    cashbook_month
  )x
GROUP BY x.accounting_unit_id,
  x.unitdesc,
  x.account_head_code,
  x.Headdesc 
ORDER BY x.accounting_unit_id,
  x.account_head_code]]></queryString>

