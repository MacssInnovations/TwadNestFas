<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="AccountheadgroupExcelfinal"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="801"
		 pageHeight="842"
		 columnWidth="801"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="frm_year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="to_year" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT majorhead, 
 minorhead,
  subhead,
  ACCOUNT_HEAD_CODE,
  account_head_des,
  CURRENT_MONTH_DEBIT,
  CURRENT_MONTH_CREDIT,
  case
    WHEN ( current_month_debit     - current_month_credit ) > 0
      THEN ' Dr'
      ELSE ' Cr'
    END                                                   AS curr_net_disp,
  --NVL(( current_month_credit - current_month_debit ),0) AS curr_net
NVL(( current_month_debit - current_month_credit ),0) AS curr_net
FROM
  (SELECT ag.majorhead,
    ag.minorhead,
    ag.subhead,
    X.ACCOUNT_HEAD_CODE,
    (SELECT ACCOUNT_HEAD_DESC
    FROM com_mst_account_heads
    WHERE ACCOUNT_HEAD_CODE = X.ACCOUNT_HEAD_CODE
    )                         AS account_head_des,
    SUM(current_month_debit)  AS current_month_debit ,
    SUM(current_month_credit) AS current_month_credit
  FROM
    (SELECT ftbr.account_head_code,
      ftbr.current_month_debit,
      ftbr.current_month_credit
    FROM FAS_TRIAL_BALANCE FTBR
    WHERE (ftbr.cashbook_year =$P{frm_year}
    AND ftbr.cashbook_month  >=4
    AND FTBR.CASHBOOK_MONTH  <=12)
    OR (ftbr.cashbook_year    =$P{to_year}
    AND ftbr.cashbook_month  >=1
    AND ftbr.cashbook_month  <=3)
    UNION ALL
    SELECT ftbs.account_head_code,
      ftbs.current_month_debit,
      ftbs.current_month_credit
    FROM FAS_TRIAL_BALANCE_SUPPLEMENT FTBS
    WHERE FTBS.CASHBOOK_YEAR =$P{to_year}
    ) x,
    fas_ho_annualgrouping ag
  WHERE x.account_head_code =ag.hoa
  GROUP BY AG.MAJORHEAD,
    MAJORHEADSORTORDER,
    AG.MINORHEAD,
    MINORHEADSORTORDER,
    AG.SUBHEAD,
    SUBHEADSORTORDER,
    ACCOUNT_HEAD_CODE
  ORDER BY Majorheadsortorder,
    minorheadsortorder,
    SUBHEADSORTORDER,
    ACCOUNT_HEAD_CODE
  )]]></queryString>

