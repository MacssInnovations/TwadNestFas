			<band height="42"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="25"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="53"
