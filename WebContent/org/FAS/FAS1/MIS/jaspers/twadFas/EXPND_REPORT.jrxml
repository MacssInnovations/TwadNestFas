<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="EXPND_REPORT"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="283"
		 pageHeight="802"
		 columnWidth="283"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pre_year" isForPrompting="false" class="java.lang.String"/>
	<parameter name="cur_year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fin_year" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT ACCOUNT_HEAD_CODE,
  account_head_des,
  CURRENT_MONTH_DEBIT,
  current_month_credit,
  SUM(curr_net)/100000 AS curr_net,
  curr_net_disp
FROM
  (SELECT T.ACCOUNT_HEAD_CODE,
    T. account_head_des,
    T.CURRENT_MONTH_DEBIT,
    T.CURRENT_MONTH_CREDIT,
    CASE
      WHEN (NVL(( CURRENT_MONTH_DEBIT - CURRENT_MONTH_CREDIT ),0)) < 0
      THEN (current_month_debit       - current_month_credit )*-1
      ELSE (current_month_debit       - current_month_credit )
    END AS curr_net,
    CASE
      WHEN ( current_month_debit - current_month_credit ) > 0
      THEN ' Dr'
      ELSE ' Cr'
    END AS curr_net_disp
  FROM
    (SELECT ACCOUNT_HEAD_CODE,
      account_head_des,
      SUM(CURRENT_MONTH_DEBIT)  AS CURRENT_MONTH_DEBIT,
      SUM(current_month_credit) AS current_month_credit
    FROM
      (SELECT X.ACCOUNT_HEAD_CODE,
        (SELECT ACCOUNT_HEAD_DESC
        FROM com_mst_account_heads
        WHERE ACCOUNT_HEAD_CODE = X.ACCOUNT_HEAD_CODE
        )                         AS account_head_des,
        SUM(current_month_debit)  AS current_month_debit ,
        SUM(current_month_credit) AS current_month_credit
      FROM
        (SELECT ftbr.account_head_code,
          ftbr.current_month_debit,
          ftbr.current_month_credit
        FROM FAS_TRIAL_BALANCE FTBR
        WHERE (ftbr.cashbook_year =2020
        AND ftbr.cashbook_month  >=4
        AND FTBR.CASHBOOK_MONTH  <=12)
        OR (ftbr.cashbook_year    = 2021
        AND ftbr.cashbook_month  >=1
        AND ftbr.cashbook_month  <=3)
        UNION ALL
        SELECT ftbs.account_head_code,
          ftbs.current_month_debit,
          ftbs.current_month_credit
        FROM FAS_TRIAL_BALANCE_SUPPLEMENT FTBS
        WHERE ftbs.cashbook_year = 2021
        ) x,
        fas_ho_annualgrouping ag
      WHERE X.ACCOUNT_HEAD_CODE =AG.HOA
      AND AG.MAJORHEADSORTORDER = 2
      AND AG.FINYEARSTART       = 2020
      AND ag.finyearend         = 2021
      AND AG.HOA               IN (222101,222102,222103,222104,222105,222106,222107,222108,222109,222110,222111)
      GROUP BY AG.MAJORHEAD,
        MAJORHEADSORTORDER,
        ag.minorhead,
        MINORHEADSORTORDER,
        AG.SUBHEAD,
        SUBHEADSORTORDER,
        ACCOUNT_HEAD_CODE
      ORDER BY Majorheadsortorder,
        minorheadsortorder,
        subheadsortorder,
        account_head_code
      )
    GROUP BY ACCOUNT_HEAD_CODE,
      account_head_des
    ORDER BY account_head_code
    )t
  )
GROUP BY ACCOUNT_HEAD_CODE,
  account_head_des,
  CURRENT_MONTH_DEBIT,
  current_month_credit,
  curr_net_disp]]></queryString>

	<field name="ACCOUNT_HEAD_CODE" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_HEAD_DES" class="java.lang.String"/>
	<field name="CURRENT_MONTH_DEBIT" class="java.math.BigDecimal"/>
	<field name="CURRENT_MONTH_CREDIT" class="java.math.BigDecimal"/>
	<field name="CURR_NET" class="java.math.BigDecimal"/>
	<field name="CURR_NET_DISP" class="java.lang.String"/>

	<variable name="curr_total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CURR_NET}]]></variableExpression>
	</variable>
		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</title>
		<pageHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageHeader>
		<columnHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnHeader>
		<detail>
			<band height="14"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="0"
						width="191"
						height="14"
						key="textField"/>
					<box leftPadding="2" rightPadding="2">					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement lineSpacing="1_1_2">
						<font fontName="Times-Roman" size="8"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{ACCOUNT_HEAD_DES}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" pattern="#,##0.00" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="167"
						y="0"
						width="80"
						height="14"
						key="textField"/>
					<box leftPadding="2" rightPadding="2">					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
</box>
					<textElement textAlignment="Right">
						<font fontName="Times-Roman" size="9"/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$F{CURR_NET}]]></textFieldExpression>
				</textField>
			</band>
		</detail>
		<columnFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnFooter>
		<pageFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageFooter>
		<summary>
			<band height="25"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" pattern="##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="166"
						y="6"
						width="80"
						height="16"
						key="textField"/>
					<box></box>
					<textElement textAlignment="Right">
						<font pdfFontName="Helvetica-Bold" size="9" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$V{curr_total}]]></textFieldExpression>
				</textField>
				<line direction="TopDown">
					<reportElement
						x="172"
						y="23"
						width="79"
						height="0"
						key="line-3"/>
					<graphicElement stretchType="NoStretch"/>
				</line>
				<line direction="TopDown">
					<reportElement
						x="172"
						y="3"
						width="80"
						height="0"
						key="line-4"/>
					<graphicElement stretchType="NoStretch"/>
				</line>
			</band>
		</summary>
</jasperReport>
