<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="yearwise"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="425"
		 pageHeight="842"
		 columnWidth="365"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[SELECT 'Quantity Supplied' AS qtyname,
  'Demand'                 AS dmdname,
  'Collection'             AS col,
  FIN_YEAR                 AS YEAR,
  SUM(Qty)       /100000         AS Qty,
  SUM(DMD)       /100000         AS DMD ,
  SUM(Collection)/100000         AS Collection
FROM
  (SELECT BILL.FIN_YEAR,
    BILL.QTY,
    COLL.DMD,
    COLL.COLLECTION
  FROM
    (SELECT BENEFICIARY_SNO,
      BENEFICIARY_NAME ,
      OFFICE_ID,
      BENEFICIARY_TYPE_ID_SUB
    FROM PMS_DCB_MST_BENEFICIARY
    )ben
  LEFT JOIN
    (SELECT YEAR,
      MONTH,
      FIN_YEAR,
      BENEFICIARY_SNO,
      SUM( QTY_CONSUMED ) AS QTY
    FROM Pms_Dcb_Wc_Billing_fin
    WHERE FIN_YEAR = 2020
    GROUP BY YEAR,
      MONTH,
      FIN_YEAR,
      BENEFICIARY_SNO
    )BILL
  ON BILL.BENEFICIARY_SNO=BEN.BENEFICIARY_SNO
  LEFT JOIN
    (SELECT BENEFICIARY_SNO,
      BILL_MONTH,
      BILL_YEAR,
      FIN_YEAR,
      SUM(MONTH_BILL_AMT)                                                                                                                                                     AS DMD,
      ((SUM(COLN_CUR_YR_WC) +SUM(COLN_MAINT) + SUM(COLN_YESTER_YR_WC) +SUM(MINUS_CHARGES_WC) + SUM(MINUS_CHARGES_MAINT) ) - (SUM(ADD_CHARGES_WC) + SUM(ADD_CHARGES_MAINT) ) ) AS COLLECTION -- add maintanence Journal
    FROM PMS_DCB_TRN_BILL_DMD_FIN
    WHERE FIN_YEAR = 2020
    GROUP BY BENEFICIARY_SNO,
      BILL_MONTH,
      BILL_YEAR,
      FIN_YEAR
    )Coll
  ON Ben.Beneficiary_Sno=Coll.Beneficiary_Sno
  AND BILL.month        =COLL.BILL_MONTH
  AND BILL.YEAR         =COLL.BILL_YEAR
  )
WHERE FIN_YEAR IS NOT NULL
GROUP BY 'Quantity Supplied',
  'Demand',
  'Collection',
  FIN_YEAR
ORDER BY FIN_YEAR]]></queryString>

	<field name="QTYNAME" class="java.lang.String"/>
	<field name="DMDNAME" class="java.lang.String"/>
	<field name="COL" class="java.lang.String"/>
	<field name="YEAR" class="java.math.BigDecimal"/>
	<field name="QTY" class="java.math.BigDecimal"/>
	<field name="DMD" class="java.math.BigDecimal"/>
	<field name="COLLECTION" class="java.math.BigDecimal"/>

