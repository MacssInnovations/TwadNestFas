<jasperReport
		 name="INCOME-EXPND_REPORT_subreport3"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="353"
		 pageHeight="802"
		 columnWidth="353"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pre_year" isForPrompting="false" class="java.lang.String"/>
	<parameter name="cur_year" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[Select T.Annualgroupingid,T.Annualgroupingname,
  Sum(T.Net)PREv_Net,
  SUM(x.net)Curr_Net
FROM
  (Select V.Account_Head_Code,
    Fh.Annualgroupingid,Ag.Annualgroupingname,
    Fin_Year,
    SUM(Dr_Amt)Dr,
    SUM(Cr_Amt)Cr,
    SUM(Dr_Amt)-SUM(Cr_Amt) net
  FROM View_Fas_Trial V
  INNER JOIN Fas_Headofaccounts Fh
  ON V.Account_Head_Code=Fh.Accountcode
  INNER JOIN Annualgrouping Ag
  On Ag.Annualgroupingid=Fh.Annualgroupingid
  And Fin_Year         ='2011-2012'
  AND Ag.Categoryid     =1
  Group By V.Account_Head_Code,
    Fh.Annualgroupingid,Ag.Annualgroupingname,
    Fin_Year
  )T left outer join
  (Select V.Account_Head_Code,
    Fh.Annualgroupingid,Ag.Annualgroupingname,
    Fin_Year,
    SUM(Dr_Amt)Dr,
    SUM(Cr_Amt)Cr,
    SUM(Dr_Amt)-SUM(Cr_Amt) net
  FROM View_Fas_Trial V
  INNER JOIN Fas_Headofaccounts Fh
  ON V.Account_Head_Code=Fh.Accountcode
  INNER JOIN Annualgrouping Ag
  On Ag.Annualgroupingid=Fh.Annualgroupingid
  And Fin_Year          ='2012-2013'
  AND Ag.Categoryid     =1 
  Group By V.Account_Head_Code,
    Fh.Annualgroupingid,Ag.Annualgroupingname,
    Fin_Year
 )X  
 on T.Annualgroupingid=X.Annualgroupingid
Group By T.Annualgroupingid,T.Annualgroupingname,X.Annualgroupingid,X.Annualgroupingname
ORDER BY t.Annualgroupingid,x.Annualgroupingid]]></queryString>

	<field name="ANNUALGROUPINGID" class="java.lang.String"/>
	<field name="ANNUALGROUPINGNAME" class="java.lang.String"/>
	<field name="PREV_NET" class="java.math.BigDecimal"/>
	<field name="CURR_NET" class="java.math.BigDecimal"/>

