	<variable name="sum(credit)" class="java.math.BigDecimal" resetType="Group" resetGroup="catgory" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT}]]></variableExpression>
	</variable>
	<variable name="sum(debit)" class="java.math.BigDecimal" resetType="Group" resetGroup="catgory" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT}]]></variableExpression>
	</variable>
	<variable name="sum(net)" class="java.math.BigDecimal" resetType="Group" resetGroup="catgory" calculation="Sum">
		<variableExpression><![CDATA[$F{NET}]]></variableExpression>
	</variable>
	<variable name="tot(debit)" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DEBIT}]]></variableExpression>
	</variable>
	<variable name="tot(credit)" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CREDIT}]]></variableExpression>
	</variable>
	<variable name="tot_net" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{NET}]]></variableExpression>
	</variable>

