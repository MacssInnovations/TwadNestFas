	<parameter name="Cb_FromYear" isForPrompting="false" class="java.lang.String"/>
	<parameter name="Cb_ToYear" isForPrompting="true" class="java.lang.String"/>
	<parameter name="Fin_year" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.id,
--a.minor,
 a.minor||'-'||
(SELECT MINORGROUPINGNAME
  FROM MINORGROUPING
  WHERE MINORGROUPINGID=a.minor
  ) as minor,
  lpad(a.id,3,0)||'-'||b.description as description,
  nvl(A.AMOUNT,0)AMOUNT
FROM TWAD_CONSOLIDATED_DATA a,
  TWAD_CONSOLIDATED_OB b
WHERE a.ID=b.ID and FIN_YEAR=$P{Fin_year} order by a.minor]]></queryString>

	<field name="ID" class="java.math.BigDecimal"/>
	<field name="MINOR" class="java.lang.String"/>
