<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="MIS_Annual_Acc_Grouping_Statement_SummaryReport"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="735"
		 pageHeight="842"
		 columnWidth="675"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year" isForPrompting="true" class="java.lang.String"/>
	<parameter name="cbyear1" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select MAJOR_HEAD_DESC,
  GROUP_HEAD_CODE,
  GROUP_HEAD_DESC,
  MINOR_HEAD_CODE,
  MINOR_HEAD_DESC,
  Debit_for_Year,
  Credit_for_Year,
  Net_for_Year,
 sum(Debit_for_Year) as Debit_for_Year1,
  sum(Credit_for_Year) as Credit_for_Year1,
  sum(Net_for_Year) as Net_for_Year1,
  CASE
      WHEN (Net_for_Year < 0)
      THEN 'CR'
      WHEN (Net_for_Year > 0)
      THEN 'DR'
      WHEN (Net_for_Year = 0)
      THEN ''
    END AS cr_dr_indicator_for_Year
    
  from

(SELECT MAJOR_HEAD_CODE,
      GROUP_HEAD_CODE,
      MINOR_HEAD_CODE, 
  sum(decode(Debit_for_Year,null,0,Debit_for_Year)) as Debit_for_Year,
  sum(decode(Credit_for_Year,null,0,Credit_for_Year)) as Credit_for_Year,
  sum(decode(Net_for_Year,null,0,Net_for_Year)) as Net_for_Year        
 
FROM
  (SELECT MAJOR_HEAD_CODE,
      GROUP_HEAD_CODE,
      MINOR_HEAD_CODE,
      ACCOUNT_HEAD_CODE
    FROM FAS_MIS_GROUP_ACC_HD_MAPPING
    ORDER BY GROUP_HEAD_CODE,
      MINOR_HEAD_CODE,
      ACCOUNT_HEAD_CODE
  )X
LEFT OUTER JOIN
  (SELECT ACCOUNT_HEAD_CODE AS acc_hd_cde,       
    Debit_for_Year,
    Credit_for_Year,
    Net_for_Year,
    cr_dr_indicator_for_Year
  FROM
    (SELECT
      ACCOUNT_HEAD_CODE,
      SUM(CURRENT_MONTH_DEBIT)                                    AS Debit_for_Year,
      SUM(CURRENT_MONTH_CREDIT)                                   AS Credit_for_Year,
      ( (SUM(CURRENT_MONTH_DEBIT)) - (SUM(CURRENT_MONTH_CREDIT)) )AS Net_for_Year,
      CASE
      WHEN (( (SUM(CURRENT_MONTH_DEBIT)) - (SUM(CURRENT_MONTH_CREDIT)) ) < 0)
      THEN 'CR'
      WHEN (( (SUM(CURRENT_MONTH_DEBIT)) - (SUM(CURRENT_MONTH_CREDIT)) ) > 0)
      THEN 'DR'
      WHEN (( (SUM(CURRENT_MONTH_DEBIT)) - (SUM(CURRENT_MONTH_CREDIT)) ) = 0)
      THEN ''
    END AS cr_dr_indicator_for_Year
    
    FROM fas_trial_balance_cmp
    WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
    AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
    AND CASHBOOK_YEAR           =$P{cbyear1}
    AND CASHBOOK_MONTH BETWEEN 1 AND 3
    GROUP BY ACCOUNT_HEAD_CODE
    )
 UNION
    (SELECT
      ACCOUNT_HEAD_CODE,
      SUM(CURRENT_MONTH_DEBIT)                                    AS Debit_for_Year,
      SUM(CURRENT_MONTH_CREDIT)                                   AS Credit_for_Year,
      ( (SUM(CURRENT_MONTH_DEBIT)) - (SUM(CURRENT_MONTH_CREDIT)) )AS Net_for_Year,     
      CASE
      WHEN (( (SUM(CURRENT_MONTH_DEBIT)) - (SUM(CURRENT_MONTH_CREDIT)) ) < 0)
      THEN 'CR'
      WHEN (( (SUM(CURRENT_MONTH_DEBIT)) - (SUM(CURRENT_MONTH_CREDIT)) ) > 0)
      THEN 'DR'
      WHEN (( (SUM(CURRENT_MONTH_DEBIT)) - (SUM(CURRENT_MONTH_CREDIT)) ) = 0)
      THEN ''
    END AS cr_dr_indicator_for_Year
    FROM fas_trial_balance_cmp
    WHERE ACCOUNTING_UNIT_ID    =$P{UnitId}
    AND ACCOUNTING_FOR_OFFICE_ID=$P{OfficeId}
    AND CASHBOOK_YEAR           =$P{cbyear}
    AND CASHBOOK_MONTH BETWEEN 4 AND 12
    GROUP BY ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      ACCOUNT_HEAD_CODE
    )
  )Y ON X.ACCOUNT_HEAD_CODE =Y.acc_hd_cde 
  GROUP BY MAJOR_HEAD_CODE, GROUP_HEAD_CODE, MINOR_HEAD_CODE)xx
    LEFT OUTER JOIN
    (SELECT GROUP_HEAD_CODE AS grp_hd_cde,
      GROUP_HEAD_DESC
    FROM FAS_MIS_GROUP_MASTER
    ORDER BY GROUP_HEAD_CODE
    )yy
  ON xx.GROUP_HEAD_CODE =yy.grp_hd_cde
  LEFT OUTER JOIN
    (SELECT MAJOR_HEAD_CODE AS maj_hd_cde,
      MAJOR_HEAD_DESC
    FROM COM_MST_MAJOR_HEADS
    ORDER BY MAJOR_HEAD_DESC
    )zz
  ON xx.MAJOR_HEAD_CODE =zz.maj_hd_cde
  LEFT OUTER JOIN
    (SELECT MAJOR_HEAD_CODE AS maj_hd_cde1,
      MINOR_HEAD_CODE       AS min_hd_cde ,
      MINOR_HEAD_DESC
    FROM COM_MST_MINOR_HEADS
    ORDER BY MINOR_HEAD_DESC
    )kk
  ON xx.MAJOR_HEAD_CODE  =kk.maj_hd_cde1
  AND xx.MINOR_HEAD_CODE =kk.min_hd_cde group by MAJOR_HEAD_DESC, GROUP_HEAD_CODE, GROUP_HEAD_DESC, MINOR_HEAD_CODE, MINOR_HEAD_DESC, Debit_for_Year, Credit_for_Year, Net_for_Year, CASE
      WHEN (Net_for_Year < 0)
      THEN 'CR'
      WHEN (Net_for_Year > 0)
      THEN 'DR'
      WHEN (Net_for_Year = 0)
      THEN ''
    END
  order by GROUP_HEAD_CODE]]></queryString>

