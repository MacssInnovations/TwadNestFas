<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Annexure-II-B"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1047"
		 pageHeight="842"
		 columnWidth="987"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="sub_qry" isForPrompting="false" class="java.lang.String"/>
	<parameter name="Statement" isForPrompting="false" class="java.lang.String"/>
	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select ct.ACCOUNTING_UNIT_ID,ct.statement_name,
  ct.STATEMENT_HEADING,
sum(clm_200820)clm_200820,
sum(clm_200824)clm_200824,
sum(clm_200825)clm_200825,
sum(clm_200826)clm_200826,
sum(clm_212002)clm_212002,
sum(clm_211902)clm_211902,
sum(clm_200828)clm_200828,
sum(clm_200829)clm_200829,
sum(clm_200838)clm_200838,
sum(clm_200840)clm_200840,
sum(clm_200850)clm_200850,
sum(clm_200852)clm_200852,
unit.accounting_unit_name
from
(SELECT map.STATEMENT_NO,
 -- map.LEVEL_NO,
--  map.ACCOUNT_HEAD_TITLE,
 -- map.ACCOUNT_HEAD_CODE,
  mis.statement_name,
  mis.STATEMENT_HEADING,
  aa.ACCOUNTING_UNIT_ID,
  aa.account_head_code head_code,
 aa.Net_Amt,
CASE
    WHEN aa.ACCOUNT_HEAD_CODE=200820
    THEN aa.Net_Amt
    else 0
  END AS clm_200820,
  CASE
    WHEN aa.ACCOUNT_HEAD_CODE=200824
    THEN aa.Net_Amt else 0
  END AS clm_200824,
  CASE
    WHEN aa.ACCOUNT_HEAD_CODE=200825
    THEN aa.Net_Amt else 0
  END AS clm_200825,
  CASE
    WHEN aa.ACCOUNT_HEAD_CODE=200826
    THEN aa.Net_Amt else 0
  END AS clm_200826,
   CASE
    WHEN aa.ACCOUNT_HEAD_CODE=212002
    THEN aa.Net_Amt else 0
  END AS clm_212002,
   CASE
    WHEN aa.ACCOUNT_HEAD_CODE=211902
    THEN aa.Net_Amt else 0
  END AS clm_211902,
   CASE
    WHEN aa.ACCOUNT_HEAD_CODE=200828
    THEN aa.Net_Amt else 0
  END AS clm_200828,
   CASE
    WHEN aa.ACCOUNT_HEAD_CODE=200829
    THEN aa.Net_Amt else 0
  END AS clm_200829,
   CASE
    WHEN aa.ACCOUNT_HEAD_CODE=200838
    THEN aa.Net_Amt else 0
  END AS clm_200838,
   CASE
    WHEN aa.ACCOUNT_HEAD_CODE=200840
    THEN aa.Net_Amt else 0
  END AS clm_200840,
   CASE
    WHEN aa.ACCOUNT_HEAD_CODE=200850
    THEN aa.Net_Amt else 0
  END AS clm_200850,
   CASE
    WHEN aa.ACCOUNT_HEAD_CODE=200852
    THEN aa.Net_Amt else 0
  END AS clm_200852
FROM (
  (SELECT a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    SUM( current_month_debit )                               AS DR_AMOUNT,
    SUM( current_month_credit)                               AS CR_AMOUNT,
    (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net_Amt,
    0                                                        AS Sup_No,
    0                                                        AS Fin_Year ,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy') Month_Tb
  FROM FAS_TRIAL_BALANCE a
  WHERE (current_month_debit!=0
  OR current_month_credit!   =0)
  GROUP BY a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    0,
    0,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy')
  )
UNION ALL
  (SELECT a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    SUM( current_month_debit )                               AS debit,
    SUM( current_month_credit)                               AS credit,
    (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net,
    Supplement_No                                            AS Sup_No,
    0                                                        AS Fin_Year ,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy')+Supplement_No month_TB
  FROM Fas_Trial_Balance_Supplement A
  WHERE (current_month_debit!=0
  OR current_month_credit!   =0)
  GROUP BY a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    Supplement_No,
    0,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy')+Supplement_No
  ) )aa
INNER JOIN FAS_MIS_ANNEXURE_HEADS_MAP map
ON aa.account_head_code=map.account_head_code
INNER JOIN FAS_MIS_ANNEXURE_MST mis
ON mis.statement_no =map.statement_no
AND map.status      ='L'
AND map.STATEMENT_NO=$P{Statement}
AND $P!{sub_qry}
group by map.STATEMENT_NO,  mis.statement_name, mis.STATEMENT_HEADING, aa.ACCOUNTING_UNIT_ID, aa.account_head_code,
aa.Net_Amt 
--ORDER BY map.LEVEL_NO
)ct inner join FAS_MST_ACCT_UNITS unit 
on ct.ACCOUNTING_UNIT_ID=unit.ACCOUNTING_UNIT_ID
group by ct.ACCOUNTING_UNIT_ID, ct.statement_name, ct.STATEMENT_HEADING, unit.accounting_unit_name
order by ct.ACCOUNTING_UNIT_ID]]></queryString>

