		<variableExpression><![CDATA[$F{CR_222508}.add( $F{CR_222503} ).add( $F{CR_221105} ).add( $F{CR_221205} ).add( $F{CR_222501} ).add( $F{CR_222504} ).add( $F{CR_222505} ).add($F{CR_222507} ).add( $F{CR_222502} ).add( $F{CR_222506} ).add( $F{CR_222509} ).add( $F{CR_251101} )]]></variableExpression>
	</variable>
