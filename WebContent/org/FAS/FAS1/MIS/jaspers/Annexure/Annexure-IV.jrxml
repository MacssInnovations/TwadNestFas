<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Annexure-IV"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1441"
		 pageHeight="842"
		 columnWidth="1381"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="Statement" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sub_qry" isForPrompting="true" class="java.lang.String"/>
	<parameter name="head" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select ct.ACCOUNTING_UNIT_ID,ct.statement_name,
  ct.STATEMENT_HEADING,
sum(cr201029)cr201029,
sum(Dr201038)Dr201038,
sum(Cr201039)Cr201039,
sum(cr201040)cr201040,
sum(cr201021)cr201021,
sum(cr201022)cr201022,
sum(cr201023)cr201023,
sum(cr201030)cr201030,
sum(Dr201031)Dr201031,
sum(Cr201032)Cr201032,
sum(cr201033)cr201033,
sum(cr201034)cr201034,
sum(cr201035)cr201035,
sum(cr201036)cr201036,
sum(cr212005)cr212005,
sum(Dr211905)Dr211905,
sum(Cr201020)Cr201020,
sum(cr201024)cr201024,
sum(cr201025)cr201025,
sum(cr201026)cr201026,
sum(cr201028)cr201028,
sum(cr201027)cr201027,
sum(cr201037)cr201037,
sum(Dr201042)Dr201042,
sum(Cr201050)Cr201050,
sum(cr201051)cr201051,
sum(cr201052)cr201052,
sum(cr201053)cr201053,
unit.accounting_unit_name
from
(SELECT map.STATEMENT_NO,
 -- map.LEVEL_NO,
--  map.ACCOUNT_HEAD_TITLE,
 -- map.ACCOUNT_HEAD_CODE,
  mis.statement_name,
  mis.STATEMENT_HEADING,
  aa.ACCOUNTING_UNIT_ID,
  aa.account_head_code head_code,
  aa.DR_AMOUNT,
  aa.CR_AMOUNT,
 case
   WHEN aa.ACCOUNT_HEAD_CODE=201029
   THEN aa.CR_AMOUNT
   else 0
 END AS cr201029,
  case
   WHEN aa.ACCOUNT_HEAD_CODE=201038
    THEN aa.DR_AMOUNT else 0
  END AS Dr201038,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201039
    THEN aa.CR_AMOUNT else 0
  END AS Cr201039,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201040
    then aa.cr_amount else 0
 END AS cr201040,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201021
    then aa.cr_amount else 0
 end as cr201021,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201022
    then aa.cr_amount else 0
 end as cr201022,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201023
    then aa.cr_amount else 0
 END AS cr201023,
case
   WHEN aa.ACCOUNT_HEAD_CODE=201030
   THEN aa.CR_AMOUNT
   else 0
 END AS cr201030,
  case
   WHEN aa.ACCOUNT_HEAD_CODE=201031
    THEN aa.DR_AMOUNT else 0
  END AS Dr201031,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201032
    THEN aa.CR_AMOUNT else 0
  END AS Cr201032,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201033
    then aa.cr_amount else 0
 END AS cr201033,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201034
    then aa.cr_amount else 0
 end as cr201034,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201035
    then aa.cr_amount else 0
 end as cr201035,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201036
    then aa.cr_amount else 0
 end as cr201036,
case
   WHEN aa.ACCOUNT_HEAD_CODE=212005
   THEN aa.CR_AMOUNT
   else 0
 END AS cr212005,
  case
   WHEN aa.ACCOUNT_HEAD_CODE=211905
    THEN aa.DR_AMOUNT else 0
  END AS Dr211905,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201020
    THEN aa.CR_AMOUNT else 0
  END AS Cr201020,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201024
    then aa.cr_amount else 0
 END AS cr201024,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201025
    then aa.cr_amount else 0
 end as cr201025,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201026
    then aa.cr_amount else 0
 end as cr201026,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201028
    then aa.cr_amount else 0
 end as cr201028,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201027
    then aa.cr_amount else 0
 end as cr201027,
case
   WHEN aa.ACCOUNT_HEAD_CODE=201037
   THEN aa.CR_AMOUNT
   else 0
 END AS cr201037,
  case
   WHEN aa.ACCOUNT_HEAD_CODE=201042
    THEN aa.DR_AMOUNT else 0
  END AS Dr201042,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201050
    THEN aa.CR_AMOUNT else 0
  END AS Cr201050,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201051
    then aa.cr_amount else 0
 END AS cr201051,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201052
    then aa.cr_amount else 0
 end as cr201052,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=201053
    then aa.cr_amount else 0
 end as cr201053

  FROM (
  (SELECT a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    SUM( current_month_debit )                               AS DR_AMOUNT,
    SUM( current_month_credit)                               AS CR_AMOUNT,
    (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net_Amt,
    0                                                        AS Sup_No,
    0                                                        AS Fin_Year ,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy') Month_Tb
  FROM FAS_TRIAL_BALANCE a
  WHERE (current_month_debit!=0
  OR current_month_credit!   =0)
  GROUP BY a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    0,
    0,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy')
  )
UNION ALL
  (SELECT a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    SUM( current_month_debit )                               AS debit,
    SUM( current_month_credit)                               AS credit,
    (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net,
    Supplement_No                                            AS Sup_No,
    0                                                        AS Fin_Year ,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy')+Supplement_No month_TB
  FROM Fas_Trial_Balance_Supplement A
  WHERE (current_month_debit!=0
  OR current_month_credit!   =0)
  GROUP BY a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    Supplement_No,
    0,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy')+Supplement_No
  ) )aa
INNER JOIN FAS_MIS_ANNEXURE_HEADS_MAP map
ON aa.account_head_code=map.account_head_code
INNER JOIN FAS_MIS_ANNEXURE_MST mis
ON mis.statement_no =map.statement_no
and map.status      ='L'
and map.statement_no=$P{Statement}
and $P!{sub_qry}
  

group by map.STATEMENT_NO,  mis.statement_name, mis.STATEMENT_HEADING, aa.ACCOUNTING_UNIT_ID, aa.account_head_code,
 aa.DR_AMOUNT,
  aa.CR_AMOUNT
--ORDER BY map.LEVEL_NO
)ct inner join FAS_MST_ACCT_UNITS unit 
on ct.accounting_unit_id=unit.accounting_unit_id
group by ct.ACCOUNTING_UNIT_ID, ct.statement_name, ct.STATEMENT_HEADING, unit.accounting_unit_name]]></queryString>

