	</variable>
	<variable name="tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR160401}.add($F{DR782404}.add($F{CR160411}.add($F{CR782404})))]]></variableExpression>
	</variable>
