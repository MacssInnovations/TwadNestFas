	</variable>
	<variable name="tot_var" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_222301}.add($F{CR_222302}.add($F{CR_222303}.add($F{CR_222304}.add($F{CR_222305}.add(
$F{CR_222306}.add($F{CR_222307}.add($F{CR_222308}.add($F{CR_222309}.add($F{CR_221102}.add(
$F{CR_221202}.add($F{CR_251101})))))))))))]]></variableExpression>
	</variable>
