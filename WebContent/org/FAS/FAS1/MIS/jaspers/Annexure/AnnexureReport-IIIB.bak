		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="sub_qry" isForPrompting="true" class="java.lang.String"/>
	<parameter name="Statement" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="head" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[Select Ct.Accounting_Unit_Id,
Ct.Statement_Name,
Ct.Statement_Heading,
unit.accounting_unit_name,
Sum(Cr_222301)Cr_222301,
Sum(Cr_222302)Cr_222302,
Sum(Cr_222303)Cr_222303,
Sum(Cr_222304)Cr_222304,
Sum(Cr_222305)Cr_222305,
Sum(Cr_222306)Cr_222306,
Sum(Cr_222307)Cr_222307,
Sum(Cr_222308)Cr_222308,
Sum(Cr_222309)Cr_222309,
Sum(Cr_221102)Cr_221102,
Sum(Cr_221202)Cr_221202,
Sum(Cr_251101)Cr_251101
from
(Select  
 Map.Statement_No,Mis.Statement_Name,Mis.Statement_Heading,
 Aa.Accounting_Unit_Id,Aa.Account_Head_Code ,
Aa.Net_Amt,
Case When Aa.Account_Head_Code=222301 Then Aa.Net_Amt Else 0 End As Cr_222301,
Case When Aa.Account_Head_Code=222302 Then Aa.Net_Amt Else 0 End As Cr_222302,
Case When Aa.Account_Head_Code=222303 Then Aa.Net_Amt Else 0 End As Cr_222303,
Case When Aa.Account_Head_Code=222304 Then Aa.Net_Amt Else 0 End As Cr_222304,
Case When Aa.Account_Head_Code=222305 Then Aa.Net_Amt Else 0 End As Cr_222305,
Case When Aa.Account_Head_Code=222306 Then Aa.Net_Amt Else 0 End As Cr_222306,
Case When Aa.Account_Head_Code=222309 Then Aa.Net_Amt Else 0 End As Cr_222309,
Case When Aa.Account_Head_Code=222308 Then Aa.Net_Amt Else 0 End As Cr_222308,
Case When Aa.Account_Head_Code=221102 Then Aa.Net_Amt Else 0 End As Cr_221102,
Case When Aa.Account_Head_Code=221202 Then Aa.Net_Amt Else 0 End As Cr_221202,
Case When Aa.Account_Head_Code=222307 Then Aa.Net_Amt Else 0 End As Cr_222307,
Case When Aa.Account_Head_Code=251101 Then Aa.Net_Amt Else 0 End As Cr_251101
 from
( (SELECT a.ACCOUNTING_UNIT_ID, 
                   a.account_head_code, 
                   SUM( current_month_debit )                               AS DR_AMOUNT, 
                   SUM( current_month_credit)                               AS CR_AMOUNT, 
                   (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net_Amt, 
                   0                                                        AS Sup_No, 
                   0                                                        AS Fin_Year , 
                   Cashbook_Year, 
                   Cashbook_Month, 
                   To_date(Cashbook_Month 
                   ||'-' 
                   ||Cashbook_Year,'MM-yyyy') Month_Tb 
                 FROM FAS_TRIAL_BALANCE a 
                 WHERE (current_month_debit!=0 
                 OR current_month_credit!   =0) 
                 GROUP BY a.ACCOUNTING_UNIT_ID, 
                   a.account_head_code, 
                   0, 
                   0, 
                   Cashbook_Year, 
                   Cashbook_Month, 
                   To_date(Cashbook_Month 
                   ||'-' 
                   ||Cashbook_Year,'MM-yyyy') 
                 ) 
               UNION ALL 
                 (SELECT a.ACCOUNTING_UNIT_ID, 
                   a.account_head_code, 
                   SUM( current_month_debit )                               AS debit, 
                   SUM( current_month_credit)                               AS credit, 
                   (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net, 
                   Supplement_No                                            AS Sup_No, 
                   0                                                        AS Fin_Year , 
                   Cashbook_Year, 
                   Cashbook_Month, 
                   To_date(Cashbook_Month 
                   ||'-' 
                   ||Cashbook_Year,'MM-yyyy')+Supplement_No month_TB 
                 FROM Fas_Trial_Balance_Supplement A 
                 WHERE (current_month_debit!=0 
                 OR current_month_credit!   =0) 
                 GROUP BY a.ACCOUNTING_UNIT_ID, 
                   a.account_head_code, 
                   Supplement_No, 
                   0, 
                   Cashbook_Year, 
                   Cashbook_Month, 
                   To_date(Cashbook_Month 
                   ||'-' 
                   ||Cashbook_Year,'MM-yyyy')+Supplement_No 
                 ) )Aa
               Inner Join Fas_Mis_Annexure_Heads_Map Map
                 On Aa.Account_Head_Code=Map.Account_Head_Code
                Inner Join Fas_Mis_Annexure_Mst Mis
                On Mis.STATEMENT_NO=Map.Statement_No
                And Map.Status='L'
               And Map.Statement_No=$P{Statement}
                 and $P!{sub_qry}
            --     Group By
                 --Map.Statement_No,Mis.Statement_Name,Mis.Statement_Heading,
               -- Aa.Accounting_Unit_Id,Aa.Account_Head_Code,Aa.Net_Amt
                 
                 
                 
                 )Ct
                 Inner Join Fas_Mst_Acct_Units Unit
                 On Ct.Accounting_Unit_Id=Unit.Accounting_Unit_Id
                 Group By Ct.Accounting_Unit_Id,Ct.Statement_Name,
                 ct.statement_heading,unit.accounting_unit_name]]></queryString>

