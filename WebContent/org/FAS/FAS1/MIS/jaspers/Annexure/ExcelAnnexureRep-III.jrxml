	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="Statement" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sub_qry" isForPrompting="true" class="java.lang.String"/>
	<parameter name="head" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT ct.ACCOUNTING_UNIT_ID,
  ct.statement_name,
  ct.STATEMENT_HEADING,
  SUM(cr_200820)cr_200820,
  SUM(cr_200824)cr_200824,
  SUM(cr_200825)cr_200825,
  SUM(cr_200826)cr_200826,
  SUM(cr_212002)cr_212002,
  SUM(cr_211902)cr_211902,
  SUM(cr_200821)cr_200821,
  SUM(cr_200830)cr_200830,
  SUM(cr_200838)cr_200838,
  SUM(cr_200840)cr_200840,
  SUM(cr_200850)cr_200850,
  SUM(cr_200852)cr_200852,
  SUM(cr_200822)cr_200822,
  SUM(cr_200823)cr_200823,
  SUM(cr_200827)cr_200827,
  SUM(cr_200828)cr_200828,
  SUM(cr_200829)cr_200829,
  SUM(cr_200831)cr_200831,
  SUM(cr_200832)cr_200832,
  SUM(cr_200833)cr_200833,
  SUM(cr_200834)cr_200834,
  SUM(cr_200835)cr_200835,
  SUM(cr_200836)cr_200836,
  SUM(cr_200837)cr_200837,
  SUM(cr_200839)cr_200839,
 SUM(cr_200842)cr_200842,
    SUM(cr_200851)cr_200851,
  SUM(cr_200853)cr_200853,
   SUM(cr_200820)+
  SUM(cr_200824)+
  SUM(cr_200825)+
  SUM(cr_200826)+
  SUM(cr_212002)+
  SUM(cr_211902)+
  SUM(cr_200821)+
  SUM(cr_200830)+
  SUM(cr_200838)+
  SUM(cr_200840)+
  SUM(cr_200850)+
  SUM(cr_200852)+
  SUM(cr_200822)+
  SUM(cr_200823)+
  SUM(cr_200827)+
  SUM(cr_200828)+
  SUM(cr_200829)+
  SUM(cr_200831)+
  SUM(cr_200832)+
  SUM(cr_200833)+
  SUM(cr_200834)+
  SUM(cr_200835)+
  SUM(cr_200836)+
  SUM(cr_200837)+
  SUM(cr_200839)+
 SUM(cr_200842)+
    SUM(cr_200851)+
  SUM(cr_200853)
 as tot,							

  unit.accounting_unit_name
FROM
  (SELECT map.STATEMENT_NO,
    -- map.LEVEL_NO,
    --  map.ACCOUNT_HEAD_TITLE,
    -- map.ACCOUNT_HEAD_CODE,
    mis.statement_name,
    mis.STATEMENT_HEADING,
    aa.ACCOUNTING_UNIT_ID,
    aa.account_head_code head_code,
    aa.Net_Amt,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200820
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200820,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200824
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200824,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200825
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200825,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200826
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200826,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=212002
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_212002,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=211902
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_211902,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200821
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200821,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200830
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200830,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200838
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200838,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200840
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200840,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200850
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200850,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200852
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200852,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200822
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200822,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200823
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200823,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200827
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200827,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200828
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200828,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200829
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200829,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200831
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200831,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200832
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200832,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200833
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200833,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200834
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200834,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200835
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200835,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200836
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200836,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200837
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200837,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200839
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200839,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200842
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200842,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200851
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200851,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200853
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200853
  FROM (
    (SELECT a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      SUM( current_month_debit )                               AS DR_AMOUNT,
      SUM( current_month_credit)                               AS CR_AMOUNT,
      (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net_Amt,
      0                                                        AS Sup_No,
      0                                                        AS Fin_Year ,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy') Month_Tb
    FROM FAS_TRIAL_BALANCE a
    WHERE (current_month_debit!=0
    OR current_month_credit!   =0)
    GROUP BY a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      0,
      0,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')
    )
  UNION ALL
    (SELECT a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      SUM( current_month_debit )                               AS debit,
      SUM( current_month_credit)                               AS credit,
      (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net,
      Supplement_No                                            AS Sup_No,
      0                                                        AS Fin_Year ,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')+Supplement_No month_TB
    FROM Fas_Trial_Balance_Supplement A
    WHERE (current_month_debit!=0
    OR current_month_credit!   =0)
    GROUP BY a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      Supplement_No,
      0,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')+Supplement_No
    ) )aa
  INNER JOIN FAS_MIS_ANNEXURE_HEADS_MAP map
  ON aa.account_head_code=map.account_head_code
  INNER JOIN FAS_MIS_ANNEXURE_MST mis
  ON mis.statement_no  =map.statement_no
  AND map.status       ='L'
  AND map.STATEMENT_NO =$P{Statement}
  AND $P!{sub_qry}
  GROUP BY map.STATEMENT_NO,
    mis.statement_name,
    mis.STATEMENT_HEADING,
    aa.ACCOUNTING_UNIT_ID,
    aa.account_head_code,
    aa.Net_Amt
    --ORDER BY map.LEVEL_NO
  )ct
INNER JOIN FAS_MST_ACCT_UNITS unit
ON ct.ACCOUNTING_UNIT_ID=unit.ACCOUNTING_UNIT_ID
GROUP BY ct.ACCOUNTING_UNIT_ID,
  ct.statement_name,
  ct.STATEMENT_HEADING,
  unit.accounting_unit_name
ORDER BY ct.ACCOUNTING_UNIT_ID]]></queryString>

