	<variable name="tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_221106}.add($F{CR_222101}.add($F{CR_222102}.add($F{CR_222103}.add($F{CR_222104}
.add($F{CR_222105}.add($F{CR_222106}.add($F{CR_222107}.add($F{CR_222108}.add($F{CR_222109}
.add($F{CR_222110}.add($F{CR_222111}.add($F{CR_222112}))))))))))))]]></variableExpression>
	</variable>
	<variable name="sum_222102" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_222102}]]></variableExpression>
	</variable>
	<variable name="SUM_401531" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
