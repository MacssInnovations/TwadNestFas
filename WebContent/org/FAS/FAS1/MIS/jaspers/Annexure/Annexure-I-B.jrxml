		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="Statement" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sub_qry" isForPrompting="true" class="java.lang.String"/>
	<parameter name="head" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT ct.ACCOUNTING_UNIT_ID,
  ct.statement_name,
  ct.STATEMENT_HEADING,
  SUM(cr_221106)cr_221106,
  SUM(cr_222101)cr_222101,
  SUM(cr_222102)cr_222102,
  SUM(cr_222103)cr_222103,
  SUM(cr_222104)cr_222104,
  SUM(cr_222105)cr_222105,
  SUM(cr_222106)cr_222106,
  SUM(cr_222107)cr_222107,
  SUM(cr_222108)cr_222108,
  SUM(cr_222109)cr_222109,
  SUM(cr_222110)cr_222110,
  SUM(cr_222111)cr_222111,
  SUM(cr_222112)cr_222112,
   sum(cr_401531)cr_401531,
  unit.accounting_unit_name
FROM
  (SELECT map.STATEMENT_NO,
    -- map.LEVEL_NO,
    --  map.ACCOUNT_HEAD_TITLE,
    -- map.ACCOUNT_HEAD_CODE,
    mis.statement_name,
    mis.STATEMENT_HEADING,
    aa.ACCOUNTING_UNIT_ID,
    aa.account_head_code head_code,
    aa.Net_Amt,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=221106
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_221106,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222101
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222101,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222102
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222102,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222103
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222103,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222104
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222104,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222105
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222105,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222106
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222106,
      CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222107
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222107,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222108
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222108,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222109
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222109,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222110
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222110,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222111
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222111,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=222112
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_222112,
 CASE
      WHEN aa.ACCOUNT_HEAD_CODE=401531
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_401531
   
  FROM (
    (SELECT a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      SUM( current_month_debit )                               AS DR_AMOUNT,
      SUM( current_month_credit)                               AS CR_AMOUNT,
      (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net_Amt,
      0                                                        AS Sup_No,
      0                                                        AS Fin_Year ,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy') Month_Tb
    FROM FAS_TRIAL_BALANCE a
    WHERE (current_month_debit!=0
    OR current_month_credit!   =0)
    GROUP BY a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      0,
      0,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')
    )
  UNION ALL
    (SELECT a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      SUM( current_month_debit )                               AS debit,
      SUM( current_month_credit)                               AS credit,
      (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net,
      Supplement_No                                            AS Sup_No,
      0                                                        AS Fin_Year ,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')+Supplement_No month_TB
    FROM Fas_Trial_Balance_Supplement A
    WHERE (current_month_debit!=0
    OR current_month_credit!   =0)
    GROUP BY a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      Supplement_No,
      0,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')+Supplement_No
    ) )aa
  INNER JOIN FAS_MIS_ANNEXURE_HEADS_MAP map
  ON aa.account_head_code=map.account_head_code
  INNER JOIN FAS_MIS_ANNEXURE_MST mis
  ON mis.statement_no  =map.statement_no
  AND map.status       ='L'
  AND map.STATEMENT_NO =$P{Statement}
  AND $P!{sub_qry}
  GROUP BY map.STATEMENT_NO,
    mis.statement_name,
    mis.STATEMENT_HEADING,
    aa.ACCOUNTING_UNIT_ID,
    aa.account_head_code,
    aa.Net_Amt
    --ORDER BY map.LEVEL_NO
  )ct
INNER JOIN FAS_MST_ACCT_UNITS unit
ON ct.ACCOUNTING_UNIT_ID=unit.ACCOUNTING_UNIT_ID
GROUP BY ct.ACCOUNTING_UNIT_ID, ct.statement_name, ct.STATEMENT_HEADING, unit.accounting_unit_name
ORDER BY ct.ACCOUNTING_UNIT_ID]]></queryString>

