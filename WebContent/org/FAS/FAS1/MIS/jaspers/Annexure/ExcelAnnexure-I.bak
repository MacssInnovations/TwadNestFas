	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="Statement" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sub_qry" isForPrompting="true" class="java.lang.String"/>
	<parameter name="head" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT ct.ACCOUNTING_UNIT_ID,
  ct.statement_name,
  ct.STATEMENT_HEADING,
  SUM(cr_200606)cr_200606,
  SUM(cr_200607)cr_200607,
  SUM(cr_200608)cr_200608,
  SUM(cr_200609)cr_200609,
  SUM(cr_200616)cr_200616,
  SUM(cr_200620)cr_200620,
  SUM(cr_200621)cr_200621,
  SUM(cr_200622)cr_200622,
  SUM(cr_200623)cr_200623,
  SUM(cr_200624)cr_200624,
  SUM(cr_200625)cr_200625,
  SUM(cr_200626)cr_200626,
  SUM(cr_200627)cr_200627,
  SUM(cr_200628)cr_200628,
  SUM(cr_200629)cr_200629,
  SUM(cr_200630)cr_200630,
  SUM(cr_200631)cr_200631,
  SUM(cr_200632)cr_200632,
  SUM(cr_200633)cr_200633,
  SUM(cr_200634)cr_200634,
  SUM(cr_200635)cr_200635,
  SUM(cr_200636)cr_200636,
  SUM(cr_200637)cr_200637,
  SUM(cr_200642)cr_200642,
  SUM(cr_200650)cr_200650,
  SUM(cr_200651)cr_200651,
  SUM(cr_200652)cr_200652,
  SUM(cr_200653)cr_200653,
  SUM(cr_211906)cr_211906,
  SUM(cr_212006)cr_212006,
   SUM(cr_200606)+  SUM(cr_200607)+  SUM(cr_200608)+  SUM(cr_200609)+  SUM(cr_200616)+  SUM(cr_200620)+  SUM(cr_200621)+
  SUM(cr_200622)+
  SUM(cr_200623)+
  SUM(cr_200624)+
  SUM(cr_200625)+
  SUM(cr_200626)+
  SUM(cr_200627)+
  SUM(cr_200628)+
  SUM(cr_200629)+
  SUM(cr_200630)+
  SUM(cr_200631)+
  SUM(cr_200632)+
  SUM(cr_200633)+
  SUM(cr_200634)+
  SUM(cr_200635)+
  SUM(cr_200636)+
  SUM(cr_200637)+
  SUM(cr_200642)+
  SUM(cr_200650)+
  SUM(cr_200651)+
  SUM(cr_200652)+
  SUM(cr_200653)+
  SUM(cr_211906)+
  SUM(cr_212006) as tot,
  unit.accounting_unit_name
FROM
  (SELECT map.STATEMENT_NO,
    -- map.LEVEL_NO,
    --  map.ACCOUNT_HEAD_TITLE,
    -- map.ACCOUNT_HEAD_CODE,
    mis.statement_name,
    mis.STATEMENT_HEADING,
    aa.ACCOUNTING_UNIT_ID,
    aa.account_head_code head_code,
    aa.Net_Amt,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200606
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200606,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200607
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200607,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200608
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200608,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200609
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200609,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200616
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200616,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200620
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200620,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200621
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200621,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200622
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200622,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200623
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200623,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200624
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200624,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200625
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200625,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200626
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200626,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200627
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200627,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200628
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200628,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200629
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200629,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200630
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200630,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200631
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200631,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200632
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200632,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200633
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200633,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200634
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200634,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200635
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200635,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200636
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200636,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200637
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200637,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200642
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200642,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200650
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200650,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200651
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200651,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200652
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200652,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200653
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200653,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=211906
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_211906,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=212006
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_212006
  FROM (
    (SELECT a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      SUM( current_month_debit )                               AS DR_AMOUNT,
      SUM( current_month_credit)                               AS CR_AMOUNT,
      (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net_Amt,
      0                                                        AS Sup_No,
      0                                                        AS Fin_Year ,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy') Month_Tb
    FROM FAS_TRIAL_BALANCE a
    WHERE (current_month_debit!=0
    OR current_month_credit!   =0)
    GROUP BY a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      0,
      0,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')
    )
  UNION ALL
    (SELECT a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      SUM( current_month_debit )                               AS debit,
      SUM( current_month_credit)                               AS credit,
      (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net,
      Supplement_No                                            AS Sup_No,
      0                                                        AS Fin_Year ,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')+Supplement_No month_TB
    FROM Fas_Trial_Balance_Supplement A
    WHERE (current_month_debit!=0
    OR current_month_credit!   =0)
    GROUP BY a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      Supplement_No,
      0,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')+Supplement_No
    ) )aa
  INNER JOIN FAS_MIS_ANNEXURE_HEADS_MAP map
  ON aa.account_head_code=map.account_head_code
  INNER JOIN FAS_MIS_ANNEXURE_MST mis
  ON mis.statement_no  =map.statement_no
  AND map.status       ='L'
  AND map.STATEMENT_NO =$P{Statement}
  AND $P!{sub_qry}
  GROUP BY map.STATEMENT_NO,
    mis.statement_name,
    mis.STATEMENT_HEADING,
    aa.ACCOUNTING_UNIT_ID,
    aa.account_head_code,
    aa.Net_Amt
    --ORDER BY map.LEVEL_NO
  )ct
INNER JOIN FAS_MST_ACCT_UNITS unit
ON ct.ACCOUNTING_UNIT_ID=unit.ACCOUNTING_UNIT_ID
GROUP BY ct.ACCOUNTING_UNIT_ID,
  ct.statement_name,
  ct.STATEMENT_HEADING,
  unit.accounting_unit_name
ORDER BY ct.ACCOUNTING_UNIT_ID]]></queryString>

