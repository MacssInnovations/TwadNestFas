		<variableExpression><![CDATA[$F{CR_222201}.add($F{CR_222202}.add($F{CR_222203}.add($F{CR_222204}.add($F{CR_222205}.add(
$F{CR_222206}.add($F{CR_222207}.add($F{CR_222208}.add($F{CR_222209}.add($F{CR_221301}.add(
$F{CR_221101}.add($F{CR_221201}.add($F{CR_222207_CP}.add($F{CR_251101})))))))))))))]]></variableExpression>
	</variable>
