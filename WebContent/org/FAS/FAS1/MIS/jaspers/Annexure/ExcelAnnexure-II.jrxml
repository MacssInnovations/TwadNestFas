	<parameter name="Statement" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="sub_qry" isForPrompting="true" class="java.lang.String"/>
	<parameter name="head" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT ct.ACCOUNTING_UNIT_ID,
  ct.statement_name,
  ct.STATEMENT_HEADING,
  SUM(cr_200727)cr_200727,
  SUM(cr_200730)cr_200730,
  SUM(cr_200731)cr_200731,
  SUM(cr_200732)cr_200732,
  SUM(cr_200733)cr_200733,
  SUM(cr_200734)cr_200734,
  SUM(cr_200735)cr_200735,
  SUM(cr_200736)cr_200736,
  SUM(cr_200737)cr_200737,
  SUM(cr_200751)cr_200751,
  SUM(cr_200753)cr_200753,
  SUM(cr_211901)cr_211901,
  SUM(cr_200720)cr_200720,
  SUM(cr_200724)cr_200724,
  SUM(cr_200725)cr_200725,
  SUM(cr_200728)cr_200728,
  SUM(cr_200729)cr_200729,
  SUM(cr_200738)cr_200738,
  SUM(cr_200739)cr_200739,
  SUM(cr_200721)cr_200721,
  SUM(cr_200742)cr_200742,
  SUM(cr_200750)cr_200750,
  SUM(cr_200752)cr_200752,
  SUM(cr_211901_cp)cr_211901_cp,
  SUM(cr_212001)cr_212001,
  SUM(cr_200722)cr_200722,
  SUM(cr_200723)cr_200723,
  SUM(cr_200726)cr_200726,
  SUM(cr_200740)cr_200740,
SUM(cr_200727)+  SUM(cr_200730)+  SUM(cr_200731)+  SUM(cr_200732)+  SUM(cr_200733)+  SUM(cr_200734)+  SUM(cr_200735)+							
  SUM(cr_200736)+							
  SUM(cr_200737)+							
  SUM(cr_200751)+							
  SUM(cr_200753)+							
  SUM(cr_211901)+							
  SUM(cr_200720)+							
  SUM(cr_200724)+							
  SUM(cr_200725)+							
  SUM(cr_200728)+							
  SUM(cr_200729)+							
  SUM(cr_200738)+							
  SUM(cr_200739)+							
  SUM(cr_200721)+							
  SUM(cr_200742)+							
  SUM(cr_200750)+							
  SUM(cr_200752)+							
  SUM(cr_211901_cp)+							
  SUM(cr_212001)+							
  SUM(cr_200722)+							
  SUM(cr_200723)+							
  SUM(cr_200726)+							
  SUM(cr_200740) as tot,							

  unit.accounting_unit_name
FROM
  (SELECT map.STATEMENT_NO,
    -- map.LEVEL_NO,
    --  map.ACCOUNT_HEAD_TITLE,
    -- map.ACCOUNT_HEAD_CODE,
    mis.statement_name,
    mis.STATEMENT_HEADING,
    aa.ACCOUNTING_UNIT_ID,
    aa.account_head_code head_code,
    aa.Net_Amt,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200727
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200727,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200730
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200730,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200731
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200731,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200732
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200732,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200733
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200733,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200734
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200734,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200735
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200735,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200736
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200736,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200737
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200737,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200751
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200751,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200753
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200753,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=211901
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_211901,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200720
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200720,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200724
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200724,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200725
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200725,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200728
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200728,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200729
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200729,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200738
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200738,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200739
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200739,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200721
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200721,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200742
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200742,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200750
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200750,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200752
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200752,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=211901
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_211901_cp,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=212001
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_212001,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200722
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200722,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200723
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200723,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200726
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200726,
    CASE
      WHEN aa.ACCOUNT_HEAD_CODE=200740
      THEN aa.Net_Amt
      ELSE 0
    END AS cr_200740
  FROM (
    (SELECT a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      SUM( current_month_debit )                               AS DR_AMOUNT,
      SUM( current_month_credit)                               AS CR_AMOUNT,
      (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net_Amt,
      0                                                        AS Sup_No,
      0                                                        AS Fin_Year ,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy') Month_Tb
    FROM FAS_TRIAL_BALANCE a
    WHERE (current_month_debit!=0
    OR current_month_credit!   =0)
    GROUP BY a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      0,
      0,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')
    )
  UNION ALL
    (SELECT a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      SUM( current_month_debit )                               AS debit,
      SUM( current_month_credit)                               AS credit,
      (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net,
      Supplement_No                                            AS Sup_No,
      0                                                        AS Fin_Year ,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')+Supplement_No month_TB
    FROM Fas_Trial_Balance_Supplement A
    WHERE (current_month_debit!=0
    OR current_month_credit!   =0)
    GROUP BY a.ACCOUNTING_UNIT_ID,
      a.account_head_code,
      Supplement_No,
      0,
      Cashbook_Year,
      Cashbook_Month,
      To_date(Cashbook_Month
      ||'-'
      ||Cashbook_Year,'MM-yyyy')+Supplement_No
    ) )aa
  INNER JOIN FAS_MIS_ANNEXURE_HEADS_MAP map
  ON aa.account_head_code=map.account_head_code
  INNER JOIN FAS_MIS_ANNEXURE_MST mis
  ON mis.statement_no  =map.statement_no
  AND map.status       ='L'
  AND map.STATEMENT_NO =$P{Statement}
  AND $P!{sub_qry}
  GROUP BY map.STATEMENT_NO,
    mis.statement_name,
    mis.STATEMENT_HEADING,
    aa.ACCOUNTING_UNIT_ID,
    aa.account_head_code,
    aa.Net_Amt
    --ORDER BY map.LEVEL_NO
  )ct
INNER JOIN FAS_MST_ACCT_UNITS unit
ON ct.ACCOUNTING_UNIT_ID=unit.ACCOUNTING_UNIT_ID
GROUP BY ct.ACCOUNTING_UNIT_ID,
  ct.statement_name,
  ct.STATEMENT_HEADING,
  unit.accounting_unit_name
ORDER BY ct.ACCOUNTING_UNIT_ID]]></queryString>

