.add($F{CR_222105}.add($F{CR_222106}.add($F{CR_222107}.add($F{CR_222108}.add($F{CR_222109}
.add($F{CR_222110}.add($F{CR_222111}.add($F{CR_222112}))))))))))))]]></variableExpression>
	</variable>
	<variable name="sum_222102" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
