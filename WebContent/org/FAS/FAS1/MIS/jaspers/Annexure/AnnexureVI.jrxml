		<variableExpression><![CDATA[$F{CR160502}]]></variableExpression>
	</variable>
	<variable name="tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR160502}.add($F{DR160502}.add($F{NET160502}.add($F{NET780406}.add($F{DIFF}.add($F{CR160611}
.add($F{DR160611}.add($F{NET160611}.add($F{NET782406}.add($F{NET780416})))))))))]]></variableExpression>
	</variable>
	<variable name="160502_dr" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DR160502}]]></variableExpression>
	</variable>
