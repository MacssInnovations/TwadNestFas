<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Annexure_IV(7)"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1048"
		 pageHeight="842"
		 columnWidth="988"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="sub_qry" isForPrompting="true" class="java.lang.String"/>
	<parameter name="Statement" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="head" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select ct.ACCOUNTING_UNIT_ID,ct.statement_name,
  ct.STATEMENT_HEADING,
sum(cr222508)cr222508,
sum(Dr222503)Dr222503,
sum(Cr221105)Cr221105,
sum(Cr221205)Cr221205,
unit.accounting_unit_name
from
(SELECT map.STATEMENT_NO,
 -- map.LEVEL_NO,
--  map.ACCOUNT_HEAD_TITLE,
 -- map.ACCOUNT_HEAD_CODE,
  mis.statement_name,
  mis.STATEMENT_HEADING,
  aa.ACCOUNTING_UNIT_ID,
  aa.account_head_code head_code,
  aa.DR_AMOUNT,
  aa.CR_AMOUNT,
 case
   WHEN aa.ACCOUNT_HEAD_CODE=222508
   THEN aa.CR_AMOUNT
   else 0
 END AS cr222508,
  case
   WHEN aa.ACCOUNT_HEAD_CODE=222503
    THEN aa.DR_AMOUNT else 0
  END AS Dr222503,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=221105
    THEN aa.CR_AMOUNT else 0
  END AS Cr221105,
  case
    WHEN aa.ACCOUNT_HEAD_CODE=221205
    THEN aa.CR_AMOUNT else 0
 END AS Cr221205
FROM (
  (SELECT a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    SUM( current_month_debit )                               AS DR_AMOUNT,
    SUM( current_month_credit)                               AS CR_AMOUNT,
    (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net_Amt,
    0                                                        AS Sup_No,
    0                                                        AS Fin_Year ,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy') Month_Tb
  FROM FAS_TRIAL_BALANCE a
  WHERE (current_month_debit!=0
  OR current_month_credit!   =0)
  GROUP BY a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    0,
    0,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy')
  )
UNION ALL
  (SELECT a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    SUM( current_month_debit )                               AS debit,
    SUM( current_month_credit)                               AS credit,
    (SUM( current_month_debit )- SUM( Current_Month_Credit)) AS Net,
    Supplement_No                                            AS Sup_No,
    0                                                        AS Fin_Year ,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy')+Supplement_No month_TB
  FROM Fas_Trial_Balance_Supplement A
  WHERE (current_month_debit!=0
  OR current_month_credit!   =0)
  GROUP BY a.ACCOUNTING_UNIT_ID,
    a.account_head_code,
    Supplement_No,
    0,
    Cashbook_Year,
    Cashbook_Month,
    To_date(Cashbook_Month
    ||'-'
    ||Cashbook_Year,'MM-yyyy')+Supplement_No
  ) )aa
INNER JOIN FAS_MIS_ANNEXURE_HEADS_MAP map
ON aa.account_head_code=map.account_head_code
INNER JOIN FAS_MIS_ANNEXURE_MST mis
ON mis.statement_no =map.statement_no
and map.status      ='L'
AND map.STATEMENT_NO=$P{Statement}
and $P!{sub_qry}
  

group by map.STATEMENT_NO,  mis.statement_name, mis.STATEMENT_HEADING, aa.ACCOUNTING_UNIT_ID, aa.account_head_code,
 aa.DR_AMOUNT,
  aa.CR_AMOUNT
--ORDER BY map.LEVEL_NO
)ct inner join FAS_MST_ACCT_UNITS unit 
on ct.accounting_unit_id=unit.accounting_unit_id
group by ct.ACCOUNTING_UNIT_ID, ct.statement_name, ct.STATEMENT_HEADING, unit.accounting_unit_name]]></queryString>

	<field name="ACCOUNTING_UNIT_ID" class="java.math.BigDecimal"/>
	<field name="STATEMENT_NAME" class="java.lang.String"/>
	<field name="STATEMENT_HEADING" class="java.lang.String"/>
	<field name="CR222508" class="java.math.BigDecimal"/>
	<field name="DR222503" class="java.math.BigDecimal"/>
	<field name="CR221105" class="java.math.BigDecimal"/>
	<field name="CR221205" class="java.math.BigDecimal"/>
	<field name="ACCOUNTING_UNIT_NAME" class="java.lang.String"/>

	<variable name="Total" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{CR222508}.add( $F{DR222503}).add($F{CR221105}).add($F{CR221205})]]></variableExpression>
	</variable>
	<variable name="222508_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR222508}]]></variableExpression>
	</variable>
	<variable name="222503_tot" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
