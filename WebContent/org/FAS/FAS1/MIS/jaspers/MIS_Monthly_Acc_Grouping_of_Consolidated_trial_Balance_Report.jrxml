<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="MIS_Monthly_Acc_Grouping_of_Consolidated_trial_Balance_Report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="821"
		 pageHeight="842"
		 columnWidth="761"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<parameter name="year" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[SELECT MAJOR_HEAD_DESC,
  GROUP_HEAD_DESC,
  MINOR_HEAD_DESC,
  ACCOUNT_HEAD_CODE ,
  ACCOUNT_HEAD_DESC,
  DECODE(Debit_for_Month,NULL,0,Debit_for_Month)                      AS Debit_for_Month,
  DECODE(Credit_for_Month,NULL,0,Credit_for_Month)                    AS Credit_for_Month,
  DECODE(Net_for_Month,NULL,0,Net_for_Month)                          AS Net_for_Month,
  DECODE(Debit_for_Year,NULL,0,Debit_for_Year)                        AS Debit_for_Year,
  DECODE(Credit_for_Year,NULL,0,Credit_for_Year)                      AS Credit_for_Year,
  DECODE(Net_for_Year,NULL,0,Net_for_Year)                            AS Net_for_Year,
  DECODE(cr_dr_indicator_for_month,NULL,'',cr_dr_indicator_for_month) AS cr_dr_indicator_for_month,
  DECODE(cr_dr_indicator_for_Year,NULL,'',cr_dr_indicator_for_Year)   AS cr_dr_indicator_for_Year
FROM
  (SELECT MAJOR_HEAD_DESC,
    GROUP_HEAD_DESC,
    MINOR_HEAD_DESC,
    ACCOUNT_HEAD_CODE,
    ACCOUNT_HEAD_DESC
  FROM
    (SELECT MAJOR_HEAD_CODE,
      GROUP_HEAD_CODE,
      MINOR_HEAD_CODE,
      ACCOUNT_HEAD_CODE
    FROM FAS_MIS_GROUP_ACC_HD_MAPPING
    ORDER BY GROUP_HEAD_CODE,
      MINOR_HEAD_CODE,
      ACCOUNT_HEAD_CODE
    )a
  LEFT OUTER JOIN
    (SELECT GROUP_HEAD_CODE AS grp_hd_cde,
      GROUP_HEAD_DESC
    FROM FAS_MIS_GROUP_MASTER
    ORDER BY GROUP_HEAD_CODE
    )b
  ON a.GROUP_HEAD_CODE =b.grp_hd_cde
  LEFT OUTER JOIN
    (SELECT MAJOR_HEAD_CODE AS maj_hd_cde,
      MAJOR_HEAD_DESC
    FROM COM_MST_MAJOR_HEADS
    ORDER BY MAJOR_HEAD_DESC
    )c
  ON a.MAJOR_HEAD_CODE =c.maj_hd_cde
  LEFT OUTER JOIN
    (SELECT MAJOR_HEAD_CODE AS maj_hd_cde1,
      MINOR_HEAD_CODE       AS min_hd_cde ,
      MINOR_HEAD_DESC
    FROM COM_MST_MINOR_HEADS
    ORDER BY MINOR_HEAD_DESC
    )d
  ON a.MAJOR_HEAD_CODE  =d.maj_hd_cde1
  AND a.MINOR_HEAD_CODE =d.min_hd_cde
  LEFT OUTER JOIN
    (SELECT ACCOUNT_HEAD_CODE AS ac_head_cd,
      ACCOUNT_HEAD_DESC,
      MAJOR_HEAD_CODE AS m_h_c,
      MINOR_HEAD_CODE AS mi_h_c
    FROM COM_MST_ACCOUNT_HEADS
    )e
  ON a.MAJOR_HEAD_CODE    =e.m_h_c
  AND a.MINOR_HEAD_CODE   =e.mi_h_c
  AND a.ACCOUNT_HEAD_CODE =e.ac_head_cd
  ORDER BY GROUP_HEAD_CODE,
    MINOR_HEAD_CODE,
    ACCOUNT_HEAD_CODE
  )X
LEFT OUTER JOIN
  (SELECT ACCOUNT_HEAD_CODE AS acc_hd_cde,
    Debit_for_Month,
    Credit_for_Month,
    Net_for_Month,
    CASE
      WHEN (net_for_month < 0)
      THEN 'DR'
      WHEN (net_for_month > 0)
      THEN 'CR'
      WHEN (Net_for_Month = 0)
      THEN ''
    END AS cr_dr_indicator_for_month,
    Debit_for_Year,
    Credit_for_Year,
    Net_for_Year,
    CASE
      WHEN (net_for_year < 0)
      THEN 'DR'
      when (net_for_year > 0)
      THEN 'CR'
      WHEN (Net_for_Year = 0)
      THEN ''
    END AS cr_dr_indicator_for_Year
  FROM
    (SELECT ACCOUNT_HEAD_CODE                                       AS acc_hd_code,
      SUM(CURRENT_MONTH_DEBIT)                                      AS Debit_for_Month,
      SUM(current_month_credit)                                     AS credit_for_month,
      (-((SUM(CURRENT_MONTH_DEBIT)) - (SUM(CURRENT_MONTH_CREDIT))) )AS Net_for_Month
    FROM fas_trial_balance_cmp
    WHERE cashbook_year =$P{cbyear}
    AND CASHBOOK_MONTH  =$P{cbmonth}
    GROUP BY ACCOUNT_HEAD_CODE
    )b
  LEFT OUTER JOIN
    (SELECT ACCOUNT_HEAD_CODE,
      SUM(CURRENT_MONTH_DEBIT)                                       AS Debit_for_Year,
      SUM(current_month_credit)                                      AS credit_for_year,
      ( -((SUM(CURRENT_MONTH_DEBIT)) - (SUM(CURRENT_MONTH_CREDIT))) )AS Net_for_Year
    FROM fas_trial_balance_cmp
    WHERE to_date(cashbook_month
      ||'-'
      || + cashbook_year, 'mm-yyyy') BETWEEN
      CASE
        WHEN $P{cbmonth} <=3
        THEN to_date( '04'
          || '-'
          || ( $P{cbyear} -1) , 'mm-yyyy')
        ELSE to_date( '04'
          || '-'
          || $P{cbyear} , 'mm-yyyy')
      END
    AND to_date ( $P{cbmonth}
      ||'-'
      || $P{cbyear} , 'mm-yyyy')
    GROUP BY ACCOUNT_HEAD_CODE
    )c
  ON b.acc_hd_code          =c.account_head_code
  )Y ON X.ACCOUNT_HEAD_CODE =Y.acc_hd_cde]]></queryString>

