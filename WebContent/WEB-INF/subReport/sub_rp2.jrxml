	<variable name="SUM_DR_AMOUNT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="month" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="grandtotal_CR" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{CR_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="grandtotal_DR" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{DR_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="netGrand" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[(($V{grandtotal_DR}.subtract($V{grandtotal_CR})).intValue()<0) ? ($V{grandtotal_CR}.subtract($V{grandtotal_DR}))+" (CR)" : ($V{grandtotal_DR}.subtract($V{grandtotal_CR}))+" (DR)"]]></variableExpression>
	</variable>

