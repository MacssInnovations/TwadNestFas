<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="BRS_PassSheet_Tally"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="708"
		 pageHeight="842"
		 columnWidth="648"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="UnitId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="OfficeId" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cbyear" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accNo" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="cbmonth_name" isForPrompting="false" class="java.lang.String"/>
	<parameter name="month" isForPrompting="true" class="java.lang.String"/>
	<parameter name="UnitName" isForPrompting="true" class="java.lang.String"/>
	<parameter name="title" isForPrompting="true" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["/home1/online_workspace/jan_2013/twadFas/WebContent/org/FAS/FAS1/BRS/jaspers/"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT dr_T1_ft,ob_part1,
  PASSBOOK_BALANCE,
  dr_amount ,
  total_four,
  cr_amount,
  seven,
  eight,
  CASE
    WHEN eight>0
    THEN eight
  END AS credit_side,
  CASE
    WHEN eight<0
    THEN eight
  END AS debit_side,
  BANK_ID,
  bankname,
  BRANCH_ID,
  branchname,tran_desc,trn_dr_amt,trn_cr_amt
  --trans_desc
FROM
  (SELECT a.dr_T1_ft,
    b.PASSBOOK_BALANCE,
    DECODE(c.dr_amount,NULL,0,c.dr_amount)                                                                                      AS dr_amount,
    (m.ob_part1+b.PASSBOOK_BALANCE+DECODE(c.cr_amount,NULL,0,c.cr_amount))                                                      AS total_four,
    DECODE(c.cr_amount,NULL,0,c.cr_amount)                                                                                      AS cr_amount,
    (a.dr_T1_ft +DECODE(c.dr_amount,NULL,0,c.dr_amount))                                                                        AS seven,
    ((a.dr_T1_ft+b.PASSBOOK_BALANCE+DECODE(c.cr_amount,NULL,0,c.cr_amount))-(a.dr_T1_ft+DECODE(c.dr_amount,NULL,0,c.dr_amount)))AS eight,
    b.BANK_ID,
    (SELECT n.bank_name FROM fas_mst_banks n WHERE n.bank_id=b.BANK_ID
    )AS bankname,
    b.BRANCH_ID,
    (SELECT k.branch_name
    FROM FAS_MST_BANK_BRANCHES k
    WHERE k.bank_id=b.BANK_ID
    AND k.branch_id=b.BRANCH_ID
    )AS branchname,
   m.ob_part1,d.tran_desc,d.trn_dr_amt,d.trn_cr_amt
  FROM
    (SELECT ACCOUNTING_UNIT_ID AS acc_u_id_T1,
      ACCOUNTING_FOR_OFFICE_ID AS acc_off_id_T1,
      CASHBOOK_YEAR            AS csh_bk_yr_T1,
      CASHBOOK_MONTH           AS csh_bk_mnth_T1,
      ACCOUNT_NO               AS acc_no_T1,
      SUM(DR_AMOUNT)           AS dr_T1_ft
    FROM FAS_BRS_TRANSACTION
    WHERE accounting_unit_id    = $P{UnitId}
    AND accounting_for_office_id=$P{OfficeId}
    AND cashbook_month          = $P{cbmonth}
    AND cashbook_year           =$P{cbyear}
    AND ACCOUNT_NO              =$P{accNo}
    AND doc_type LIKE 'FT%'
    GROUP BY ACCOUNTING_UNIT_ID,
      ACCOUNTING_FOR_OFFICE_ID,
      CASHBOOK_YEAR,
      CASHBOOK_MONTH,
      ACCOUNT_NO
    )a
  FULL OUTER JOIN
    (SELECT DECODE(PASSBOOK_BALANCE,NULL,0,PASSBOOK_BALANCE) AS PASSBOOK_BALANCE,
      BANK_ID,
      BRANCH_ID,
      accounting_unit_id,
      accounting_for_office_id,
      cashbook_year,
      cashbook_month,
      ACCOUNT_NO
    FROM FAS_BRS_MASTER
    WHERE accounting_unit_id    = $P{UnitId}
    AND accounting_for_office_id=$P{OfficeId}
    AND cashbook_month          =$P{cbmonth}
    AND cashbook_year           =$P{cbyear}
    AND ACCOUNT_NO              =$P{accNo}
    )b
  ON a.acc_u_id_T1    =b.accounting_unit_id
  AND a.acc_off_id_T1 =b.accounting_for_office_id
  AND a.csh_bk_yr_T1  =b.cashbook_year
  AND a.csh_bk_mnth_T1=b.cashbook_month
  AND a.acc_no_T1     =b.ACCOUNT_NO
  left outer join
  (
  select accounting_unit_id,accounting_for_office_id,cashbook_year,cashbook_month,account_no,ob_part1 from FAS_BRS_OB
  where accounting_unit_id      =$P{UnitId}
  AND accounting_for_office_id=$P{OfficeId}
  AND Cashbook_Year           =$P{cbyear}
  AND cashbook_month          =$P{cbmonth}
  AND ACCOUNT_NO              =$P{accNo}
  )m
on m.accounting_unit_id      =b.accounting_unit_id
AND m.accounting_for_office_id=b.accounting_for_office_id
AND m.cashbook_year           =b.cashbook_year
AND m.cashbook_month          =b.cashbook_month
AND m.account_no              =b.ACCOUNT_NO
  
  
  left OUTER JOIN
    (
select decode(t.dr_amount,null,0,t.dr_amount)dr_amount,decode(t.cr_amount,null,0,t.cr_amount)cr_amount,t.auid_2T_5A,t.aoid_2T_5A,
t.cbm_2T_5A,t.cby_2T_5A,t.ano_2T_5A--,m.ob_part1
from
(SELECT sum(dr_amount)as dr_amount,
  sum(cr_amount) as cr_amount,
  accounting_unit_id                                  AS auid_2T_5A,
  accounting_for_office_id                            AS aoid_2T_5A,
  cashbook_month                                      AS cbm_2T_5A,
  cashbook_year                                       AS cby_2T_5A,
  ACCOUNT_NO                                          AS ano_2T_5A
FROM fas_brs_transaction
where accounting_unit_id      =$P{UnitId}
AND accounting_for_office_id=$P{OfficeId}
AND Cashbook_Year           =$P{cbyear}
AND cashbook_month          =$P{cbmonth}
AND ACCOUNT_NO              =$P{accNo}
AND twad_or_non_twad        = 'NT'
GROUP BY accounting_unit_id,
  accounting_for_office_id,
  cashbook_month,
  cashbook_year,
  ACCOUNT_NO
) t

    )c
  ON a.acc_u_id_T1    =c.auid_2T_5A
  AND a.acc_off_id_T1 =c.aoid_2T_5A
  AND a.csh_bk_yr_T1  =c.cby_2T_5A
  AND a.csh_bk_mnth_T1=c.cbm_2T_5A
  AND a.acc_no_T1     =c.ano_2T_5A
  left outer join
  (
     SELECT DECODE(SUM(t.dr_amount),NULL,0,SUM(t.dr_amount)) AS trn_dr_amt,
      DECODE(SUM(t.cr_amount),NULL,0,SUM(t.cr_amount))       AS trn_cr_amt,
      t.transaction_type,
     (SELECT y.trans_short_desc FROM FAS_BRS_TRANSACTION_TYPE y WHERE y.trans_code=t.transaction_type)as tran_desc,
      t.accounting_unit_id       AS auid,
      t.accounting_for_office_id AS aoid,
      t.cashbook_month           AS cbm,
      t.cashbook_year            AS cby,
      t.ACCOUNT_NO               AS ano
    FROM fas_brs_transaction t
    WHERE t.accounting_unit_id      =$P{UnitId}
    AND t.accounting_for_office_id=$P{OfficeId}
    AND t.Cashbook_Year           =$P{cbyear}
    AND t.cashbook_month          =$P{cbmonth}
    AND t.ACCOUNT_NO              =$P{accNo}
    AND t.twad_or_non_twad        = 'NT'
    GROUP BY t.accounting_unit_id,
      t.accounting_for_office_id,
      t.cashbook_month,t.transaction_type,
      t.cashbook_year,
      t.ACCOUNT_NO
  )d
  ON a.acc_u_id_T1    =d.auid
  AND a.acc_off_id_T1 =d.aoid
  AND a.csh_bk_yr_T1  =d.cby
  AND a.csh_bk_mnth_T1=d.cbm
  AND a.acc_no_T1     =d.ano
  )]]></queryString>

