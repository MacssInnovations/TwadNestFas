	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="ac" isForPrompting="true" class="java.math.BigDecimal"/>
	<parameter name="accountingunitid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="accountofficeid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear_from" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cashbookyear_to" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="monthvalue_from" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthvalue_to" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[Select A.*,B.Month_Opening_Balance ,
  B.Month_Opening_Bal_Dr_Cr_Ind,
  B.Month_Closing_Balance ,
  B.Month_Closing_Bal_Dr_Cr_Ind,
  B.Account_Head_Code As H_Code,
  b.YEAR as h_year,b.Month as h_month
FROM
  (SELECT a.CR_DR_INDICATOR,
    a.RECEIPT_NO,
    a.AMOUNT,
    a.CR_AMOUNT,
    a.DR_AMOUNT,
    a.TYPE,
    TO_CHAR(a.DATE_G,'DD-MM-YYYY') AS gl_date ,
    A.Particulars,
    A.Sub_Typedesc,
  A.Subtype_Codedesc,
    a.ACCOUNT_HEAD_CODE,
    a.MONTH,
    a.DOCTYPE,
    a.YEAR,
    a.ACCOUNTING_UNIT_ID,
    a.ACCOUNTING_FOR_OFFICE_ID,
    a.CASHBOOK_YEAR,
    a.CASHBOOK_MONTH ,
    a.MONTH_IN_WORDS,
    accunit.accounting_unit_name,
    office.office_name,
    acc.account_head_desc
  FROM FAS_GENERAL_LEDGER_REPORT_TMP a ,
    FAS_MST_ACCT_UNITS accunit,
    Com_Mst_Offices Office ,
    Com_Mst_Account_Heads Acc
  WHERE a.ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND a.account_head_code       =$P{ac}
  AND a.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND office.office_id          =$P{accountofficeid}
  AND accunit.accounting_unit_id=$P{accountingunitid}
  AND acc.account_head_code     = a.account_head_code
  AND to_date(a.cashbook_month
    ||'-'
    || + a.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{monthvalue_from})
    || '-'
    || ($P{cashbookyear_from}) , 'mm-yyyy')
  AND to_date( ($P{monthvalue_to})
    ||'-'
    || ($P{cashbookyear_to}) , 'mm-yyyy')
  ORDER BY A.Cashbook_Year,
    A.Cashbook_Month,
	a.RECEIPT_NO,
    Gl_Date,
    A.Account_Head_Code
  )A
  left Outer Join
  (Select ACCOUNTING_UNIT_ID,
  Accounting_For_Office_Id,
  month_opening_balance ,
  month_opening_bal_dr_cr_ind,
  MONTH_CLOSING_BALANCE ,
  MONTH_CLOSING_BAL_DR_CR_IND,
  Month,
  YEAR,ACCOUNT_HEAD_CODE
From Fas_General_Ledger
Where Accounting_Unit_Id    =$P{accountingunitid}
AND Accounting_For_Office_Id=$P{accountofficeid}
AND to_date(MONTH
  ||'-'
  || + YEAR, 'mm-yyyy') BETWEEN to_date( $P{monthvalue_from}
  || '-'
  ||$P{cashbookyear_from} , 'mm-yyyy')
AND to_date( $P{monthvalue_to}
  ||'-'
  || $P{cashbookyear_to} , 'mm-yyyy')
    AND account_head_code       =$P{ac}
  Order By Year,Month,Account_Head_Code
)B
On A.Accounting_Unit_Id=B.Accounting_Unit_Id
And A.Accounting_For_Office_Id=B.Accounting_For_Office_Id
and a.ACCOUNT_HEAD_CODE=b.ACCOUNT_HEAD_CODE
And A.Cashbook_Year=B.Year
and a.Cashbook_Month=b.Month
ORDER BY A.Cashbook_Year,
    A.Cashbook_Month,
    a.Gl_Date,
    A.Receipt_No,
    A.Account_Head_Code,
    b.Year,b.Month]]></queryString>

