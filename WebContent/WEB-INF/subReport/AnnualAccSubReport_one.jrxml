	</variable>
	<variable name="sum_nextyear" class="java.math.BigDecimal" resetType="Group" resetGroup="groupHead" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL1_NEXT}]]></variableExpression>
	</variable>

