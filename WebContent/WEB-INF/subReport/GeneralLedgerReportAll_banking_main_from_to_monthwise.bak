	<parameter name="orgUnitName" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[Select distinct a.Account_Head_Code,C.Account_Head_Desc
--,A.Sub_Typedesc,A.Subtype_Codedesc
  From Fas_General_Ledger_Report_Tmp A Inner Join Com_Mst_Account_Heads C
  On A.Account_Head_Code=C.Account_Head_Code
  and a.ACCOUNTING_UNIT_ID    =$P{accountingunitid}
  AND a.ACCOUNTING_FOR_OFFICE_ID=$P{accountofficeid}
  AND to_date(a.cashbook_month
    ||'-'
    || + a.cashbook_year, 'mm-yyyy') BETWEEN to_date( ($P{monthvalue_from})
    || '-'
    || ($P{cashbookyear_from}) , 'mm-yyyy')
  AND To_Date( ($P{monthvalue_to})
    ||'-'
    || ($P{cashbookyear_to}) , 'mm-yyyy') 
ORDER BY a.ACCOUNT_HEAD_CODE]]></queryString>

