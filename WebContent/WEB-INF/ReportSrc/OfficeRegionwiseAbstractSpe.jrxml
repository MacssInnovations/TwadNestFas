	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="officelevelid" isForPrompting="true" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[$P{officelevelid}]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select * from (

(select upper( b.REGION_OFFICE_NAME) as REGION_OFFICE_NAME,c.OFFICE_LEVEL_ID,count(a.CIRCLE_OFFICE_ID) as count
from COM_MST_CIRCLES_HVIEW a,COM_MST_REGIONS_HVIEW b,COM_MST_OFFICES c
where a.REGION_OFFICE_ID=b.REGION_OFFICE_ID and c.OFFICE_ID=a.CIRCLE_OFFICE_ID
and a.REGION_OFFICE_ID=$P{officelevelid}
group by b.REGION_OFFICE_NAME,c.OFFICE_LEVEL_ID)


union all

(select upper(b.REGION_OFFICE_NAME),c.OFFICE_LEVEL_ID,count(a.DIVISION_OFFICE_ID)
from COM_MST_DIVISIONS_HVIEW a,COM_MST_REGIONS_HVIEW b,COM_MST_OFFICES c
where a.REGION_OFFICE_ID=b.REGION_OFFICE_ID and c.OFFICE_ID=a.DIVISION_OFFICE_ID
and a.REGION_OFFICE_ID=$P{officelevelid}
group by b.REGION_OFFICE_NAME,c.OFFICE_LEVEL_ID)

union all

(select upper(b.REGION_OFFICE_NAME),c.OFFICE_LEVEL_ID,count(a.SUBDIVISION_OFFICE_ID)
from COM_MST_SUBDIVISIONS_HVIEW a,COM_MST_REGIONS_HVIEW b,COM_MST_OFFICES c
where a.REGION_OFFICE_ID=b.REGION_OFFICE_ID and c.OFFICE_ID=a.SUBDIVISION_OFFICE_ID
and a.REGION_OFFICE_ID=$P{officelevelid}
group by b.REGION_OFFICE_NAME,c.OFFICE_LEVEL_ID)

)


order by REGION_OFFICE_NAME,OFFICE_LEVEL_ID]]></queryString>

	<field name="REGION_OFFICE_NAME" class="java.lang.String"/>
	<field name="OFFICE_LEVEL_ID" class="java.lang.String"/>
	<field name="COUNT" class="java.math.BigDecimal"/>


		<group  name="Region" >
