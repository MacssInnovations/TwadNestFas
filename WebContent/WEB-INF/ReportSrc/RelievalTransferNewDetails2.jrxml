	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select * from 
(
select EMPLOYEE_ID, DATE_OF_RELIEVAL, decode(REMARKS,null,' ',REMARKS) REMARKS,
to_char(DATE_OF_RELIEVAL,'mm') as mnt, PROCESS_FLOW_STATUS_ID, RELIEVAL_SLNO, OFFICE_ID
from HRM_EMP_RELIEVAL_DETAILS
where PROCESS_FLOW_STATUS_ID='FR'
) a
inner join
(
select RELIEVAL_SLNO,OFFICE_ID, DESIGNATION_ID,
decode(TRANSFER_PROCEED_DATE,null,' ',TRANSFER_PROCEED_DATE) TRANSFER_PROCEED_DATE from  HRM_EMP_RELIEVAL_TRN 
) b
on a.OFFICE_ID=b.OFFICE_ID and b.RELIEVAL_SLNO=a.RELIEVAL_SLNO
inner join
(
select EMPLOYEE_ID,EMPLOYEE_NAME||decode(EMPLOYEE_INITIAL,null,' ','.'||EMPLOYEE_INITIAL) AS employee_name from  HRM_MST_EMPLOYEES
) c
on c.EMPLOYEE_ID=a.EMPLOYEE_ID
left outer join
(
select DESIGNATION_ID,DESIGNATION from  HRM_MST_DESIGNATIONS
) d
on d.DESIGNATION_ID=b.DESIGNATION_ID
inner join 
(
select  OFFICE_ID,OFFICE_NAME,OFFICE_NAME as Office_to_be_joined, OFF_ORDER from  COM_MST_ALL_OFFICES_VIEW
) e
on e.OFFICE_ID=b.OFFICE_ID
inner join
(
select date_of_joining,EMPLOYEE_ID from HRM_EMP_JOIN_REPORTS
) f
on f.EMPLOYEE_ID=a.EMPLOYEE_ID
where  e.OFFICE_ID in ($P!{offids})  and
a.DATE_OF_RELIEVAL between $P{fromdate} and $P{todate}
order by e.OFF_ORDER,e.OFFICE_NAME,a.EMPLOYEE_ID]]></queryString>

