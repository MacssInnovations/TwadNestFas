	<parameter name="deptid" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.other_dept_id,a.other_dept_name,b.other_dept_office_id,b.other_dept_office_name, 
decode(b.ADDRESS1,null,' ',b.ADDRESS1  ) OFFICE_ADDRESS1 ,
decode(b.ADDRESS2,null,' ',b.ADDRESS2  ) OFFICE_ADDRESS2 ,
decode(b.CITY_TOWN,null,' ', b.CITY_TOWN ) CITY_TOWN_NAME ,
decode(b.PINCODE,null,' ',b.PINCODE  ) OFFICE_PIN_CODE ,
decode(b.E_MAIL,null,' ',b.E_MAIL ) OFFICE_EMAIL_ID ,
decode(b.STD_CODE,null,' ', b.STD_CODE ) OFFICE_STD_CODE ,
decode(b.PHONE_NO,null,' ', b.PHONE_NO  ) OFFICE_PHONE_NO ,
decode(b.FAX_NO,null,' ', b.FAX_NO ) OFFICE_FAX_NO from hrm_mst_other_depts a
inner join hrm_mst_other_dept_offices b on a.other_dept_id=b.other_dept_id where a.other_dept_id=$P{deptid}]]></queryString>

