	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="des_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select d.employee_id,d.employee_name,e.office_name,b.post_rank_name,a.designation,c.date_effective_from,a.post_rank_id from
(
select designation_id,post_rank_id,designation from hrm_mst_designations
where post_rank_id=$P{des_id}
) a
left outer join
(
select post_rank_id,post_rank_name from hrm_mst_post_ranks
) b
on a.post_rank_id=b.post_rank_id
left outer join
(
select designation_id,employee_id,office_id,date_effective_from from hrm_emp_current_posting
where office_id in ($P!{off_id})
) c
on a.designation_id=c.designation_id
left outer join
(
select employee_id,employee_name||decode(employee_initial,null,' ','.'||employee_initial) employee_name from hrm_mst_employees
) d
on c.employee_id=d.employee_id
left outer join
(
select office_id,office_name,off_order from com_mst_all_offices_view
) e
on c.office_id=e.office_id
order by e.off_order,d.employee_name]]></queryString>

