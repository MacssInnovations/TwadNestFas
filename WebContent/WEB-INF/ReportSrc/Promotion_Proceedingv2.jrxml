<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Promotion_Proceedingv2"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="order" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="office" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="suffix" isForPrompting="true" class="java.lang.String"/>
	<parameter name="pwhole" isForPrompting="true" class="java.lang.String"/>
	<parameter name="copyto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="proceed" isForPrompting="true" class="java.lang.String"/>
	<parameter name="address" isForPrompting="true" class="java.lang.String"/>
	<parameter name="no_date" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.promotion_issue_office_id,a.promotion_order_id,a.employee_id,a.to_which_office_id,decode(a.reposts_required,'Y','Yes','N','No') as reposts_required , 
a.new_designation,decode(a.ta_da_eligible,'Y','Yes','N','No')as ta_da_eligible,b.proceeding_date,b.proceeding_no,
b.proceed_subject,decode(b.proceed_subject,null,null,'Sub : ' || b.proceed_subject) as proc_subj,
b.proceed_reference,decode(b.proceed_reference,null,null,'Ref : ' || b.proceed_reference) as proc_ref,
b.addl_para_1,b.addl_para_2,b.copy_to,b.presiding_officer,
b.presiding_officer_designation,b.signed,b.suffix,b.prefix,c.employee_name,d.trf_office_name,
decode(s.new_office_name,null, 
( select office_name as new_office_name from com_mst_offices
where office_id=a.to_which_office_id),s.new_office_name)as new_office_name ,g.current_designation, decode(a.posted,'Y','Yes','N','No')as posted,
h.new_designation_name,org_office_name from 
( 
select promotion_issue_office_id,promotion_order_id,employee_id,to_which_office_id,reposts_required,new_designation, 
process_flow_status_id,ta_da_eligible,posted,dept_id
from HRM_promotion_DETAILS 
where process_flow_status_id in ('CR','MD')
) a
left outer join 
( 
select promotion_issue_office_id as trf_off_id,promotion_order_id as trf_ord_id,proceeding_date,proceeding_no,proceed_subject,proceed_reference, 
addl_para_1,addl_para_2,copy_to,prefix,presiding_officer,presiding_officer_designation,process_flow_status_id,signed_po as signed,suffix 
from HRM_promotion_ORDERS 
where process_flow_status_id in ('CR','MD') 
) b 
on a.promotion_issue_office_id=b.trf_off_id and a.promotion_order_id=b.trf_ord_id 
left outer join 
( 
select employee_id as emp_id, employee_prefix || '.' || employee_name || '.' || employee_initial as employee_name from 
hrm_mst_employees 
) c 
on a.employee_id=c.emp_id 
left outer join 
( 
select office_id,office_name as trf_office_name from com_mst_offices 
where office_status_id not in ('CL','RD','NC')
) d 
on a.promotion_issue_office_id=d.office_id
left outer join  
( 
select office_id,office_name as new_office_name from com_mst_offices 
where office_status_id not in ('CL','RD','NC') 
) e 
on a.to_which_office_id=e.office_id 
left outer join
( 
select employee_id as emp_id2, office_id as off_id2, designation_id as desig_id2 from hrm_emp_current_posting 
where employee_status_id in 'WKG' and process_flow_status_id in 'FR' 
) f 
on a.employee_id=f.emp_id2 
left outer join 
( 
select office_id,office_name as org_office_name from com_mst_offices 
where office_status_id not in ('CL','RD','NC')
) ff
on f.off_id2=ff.office_id
left outer join 
( 
select designation_id as desig_id3, designation as current_designation from hrm_mst_designations 
) g 
on f.desig_id2=g.desig_id3
left outer join 
( 
select designation_id as desig_id4, designation as new_designation_name from hrm_mst_designations 
) h
on a.new_designation=h.desig_id4
left outer join  
( 
select other_dept_id,other_dept_office_id,other_dept_office_name as new_office_name from hrm_mst_other_dept_offices 
)s                                         
on   s.other_dept_id=a.dept_id and s.other_dept_office_id=a.to_which_office_id
where a.promotion_issue_office_id=$P{office} and a.promotion_order_id=$P{order}]]></queryString>

