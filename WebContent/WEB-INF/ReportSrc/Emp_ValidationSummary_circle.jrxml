<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Emp_ValidationSummary_circle"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select   region_office_id,circle_office_id,
decode(sum(srcont_available),null,0,sum(srcont_available)) sravail ,
decode(sum(srcont_validated),null,0,sum(srcont_validated)) srvalid,
decode(sum(curpost_validated),null,0,sum(curpost_validated)) curpostvalid,
decode(sum(addl_validated),null,0,sum(addl_validated)) addl_valid,
decode(sum(sr_data_valid),null,0,sum(sr_data_valid)) sr_data_valid 
from hrm_emp_validation_view  
where  circle_office_id is not null  and circle_office_id in ($P!{offids})  
group by  region_office_id,circle_office_id  order By 
region_office_id,circle_office_id
)a
left join 
(
select office_id, office_name from com_mst_offices 
)b
on a.circle_office_id=b.office_id
left join
(
select office_id,office_name as offname from com_mst_offices 
)c
on a.region_office_id=c.office_id
left outer join
(
select a.controlling_office_id,count(b.employee_id) PHOTO_VALID from hrm_emp_controlling_office a
inner join HRM_EMP_ADDL_PHOTO_NEW_TMP b on b.employee_id=a.employee_id where b.process_flow_status_id='FR' and b.process_flow_status_id is not null
group by controlling_office_id
) j on j.controlling_office_id=a.circle_office_id]]></queryString>

