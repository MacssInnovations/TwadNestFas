	<field name="OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="OFFNAME" class="java.lang.String"/>
	<field name="PHOTO_VALID" class="java.lang.Integer"/>


