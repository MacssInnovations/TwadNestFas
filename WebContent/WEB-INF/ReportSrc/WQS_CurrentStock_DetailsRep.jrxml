<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="WQS_CurrentStock_DetailsRep"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="lab" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="cat" isForPrompting="true" class="java.lang.String"/>
	<parameter name="catdesc" isForPrompting="true" class="java.lang.String"/>
	<parameter name="tdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="labname" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select cat_code,item,
       (case when cat_code=$P{cat} then(select che_specification from wqs_mst_inv_chemical where chemical_code=item)
	     when cat_code='GLA' then(select glassware_spec from wqs_mst_inv_glassware where glassware_code=item)
	     when cat_code='MIS' then(select miscellaneous_spec from wqs_mst_inv_miscellaneous where miscellaneous_code=item)
	     else (select inst_category_spec from wqs_mst_inv_instrument where inst_category=item)end
       )as item_spec,qty_rc,qty_is,qty_is_lab,qty_rc_lab,(qty_is + qty_is_lab) as issued,(qty_rc+qty_rc_lab) as received,
       (case when cat_code=$P{cat} then(select sum(qty_available) as avail from wqs_chemical_master where chemical_code=item and lab_code=$P{lab} group by chemical_code)
             when cat_code='GLA' then(select no_available from wqs_glassware_master where glassware_code=item and lab_code=$P{lab})
             else(select qty_available from wqs_miscellaneous_master where miscellaneous_code=item and lab_code=$P{lab})end
       )as balance from(select 
       (case when a.item_code is not null then a.item_code
             when b.item_code is not null then b.item_code
             when c.item_code is not null then c.item_code
             else d.item_code end
       )as item,
       (case when a.qty_rc is null then 0
	     else a.qty_rc end)as qty_rc,
       (case when b.qty_is is null then 0
	     else b.qty_is end)as qty_is,
       (case when c.qty_is_lab is null then 0
	     else c.qty_is_lab end)as qty_is_lab,
       (case when d.qty_rc_lab is null then 0
	     else d.qty_rc_lab end)as qty_rc_lab,
       (case when a.major_category_code is not null then a.major_category_code
             when b.major_category_code is not null then b.major_category_code
             when c.major_category_code is not null then c.major_category_code
             else d.major_category_code end
       )as cat_code
      from(select major_category_code,item_code,sum(qty_received)as qty_rc from wqs_item_receipt where lab_code=$P{lab} and date_of_receipt=$P{tdate} and major_category_code=$P{cat} group by major_category_code,item_code)a
      full join(select major_category_code,item_code,sum(qty_issued)as qty_is from wqs_item_issue where lab_code=$P{lab} and date_of_issue=$P{tdate} and major_category_code=$P{cat} group by major_category_code,item_code 
               )b on a.major_category_code=b.major_category_code and a.item_code=b.item_code
      full join(select major_category_code,item_code,sum(qty_issued) as qty_is_lab from wqs_lab_transfer where from_lab_code=$P{lab} and date_of_issue=$P{tdate} and major_category_code=$P{cat} and status='Accept' group by major_category_code,item_code
               )c on b.major_category_code=c.major_category_code and b.item_code=c.item_code
      full join(select major_category_code,item_code,sum(qty_issued) as qty_rc_lab from wqs_lab_transfer where to_lab_code=$P{lab} and date_of_receipt=$P{tdate} and major_category_code=$P{cat} and status='Accept' group by major_category_code,item_code
          )d on c.major_category_code=c.major_category_code and c.item_code=d.item_code
      )order by cat_code]]></queryString>

