	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select * from 
(
select EMPLOYEE_ID,OFFICE_ID,DATE_OF_RELIEVAL,TO_CHAR(DATE_OF_RELIEVAL,'Month') as Relieval_month,RELIEVAL_SLNO,RELIEVAL_REASON_ID,LEAVE_TYPE_CODE from HRM_EMP_RELIEVAL_DETAILS
) a

left outer join 
(
select office_id,office_name,office_level_id,OFF_ORDER from COM_MST_ALL_OFFICES_VIEW
) b 
on b.office_id = a.office_id

inner join
(
select employee_id,EMPLOYEE_NAME||decode(EMPLOYEE_INITIAL,null,' ','.'||EMPLOYEE_INITIAL) AS employee_name,
DATE_OF_BIRTH from HRM_MST_EMPLOYEES 
)c
on c.EMPLOYEE_ID=a.EMPLOYEE_ID
inner join
(
select employee_id,DESIGNATION_ID from HRM_EMP_CURRENT_POSTING
) d
on d.employee_id=a.employee_id
inner join
(select designation_id,designation,service_group_id from HRM_MST_DESIGNATIONS) e
on e.designation_id=d.designation_id 

left outer join
( select a.employee_id,a.other_dept_id,a.other_dept_office_id,a.office_id,a.deputation_date,a.DEPUTATION_COMPLETION_DATE,a.RELIEVAL_SLNO,b.OTHER_DEPT_OFFICE_NAME	
 from HRM_EMP_RELIEVAL_DPN a
inner join HRM_MST_OTHER_DEPT_OFFICES b on b.OTHER_DEPT_ID = a.other_dept_id and b.OTHER_DEPT_OFFICE_ID	=a.other_dept_office_id
)  i
on i.employee_id=a.employee_id and i.RELIEVAL_SLNO=a.RELIEVAL_SLNO

inner join
(
select service_group_id,service_group_name from HRM_MST_SERVICE_GROUP
) g 
on g.service_group_id=e.service_group_id 
left outer join
(
select LEAVE_TYPE_CODE,LEAVE_TYPE_DESC from HRM_MST_LEAVE_TYPES
) j
on j.LEAVE_TYPE_CODE=a.LEAVE_TYPE_CODE
left outer join
(
select RELIEVAL_REASON_ID,RELIEVAL_REASON_DESC from HRM_MST_RELIEVAL_REASONS
) k
on k.RELIEVAL_REASON_ID=a.RELIEVAL_REASON_ID
where a.RELIEVAL_REASON_ID in('DPN','SLV')
and a.office_id in ($P!{offids})
and  a.DATE_OF_RELIEVAL between $P{fromdate} and $P{todate}

order by OFF_ORDER,b.office_name,e.designation]]></queryString>

