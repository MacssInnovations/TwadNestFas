	<parameter name="cadre" isForPrompting="true" class="java.lang.String"/>
	<parameter name="name" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select employee_name,office_name,employee_status_desc, decode(floor(months_between(now(),designation_date)/12),null,0,floor(months_between(now(),designation_date)/12)) as years_completed,designation_id,employee_id,designation_date,joining_date,service_list_slno,
current_posting_date,office_id,employee_status_id,department_id
 from
(
select * from
(
select employee_id,designation_id from hrm_emp_current_posting
where designation_id in ($P!{cadre}) and employee_status_id not in ('SAN','VRS','DTH','RES')
and employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
)aa
left outer join
(
select employee_id as emp_id,min(date_from) as designation_date,designation_id as desig_id from hrm_emp_service_data
where designation_id in ($P!{cadre}) and  employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
and employee_status_id not in ('SAN','VRS','DTH','RES') 
group by employee_id,designation_id 
)a1
on aa.designation_id=a1.desig_id and aa.employee_id=a1.emp_id

left outer join
(
select employee_id as emp_id1,min(date_from) as joining_date,designation_id as des,service_list_slno from hrm_emp_service_data
where service_list_slno=1
group by employee_id,designation_id,service_list_slno
) b
on aa.employee_id=b.emp_id1
left outer join
(
select employee_id as emp_id2,date_effective_from as current_posting_date,office_id ,employee_status_id,
department_id
from hrm_emp_current_posting
) c
on aa.employee_id=c.emp_id2
where c.employee_status_id not in ('SAN','DTH','VRS','RES')
) x
left outer join
(
select office_id as off_id,office_name,'TWAD' as dept_id from com_mst_offices
where office_status_id not in ('CL','RD','NC') 
union
select other_dept_office_id as office_id,other_dept_office_name as office_name,
other_dept_id as dept_id from hrm_mst_other_dept_offices
) y
on x.office_id=y.off_id and x.department_id=y.dept_id
left outer join
(
select employee_status_id as emp_stat_id,employee_status_desc from hrm_mst_employee_status
) z
on x.employee_status_id=z.emp_stat_id
left outer join
(
select employee_id as emp_id3,employee_name || '.' || employee_initial as employee_name from hrm_mst_employees
) w
on x.employee_id=w.emp_id3
)p

left outer join
(
select designation_id as desig_id1,designation from hrm_mst_designations
) v
on p.designation_id=v.desig_id1
order by DESIGNATION_DATE]]></queryString>

