	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[SELECT * FROM 
(
select a.employee_id,a.employee_name,
last_day(add_months(date_of_birth,720)) as retiredate,a.date_of_birth,b.designation,
c.office_level_id,c.OFFICE_SHORT_NAME,d.office_level_name  from HRM_MST_EMPLOYEES a
inner join HRM_EMP_CURRENT_POSTING e on  a.employee_id=e.employee_id
left outer join HRM_MST_DESIGNATIONS b on e.designation_id=b.designation_id 
left outer join COM_MST_OFFICES c on c.office_id=e.office_id 
inner join  COM_MST_OFFICE_LEVELS d on c.office_level_id=d.office_level_id

where (last_day(add_months(date_of_birth,720)) between  $P{txtfrom} and $P{txtto} ) 
and  b.DESIGNATION_SHORT_NAME in ('DUFF','OA','WM','SEPR','MTAST','GARNR','SW','WCE8','WCE36','WCE54','WCE59','LA','LASCA','WMCGD','MAZDR','WCE10','CLEII') and to_number(extract(day from a.date_of_birth))!=1 

UNION 

select a.employee_id,a.employee_name,
last_day(add_months(date_of_birth,696)) as retiredate,a.date_of_birth,b.designation,
c.office_level_id,c.OFFICE_SHORT_NAME,d.office_level_name  from HRM_MST_EMPLOYEES a
inner join HRM_EMP_CURRENT_POSTING e on  a.employee_id=e.employee_id
left outer join HRM_MST_DESIGNATIONS b on e.designation_id=b.designation_id 
left outer join COM_MST_OFFICES c on c.office_id=e.office_id 
inner join  COM_MST_OFFICE_LEVELS d on c.office_level_id=d.office_level_id

where (last_day(add_months(date_of_birth,696)) between  $P{txtfrom} and $P{txtto})  
and  b.DESIGNATION_SHORT_NAME not in ('DUFF','OA','WM','SEPR','MTAST','GARNR','SW','WCE8','WCE36','WCE54','WCE59','LA','LASCA','WMCGD','MAZDR','WCE10','CLEII') and to_number(extract(day from a.date_of_birth))!=1

UNION 

select a.employee_id,a.employee_name,
last_day(add_months(date_of_birth,719)) as retiredate,a.date_of_birth,b.designation,
c.office_level_id,c.OFFICE_SHORT_NAME,d.office_level_name  from HRM_MST_EMPLOYEES a
inner join HRM_EMP_CURRENT_POSTING e on  a.employee_id=e.employee_id
left outer join HRM_MST_DESIGNATIONS b on e.designation_id=b.designation_id 
left outer join COM_MST_OFFICES c on c.office_id=e.office_id 
inner join  COM_MST_OFFICE_LEVELS d on c.office_level_id=d.office_level_id

where (last_day(add_months(date_of_birth,719)) between  $P{txtfrom} and $P{txtto})  
and  b.DESIGNATION_SHORT_NAME  in ('DUFF','OA','WM','SEPR','MTAST','GARNR','SW','WCE8','WCE36','WCE54','WCE59','LA','LASCA','WMCGD','MAZDR','WCE10','CLEII') and to_number(extract(day from a.date_of_birth))=1

UNION

select a.employee_id,a.employee_name,
last_day(add_months(date_of_birth,695)) as retiredate,a.date_of_birth,b.designation,
c.office_level_id,c.OFFICE_SHORT_NAME,d.office_level_name  from HRM_MST_EMPLOYEES a
inner join HRM_EMP_CURRENT_POSTING e on  a.employee_id=e.employee_id
left outer join HRM_MST_DESIGNATIONS b on e.designation_id=b.designation_id 
left outer join COM_MST_OFFICES c on c.office_id=e.office_id 
inner join  COM_MST_OFFICE_LEVELS d on c.office_level_id=d.office_level_id

where (last_day(add_months(date_of_birth,695)) between  $P{txtfrom} and $P{txtto}) 
and  b.DESIGNATION_SHORT_NAME not  in ('DUFF','OA','WM','SEPR','MTAST','GARNR','SW','WCE8','WCE36','WCE54','WCE59','LA','LASCA','WMCGD','MAZDR','WCE10','CLEII') and to_number(extract(day from a.date_of_birth))=1


)]]></queryString>

