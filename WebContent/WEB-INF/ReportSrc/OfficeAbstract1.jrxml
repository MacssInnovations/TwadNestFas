	<queryString><![CDATA[select b.OFFICE_LEVEL_NAME,count(a.OFFICE_LEVEL_ID) 
from COM_MST_OFFICES a
inner join COM_MST_OFFICE_LEVELS b on a.OFFICE_LEVEL_ID=b.OFFICE_LEVEL_ID
where a.OFFICE_LEVEL_ID != 'HO'
group by b.OFFICE_LEVEL_NAME]]></queryString>

	<field name="OFFICE_LEVEL_NAME" class="java.lang.String"/>
	<field name="COUNT(A.OFFICE_LEVEL_ID)" class="java.lang.Integer"/>

