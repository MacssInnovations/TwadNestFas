	<parameter name="catdesc" isForPrompting="true" class="java.lang.String"/>
	<parameter name="lab" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select * from
(
 select distinct LAB_CODE,SUPPLIER_CODE,MAJOR_CATEGORY_CODE,ITEM_CODE from WQS_MST_INV_SUP_ITEM
)a
inner join(select LAB_CODE,SUPPLIER_CODE,SUPPLIER_NAME,ADDRESS1,ADDRESS2,ADDRESS3,PINCODE,SOURCE_LOC_DISTRICT_CODE,CONTACT_PHONE1,FAX,EMAIL,CURRENT_STATUS,FILE_REFERENCE,REMARKS from WQS_MST_INV_SUPPLIER)b on a.LAB_CODE=b.LAB_CODE and a.SUPPLIER_CODE=b.SUPPLIER_CODE 
inner join(select MISCELLANEOUS_CODE,MISCELLANEOUS_SPEC from WQS_MST_INV_MISCELLANEOUS)e on a.ITEM_CODE=e.MISCELLANEOUS_CODE 
left outer join(select MAJOR_CATEGORY_CODE,MAJOR_CATEGORY_DESC from WQS_MST_INV_CATEGORY)d on a.MAJOR_CATEGORY_CODE=d.MAJOR_CATEGORY_CODE 
left outer join(select LAB_CODE,LAB_DESC from WQS_MST_LAB)f on a.LAB_CODE=f.LAB_CODE where a.LAB_CODE=$P{lab} and d.MAJOR_CATEGORY_DESC=$P{catdesc} order by a.SUPPLIER_CODE]]></queryString>

