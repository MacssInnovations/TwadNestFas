	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select office_id,employee_id,employee_name,date_of_joining,subdivision_office_id,office_name,process_flow_status_id,joining_year,
remarks,fn_or_an,updated_by_user_id,updated_date,off_order,office_level_id from
(
select office_id,employee_id,date_of_joining,subdivision_office_id,process_flow_status_id,joining_year,
remarks,fn_or_an,updated_by_user_id,updated_date from hrm_emp_join_reports 
where office_id in($P!{offids}) and date_of_joining between ($P{fromdate}) and ($P{todate})
)a
left join
(
select employee_id as emp_id,employee_name from hrm_mst_employees
)b
on a.employee_id=b.emp_id
left join
(
select office_id as offid,office_name,off_order,office_level_id from com_mst_all_offices_view
)c
on a.office_id=c.offid
order by off_order]]></queryString>

