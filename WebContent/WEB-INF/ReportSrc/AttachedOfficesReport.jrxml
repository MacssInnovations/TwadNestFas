	<queryString><![CDATA[select 
a.attached_office_id,a.date_of_attachment,a.controlling_office_id,b.office_name,decode(b.office_address1,null,' ',b.office_address1)office_address1,decode(b.office_address2,null,' ',b.office_address2)office_address2,decode(b.city_town_name,null,' ',b.city_town_name)city_town_name,decode(b.OFFICE_PIN_CODE,null,' ',0,' ',b.office_pin_code)office_pin_code,decode(c.district_name,null,' ',c.district_name)district_name,d.office_level_name,f.office_name as controlling_office_name from com_office_attachments a,com_mst_offices b,com_mst_districts c,COM_MST_OFFICE_LEVELS d,com_mst_offices f where  
a.attached_office_id=b.office_id and c.district_code=b.district_code and d.office_level_id=b.office_level_id and a.controlling_office_id=f.office_id and a.process_flow_status_id in 'FR' and a.date_of_attachment between $P{txtfrom} and $P{txtto}]]></queryString>

