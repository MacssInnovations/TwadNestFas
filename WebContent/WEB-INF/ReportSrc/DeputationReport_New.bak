	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="off_id" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select emp_id1, date_from, date_to, date_to_prnt, designation_id, office_id,
decode(office_dept_id,'TWAD','',office_dept_id) as office_dept_id1, employee_name,
DATE_OF_BIRTH, designation, employee_status_id, employee_status_desc, other_dept_office_name from
(
select employee_id as emp_id1, date_from, date_to, to_char(date_to) as date_to_prnt, designation_id, office_id,
employee_status_id, office_dept_id, process_flow_status_id from hrm_emp_service_data
where employee_status_id in ('DPN','STU','ABR') and process_flow_status_id='FR'
union
select employee_id as emp_id1, date_effective_from as date_from, now() as date_to, '' as date_to_prnt, designation_id, office_id,
employee_status_id, department_id as office_dept_id, process_flow_status_id
from hrm_emp_current_posting
where employee_status_id in ('DPN','STU','ABR') and process_flow_status_id='FR'
) a
left outer join
(
select employee_id as emp_id2,EMPLOYEE_NAME||decode(EMPLOYEE_INITIAL,null,' ','.'||EMPLOYEE_INITIAL) AS employee_name,
DATE_OF_BIRTH from HRM_MST_EMPLOYEES
) b
on a.emp_id1=b.emp_id2
left outer join
(
select designation_id as desig_id, designation from hrm_mst_designations 
) c
on a.designation_id=c.desig_id
left outer join
(
select other_dept_id , other_dept_office_id, other_dept_office_name from hrm_mst_other_dept_offices
) d
on a.office_dept_id=d.other_dept_id and a.office_id=d.other_dept_office_id
left outer join
(
select employee_status_id as emp_stat_id, employee_status_desc from HRM_MST_EMPLOYEE_STATUS
) e
on a.employee_status_id=e.emp_stat_id
where ($P{fromdate} between a.date_from and a.date_to)
or    ($P{todate} between a.date_from  and  a.date_to)
order by d.other_dept_office_name,a.date_from desc]]></queryString>

