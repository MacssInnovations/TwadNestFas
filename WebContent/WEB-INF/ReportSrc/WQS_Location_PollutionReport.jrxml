	<parameter name="fromdt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="district" isForPrompting="true" class="java.lang.String"/>
	<parameter name="block" isForPrompting="true" class="java.lang.String"/>
	<parameter name="panchayat" isForPrompting="true" class="java.lang.String"/>
	<parameter name="habitation" isForPrompting="true" class="java.lang.String"/>
	<parameter name="location" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select aa.districtname,a.location,a.element_symbol,a.element_value,a.element_date,b.blockname,c.panchayatname,d.name from
(
  select district_code,block_code,panchayat_code,habitation_code,location,element_symbol,element_value,element_date from wqs_pollution
)a 
inner join
(
  select district_code,districtname from com_mst_districts
)aa on a.district_code=aa.district_code
inner join
(
  select district_code,blockcode,blockname from com_mst_blocks
)b on a.district_code=b.district_code and a.block_code=b.blockcode 
inner join
(
  select district_code,block_code,panch_code,panchayatname from com_mst_panchayats
)c on a.district_code=c.district_code and a.block_code=c.block_code and a.panchayat_code=c.panch_code 
inner join
(
  select district_code,block_code,panch_code,hab_code,name from com_mst_habitations
)d on a.district_code=d.district_code and a.block_code=d.block_code and a.panchayat_code=d.panch_code and a.habitation_code=d.hab_code where a.district_code=$P{district} and a.block_code=$P{block} and a.panchayat_code=$P{panchayat} and a.habitation_code=$P{habitation} and a.location=$P{location} order by a.element_symbol,a.element_date]]></queryString>

