	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select employee_id as emp_id1 ,controlling_office_id as cont_office_id ,controlling_department_id from
HRM_EMP_CONTROLLING_OFFICE
where controlling_office_id in ($P!{offids})and employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
) a
left outer join
(
select employee_id as emp_id2, office_id as off_id1, department_id as depart_id,
designation_id, employee_status_id
from hrm_emp_current_posting
) b
on a.emp_id1=b.emp_id2
left outer join
(
select 'TWAD' as dept_id, office_id, office_name from com_mst_offices
where office_status_id not in ('CL','RD','NC')
union
select other_dept_id as dept_id, other_dept_office_id as office_id, other_dept_office_name as office_name
from hrm_mst_other_dept_offices
) c
on b.off_id1=c.office_id and b.depart_id=c.dept_id
left outer join
(
select office_id as off_id2, office_name as cont_office_name, office_level_id, off_order from  COM_MST_ALL_OFFICES_VIEW
) d
on  a.cont_office_id=d.off_id2
left outer join
(
select EMPLOYEE_ID as emp_id3, EMPLOYEE_NAME||'.'||EMPLOYEE_INITIAL EMPLOYEE_NAME from hrm_mst_employees
) e
on a.emp_id1=e.emp_id3
left outer join
(
select designation_id as desig_id, designation from hrm_mst_designations
) f
on b.designation_id=f.desig_id
left outer join
(
select employee_status_id as emp_status_id, employee_status_desc from hrm_mst_employee_status
) g
on b.employee_status_id=g.emp_status_id
order by d.off_order, e.employee_name]]></queryString>

