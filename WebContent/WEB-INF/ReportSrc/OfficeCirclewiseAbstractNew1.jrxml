	<queryString><![CDATA[select region_office_id,circle_office_id,office_level_id,region_office_name,circle_office_name,
office_level_name,HIERARCHICAL_SEQUENCE, noofoffices from
(
select region_office_id,circle_office_id,office_level_id,count(office_id) as noofoffices from
com_mst_all_offices_view where office_level_id!='HO'
group by region_office_id,circle_office_id,office_level_id
)a
left outer join
(
select region_office_id as regofficeid,region_office_name  from com_mst_regions_hview
)b
on a.region_office_id=b.regofficeid
left outer join 
(
select office_level_id as offlevelid,office_level_name,HIERARCHICAL_SEQUENCE from com_mst_office_levels
)c
on a.office_level_id=c.offlevelid
left outer join
(
select region_office_id as regofficeid1,circle_office_id as circleid,circle_office_name  from com_mst_circles_hview
)d
on a.region_office_id=d.regofficeid1 and a.circle_office_id= d.circleid

order by region_office_id,HIERARCHICAL_SEQUENCE]]></queryString>

