	<parameter name="status_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="Status_desc" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.designation_id,b.designation,a.total_no from
(
select designation_id,count(*) as total_no from hrm_emp_current_posting
where employee_status_id in ($P!{status_id}) and employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
group by designation_id
) a
left outer join
(
select designation_id as desig_id,designation,ordering_sequence_no from hrm_mst_designations
) b
on a.designation_id=b.desig_id
order by designation_id]]></queryString>

	<field name="DESIGNATION_ID" class="java.math.BigDecimal"/>
	<field name="DESIGNATION" class="java.lang.String"/>
	<field name="TOTAL_NO" class="java.math.BigDecimal"/>

	<variable name="grand_total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
