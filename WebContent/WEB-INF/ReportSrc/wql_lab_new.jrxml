	<queryString><![CDATA[select LAB_DESC,CHE_SPECIFICATION,PURCHASE_ORDER_NO,PURCHASE_ORDER_DATE,QTY_ORDERED,QTY_RECEIVED_SOFAR,
SUPPLIER_NAME from
(
select * from WQS_CHEMICAL_PUR_ORDER
) a
inner join
(
select LAB_CODE,LAB_DESC from WQS_MST_LAB
) b
on a.LAB_CODE=b.LAB_CODE
left outer join
(
select CHEMICAL_CODE,CHE_SPECIFICATION from WQS_MST_INV_CHEMICAL
) c
on a.CHEMICAL_CODE=c.CHEMICAL_CODE
left outer join
(
select SUPPLIER_CODE,SUPPLIER_NAME from WQS_MST_SUPPLIER
) d
on a.SUPPLIER_CODE=d.SUPPLIER_CODE]]></queryString>

