		 columnWidth="381"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="CASHBOOK_MONTH_FROM" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="CASHBOOK_YEAR_FROM" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="CASHBOOK_MONTH_TO" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="CASHBOOK_YEAR_TO" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select case when total1 is null then 0
else total1 end as total1_before,
case when total1_next is null then 0
else total1_next end as total1_after,
fin.*

from

(SELECT aa.ORDER_NO,
  aa.minor_head_code,
 (SELECT MINOR_HEAD_DESC FROM COM_MST_MINOR_HEADS min1 WHERE min1.MINOR_HEAD_CODE=aa.MINOR_HEAD_CODE)as MINOR_HEAD_DESC,
  aa.major_head_code,
  (SELECT MAJOR_HEAD_DESC
  FROM com_mst_major_heads maj
  WHERE MAJ.MAJOR_HEAD_CODE= aa.major_head_code
  )as MAJOR_HEAD_DESC,
  aa.GROUP_HEAD_CODE,
 (select GROUP_HEAD_DESC from FAS_MIS_GROUP_MASTER gp where gp.group_head_code= aa.GROUP_HEAD_CODE)as GROUP_HEAD_DESC,

  sum((SELECT SUM(trial.DEBIT_CLOSING_BALANCE+trial.CREDIT_CLOSING_BALANCE)
  FROM FAS_TRIAL_BALANCE trial
  WHERE trial.ACCOUNT_HEAD_CODE=hc.ACCOUNT_HEAD_CODE
  AND 
  To_Date((trial.cashbook_month
  ||'-'
  || trial.cashbook_year),'mm-yyyy') BETWEEN To_Date($P{CASHBOOK_MONTH_FROM}
  ||'-'
  ||($P{CASHBOOK_YEAR_FROM}-1),'mm-yyyy')
AND to_date($P{CASHBOOK_MONTH_TO}
  ||'-'
  ||($P{CASHBOOK_YEAR_TO}-1),'mm-yyyy') 
  ))AS total1,
 sum((SELECT SUM(trial.DEBIT_CLOSING_BALANCE+trial.CREDIT_CLOSING_BALANCE)
  FROM FAS_TRIAL_BALANCE trial
  WHERE trial.ACCOUNT_HEAD_CODE=hc.ACCOUNT_HEAD_CODE
  AND 
  To_Date((trial.cashbook_month
  ||'-'
  || trial.cashbook_year),'mm-yyyy') BETWEEN To_Date($P{CASHBOOK_MONTH_FROM}
  ||'-'
  ||$P{CASHBOOK_YEAR_FROM},'mm-yyyy')
AND to_date($P{CASHBOOK_MONTH_TO}
  ||'-'
  ||$P{CASHBOOK_YEAR_TO},'mm-yyyy') 
  GROUP BY trial.ACCOUNT_HEAD_CODE
  ))AS total1_next
FROM ANNUAL_ACCOUNT_SUB_GROUP aa,
  com_mst_account_heads hc
WHERE aa.MINOR_HEAD_CODE= hc.MINOR_HEAD_CODE
AND aa.MAJOR_HEAD_CODE  = hc.MAJOR_HEAD_CODE
AND hc.MAJOR_HEAD_CODE ='L'
GROUP BY aa.ORDER_NO,
  aa.minor_head_code,
  aa.major_head_code,
  aa.GROUP_HEAD_CODE
ORDER BY aa.major_head_code, aa.minor_head_code,aa.GROUP_HEAD_CODE,
  aa.ORDER_NO)fin]]></queryString>

	<field name="TOTAL1_BEFORE" class="java.math.BigDecimal"/>
	<field name="TOTAL1_AFTER" class="java.math.BigDecimal"/>
	<field name="ORDER_NO" class="java.lang.String"/>
	<field name="MINOR_HEAD_CODE" class="java.math.BigDecimal"/>
