	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="off_id" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select emp_id1, date_from, date_to, designation_id,   employee_name, 
designation, employee_status_id, EMPLOYEE_STATUS_DESC from
(
select employee_id as emp_id1, date_from, date_to, designation_id, office_id,
employee_status_id, process_flow_status_id from hrm_emp_service_data
where employee_status_id='CMW' and process_flow_status_id='FR' 
union
select employee_id as emp_id1, date_effective_from as date_from, now() as date_to, designation_id, office_id,
employee_status_id, process_flow_status_id
from hrm_emp_current_posting
where employee_status_id='CMW' and process_flow_status_id='FR'
) a
left outer join
(
select employee_id as emp_id2,EMPLOYEE_NAME||decode(EMPLOYEE_INITIAL,null,' ','.'||EMPLOYEE_INITIAL) AS employee_name,
DATE_OF_BIRTH from HRM_MST_EMPLOYEES
) b
on a.emp_id1=b.emp_id2
left outer join
(
select designation_id as desig_id, designation from hrm_mst_designations 
) c
on a.designation_id=c.desig_id
left outer join
(
select EMPLOYEE_STATUS_ID as emp_status_id, EMPLOYEE_STATUS_DESC from HRM_MST_EMPLOYEE_STATUS
) d
on a.employee_status_id=d.emp_status_id
where ($P{fromdate} between a.date_from and a.date_to)
or    ($P{todate} between a.date_from  and  a.date_to) 
order by a.date_from desc]]></queryString>

