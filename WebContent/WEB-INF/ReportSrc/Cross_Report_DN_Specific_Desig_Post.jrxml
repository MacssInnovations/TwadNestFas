	<parameter name="txtofficeid" isForPrompting="true" class="java.lang.String"/>
	<parameter name="finyear" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select division_office_id,office_name,post_rank_id,post_rank_name,post_rank_short_name,total_posts from 
(
select division_office_id,post_rank_id,office_name,
sum(decode(sanctioned_no_of_posts,null,0,sanctioned_no_of_posts)) as total_posts from 
(
select division_office_id, division_office_id as office_id,division_office_name as 
office_name from com_mst_divisions_hview
union
select division_office_id, subdivision_office_id as office_id,subdivision_office_name as 
office_name from com_mst_subdivisions_hview
) a
inner join 
(
select office_id as office_id1,post_rank_id,sanctioned_no_of_posts from 
hrm_ss_sanction_details where fin_year=($P{finyear})
) b
on a.office_id=b.office_id1
where division_office_id  in ($P!{txtofficeid})
group by division_office_id,post_rank_id,office_name order by division_Office_id,post_rank_id,office_name
) x
left outer join 
(
select post_rank_id as rank_id,post_rank_name,post_rank_short_name from hrm_mst_post_ranks
) y
on x.post_rank_id=y.rank_id]]></queryString>

