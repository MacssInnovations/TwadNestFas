	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select  upper(b.REGION_OFFICE_NAME) as REGION_OFFICE_NAME,upper(d.OFFICE_NAME) AS circle_name,
upper(e.OFFICE_NAME) AS division_name,c.OFFICE_NAME ,a.REGION_OFFICE_ID,a.CIRCLE_OFFICE_ID,
a.DIVISION_OFFICE_ID,
decode(c.OFFICE_ADDRESS1,null,' ',c.OFFICE_ADDRESS1  ) OFFICE_ADDRESS1 ,
decode(c.OFFICE_ADDRESS2,null,' ',c.OFFICE_ADDRESS2  ) OFFICE_ADDRESS2 ,
decode(c.CITY_TOWN_NAME,null,' ', c.CITY_TOWN_NAME ) CITY_TOWN_NAME ,
decode(c.OFFICE_PIN_CODE,null,' ',c.OFFICE_PIN_CODE  ) OFFICE_PIN_CODE ,
decode(c.OFFICE_EMAIL_ID,null,' ',c.OFFICE_EMAIL_ID  ) OFFICE_EMAIL_ID ,
decode(c.OFFICE_STD_CODE,null,' ', c.OFFICE_STD_CODE ) OFFICE_STD_CODE ,
decode(c.OFFICE_PHONE_NO,null,' ', c.OFFICE_PHONE_NO  ) OFFICE_PHONE_NO ,
decode(c.OFFICE_FAX_NO,null,' ', c.OFFICE_FAX_NO ) OFFICE_FAX_NO 
from COM_MST_SUBDIVISIONS_HVIEW a
inner join COM_MST_REGIONS_HVIEW b on a.REGION_OFFICE_ID=b.REGION_OFFICE_ID 
inner join COM_MST_OFFICES c on  c.OFFICE_ID=a.SUBDIVISION_OFFICE_ID 
inner join COM_MST_OFFICES d on d.OFFICE_ID=a.CIRCLE_OFFICE_ID
inner join COM_MST_OFFICES e on e.OFFICE_ID=a.DIVISION_OFFICE_ID

order by REGION_OFFICE_NAME,d.OFFICE_NAME,e.OFFICE_NAME]]></queryString>

