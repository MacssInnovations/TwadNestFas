	<queryString><![CDATA[select a.DESIGNATION_ID,a.DESIGNATION,b.CADRE_NAME,POST_RANK_NAME,d.SERVICE_GROUP_NAME from HRM_MST_DESIGNATIONS a
left outer join   hrm_mst_cadre b on b.cadre_id=a.cadre_id
left outer join hrm_mst_post_ranks c on c.POST_RANK_ID=a.POST_RANK_ID
left outer join hrm_mst_service_group d on d.SERVICE_GROUP_ID=a.SERVICE_GROUP_ID

order by SERVICE_GROUP_ID,a.ordering_sequence_no]]></queryString>

	<field name="DESIGNATION_ID" class="java.math.BigDecimal"/>
	<field name="DESIGNATION" class="java.lang.String"/>
	<field name="CADRE_NAME" class="java.lang.String"/>
