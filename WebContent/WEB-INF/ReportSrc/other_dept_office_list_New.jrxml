	<parameter name="dep_id" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select other_dept_id,other_dept_name from hrm_mst_other_depts
) a
left outer join
(
select OTHER_DEPT_ID, OTHER_DEPT_OFFICE_ID, OTHER_DEPT_OFFICE_NAME from
hrm_mst_other_dept_offices
) b
on a.other_dept_id=b.OTHER_DEPT_ID
where a.other_dept_id in ($P!{dep_id})
order by a.other_dept_id]]></queryString>

	<field name="OTHER_DEPT_ID" class="java.lang.String"/>
	<field name="OTHER_DEPT_NAME" class="java.lang.String"/>
