	<parameter name="regions" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select upper(a.REGION_OFFICE_NAME) REGION_OFFICE_NAME,upper(c.DESIGNATION) DESIGNATION,
d.EMPLOYEE_NAME||decode(d.EMPLOYEE_INITIAL,null,' ','.'||d.EMPLOYEE_INITIAL) EMPLOYEE_NAME,d.employee_id,
decode( b.DATE_EFFECTIVE_FROM,null,' ', to_char(b.DATE_EFFECTIVE_FROM,'dd/mm/yyyy')  ) DATE_OF_JOINING,
decode(d.REMARKS,null,' ',d.REMARKS) REMARKS

from COM_MST_REGIONS_HVIEW a

inner join HRM_EMP_CURRENT_POSTING b on b.OFFICE_ID = a.REGION_OFFICE_ID
inner join HRM_MST_DESIGNATIONS c on c.DESIGNATION_ID = b.DESIGNATION_ID
inner join HRM_MST_EMPLOYEES d on d.EMPLOYEE_ID = b.EMPLOYEE_ID

where a.REGION_OFFICE_ID in ($P!{regions})
order by a.REGION_OFFICE_id,c.ORDERING_SEQUENCE_NO,EMPLOYEE_id]]></queryString>

