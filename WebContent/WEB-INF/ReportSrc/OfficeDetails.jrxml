from COM_MST_OFFICES a




inner join COM_MST_OFFICE_LEVELS g on g.OFFICE_LEVEL_ID= a.OFFICE_LEVEL_ID and g.OFFICE_LEVEL_ID in upper(($P{officelevelid}))]]></queryString>

