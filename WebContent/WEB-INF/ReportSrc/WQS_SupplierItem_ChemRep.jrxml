	<queryString><![CDATA[select * from(select SUPPLIER_CODE,MAJOR_CATEGORY_CODE,ITEM_CODE from WQS_MST_INV_SUP_ITEM)a inner join(select SUPPLIER_CODE,SUPPLIER_NAME from WQS_MST_INV_SUPPLIER)b on a.SUPPLIER_CODE=b.SUPPLIER_CODE left outer join(select MAJOR_CATEGORY_CODE,MAJOR_CATEGORY_DESC from WQS_MST_INV_CATEGORY)c on a.MAJOR_CATEGORY_CODE=c.MAJOR_CATEGORY_CODE left outer join(select CHEMICAL_CODE,CHE_SPECIFICATION from WQS_MST_INV_CHEMICAL)d on a.ITEM_CODE=d.CHEMICAL_CODE  where a.SUPPLIER_CODE=$P{scode} and(c.MAJOR_CATEGORY_DESC='chemical' or c.MAJOR_CATEGORY_DESC='Chemical' or c.MAJOR_CATEGORY_DESC='CHEMICAL')]]></queryString>

