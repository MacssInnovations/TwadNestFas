<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Employee_Service_Data_Pending"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="status" isForPrompting="true" class="java.lang.String"/>
	<parameter name="Status_desc" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.employee_id,a.employee_name,b.employee_id,decode(b.cnt,null,0,b.cnt) as cnt,d.designation,e.office_name,c.DATE_EFFECTIVE_FROM from
(
select employee_id,employee_name from hrm_mst_employees where employee_id in
(
select employee_id from HRM_EMP_CURRENT_POSTING where EMPLOYEE_STATUS_ID in($P!{status}) )
)a
left outer join
(
select employee_id,count(employee_id) as cnt from hrm_emp_service_data   group by employee_id 
)b
on b.employee_id=a.employee_id 
left outer join 
(
select employee_id as emp_id ,designation_id,office_id,DATE_EFFECTIVE_FROM from hrm_emp_current_posting where EMPLOYEE_STATUS_ID in($P!{status})
)c
on a.employee_id=c.emp_id
left outer join
(
select DESIGNATION,designation_id as des_id from HRM_MST_DESIGNATIONS
)d
on d.des_id=c.designation_id
left outer join
(
select office_id as off_id,office_name from com_mst_offices
)e
on c.office_id=e.off_id
where b.cnt is null]]></queryString>

	<field name="EMPLOYEE_ID" class="java.math.BigDecimal"/>
	<field name="EMPLOYEE_NAME" class="java.lang.String"/>
	<field name="CNT" class="java.math.BigDecimal"/>
	<field name="DESIGNATION" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="DATE_EFFECTIVE_FROM" class="java.sql.Timestamp"/>

