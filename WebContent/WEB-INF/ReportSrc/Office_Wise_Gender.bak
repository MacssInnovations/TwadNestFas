<jasperReport
		 name="Office Wise Gender"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="officeid" isForPrompting="false" class="java.lang.String"/>
	<parameter name="name1" isForPrompting="false" class="java.lang.String"/>
	<parameter name="status" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select nvl(ss.offl, ''), nvl(ss.Male_count,0), nvl(ss1.Female_count,0) from 
(
select d.OFFICE_LEVEL_NAME offl ,count(*) Male_count from 
(
(
SELECT employee_id,gender FROM hrm_mst_employees   WHERE gender='M'
)a left outer join
(
SELECT employee_id, office_id FROM hrm_emp_current_posting  where employee_status_id in('WKG')
)b on a.employee_id=b.employee_id 
left outer join( 
select office_level_id, office_id from com_mst_offices where office_id in(select office_id FROM hrm_emp_current_posting where employee_status_id in('WKG') and OFFICE_LEVEL_ID not in('SD','LB','AW'))
)c on c.office_id=b.office_id 
left outer join
(
select office_level_id,OFFICE_LEVEL_NAME from COM_MST_OFFICE_LEVELS
)d on c.office_level_id=d.office_level_id
)
where  c.office_level_id is not null 
group by d.OFFICE_LEVEL_NAME
)
ss 
left outer join
(
select d.OFFICE_LEVEL_NAME offl ,count(*) Female_count from 
(
(
SELECT employee_id,gender FROM hrm_mst_employees   WHERE gender='F'
)a left outer join
(
SELECT employee_id, office_id FROM hrm_emp_current_posting  where employee_status_id in('WKG','TRT')
)b on a.employee_id=b.employee_id 
left outer join( 
select office_level_id, office_id from com_mst_offices where office_id in(select office_id FROM hrm_emp_current_posting where employee_status_id in('WKG','TRT') and OFFICE_LEVEL_ID not in('SD','LB','AW'))
)c on c.office_id=b.office_id 
left outer join
(
select office_level_id,OFFICE_LEVEL_NAME from COM_MST_OFFICE_LEVELS
)d on c.office_level_id=d.office_level_id
)
where  c.office_level_id is not null 
group by d.OFFICE_LEVEL_NAME
)ss1 on ss1.offl=ss.offl]]></queryString>

	<field name="NVL(SS.OFFL,'')" class="java.lang.String"/>
	<field name="NVL(SS.MALE_COUNT,0)" class="java.math.BigDecimal"/>
	<field name="NVL(SS1.FEMALE_COUNT,0)" class="java.math.BigDecimal"/>

	<variable name="offtotal" class="java.lang.Integer" resetType="Report" calculation="Nothing">
	</variable>
	<variable name="final_total" class="java.lang.Integer" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[new java.lang.Integer(  ($F{NVL(SS.MALE_COUNT,0)}.intValue()) +($F{NVL(SS1.FEMALE_COUNT,0)}.intValue()) )]]></variableExpression>
	</variable>
