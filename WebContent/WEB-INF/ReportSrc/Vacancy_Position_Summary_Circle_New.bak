	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="pos_id" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select * from
(
select region_office_id, circle_office_id, office_id , office_level_id , office_name, off_order, 
       post_rank_id,sanctioned_no_of_posts, diversion_to_other, diversion_from_other,
       decode(filled,NULL,0,filled) as filled,
       (decode(sanctioned_no_of_posts,null,0,sanctioned_no_of_posts)+decode(diversion_from_other,null,0,diversion_from_other)-decode(diversion_to_other,null,0,diversion_to_other)) as total,
       ((decode(sanctioned_no_of_posts,null,0,sanctioned_no_of_posts)+decode(diversion_from_other,null,0,diversion_from_other)-decode(diversion_to_other,null,0,diversion_to_other))-decode(filled,null,0,filled)) as vacant
       from 
(
select  region_office_id, circle_office_id, office_id, office_level_id, office_name, off_order, 
       post_rank_id,sanctioned_no_of_posts, diversion_to_other, diversion_from_other
from 
(
select office_id as offid, post_rank_id, sanctioned_no_of_posts,
diversion_to_other, diversion_from_other
from HRM_SS_SANCTION_DETAILS
where  fin_year='2006-2007'
) a
inner join
( 
select * from com_mst_all_offices_view
) b
on a.offid=b.office_id
) aa
left outer join
(
select office_id as offid,post_rank_id as postid ,count(*) as filled from
(
select office_id,post_rank_id,employee_id from
(
select office_id, designation_id,employee_id
from hrm_emp_current_posting
where department_id='TWAD'
) a1
left outer join
(
select designation_id as desig_id,post_rank_id from hrm_mst_designations
) b1
on a1.designation_id=b1.desig_id
)
group by office_id,post_rank_id
order by office_id,post_rank_id
) bb
on aa.office_id = bb.offid and aa.post_rank_id = bb.postid
where office_id in ($P!{off_id}) and post_rank_id=$P{pos_id}
order by off_order
) x
left outer join
(
select post_rank_id,post_rank_name from hrm_mst_post_ranks
) y
on x.post_rank_id=y.post_rank_id]]></queryString>

