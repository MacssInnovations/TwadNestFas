	<parameter name="WORK" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA[$F{WORK_NATURE_ID}]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select * from (
select upper(b.REGION_OFFICE_NAME) as REGION_OFFICE_NAME  ,a.REGION_OFFICE_ID,
upper(c.OFFICE_NAME) as CIRCLE_OFFICE_NAME,c.OFFICE_ID,upper(d.OFFICE_NAME) AS DIVISION_OFFICE_NAME,e.WORK_NATURE_ID,e.WORK_NATURE_DESC,
count(a.SUBDIVISION_OFFICE_ID) as count,a.DIVISION_OFFICE_ID

from COM_MST_SUBDIVISIONS_HVIEW a
inner join COM_MST_REGIONS_HVIEW b on a.REGION_OFFICE_ID=b.REGION_OFFICE_ID 
inner join COM_MST_OFFICES c on c.OFFICE_ID=a.CIRCLE_OFFICE_ID 

inner join COM_MST_OFFICES d on d.OFFICE_ID=a.DIVISION_OFFICE_ID
inner join COM_MST_WORK_NATURE e on e.WORK_NATURE_ID=d.PRIMARY_WORK_ID 
inner join COM_MST_OFFICES f on f.OFFICE_ID=a.SUBDIVISION_OFFICE_ID
where e.Work_Nature_Id=$P{WORK}
group by REGION_OFFICE_NAME,a.REGION_OFFICE_ID,c.OFFICE_NAME,c.OFFICE_ID,d.OFFICE_NAME,a.DIVISION_OFFICE_ID,e.WORK_NATURE_ID,e.WORK_NATURE_DESC

) x

left outer join(

select SUBDIVISION_OFFICE_NAME,SUBDIVISION_OFFICE_ID,DIVISION_OFFICE_ID div_id from COM_MST_SUBDIVISIONS_HVIEW
) y on y.div_id =x.DIVISION_OFFICE_ID



order by REGION_OFFICE_ID,OFFICE_ID,DIVISION_OFFICE_ID,SUBDIVISION_OFFICE_ID,WORK_NATURE_ID]]></queryString>

