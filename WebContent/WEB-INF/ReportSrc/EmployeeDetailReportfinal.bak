	<parameter name="level" isForPrompting="true" class="java.lang.String"/>
	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select upper(d.OFFICE_NAME) as OFFICE_NAME,upper(c.DESIGNATION)as DESIGNATION,
A.EMPLOYEE_ID,a.EMPLOYEE_NAME||decode(a.EMPLOYEE_INITIAL,null,' ','.'||a.EMPLOYEE_INITIAL) EMPLOYEE_NAME,
decode( b.DATE_EFFECTIVE_FROM,null,' ', to_char(b.DATE_EFFECTIVE_FROM,'dd/mm/yyyy')  ) DATE_OF_JOINING,
decode(a.REMARKS,null,' ',a.REMARKS) REMARKS,d.office_level_id,d.office_id,c.ORDERING_SEQUENCE_NO,
d.off_order

from HRM_MST_EMPLOYEES a, HRM_EMP_CURRENT_POSTING b ,HRM_MST_DESIGNATIONS c ,COM_MST_ALL_OFFICES_VIEW d  
where a.EMPLOYEE_ID = b.EMPLOYEE_ID and  c.DESIGNATION_ID = b.DESIGNATION_ID and d.OFFICE_ID = b.OFFICE_ID
and d.OFFICE_ID in ($P!{offids}) and a.employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
order by  ORDERING_SEQUENCE_NO,off_order]]></queryString>

