	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="des_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="finyear" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select  newoffid,post_Rank_id,fin_year,sanctionedposts,filledposts,
divertoother,diverfromother,total,remainingposts,office_name,post_Rank_name,off_order,ordering_seq_no from
(
select to_char(office_id) as newoffid,post_Rank_id,fin_year,sanctionedposts,filledposts,
divertoother,diverfromother,total,remainingposts,office_name,post_Rank_name from 
(
select office_id,post_Rank_id,fin_year,sanctionedposts,filledposts,
divertoother,diverfromother,total,remainingposts,office_name,post_Rank_name from hrm_sanction_ho_view1 
where office_id in ($P!{off_id}) and post_Rank_id in($P!{des_id}) and fin_year in($P{finyear})
)
union
select to_char(region_office_id) as newoffid,post_Rank_id,fin_year,sanctionedposts,filledposts,
divertoother,diverfromother,total,remainingposts,office_name,post_Rank_name from 
(
select region_office_id,post_Rank_id,fin_year,sanctionedposts,filledposts,
divertoother,diverfromother,total,remainingposts,office_name,post_Rank_name from hrm_sanction_region_view1 
where region_office_id in ($P!{off_id}) and post_Rank_id in($P!{des_id}) and fin_year in($P{finyear})
)
union
select to_char(circle_office_id) as newoffid,post_Rank_id,fin_year,sanctionedposts,filledposts,
divertoother,diverfromother,total,remainingposts,office_name,post_Rank_name from 
(
select circle_office_id,post_Rank_id,fin_year,sanctionedposts,filledposts,
divertoother,diverfromother,total,remainingposts,office_name,post_Rank_name from hrm_sanction_circle_view1 
where circle_office_id in ($P!{off_id}) and post_Rank_id in($P!{des_id}) and fin_year in($P{finyear})
)
union
select to_char(division_office_id) as newoffid,post_Rank_id,fin_year,sanctionedposts,filledposts,
divertoother,diverfromother,total,remainingposts,office_name,post_Rank_name from
(
select division_office_id,post_Rank_id,fin_year,sanctionedposts,filledposts,
divertoother,diverfromother,total,remainingposts,office_name,post_Rank_name from hrm_sanction_division_view1 
where division_office_id in ($P!{off_id}) and post_Rank_id in($P!{des_id}) and fin_year in($P{finyear})
)
)a
left outer join
(
select office_id, off_order from com_mst_all_offices_view
)b
on a.newoffid=b.office_id
left outer join 
(
select post_rank_id as postrankid,ordering_seq_no from  hrm_mst_post_ranks
)c
on a.post_rank_id=c.postrankid
order by ordering_seq_no,off_order]]></queryString>

