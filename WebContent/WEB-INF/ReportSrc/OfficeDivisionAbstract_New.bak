	<queryString><![CDATA[select * from (
select upper(b.REGION_OFFICE_NAME) as REGION_OFFICE_NAME ,b.REGION_OFFICE_ID,upper(c.OFFICE_NAME) as OFFICE_NAME,
count(a.DIVISION_OFFICE_ID) as count,a.CIRCLE_OFFICE_ID 
from COM_MST_DIVISIONS_HVIEW a,COM_MST_REGIONS_HVIEW b,COM_MST_OFFICES c
where a.REGION_OFFICE_ID=b.REGION_OFFICE_ID and c.OFFICE_ID=a.CIRCLE_OFFICE_ID 

group by REGION_OFFICE_NAME,b.REGION_OFFICE_ID,OFFICE_NAME,a.CIRCLE_OFFICE_ID 
) x
left outer join(
select DIVISION_OFFICE_NAME,DIVISION_OFFICE_ID,CIRCLE_OFFICE_ID CIR_ID from COM_MST_DIVISIONS_HVIEW
)y on y.cir_id=x.circle_office_id

order by REGION_OFFICE_ID,CIRCLE_OFFICE_ID,DIVISION_OFFICE_ID]]></queryString>

