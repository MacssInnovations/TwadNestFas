	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select employee_id, employee_name, date_of_joining, join_office_id, join_office_name, join_desig_id, joining_desig_name,
last_office_id, last_office_name, last_desig_id, last_desig_name from
(
select EMPLOYEE_ID, SUBDIVISION_OFFICE_ID as join_office_id, DATE_OF_JOINING,
upper(to_char(DATE_OF_JOINING,'month'))as mnt, designation_id as join_desig_id from
HRM_EMP_JOIN_REPORTS
) a
left outer join
(
select employee_id as emp_id1, office_id as last_office_id, designation_id as last_desig_id
from hrm_emp_service_data a
where a.service_list_slno = ( select max(b.service_list_slno) from hrm_emp_service_data b
where a.employee_id= b.employee_id and process_flow_status_id='FR' and
employee_status_id='WKG')
) b
on a.employee_id=b.emp_id1
left outer join
(
select employee_id as emp_id2, EMPLOYEE_NAME||decode(EMPLOYEE_INITIAL,null,' ','.'||EMPLOYEE_INITIAL) AS employee_name
from hrm_mst_employees
) c
on a.employee_id=c.emp_id2
left outer join
(
select office_id as off_id, office_name as join_office_name,off_order from com_mst_all_offices_view
) d
on a.join_office_id=d.off_id
left outer join
(
select office_id as off_id1, office_name as last_office_name from com_mst_all_offices_view
) e
on b.last_office_id=e.off_id1
left outer join
(
select designation_id as desig_id, designation as joining_desig_name from hrm_mst_designations
) f
on a.join_desig_id=f.desig_id
left outer join
(
select designation_id as desig_id1, designation as last_desig_name from hrm_mst_designations
) g
on b.last_desig_id=g.desig_id1
where  d.OFF_ID in ($P!{offids}) and
a.DATE_OF_JOINING between $P{fromdate} and $P{todate}
order by OFF_ORDER, EMPLOYEE_ID]]></queryString>

