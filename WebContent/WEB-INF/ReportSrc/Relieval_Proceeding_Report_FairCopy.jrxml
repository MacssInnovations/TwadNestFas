	<parameter name="relslno" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="offid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="subject" isForPrompting="true" class="java.lang.String"/>
	<parameter name="refer" isForPrompting="true" class="java.lang.String"/>
	<parameter name="paraone" isForPrompting="true" class="java.lang.String"/>
	<parameter name="paratwo" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select office_id,relieval_Slno, employee_id, date_of_relieval,Relieval_FN_AN,Relieval_Reason_id, 
Proceeding_no,Proceeding_Date,Presiding_officer,Copy_To,employee_name,office_name,designation,relieval_reason_desc from 
(
select office_id,relieval_Slno, employee_id, date_of_relieval,Relieval_FN_AN,Relieval_Reason_id, 
Proceeding_no,Proceeding_Date,Presiding_officer,Copy_To from hrm_emp_relieval_details 
)a
left outer join 
(
select employee_id as empid,employee_name from  hrm_mst_employees
)b
on a.employee_id=b.empid
left outer join
(
select office_id as offid,office_name from com_mst_offices
)c
on a.office_id=c.offid
left outer join 
(
select employee_id as empid,designation_id from hrm_emp_current_posting 
)d
on a.employee_id=d.empid
left outer join
(
select designation_id as desigid,designation from hrm_mst_designations
)e
on d.designation_id=e.desigid
left outer join 
(
select relieval_reason_id as relslno,relieval_reason_desc from hrm_mst_relieval_reasons 
)f
on a.Relieval_Reason_id=f.relslno
where relieval_slno=$P{relslno} and office_id=$P{offid}]]></queryString>

