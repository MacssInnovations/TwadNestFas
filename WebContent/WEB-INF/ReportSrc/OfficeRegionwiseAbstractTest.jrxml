	<field name="OFFICE_LEVEL_ID" class="java.lang.String"/>
	<field name="COUNT" class="java.math.BigDecimal"/>
	<field name="OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="OFF_NAME" class="java.lang.String"/>

	<variable name="SUM_COUNT_1" class="java.math.BigDecimal" resetType="Group" resetGroup="Region" calculation="Sum">
		<variableExpression><![CDATA[$F{COUNT}]]></variableExpression>
	</variable>
	<variable name="SUM_COUNT_2" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{COUNT}]]></variableExpression>
	</variable>
	<variable name="test" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[(java.lang.Integer)1]]></variableExpression>
	</variable>

