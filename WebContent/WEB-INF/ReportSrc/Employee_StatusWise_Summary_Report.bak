	<parameter name="status_id" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select designation_id,designation,total from
(
select designation_id,count(designation_id) as total from hrm_emp_current_posting
where employee_status_id not in ('SAN','DIS','DTH','RES','VRS') and employee_status_id in ($P!{status_id})
group by designation_id
) a
left outer join
(
select designation_id as desig_id,designation from hrm_mst_designations
) b
on a.designation_id=b.desig_id
order by a.designation_id]]></queryString>

	<field name="DESIGNATION_ID" class="java.lang.Integer"/>
	<field name="DESIGNATION" class="java.lang.String"/>
	<field name="TOTAL" class="java.lang.Integer"/>

	<variable name="SUM" class="java.lang.Integer" resetType="Report" calculation="Sum">
