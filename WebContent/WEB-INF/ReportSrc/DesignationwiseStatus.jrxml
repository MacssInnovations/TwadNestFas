	<parameter name="workstat" isForPrompting="true" class="java.lang.String"/>
	<parameter name="url" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select a.DESIGNATION_ID, b.designation,a.total from ( 
select DESIGNATION_ID,count(DESIGNATION_ID) as total from HRM_EMP_CURRENT_POSTING 
where EMPLOYEE_STATUS_ID in($P{workstat})  group by DESIGNATION_ID ) a left outer join( 
select DESIGNATION_ID, designation from hrm_mst_designations) b on a.DESIGNATION_ID=b.DESIGNATION_ID]]></queryString>

	<field name="DESIGNATION_ID" class="java.math.BigDecimal"/>
	<field name="DESIGNATION" class="java.lang.String"/>
	<field name="TOTAL" class="java.math.BigDecimal"/>

