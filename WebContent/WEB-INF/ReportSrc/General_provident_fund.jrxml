	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="gpfno" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from 
(
select * from
(
select  c.gpfno_1,c.EMP_NAME,c.DESIG,c.DOB,c.open_bal,c.deposit,c.interest,c.withdraw,c.closing_bal,c.total,c.cum_cb,d.sl_DIVN_CD,d.sl_ACCT_MMYY,d.sl_SUB_AMT,d.sl_SUB_AR_AMT as arrear,
case when d.sl_AR_INS_NO is null and d.sl_AR_INS_TOT is null then ''
     else d.sl_AR_INS_NO||'/'||d.sl_AR_INS_TOT end  as Inst_no,d.sl_REF_AMT as refund,
case when d.sl_REF_INS_NO is null and d.sl_REF_INS_TO is null then ''
else
 d.sl_REF_INS_NO||'/'||d.sl_REF_INS_TO end as ref_inst_no,d.sl_REL_MMYY,d.sl_ADV_AMT,d.sl_ADV_TYP,d.sl_CON_AMT,d.sl_NO_INST,d.sl_INST_AMT,d.sl_AMOUNT,d.sl_WITHDRAW,d.sl_SPLIND
 from
(
select a.gpfno_1,a.EMP_NAME,a.DESIG,a.DOB,b.OB as open_bal,b.TOT_DEP,b.TOT_WITH as withdraw ,b.JINT,b.TOT_RECOV,b.CUM_CB as closing_bal,b.TOT_INT,b.deposit,b.interest,b.total,b.cum_cb  from 
(
select GPFNO as gpfno_1,EMP_NAME,DESIG,to_char(DOB,'dd/mm/yy') as dob from emp_cat where gpfno =$P{gpfno}
)a
left outer join
(
select GPFNO,OB,TOT_DEP,TOT_WITH,JINT,TOT_RECOV,TOT_INT,(TOT_DEP+TOT_RECOV) as deposit,(JINT+TOT_INT) as interest, 
(ob+TOT_DEP+TOT_RECOV+JINT+TOT_INT) as total,(ob+TOT_DEP+TOT_RECOV+JINT+TOT_INT)-(TOT_WITH)as cum_cb from reg_bal
)b
on a.gpfno_1=b.gpfno
)c
left outer join
(
select DIVN_CD as sl_DIVN_CD,ACCT_MMYY as sl_ACCT_MMYY,GPFNO as sl_GPFNO,SUB_AMT as sl_SUB_AMT,SUB_AR_AMT as sl_SUB_AR_AMT,AR_INS_NO as sl_AR_INS_NO,AR_INS_TOT as sl_AR_INS_TOT,REF_AMT as sl_REF_AMT,REF_INS_NO as sl_REF_INS_NO,REF_INS_TO as sl_REF_INS_TO,REL_MMYY as sl_REL_MMYY, ADV_AMT as sl_ADV_AMT,ADV_TYP as sl_ADV_TYP,CON_AMT as sl_CON_AMT,NO_INST as sl_NO_INST,INST_AMT as sl_INST_AMT,AMOUNT as sl_AMOUNT,WITHDRAW as sl_WITHDRAW,SPLIND as sl_SPLIND from slippr
)d
on c.gpfno_1=d.sl_gpfno 
)g
left outer join
(
select GPFNO,OB as imp_open_bal,TOT_DEP,TOT_WITH,JINT,TOT_RECOV,(ob+JINT+TOT_INT) as clos_ob_imp,TOT_INT,(TOT_DEP+TOT_RECOV) as imp_deposit,(JINT+TOT_INT) as imp_interest, 
(ob+JINT+TOT_INT) as imp_total from imp_bal
)h
on g.gpfno_1=h.gpfno
)i
left outer join
(
select GPFNO,OB as imp_open_bal_2003,TOT_DEP,TOT_WITH,JINT,TOT_RECOV,(ob+JINT+TOT_INT) as clos_ob_imp_2003,TOT_INT,(TOT_DEP+TOT_RECOV) as imp_deposit_2003,(JINT+TOT_INT) as imp_interest_2003, 
(ob+JINT+TOT_INT) as imp_total_2003 from imp_bal2003
)j
on i.gpfno_1=j.gpfno]]></queryString>

