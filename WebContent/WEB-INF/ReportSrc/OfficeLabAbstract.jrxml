		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select * from
(
select * from
(
select * from
(
select e.lab_OFFICE_ID as lab_id1,e.region_office_id,upper(f.office_name) as region_office_name,e.lab_office_name as lab_name 
from COM_MST_labS_HVIEW e,com_mst_offices f
where e.region_office_id=f.office_id

)p
left outer join
(
select c.lab_OFFICE_ID as lab_id,c.circle_office_id as office_id,upper(d.office_name) as circle_office_name,c.circle_office_id 
from COM_MST_labs_HVIEW c,com_mst_offices d
where c.circle_office_id=d.office_id
)q
on q.lab_ID=p.lab_id1
)r
left outer join
(
select x.lab_office_name,x.lab_OFFICE_ID,y.DIVISION_OFFICE_name,y.division_office_id 
from COM_MST_labs_HVIEW x,com_mst_divisions_hview y
where y.division_office_id=x.division_office_id
)s
on r.lab_ID1=s.lab_office_id
)u
left outer join
(
select a.circle_office_id as cir_id,
count(a.lab_OFFICE_id) as count
from COM_MST_labS_HVIEW a
group by a.region_office_id,a.circle_office_id
)v
on u.circle_OFFICE_ID=v.cir_id
order by REGION_OFFICE_ID,OFFICE_ID,DIVISION_OFFICE_ID,lab_OFFICE_ID]]></queryString>

