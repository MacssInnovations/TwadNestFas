		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.Long"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select * from
(
select EMPLOYEE_ID,OFFICE_ID,RELIEVAL_SLNO,DATE_OF_RELIEVAL,TO_CHAR(DATE_OF_RELIEVAL,'Month') as Relieval_month,RELIEVAL_REASON_ID,remarks,LEAVE_TYPE_CODE from HRM_EMP_RELIEVAL_DETAILS
) a
left outer join
(
select leave_type_code,leave_type_desc from HRM_MST_LEAVE_TYPES
) b
on b.leave_type_code=a.leave_type_code
left outer join
(
select EMPLOYEE_ID,CONTROLLING_OFFICE_ID,CONTROLLING_DEPARTMENT_ID from HRM_EMP_CONTROLLING_OFFICE
) c
on c.employee_id=a.employee_id
left outer join
(
select employee_id,DESIGNATION_ID,department_id,date_effective_from from HRM_EMP_CURRENT_POSTING
) d
on d.employee_id=a.employee_id 
left outer join
(
select DESIGNATION_ID,designation,service_group_id from HRM_MST_DESIGNATIONS
) e
on e.DESIGNATION_ID=d.DESIGNATION_ID
left outer join
( select employee_id,(EMPLOYEE_NAME||'.'||employee_initial)as employee_name,date_of_birth from HRM_MST_EMPLOYEES
) f
on f.employee_id=a.employee_id

left outer join
(
select office_id,office_name,office_level_id,OFF_ORDER from COM_MST_ALL_OFFICES_VIEW
) g
on g.office_id=c.controlling_office_id
left outer join
(
select office_level_id,office_level_name from COM_MST_OFFICE_LEVELS
) h
on h.office_level_id=g.office_level_id
left outer join
(
select employee_id,office_id,period_from,leave_type_id,RELIEVAL_SLNO from HRM_EMP_RELIEVAL_LLV
)  i
on i.RELIEVAL_SLNO=a.RELIEVAL_SLNO
left outer join
(
select RELIEVAL_REASON_ID,RELIEVAL_REASON_DESC from HRM_MST_RELIEVAL_REASONS
) j
on j.RELIEVAL_REASON_ID=a.RELIEVAL_REASON_ID
inner join 
(
select service_group_id,service_group_name from HRM_MST_SERVICE_GROUP 
) k 
on k.service_group_id=e.service_group_id 
where a.RELIEVAL_REASON_ID in('LLV','SUS') 
and a.OFFICE_ID in ($P!{offids}) 
and  a.DATE_OF_RELIEVAL between $P{fromdate} and $P{todate} 
order by g.OFF_ORDER,g.office_name
]]></queryString>

