	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<parameter name="joinmonth" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="joinyear" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select a.EMPLOYEE_ID,c.EMPLOYEE_NAME||decode(c.EMPLOYEE_INITIAL,null,' ','.'||c.EMPLOYEE_INITIAL) AS employee_name,d.DESIGNATION,a.DATE_OF_JOINING,
b.OFFICE_NAME,upper(to_char(a.DATE_OF_JOINING,'month'))as mnt
from HRM_EMP_JOIN_REPORTS a
inner join COM_MST_OFFICES b on b.OFFICE_ID=a.OFFICE_ID
inner join HRM_MST_EMPLOYEES c on c.EMPLOYEE_ID=a.EMPLOYEE_ID
left outer join HRM_MST_DESIGNATIONS d on d.DESIGNATION_ID=a.DESIGNATION_ID
where
a.PROCESS_FLOW_STATUS_ID='FR' and
 b.OFFICE_ID in ($P!{offids}) 
and extract(month from a.DATE_OF_JOINING)=$P{joinmonth}
and extract(year from a.DATE_OF_JOINING)=$P{joinyear}
order by OFFICE_NAME,EMPLOYEE_ID]]></queryString>

