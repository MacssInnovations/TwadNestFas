<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="OfficeCirclewiseDetailsSpe"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="officelevelid" isForPrompting="true" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[$P{officelevelid}]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select  upper(b.REGION_OFFICE_NAME) as REGION_OFFICE_NAME,a.CIRCLE_OFFICE_NAME,
decode(c.OFFICE_ADDRESS1,null,' ',c.OFFICE_ADDRESS1) OFFICE_ADDRESS1,
decode(c.OFFICE_ADDRESS2,null,' ',c.OFFICE_ADDRESS2) OFFICE_ADDRESS2,
decode(c.CITY_TOWN_NAME,null,' ',c.CITY_TOWN_NAME) CITY_TOWN_NAME,
decode(c.OFFICE_PIN_CODE,null,' ',c.OFFICE_PIN_CODE) OFFICE_PIN_CODE,
decode(c.OFFICE_EMAIL_ID,null,' ',c.OFFICE_EMAIL_ID) OFFICE_EMAIL_ID,
decode(c.OFFICE_STD_CODE,null,' ',c.OFFICE_STD_CODE) OFFICE_STD_CODE,
decode(c.OFFICE_PHONE_NO,null,' ',c.OFFICE_PHONE_NO) OFFICE_PHONE_NO,
decode(c.OFFICE_FAX_NO,null,' ',c.OFFICE_FAX_NO) OFFICE_FAX_NO
from COM_MST_CIRCLES_HVIEW a,COM_MST_REGIONS_HVIEW b,COM_MST_OFFICES c
where a.REGION_OFFICE_ID=b.REGION_OFFICE_ID and c.OFFICE_ID=a.CIRCLE_OFFICE_ID and a.CIRCLE_OFFICE_ID=$P{officelevelid}
order by REGION_OFFICE_NAME,CIRCLE_OFFICE_NAME]]></queryString>

	<field name="REGION_OFFICE_NAME" class="java.lang.String"/>
	<field name="CIRCLE_OFFICE_NAME" class="java.lang.String"/>
	<field name="OFFICE_ADDRESS1" class="java.lang.String"/>
	<field name="OFFICE_ADDRESS2" class="java.lang.String"/>
	<field name="CITY_TOWN_NAME" class="java.lang.String"/>
	<field name="OFFICE_PIN_CODE" class="java.lang.String"/>
	<field name="OFFICE_EMAIL_ID" class="java.lang.String"/>
	<field name="OFFICE_STD_CODE" class="java.lang.String"/>
	<field name="OFFICE_PHONE_NO" class="java.lang.String"/>
	<field name="OFFICE_FAX_NO" class="java.lang.String"/>


		<group  name="region" >
			<groupExpression><![CDATA[$F{REGION_OFFICE_NAME}]]></groupExpression>
			<groupHeader>
			<band height="21"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
