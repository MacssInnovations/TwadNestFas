				<textFieldExpression   class="java.lang.String"><![CDATA[$F{CIRCLE_OFFICE_NAME}+"\n"+$F{OFFICE_ADDRESS1}+"\n"+$F{OFFICE_ADDRESS2}+"\n"+$F{CITY_TOWN_NAME}+"\nPincode:"+$F{OFFICE_PIN_CODE}]]></textFieldExpression>
