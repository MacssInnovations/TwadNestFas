	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select  office_id1,
decode((srcont_available),null,0,(srcont_available)) sravail ,
decode((srcont_validated),null,0,(srcont_validated)) srvalid,
decode((curpost_validated),null,0,(curpost_validated)) curpostvalid,
decode((addl_validated),null,0,(addl_validated)) addl_valid,
decode((sr_data_valid),null,0,(sr_data_valid)) sr_data_valid 
from hrm_emp_validation_view 
)a
left join 
(
select office_id, office_name from com_mst_offices 
)b
on a.office_id1=b.office_id]]></queryString>

