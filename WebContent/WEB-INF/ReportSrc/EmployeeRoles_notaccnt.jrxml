	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select a.EMPLOYEE_ID,a.EMPLOYEE_NAME
from  hrm_mst_employees a where employee_id not in (select b.employee_id from sec_mst_users b where b.employee_id is not null)
)aa
join
(
select employee_id,office_id,DESIGNATION_ID from  HRM_EMP_CURRENT_POSTING
) e
 on e.EMPLOYEE_ID = aa.EMPLOYEE_ID
 join 
 (select designation_id,DESIGNATION from HRM_MST_DESIGNATIONS
 ) f
 on f.DESIGNATION_ID=e.DESIGNATION_ID
 join
 (select office_id,office_name,OFFICE_LEVEL_ID from  COM_MST_OFFICES 
 ) g on g.OFFICE_ID = e.OFFICE_ID
 join
 (select OFFICE_LEVEL_ID,office_level_name,HIERARCHICAL_SEQUENCE from COM_MST_OFFICE_LEVELS  
 ) h on h.OFFICE_LEVEL_ID = g.OFFICE_LEVEL_ID
where g.OFFICE_ID in ($P!{offids})

order by h.HIERARCHICAL_SEQUENCE,g.OFFICE_NAME,e.DESIGNATION_ID,aa.EMPLOYEE_NAME]]></queryString>

	<field name="EMPLOYEE_ID" class="java.math.BigDecimal"/>
	<field name="EMPLOYEE_NAME" class="java.lang.String"/>
	<field name="OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="DESIGNATION_ID" class="java.math.BigDecimal"/>
	<field name="DESIGNATION" class="java.lang.String"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="OFFICE_LEVEL_ID" class="java.lang.String"/>
	<field name="OFFICE_LEVEL_NAME" class="java.lang.String"/>
	<field name="HIERARCHICAL_SEQUENCE" class="java.math.BigDecimal"/>


