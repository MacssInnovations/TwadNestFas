	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yea" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select * from 
( select employee_id,other_dept_id,office_id,other_dept_office_id,DEPUTATION_PERIOD,DEPUTATION_DATE,DEPUTATION_COMPLETION_DATE from HRM_EMP_RELIEVAL_DPN
) a
inner join 
(
select office_id,office_name from com_mst_offices 
) b 
on a.office_id = b.office_id

inner join
(
select employee_id,EMPLOYEE_NAME||decode(EMPLOYEE_INITIAL,null,' ','.'||EMPLOYEE_INITIAL) AS employee_name,
DATE_OF_BIRTH from HRM_MST_EMPLOYEES 
)c
on c.EMPLOYEE_ID=a.EMPLOYEE_ID
inner join
(
select employee_id,DESIGNATION_ID from HRM_EMP_CURRENT_POSTING
) d
on d.employee_id=a.employee_id
inner join
(select designation_id,designation,service_group_id from HRM_MST_DESIGNATIONS) e
on e.designation_id=d.designation_id 

inner join
( select other_dept_id,other_dept_office_id,OTHER_DEPT_OFFICE_NAME	
 from HRM_MST_OTHER_DEPT_OFFICES ) f 
 on f.OTHER_DEPT_ID = a.other_dept_id and f.OTHER_DEPT_OFFICE_ID=a.other_dept_office_id


inner join
(
select service_group_id,service_group_name from HRM_MST_SERVICE_GROUP
) g 
on g.service_group_id=e.service_group_id 

where extract(month from a.DEPUTATION_DATE)=$P{mon}
and extract(year from a.DEPUTATION_DATE)=$P{yea}
order by g.service_group_name,b.office_name,e.designation]]></queryString>

