	<queryString><![CDATA[select a.REDEPLOYED_OFFICE_ID,a.REDEPLOYMENT_DATE,a.NEW_OFFICE_NAME,a.NEW_OFFICE_ID,b.office_name,
decode(b.office_address1,null,' ',b.office_address1)office_address1,decode(b.office_address2,null,' ',b.office_address2)office_address2,decode(b.city_town_name,null,' ',b.city_town_name)city_town_name,decode(b.office_pin_code,0,'',b.office_pin_code)office_pin_code,decode(c.district_name,null,' ',c.district_name)district_name,d.office_level_name from com_office_redeployments a,com_mst_offices b,com_mst_districts c,com_mst_office_levels d where a.redeployed_office_id=b.office_id and c.district_code=b.district_code and d.office_level_id=b.office_level_id and a.process_flow_status_id in 'FR' and a.redeployment_date between $P{txtfrom} and $P{txtto}]]></queryString>

