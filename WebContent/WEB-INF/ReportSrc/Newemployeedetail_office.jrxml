	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select upper(d.OFFICE_NAME) as OFFICE_NAME,upper(c.DESIGNATION)as DESIGNATION,a.EMPLOYEE_ID,
a.EMPLOYEE_NAME||decode(a.EMPLOYEE_INITIAL,null,' ','.'||a.EMPLOYEE_INITIAL) EMPLOYEE_NAME,
to_char(decode( b.DATE_EFFECTIVE_FROM,null,' ', to_char(b.DATE_EFFECTIVE_FROM,'dd/mm/yyyy')  )) DATE_OF_JOINING ,
decode(a.REMARKS,null,' ',a.REMARKS) REMARKS,d.off_order

from HRM_MST_EMPLOYEES a, HRM_EMP_CURRENT_POSTING b ,HRM_MST_DESIGNATIONS c ,COM_MST_ALL_OFFICES_VIEW d ,COM_MST_OFFICE_LEVELS e 
where a.EMPLOYEE_ID = b.EMPLOYEE_ID and  c.DESIGNATION_ID = b.DESIGNATION_ID and d.OFFICE_ID = b.OFFICE_ID and e.OFFICE_LEVEL_ID = d.OFFICE_LEVEL_ID
and b.department_id = 'TWAD' and
b.OFFICE_ID in ($P!{offids})

order by  d.off_order,c.ORDERING_SEQUENCE_NO,EMPLOYEE_NAME]]></queryString>

	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="DESIGNATION" class="java.lang.String"/>
	<field name="EMPLOYEE_ID" class="java.lang.Integer"/>
	<field name="EMPLOYEE_NAME" class="java.lang.String"/>
	<field name="DATE_OF_JOINING" class="java.lang.String"/>
	<field name="REMARKS" class="java.lang.String"/>
	<field name="OFF_ORDER" class="java.lang.String"/>


