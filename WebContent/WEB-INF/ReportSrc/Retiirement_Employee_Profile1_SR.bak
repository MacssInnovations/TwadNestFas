	<parameter name="emp_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA[$P{SUBREPORT_DIR}]]></defaultValueExpression>
	</parameter>
	<parameter name="ppath" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select a.EMPLOYEE_ID,decode(a.EMPLOYEE_INITIAL,null,' ',a.EMPLOYEE_INITIAL||'.')||a.EMPLOYEE_NAME EMPLOYEE_NAME,a.GPF_NO,a.DATE_OF_BIRTH,a.GENDER,
a.REMARKS,a.MARITAL_STATUS,b.COMMUNITY_NAME,c.District_Name,d.Taluk_Name,e.EMPLOYMENT_STATUS
from HRM_MST_EMPLOYEES a
left outer join HRM_MST_COMMUNITY b on to_number(b.COMMUNITY_CODE)=to_number(a.COMMUNITY_ID) 
left outer join COM_MST_DISTRICTS c on c.District_Code=a.NATIVE_DISTRICT_CODE 
left outer join COM_MST_TALUKS d on d.Taluk_Code=a.NATIVE_TALUK_CODE  and d.DISTRICT_CODE=a.NATIVE_DISTRICT_CODE 
left outer join HRM_MST_EMPLOYMENT_STATUS e on e.EMPLOYMENT_STATUS_ID=a.EMPLOYMENT_STATUS_ID 
left outer join hrm_emp_addl_details f on f.EMPLOYEE_ID=a.EMPLOYEE_ID 
where a.EMPLOYEE_ID=$P{emp_id}
) x

left outer join
(
select a.employee_id,a.employee_name,
last_day(add_months(date_of_birth,720)) as retiredate,a.date_of_birth,b.designation,
c.office_level_id,c.OFFICE_SHORT_NAME,d.office_level_name from HRM_MST_EMPLOYEES a
inner join HRM_EMP_CURRENT_POSTING e on  a.employee_id=e.employee_id
left outer join HRM_MST_DESIGNATIONS b on e.designation_id=b.designation_id 
left outer join COM_MST_OFFICES c on c.office_id=e.office_id 
left outer join  COM_MST_OFFICE_LEVELS d on c.office_level_id=d.office_level_id

where b.DESIGNATION_SHORT_NAME in ('DUFF','OA','WM','SEPR','MTAST','GARNR','SW','WCE8','WCE36','WCE54','WCE59','LA','LASCA','WMCGD','MAZDR','WCE10','CLEII') 
and to_number(extract(day from a.date_of_birth))!=1 

UNION 

select a.employee_id,a.employee_name,
last_day(add_months(date_of_birth,696)) as retiredate,a.date_of_birth,b.designation,
c.office_level_id,c.OFFICE_SHORT_NAME,d.office_level_name from HRM_MST_EMPLOYEES a
inner join HRM_EMP_CURRENT_POSTING e on  a.employee_id=e.employee_id
left outer join HRM_MST_DESIGNATIONS b on e.designation_id=b.designation_id 
left outer join COM_MST_OFFICES c on c.office_id=e.office_id 
left outer join  COM_MST_OFFICE_LEVELS d on c.office_level_id=d.office_level_id

where b.DESIGNATION_SHORT_NAME not in ('DUFF','OA','WM','SEPR','MTAST','GARNR','SW','WCE8','WCE36','WCE54','WCE59','LA','LASCA','WMCGD','MAZDR','WCE10','CLEII') 
and to_number(extract(day from a.date_of_birth))!=1

UNION 

select a.employee_id,a.employee_name,
last_day(add_months(date_of_birth,719)) as retiredate,a.date_of_birth,b.designation,
c.office_level_id,c.OFFICE_SHORT_NAME,d.office_level_name from HRM_MST_EMPLOYEES a
inner join HRM_EMP_CURRENT_POSTING e on  a.employee_id=e.employee_id
left outer join HRM_MST_DESIGNATIONS b on e.designation_id=b.designation_id 
left outer join COM_MST_OFFICES c on c.office_id=e.office_id 
left outer join  COM_MST_OFFICE_LEVELS d on c.office_level_id=d.office_level_id

where b.DESIGNATION_SHORT_NAME  in ('DUFF','OA','WM','SEPR','MTAST','GARNR','SW','WCE8','WCE36','WCE54','WCE59','LA','LASCA','WMCGD','MAZDR','WCE10','CLEII') 
and to_number(extract(day from a.date_of_birth))=1

UNION

select a.employee_id,a.employee_name,
last_day(add_months(date_of_birth,695)) as retiredate,a.date_of_birth,b.designation,
c.office_level_id,c.OFFICE_SHORT_NAME,d.office_level_name from HRM_MST_EMPLOYEES a
inner join HRM_EMP_CURRENT_POSTING e on  a.employee_id=e.employee_id
left outer join HRM_MST_DESIGNATIONS b on e.designation_id=b.designation_id 
left outer join COM_MST_OFFICES c on c.office_id=e.office_id 
left outer join  COM_MST_OFFICE_LEVELS d on c.office_level_id=d.office_level_id

where b.DESIGNATION_SHORT_NAME not  in ('DUFF','OA','WM','SEPR','MTAST','GARNR','SW','WCE8','WCE36','WCE54','WCE59','LA','LASCA','WMCGD','MAZDR','WCE10','CLEII') 
and to_number(extract(day from a.date_of_birth))=1

) y on y.employee_id=$P{emp_id}

left outer join
(
select a.EMPLOYEE_ID,a.DATE_EFFECTIVE_FROM,a.OFFICE_GRADE,a.DEPARTMENT_ID,a.OFFICE_ID,b.OFFICE_SHORT_NAME,c.DESIGNATION current_designation,
d.EMPLOYEE_STATUS_DESC,e.OTHER_DEPT_OFFICE_NAME ,f.OTHER_DEPT_NAME
from HRM_EMP_CURRENT_POSTING a 
left outer join COM_MST_OFFICES b on b.OFFICE_ID=a.OFFICE_ID 
left outer join HRM_MST_DESIGNATIONS c on c.DESIGNATION_ID=a.DESIGNATION_ID 
left outer join HRM_MST_EMPLOYEE_STATUS d on d.EMPLOYEE_STATUS_ID = a.EMPLOYEE_STATUS_ID 
left outer join HRM_MST_OTHER_DEPT_OFFICES e on e.OTHER_DEPT_OFFICE_ID = a.OFFICE_ID 
and e.OTHER_DEPT_ID=a.DEPARTMENT_ID
left outer join HRM_MST_OTHER_DEPTS f on f.OTHER_DEPT_ID = a.DEPARTMENT_ID
) z  on z.EMPLOYEE_ID=$P{emp_id}

left outer join 
(
select b.EMPLOYEE_ID, b.DATE_FROM ,c.DESIGNATION joining_designation
from HRM_EMP_SERVICE_DATA b
left outer join HRM_MST_DESIGNATIONS c on c.DESIGNATION_ID=b.DESIGNATION_ID 
where  b.DATE_FROM = (select min(a.DATE_FROM) from HRM_EMP_SERVICE_DATA a  where a.EMPLOYEE_ID=$P{emp_id})
) p on  p.EMPLOYEE_ID=$P{emp_id}

left outer join
(
select  a.EMPLOYEE_ID,a.CONTROLLING_OFFICE_ID cntrl_office_id,b.OFFICE_NAME ctrl_office_name
from HRM_EMP_CONTROLLING_OFFICE a,COM_MST_OFFICES b where b.OFFICE_ID=a.CONTROLLING_OFFICE_ID 
and a.EMPLOYEE_ID=$P{emp_id}
) q on q.employee_id=$P{emp_id}]]></queryString>

