	<queryString><![CDATA[select upper(g.OFFICE_NAME) as OFFICE_NAME,f.DESIGNATION,b.EMPLOYEE_ID,b.EMPLOYEE_NAME||decode(b.EMPLOYEE_INITIAL,null,' ','.'||b.EMPLOYEE_INITIAL) EMPLOYEE_NAME,
d.ROLE_NAME,a.user_id,decode(a.LOGIN_ENABLED,1,'Active',0,'Deactive') as LOGIN_ENABLED


from SEC_MST_USERS a
inner join  HRM_MST_EMPLOYEES b on b.EMPLOYEE_ID=a.EMPLOYEE_ID
inner join SEC_MST_USER_ROLES c on c.EMPLOYEE_ID=a.EMPLOYEE_ID
inner join SEC_MST_ROLES d on d.ROLE_ID = c.ROLE_ID
inner join HRM_EMP_CURRENT_POSTING e on e.EMPLOYEE_ID = a.EMPLOYEE_ID
inner join HRM_MST_DESIGNATIONS f on f.DESIGNATION_ID=e.DESIGNATION_ID
inner join COM_MST_OFFICES g on g.OFFICE_ID = e.OFFICE_ID
inner join COM_MST_OFFICE_LEVELS h on h.OFFICE_LEVEL_ID = g.OFFICE_LEVEL_ID

order by h.HIERARCHICAL_SEQUENCE,OFFICE_NAME,EMPLOYEE_NAME,ROLE_NAME]]></queryString>

