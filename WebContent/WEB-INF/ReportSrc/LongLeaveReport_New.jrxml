	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yea" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="txtofficeid" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select EMPLOYEE_ID,OFFICE_ID,RELIEVAL_SLNO,DATE_OF_RELIEVAL,TO_CHAR(DATE_OF_RELIEVAL,'Month') as Relieval_month,RELIEVAL_REASON_ID,LEAVE_TYPE_CODE from HRM_EMP_RELIEVAL_DETAILS
) a
left outer join
(
select leave_type_code,leave_type_desc from HRM_MST_LEAVE_TYPES
) b
on b.leave_type_code=a.leave_type_code
left outer join
(
select EMPLOYEE_ID,CONTROLLING_OFFICE_ID,CONTROLLING_DEPARTMENT_ID from HRM_EMP_CONTROLLING_OFFICE
) c
on c.employee_id=a.employee_id
left outer join
(
select employee_id,DESIGNATION_ID,department_id from HRM_EMP_CURRENT_POSTING
) d
on d.employee_id=a.employee_id 
left outer join
(
select DESIGNATION_ID,designation from HRM_MST_DESIGNATIONS
) e
on e.DESIGNATION_ID=d.DESIGNATION_ID
left outer join
( select employee_id,(EMPLOYEE_NAME||'.'||employee_initial)as employee_name from HRM_MST_EMPLOYEES
) f
on f.employee_id=a.employee_id

left outer join
(
select office_id,office_name,office_level_id from COM_MST_OFFICES
) g
on g.office_id=c.controlling_office_id
left outer join
(
select office_level_id,office_level_name from COM_MST_OFFICE_LEVELS
) h
on h.office_level_id=g.office_level_id
left outer join
(
select employee_id,office_id,period_from,leave_type_id,RELIEVAL_SLNO from HRM_EMP_RELIEVAL_LLV
)  i
on i.RELIEVAL_SLNO=a.RELIEVAL_SLNO
left outer join
(
select RELIEVAL_REASON_ID,RELIEVAL_REASON_DESC from HRM_MST_RELIEVAL_REASONS
) j
on j.RELIEVAL_REASON_ID=a.RELIEVAL_REASON_ID

where a.RELIEVAL_REASON_ID in('UAL','SUS') 
and a.office_id in ($P!{txtofficeid})
and extract(month from a.DATE_OF_RELIEVAL)=$P{mon}
and extract(year from a.DATE_OF_RELIEVAL)=$P{yea}
order by g.office_name]]></queryString>

