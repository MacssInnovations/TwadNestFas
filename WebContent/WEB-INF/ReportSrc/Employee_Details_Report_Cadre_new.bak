	<parameter name="des_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select d.employee_id,d.employee_name,g.cadre_name,f.designation,e.office_name,c.designation_id ,c.date_effective_from from
(
select designation_id, employee_id,office_id,date_effective_from from hrm_emp_current_posting
where office_id in ($P!{off_id}) and 
  designation_id in(select designation_id from hrm_mst_designations
  where cadre_id in ($P!{des_id}))
) c
inner join 
(
select designation_id,cadre_id,designation from hrm_mst_designations
where cadre_id in ($P!{des_id})
)f
on c.designation_id=f.designation_id 
left join
(
select cadre_id,cadre_name from HRM_MST_CADRE 
) g
on g.cadre_id=f.cadre_id
left join
(
select employee_id,employee_name||decode(employee_initial,null,' ','.'||employee_initial) employee_name from hrm_mst_employees
) d
on c.employee_id=d.employee_id
left join
(
select * from EMP_REC_VALID_ALL_OFFICE_NEW where CONTROLLING_OFFICE_ID in ($P!{off_id})
)e
on c.office_id=e.CONTROLLING_OFFICE_ID 
order by g.cadre_name,e.off_order,d.employee_name]]></queryString>

