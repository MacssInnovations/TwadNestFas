	<queryString><![CDATA[select invoice_number,sample_number,parameter,description,date_of_receipt,receipt_time,res,description from
(
select a.lab_code,a.invoice_number,a.sample_number,date_of_receipt,receipt_time,parameter,description,res from
(select lab_code,invoice_number,sample_number,date_of_receipt,receipt_time,parameter,res from
(select lab_code,invoice_number,sample_number,date_of_receipt,receipt_time,parameter,result,cast(result as float)as res from wqs_watersample_result
    where lab_code=5000 and parameter in('ph','color','acidity','talk','turb')and result not in('Nil','None','nil','none') and date_of_receipt between '01/jan/2007' and '01/dec/2008'
) where res in(
		12,23,34,45,56,67,78,89,90,85,58
              )
)a inner join
(select lab_code,invoice_number,customer_type from wqs_invoice_details
)b on a.lab_code=b.lab_code and a.invoice_number=b.invoice_number left outer join
(select sno,element_symbol,description from wqs_element_symbol
)b1 on a.parameter=b1.element_symbol inner join
(select lab_code,invoice_number,sample_number,district_code,location_type,local_body_code,location from wqs_sample_entry
)c on a.lab_code=c.lab_code and a.invoice_number=c.invoice_number and a.sample_number=c.sample_number
where b.customer_type='Twad' and c.district_code='10' and c.location_type='Corporation' and c.local_body_code='1' order by sno
)order by invoice_number,sample_number,date_of_receipt]]></queryString>

