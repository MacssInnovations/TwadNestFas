<jasperReport
		 name="OfficeDivisionDetail"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select * from
(
select * from
(
select  upper(b.REGION_OFFICE_NAME) as REGION_OFFICE_NAME,a.region_office_id,a.division_office_name as office_name,a.division_office_id 
from COM_MST_DIVISIONS_HVIEW a,COM_MST_REGIONS_HVIEW b
where a.region_office_id=b.region_office_id
)x
left outer join
(
select d.division_office_id as div_id,
decode(c.OFFICE_ADDRESS1,null,' ',c.OFFICE_ADDRESS1  ) OFFICE_ADDRESS1 ,
decode(c.OFFICE_ADDRESS2,null,' ',c.OFFICE_ADDRESS2  ) OFFICE_ADDRESS2 ,
decode(c.CITY_TOWN_NAME,null,' ', c.CITY_TOWN_NAME ) CITY_TOWN_NAME ,
decode(c.OFFICE_PIN_CODE,null,' ',c.OFFICE_PIN_CODE  ) OFFICE_PIN_CODE ,
decode(c.OFFICE_EMAIL_ID,null,' ',c.OFFICE_EMAIL_ID  ) OFFICE_EMAIL_ID ,
decode(c.OFFICE_STD_CODE,null,' ', c.OFFICE_STD_CODE ) OFFICE_STD_CODE ,
decode(c.OFFICE_PHONE_NO,null,' ', c.OFFICE_PHONE_NO  ) OFFICE_PHONE_NO ,
decode(c.OFFICE_FAX_NO,null,' ', c.OFFICE_FAX_NO ) OFFICE_FAX_NO 
from COM_MST_DIVISIONS_HVIEW d,com_mst_offices c
where c.OFFICE_ID=d.DIVISION_OFFICE_ID
)y
on x.division_office_id=y.div_id
)z
left outer join
(
select e.division_office_id,upper(f.office_name) as circle_name 
from com_mst_offices f,COM_MST_DIVISIONS_HVIEW e
where e.circle_office_id=f.office_id
)z1
on z.division_office_id=z1.division_office_id
order by REGION_OFFICE_NAME,circle_name]]></queryString>

	<field name="REGION_OFFICE_NAME" class="java.lang.String"/>
	<field name="REGION_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="DIVISION_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="DIV_ID" class="java.math.BigDecimal"/>
	<field name="OFFICE_ADDRESS1" class="java.lang.String"/>
	<field name="OFFICE_ADDRESS2" class="java.lang.String"/>
	<field name="CITY_TOWN_NAME" class="java.lang.String"/>
	<field name="OFFICE_PIN_CODE" class="java.lang.String"/>
	<field name="OFFICE_EMAIL_ID" class="java.lang.String"/>
	<field name="OFFICE_STD_CODE" class="java.lang.String"/>
	<field name="OFFICE_PHONE_NO" class="java.lang.String"/>
	<field name="OFFICE_FAX_NO" class="java.lang.String"/>
	<field name="CIRCLE_NAME" class="java.lang.String"/>


