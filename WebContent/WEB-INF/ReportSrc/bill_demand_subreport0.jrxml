	<parameter name="billsno" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select 
    WC.BILL_SNO,
    WC.BENEFICIARY_SNO,
    WC.METRE_SNO,
    WC.QTY_CONSUMED,
    WC.EXCESS_QTY,
    WC.AMT,
    WC.EXCESS_AMT,
    WC.TOTAL_AMT,
    WC.TARIFF_RATE,
    WC.EXCESS_RATE,
    PR.METRE_INITIAL_READING,
    PR.METRE_CLOSING_READING,
    MT.MULTIPLY_FACTOR,
    MT.MIN_BILL_QTY,
    MT.ALLOTED_QTY,
    MT.METRE_LOCATION,
    CASE WHEN (WC.QTY_CONSUMED * MT.MULTIPLY_FACTOR) > MT.MIN_BILL_QTY 
            THEN (WC.QTY_CONSUMED * MT.MULTIPLY_FACTOR) 
            ELSE  MT.MIN_BILL_QTY END
            AS TOT_CONSUMPT
    
    
from 
(   
(
    select
    PR_SNO,
    BILL_SNO,
    BENEFICIARY_SNO,
    METRE_SNO,
    QTY_CONSUMED,
    EXCESS_QTY,
    AMT,
    EXCESS_AMT,
    TOTAL_AMT,
    TARIFF_RATE,
    EXCESS_RATE
      FROM 
      PMS_DCB_WC_BILLING    
 WHERE BILL_SNO=$P{billsno}
)WC
join 
(
  select
        PR_SNO,
        METRE_SNO,
        METRE_INITIAL_READING,
        METRE_CLOSING_READING
   from 
        PMS_DCB_TRN_MONTHLY_PR        
)PR
on WC.PR_SNO=PR.PR_SNO


JOIN
  (SELECT BENEFICIARY_SNO,
    METRE_SNO,
    MULTIPLY_FACTOR,
    MIN_BILL_QTY,
    ALLOTED_QTY,
    METRE_LOCATION
  FROM PMS_DCB_MST_BENEFICIARY_METRE
  )MT
ON WC.METRE_SNO=MT.METRE_SNO


)]]></queryString>

