	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="des_id" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select a.office_id,b.off_order,b.office_name,c.designation,
a.designation_id,a.cnt from
(
select office_id,designation_id,count(*) as cnt from hrm_emp_current_posting
where office_id in ($P!{off_id}) and designation_id=$P{des_id}
group by office_id,designation_id
) a
left outer join
(
select office_id,region_office_id,off_order,office_name from com_mst_all_offices_view
) b
on a.office_id=b.office_id
left outer join
(
select designation_id,designation from hrm_mst_designations
) c
on a.designation_id=c.designation_id
order by b.off_order]]></queryString>

	<field name="office_id" class="java.lang.Integer"/>
	<field name="off_order" class="java.lang.String"/>
	<field name="office_name" class="java.lang.String"/>
	<field name="designation" class="java.lang.String"/>
	<field name="designation_id" class="java.lang.Integer"/>
	<field name="cnt" class="java.lang.Integer"/>

