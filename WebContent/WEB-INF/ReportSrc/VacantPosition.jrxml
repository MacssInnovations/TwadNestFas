	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select OFFICE_ID,office_name,HIERARCHICAL_SEQUENCE,FIN_YEAR,POST_RANK_ID,POST_RANK_NAME,ORDERING_SEQUENCE_NO,SANCTIONED_NO_OF_POSTS,decode(DIVERSION_TO_OTHER,null,0,DIVERSION_TO_OTHER) DIVERSION_TO_OTHER,decode(DIVERSION_FROM_OTHER,null,0,DIVERSION_FROM_OTHER) DIVERSION_FROM_OTHER,(decode(SANCTIONED_NO_OF_POSTS,null,0,SANCTIONED_NO_OF_POSTS)+decode(DIVERSION_FROM_OTHER,null,0,DIVERSION_FROM_OTHER)-decode(DIVERSION_TO_OTHER,null,0,DIVERSION_TO_OTHER)) as Total,decode(filled_post,null,0,filled_post) filled_post,((decode(SANCTIONED_NO_OF_POSTS,null,0,SANCTIONED_NO_OF_POSTS)+decode(DIVERSION_FROM_OTHER,null,0,DIVERSION_FROM_OTHER)-decode(DIVERSION_TO_OTHER,null,0,DIVERSION_TO_OTHER))-decode(filled_post,null,0,filled_post)) filled_not_post,OFF_ORDER  from 
(
select a.OFFICE_ID,c.office_name,d.HIERARCHICAL_SEQUENCE,a.FIN_YEAR,a.POST_RANK_ID,a.SANCTIONED_NO_OF_POSTS,a.DIVERSION_TO_OTHER,a.DIVERSION_FROM_OTHER,b.POST_RANK_NAME,c.OFF_ORDER from HRM_SS_SANCTION_DETAILS_TMP a,HRM_MST_POST_RANKS b,COM_MST_ALL_OFFICES_VIEW c,com_mst_office_levels d
where   b.POST_RANK_ID=a.POST_RANK_ID and c.office_id=a.office_id and d.office_level_id=c.office_level_id
and c.office_id in ($P!{offids})
) x
left join 
(
select a.office_id office_id1 ,a.designation_id,b.POST_RANK_ID POST_RANK_ID1,count(b.POST_RANK_ID) filled_post,b.ORDERING_SEQUENCE_NO	
from hrm_emp_current_posting a 
inner join HRM_MST_DESIGNATIONS b on b.designation_id=a.designation_id
where a.office_id is not null
group by a.office_id,a.designation_id,b.post_rank_id ,ORDERING_SEQUENCE_NO
) y on  y.office_id1=x.office_id and y.POST_RANK_ID1 =x.POST_RANK_ID
order by OFF_ORDER,ORDERING_SEQUENCE_NO,post_rank_id]]></queryString>

