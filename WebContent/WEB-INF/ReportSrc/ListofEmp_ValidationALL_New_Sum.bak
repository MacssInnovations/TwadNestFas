	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select office_id as controlling_office_id,employee_id,employee_name,office_name,off_order,
   decode(sr_control_available,'YES',1,0) as sr_control_available,
   decode(addl_available,'YES',1,0) as addl_available,
   decode(addl_validated,'YES',1,0) as addl_validated,
   decode(current_posting_validated,'YES',1,0) as current_posting_validated,
   decode(sr_validated,'YES',1,0) as sr_validated,
   decode(photo_validated,'YES',1,0) as photo_validated,
   decode(photo_uploaded,'YES',1,0) as photo_uploaded,

   decode(sr_control_available,'YES','YES','NO') as sr_control_available_disp,
   decode(addl_available,'YES','YES','NO') as addl_available_disp,
   decode(addl_validated,'YES','YES','NO') as addl_validated_disp,
   decode(current_posting_validated,'YES','YES','NO') as current_posting_validated_disp,
   decode(sr_validated,'YES','YES','NO') as sr_validated_disp,
   decode(photo_validated,'YES','YES','NO') as photo_validated_disp,
   decode(photo_uploaded,'YES','YES','NO') as photo_uploaded_disp

from
(
select office_id,employee_id,office_name,
   decode(sr_control_available,null,'NO',sr_control_available) as sr_control_available,
   decode(addl_available,null,'NO',addl_available) as addl_available,
   decode(addl_validated,null,'NO',addl_validated) as addl_validated,
   decode(current_posting_validated,null,'NO',current_posting_validated) as current_posting_validated,
   decode(sr_validated,null,'NO',sr_validated) as sr_validated,
   decode(photo_validated,null,'NO',photo_validated) as photo_validated,
   decode(photo_uploaded,null,'NO',photo_uploaded) as photo_uploaded
 from
(
select office_id, office_name from com_mst_offices 
where office_status_id not in ('CL','RD','NC') and office_level_id not in ('SD')
and office_id in ($P!{offids})
) a1
left outer join
(
select controlling_office_id,employee_id,'YES' as sr_control_available from hrm_emp_controlling_office
where employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
) a
on a1.office_id=a.controlling_office_id
left outer join
(
select employee_id as emp_id1,'YES' as addl_available  from hrm_mst_emp_addl_tmp where employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
) b
on a.employee_id=b.emp_id1
left outer join
(
select employee_id as emp_id2,decode(process_flow_status_id,null,'NO','FR','YES','NO') as addl_validated
from hrm_mst_emp_addl_tmp where employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
) c
on a.employee_id=c.emp_id2
left outer join
(
select employee_id as emp_id3,decode(employee_status_id,'TRT','NO','YES') as current_posting_validated
from hrm_emp_current_posting 
where employee_status_id not in ('SAN', 'VRS') and employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
) d
on a.employee_id=d.emp_id3
left outer join
(
select emp1 as emp_id4,  decode(cnt1-cnt2,null,'NO',0,'YES','NO') as sr_validated from
    (
    select EMPLOYEE_ID  as emp1,  COUNT(*) as cnt1 FROM HRM_EMP_SERVICE_DATA where employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
    group by EMPLOYEE_ID
    ) x1
    left outer join
   (
    select EMPLOYEE_ID as emp2,  COUNT(*) as cnt2 FROM HRM_EMP_SERVICE_DATA where employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
    and process_flow_status_id='FR' 
    group by EMPLOYEE_ID
    ) y1
    on x1.emp1 = y1.emp2
) e
on a.employee_id=e.emp_id4
left outer join
(
select employee_id as emp_id5,decode(process_flow_status_id,'FR','YES','NO') as photo_validated,
decode(process_flow_status_id,NULL,'NO','YES') as photo_uploaded from hrm_emp_addl_photo_new_tmp where employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
) f
on a.employee_id=f.emp_id5
) y
left outer join
(
select employee_id as emp_id6, ( employee_name || ' ' || employee_initial ) as employee_name
from hrm_mst_employees where employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
) z
on y.employee_id = z.emp_id6
left outer join
(
select office_id as off_id, off_order from com_mst_all_offices_view
)z1
on y.office_id = z1.off_id
order by off_order,employee_name]]></queryString>

