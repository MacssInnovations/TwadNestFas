	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="des_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="emp_status" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select a.employee_id,b.employee_name,c.office_name, c.off_order, a.date_effective_from,d.designation
from 
(
select employee_id,office_id,date_effective_from,designation_id from hrm_emp_current_posting
where EMPLOYEE_STATUS_ID in ($P!{emp_status}) and office_id in ($P!{off_id}) and designation_id in ($P!{des_id}) and employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
) a
left outer join
(
select employee_id,employee_name||decode(employee_initial,null,' ','.'||employee_initial) employee_name from hrm_mst_employees

) b
on a.employee_id=b.employee_id
left outer join
(
select office_id,office_name, off_order from com_mst_all_offices_view
) c
on a.office_id=c.office_id
left outer join
(
select designation_id,designation,service_group_id from hrm_mst_designations
) d
on a.designation_id=d.designation_id order by d.designation,c.off_order,b.employee_name]]></queryString>

