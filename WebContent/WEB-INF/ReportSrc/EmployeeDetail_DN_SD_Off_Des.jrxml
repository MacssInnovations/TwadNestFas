	<parameter name="desg_id" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select c.REGION_OFFICE_NAME,b.CIRCLE_OFFICE_NAME,a.DIVISION_OFFICE_NAME,e.DESIGNATION,
f.employee_id,f.EMPLOYEE_NAME||decode(f.EMPLOYEE_INITIAL,null,' ','.'||f.EMPLOYEE_INITIAL) EMPLOYEE_NAME,
decode( d.DATE_EFFECTIVE_FROM,null,' ', to_char(d.DATE_EFFECTIVE_FROM,'dd/mm/yyyy')  ) DATE_OF_JOINING,
decode(f.REMARKS,null,' ',f.REMARKS) REMARKS

from COM_MST_DIVISIONS_HVIEW a

inner join COM_MST_CIRCLES_HVIEW b on b.CIRCLE_OFFICE_ID=a.CIRCLE_OFFICE_ID
inner join COM_MST_REGIONS_HVIEW c on c.REGION_OFFICE_ID=a.REGION_OFFICE_ID
inner join HRM_EMP_CURRENT_POSTING d on d.OFFICE_ID = a.DIVISION_OFFICE_ID
inner join HRM_MST_DESIGNATIONS e on e.DESIGNATION_ID = d.DESIGNATION_ID
inner join HRM_MST_EMPLOYEES f on f.EMPLOYEE_ID = d.EMPLOYEE_ID
where d.DESIGNATION_ID=$P{desg_id}
order by REGION_OFFICE_NAME,CIRCLE_OFFICE_NAME,DIVISION_OFFICE_NAME,DESIGNATION,EMPLOYEE_NAME]]></queryString>

