	<parameter name="fromdt" isForPrompting="true" class="java.lang.String"/>
	<parameter name="todt" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select cadre_id,no_of_retired,cadre_name,cadre_short_name,retyear,retmonth,
yrmon,fin from
(
select cadre_id,retmonth,retyear,count(employee_id) as no_of_retired,
yrmon, retyear || '-'  || yrmon as fin from
(
select employee_id,employee_name,date_of_birth,retiredate,cadre_id,office_name,
to_char(retiredate,'YYYY') as retyear,
to_char(retiredate,'MONTH') as retmonth,
to_char(retiredate,'MM') as yrmon from RETIRE_58YRS_AFTER_FIRST_RC 
union
select employee_id,employee_name,date_of_birth,retiredate,cadre_id,office_name,
to_char(retiredate,'YYYY') as retyear,
to_char(retiredate,'MONTH') as retmonth,
to_char(retiredate,'MM') as yrmon from RETIRE_58YRS_ON_FIRST_RC
union
select employee_id,employee_name,date_of_birth,retiredate,cadre_id,office_name,
to_char(retiredate,'YYYY') as retyear,
to_char(retiredate,'MONTH') as retmonth,
to_char(retiredate,'MM') as yrmon from RETIRE_60YRS_AFTER_FIRST_RC
union
select employee_id,employee_name,date_of_birth,retiredate,cadre_id,office_name,
to_char(retiredate,'YYYY') as retyear,
to_char(retiredate,'MONTH') as retmonth,
to_char(retiredate,'MM') as yrmon from RETIRE_60YRS_ON_FIRST_RC
)
group by cadre_id,retmonth,retyear,yrmon
order by retmonth asc,retyear
)a
left outer join
(
select cadre_id as cadid,cadre_name,cadre_short_name from hrm_mst_cadre
)b
on a.cadre_id=b.cadid
where fin >= ($P{fromdt}) and fin <= ($P{todt})]]></queryString>

