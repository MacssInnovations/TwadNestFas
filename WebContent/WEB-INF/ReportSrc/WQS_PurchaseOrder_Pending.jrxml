	<parameter name="labcode" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fromdt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="labname" isForPrompting="true" class="java.lang.String"/>
	<parameter name="catcode" isForPrompting="true" class="java.lang.String"/>
	<parameter name="catdesc" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.purchase_order_no,a.major_category_code,a.item_code,a.qty_ordered,a.qty_received_sofar,a.qty_avail,a.ordered_uom_code,
(case when a.major_category_code='CHE' then (select che_specification from wqs_mst_inv_chemical where chemical_code=a.item_code)
when a.major_category_code='GLA' then(select glassware_spec from wqs_mst_inv_glassware where glassware_code=a.item_code)
when a.major_category_code='MIS' then(select miscellaneous_spec from wqs_mst_inv_miscellaneous where miscellaneous_code=a.item_code)
else(select inst_category_spec from wqs_mst_inv_instrument where inst_category=a.item_code)end)as item_spec,aa.purchase_order_date,d.uom_desc from
(
  select lab_code,purchase_order_no,major_category_code,item_code,qty_ordered,qty_received_sofar,(qty_ordered-qty_received_sofar) as qty_avail,ordered_uom_code,current_status from wqs_item_pur_order_details
)a
inner join(select lab_code,purchase_order_no,purchase_order_date from wqs_item_pur_order_master)aa on a.lab_code=aa.lab_code and a.purchase_order_no=aa.purchase_order_no
left outer join
(
  select uom_code,uom_desc from wqs_mst_uom
)d on a.ordered_uom_code=d.uom_code
where a.lab_code=$P{labcode} and (aa.purchase_order_date between $P{fromdt} and $P{todt}) and a.major_category_code=$P{catcode} and a.current_status='A'
order by a.major_category_code,a.purchase_order_no,a.item_code]]></queryString>

