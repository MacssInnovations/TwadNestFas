	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="finyear" isForPrompting="true" class="java.lang.String"/>
	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="des_id" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select OFFICE_ID,POST_RANK_ID,SANCTIONED_POSTS,DIVERTOOTHER,DIVERFROMOTHER,FILLED_NO_OF_POSTS,
OFFICE_NAME,total,post_rank_name,off_order,(total-FILLED_NO_OF_POSTS)  as remaining_no_of_posts,
fin_year,ordering_seq_no as rank_order_seq_no
from
(
select OFFICE_ID,POST_RANK_ID,SANCTIONED_POSTS,DIVERTOOTHER,DIVERFROMOTHER,FILLED_NO_OF_POSTS,
OFFICE_NAME,(SANCTIONED_POSTS+DIVERFROMOTHER-DIVERTOOTHER) as total,fin_year 
 from HRM_SANC_DETAILS_DIV_VIEW
where office_id in ($P!{off_id}) and post_Rank_id in($P!{des_id}) and fin_year in($P{finyear})
)a
left outer join
(
select post_rank_id as postrankid,post_rank_name,ordering_seq_no from  hrm_mst_post_ranks
)b
on a.post_rank_id=b.postrankid
left outer join 
(
select office_id as offid,off_order from com_mst_all_offices_view
)c
on a.office_id=c.offid
order by off_order,rank_order_seq_no]]></queryString>

