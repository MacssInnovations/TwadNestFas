	<queryString><![CDATA[select upper(b.REGION_OFFICE_NAME) REGION_OFFICE_NAME,
upper(a.CIRCLE_OFFICE_NAME) CIRCLE_OFFICE_NAME,upper(d.DESIGNATION) DESIGNATION,
e.employee_id,e.EMPLOYEE_NAME||decode(e.EMPLOYEE_INITIAL,null,' ','.'||e.EMPLOYEE_INITIAL) EMPLOYEE_NAME,
decode( c.DATE_EFFECTIVE_FROM,null,' ', to_char(c.DATE_EFFECTIVE_FROM,'dd/mm/yyyy')  ) DATE_OF_JOINING,
decode(e.REMARKS,null,' ',e.REMARKS) REMARKS

from COM_MST_CIRCLES_HVIEW a

inner join COM_MST_REGIONS_HVIEW b on b.REGION_OFFICE_ID=a.REGION_OFFICE_ID
inner join HRM_EMP_CURRENT_POSTING c on c.OFFICE_ID = a.CIRCLE_OFFICE_ID
inner join HRM_MST_DESIGNATIONS d on d.DESIGNATION_ID = c.DESIGNATION_ID
inner join HRM_MST_EMPLOYEES e on e.EMPLOYEE_ID = c.EMPLOYEE_ID


order by REGION_OFFICE_NAME,CIRCLE_OFFICE_NAME,DESIGNATION]]></queryString>

