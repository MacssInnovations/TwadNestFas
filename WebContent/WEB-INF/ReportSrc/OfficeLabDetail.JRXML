<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="OfficeLabDetail"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select * from
(
select * from
(
select * from
(
select e.lab_OFFICE_ID as lab_id1,e.region_office_id,upper(f.office_name) as region_office_name,e.lab_office_name as lab_name 
from COM_MST_labS_HVIEW e,com_mst_offices f
where e.region_office_id=f.office_id

)p
left outer join
(
select c.lab_OFFICE_ID as lab_id,c.circle_office_id as office_id,upper(d.office_name) as circle_office_name,c.circle_office_id 
from COM_MST_labs_HVIEW c,com_mst_offices d
where c.circle_office_id=d.office_id
)q
on q.lab_ID=p.lab_id1
)r
left outer join
(
select x.lab_office_name,x.lab_OFFICE_ID,y.DIVISION_OFFICE_name,y.division_office_id 
from COM_MST_labs_HVIEW x,com_mst_divisions_hview y
where y.division_office_id=x.division_office_id
)s
on r.lab_ID1=s.lab_office_id
)u
left outer join
(
select upper(h.office_name) as office_name ,g.lab_office_id as lab_id2,
decode(h.OFFICE_ADDRESS1,null,' ',h.OFFICE_ADDRESS1  ) OFFICE_ADDRESS1 ,
decode(h.OFFICE_ADDRESS2,null,' ',h.OFFICE_ADDRESS2  ) OFFICE_ADDRESS2 ,
decode(h.CITY_TOWN_NAME,null,' ', h.CITY_TOWN_NAME ) CITY_TOWN_NAME ,
decode(h.OFFICE_PIN_CODE,null,' ',h.OFFICE_PIN_CODE  ) OFFICE_PIN_CODE ,
decode(h.OFFICE_EMAIL_ID,null,' ',h.OFFICE_EMAIL_ID  ) OFFICE_EMAIL_ID ,
decode(h.OFFICE_STD_CODE,null,' ', h.OFFICE_STD_CODE ) OFFICE_STD_CODE ,
decode(h.OFFICE_PHONE_NO,null,' ', h.OFFICE_PHONE_NO  ) OFFICE_PHONE_NO ,
decode(h.OFFICE_FAX_NO,null,' ', h.OFFICE_FAX_NO ) OFFICE_FAX_NO 
from com_mst_offices h,com_mst_labs_hview g
where h.office_id=g.lab_office_id
)n
on u.lab_id1=n.lab_id2
order by REGION_OFFICE_ID,OFFICE_ID,DIVISION_OFFICE_ID,lab_OFFICE_ID]]></queryString>

	<field name="LAB_ID1" class="java.math.BigDecimal"/>
	<field name="REGION_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="REGION_OFFICE_NAME" class="java.lang.String"/>
	<field name="LAB_NAME" class="java.lang.String"/>
	<field name="LAB_ID" class="java.math.BigDecimal"/>
	<field name="OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CIRCLE_OFFICE_NAME" class="java.lang.String"/>
	<field name="CIRCLE_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="LAB_OFFICE_NAME" class="java.lang.String"/>
	<field name="LAB_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="DIVISION_OFFICE_NAME" class="java.lang.String"/>
	<field name="DIVISION_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="LAB_ID2" class="java.math.BigDecimal"/>
	<field name="OFFICE_ADDRESS1" class="java.lang.String"/>
