	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select office_name, designation, employee_name, emp_id,crtl_office_avail, crtl_office_valid, current_posting_avail,
current_posting_valid, add_detail_avail, add_detail_valid, sr_count as sr_validated, photo_validated, crtl_office_avail_total,
crtl_office_valid_total, add_detail_avail_total, add_detail_valid_total, current_posting_avail_total,
current_posting_valid_total, sr_count_total, photo_validated_total from 
(

select EMP_ID,Employee_Name,OFFICE_NAME,
decode( add_detail_avail,null,'NO','YES' ) add_detail_avail,
decode(add_detail_valid ,null,'NO', 'YES' ) add_detail_valid,
decode( crtl_office_avail,null,'NO','YES'  ) crtl_office_avail,
decode(crtl_office_valid ,null,'NO','YES'  ) crtl_office_valid,
decode(current_posting_avail ,null,'NO','YES'  ) current_posting_avail,
decode( current_posting_valid,null,'NO','YES'  ) current_posting_valid,
to_char(decode(cnt,0,'YES','NO')) sr_count, photo_validated,

decode(crtl_office_avail,'YES',1,0) as crtl_office_avail_total,
decode(crtl_office_valid,'YES',1,0) as crtl_office_valid_total,
decode(add_detail_avail,'YES',1,0) as add_detail_avail_total,
decode(add_detail_valid,'YES',1,0) as add_detail_valid_total,
decode(current_posting_avail,'YES',1,0) as current_posting_avail_total,
decode(current_posting_valid,'YES',1,0) as current_posting_valid_total,
decode(cnt,null,0,1) as sr_count_total,
decode(photo_validated,'YES',1,0) as photo_validated_total
from 
(

select a.EMPLOYEE_ID EMP_ID,b.Employee_Name||decode(b.Employee_Initial,null,' ','.'||b.Employee_Initial) Employee_Name ,b.GPF_NO,
c.OFFICE_NAME
from HRM_EMP_CONTROLLING_OFFICE a
inner join HRM_MST_EMPLOYEES b on  b.EMPLOYEE_ID =a.EMPLOYEE_ID
inner join COM_MST_ALL_OFFICES_VIEW c on c.OFFICE_ID=a.CONTROLLING_OFFICE_ID
inner join COM_MST_OFFICE_LEVELS d on d.OFFICE_LEVEL_ID=c.OFFICE_LEVEL_ID
WHERE c.OFFICE_ID in ($P!{offids})
ORDER BY HIERARCHICAL_SEQUENCE,c.office_id,a.employee_id
) x
left outer join
(
select decode(PROCESS_FLOW_STATUS_ID,null,'NO','YES') add_detail_avail,
decode(PROCESS_FLOW_STATUS_ID,null,'NO','FR','YES','NO') add_detail_valid,EMPLOYEE_ID
from HRM_MST_EMP_ADDL_TMP
where  PROCESS_FLOW_STATUS_ID!='DL'  or PROCESS_FLOW_STATUS_ID is null
) y on y.EMPLOYEE_ID=x.EMP_ID
left outer join 
(
select decode(PROCESS_FLOW_STATUS_ID,null,'NO','YES') crtl_office_avail,
decode(PROCESS_FLOW_STATUS_ID,null,'NO','FR','YES','NO') crtl_office_valid,
EMPLOYEE_ID
from HRM_EMP_CONTROLLING_OFFICE_TMP
where  PROCESS_FLOW_STATUS_ID!='DL'  or PROCESS_FLOW_STATUS_ID is null
)z on z.EMPLOYEE_ID=x.EMP_ID
left outer join 
(
select decode(PROCESS_FLOW_STATUS_ID,null,'NO','YES') current_posting_avail,
decode(PROCESS_FLOW_STATUS_ID,null,'NO','FR','YES','NO') current_posting_valid ,
EMPLOYEE_ID from HRM_EMP_CURRENT_POSTING
where office_id in ($P!{offids})
)a on a.EMPLOYEE_ID=x.EMP_ID
left outer join 
(
select DISTINCT TO_CHAR(EMPLOYEE_ID) SR_RECORD from HRM_EMP_SERVICE_DATA 
) b on b.SR_RECORD=TO_CHAR(x.EMP_ID)
left outer join 
(
select * from 
(
select empid1,  cnt1-cnt2 as cnt from
(
select EMPLOYEE_ID  as empid1,  COUNT(*) as cnt1 FROM HRM_EMP_SERVICE_DATA 
group by EMPLOYEE_ID
) x1
left outer join
(
select EMPLOYEE_ID as empid2,  COUNT(*) as cnt2 FROM HRM_EMP_SERVICE_DATA 
where process_flow_status_id='FR' 
group by EMPLOYEE_ID
) y1
on x1.empid1 = y1.empid2
)

) c on c.EMPID1 =x.EMP_ID
left outer join
(
     select m.controlling_office_id, m.employee_id , 
     
     decode(n.process_flow_status_id,'FR','YES','NO') as photo_validated from
     hrm_emp_controlling_office m, hrm_emp_addl_photo_new_tmp n 
     where m.employee_id = n.employee_id 
) d on a.employee_id=d.employee_id
) zz
left outer join
(

select controlling_office_id, designation_id, employee_id from 
(
select controlling_office_id, employee_id from hrm_emp_controlling_office
where controlling_office_id in ($P!{offids})
) aa
inner join 
(
select employee_id as employee_id1, designation_id from hrm_emp_current_posting
where office_id in ($P!{offids}) 
) bb
on aa.employee_id = bb.employee_id1
) yy
on zz.emp_id=yy.employee_id
left outer join
(
select designation_id, designation from hrm_mst_designations
) xx
on yy.designation_id=xx.designation_id
order by office_name,designation]]></queryString>

