	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="reg_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="finyear" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select to_char(office_id) as newoffid,post_Rank_id,fin_year,
total,filledposts,remainingposts,office_name,post_Rank_name from 
(
select office_id,post_Rank_id,fin_year,decode(filledposts,null,0,filledposts) as filledposts,
total,decode(remainingposts,null,0,remainingposts) as remainingposts,office_name,post_Rank_name from hrm_sanction_ho_view1 
where office_id =$P{off_id} and fin_year=$P{finyear}
)
union 
select to_char(region_office_id) as newoffid,post_Rank_id,fin_year,
(reg_total+cir_total+div_total)as total,(reg_filledposts+cir_filledposts+div_filledposts)as filledposts,(reg_remainingposts+cir_remainingposts+div_remainingposts)as remainingposts,office_name,post_Rank_name from 
(
  select a.region_office_id,a.post_Rank_id,a.fin_year,
  decode(a.filledposts,null,0,a.filledposts) as reg_filledposts,decode(a.total,null,0,a.total)as reg_total,decode(a.remainingposts,null,0,a.remainingposts)as reg_remainingposts,
  decode(b.filledposts,null,0,b.filledposts)as cir_filledposts,decode(b.total,null,0,b.total)as cir_total,decode(b.remainingposts,null,0,b.remainingposts)as cir_remainingposts,
  decode(c.filledposts,null,0,c.filledposts)as div_filledposts,decode(c.total,null,0,c.total)as div_total,decode(c.remainingposts,null,0,c.remainingposts)as div_remainingposts,
  a.office_name,a.post_Rank_name from 
  (
    select region_office_id,post_Rank_id,fin_year,decode(filledposts,null,0,filledposts) as filledposts,
    total,decode(remainingposts,null,0,remainingposts) as remainingposts,office_name,post_Rank_name from hrm_sanction_region_view1 where region_office_id in($P!{reg_id}) and fin_year=$P{finyear} order by post_Rank_id 
  )a
  left outer join
  (
    select region_office_id,post_Rank_id,post_Rank_name,sum(decode(filledposts,null,0,filledposts)) as filledposts,
    sum(total)as total,sum(decode(remainingposts,null,0,remainingposts)) as remainingposts from hrm_sanction_circle_view1 where region_office_id in($P!{reg_id}) and fin_year=$P{finyear} group by region_office_id,post_Rank_id,post_Rank_name order by post_Rank_id
  )b on a.region_office_id=b.region_office_id and a.post_Rank_id=b.post_Rank_id 
  full join
  (
    select region_office_id,post_Rank_id,post_Rank_name,sum(decode(filledposts,null,0,filledposts)) as filledposts,
    sum(total)as total,sum(decode(remainingposts,null,0,remainingposts)) as remainingposts from hrm_sanction_division_view1 where region_office_id in($P!{reg_id}) and fin_year=$P{finyear} group by region_office_id,post_Rank_id,post_Rank_name order by post_Rank_id
  )c on a.region_office_id=c.region_office_id and a.post_Rank_id=c.post_Rank_id
)order by newoffid,post_Rank_name]]></queryString>

