	<parameter name="jrid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="offid" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select office_id,joining_report_id, employee_id, date_of_joining,FN_OR_AN, 
Proceeding_no,Proceeding_Date,Presiding_officer,Copy_To,employee_name,office_name,designation from 
(
select office_id,joining_report_id, employee_id,designation_id, date_of_joining,FN_OR_AN, 
Proceeding_no,Proceeding_Date,Presiding_officer,Copy_To from hrm_emp_join_reports 
)a
left outer join 
(
select employee_id as empid,employee_name from  hrm_mst_employees
)b
on a.employee_id=b.empid
left outer join
(
select office_id as offid,office_name from com_mst_offices
)c
on a.office_id=c.offid
left outer join
(
select designation_id as desigid,designation from hrm_mst_designations
)d
on a.designation_id=d.desigid
where joining_report_id=$P{jrid} and office_id=$P{offid}]]></queryString>

