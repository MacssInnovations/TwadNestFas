	<parameter name="offid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="subject" isForPrompting="true" class="java.lang.String"/>
	<parameter name="refer" isForPrompting="true" class="java.lang.String"/>
	<parameter name="paraone" isForPrompting="true" class="java.lang.String"/>
	<parameter name="paratwo" isForPrompting="true" class="java.lang.String"/>
	<parameter name="preno" isForPrompting="true" class="java.lang.String"/>
	<parameter name="predate" isForPrompting="true" class="java.lang.String"/>
	<parameter name="predesig" isForPrompting="true" class="java.lang.String"/>
	<parameter name="preoff" isForPrompting="true" class="java.lang.String"/>
	<parameter name="copyto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="empid" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select distinct(employee_id),empname,designation, date_of_relieval,relieval_fn_an,
transfer_to_office_id,transfertoofficename,office_Name
from 
( 
select * from
(
select employee_id,office_id,transfer_to_office_id,transfer_proceed_date,PROCESS_FLOW_STATUS_ID,
date_of_relieval,relieval_fn_an,transfer_proceed_no
from
(
select distinct(employee_id),office_id,transfer_to_office_id,transfer_proceed_no,transfer_proceed_date
from hrm_emp_relieval_trn where transfer_proceed_no=$P{preno} and office_id=$P{offid}
)aa
inner join
(
select employee_id as empid,office_id as offid,proceeding_no,PROCESS_FLOW_STATUS_ID,
date_of_relieval,relieval_fn_an from hrm_emp_relieval_details
where process_flow_Status_id not in('FR','DL')
)bb
on aa.transfer_proceed_no=bb.proceeding_no and  aa.office_id=bb.offid and aa.employee_id=bb.empid
)
)a 
left outer join 
( 
select Proceeding_no as prono,
office_id as offid,Proceeding_Date,subject,sub_reference,copyto,addl_para_one,
addl_para_2, presiding_officer,presiding_officer_desig from hrm_emp_relieval_proceed_new
where proceeding_no=$P{preno} and office_id=$P{offid}
)b 
on a.transfer_proceed_no=b.prono  and a.office_id=b.offid 
left outer join 
( 
select employee_id as empid1,
(employee_prefix||'.'||employee_name||'.'||employee_initial) as empname 
from hrm_mst_employees 
)c 
on a.employee_id=c.empid1 

left outer join 
( 
select employee_id as empid2,designation_id from 
hrm_emp_current_posting  
)e
on a.employee_id=e.empid2 
left outer join 
( 
select designation_id as desigid,designation
from hrm_mst_designations 
)f 
on e.designation_id=f.desigid
left outer join
(
select Office_id as offid, office_name as transfertoofficename from com_mst_offices 
)g
on a.transfer_to_office_id=g.offid
left outer join
(
select office_id as offid,office_Name from com_mst_offices
)h
on a.office_id=h.offid]]></queryString>

