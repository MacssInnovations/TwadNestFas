<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="EmployeeWaiting4Post"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select decode(d.OFFICE_NAME,null,' ',d.OFFICE_NAME) OFFICE_NAME,a.EMPLOYEE_ID,a.EMPLOYEE_NAME||decode(a.EMPLOYEE_INITIAL,null,' ','.'||a.EMPLOYEE_INITIAL) EMPLOYEE_NAME,
d.OFFICE_NAME,f.DESIGNATION


from HRM_MST_EMPLOYEES a
left outer join HRM_EMP_SERVICE_DATA b on b.EMPLOYEE_ID=a.EMPLOYEE_ID
left outer  join COM_MST_OFFICES d on d.OFFICE_ID = b.OFFICE_ID 
left outer join COM_MST_OFFICE_LEVELS e on e.OFFICE_LEVEL_ID = d.OFFICE_LEVEL_ID
left outer join HRM_MST_DESIGNATIONS f on f.DESIGNATION_ID = b.DESIGNATION_ID

where  
 a.EMPLOYEE_ID  in  (select f.EMPLOYEE_ID  from  HRM_EMP_CURRENT_POSTING f where f.EMPLOYEE_STATUS_ID ='TRT' or f.EMPLOYEE_STATUS_ID ='DPT'  )
and
b.DATE_FROM = (select max(h.DATE_FROM) from HRM_EMP_SERVICE_DATA h where h.EMPLOYEE_ID =a.EMPLOYEE_ID)

order by EMPLOYEE_NAME]]></queryString>

	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="EMPLOYEE_ID" class="java.math.BigDecimal"/>
	<field name="EMPLOYEE_NAME" class="java.lang.String"/>
	<field name="DESIGNATION" class="java.lang.String"/>

