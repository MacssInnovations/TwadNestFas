<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="wc_billing"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="650"
		 pageHeight="842"
		 columnWidth="590"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="ctxpath" isForPrompting="true" class="java.lang.String"/>
	<parameter name="billsno" isForPrompting="false" class="java.lang.Integer"/>
	<queryString><![CDATA[select 
    WC.BILL_SNO,
    WC.BENEFICIARY_SNO,
    WC.METRE_SNO,
    WC.QTY_CONSUMED,
    WC.EXCESS_QTY,
    WC.AMT,
    WC.EXCESS_AMT,
    WC.TARIFF_RATE,
    WC.EXCESS_RATE,
    PR.METRE_INITIAL_READING,
    PR.METRE_CLOSING_READING,
    MT.MULTIPLY_FACTOR,
    MT.MIN_BILL_QTY,
    MT.ALLOTED_QTY,
    MT.METRE_LOCATION,
    CASE WHEN (WC.QTY_CONSUMED * MT.MULTIPLY_FACTOR) > MT.MIN_BILL_QTY 
            THEN (WC.QTY_CONSUMED * MT.MULTIPLY_FACTOR) 
            ELSE  MT.MIN_BILL_QTY END
            AS TOT_CONSUMPT
    
    
from 
(   
(
    select
    PR_SNO,
    BILL_SNO,
    BENEFICIARY_SNO,
    METRE_SNO,
    QTY_CONSUMED,
    EXCESS_QTY,
    AMT,
    EXCESS_AMT,
    TOTAL_AMT,
    TARIFF_RATE,
    EXCESS_RATE
      FROM 
      PMS_DCB_WC_BILLING    
 WHERE BILL_SNO=1
)WC
join 
(
  select
        PR_SNO,
        METRE_SNO,
        METRE_INITIAL_READING,
        METRE_CLOSING_READING
   from 
        PMS_DCB_TRN_MONTHLY_PR        
)PR
on WC.PR_SNO=PR.PR_SNO


JOIN
  (SELECT BENEFICIARY_SNO,
    METRE_SNO,
    MULTIPLY_FACTOR,
    MIN_BILL_QTY,
    ALLOTED_QTY,
    METRE_LOCATION
  FROM PMS_DCB_MST_BENEFICIARY_METRE
  )MT
ON WC.METRE_SNO=MT.METRE_SNO


)]]></queryString>

	<field name="BILL_SNO" class="java.math.BigDecimal"/>
	<field name="BENEFICIARY_SNO" class="java.math.BigDecimal"/>
	<field name="METRE_SNO" class="java.math.BigDecimal"/>
	<field name="QTY_CONSUMED" class="java.math.BigDecimal"/>
	<field name="EXCESS_QTY" class="java.math.BigDecimal"/>
	<field name="AMT" class="java.math.BigDecimal"/>
	<field name="EXCESS_AMT" class="java.math.BigDecimal"/>
	<field name="TARIFF_RATE" class="java.math.BigDecimal"/>
	<field name="EXCESS_RATE" class="java.math.BigDecimal"/>
	<field name="METRE_INITIAL_READING" class="java.math.BigDecimal"/>
	<field name="METRE_CLOSING_READING" class="java.math.BigDecimal"/>
	<field name="MULTIPLY_FACTOR" class="java.math.BigDecimal"/>
	<field name="MIN_BILL_QTY" class="java.math.BigDecimal"/>
	<field name="ALLOTED_QTY" class="java.math.BigDecimal"/>
	<field name="METRE_LOCATION" class="java.lang.String"/>
	<field name="TOT_CONSUMPT" class="java.math.BigDecimal"/>

	<variable name="SUM_TC" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOT_CONSUMPT}]]></variableExpression>
	</variable>
	<variable name="SUM_WC" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$V{WC}]]></variableExpression>
	</variable>
	<variable name="WC" class="java.math.BigDecimal" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[$F{TOT_CONSUMPT}.multiply( $F{TARIFF_RATE} )]]></variableExpression>
	</variable>
