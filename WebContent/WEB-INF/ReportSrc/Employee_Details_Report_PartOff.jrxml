	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.employee_id,a.employee_name,d.office_name,b.date_effective_from,c.designation from
(
select employee_id,employee_name||decode(employee_initial,null,' ','.'||employee_initial) employee_name 
from hrm_mst_employees
) a
inner join
(
select employee_id,office_id,designation_id,date_effective_from from hrm_emp_current_posting
where office_id in ($P!{off_id})
) b
on a.employee_id=b.employee_id
left outer join
(
select designation_id,designation from hrm_mst_designations
) c
on b.designation_id=c.designation_id
inner join
(
select office_id,office_name,off_order from com_mst_all_offices_view
) d
on b.office_id=d.office_id
order by d.off_order,a.employee_name]]></queryString>

