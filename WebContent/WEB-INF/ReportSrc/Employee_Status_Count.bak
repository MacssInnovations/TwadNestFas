	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select a.employee_status_id, b.employee_status_desc, a.total_no  from
(
select employee_status_id,count(*) as total_no from hrm_emp_current_posting
where employee_status_id not in ('DTH','SAN','VRS','DIS')
group by employee_status_id
) a
left outer join
(
select employee_status_id as emp_stat_id, employee_status_desc from HRM_MST_EMPLOYEE_STATUS
) b
on a.employee_status_id=b.emp_stat_id
order by 3 desc]]></queryString>

	<field name="EMPLOYEE_STATUS_ID" class="java.lang.String"/>
	<field name="EMPLOYEE_STATUS_DESC" class="java.lang.String"/>
	<field name="TOTAL_NO" class="java.lang.Integer"/>

