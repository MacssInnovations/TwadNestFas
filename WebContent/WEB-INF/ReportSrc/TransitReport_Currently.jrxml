	<queryString><![CDATA[select employee_id,employee_name,designation, employee_status_id, date_effective_from, last_office_id, office_name
from
(
select employee_id,employee_name,designation, employee_status_id, date_effective_from from
(
select employee_id,designation_id,date_effective_from,employee_status_id from hrm_emp_current_posting
where employee_status_id='TRT'and employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
) a
left outer join
(
select EMPLOYEE_ID as emp_id, (EMPLOYEE_NAME || ' ' || EMPLOYEE_INITIAL) AS employee_name from  HRM_MST_EMPLOYEES
) b
on a.employee_id=b.emp_id
left outer join
(
select designation_id as des_id,designation from HRM_MST_DESIGNATIONS
) c
on a.designation_id=c.des_id
) aa
left outer join
(
select employee_id as emp_id1, office_id as last_office_id from hrm_emp_service_data a
where a.service_list_slno = ( select max(b.service_list_slno) from hrm_emp_service_data b
where a.employee_id= b.employee_id and process_flow_status_id='FR' and employee_status_id='WKG')
) bb
on aa.employee_id=bb.emp_id1
left outer join
(
select office_id as off_id, office_name from com_mst_offices
) cc
on bb.last_office_id=cc.off_id
left outer join
(
select office_id as off_id1, off_order from com_mst_all_offices_view
) dd
on bb.last_office_id=dd.off_id1
order by off_order,aa.employee_name]]></queryString>

