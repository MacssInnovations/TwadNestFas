	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select * from
(
select e.auditwing_OFFICE_ID as audit_id,e.region_office_id,upper(f.office_name) as region_office_name,e.auditwing_office_name as auditwing_name 
from COM_MST_audit_wing_HVIEW e,com_mst_offices f
where e.region_office_id=f.office_id
)p
left outer join
(
select a.region_office_id as reg_id,
count(a.auditwing_OFFICE_id) as count
from COM_MST_audit_wing_HVIEW a
group by a.region_office_id
)v
on p.region_OFFICE_ID=v.reg_id
order by REGION_OFFICE_ID,audit_ID]]></queryString>

