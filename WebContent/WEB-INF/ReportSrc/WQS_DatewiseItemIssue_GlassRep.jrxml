	<parameter name="fromdt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="catdesc" isForPrompting="true" class="java.lang.String"/>
	<parameter name="lab" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select * from(select lab_code,major_category_code,item_code,date_of_issue,qty_issued,remarks,uom_code from wqs_item_issue)a 
inner join(select major_category_code,major_category_desc from wqs_mst_inv_category)b 
on a.major_category_code=b.major_category_code left outer join(select glassware_code,glassware_spec from wqs_mst_inv_glassware)c 
on a.item_code=c.glassware_code left outer join(select lab_code,lab_desc from wqs_mst_lab)d on a.lab_code=d.lab_code 
where a.lab_code=$P{lab} and b.major_category_desc=$P{catdesc} and a.date_of_issue between $P{fromdt} and $P{todt} order by a.item_code,a.date_of_issue]]></queryString>

