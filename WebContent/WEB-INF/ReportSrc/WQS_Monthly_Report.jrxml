<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="WQS_Monthly_Report"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="651"
		 pageHeight="842"
		 columnWidth="591"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="date_from" isForPrompting="true" class="java.lang.String"/>
	<parameter name="date_to" isForPrompting="true" class="java.lang.String"/>
	<parameter name="monthInWords" isForPrompting="true" class="java.lang.String"/>
	<parameter name="yr" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fin_yr" isForPrompting="true" class="java.lang.String"/>
	<parameter name="prev_month" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select lab_id, lab_name, nvl(no_chemical_tests_cum,0)as no_chemical_tests_cum,nvl(no_of_bacterial_tests_cum,0) as no_of_bacterial_tests_cum,nvl((no_chemical_tests_cum+no_of_bacterial_tests_cum),0)as total_cum, 
nvl(no_of_chemical_tests_dur,0) as no_of_chemical_tests_dur, nvl(no_of_bacterial_tests_dur,0)as no_of_bacterial_tests_dur,nvl((no_of_chemical_tests_dur+no_of_bacterial_tests_dur),0) as total_dur
from 
(
select office_id as lab_id, office_name as lab_name from com_mst_all_offices_view where office_level_id in ('LB','HO')
order by off_order

) aaa
left outer join

(
select  lab1 as lab_id1, nvl(no_of_chemical_tests,0) as no_chemical_tests_cum,
                  nvl(no_of_bacteriological_tests,0) as no_of_bacterial_tests_cum from 
(
select lab1, test_type, count(sample_number) as No_of_Chemical_tests from 
(
select distinct lab1, test_year, test_month, test_type, sample_number from 
(
select lab_code as lab1, invoice_number, sample_number, test_purpose_id, 
       parameter  as test_parameter, extract(year from date_of_receipt) as test_year, extract(month from date_of_receipt) as test_month
from WQS_WATERSAMPLE_RESULT
where date_of_receipt >= to_date($P{date_from},'dd/mm/yyyy') and date_of_receipt <=  to_date($P{date_to},'dd/mm/yyyy') 
)a
left outer join
(
select element_symbol, test_result as test_type from wqs_element_symbol
) b
on a.test_parameter = b.element_symbol
where test_type in ( 'Chemical')
order by 1,2,3,4,5 
) aa
group by lab1, test_type

) bb
left outer join 
(
select  lab2, test_type, count(sample_number) as No_of_Bacteriological_Tests from 
(
select distinct lab2, test_year, test_month, test_type, sample_number from 
(
select lab_code as lab2, invoice_number, sample_number, test_purpose_id, 
       parameter  as test_parameter, extract(year from date_of_receipt) as test_year, extract(month from date_of_receipt) as test_month
from WQS_WATERSAMPLE_RESULT
where date_of_receipt >= to_date($P{date_from},'dd/mm/yyyy') and date_of_receipt <=  to_date($P{date_to},'dd/mm/yyyy') 
)a
left outer join
(
select element_symbol, test_result as test_type from wqs_element_symbol
) b
on a.test_parameter = b.element_symbol
where test_type in ( 'Bacteriological')
order by 1,2,3,4,5 
) aa
group by lab2, test_type
)cc
on bb.lab1 = cc.lab2



)  bbb
on aaa.lab_id = bbb.lab_id1
left outer join
(
select  lab1 as lab_id2, nvl(no_of_chemical_tests,0) as no_of_chemical_tests_dur,
                  nvl(no_of_bacteriological_tests,0) as no_of_bacterial_tests_dur from 
(
select lab1, test_type, count(sample_number) as No_of_Chemical_tests from 
(
select distinct lab1, test_year, test_month, test_type, sample_number from 
(
select lab_code as lab1, invoice_number, sample_number, test_purpose_id, 
       parameter  as test_parameter, extract(year from date_of_receipt) as test_year, extract(month from date_of_receipt) as test_month
from WQS_WATERSAMPLE_RESULT
where extract(year from date_of_receipt) =$P{yr} and extract(month from date_of_receipt)=$P{mon}
)a
left outer join
(
select element_symbol, test_result as test_type from wqs_element_symbol
) b
on a.test_parameter = b.element_symbol
where test_type in ( 'Chemical')
order by 1,2,3,4,5 
) aa
group by lab1, test_type

) bb
left outer join 
(
select  lab2, test_type, count(sample_number) as No_of_Bacteriological_Tests from 
(
select distinct lab2, test_year, test_month, test_type, sample_number from 
(
select lab_code as lab2, invoice_number, sample_number, test_purpose_id, 
       parameter  as test_parameter, extract(year from date_of_receipt) as test_year, extract(month from date_of_receipt) as test_month
from WQS_WATERSAMPLE_RESULT
where extract(year from date_of_receipt) =$P{yr} and extract(month from date_of_receipt)=$P{mon}
)a
left outer join
(
select element_symbol, test_result as test_type from wqs_element_symbol
) b
on a.test_parameter = b.element_symbol
where test_type in ( 'Bacteriological')
order by 1,2,3,4,5 
) aa
group by lab2, test_type
)cc
on bb.lab1 = cc.lab2 
) ccc
on aaa.lab_id=ccc.lab_id2]]></queryString>

	<field name="LAB_ID" class="java.math.BigDecimal"/>
	<field name="LAB_NAME" class="java.lang.String"/>
	<field name="NO_CHEMICAL_TESTS_CUM" class="java.math.BigDecimal"/>
	<field name="NO_OF_BACTERIAL_TESTS_CUM" class="java.math.BigDecimal"/>
	<field name="TOTAL_CUM" class="java.math.BigDecimal"/>
	<field name="NO_OF_CHEMICAL_TESTS_DUR" class="java.math.BigDecimal"/>
	<field name="NO_OF_BACTERIAL_TESTS_DUR" class="java.math.BigDecimal"/>
	<field name="TOTAL_DUR" class="java.math.BigDecimal"/>

	<variable name="total_chemical_cum" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{NO_CHEMICAL_TESTS_CUM}]]></variableExpression>
	</variable>
	<variable name="total_bateria_cum" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{NO_OF_BACTERIAL_TESTS_CUM}]]></variableExpression>
	</variable>
	<variable name="cum_total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_CUM}]]></variableExpression>
	</variable>
	<variable name="total_chemical_dur" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{NO_OF_CHEMICAL_TESTS_DUR}]]></variableExpression>
	</variable>
	<variable name="total_bacteria_dur" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{NO_OF_BACTERIAL_TESTS_DUR}]]></variableExpression>
	</variable>
	<variable name="dur_total" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_DUR}]]></variableExpression>
	</variable>
