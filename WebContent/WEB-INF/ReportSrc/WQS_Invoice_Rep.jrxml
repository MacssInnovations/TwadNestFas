	<queryString><![CDATA[select invoice_number,customer_id,invoice_date,invoice_amount,payment_mode,cheque_number,cheque_date,bank_name,drawee_branch,customer_ref_no,report_due_date,b.sample_type,total_samples from
(select invoice_number,customer_id,invoice_date,invoice_amount,payment_mode,cheque_number,cheque_date,bank_name,drawee_branch,customer_ref_no,report_due_date,sample_type,total_samples from wqs_invoice_details where lab_code=$P{labcode} and customer_type=$P{type} order by invoice_number
)a left outer join
(select sample_id,sample_type from wqs_sample_type 
)b on a.sample_type=b.sample_id]]></queryString>

