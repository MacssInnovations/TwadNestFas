	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="gpfno" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select * from 
(
select  e.gpfno_1,e.EMP_NAME,e.DESIG,e.DOB,e.open_bal,e.deposit,e.interest,e.withdraw,e.closing_bal,e.cr_ACCT_MMYY,e.cr_REL_MMYY,e.cr_SUB_AMT,
e.arrear,e. inst_no,e.arrear_inst_no,e.total,f.db_ADV_AMT,f.db_ADV_TYP,f.db_CON_AMT,f.db_INST_AMT,f.db_REL_MMYY,f.db_NO_INST,e.cr_DIVN_CD,e.cum_cb from
(
select  c.gpfno_1,c.EMP_NAME,c.DESIG,c.DOB,c.open_bal,c.deposit,c.interest,c.withdraw,c.closing_bal,d.cr_ACCT_MMYY,d.cr_REL_MMYY,d.cr_SUB_AMT,
d.cr_REF_AMT as arrear,(d.cr_REF_INS_NO||'/'||d.cr_REF_INS_TO) as inst_no,(d.cr_AR_INS_TOT||'/'||d.cr_AR_INS_NO) as arrear_inst_no,c.total,d.cr_DIVN_CD,c.cum_cb
from
(
select a.gpfno_1,a.EMP_NAME,a.DESIG,a.DOB,b.OB as open_bal,b.TOT_DEP,b.TOT_WITH as withdraw ,b.JINT,b.TOT_RECOV,b.CUM_CB as closing_bal,b.TOT_INT,b.deposit,b.interest,b.total,b.cum_cb  from 
(
select GPFNO as gpfno_1,EMP_NAME,DESIG,to_char(DOB,'dd/mm/yy') as dob from emp_cat where gpfno =$P{gpfno}
)a
left outer join
(
select GPFNO,OB,TOT_DEP,TOT_WITH,JINT,TOT_RECOV,TOT_INT,(TOT_DEP+TOT_RECOV) as deposit,(JINT+TOT_INT) as interest, 
(ob+TOT_DEP+TOT_RECOV+JINT+TOT_INT) as total,(ob+TOT_DEP+TOT_RECOV+JINT+TOT_INT)-(TOT_WITH)as cum_cb from reg_bal
)b
on a.gpfno_1=b.gpfno
)c
left outer join
(
select GPFNO as cr_gpf,ACCT_MMYY as cr_ACCT_MMYY,DIVN_CD as cr_DIVN_CD,REL_MMYY as cr_REL_MMYY,SUB_AMT as cr_SUB_AMT,REF_AMT as cr_REF_AMT,REF_INS_NO as cr_REF_INS_NO ,REF_INS_TO as cr_REF_INS_TO ,SPLIND as cr_SPLIND,SUB_AR_AMT as cr_SUB_AR_AMT,
AR_INS_NO as cr_AR_INS_NO,AR_INS_TOT as cr_AR_INS_TOT from cr_trn 
)d
on c.gpfno_1=d.cr_gpf
)e
left outer join
(
select DIVN_CD,ACCT_MMYY,GPFNO as gpf1,ADV_AMT as db_ADV_AMT,ADV_TYP as db_ADV_TYP,CON_AMT as db_CON_AMT,INST_AMT as db_INST_AMT,NO_INST as db_NO_INST,REL_MMYY as db_REL_MMYY,GPFTYPE,SPLIND from db_trn
)f
on e.gpfno_1=f.gpf1
)g
left outer join
(
select GPFNO,OB as imp_open_bal,TOT_DEP,TOT_WITH,JINT,TOT_RECOV,(ob+JINT+TOT_INT) as clos_ob_imp,TOT_INT,(TOT_DEP+TOT_RECOV) as imp_deposit,(JINT+TOT_INT) as imp_interest, 
(ob+JINT+TOT_INT) as imp_total from imp_bal
)h
on g.gpfno_1=h.gpfno
)i
left outer join
(
select GPFNO,OB as imp_open_bal_2003,TOT_DEP,TOT_WITH,JINT,TOT_RECOV,(ob+JINT+TOT_INT) as clos_ob_imp_2003,TOT_INT,(TOT_DEP+TOT_RECOV) as imp_deposit_2003,(JINT+TOT_INT) as imp_interest_2003, 
(ob+JINT+TOT_INT) as imp_total_2003 from imp_bal2003
)j
on gpfno_1=j.gpfno]]></queryString>

