		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="year" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="day" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select a.USER_ID,to_char(a.LOGGED_IN_TIME,'DD/MM/YYYY HH:MI:SS AM') LOGGED_IN_TIME ,to_char(a.LOGGED_OUT_TIME,'DD/MM/YYYY HH:MI:SS AM') LOGGED_OUT_TIME,
c.employee_name||decode(c.employee_initial,null,' ','.'||c.employee_initial) employee_name,
e.office_name,a.IP_ADDRESS,f.designation
from SEC_MST_USERS_LOGIN_HISTORY a
inner join sec_mst_users b on b.user_id=a.user_id
inner join hrm_mst_employees c on c.employee_id=b.employee_id
left outer join hrm_emp_current_posting d on d.employee_id=b.employee_id
left outer join com_mst_offices e on e.office_id=d.office_id
left outer join hrm_mst_designations f on f.designation_id =d.designation_id


where extract (year from a.LOGGED_IN_TIME)=$P{year}
and extract (month from a.LOGGED_IN_TIME)=$P{month}
and extract (day from a.LOGGED_IN_TIME)=$P{day}
order by c.employee_name,a.LOGGED_IN_TIME]]></queryString>

