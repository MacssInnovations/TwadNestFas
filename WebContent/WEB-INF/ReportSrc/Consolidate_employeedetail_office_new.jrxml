	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.employee_id, b.EMPLOYEE_NAME||decode(b.EMPLOYEE_INITIAL,null,' ','.'||b.EMPLOYEE_INITIAL) EMPLOYEE_NAME,
upper(c.designation) as designation, upper(d.office_name) as office_name,
to_char(decode( a.DATE_EFFECTIVE_FROM,null,' ', to_char(a.DATE_EFFECTIVE_FROM,'dd/mm/yyyy')  )) DATE_OF_JOINING,
a.remarks, e.off_order,e.off_id1 from 
(
select EMPLOYEE_ID,office_id,DESIGNATION_ID,department_id,DATE_EFFECTIVE_FROM,'' as remarks
from hrm_emp_current_posting where employee_id in (select employee_id from hrm_mst_employees  where is_consolidate='Y')
and employee_status_id='WKG'
) a

left outer join
(
select employee_id as emp_id,employee_initial,employee_name from hrm_mst_employees 
) b
on a.employee_id=b.emp_id
left outer join
(
select designation_id as desig_id, designation, ORDERING_SEQUENCE_NO from hrm_mst_designations
) c
on a.designation_id=c.desig_id
left outer join
(
select office_id as off_id,office_name from com_mst_offices
) d
on a.office_id=d.off_id
left outer join
(
select office_id as off_id1,off_order from com_mst_all_offices_view
) e
on a.office_id=e.off_id1
where a.office_id in ($P!{offids}) and a.department_id='TWAD'
order by e.off_order,c.ORDERING_SEQUENCE_NO,b.EMPLOYEE_NAME]]></queryString>

