	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select e.OFFICE_NAME,a.EMPLOYEE_ID,c.EMPLOYEE_NAME||decode(c.EMPLOYEE_INITIAL,null,' ','.'||c.EMPLOYEE_INITIAL) AS employee_name,d.DESIGNATION,e.OFFICE_NAME as Office_to_be_joined,a.DATE_OF_RELIEVAL,
decode(b.TRANSFER_PROCEED_DATE,null,' ',b.TRANSFER_PROCEED_DATE) TRANSFER_PROCEED_DATE,decode(a.REMARKS,null,' ',a.REMARKS) REMARKS,
upper(to_char(a.DATE_OF_RELIEVAL,'mm'))as mnt,e.OFF_ORDER
from HRM_EMP_RELIEVAL_DETAILS a
inner join HRM_EMP_RELIEVAL_TRN b on a.OFFICE_ID=b.OFFICE_ID and b.RELIEVAL_SLNO=a.RELIEVAL_SLNO
inner join HRM_MST_EMPLOYEES c on c.EMPLOYEE_ID=a.EMPLOYEE_ID
left outer join HRM_MST_DESIGNATIONS d on d.DESIGNATION_ID=b.DESIGNATION_ID
inner join COM_MST_ALL_OFFICES_VIEW e on e.OFFICE_ID=b.OFFICE_ID 

where 
a.PROCESS_FLOW_STATUS_ID='FR'
and a.DATE_OF_RELIEVAL between $P{fromdate} and $P{todate}
and e.OFFICE_ID in ($P!{offids})

order by OFF_ORDER,OFFICE_NAME,EMPLOYEE_ID]]></queryString>

