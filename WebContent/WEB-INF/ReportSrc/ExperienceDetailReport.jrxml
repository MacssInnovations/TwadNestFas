	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select designation_id ,designation,office_name,office_level_name,count(yrs10) as yrs10,count(yrs1115)as yrs1115,
count(yrs1620)as yrs1620,count(yrs20)as yrs20 from(
select  * from
(
select designation_id ,designation,office_name,office_level_name from EXP_OFF_DESIG

)a
left outer join
(
select designation_id, count(*) as  yrs10 from EXP_OFF_DESIG
where (extract(year from now())-extract(year from TWAD_ENTRY_DATE))<10
and TWAD_ENTRY_DATE is not null
group by designation_id
) b
on b.designation_id=a.designation_id 
left outer join
(
select  designation_id,  count(*) as yrs1115 from EXP_OFF_DESIG
where (extract(year from now())-extract(year from TWAD_ENTRY_DATE))
 between   11 and 15  and TWAD_ENTRY_DATE is not null
group by designation_id
) c
on c.designation_id=a.designation_id
left outer join
(
select designation_id, count(*) as yrs1620 from EXP_OFF_DESIG
where (extract(year from now())-extract(year from TWAD_ENTRY_DATE))
 between   16 and 20  and TWAD_ENTRY_DATE is not null
group by designation_id
) d
on d.designation_id=a.designation_id
left outer join
(
select  designation_id,  count(*) as  yrs20 from EXP_OFF_DESIG
where (extract(year from now())-extract(year from TWAD_ENTRY_DATE))>20
and TWAD_ENTRY_DATE is not null
group by designation_id
)  e
on e.designation_id=a.designation_id 
) 
where designation_id is not null
group by designation_id ,designation,office_name,office_level_name



]]></queryString>

