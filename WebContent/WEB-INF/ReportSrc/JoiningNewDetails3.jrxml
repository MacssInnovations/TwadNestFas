	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fromdate" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todate" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select a.EMPLOYEE_ID,a.SUBDIVISION_OFFICE_ID,c.EMPLOYEE_NAME||decode(c.EMPLOYEE_INITIAL,null,' ','.'||c.EMPLOYEE_INITIAL) AS employee_name,d.DESIGNATION,a.DATE_OF_JOINING,
b.OFFICE_NAME,upper(to_char(a.DATE_OF_JOINING,'month'))as mnt,b.OFF_ORDER,e.office_id,e.DATE_OF_RELIEVAL,f.office_name as trnsoffice,g.office_name as joinoffice
from HRM_EMP_JOIN_REPORTS a
inner join COM_MST_ALL_OFFICES_VIEW b on b.OFFICE_ID=a.OFFICE_ID
inner join HRM_MST_EMPLOYEES c on c.EMPLOYEE_ID=a.EMPLOYEE_ID

inner join HRM_EMP_RELIEVAL_DETAILS e on e.EMPLOYEE_ID=c.EMPLOYEE_ID 
inner join COM_MST_OFFICES f on f.office_id=e.office_id
inner join COM_MST_OFFICES g on g.office_id=a.SUBDIVISION_OFFICE_ID
left outer join HRM_MST_DESIGNATIONS d on d.DESIGNATION_ID=a.DESIGNATION_ID
where
a.PROCESS_FLOW_STATUS_ID='FR' and
 b.OFFICE_ID in ($P!{offids}) 
and  a.DATE_OF_JOINING between $P{fromdate} and $P{todate}
order by OFF_ORDER,OFFICE_NAME,EMPLOYEE_ID]]></queryString>

