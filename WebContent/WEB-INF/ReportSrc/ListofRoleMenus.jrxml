	<queryString><![CDATA[select distinct decode(f.role_name,null,' ',f.role_name)as role_name,f.office_level_id,
decode(g.office_level_name,null,' ',g.office_level_name) as office_level_name,
a.role_id,a.major_system_id,b.major_system_short_desc,a.minor_system_id,c.minor_system_short_desc,a.sub_system_id,
d.sub_system_short_desc,a.menu_id,e.menu_short_desc,e.category_seq_no,e.order_seq_no
from sec_mst_role_menus a left outer join  sec_mst_major_systems b on b.major_system_id=a.major_system_id left outer join sec_mst_minor_systems c on a.major_system_id=c.major_system_id and a.minor_system_id=c.minor_system_id left outer join sec_mst_subsystems d on a.major_system_id=d.major_system_id and a.minor_system_id=d.minor_system_id and a.sub_system_id=d.sub_system_id left outer join sec_mst_intranet_menus e on a.major_system_id=e.major_system_id and a.minor_system_id=e.minor_system_id and a.sub_system_id=e.sub_system_id and e.menu_id=a.menu_id left outer join sec_mst_roles f on a.role_id=f.role_id left outer join com_mst_office_levels g on f.office_level_id=g.office_level_id where menu_short_desc is not null
 order by office_level_id,major_system_id,minor_system_id,sub_system_id,category_seq_no,order_seq_no]]></queryString>

