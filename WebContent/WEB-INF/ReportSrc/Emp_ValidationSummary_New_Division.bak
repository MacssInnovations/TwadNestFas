	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select office_name, Region_office_id, Circle_office_id, Division_office_id, office_id, 
sr_control_available_tot, addl_available_tot,  addl_validated_tot, current_posting_validated_tot,
sr_validated_tot, photo_validated_tot
from
(
select Region_office_id, Circle_office_id, Division_office_id,
decode(division_office_id,null,decode(circle_office_id,null,decode(Region_office_id,null,'5000',Region_office_id),circle_office_id),division_office_id) as office_id, 
sum(sr_control_available_tot) as sr_control_available_tot,
sum(addl_available_tot) as addl_available_tot,
sum(addl_validated_tot) as addl_validated_tot,
sum(current_posting_validated_tot) as current_posting_validated_tot,
sum(sr_validated_tot) as sr_validated_tot,
sum(photo_validated_tot) as photo_validated_tot from 
(
select Controlling_Office_id, office_name, sr_control_available_tot,
addl_available_tot, addl_validated_tot, current_posting_validated_tot,
sr_validated_tot, photo_validated_tot, off_order
from emp_rec_valid_all_office
where Controlling_Office_id in ($P!{offids})
) a
inner  join
( 
select office_id, office_level_id, region_office_id,
circle_office_id, division_office_id
from com_mst_all_offices_view

) b
on a.controlling_office_id = b.office_id
group by region_office_id, Circle_office_id, Division_office_id
order by 1 desc, 2 desc , 3 desc
) x
left outer join
(
select office_id as off_id, office_name, off_order from com_mst_all_offices_view
) y
on x.office_id=y.off_id]]></queryString>

