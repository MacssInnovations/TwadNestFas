	<parameter name="officelevelid" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.OFFICE_ID , a.OFFICE_NAME, a.OFFICE_ADDRESS1, a.OFFICE_ADDRESS2, a.CITY_TOWN_NAME, a.OFFICE_PIN_CODE, decode(a.OFFICE_EMAIL_ID,null,' ') as OFFICE_EMAIL_ID,
decode(a.OFFICE_STD_CODE,null,' ','0',' ') as OFFICE_STD_CODE, decode(a.OFFICE_PHONE_NO,null,' ')  as OFFICE_PHONE_NO , decode(a.OFFICE_FAX_NO,null,' ') as OFFICE_FAX_NO, b.WORK_NATURE_DESC, h.WORK_NATURE_DESC as ADDL_WORK_NATURE,  f.CADRE_NAME, e.OFFICE_NAME as CONTROL_OFFICE,  a.DATE_OF_FORMATION, a.REMARKS 

from COM_MST_OFFICES a

inner join COM_MST_WORK_NATURE b on a.PRIMARY_WORK_ID = b.WORK_NATURE_ID
inner join COM_OFFICE_ADDL_NATURE c on a.OFFICE_ID = c.OFFICE_ID and b.WORK_NATURE_ID = c.WORK_NATURE_ID
inner join COM_MST_WORK_NATURE h on  c.WORK_NATURE_ID =h.WORK_NATURE_ID
inner join COM_OFFICE_CONTROL d on d.OFFICE_ID  = a.OFFICE_ID 
inner join COM_MST_OFFICES e on d.CONTROLLING_OFFICE_ID = e.OFFICE_ID  
inner join HRM_MST_CADRE f on f.CADRE_ID = a.OFFICE_HEAD_CADRE_ID 


inner join COM_MST_OFFICE_LEVELS g on g.OFFICE_LEVEL_ID= a.OFFICE_LEVEL_ID]]></queryString>

