	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="emp_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="acc_head_code" isForPrompting="true" class="java.lang.Object"/>
	<parameter name="voucher_no" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="year" isForPrompting="true" class="java.util.Date"/>
	<parameter name="CASHBOOK_MONTH" isForPrompting="true" class="java.lang.String"/>
	<parameter name="CASHBOOK_YEAR" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="Sanction_Amt" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sanctionid" isForPrompting="true" class="java.lang.String"/>
	<parameter name="unit_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="month" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="bill_no" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select * from (SELECT *
FROM
  (SELECT m.ACCOUNTING_UNIT_ID,
m.ACCOUNTING_UNIT_OFFICE_ID OFFICE_ID,
t.AMOUNT as PAYMENT_AMOUNT_FINAL,
0 as PAYMENT_AMOUNT_OTHERS,
0 as PAYMENT_AMOUNT_ADV,
m.CASHBOOK_YEAR,
m.CASHBOOK_MONTH,
m.SANCTION_PROC_NO,
'' as SANCTION_PROC_date,

t.BILL_NO,
t.SL_NO,
t.ACCOUNT_HEAD_CODE,
t.PARTICULARS,

t.BILL_MINOR_TYPE_CODE,
t.BILL_MAJOR_TYPE,
t.BILL_SUB_TYPE_CODE,
t.PAYEE_TYPE_CODE,
t.AMOUNT,
t.REF_NO,
t.REF_DATE,
t.BUDGET_PROVISION,
t.BUDGET_SO_FAR_SPENT,
t.PAYABLE_TO as gpf_no,
t.DEDUCTED_AMOUNT,
    $P{emp_id} AS employee_id,
    (SELECT 
  b.DESIGNATION

FROM HRM_MST_EMPLOYEES a
LEFT OUTER JOIN HRM_EMP_CURRENT_POSTING d
ON a.EMPLOYEE_ID=d.EMPLOYEE_ID
LEFT OUTER JOIN HRM_MST_DESIGNATIONS b
ON d.DESIGNATION_ID=b.DESIGNATION_ID
--WHERE upper(a.EMPLOYEE_NAME) LIKE 'kum'
WHERE a.EMPLOYEE_ID LIKE $P{emp_id}) as designation
  FROM fas_bill_register_master m,
    fas_bill_register_transaction t
  WHERE m.accounting_unit_id     =t.accounting_unit_id
  AND m.accounting_unit_office_id=t.accounting_unit_office_id
  AND m.cashbook_year            =t.cashbook_year
  AND m.cashbook_month           =t.cashbook_month
  AND m.bill_no                  =t.bill_no
  AND m.accounting_unit_id       =$P{unit_id}
  AND m.bill_no                  =$P{voucher_no}
  AND m.cashbook_year            =$P{CASHBOOK_YEAR}
  AND m.cashbook_month           =$P{month}
  )a
LEFT OUTER JOIN
  (SELECT employee_id AS pay_emp_id,
    pay_element_value as pay
  FROM HRM_PAY_EMP_PAYFIX_TRN
  WHERE pay_element_id='E01'
  AND pay_fixation_id =
    (SELECT MAX(pay_fixation_id)
    FROM hrm_pay_emp_payfix_trn
    WHERE employee_id =$P{emp_id}
    )
  )b
 -- on b.pay_emp_id=a.PAYABLE_TO
  
ON b.pay_emp_id=a.employee_id


LEFT OUTER JOIN
    (SELECT EMPLOYEE_INITIAL
      || '.'
      ||employee_name AS employee_name,
      employee_id     AS eid
    FROM hrm_mst_employees
    )d
  ON a.employee_id=d.eid
--  LEFT OUTER JOIN
--    (SELECT designation_id AS desig,designation FROM hrm_mst_designations
--    )e
--  ON e.desig=a.designation_id
  LEFT OUTER JOIN
    (SELECT Office_Id AS Off_Id,Office_Name,District_Code FROM Com_Mst_Offices
    )F
  ON f.off_id=a.OFFICE_ID
  ) ccc
LEFT OUTER JOIN
  (SELECT district_code,district_name FROM com_mst_districts
  )bbb
ON bbb.district_code=ccc.District_Code]]></queryString>

