	<parameter name="catcode" isForPrompting="true" class="java.lang.String"/>
	<parameter name="lab" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fromdt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todt" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select a.lab_code,a.purchase_order_no,a.major_category_code,a.item_code,a.item_spec,a.date_of_receipt,a.qty_received,a.uom_code,b.major_category_desc,d.lab_desc from
(select lab_code,purchase_order_no,major_category_code,item_code,
  (case when major_category_code='CHE' then (select che_specification from wqs_mst_inv_chemical where chemical_code=item_code)
        when major_category_code='GLA' then(select glassware_spec from wqs_mst_inv_glassware where glassware_code=item_code)
        when major_category_code='MIS' then(select miscellaneous_spec from wqs_mst_inv_miscellaneous where miscellaneous_code=item_code)
        else(select inst_category_spec from wqs_mst_inv_instrument where inst_category=item_code
   )end)as item_spec,date_of_receipt,qty_received,uom_code from wqs_item_receipt
)a 
inner join
(select major_category_code,major_category_desc from wqs_mst_inv_category
)b on a.major_category_code=b.major_category_code 
left outer join
(select lab_code,lab_desc from wqs_mst_lab
)d on a.lab_code=d.lab_code 
where a.lab_code=$P{lab} and (a.date_of_receipt between $P{fromdt} and $P{todt}) and a.major_category_code=$P{catcode} 
order by purchase_order_no,item_code,date_of_receipt]]></queryString>

