	<queryString><![CDATA[select a.role_id,decode(a.role_name,null,' ',a.role_name)as role_name,decode(b.office_level_name,null,' ',b.office_level_name)as office_level_name,decode(a.office_level_id,null,' ',a.office_level_id)as office_level_id from sec_mst_roles a left outer join  com_mst_office_levels b on  a.office_level_id=b.office_level_id order by a.office_level_id]]></queryString>

