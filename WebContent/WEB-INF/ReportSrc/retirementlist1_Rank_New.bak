<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="retirementlist1_Rank_New"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<parameter name="rank_id" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select  aa.emp_id,aa.RETIREDATE,aa.emp_status_id,bb.employee_name,bb.date_of_birth,
decode(cc.employee_status_desc,'DEATH','DEATH on ' || aa.retiredate,cc.employee_status_desc) as emp_status_desc,
dd.office_id,dd.designation_id,ee.office_name,ff.designation,to_char(aa.retiredate, 'Month YYYY') as retire_yrmonth,
to_char(aa.retiredate,'mm') as order_month,gg.rank_id,gg.post_rank_name
from
(
select employee_id as emp_id,  date_effective_from as retiredate, 
employee_status_id as emp_status_id
from hrm_emp_current_posting
where employee_status_id in ('VRS','DTH','SAN') 
and date_effective_from between $P{txtfrom} and $P{txtto}
union
select emp_id,retiredate, emp_status_id from 
(
select employee_id as emp_id ,retiredate 
from ALLRETIREMENTVIEW 
where retiredate between $P{txtfrom} and $P{txtto} and 
employee_id not in (select employee_id from hrm_emp_current_posting where employee_status_id  in ('VRS','DTH','SAN'))
) x
left outer join
(
select employee_id as emp_id2, employee_status_id as emp_status_id from hrm_emp_current_posting
) y
on x.emp_id=y.emp_id2
) aa
left outer join
(
select EMPLOYEE_ID as emp_id1, (EMPLOYEE_NAME || ' ' || EMPLOYEE_INITIAL) AS employee_name,date_of_birth from
HRM_MST_EMPLOYEES
) bb
on aa.emp_id=bb.emp_id1
left outer join
(
select employee_status_id,employee_status_desc from hrm_mst_employee_status
) cc
on aa.emp_status_id=cc.employee_status_id
left outer join
(
select employee_id as eid,office_id,designation_id from hrm_emp_current_posting
) dd
on aa.emp_id=dd.eid
left outer join
(
select office_id as off_id,office_name from com_mst_offices
) ee
on dd.office_id=ee.off_id
left outer join
(
select designation_id,designation,post_rank_id from hrm_mst_designations
) ff
on dd.designation_id=ff.designation_id
left outer join
(
select post_rank_id as rank_id ,post_rank_name from hrm_mst_post_ranks
) gg
on ff.post_rank_id=gg.rank_id
where gg.rank_id in ($P!{rank_id})
order by aa.retiredate]]></queryString>

