	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="des_id" isForPrompting="false" class="java.lang.String"/>
	<parameter name="finyear" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select office_name,ciroffname,divoffname,auditoffname,laboffname,post_rank_name,fin_year,region_office_id ,circle_office_id,
division_office_id,auditwing_office_id,lab_office_id,offid2,office_id,
decode(region_office_id,5001,'Northern Region,Vellore',5002,'Western Region,Coimbatore',5003,'Southern Region,Madurai',5004,'Eastern Region,Thanjavur') as regoffname,
postid,post_rank_id, sanctioned_no_of_posts,
 filledup_posts,diversion_to_other,diversion_from_other,total,remainingposts,off_order  from
(
select fin_year,region_office_id,circle_office_id,division_office_id,auditwing_office_id,lab_office_id,
offid2,office_id,postid,post_rank_id, sanctioned_no_of_posts,
 filledup_posts,diversion_to_other,
diversion_from_other,total,(total-filledup_posts) as remainingposts,off_order from
(
select fin_year,region_office_id,circle_office_id,division_office_id,auditwing_office_id,lab_office_id,offid2,office_id,postid,post_rank_id,sanctioned_no_of_posts,filledup_posts,diversion_to_other,
diversion_from_other,(sanctioned_no_of_posts-diversion_to_other+diversion_from_other) as total,
off_order from
(
select fin_year,region_office_id,circle_office_id,division_office_id,auditwing_office_id,lab_office_id,
offid2,office_id,postid,post_rank_id, decode(sanctioned_no_of_posts,null,0,sanctioned_no_of_posts) as sanctioned_no_of_posts,
 decode(filledup_posts,null,0,filledup_posts) as filledup_posts,
 decode(diversion_to_other,null,0,diversion_to_other) as diversion_to_other,
 decode(diversion_from_other,null,0,diversion_from_other) as diversion_from_other,
 off_order from
 ( 
 select * from
(
select  office_id,post_rank_id,region_office_id,circle_office_id,division_office_id,auditwing_office_id,lab_office_id,
off_order from HRM_SANCTION_STRENGTH_VIEW
where office_id is not null
union
select  office_id,post_rank_id,region_office_id,circle_office_id,division_office_id,auditwing_office_id,lab_office_id,
off_order from hrm_sanction_filled_view
where office_id is not null
) aa
left outer join
(
select office_id as offid2, post_rank_id as postid,  filledup_posts
from HRM_SANCTION_FILLED_VIEW 

where office_id in ($P!{off_id}) 

) bb
on aa.office_id = bb.offid2 and aa.post_rank_id=bb.postid
left outer join
(
select fin_year, office_id as offid, post_rank_id as postrankid, 
 sanctioned_no_of_posts,diversion_to_other,
diversion_from_other from HRM_SANCTION_STRENGTH_VIEW
where office_id in ($P!{off_id})  and fin_year in($P{finyear})
)cc
on aa.office_id=cc.offid and aa.post_rank_id=cc.postrankid 
)
)
)

where office_id in ($P!{off_id}) and post_Rank_id in (select post_rank_id  from hrm_mst_post_Ranks)

)xyz
left outer join
(
select office_id as offid3, office_name from com_mst_offices
)xyz1
on xyz.office_id=xyz1.offid3
left outer join
(
select post_rank_id as psid,post_rank_name from hrm_mst_post_ranks 
)xyz2
on xyz.post_rank_id=xyz2.psid
left outer join
(
select office_id as offid4, office_name as ciroffname from com_mst_offices
)xyz3
on  xyz.circle_office_id=xyz3.offid4
left outer join
(
select office_id as offid5, office_name as divoffname from com_mst_offices
)xyz4
on  xyz.division_office_id=xyz4.offid5
left outer join
(
select office_id as offid6, office_name as auditoffname from com_mst_offices
)xyz5
on  xyz.auditwing_office_id=xyz5.offid6
left outer join
(
select office_id as offid7, office_name as laboffname from com_mst_offices
)xyz6
on  xyz.lab_office_id=xyz6.offid7

order by off_order,region_office_id,circle_office_id,division_office_id,auditwing_office_id,lab_office_id,post_rank_id]]></queryString>

