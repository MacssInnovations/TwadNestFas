	<parameter name="copyto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="empid" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select employee_id,empname,office_Name,designation,relieval_reason_desc,date_of_relieval,relieval_fn_an  from
(
select employee_id,Relieval_Reason_id,date_of_relieval,relieval_fn_an,office_id 
from hrm_emp_relieval_details where employee_id in($P!{empid}) and process_flow_status_id='FR'
)a
left outer join
(
select employee_id as empid1,(employee_prefix||'.'||employee_name||'.'||employee_initial) as empname from hrm_mst_employees
)b
on a.employee_id=b.empid1
left outer join 
(
select relieval_reason_id as reasonid,relieval_reason_desc from hrm_mst_relieval_reasons
)c
on a.relieval_reason_id=c.reasonid
left outer join
(
select employee_id as empid2,designation_id from hrm_emp_current_posting 
)d
on a.employee_id=d.empid2
 left outer join
(
select designation_id as desigid,designation from hrm_mst_designations
)e
on d.designation_id=e.desigid
left outer join
(
select office_id as offid,office_Name from com_mst_offices
)f
on a.office_id=f.offid]]></queryString>

