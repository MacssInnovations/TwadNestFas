	<parameter name="lab" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fromdt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="catdesc" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select bb.LAB_CODE,bb.PURCHASE_ORDER_NO,b.PURCHASE_ORDER_DATE,c.SUPPLIER_NAME,d.MAJOR_CATEGORY_DESC,a.QTY_ORDERED,a.ORDERED_UOM_CODE,a.QTY_RECEIVED_SOFAR,a.RECEIVED_UOM_CODE,a.qty_avail,d.MAJOR_CATEGORY_DESC,aa.LAB_DESC,e.INST_CATEGORY_SPEC from
(select distinct LAB_CODE,PURCHASE_ORDER_NO from WQS_ITEM_PUR_ORDER_DETAILS)bb 
inner join(select LAB_CODE,PURCHASE_ORDER_NO,CURRENT_STATUS,MAJOR_CATEGORY_CODE,ITEM_CODE,QTY_ORDERED,QTY_RECEIVED_SOFAR,ORDERED_UOM_CODE,RECEIVED_UOM_CODE,(QTY_ORDERED-QTY_RECEIVED_SOFAR) as qty_avail from WQS_ITEM_PUR_ORDER_DETAILS)a on bb.LAB_CODE=a.LAB_CODE and bb.PURCHASE_ORDER_NO=a.PURCHASE_ORDER_NO
inner join(select LAB_CODE,PURCHASE_ORDER_NO,PURCHASE_ORDER_DATE,SUPPLIER_CODE from WQS_ITEM_PUR_ORDER_MASTER
	  )b on a.LAB_CODE=b.LAB_CODE and a.PURCHASE_ORDER_NO=b.PURCHASE_ORDER_NO 
inner join(select LAB_CODE,SUPPLIER_CODE,SUPPLIER_NAME from WQS_MST_INV_SUPPLIER)c on a.LAB_CODE=c.LAB_CODE and b.SUPPLIER_CODE=c.SUPPLIER_CODE 
left outer join(select MAJOR_CATEGORY_CODE,MAJOR_CATEGORY_DESC from WQS_MST_INV_CATEGORY)d on a.MAJOR_CATEGORY_CODE=d.MAJOR_CATEGORY_CODE 
left outer join(select INST_CATEGORY,INST_CATEGORY_SPEC from WQS_MST_INV_INSTRUMENT)e on a.ITEM_CODE=e.INST_CATEGORY
left outer join
(
  select LAB_CODE,LAB_DESC from WQS_MST_LAB
)aa on a.LAB_CODE=aa.LAB_CODE	
where a.LAB_CODE=$P{lab} and a.CURRENT_STATUS NOT IN('T') and (b.PURCHASE_ORDER_DATE between $P{fromdt} and $P{todt}) and d.MAJOR_CATEGORY_DESC=$P{catdesc} order by PURCHASE_ORDER_NO,PURCHASE_ORDER_DATE,SUPPLIER_NAME]]></queryString>

