<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Deputation_Final_Proceedingv2"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="order" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="office" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="suffix" isForPrompting="true" class="java.lang.String"/>
	<parameter name="pwhole" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fwd" isForPrompting="true" class="java.lang.String"/>
	<parameter name="copyto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="no_date" isForPrompting="true" class="java.lang.String"/>
	<parameter name="proceed" isForPrompting="true" class="java.lang.String"/>
	<parameter name="address" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sd" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fwddesig" isForPrompting="true" class="java.lang.String"/>
	<parameter name="new" isForPrompting="true" class="java.lang.String"/>
	<parameter name="comment" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.deputn_issue_office_id,a.deputn_order_id,a.employee_id,a.to_which_office_id,decode(a.reposts_required,'Y','Yes','N','No') as reposts_required , 
a.dpn_designation,a.reason,decode(a.ta_da_eligible,'Y','Yes','N','No')as ta_da_eligible,b.proceeding_date,b.proceeding_no,
b.proceed_subject,decode(b.proceed_subject,null,null,'Sub : ' || b.proceed_subject) as proced_subj,
b.proceed_reference,decode(b.proceed_reference,null,null,'Ref : ' || b.proceed_reference) as proced_refr,
b.addl_para_1,b.addl_para_2,b.copy_to,b.presiding_officer,
b.presiding_officer_designation,b.signed,b.suffix,c.employee_name,d.trf_office_name,j.new_office_name,g.current_designation,
a.dpn_designation,h.new_designation,i.other_deptname as other_deptname,org_office_name
from 
( 
select deputn_issue_office_id,deputn_order_id,employee_id,to_which_office_id,reposts_required,dpn_designation, 
process_flow_status_id,reason_id,ta_da_eligible,new_designation,other_dept_id,reason
from HRM_deputn_DETAILS 
where process_flow_status_id in ('FR')
) a
left outer join 
( 
select deputn_issue_office_id as trf_off_id,deputn_order_id as trf_ord_id,proceeding_date,proceeding_no,proceed_subject,proceed_reference, 
addl_para_1,addl_para_2,copy_to,presiding_officer,presiding_officer_designation,process_flow_status_id,signed_po as signed,suffix 
from HRM_deputn_ORDERS 
where process_flow_status_id in ('FR') 
) b 
on a.deputn_issue_office_id=b.trf_off_id and a.deputn_order_id=b.trf_ord_id 
left outer join 
( 
select employee_id as emp_id, employee_prefix || '.' || employee_name || '.' || employee_initial as employee_name from 
hrm_mst_employees 
) c 
on a.employee_id=c.emp_id 
left outer join 
( 
select office_id,office_name as trf_office_name from com_mst_offices 
where office_status_id not in ('CL','RD','NC')
) d 
on a.deputn_issue_office_id=d.office_id
left outer join
( 
select employee_id as emp_id2, office_id as off_id2, designation_id as desig_id2 from hrm_emp_current_posting 
where employee_status_id in 'WKG' and process_flow_status_id in 'FR' 
) f 
on a.employee_id=f.emp_id2 
left outer join 
( 
select office_id,office_name as org_office_name from com_mst_offices 
where office_status_id not in ('CL','RD','NC')
) e
on f.off_id2=e.office_id
left outer join 
( 
select designation_id as desig_id3, designation as current_designation from hrm_mst_designations 
) g 
on f.desig_id2=g.desig_id3
left outer join 
( 
select designation_id as desig_id3, designation as new_designation from hrm_mst_designations 
) h
on a.new_designation=h.desig_id3
left outer join
(
select other_dept_id, other_dept_name as other_deptname from hrm_mst_other_depts 
)i
on i.other_dept_id=a.other_dept_id
left outer join
(
select other_dept_id,other_dept_office_id,other_dept_office_name as new_office_name from hrm_mst_other_dept_offices
)j
on j.other_dept_office_id=a.to_which_office_id and j.other_dept_id=a.other_dept_id
where a.deputn_issue_office_id=$P{office} and a.deputn_order_id=$P{order}]]></queryString>

