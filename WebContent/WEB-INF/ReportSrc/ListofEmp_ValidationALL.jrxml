	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select EMP_ID,Employee_Name,OFFICE_NAME,decode( add_detail_avail,null,'NO',add_detail_avail ) add_detail_avail, decode(add_detail_valid ,null,'NO', add_detail_valid ) add_detail_valid,
decode( crtl_office_avail,null,'NO',crtl_office_avail  ) crtl_office_avail, decode(crtl_office_valid ,null,'NO',crtl_office_valid  ) crtl_office_valid, decode(current_posting_avail ,null,'NO',current_posting_avail  ) current_posting_avail,
decode( current_posting_valid,null,'NO',current_posting_valid  ) current_posting_valid,
to_char(decode(cnt,null,'YES','NO')) count,SR_RECORD 
from 
(

select a.EMPLOYEE_ID EMP_ID,b.Employee_Name||decode(b.Employee_Initial,null,' ','.'||b.Employee_Initial) Employee_Name ,b.GPF_NO,
c.OFFICE_NAME
from HRM_EMP_CONTROLLING_OFFICE a
inner join HRM_MST_EMPLOYEES b on  b.EMPLOYEE_ID =a.EMPLOYEE_ID
inner join COM_MST_ALL_OFFICES_VIEW c on c.OFFICE_ID=a.CONTROLLING_OFFICE_ID
inner join COM_MST_OFFICE_LEVELS d on d.OFFICE_LEVEL_ID=c.OFFICE_LEVEL_ID
WHERE c.OFFICE_ID in ($P!{offids})
ORDER BY HIERARCHICAL_SEQUENCE,c.office_id,a.employee_id
) x
left outer join
(
select decode(PROCESS_FLOW_STATUS_ID,null,'NO','YES') add_detail_avail,decode(PROCESS_FLOW_STATUS_ID,null,'NO','FR','YES','NO') add_detail_valid,EMPLOYEE_ID from HRM_MST_EMP_ADDL_TMP where   PROCESS_FLOW_STATUS_ID!='DL'  or PROCESS_FLOW_STATUS_ID is null
) y on y.EMPLOYEE_ID=x.EMP_ID
left outer join 
(
select decode(PROCESS_FLOW_STATUS_ID,null,'NO','YES') crtl_office_avail,decode(PROCESS_FLOW_STATUS_ID,null,'NO','FR','YES','NO') crtl_office_valid,EMPLOYEE_ID from HRM_EMP_CONTROLLING_OFFICE_TMP  where  PROCESS_FLOW_STATUS_ID!='DL'  or PROCESS_FLOW_STATUS_ID is null
)z on z.EMPLOYEE_ID=x.EMP_ID
left outer join 
(
select decode(PROCESS_FLOW_STATUS_ID,null,'NO','YES') current_posting_avail,decode(PROCESS_FLOW_STATUS_ID,null,'NO','FR','YES','NO') current_posting_valid ,EMPLOYEE_ID from HRM_EMP_CURRENT_POSTING_TMP  where  PROCESS_FLOW_STATUS_ID!='DL'  or PROCESS_FLOW_STATUS_ID is null
)a on a.EMPLOYEE_ID=x.EMP_ID
left outer join 
(
select DISTINCT TO_CHAR(EMPLOYEE_ID) SR_RECORD from HRM_EMP_SERVICE_DATA 
) b on b.SR_RECORD=TO_CHAR(x.EMP_ID)
left outer join 
(
select COUNT(*) as cnt,EMPLOYEE_ID FROM HRM_EMP_SERVICE_DATA where (PROCESS_FLOW_STATUS_ID!='FR' or  PROCESS_FLOW_STATUS_ID is null) group by EMPLOYEE_ID
) c on c.EMPLOYEE_ID=x.EMP_ID]]></queryString>

