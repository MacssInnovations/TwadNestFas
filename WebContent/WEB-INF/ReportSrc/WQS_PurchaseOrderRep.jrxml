	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="lab" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="ono" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(select LAB_CODE,PURCHASE_ORDER_NO,MAJOR_CATEGORY_CODE,ITEM_CODE,
  (case when MAJOR_CATEGORY_CODE='CHE' then (select che_specification from wqs_mst_inv_chemical where chemical_code=ITEM_CODE)
        when MAJOR_CATEGORY_CODE='GLA' then(select GLASSWARE_SPEC from WQS_MST_INV_GLASSWARE where GLASSWARE_CODE=ITEM_CODE)
        when MAJOR_CATEGORY_CODE='MIS' then(select MISCELLANEOUS_SPEC from WQS_MST_INV_MISCELLANEOUS where MISCELLANEOUS_CODE=ITEM_CODE)
        else(select INST_CATEGORY_SPEC from WQS_MST_INV_INSTRUMENT where INST_CATEGORY=ITEM_CODE)end
  )as ITEM_SPEC,QTY_ORDERED,QTY_RECEIVED_SOFAR,CURRENT_STATUS,PROCESS_FLOW_STATUS_ID,
  (case when PROCESS_FLOW_STATUS_ID='FR' then 'Freezed'
	when PROCESS_FLOW_STATUS_ID='MD' then 'Modified'
	when PROCESS_FLOW_STATUS_ID='CL' then 'Cancelled'
	else 'Created' end
  )as flow_status,RECONCILIATION_QTY,RECONCILIATION_REMARKS from WQS_ITEM_PUR_ORDER_DETAILS
)a 
inner join(select MAJOR_CATEGORY_CODE,MAJOR_CATEGORY_DESC from WQS_MST_INV_CATEGORY
)b on a.MAJOR_CATEGORY_CODE=b.MAJOR_CATEGORY_CODE
left outer join(select LAB_CODE,LAB_DESC FROM WQS_MST_LAB)c on a.LAB_CODE=c.LAB_CODE
where a.LAB_CODE=$P{lab} and a.PURCHASE_ORDER_NO=$P{ono} order by b.MAJOR_CATEGORY_DESC]]></queryString>

