	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="status_id" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.employee_id,designation_id,employee_status_id,employee_name,designation,employee_status_desc,
date_effective_from,office_name from
(
select employee_id,designation_id,employee_status_id,date_effective_from,office_id,department_id
from hrm_emp_current_posting
where employee_status_id in ($P!{status_id}) and employee_status_id not in ('SAN','DIS','DTH','RES','VRS')
) a
left outer join
(
select employee_id as emp_id, employee_name || '.' || employee_initial as employee_name from
hrm_mst_employees
) b
on a.employee_id=b.emp_id
left outer join
(
select designation_id as desig_id,designation,ordering_sequence_no from hrm_mst_designations
) c
on a.designation_id=c.desig_id
left outer join
(
select employee_status_id as emp_stat_id,employee_status_desc from hrm_mst_employee_status
where employee_status_id not in ('SAN','DIS','DTH','RES','VRS')
) d
on a.employee_status_id=d.emp_stat_id
left outer join
(
select 'TWAD' as dept_id,office_id as off_id,office_name from com_mst_offices
union
select other_dept_id as dept_id,other_dept_office_id as off_id,other_dept_office_name as office_name
from hrm_mst_other_dept_offices
) e
on a.office_id=e.off_id and a.department_id=e.dept_id
order by c.ordering_sequence_no]]></queryString>

