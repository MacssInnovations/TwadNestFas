	<parameter name="mon" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="yea" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select a.employee_id,a.office_id,a.date_of_relieval,a.relieval_slno,a.remarks,b.office_name,(c.EMPLOYEE_NAME||'.'||c.employee_initial)as employee_name ,c.DATE_OF_BIRTH,
d.designation_id,d.date_effective_from,e.designation,e.service_group_id,f.leave_type_id,f.period_from,f.period_to,
f.relieval_slno,g.service_group_name,h.leave_type_code,h.leave_type_desc
from HRM_EMP_RELIEVAL_DETAILS a
inner join  HRM_MST_EMPLOYEES c on c.EMPLOYEE_ID=a.EMPLOYEE_ID
inner join  HRM_EMP_CURRENT_POSTING d on d.employee_id=a.employee_id
inner join  com_mst_offices b on  b.office_id = a.office_id
inner join  HRM_MST_DESIGNATIONS e on e.designation_id=d.designation_id
inner join  HRM_EMP_RELIEVAL_LLV f on f.relieval_slno = a.relieval_slno AND f.employee_id= a.employee_id
inner join  HRM_MST_SERVICE_GROUP g on g.service_group_id=e.service_group_id
inner join  HRM_MST_LEAVE_TYPES h on h.leave_type_code=f.leave_type_id
where a.RELIEVAL_REASON_ID in('LLV','SUS','SAN')
order by g.service_group_name,b.office_name,e.designation]]></queryString>

