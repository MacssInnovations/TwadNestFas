		 isIgnorePagination="true">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="Div" isForPrompting="true" class="java.lang.String"/>
	<parameter name="Off" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT
  BENEFICIARY_NAME,
  BEN_TYPE_DESC,
  DECODE(DISTRICT_NAME,NULL,'  -',DISTRICT_NAME) AS DISTRICT_NAME,
  DECODE(BLOCK_NAME,NULL,'  -',BLOCK_NAME) AS BLOCK_NAME,
  BILLING_ADDRESS1,
  BILLING_ADDRESS2,
  BILLING_ADDRESS3
FROM
(
  (
    SELECT 
      BENEFICIARY_NAME,
      BENEFICIARY_TYPE_ID, 
      DISTRICT_CODE,
      BLOCK_SNO,
      BILLING_ADDRESS1,
      BILLING_ADDRESS2,
      BILLING_ADDRESS3
    FROM PMS_DCB_MST_BENEFICIARY
    WHERE OFFICE_ID=$P{Off}
    ORDER BY BENEFICIARY_TYPE_ID
  )a
  
  LEFT OUTER JOIN
  
  (
    SELECT
      BEN_TYPE_ID,
      BEN_TYPE_DESC
    FROM PMS_DCB_BEN_TYPE
  )b
  
  ON a.BENEFICIARY_TYPE_ID = b.BEN_TYPE_ID
  LEFT OUTER JOIN
  
  (
    SELECT
      DISTRICT_CODE,
      DISTRICT_NAME
    FROM COM_MST_DISTRICTS
  )c
  
  ON a.DISTRICT_CODE = c.DISTRICT_CODE
  LEFT OUTER JOIN
  
  (
    SELECT
      BLOCK_SNO,
      BLOCK_NAME
    FROM COM_MST_BLOCKS
  )d
  
  ON a.BLOCK_SNO = d.BLOCK_SNO
  
)]]></queryString>

