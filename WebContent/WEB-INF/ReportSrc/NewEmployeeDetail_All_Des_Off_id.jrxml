	<queryString><![CDATA[select upper(d.OFFICE_NAME) as OFFICE_NAME,upper(c.DESIGNATION)as DESIGNATION,a.EMPLOYEE_ID,
a.EMPLOYEE_NAME||decode(a.EMPLOYEE_INITIAL,null,' ','.'||a.EMPLOYEE_INITIAL) EMPLOYEE_NAME,
to_char(decode( b.DATE_EFFECTIVE_FROM,null,' ', to_char(b.DATE_EFFECTIVE_FROM,'dd/mm/yyyy')  )) DATE_OF_JOINING ,
decode(a.REMARKS,null,' ',a.REMARKS) REMARKS

from HRM_MST_EMPLOYEES a, HRM_EMP_CURRENT_POSTING b ,HRM_MST_DESIGNATIONS c ,COM_MST_OFFICES d ,COM_MST_OFFICE_LEVELS e 
where a.EMPLOYEE_ID = b.EMPLOYEE_ID and  c.DESIGNATION_ID = b.DESIGNATION_ID and d.OFFICE_ID = b.OFFICE_ID and e.OFFICE_LEVEL_ID = d.OFFICE_LEVEL_ID
 

order by  e.HIERARCHICAL_SEQUENCE,OFFICE_NAME,c.ORDERING_SEQUENCE_NO,EMPLOYEE_ID]]></queryString>

