	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select * from
(
select * from
(
select * from
(
select a.division_office_id,upper(b.division_office_name)as division_name,a.subdivision_office_id
from COM_MST_SUBDIVISIONS_HVIEW a,COM_MST_DIVISIONS_HVIEW b
where a.division_office_id=b.division_office_id
)i
left outer join
(
select upper(c.OFFICE_NAME) as REGION_OFFICE_NAME, d.subdivision_office_id as sub_div
from com_mst_offices c,com_mst_SUBDIVISIONS_HVIEW d
where c.office_id=d.region_office_id
)j
on j.sub_div=i.subdivision_office_id
)k
left outer join
(
select upper(e.office_name) as circle_name,f.subdivision_office_id
from com_mst_offices e,com_mst_SUBDIVISIONS_HVIEW f
where e.office_id=f.circle_office_id
)l
on k.sub_div=l.subdivision_office_id
)m
left outer join
(
select upper(h.office_name) as office_name ,g.subdivision_office_id,
decode(h.OFFICE_ADDRESS1,null,' ',h.OFFICE_ADDRESS1  ) OFFICE_ADDRESS1 ,
decode(h.OFFICE_ADDRESS2,null,' ',h.OFFICE_ADDRESS2  ) OFFICE_ADDRESS2 ,
decode(h.CITY_TOWN_NAME,null,' ', h.CITY_TOWN_NAME ) CITY_TOWN_NAME ,
decode(h.OFFICE_PIN_CODE,null,' ',h.OFFICE_PIN_CODE  ) OFFICE_PIN_CODE ,
decode(h.OFFICE_EMAIL_ID,null,' ',h.OFFICE_EMAIL_ID  ) OFFICE_EMAIL_ID ,
decode(h.OFFICE_STD_CODE,null,' ', h.OFFICE_STD_CODE ) OFFICE_STD_CODE ,
decode(h.OFFICE_PHONE_NO,null,' ', h.OFFICE_PHONE_NO  ) OFFICE_PHONE_NO ,
decode(h.OFFICE_FAX_NO,null,' ', h.OFFICE_FAX_NO ) OFFICE_FAX_NO 
from com_mst_offices h,com_mst_SUBDIVISIONS_HVIEW g
where h.office_id=g.subdivision_office_id
)n
on m.sub_div=n.subdivision_office_id
order by REGION_OFFICE_NAME,circle_name,division_name,OFFICE_NAME]]></queryString>

