	<queryString><![CDATA[select d.office_name,c.post_rank_name,a.SANCTIONED_NO_OF_POSTS,a.diversion_to_other,a.diversion_from_other,a.sanctioned_no_of_posts-a.diversion_to_other+a.diversion_from_other result from hrm_ss_sanction_details a,hrm_ss_sanction b,hrm_mst_post_ranks c,com_mst_offices d where 
a.office_id=b.office_id and a.fin_year=b.fin_year
and c.post_rank_id=a.post_rank_id 
and d.office_id=a.office_id
and a.office_id in ($P!{txtofficeid}) and a.fin_year=($P{finyear}) order by a.post_rank_id]]></queryString>

