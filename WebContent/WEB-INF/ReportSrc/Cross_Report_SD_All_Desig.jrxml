	<parameter name="finyear" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select office_name,office_short_name, (to_char(post_rank_id,'999') || ' ' || ' ' || ' ' || post_rank_name) as post_rank_name, sanctioned_no_of_posts  from
(
select office_id , post_rank_id, sanctioned_no_of_posts,fin_year from HRM_SS_SANCTION_DETAILS
) a
left outer join
(
select office_id as office_id1, office_name,office_short_name from com_mst_offices
where office_level_id ='SD'
) b
on a.office_id = b.office_id1
left outer join
(
select post_rank_id as post_rank_id1, post_rank_name from hrm_mst_post_ranks
) c
on a.post_rank_id = c.post_rank_id1
where office_name is not null and a.fin_year=($P{finyear})
order by office_id,post_rank_id]]></queryString>

