	<queryString><![CDATA[select b.OFFICE_LEVEL_NAME,b.HIERARCHICAL_SEQUENCE,count(a.OFFICE_LEVEL_ID)as cnt 
from COM_MST_OFFICES a
inner join COM_MST_OFFICE_LEVELS b on a.OFFICE_LEVEL_ID=b.OFFICE_LEVEL_ID
where (A.OFFICE_STATUS_ID not in ('CL','RD', 'NC') OR A.OFFICE_STATUS_ID IS NULL)
group by b.OFFICE_LEVEL_NAME,b.HIERARCHICAL_SEQUENCE
order by HIERARCHICAL_SEQUENCE]]></queryString>

