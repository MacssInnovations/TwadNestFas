	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select upper(a.REGION_OFFICE_NAME) REGION_OFFICE_NAME,upper(c.DESIGNATION) DESIGNATION,count(d.EMPLOYEE_NAME) count

from COM_MST_REGIONS_HVIEW a

inner join HRM_EMP_CURRENT_POSTING b on b.OFFICE_ID = a.REGION_OFFICE_ID
inner join HRM_MST_DESIGNATIONS c on c.DESIGNATION_ID = b.DESIGNATION_ID
inner join HRM_MST_EMPLOYEES d on d.EMPLOYEE_ID = b.EMPLOYEE_ID

group by a.REGION_OFFICE_NAME,c.DESIGNATION
order by REGION_OFFICE_NAME,DESIGNATION]]></queryString>

	<field name="REGION_OFFICE_NAME" class="java.lang.String"/>
	<field name="DESIGNATION" class="java.lang.String"/>
	<field name="COUNT" class="java.math.BigDecimal"/>

	<variable name="SUM_COUNT_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
