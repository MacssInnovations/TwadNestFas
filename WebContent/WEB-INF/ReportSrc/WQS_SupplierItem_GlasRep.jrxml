	<parameter name="scode" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from(select SUPPLIER_CODE,MAJOR_CATEGORY_CODE,ITEM_CODE from WQS_MST_INV_SUP_ITEM)a inner join(select SUPPLIER_CODE,SUPPLIER_NAME from WQS_MST_INV_SUPPLIER)b on a.SUPPLIER_CODE=b.SUPPLIER_CODE left outer join(select MAJOR_CATEGORY_CODE,MAJOR_CATEGORY_DESC from WQS_MST_INV_CATEGORY)c on a.MAJOR_CATEGORY_CODE=c.MAJOR_CATEGORY_CODE left outer join(select GLASSWARE_CODE,GLASSWARE_SPEC from WQS_MST_INV_GLASSWARE)d on a.ITEM_CODE=d.GLASSWARE_CODE  where a.SUPPLIER_CODE=$P{scode} and(c.MAJOR_CATEGORY_DESC='glassware' or c.MAJOR_CATEGORY_DESC='Glassware' or c.MAJOR_CATEGORY_DESC='GLASSWARE')]]></queryString>

	<field name="SUPPLIER_CODE" class="java.lang.String"/>
	<field name="MAJOR_CATEGORY_CODE" class="java.lang.String"/>
