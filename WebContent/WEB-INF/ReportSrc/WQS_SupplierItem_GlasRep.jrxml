	<field name="SUPPLIER_NAME" class="java.lang.String"/>
	<field name="MAJOR_CATEGORY_DESC" class="java.lang.String"/>
	<field name="GLASSWARE_CODE" class="java.lang.String"/>
	<field name="GLASSWARE_SPEC" class="java.lang.String"/>


