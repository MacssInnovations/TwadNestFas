	<parameter name="emp_id" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.employee_id,a.employee_name||decode(a.employee_initial,null,' ','.'||a.employee_initial) employee_name,c.designation,e.office_name controlling_office_name,
g.designation service_designation,f.DATE_FROM,f.DATE_FROM_SESSION,f.DATE_TO,f.DATE_TO_SESSION,h.office_name||i.OTHER_DEPT_OFFICE_NAME service_office_name,
j.EMPLOYEE_STATUS_DESC,b1.office_name||b2.OTHER_DEPT_OFFICE_NAME current_office,b.date_effective_from,b3.EMPLOYEE_STATUS_DESC current_status,
B1.office_name||B2.OTHER_DEPT_OFFICE_NAME CURRENT_OFFICE_NAME
from hrm_mst_employees a
left outer join hrm_emp_current_posting b on b.employee_id= a.employee_id

left outer join com_mst_offices b1 on b1.office_id=b.office_id
left outer join hrm_mst_other_dept_offices b2 on b2.OTHER_DEPT_OFFICE_ID =b.office_id and b2.OTHER_DEPT_ID=b.DEPARTMENT_ID
left outer join hrm_mst_employee_status b3 on b3.EMPLOYEE_STATUS_ID = b.EMPLOYEE_STATUS_ID


left outer join hrm_mst_designations c on c.designation_id=b.designation_id
left outer join hrm_emp_controlling_office d on d.employee_id=a.employee_id
left outer join com_mst_offices e on e.office_id=d.controlling_office_id
left outer join com_mst_office_levels e1 on e1.office_level_id=e.office_level_id
left outer join hrm_emp_service_data f on f.employee_id=a.employee_id
left outer join hrm_mst_designations g on g.designation_id=f.designation_id
left outer join com_mst_offices h on h.office_id=f.office_id
left outer join hrm_mst_other_dept_offices i on i.OTHER_DEPT_OFFICE_ID =f.office_id and i.OTHER_DEPT_ID	=f.OFFICE_DEPT_ID
left outer join hrm_mst_employee_status j on j.EMPLOYEE_STATUS_ID = f.EMPLOYEE_STATUS_ID
where a.employee_id=$P{emp_id}
order by e1.HIERARCHICAL_SEQUENCE,controlling_office_name,a.employee_id,f.DATE_FROM asc]]></queryString>

	<field name="EMPLOYEE_ID" class="java.lang.Integer"/>
	<field name="EMPLOYEE_NAME" class="java.lang.String"/>
