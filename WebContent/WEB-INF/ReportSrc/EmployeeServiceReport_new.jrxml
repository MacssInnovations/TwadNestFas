	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<parameter name="emp_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="order_type" isForPrompting="true" class="java.lang.String"/>
	<parameter name="sel_design" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
    select
          EMP_NAME,
          OFFICE_ID,
          EMPLOYEE_ID,
          QUALIFICATIONS,
          OFFICE_NAME,
          CONTROL_OFFICE_NAME,
          DATE_EFFECTIVE_FROM,
          decode(rws_yr,'',0,rws_yr) as rws_yr,
          decode(rws_months,'',0,rws_months) as rws_months,
          decode(urb_yr,'',0,urb_yr) as urb_yr,
          decode(urb_months,'',0,urb_months)as urb_months,
          decode(sew_yr,'',0,sew_yr)as sew_yr,
          decode(sew_months,'',0,sew_months)as sew_months,
          decode(main_yr,'',0,main_yr)as main_yr,
	  decode(main_months,'',0,main_months)as main_months,
          decode(pf_yr,'',0,pf_yr)as pf_yr,
	  decode(pf_months,'',0,pf_months)as pf_months,
          decode(off_yr,'',0,off_yr)as off_yr,
	  decode(off_months,'',0,off_months)as off_months,
          decode(dpn_yr,'',0,dpn_yr)as dpn_yr,
	  decode(dpn_months,'',0,dpn_months)as dpn_months,
          (decode(rws_yr,'',0,rws_yr)+decode(urb_yr,'',0,urb_yr)+decode(sew_yr,'',0,sew_yr)+decode(main_yr,'',0,main_yr)+decode(pf_yr,'',0,pf_yr)+decode(off_yr,'',0,off_yr)+decode(dpn_yr,'',0,dpn_yr)
          + floor((decode(rws_months,'',0,rws_months)+decode(urb_months,'',0,urb_months)
                 + decode(sew_months,'',0,sew_months)+decode(main_months,'',0,main_months)
                 + decode(pf_months,'',0,pf_months) + decode(off_months,'',0,off_months)
                 + decode(dpn_months,'',0,dpn_months))/12)) as total_yr,
   
          mod((decode(rws_months,'',0,rws_months)+decode(urb_months,'',0,urb_months)+decode(sew_months,'',0,sew_months)+decode(main_months,'',0,main_months)+decode(pf_months,'',0,pf_months)+decode(off_months,'',0,off_months)+decode(dpn_months,'',0,dpn_months)),12) as total_month       
      from
    (
          select 
              EMP_NAME,
              OFFICE_ID,
              EMPLOYEE_ID,
              QUALIFICATIONS,
              OFFICE_NAME,
              CONTROL_OFFICE_NAME,
              DATE_EFFECTIVE_FROM,
              floor(TOTAL_RWS/365)as rws_yr,
              floor(mod(TOTAL_RWS,365)/30.5) as rws_months,   
              floor(TOTAL_URBAN/365)as urb_yr,
              floor(mod(TOTAL_URBAN,365)/30.5) as urb_months,   
              floor(TOTAL_SEWAGE/365)as sew_yr,
              floor(mod(TOTAL_SEWAGE,365)/30.5) as sew_months,   
              floor(TOTAL_MAINT/365)as main_yr,
              floor(mod(TOTAL_MAINT,365)/30.5) as main_months, 
              floor(TOTAL_PF/365)as pf_yr,
              floor(mod(TOTAL_PF,365)/30.5) as pf_months,
              floor(TOTAL_OFFICE/365)as off_yr,
              floor(mod(TOTAL_OFFICE,365)/30.5) as off_months,
              floor(TOTAL_DPN/365)as dpn_yr,
              floor(mod(TOTAL_DPN,365)/30.5) as dpn_months
          from 
              HRM_CALC_TYPEOFSERVICE_FINAL
          where 
              employee_id in($P!{emp_id})
                   and
              office_id in($P!{offids})
      )
)a 
left outer join
(
    select
        office_id as offid,
        off_order
    from
        com_mst_all_offices_view
)b
on a.office_id=b.offid
$P!{order_type}]]></queryString>

