		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="2" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select * from (
select upper(b.REGION_OFFICE_NAME) as REGION_OFFICE_NAME  ,a.REGION_OFFICE_ID,
upper(c.OFFICE_NAME) as CIRCLE_OFFICE_NAME,c.OFFICE_ID,upper(d.OFFICE_NAME) AS DIVISION_OFFICE_NAME,
count(a.SUBDIVISION_OFFICE_ID) as count,a.DIVISION_OFFICE_ID

from COM_MST_SUBDIVISIONS_HVIEW a
inner join COM_MST_REGIONS_HVIEW b on a.REGION_OFFICE_ID=b.REGION_OFFICE_ID 
inner join COM_MST_OFFICES c on c.OFFICE_ID=a.CIRCLE_OFFICE_ID 

inner join COM_MST_OFFICES d on d.OFFICE_ID=a.DIVISION_OFFICE_ID

group by REGION_OFFICE_NAME,a.REGION_OFFICE_ID,c.OFFICE_NAME,c.OFFICE_ID,d.OFFICE_NAME,a.DIVISION_OFFICE_ID
) x
left outer join(

select SUBDIVISION_OFFICE_NAME,SUBDIVISION_OFFICE_ID,DIVISION_OFFICE_ID div_id from COM_MST_SUBDIVISIONS_HVIEW
) y on y.div_id =x.DIVISION_OFFICE_ID
order by REGION_OFFICE_ID,OFFICE_ID,DIVISION_OFFICE_ID,SUBDIVISION_OFFICE_ID]]></queryString>

	<field name="REGION_OFFICE_NAME" class="java.lang.String"/>
	<field name="REGION_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="CIRCLE_OFFICE_NAME" class="java.lang.String"/>
	<field name="OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="DIVISION_OFFICE_NAME" class="java.lang.String"/>
	<field name="COUNT" class="java.math.BigDecimal"/>
	<field name="DIVISION_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="SUBDIVISION_OFFICE_NAME" class="java.lang.String"/>
	<field name="SUBDIVISION_OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="DIV_ID" class="java.math.BigDecimal"/>

