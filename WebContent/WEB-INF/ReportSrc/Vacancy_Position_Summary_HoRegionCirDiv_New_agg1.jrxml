	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="off_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="des_id" isForPrompting="true" class="java.lang.String"/>
	<parameter name="finyear" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select office_level_id,office_name,post_rank_name,region_office_id,circle_office_id,division_office_id ,'' as office_id,
 post_rank_id,filledup_posts,sanctioned_no_of_posts,
 diversion_to_other,diversion_from_other,total,remainingposts,off_order
 from
 (
 select region_office_id,circle_office_id,division_office_id ,post_rank_id,sum(filledup_posts) as filledup_posts,
 sum(sanctioned_no_of_posts) as sanctioned_no_of_posts,sum(diversion_to_other) as diversion_to_other,
 sum(diversion_from_other) as diversion_from_other, sum(total) as total,sum(remainingposts) as remainingposts from
(
select fin_year,region_office_id,circle_office_id,division_office_id,offid2,office_id,postid,post_rank_id, sanctioned_no_of_posts,
 filledup_posts,diversion_to_other,
diversion_from_other,total,(total-filledup_posts) as remainingposts,off_order from
(
select fin_year,region_office_id,circle_office_id,division_office_id,offid2,office_id,postid,post_rank_id,sanctioned_no_of_posts,filledup_posts,diversion_to_other,
diversion_from_other,(sanctioned_no_of_posts-diversion_to_other+diversion_from_other) as total,
off_order from
(
select fin_year,region_office_id,circle_office_id,division_office_id,offid2,office_id,postid,post_rank_id, decode(sanctioned_no_of_posts,null,0,sanctioned_no_of_posts) as sanctioned_no_of_posts,
 decode(filledup_posts,null,0,filledup_posts) as filledup_posts,
 decode(diversion_to_other,null,0,diversion_to_other) as diversion_to_other,
 decode(diversion_from_other,null,0,diversion_from_other) as diversion_from_other,
 off_order from
 ( 
 select * from
(
select  office_id,post_rank_id,region_office_id,circle_office_id,division_office_id,off_order from HRM_SANCTION_STRENGTH_VIEW
where office_id is not null
union
select  office_id,post_rank_id,region_office_id,circle_office_id,division_office_id,off_order from hrm_sanction_filled_view
where office_id is not null
) aa
left outer join
(
select office_id as offid2, post_rank_id as postid,  filledup_posts
from HRM_SANCTION_FILLED_VIEW 
where office_id in (select office_id from com_mst_all_offices_view where 
circle_office_id in($P!{off_id})) and post_Rank_id in($P!{des_id})
) bb
on aa.office_id = bb.offid2 and aa.post_rank_id=bb.postid
left outer join
(
select fin_year, office_id as offid, post_rank_id as postrankid, 
 sanctioned_no_of_posts,diversion_to_other,
diversion_from_other
 from HRM_SANCTION_STRENGTH_VIEW
where office_id in (select office_id from com_mst_all_offices_view where 
circle_office_id in($P!{off_id})) and post_Rank_id in($P!{des_id}) and fin_year in($P{finyear})
)cc
on aa.office_id=cc.offid and aa.post_rank_id=cc.postrankid 
)
)
)
)aaa
where division_office_id in($P!{off_id}) 
and post_rank_id in($P!{des_id})
group by region_office_id,circle_office_id,division_office_id,post_rank_id
)bbb
left outer join
(
select office_id as offid3,office_name,office_level_id from com_mst_offices 
)ccc
on bbb.division_office_id=ccc.offid3
left outer join
(
select post_rank_id as psid,post_rank_name from hrm_mst_post_ranks 
)ddd
on bbb.post_rank_id=ddd.psid
left outer join
(
select office_id as offid4,off_order from com_mst_all_offices_view
)eee
on bbb.division_office_id=eee.offid4

union

select office_level_id,office_name,post_rank_name,region_office_id ,circle_office_id, division_office_id,to_char(office_id) as office_id,
post_rank_id,filledup_posts, sanctioned_no_of_posts,
 diversion_to_other,diversion_from_other,total,remainingposts,off_order  from
(
select fin_year,region_office_id,circle_office_id,division_office_id,offid2,office_id,postid,post_rank_id, sanctioned_no_of_posts,
 filledup_posts,diversion_to_other,
diversion_from_other,total,(total-filledup_posts) as remainingposts,off_order from
(
select fin_year,region_office_id,circle_office_id,division_office_id,offid2,office_id,postid,post_rank_id,sanctioned_no_of_posts,filledup_posts,diversion_to_other,
diversion_from_other,(sanctioned_no_of_posts-diversion_to_other+diversion_from_other) as total,
off_order from
(
select fin_year,region_office_id,circle_office_id,division_office_id,offid2,office_id,postid,post_rank_id, decode(sanctioned_no_of_posts,null,0,sanctioned_no_of_posts) as sanctioned_no_of_posts,
 decode(filledup_posts,null,0,filledup_posts) as filledup_posts,
 decode(diversion_to_other,null,0,diversion_to_other) as diversion_to_other,
 decode(diversion_from_other,null,0,diversion_from_other) as diversion_from_other,
 off_order from
 ( 
 select * from
(
select  office_id,post_rank_id,region_office_id,circle_office_id,division_office_id,off_order from HRM_SANCTION_STRENGTH_VIEW
where office_id is not null
union
select  office_id,post_rank_id,region_office_id,circle_office_id,division_office_id,off_order from hrm_sanction_filled_view
where office_id is not null
) aa
left outer join
(
select office_id as offid2, post_rank_id as postid,  filledup_posts
from HRM_SANCTION_FILLED_VIEW 

where office_id in ($P!{off_id}) and post_Rank_id in($P!{des_id})

) bb
on aa.office_id = bb.offid2 and aa.post_rank_id=bb.postid
left outer join
(
select fin_year, office_id as offid, post_rank_id as postrankid, 
 sanctioned_no_of_posts,diversion_to_other,
diversion_from_other from HRM_SANCTION_STRENGTH_VIEW
where office_id in ($P!{off_id}) and post_Rank_id in($P!{des_id}) and fin_year in($P{finyear})
)cc
on aa.office_id=cc.offid and aa.post_rank_id=cc.postrankid 
)
)
)

where office_id in ($P!{off_id}) and post_Rank_id in($P!{des_id}) 

)xyz
left outer join
(
select office_id as offid3, office_name,office_level_id from com_mst_offices
)xyz1
on xyz.office_id=xyz1.offid3
left outer join
(
select post_rank_id as psid,post_rank_name from hrm_mst_post_ranks 
)xyz2
on xyz.post_rank_id=xyz2.psid
where office_level_id not in('DN')
order by post_Rank_id,off_order,region_office_id,circle_office_id,division_office_id]]></queryString>

