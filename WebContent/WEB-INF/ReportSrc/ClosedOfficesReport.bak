	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select a.closed_office_id,a.date_closed,b.office_name,
decode(b.office_address1,null,' ',b.office_address1)office_address1,
decode(b.office_address2,null,' ',b.office_address2)office_address2,
decode(b.city_town_name,null,' ',b.city_town_name)city_town_name,
decode(c.district_name,null,' ',c.district_name)district_name,decode(b.office_pin_code,null,' ',0,' ',b.office_pin_code)office_pin_code,d.office_level_name from com_office_closure a,com_mst_offices b,com_mst_districts c,com_mst_office_levels d where a.closed_office_id=b.office_id and c.district_code=b.district_code and d.office_level_id=b.office_level_id and a.process_flow_status_id in ('FR') and b.office_status_id in ('NC','RD') and a.date_closed between $P{txtfrom} and $P{txtto}]]></queryString>

