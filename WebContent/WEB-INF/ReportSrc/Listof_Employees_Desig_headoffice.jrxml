<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Listof_Employees_Desig"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="desig" isForPrompting="true" class="java.lang.Integer"/>
	<queryString><![CDATA[select x.employee_id,employee_name,x.designation_date,x.designation_id,v.designation,x.joining_date,x.service_list_slno,
x.current_posting_date,x.office_id,y.office_name,x.employee_status_id,x.department_id,
z.employee_status_desc,years_completed
from
(
select a.employee_id,a.designation_date,a.designation_id,b.joining_date,b.service_list_slno,
c.current_posting_date,c.office_id,c.employee_status_id,c.department_id,
floor(months_between(now(),designation_date)/12) as years_completed  from
(
select employee_id,min(designation_date) as designation_date,designation_id from
(
select employee_id,min(date_from) as designation_date,designation_id from hrm_emp_service_data
where designation_id in ($P{desig})  and employee_id in (select employee_id from hrm_emp_current_posting
where designation_id in ($P{desig})) and employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
group by employee_id,designation_id
union
select employee_id,date_effective_from as designation_date,designation_id from hrm_emp_current_posting
where designation_id in ($P{desig}) and employee_status_id not in ('SAN','VRS','DTH','RES')
and employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
)
group by employee_id,designation_id
) a
left outer join
(
select employee_id as emp_id1,min(date_from) as joining_date,designation_id,service_list_slno from hrm_emp_service_data
where service_list_slno=1
group by employee_id,designation_id,service_list_slno
) b
on a.employee_id=b.emp_id1
left outer join
(
select employee_id as emp_id2,date_effective_from as current_posting_date,office_id,employee_status_id,
department_id
from hrm_emp_current_posting 
) c
on a.employee_id=c.emp_id2
where c.employee_status_id not in ('SAN','DTH','VRS','RES')
) x
left outer join
(
select office_id,office_name,'TWAD' as dept_id from com_mst_offices
where office_status_id not in ('CL','RD','NC') 
union
select other_dept_office_id as office_id,other_dept_office_name as office_name,
other_dept_id as dept_id from hrm_mst_other_dept_offices
) y
on x.office_id=y.office_id and x.department_id=y.dept_id
left outer join
(
select employee_status_id as emp_stat_id,employee_status_desc from hrm_mst_employee_status
) z
on x.employee_status_id=z.emp_stat_id
left outer join
(
select employee_id as emp_id3,employee_name || '.' || employee_initial as employee_name from hrm_mst_employees
) w
on x.employee_id=w.emp_id3
left outer join
(
select designation_id as desig_id,designation from hrm_mst_designations
) v
on x.designation_id=v.desig_id
order by current_posting_date,designation_date]]></queryString>

