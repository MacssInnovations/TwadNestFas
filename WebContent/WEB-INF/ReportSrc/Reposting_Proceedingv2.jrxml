<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Reposting_Proceedingv2"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="order" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="office" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="suffix" isForPrompting="true" class="java.lang.String"/>
	<parameter name="pwhole" isForPrompting="true" class="java.lang.String"/>
	<parameter name="copyto" isForPrompting="true" class="java.lang.String"/>
	<parameter name="proceed" isForPrompting="true" class="java.lang.String"/>
	<parameter name="address" isForPrompting="true" class="java.lang.String"/>
	<parameter name="no_date" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select a.REPOST_ISSUE_OFFICE_ID,d.rpt_office_name,a.REPOST_ORDER_ID,a.EMPLOYEE_ID,c.employee_name,
a.TO_WHICH_OFFICE_ID,e.new_office_name,a.REPOSTS_REQUIRED, g.curr_off_name,h.curr_desig_name,
a.TA_DA_ELIGIBLE,b.PROCEEDING_DATE,b.PROCEEDING_NO,
decode(CATEGORY_ORDER_ID,1,'Reposting',2,'Promotion',3,'Transfer') as reason,
b.PROCEED_SUBJECT,decode(b.PROCEED_SUBJECT,null,null,'Sub : ' || b.PROCEED_SUBJECT) as subj,
b.PROCEED_REFERENCE,decode(b.PROCEED_REFERENCE,null,null,'Ref : ' || b.PROCEED_REFERENCE) as ref,
b.ADDL_PARA_1,b.ADDL_PARA_2,b.COPY_TO,b.PRESIDING_OFFICER,
b.PRESIDING_OFFICER_DESIGNATION,b.signed,b.SUFFIX from
(
select REPOST_ISSUE_OFFICE_ID,REPOST_ORDER_ID,EMPLOYEE_ID,TO_WHICH_OFFICE_ID,REPOSTS_REQUIRED, 
PROCESS_FLOW_STATUS_ID,TA_DA_ELIGIBLE
from HRM_REPOST_DETAILS 
where PROCESS_FLOW_STATUS_ID in ('CR','MD')
) a
left outer join
(
select REPOST_ISSUE_OFFICE_ID as rpt_off_id,REPOST_ORDER_ID as rpt_ord_id,PROCEEDING_DATE,PROCEEDING_NO,
PROCEED_SUBJECT,PROCEED_REFERENCE,ADDL_PARA_1,ADDL_PARA_2,COPY_TO,PRESIDING_OFFICER,
PRESIDING_OFFICER_DESIGNATION,PROCESS_FLOW_STATUS_ID,SIGNED_PO as signed,SUFFIX,CATEGORY_ORDER_ID 
from HRM_REPOST_ORDERS 
where PROCESS_FLOW_STATUS_ID in ('CR','MD') 
) b
on a.REPOST_ISSUE_OFFICE_ID=b.rpt_off_id and a.REPOST_ORDER_ID=b.rpt_ord_id
left outer join 
( 
select employee_id as emp_id, employee_prefix || '.' || employee_name || '.' || employee_initial as employee_name from 
hrm_mst_employees
) c
on a.EMPLOYEE_ID=c.emp_id
left outer join 
( 
select office_id,office_name as rpt_office_name from com_mst_offices 
where office_status_id not in ('CL','RD','NC')
) d
on a.REPOST_ISSUE_OFFICE_ID=d.office_id
left outer join 
( 
select office_id,office_name as new_office_name from com_mst_offices 
where office_status_id not in ('CL','RD','NC')
) e
on a.TO_WHICH_OFFICE_ID=e.office_id
left outer join
( 
select employee_id as emp_id2, office_id as off_id2, designation_id as desig_id2 from hrm_emp_current_posting 
where employee_status_id in 'WKG' and process_flow_status_id in 'FR' 
) f
on a.EMPLOYEE_ID=f.emp_id2
left outer join
(
select office_id,office_name as curr_off_name from com_mst_offices
where office_status_id not in ('CL','RD','NC')
) g
on f.off_id2=g.office_id
left outer join
(
select designation_id, designation as curr_desig_name from hrm_mst_designations
) h
on f.desig_id2=h.designation_id
where a.REPOST_ISSUE_OFFICE_ID=$P{office} and a.REPOST_ORDER_ID=$P{order}]]></queryString>

