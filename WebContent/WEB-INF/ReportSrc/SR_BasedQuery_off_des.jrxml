	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offid" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="dest" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="fromdt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todt" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select a.EMPLOYEE_ID,b.EMPLOYEE_NAME||decode(b.EMPLOYEE_INITIAL,null,' ','.'||b.EMPLOYEE_INITIAL) EMPLOYEE_NAME,
c.DESIGNATION,d.OFFICE_NAME,a.DATE_FROM,a.DATE_FROM_SESSION,a.DATE_TO,a.DATE_TO_SESSION
from HRM_EMP_SERVICE_DATA a
inner join HRM_MST_EMPLOYEES  b on b.EMPLOYEE_ID=a.EMPLOYEE_ID 
inner join HRM_MST_DESIGNATIONS c on c.DESIGNATION_ID =A.DESIGNATION_ID
inner join COM_MST_OFFICES d on d.OFFICE_ID = a.OFFICE_ID
where a.OFFICE_ID=$P{offid} and a.DESIGNATION_ID=$P{dest} and a.employee_id in (select employee_id from hrm_mst_employees where is_consolidate='N')
and a.PROCESS_FLOW_STATUS_ID = 'FR'
and ( 
          (( $P{fromdt} between  a.DATE_FROM and  a.DATE_TO)
          or 
          ( $P{todt} between  a.DATE_FROM and  a.DATE_TO))
	or 
	(  (a.DATE_FROM between  $P{fromdt} and $P{todt}) and  (a.DATE_TO between  $P{fromdt} and $P{todt}) )
)

ORDER BY  a.EMPLOYEE_ID]]></queryString>

