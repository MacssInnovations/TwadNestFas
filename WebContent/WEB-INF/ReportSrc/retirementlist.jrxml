	<parameter name="txtfrom" isForPrompting="true" class="java.util.Date"/>
	<parameter name="txtto" isForPrompting="true" class="java.util.Date"/>
	<queryString><![CDATA[select a.employee_id,a.employee_name,
last_day(add_months(date_of_birth,720)) as retiredate,a.date_of_birth,b.designation,
c.office_level_id,c.office_name,c.office_address1,
c.office_address2,d.office_level_name  from HRM_MST_EMPLOYEES a,HRM_MST_DESIGNATIONS b,COM_MST_OFFICES c,
COM_MST_OFFICE_LEVELS d,HRM_EMP_CURRENT_POSTING e 
where a.employee_id=e.employee_id and e.designation_id=b.designation_id and c.office_id=e.office_id and 
c.office_level_id=d.office_level_id and (last_day(add_months(date_of_birth,720)) between  $P{txtfrom} and $P{txtto})]]></queryString>

