	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select * from
(
select * from
(
select a.division_office_name,a.DIVISION_OFFICE_ID,a.region_office_id,
a.circle_office_id as cir_id,upper(o.office_name) as region_office_name
   from COM_MST_DIVISIONS_HVIEW a ,COM_MST_REGIONS_HVIEW b,com_mst_offices o
  where a.region_office_id=b.region_office_id and a.region_office_id=o.office_id
 )z
left outer  join
 (
 select x.region_office_id as reg_id,x.circle_office_id,count(x.DIVISION_OFFICE_ID) as count
from COM_MST_DIVISIONS_HVIEW x

group by x.region_office_id,x.circle_office_id
  )z1
  on z.cir_id=z1.circle_office_id
  )z3
  left outer join
  (
  select p.division_office_id as div_id,p.circle_office_id,upper(q.office_name) as office_name from com_mst_offices q,COM_MST_DIVISIONS_HVIEW p
  where p.circle_office_id=q.office_id
  )z2
  on z3.division_office_id=z2.div_id
order by REG_ID,CIR_ID,DIVISION_OFFICE_ID]]></queryString>

