		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offids" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
select * from
(
select to_char(offid) as offid,'' as coffid,sravail,srvalid,curpostvalid,addl_valid,sr_data_valid,
office_id, office_name,'' as office_id1,'' as offname,to_char(controlling_office_id),PHOTO_VALID from
(
select  region_office_id as offid,
decode(sum(srcont_available),null,0,sum(srcont_available)) sravail ,
decode(sum(srcont_validated),null,0,sum(srcont_validated)) srvalid,
decode(sum(curpost_validated),null,0,sum(curpost_validated)) curpostvalid,
decode(sum(addl_validated),null,0,sum(addl_validated)) addl_valid,
decode(sum(sr_data_valid),null,0,sum(sr_data_valid)) sr_data_valid 
from hrm_emp_validation_view 
where office_id1<>5000 and region_office_id in($P!{offids}) 
group by region_office_id 
order By region_office_id
)a
left join 
(
select office_id, office_name from com_mst_offices 
)b
on a.offid=b.office_id
left outer join
(
select region_office_id as controlling_office_id,count(employee_id) as PHOTO_VALID  from hrm_rg_photo_view
group by region_office_id 
) j 
on j.controlling_office_id=a.offid
order by a.offid
)
union

select to_char(office_id) as offid,'' as coffid,sravail,srvalid,curpostvalid,addl_valid,sr_data_valid,
office_id, office_name,'' as office_id1,'' as offname,to_char(controlling_office_id),PHOTO_VALID 
from hrm_validation_ho_view where office_id in($P!{offids})

union

select to_char(offid) as offid,'' as coffid,sravail,srvalid,curpostvalid,addl_valid,sr_data_valid,
office_id, office_name,'' as office_id1,'' as offname,to_char(controlling_office_id),PHOTO_VALID from
(
select   region_office_id as offid,circle_office_id as coffid,
decode(sum(srcont_available),null,0,sum(srcont_available)) sravail ,
decode(sum(srcont_validated),null,0,sum(srcont_validated)) srvalid,
decode(sum(curpost_validated),null,0,sum(curpost_validated)) curpostvalid,
decode(sum(addl_validated),null,0,sum(addl_validated)) addl_valid,
decode(sum(sr_data_valid),null,0,sum(sr_data_valid)) sr_data_valid 
from hrm_emp_validation_view  
where  circle_office_id is not null  and circle_office_id in($P!{offids})  
group by  region_office_id,circle_office_id  order By 
region_office_id,circle_office_id
)a
left join 
(
select office_id, office_name from com_mst_offices 
)b
on a.coffid=b.office_id
left join
(
select office_id as office_id1,office_name as offname from com_mst_offices 
)c
on a.offid=c.office_id1
left outer join
(
select circle_office_id as controlling_office_id,count(employee_id) as PHOTO_VALID  from hrm_cr_photo_view
group by circle_office_id 
) j 
on j.controlling_office_id=b.office_id
)aa
left outer join
(
select office_id as officeid1,off_order from com_mst_all_offices_view 
)bb
on aa.office_id=bb.officeid1
order by off_order]]></queryString>

