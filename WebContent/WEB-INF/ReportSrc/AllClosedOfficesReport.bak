	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[select office_id,office_name,status_effective_from,office_level_name from
(
select office_id,office_name,status_effective_from,office_level_id  from com_mst_offices where office_status_id in ('CL','RD','NC') order by office_id desc
)a
left join
(
select office_level_id as olevelid,office_level_name  from com_mst_office_levels
)c
on a.office_level_id=c.olevelid]]></queryString>

	<field name="OFFICE_ID" class="java.math.BigDecimal"/>
	<field name="OFFICE_NAME" class="java.lang.String"/>
	<field name="STATUS_EFFECTIVE_FROM" class="java.sql.Timestamp"/>
