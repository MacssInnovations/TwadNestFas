	<parameter name="lab" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="labname" isForPrompting="true" class="java.lang.String"/>
	<parameter name="element_symbol" isForPrompting="true" class="java.lang.String"/>
	<parameter name="comparing_values" isForPrompting="true" class="java.lang.String"/>
	<parameter name="fromdt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="todt" isForPrompting="true" class="java.util.Date"/>
	<parameter name="ctype" isForPrompting="true" class="java.lang.String"/>
	<parameter name="district" isForPrompting="true" class="java.lang.String"/>
	<parameter name="districtname" isForPrompting="true" class="java.lang.String"/>
	<parameter name="block" isForPrompting="true" class="java.lang.String"/>
	<parameter name="blockname" isForPrompting="true" class="java.lang.String"/>
	<parameter name="panchayat" isForPrompting="true" class="java.lang.String"/>
	<parameter name="panchayatname" isForPrompting="true" class="java.lang.String"/>
	<parameter name="habitation" isForPrompting="true" class="java.lang.String"/>
	<parameter name="habitationname" isForPrompting="true" class="java.lang.String"/>
	<parameter name="location" isForPrompting="true" class="java.lang.String"/>
	<parameter name="location_type" isForPrompting="true" class="java.lang.String"/>
	<queryString><![CDATA[select * from
(
 select a.lab_code,a.invoice_number,sample_number,date_of_receipt,receipt_time,parameter,description,res from
 (
    select lab_code,invoice_number,sample_number,date_of_receipt,receipt_time,parameter,res from
    (
          select lab_code,invoice_number,sample_number,date_of_receipt,receipt_time,parameter,result,cast(result as float)as res from wqs_watersample_result
          where lab_code=$P{lab} and parameter in($P!{element_symbol})and result not in('Nil','None','nil','none') and date_of_receipt between $P{fromdt} and $P{todt}
    ) where res in(
		$P!{comparing_values}
                  )
 )a inner join
 (select lab_code,invoice_number,customer_type from wqs_invoice_details
 )b on a.lab_code=b.lab_code and a.invoice_number=b.invoice_number left outer join
 (select sno,element_symbol,description from wqs_element_symbol
 )b1 on a.parameter=b1.element_symbol inner join
 (select lab_code,invoice_number,sample_number,district_code,location_type,block_code,panchayat_code,habitation_code,location from wqs_sample_entry
 )c on a.lab_code=c.lab_code and a.invoice_number=c.invoice_number and a.sample_number=c.sample_number
  where b.customer_type=$P{ctype} and c.district_code=$P{district} and c.location_type=$P{location_type} and c.block_code=$P{block} and c.panchayat_code=$P{panchayat} and c.habitation_code=$P{habitation} and c.location=$P{location} order by sno
) order by invoice_number,sample_number,date_of_receipt]]></queryString>

