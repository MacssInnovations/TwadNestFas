<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="WQS_Location_SampleReport"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="594"
		 pageHeight="842"
		 columnWidth="534"
		 columnSpacing="0"
		 leftMargin="30"
